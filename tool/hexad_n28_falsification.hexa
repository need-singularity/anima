}

// D4 reused for apples-to-apples with the n=6 baseline run. Category
// theory is "closed by definition" — the axioms hold trivially — so
// this row is informational; it does NOT count toward the empirical
// H★ verdict.
fn dom_cattheory_n28() -> N28DomainMap {
    return N28DomainMap {
        name:            "D4_category_theory_n28",
        primary_d1:      "(Id functor)",
        primary_d2:      "(functor category [C,D])",
        primary_d4:      "(composition F.G)",
        primary_d7:      "(Yoneda embedding y)",
        secondary_d14:   "(object c in C)",
        secondary_d28:   "(representable Hom(-,c))",
        morph_primary_a: "(natural transformation eta)",
        morph_primary_b: "(unit of adjunction)",
        morph_secondary: "(Yoneda lemma)",
        tau_observed:    TAU_28
    }
}

// ── JSON emitters ───────────────────────────────────────────────────────────

fn matrix_row_json(m: AxiomMatrix) -> string {
    let mut s = "{"
    s = s + "\"domain\":\"" + m.domain + "\""
    s = s + ",\"a_non_empty\":" + bool_s(m.a)
    s = s + ",\"b_morphism\":" + bool_s(m.b)
    s = s + ",\"c_composition\":" + bool_s(m.c)
    s = s + ",\"d_phantom_absent\":" + bool_s(m.d)
    s = s + ",\"p_primary_quartet\":" + bool_s(m.p)
    s = s + ",\"s_secondary_pair\":" + bool_s(m.s)
    s = s + ",\"n_pass\":" + str(m.n_pass)
    s = s + ",\"tau_match_4\":" + bool_s(m.tau_ok)
    s = s + ",\"primary_count_obs\":" + str(m.primary_count)
    s = s + "}"
    return s
}

fn dm_json(dm: N28DomainMap) -> string {
    let mut s = "{"
    s = s + "\"name\":\"" + dm.name + "\""
    s = s + ",\"tau_observed\":" + str(dm.tau_observed)
    s = s + ",\"primary_d1\":\"" + dm.primary_d1 + "\""
    s = s + ",\"primary_d2\":\"" + dm.primary_d2 + "\""
    s = s + ",\"primary_d4\":\"" + dm.primary_d4 + "\""
    s = s + ",\"primary_d7\":\"" + dm.primary_d7 + "\""
    s = s + ",\"secondary_d14\":\"" + dm.secondary_d14 + "\""
    s = s + ",\"secondary_d28\":\"" + dm.secondary_d28 + "\""
    s = s + ",\"morph_primary_a\":\"" + dm.morph_primary_a + "\""
    s = s + ",\"morph_primary_b\":\"" + dm.morph_primary_b + "\""
    s = s + ",\"morph_secondary\":\"" + dm.morph_secondary + "\""
    s = s + "}"
    return s
}

// ── verdict resolvers ───────────────────────────────────────────────────────

fn resolve_universality(score_x1000: int) -> string {
    if score_x1000 >= 750 { return "HEXAD_UNIVERSAL" }
    if score_x1000 >= 500 { return "HEXAD_CONDITIONAL" }
    return "HEXAD_CELL_SPECIFIC"
}

// H★ support rules (pre-registered, raw#12):
//   primary_pass_count = 0  → H_STAR_STRONGLY_SUPPORTED
//   primary_pass_count = 1  → H_STAR_WEAKLY_SUPPORTED
//   primary_pass_count = 2  → H_STAR_INCONCLUSIVE  (further exp needed)
//   primary_pass_count ≥ 3  → H_STAR_REFUTED       (τ(6)=4 primitivity denied)
fn resolve_h_star(primary_pass_count: int) -> string {
    if primary_pass_count == 0 { return "H_STAR_STRONGLY_SUPPORTED" }
    if primary_pass_count == 1 { return "H_STAR_WEAKLY_SUPPORTED" }
    if primary_pass_count == 2 { return "H_STAR_INCONCLUSIVE" }
    return "H_STAR_REFUTED"
}

// SAME_STRUCTURE iff ≥2 empirical domains pass primary-quartet.
// Under n=28 this is predicted to be false uniformly.
fn universal4_relation(primary_pass_count: int) -> string {
    if primary_pass_count >= 2 { return "SAME_STRUCTURE" }
    return "INDEPENDENT_4"
}

// ── main ────────────────────────────────────────────────────────────────────

fn main() {
    println("[hexad_n28_falsification] EXP-1: H★ τ(6)=4 primitivity falsification")
    println("  target n      = " + str(N_TARGET))
    println("  baseline n    = " + str(N_BASELINE))
    println("")

    // Compute divisor signatures for record.
    let divs_6  = divisors_of(N_BASELINE)
    let divs_28 = divisors_of(N_TARGET)
    let sigma_6_obs  = sum_list_int(divs_6)
    let sigma_28_obs = sum_list_int(divs_28)
    let sigma_phi_6  = sigma_6_obs * PHI_6
    let n_tau_6      = N_BASELINE * TAU_6
    let sigma_phi_28 = sigma_28_obs * PHI_28
    let n_tau_28     = N_TARGET * TAU_28
    let eq_6_holds   = sigma_phi_6 == n_tau_6
    let eq_28_holds  = sigma_phi_28 == n_tau_28

    println("=== Number-theoretic signature ===")
    println("  n=6 : divisors " + int_list_json(divs_6)  + "  τ=" + str(TAU_6)
          + "  σ=" + str(sigma_6_obs) + "  φ=" + str(PHI_6))
    println("         σ·φ = " + str(sigma_phi_6) + "   n·τ = " + str(n_tau_6)
          + "   equality=" + bool_s(eq_6_holds))
    println("  n=28: divisors " + int_list_json(divs_28) + "  τ=" + str(TAU_28)
          + "  σ=" + str(sigma_28_obs) + "  φ=" + str(PHI_28))
    println("         σ·φ = " + str(sigma_phi_28) + "   n·τ = " + str(n_tau_28)
          + "   equality=" + bool_s(eq_28_holds))
    println("")

    // Evaluate matrix.
    let maps = [
        dom_cell_baseline_n28(),
        dom_lora_n28(),
        dom_n6_n28(),
        dom_iit_n28(),
        dom_cattheory_n28()
    ]

    let mut matrix = []
    let mut total_pass = 0
    let mut total_cells = 0
    let mut primary_pass_count = 0

    let mut i = 0
    while i < len(maps) {
        let dm = maps[i]
        let row = eval_n28_domain(dm)
        matrix = matrix.push(row)
        total_pass = total_pass + row.n_pass
        total_cells = total_cells + 6
        // Only D0..D3 are empirical; D4 is closed-by-definition.
        if i < 4 {
            if row.p { primary_pass_count = primary_pass_count + 1 }
        }
        i = i + 1
    }

    let score_x1000 = (total_pass * 1000) / total_cells

    // Empirical-only (exclude D4 definitional).
    let mut emp_pass = 0
    let mut emp_cells = 0
    let mut k = 0
    while k < 4 {
        emp_pass = emp_pass + matrix[k].n_pass
        emp_cells = emp_cells + 6
        k = k + 1
    }
    let emp_score_x1000 = (emp_pass * 1000) / emp_cells

    let verdict_full = resolve_universality(score_x1000)
    let verdict_emp  = resolve_universality(emp_score_x1000)
    let u4_rel       = universal4_relation(primary_pass_count)
    let h_star       = resolve_h_star(primary_pass_count)

    // ── stdout matrix ───────────────────────────────────────────────────────
    println("=== Domain × Axiom matrix (n=28 frame; 5 domains × 6 axioms) ===")
    println("  domain                              a  b  c  d  p  s  n/6  tau=4?  n_prim")
    let mut r = 0
    while r < len(matrix) {
        let m = matrix[r]
        let line = "  " + m.domain
            + "   " + bool_s(m.a)
            + " "  + bool_s(m.b)
            + " "  + bool_s(m.c)
            + " "  + bool_s(m.d)
            + " "  + bool_s(m.p)
            + " "  + bool_s(m.s)
            + "   " + str(m.n_pass)
            + "    " + bool_s(m.tau_ok)
            + "    " + str(m.primary_count)
        println(line)
        r = r + 1
    }
    println("")
    println("=== n=6 baseline vs n=28 Δ ===")
    println("  baseline (n=6) score_empirical_x1000 = 1000 (from " + BASELINE_PATH + ")")
    println("  n=28     score_full_x1000            = " + str(score_x1000))
    println("  n=28     score_empirical_x1000       = " + str(emp_score_x1000))
    println("  Δ_empirical_x1000                    = " + str(1000 - emp_score_x1000))
    println("")
    println("  primary_pass_count (empirical D0..D3) = " + str(primary_pass_count))
    println("  UNIVERSAL_4 relation                  = " + u4_rel)
    println("  H★ support verdict                    = " + h_star)
    println("  σ·φ = n·τ at n=6 ?                    = " + bool_s(eq_6_holds))
    println("  σ·φ = n·τ at n=28?                    = " + bool_s(eq_28_holds))
    println("")

    // ── JSON emit ───────────────────────────────────────────────────────────
    let mut out = "{\n"
    out = out + "  \"verifier_type\": \"hexad_n28_falsification\",\n"
    out = out + "  \"version\": \"v1\",\n"
    out = out + "  \"experiment_id\": \"EXP-1\",\n"
    out = out + "  \"generated\": \"" + now_stamp() + "\",\n"
    out = out + "  \"source\": \"tool/hexad_n28_falsification.hexa\",\n"
    out = out + "  \"baseline_verdict_path\": \"" + BASELINE_PATH + "\",\n"
    out = out + "  \"note\": \"H★ pre-registered: primary_pass_count=0 → H★ strongly supported (τ(6)=4 primitivity)\",\n"
    out = out + "  \"axioms\": " + str_list_json(AXIOM_KEYS) + ",\n"
    out = out + "  \"parameters\": {\n"
    out = out + "    \"n_target\": " + str(N_TARGET) + ",\n"
    out = out + "    \"n_baseline\": " + str(N_BASELINE) + ",\n"
    out = out + "    \"tau_28\": " + str(TAU_28) + ",\n"
    out = out + "    \"sigma_28\": " + str(SIGMA_28) + ",\n"
    out = out + "    \"phi_28\": " + str(PHI_28) + ",\n"
    out = out + "    \"tau_6\": " + str(TAU_6) + ",\n"
    out = out + "    \"sigma_6\": " + str(SIGMA_6) + ",\n"
    out = out + "    \"phi_6\": " + str(PHI_6) + ",\n"
    out = out + "    \"primary_quartet_required\": " + str(PRIMARY_QUARTET_REQUIRED) + "\n"
    out = out + "  },\n"
    out = out + "  \"divisor_signature\": {\n"
    out = out + "    \"divisors_6\": " + int_list_json(divs_6) + ",\n"
    out = out + "    \"divisors_28\": " + int_list_json(divs_28) + ",\n"
    out = out + "    \"sigma_phi_6\": " + str(sigma_phi_6) + ",\n"
    out = out + "    \"n_tau_6\": " + str(n_tau_6) + ",\n"
    out = out + "    \"sigma_phi_equals_n_tau_at_6\": " + bool_s(eq_6_holds) + ",\n"
    out = out + "    \"sigma_phi_28\": " + str(sigma_phi_28) + ",\n"
    out = out + "    \"n_tau_28\": " + str(n_tau_28) + ",\n"
    out = out + "    \"sigma_phi_equals_n_tau_at_28\": " + bool_s(eq_28_holds) + "\n"
    out = out + "  },\n"
    out = out + "  \"scoring\": {\n"
    out = out + "    \"total_pass\": " + str(total_pass) + ",\n"
    out = out + "    \"total_cells\": " + str(total_cells) + ",\n"
    out = out + "    \"score_x1000_full\": " + str(score_x1000) + ",\n"
    out = out + "    \"score_x1000_empirical\": " + str(emp_score_x1000) + ",\n"
    out = out + "    \"primary_pass_count_empirical\": " + str(primary_pass_count) + "\n"
    out = out + "  },\n"
    out = out + "  \"verdict_full\": \"" + verdict_full + "\",\n"
    out = out + "  \"verdict_empirical\": \"" + verdict_emp + "\",\n"
    out = out + "  \"universal4_relation\": \"" + u4_rel + "\",\n"
    out = out + "  \"h_star_verdict\": \"" + h_star + "\",\n"
    out = out + "  \"delta_vs_n6_empirical_x1000\": " + str(1000 - emp_score_x1000) + ",\n"

    out = out + "  \"domain_maps\": [\n"
    let mut a = 0
    while a < len(maps) {
        if a > 0 { out = out + ",\n" }
        out = out + "    " + dm_json(maps[a])
        a = a + 1
    }
    out = out + "\n  ],\n"

    out = out + "  \"matrix\": [\n"
    let mut b = 0
    while b < len(matrix) {
        if b > 0 { out = out + ",\n" }
        out = out + "    " + matrix_row_json(matrix[b])
        b = b + 1
    }
    out = out + "\n  ]\n"
    out = out + "}\n"

    write_file(OUT_PATH, out)
    println("  wrote: " + OUT_PATH)

    // Exit code encodes H★ result.
    if h_star == "H_STAR_STRONGLY_SUPPORTED" { exit(0) }
    if h_star == "H_STAR_WEAKLY_SUPPORTED"   { exit(1) }
    if h_star == "H_STAR_INCONCLUSIVE"       { exit(2) }
    exit(3)
}

main()
