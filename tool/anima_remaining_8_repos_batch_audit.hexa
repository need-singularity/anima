// tool/anima_remaining_8_repos_batch_audit.hexa — remaining 8 ws repos batch audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 36 13-new-discovered repos: cycles 37-41 audited 5; remaining 8 (mostly small/peripheral).
//   Single batch helper instead of 8 separate cycles — efficiency for marginal-value repos.
//
//   본 helper = mac-local NON_MUTATION:
//     - 8 repos (hexa-os, _github-org, contact, gohive.sh, pi-telegram, pixie, secret, skynet-timer)
//     - 각각 file type counts + git HEAD + size summary
//     - selftest verifies: 8 entries / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/remaining_8_repos_batch_audit.json)
//   ANIMA_WS          workspace (default: /Users/ghost/core)
//
// OUTPUT
//   - repos: list of {name, present, hexa, md, py, total_size_kb, head_commit}
//   - characterization_per_repo
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_remaining_8_repos_batch_audit.hexa --selftest
//   ANIMA_OUTPUT=state/remaining_8_repos_batch_audit.json hexa run tool/anima_remaining_8_repos_batch_audit.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - 일부는 git repo 아닐 수 있음 (gohive.sh는 dir 형태이지만 .git 부재 가능).
//   - file count는 max_depth 2 (peripheral repos는 보통 shallow).
//   - 8 repos batch는 cycles 37-41 deep-audit 패턴 대비 brevity 우선.

let HELPER_PATH = "/tmp/anima_remaining_8_repos_batch_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima remaining 8 ws repos batch audit — emitted by tool/anima_remaining_8_repos_batch_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION batch audit.\n")
    parts.push("import json, os, sys, subprocess\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/remaining_8_repos_batch_audit.json')\n")
    parts.push("WS = os.environ.get('ANIMA_WS', '/Users/ghost/core')\n\n")

    parts.push("REMAINING = ['hexa-os', '_github-org', 'contact', 'gohive.sh', 'pi-telegram', 'pixie', 'secret', 'skynet-timer']\n\n")

    parts.push("def _count(path, ext, max_depth=2):\n")
    parts.push("    base_depth = path.rstrip('/').count('/')\n")
    parts.push("    count = 0\n")
    parts.push("    for root, dirs, files in os.walk(path):\n")
    parts.push("        depth = root.count('/') - base_depth\n")
    parts.push("        if depth > max_depth:\n")
    parts.push("            dirs.clear(); continue\n")
    parts.push("        dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__', 'build', 'dist')]\n")
    parts.push("        for f in files:\n")
    parts.push("            if f.endswith(ext): count += 1\n")
    parts.push("    return count\n\n")

    parts.push("def _total_size(path, max_files=2000):\n")
    parts.push("    total = 0\n")
    parts.push("    seen = 0\n")
    parts.push("    for root, dirs, files in os.walk(path):\n")
    parts.push("        dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__', 'build', 'dist')]\n")
    parts.push("        for f in files:\n")
    parts.push("            try:\n")
    parts.push("                total += os.path.getsize(os.path.join(root, f))\n")
    parts.push("                seen += 1\n")
    parts.push("                if seen >= max_files: return total\n")
    parts.push("            except Exception: continue\n")
    parts.push("    return total\n\n")

    parts.push("def _git_head(path):\n")
    parts.push("    if not os.path.isdir(os.path.join(path, '.git')): return None\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['git', 'rev-parse', 'HEAD'], cwd=path, capture_output=True, text=True, timeout=5)\n")
    parts.push("        if r.returncode == 0: return r.stdout.strip()[:8]\n")
    parts.push("    except Exception: pass\n")
    parts.push("    return None\n\n")

    parts.push("audit = []\n")
    parts.push("for name in REMAINING:\n")
    parts.push("    p = os.path.join(WS, name)\n")
    parts.push("    if not os.path.isdir(p):\n")
    parts.push("        audit.append({'name':name, 'present':False})\n")
    parts.push("        continue\n")
    parts.push("    audit.append({\n")
    parts.push("        'name':name,\n")
    parts.push("        'present':True,\n")
    parts.push("        'is_git':os.path.isdir(os.path.join(p, '.git')),\n")
    parts.push("        'hexa':_count(p, '.hexa'),\n")
    parts.push("        'md':_count(p, '.md'),\n")
    parts.push("        'py':_count(p, '.py'),\n")
    parts.push("        'js':_count(p, '.js'),\n")
    parts.push("        'ts':_count(p, '.ts'),\n")
    parts.push("        'sh':_count(p, '.sh'),\n")
    parts.push("        'total_size_kb':round(_total_size(p) / 1024, 1),\n")
    parts.push("        'head_commit':_git_head(p),\n")
    parts.push("        'has_readme':os.path.exists(os.path.join(p, 'README.md')),\n")
    parts.push("    })\n\n")

    parts.push("# Aggregate\n")
    parts.push("present_count = sum(1 for a in audit if a.get('present'))\n")
    parts.push("git_repo_count = sum(1 for a in audit if a.get('is_git'))\n")
    parts.push("total_hexa = sum(a.get('hexa', 0) for a in audit if a.get('present'))\n")
    parts.push("total_md = sum(a.get('md', 0) for a in audit if a.get('present'))\n")
    parts.push("total_py = sum(a.get('py', 0) for a in audit if a.get('present'))\n")
    parts.push("with_readme = sum(1 for a in audit if a.get('has_readme'))\n")
    parts.push("largest_repo = max((a for a in audit if a.get('present')), key=lambda x: x.get('total_size_kb', 0), default=None)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'remaining 8 ws repos batch audit (cycles 37-41 deep-audit chain peripheral)',\n")
    parts.push("    'workspace':WS,\n")
    parts.push("    'repos':audit,\n")
    parts.push("    'present_count':present_count,\n")
    parts.push("    'git_repo_count':git_repo_count,\n")
    parts.push("    'aggregate_metrics':{\n")
    parts.push("        'total_hexa':total_hexa,\n")
    parts.push("        'total_md':total_md,\n")
    parts.push("        'total_py':total_py,\n")
    parts.push("        'with_readme':with_readme,\n")
    parts.push("    },\n")
    parts.push("    'largest_remaining':largest_repo['name'] if largest_repo else None,\n")
    parts.push("    'note':'these 8 repos are peripheral compared to nexus/n6/hive/papers/void (cycles 37-41 deep-audited)',\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify any repo; read-only batch audit',\n")
    parts.push("    'cross_link_cycles':['cycle 36 ws full inventory (these 8 in unaudited list)','cycle 42 ecosystem capstone (unaudited_remaining list mirror)'],\n")
    parts.push("    'pattern':'governance audit chain layer 23 (cycles 21-42 + this) — completes WS audit coverage',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[remaining_8] present={present_count}/8 git_repos={git_repo_count} total_hexa={total_hexa} total_md={total_md} total_py={total_py} with_readme={with_readme} largest={largest_repo[\"name\"] if largest_repo else None} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let remaining_count = 8
    let remaining_list = "hexa-os,_github-org,contact,gohive.sh,pi-telegram,pixie,secret,skynet-timer"
    let non_mutation = "READ_ONLY"
    println("inv:remaining_count=" + to_string(remaining_count))
    println("inv:remaining_list=" + remaining_list)
    println("inv:non_mutation=" + non_mutation)
    println("inv:max_depth_2=true (peripheral repos shallow)")
    println("inv:cross_link_cycle36_cycle42=true")
    return true
}

fn cmd_selftest() {
    println("── anima_remaining_8_repos_batch_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=remaining 8 ws repos batch audit (peripheral / completes WS audit coverage; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
