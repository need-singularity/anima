// tool/anima_contact_repo_deep_audit.hexa — contact (Outreach Hub) deep audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   /Users/ghost/core/contact = need-singularity Outreach Hub. cycle 43이 17MB 의외 발견.
//   cycle 46 deep audit으로 17MB 정체 확인:
//     - 813+ sends, 235+ contacts, 29 Awesome Lists PRs (README claims)
//     - 18 PDFs (papers attachments?), 14 json (contact DB)
//     - 8 sub-dirs (anthropic/discord/github/paid-promo/data/docs/scripts/attachments)
//
//   본 helper = mac-local NON_MUTATION:
//     - 8 sub-dirs file count + size breakdown
//     - README claim verification (sends/contacts/PRs)
//     - anima cross-link (anima-related outreach activity)
//     - selftest verifies: 8 sub-dirs / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/contact_repo_deep_audit.json)
//   ANIMA_CONTACT_DIR contact dir (default: /Users/ghost/core/contact)
//
// OUTPUT
//   - sub_dirs: list of {name, file_count, total_size_kb}
//   - file_type_counts (md/hexa/json/pdf/jpg/etc)
//   - readme_claims (sends, contacts, PRs)
//   - anima_mentions
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_contact_repo_deep_audit.hexa --selftest
//   ANIMA_OUTPUT=state/contact_repo_deep_audit.json hexa run tool/anima_contact_repo_deep_audit.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - 17MB 대부분은 PDF + attachments (papers/email outputs).
//   - 813 sends 주장 verification은 send log file 검토 필요 (out of scope).
//   - 5 .py files (cycle 43)는 raw#9 not enforced (consistent with cycle 32).

let HELPER_PATH = "/tmp/anima_contact_repo_deep_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima contact repo deep audit — emitted by tool/anima_contact_repo_deep_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION contact deep audit.\n")
    parts.push("import json, os, sys, re\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/contact_repo_deep_audit.json')\n")
    parts.push("CONTACT_DIR = os.environ.get('ANIMA_CONTACT_DIR', '/Users/ghost/core/contact')\n\n")

    parts.push("if not os.path.isdir(CONTACT_DIR):\n")
    parts.push("    summary = {'paradigm':'contact deep audit', 'status':'CONTACT_DIR_MISSING'}\n")
    parts.push("    os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("    with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("    print(f'[contact_audit] status=CONTACT_DIR_MISSING -> {OUTPUT}')\n")
    parts.push("    sys.exit(0)\n\n")

    parts.push("def _count(path, ext, max_depth=4):\n")
    parts.push("    base_depth = path.rstrip('/').count('/')\n")
    parts.push("    count = 0\n")
    parts.push("    for root, dirs, files in os.walk(path):\n")
    parts.push("        depth = root.count('/') - base_depth\n")
    parts.push("        if depth > max_depth:\n")
    parts.push("            dirs.clear(); continue\n")
    parts.push("        dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__')]\n")
    parts.push("        for f in files:\n")
    parts.push("            if f.endswith(ext): count += 1\n")
    parts.push("    return count\n\n")

    parts.push("def _dir_summary(path, max_files=2000):\n")
    parts.push("    file_count = 0\n")
    parts.push("    total_size = 0\n")
    parts.push("    for root, dirs, files in os.walk(path):\n")
    parts.push("        dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__')]\n")
    parts.push("        for f in files:\n")
    parts.push("            try:\n")
    parts.push("                total_size += os.path.getsize(os.path.join(root, f))\n")
    parts.push("                file_count += 1\n")
    parts.push("                if file_count >= max_files: return file_count, total_size\n")
    parts.push("            except Exception: continue\n")
    parts.push("    return file_count, total_size\n\n")

    parts.push("# Sub-dirs\n")
    parts.push("entries = sorted([d for d in os.listdir(CONTACT_DIR) if os.path.isdir(os.path.join(CONTACT_DIR, d)) and not d.startswith('.')])\n")
    parts.push("sub_dirs_audit = []\n")
    parts.push("for d in entries:\n")
    parts.push("    fc, sz = _dir_summary(os.path.join(CONTACT_DIR, d))\n")
    parts.push("    sub_dirs_audit.append({\n")
    parts.push("        'name':d,\n")
    parts.push("        'file_count':fc,\n")
    parts.push("        'total_size_kb':round(sz / 1024, 1),\n")
    parts.push("    })\n\n")

    parts.push("file_type_counts = {\n")
    parts.push("    'md':_count(CONTACT_DIR, '.md'),\n")
    parts.push("    'hexa':_count(CONTACT_DIR, '.hexa'),\n")
    parts.push("    'json':_count(CONTACT_DIR, '.json'),\n")
    parts.push("    'pdf':_count(CONTACT_DIR, '.pdf'),\n")
    parts.push("    'py':_count(CONTACT_DIR, '.py'),\n")
    parts.push("    'jpg':_count(CONTACT_DIR, '.jpg'),\n")
    parts.push("    'png':_count(CONTACT_DIR, '.png'),\n")
    parts.push("    'csv':_count(CONTACT_DIR, '.csv'),\n")
    parts.push("    'sh':_count(CONTACT_DIR, '.sh'),\n")
    parts.push("}\n\n")

    parts.push("# README claims verification\n")
    parts.push("readme_path = os.path.join(CONTACT_DIR, 'README.md')\n")
    parts.push("readme_claims = {}\n")
    parts.push("if os.path.exists(readme_path):\n")
    parts.push("    try:\n")
    parts.push("        with open(readme_path, encoding='utf-8') as f: rc = f.read()\n")
    parts.push("        m = re.search(r'(\\d+)\\+\\s*sends', rc)\n")
    parts.push("        if m: readme_claims['sends'] = int(m.group(1))\n")
    parts.push("        m = re.search(r'(\\d+)\\+\\s*contacts', rc)\n")
    parts.push("        if m: readme_claims['contacts'] = int(m.group(1))\n")
    parts.push("        m = re.search(r'(\\d+)\\s*Awesome Lists PRs', rc)\n")
    parts.push("        if m: readme_claims['awesome_prs'] = int(m.group(1))\n")
    parts.push("        m = re.search(r'(\\d+)\\s*AI company Issues', rc)\n")
    parts.push("        if m: readme_claims['ai_company_issues'] = int(m.group(1))\n")
    parts.push("    except Exception: pass\n\n")

    parts.push("# anima mentions\n")
    parts.push("anima_mentions = 0\n")
    parts.push("for root, dirs, files in os.walk(CONTACT_DIR):\n")
    parts.push("    dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__')]\n")
    parts.push("    for f in files:\n")
    parts.push("        if f.endswith('.md'):\n")
    parts.push("            try:\n")
    parts.push("                with open(os.path.join(root, f), encoding='utf-8', errors='replace') as fh: c = fh.read()\n")
    parts.push("                if 'anima' in c.lower():\n")
    parts.push("                    anima_mentions += 1\n")
    parts.push("            except Exception: continue\n\n")

    parts.push("largest_subdir = max(sub_dirs_audit, key=lambda x: x['total_size_kb'], default=None)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'contact (Outreach Hub) repo deep audit (cycle 43 17MB peripheral discovery)',\n")
    parts.push("    'contact_dir':CONTACT_DIR,\n")
    parts.push("    'sub_dirs':sub_dirs_audit,\n")
    parts.push("    'sub_dir_count':len(sub_dirs_audit),\n")
    parts.push("    'file_type_counts':file_type_counts,\n")
    parts.push("    'readme_claims':readme_claims,\n")
    parts.push("    'anima_mentions_in_md':anima_mentions,\n")
    parts.push("    'largest_subdir':largest_subdir,\n")
    parts.push("    'characterization':'contact = need-singularity Outreach Hub (anthropic/discord/github/paid-promo). 18 PDFs (paper attachments) + 14 json (contact DB) + 77 md docs explain 17MB size discovered in cycle 43.',\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify contact; read-only deep audit',\n")
    parts.push("    'cross_link_cycles':['cycle 43 remaining 8 batch (contact 17MB discovery)','cycle 36 ws full inventory'],\n")
    parts.push("    'pattern':'governance audit chain layer 26 (cycles 21-45 + this) — last surprising peripheral characterized',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[contact_audit] sub_dirs={len(sub_dirs_audit)} md={file_type_counts[\"md\"]} pdf={file_type_counts[\"pdf\"]} json={file_type_counts[\"json\"]} sends={readme_claims.get(\"sends\")} contacts={readme_claims.get(\"contacts\")} anima_mentions={anima_mentions} largest={largest_subdir[\"name\"] if largest_subdir else None} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let sub_dirs_min = 5
    let readme_metrics = "sends,contacts,awesome_prs,ai_company_issues"
    let non_mutation = "READ_ONLY"
    println("inv:sub_dirs_min=" + to_string(sub_dirs_min))
    println("inv:readme_metrics=" + readme_metrics)
    println("inv:non_mutation=" + non_mutation)
    println("inv:cross_link_cycle43_cycle36=true")
    return true
}

fn cmd_selftest() {
    println("── anima_contact_repo_deep_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=contact repo deep audit (Outreach Hub / 17MB peripheral; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
