// ════════════════════════════════════════════════════════════════════════════
//  tool/phase_progression_controller.hexa — 3-stage OS-level progression
//
//  PURPOSE
//    Orchestrates the user's mandated progression rule:
//      Stage 1 (check)  100% — true_closure + integrity + closure_debt
//      Stage 2 (plan)   100% — next-phase required entries fully planned
//      Stage 3 (live)        — daemon-tick auto-adjust within spec bounds
//
//    Each stage is a hard gate; forward progression is blocked by any FAIL.
//    All sub-tools are dispatched via `hexa run`, strictly sequential. The
//    controller never mutates sub-tools; it only composes them.
//
//  USAGE
//    hexa tool/phase_progression_controller.hexa --help
//    hexa tool/phase_progression_controller.hexa --stage check
//    hexa tool/phase_progression_controller.hexa --stage plan  --phase 1
//    hexa tool/phase_progression_controller.hexa --stage live
//    hexa tool/phase_progression_controller.hexa --stage all   --phase 1
//
//  CONFIG (raw#15)
//    shared/config/phase_progression_config.json
//
//  OUTPUT (raw#10 proof-carrying)
//    state/phase_progression_cert.json     structured cert
//    .raw-audit/phase_progression.log             hash-chain append line
//
//  EXIT CODES
//    0   stage cleared cleanly
//    1   stage FAIL — next stage blocked
//    2   config / setup error
//
//  CONSTRAINTS
//    raw#1  chflags state untouched by controller (sub-tools may toggle)
//    raw#9  hexa-only
//    raw#10 hash-chain append on every stage transition
//    raw#11 snake_case
//    raw#12 실측 only — stage verdict derived from sub-tool SSOT
//    raw#15 no-hardcode (all tool paths / thresholds in config JSON)
// ════════════════════════════════════════════════════════════════════════════

use "airgenome_cli_probe"

let CONFIG_PATH_DEFAULT = "config/phase_progression_config.json"
let HEXA_BIN_DEFAULT    = "/Users/ghost/.hx/bin/hexa"
let WITH_UNLOCK_TOOL    = "/Users/ghost/core/hexa-lang/tool/roadmap_with_unlock.hexa"

// ─── type / helpers ───────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _bool_s(b: bool) -> string { return if b { "true" } else { "false" } }

// INLINE_DEPRECATED[H42]: see shared/util/sh_quote.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _sh_quote(s: string) -> string {
    let mut out = "'"
    out = out + s.replace("'", "'\\''")
    out = out + "'"
    return out
}

fn _exec_out(cmd: string) -> string {
    let r = exec_with_status(cmd)
    return to_string(r[0])
}

fn _exec_code(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

// INLINE_DEPRECATED[H42]: see shared/util/ts_iso.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _ts_iso() -> string {
    return _exec_out("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _ts_epoch() -> string {
    return _exec_out("date -u +%s").trim()
}

// INLINE_DEPRECATED[H42]: see shared/util/file_exists.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _file_exists(path: string) -> bool {
    return _exec_code("test -f " + _sh_quote(path)) == 0
}

fn _dir_exists(path: string) -> bool {
    return _exec_code("test -d " + _sh_quote(path)) == 0
}

fn _mkdir_p(dir: string) -> bool {
    return _exec_code("mkdir -p " + _sh_quote(dir)) == 0
}

fn _sha256_str(s: string) -> string {
    let cmd = "printf %s " + _sh_quote(s) + " | shasum -a 256 | awk '{print $1}'"
    return _exec_out(cmd).trim()
}

fn _sha256_file(path: string) -> string {
    if !_file_exists(path) { return "" }
    return _exec_out("shasum -a 256 " + _sh_quote(path) + " | awk '{print $1}'").trim()
}

// INLINE_DEPRECATED[H42]: see shared/util/json_escape.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
}

fn _is_map(v) -> bool {
    let s = str(v)
    if s.len() < 1 { return false }
    return s.substring(0, 1) == "{"
}

// ─── argv helpers ──────────────────────────────────────────────────────

fn _argv() -> array {
    return args()
}

fn _arg_value(argv, key: string, dflt: string) -> string {
    let mut i = 0
    while i < len(argv) {
        if _str(argv[i]) == key && i + 1 < len(argv) { return _str(argv[i + 1]) }
        i = i + 1
    }
    return dflt
}

fn _arg_present(argv, key: string) -> bool {
    let mut i = 0
    while i < len(argv) {
        if _str(argv[i]) == key { return true }
        i = i + 1
    }
    return false
}

// ─── config load ──────────────────────────────────────────────────────

fn _resolve_root() -> string {
    let gt = _exec_out("git rev-parse --show-toplevel 2>/dev/null").trim()
    if gt != "" { return gt }
    let e = _str(env("ANIMA"))
    if e != "" { return e }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn _resolve_hexa_bin(cfg) -> string {
    let e = _str(env("HEXA_BIN"))
    if e != "" { return e }
    let pref = if cfg.contains_key("hexa_bin") { _str(cfg["hexa_bin"]) } else { "" }
    if pref != "" && _file_exists(pref) { return pref }
    if _file_exists(HEXA_BIN_DEFAULT) { return HEXA_BIN_DEFAULT }
    let p = _exec_out("command -v hexa 2>/dev/null").trim()
    if p != "" { return p }
    return HEXA_BIN_DEFAULT
}

fn _load_config(path: string) {
    if !_file_exists(path) {
        eprintln("phase_progression_controller: SETUP_ERROR — config missing: " + path)
        exit(2)
    }
    let raw = read_file(path)
    let cfg = json_parse(raw)
    if !_is_map(cfg) {
        eprintln("phase_progression_controller: SETUP_ERROR — malformed config JSON: " + path)
        exit(2)
    }
    return cfg
}

// ─── sub-tool dispatch ────────────────────────────────────────────────

// Run a hexa tool file and return [exit_code, log_path]
fn _run_hexa(bin: string, root: string, tool_rel: string, args_inline: string, slug: string) -> array {
    let tool_abs = root + "/" + tool_rel
    if !_file_exists(tool_abs) {
        return [127, ""]
    }
    let log_path = "/tmp/_phase_ctrl_" + slug + "_" + _ts_epoch() + ".log"
    let cmd = "cd " + _sh_quote(root) + " && " +
              "HEXA_NO_LAUNCHD=1 " + _sh_quote(bin) + " run " + _sh_quote(tool_abs) +
              " " + args_inline + " > " + _sh_quote(log_path) + " 2>&1; echo __rc=$?"
    let tail = _exec_out(cmd).trim()
    let rc_idx = tail.index_of("__rc=")
    let rc_s = if rc_idx >= 0 { tail.substring(rc_idx + 5, len(tail)).trim() } else { "255" }
    let rc = to_int(rc_s)
    return [rc, log_path]
}

// ─── Stage 1: check 100% ──────────────────────────────────────────────

// Read true_closure_cert.json and extract true_closure_pct + passed + total
// Returns [pct, passed, total, hash]
fn _read_closure_cert(ssot_path: string) -> array {
    if !_file_exists(ssot_path) { return [0, 0, 0, ""] }
    let raw = read_file(ssot_path)
    let j = json_parse(raw)
    if !_is_map(j) { return [0, 0, 0, ""] }
    let pct = if j.contains_key("true_closure_pct") { to_int(str(j["true_closure_pct"])) } else { 0 }
    let passed = if j.contains_key("passed") { to_int(str(j["passed"])) } else { 0 }
    let total = if j.contains_key("total_components") { to_int(str(j["total_components"])) } else { 0 }
    let hash = _sha256_file(ssot_path)
    return [pct, passed, total, hash]
}

// Read integrity_result.json and return [exit_code, checks_fail_count, hash]
fn _read_integrity(ssot_path: string) -> array {
    if !_file_exists(ssot_path) { return [-1, 0, ""] }
    let raw = read_file(ssot_path)
    let j = json_parse(raw)
    if !_is_map(j) { return [-1, 0, ""] }
    let ec = if j.contains_key("exit_code") { to_int(str(j["exit_code"])) } else { -1 }
    let mut fails = 0
    if j.contains_key("checks") {
        let checks = j["checks"]
        let mut i = 0
        while i < len(checks) {
            let c = checks[i]
            let v = _str(c["verdict"])
            if v != "PASS" && v != "INFO" { fails = fails + 1 }
            i = i + 1
        }
    }
    let h = _sha256_file(ssot_path)
    return [ec, fails, h]
}

// Stage 1: run all three check tools, verify 100%
// Returns [overall_pass_bool, closure_pct, integrity_rc, debt_present_bool, detail_lines]
fn stage_check(bin: string, root: string, cfg) -> array {
    let tools = cfg["tools"]
    let ssot = cfg["ssot"]
    let mut detail = []

    println("")
    println("┌── Stage 1: check 100%  (true_closure + integrity + closure_debt)")

    // 1a. true_closure_verifier --skip-run (read-only; assumes prior physical run)
    //     If the cert doesn't exist, we do a --skip-run which re-derives
    //     verdicts from existing SSOTs without re-executing heavy tools.
    let tcv_path = _str(tools["true_closure_verifier"])
    let tcv_r = _run_hexa(bin, root, tcv_path, "--skip-run", "tcv")
    let tcv_rc = tcv_r[0]
    let tcv_log = _str(tcv_r[1])
    let cert_ssot = root + "/" + _str(ssot["true_closure_cert"])
    let cert = _read_closure_cert(cert_ssot)
    let closure_pct = cert[0]
    let closure_passed = cert[1]
    let closure_total = cert[2]
    let closure_hash = _str(cert[3])
    let closure_pass = (closure_pct == 100) && (closure_total > 0)
    let sym1 = if closure_pass { "✓" } else { "✗" }
    println("│  " + sym1 + " true_closure_verifier   rc=" + str(tcv_rc) +
            "  " + str(closure_passed) + "/" + str(closure_total) +
            " (" + str(closure_pct) + "%)  sha=" + (if len(closure_hash) >= 12 { closure_hash.substring(0, 12) } else { closure_hash }))
    detail.push("true_closure_pct=" + str(closure_pct) + " passed=" + str(closure_passed) + "/" + str(closure_total))

    // 1b. roadmap_integrity_guard — pass repo-local config explicitly to
    //     avoid the canonical /Users/ghost/core/anima hardcode leaking into
    //     the active worktree (integrity_guard DEFAULT_CONFIG is anima-root).
    let rig_path = _str(tools["roadmap_integrity_guard"])
    let rig_cfg_rel = "config/roadmap_integrity_config.json"
    let rig_args = if _file_exists(root + "/" + rig_cfg_rel) {
        "--json --config " + _sh_quote(root + "/" + rig_cfg_rel)
    } else { "--json" }
    let rig_r = _run_hexa(bin, root, rig_path, rig_args, "rig")
    let rig_rc = rig_r[0]
    // integrity_guard writes to the summary_ssot path encoded in its own
    // config (absolute path by design). Prefer that; fall back to repo-local.
    let mut int_ssot = root + "/" + _str(ssot["integrity_result"])
    let rig_cfg_abs = root + "/" + rig_cfg_rel
    if _file_exists(rig_cfg_abs) {
        let rc = json_parse(read_file(rig_cfg_abs))
        if _is_map(rc) && rc.contains_key("output") {
            let o = rc["output"]
            if o.contains_key("summary_ssot") {
                let alt = _str(o["summary_ssot"])
                if alt != "" && _file_exists(alt) { int_ssot = alt }
            }
        }
    }
    let ires = _read_integrity(int_ssot)
    let int_ec = ires[0]
    let int_fails = ires[1]
    let int_hash = _str(ires[2])
    let int_pass = (rig_rc == 0) && (int_ec == 0)
    let sym2 = if int_pass { "✓" } else { "✗" }
    println("│  " + sym2 + " roadmap_integrity_guard  rc=" + str(rig_rc) +
            "  ssot_exit=" + str(int_ec) + "  non_pass=" + str(int_fails) +
            "  sha=" + (if len(int_hash) >= 12 { int_hash.substring(0, 12) } else { int_hash }))
    detail.push("integrity_rc=" + str(rig_rc) + " ssot_exit=" + str(int_ec) + " non_pass=" + str(int_fails))

    // 1c. closure_debt_scanner (task 59 pending — skip if tool missing)
    let cds_path = _str(tools["closure_debt_scanner"])
    let cds_abs = root + "/" + cds_path
    let mut debt_present = false
    let mut debt_detail = "SKIP_TOOL_MISSING"
    if _file_exists(cds_abs) {
        let cds_r = _run_hexa(bin, root, cds_path, "--json", "cds")
        let cds_rc = cds_r[0]
        debt_present = cds_rc != 0
        debt_detail = "rc=" + str(cds_rc)
    }
    let debt_pass = !debt_present
    let sym3 = if debt_pass { "·" } else { "⚠" }
    println("│  " + sym3 + " closure_debt_scanner     " + debt_detail +
            "  closure_debt=" + (if debt_present { "present" } else { "0 (resolved all known)" }))
    detail.push("closure_debt=" + (if debt_present { "present" } else { "0" }) + " " + debt_detail)

    let overall = closure_pass && int_pass && debt_pass
    let sym = if overall { "✓ CLEAR" } else { "✗ BLOCKED" }
    println("└── Stage 1 " + sym + "  (blocks Stage 2 if BLOCKED)")

    return [overall, closure_pct, rig_rc, debt_present, detail]
}

// ─── Stage 2: roadmap flow 100% ───────────────────────────────────────

// Check if a roadmap_entry_target id already exists as an entry in .roadmap
fn _roadmap_entry_exists(roadmap_path: string, id: int) -> bool {
    if !_file_exists(roadmap_path) { return false }
    let needle = "roadmap " + str(id) + " "
    let src = to_string(read_file(roadmap_path))
    return src.index_of(needle) >= 0
}

// Return "planned" / "active" / "done" / "blocked" / "deferred" / ""
fn _roadmap_entry_status(roadmap_path: string, id: int) -> string {
    if !_file_exists(roadmap_path) { return "" }
    let src = to_string(read_file(roadmap_path))
    let needle = "roadmap " + str(id) + " "
    let k = src.index_of(needle)
    if k < 0 { return "" }
    let after = src.substring(k + len(needle), len(src))
    // status token is the first word
    let sp = after.index_of(" ")
    if sp < 0 { return "" }
    return after.substring(0, sp).trim()
}

// Stage 2: verify all required_entries for phase N+1 are present + planned
// Returns [ready_bool, planned_count, required_count, missing_ids, detail_lines]
fn stage_plan(bin: string, root: string, cfg, phase_num: int) -> array {
    let phases = cfg["phases"]
    let key = str(phase_num)
    let mut detail = []
    let mut missing = []
    let mut planned = 0

    println("")
    println("┌── Stage 2: roadmap flow 100%  (phase " + str(phase_num) + " required_entries)")

    if !phases.contains_key(key) {
        println("│  ✗ phase " + key + " not defined in config")
        println("└── Stage 2 ✗ BLOCKED")
        return [false, 0, 0, missing, detail]
    }

    let ph = phases[key]
    let label = _str(ph["label"])
    println("│  target phase: " + label + "  target_closure=" +
            (if ph.contains_key("closure_pct_target") { str(ph["closure_pct_target"]) } else { "?" }) + "%")

    let required = ph["required_entries"]
    let required_count = len(required)
    let roadmap_path = root + "/" + _str(cfg["roadmap_path"])

    let mut i = 0
    while i < required_count {
        let r = required[i]
        let target_id = to_int(str(r["roadmap_entry_target"]))
        let comp = _str(r["component"])
        let track = _str(r["track"])
        let phase = _str(r["phase"])

        let exists = _roadmap_entry_exists(roadmap_path, target_id)
        let st = _roadmap_entry_status(roadmap_path, target_id)
        let acceptable = exists && (st == "planned" || st == "active" || st == "done")
        let sym = if acceptable { "✓" } else { "✗" }
        println("│  " + sym + " roadmap " + str(target_id) + "  status=" +
                (if st == "" { "MISSING" } else { st }) + "  " + comp)
        if acceptable {
            planned = planned + 1
        } else {
            missing.push(str(target_id) + ":" + track + ":" + phase + ":" + comp)
        }
        detail.push("entry_" + str(target_id) + "=" + (if exists { st } else { "missing" }))
        i = i + 1
    }

    // roadmap_lint verification (best-effort — requires hexa-lang tool)
    let lint_path = _str(cfg["tools"]["roadmap_lint"])
    let lint_rc = if _file_exists(lint_path) {
        let lc = "cd " + _sh_quote(root) + " && HEXA_NO_LAUNCHD=1 " +
                 _sh_quote(bin) + " " + _sh_quote(lint_path) + " 2>&1 > /dev/null; echo __rc=$?"
        let out = _exec_out(lc).trim()
        let k = out.index_of("__rc=")
        if k >= 0 { to_int(out.substring(k + 5, len(out)).trim()) } else { -1 }
    } else { -2 }
    let lint_ok = lint_rc == 0
    let sym_lint = if lint_ok { "✓" } else { if lint_rc == -2 { "·" } else { "⚠" } }
    println("│  " + sym_lint + " roadmap_lint  rc=" + str(lint_rc))
    detail.push("lint_rc=" + str(lint_rc))

    let ready = (planned == required_count) && (lint_ok || lint_rc == -2)

    // Auto-reflect fallback: if entries missing, print hint (auto-append is
    // not done here — user controls via --apply flag on auto_reflect)
    if !ready && len(missing) > 0 {
        println("│  hint: " + str(len(missing)) + " entries missing — consider running:")
        println("│    hexa " + _str(cfg["tools"]["roadmap_auto_reflect"]) +
                " --audit-report state/phase_" + str(phase_num) + "_flow_ready.json --apply")
    }

    let sym = if ready { "✓ CLEAR" } else { "✗ BLOCKED" }
    println("└── Stage 2 " + sym + "  planned=" + str(planned) + "/" + str(required_count))

    // Emit flow_ready SSOT for this phase
    let flow_path = root + "/state/phase_" + str(phase_num) + "_flow_ready.json"
    _emit_flow_ready(flow_path, phase_num, label, ready, planned, required_count, missing, lint_rc)

    return [ready, planned, required_count, missing, detail]
}

fn _emit_flow_ready(path: string, phase_num: int, label: string, ready: bool,
                    planned: int, required: int, missing, lint_rc: int) {
    let mut parts = []
    parts.push("{\n")
    parts.push("  \"schema\": \"anima.phase_flow_ready.v1\",\n")
    parts.push("  \"ts\": \"" + _ts_iso() + "\",\n")
    parts.push("  \"tool\": \"tool/phase_progression_controller.hexa\",\n")
    parts.push("  \"phase\": " + str(phase_num) + ",\n")
    parts.push("  \"label\": \"" + _json_escape(label) + "\",\n")
    parts.push("  \"ready\": " + _bool_s(ready) + ",\n")
    parts.push("  \"planned_count\": " + str(planned) + ",\n")
    parts.push("  \"required_count\": " + str(required) + ",\n")
    parts.push("  \"missing_count\": " + str(len(missing)) + ",\n")
    parts.push("  \"missing\": [")
    let mut i = 0
    while i < len(missing) {
        let comma = if i + 1 < len(missing) { ", " } else { "" }
        parts.push("\"" + _json_escape(_str(missing[i])) + "\"" + comma)
        i = i + 1
    }
    parts.push("],\n")
    parts.push("  \"lint_rc\": " + str(lint_rc) + "\n")
    parts.push("}\n")
    let body = parts.join("")
    let _ = _mkdir_p(_dirname(path))
    let _ = write_file(path, body)
}

fn _dirname(path: string) -> string {
    let k = path.last_index_of("/")
    if k < 0 { return "." }
    return path.substring(0, k)
}

// ─── Stage 3: live adjust ──────────────────────────────────────────────

fn stage_live(bin: string, root: string, cfg) -> array {
    println("")
    println("┌── Stage 3: live adjust  (daemon-tick mode)")

    let tools = cfg["tools"]
    let policy = cfg["live_adjust_policy"]

    // delegate to phase_live_adjuster if present; else run integrity_guard + auto_fix inline
    let live_path = _str(tools["phase_live_adjuster"])
    let live_abs = root + "/" + live_path
    let mut adjuster_rc = 0
    let mut detail = []
    if _file_exists(live_abs) {
        let r = _run_hexa(bin, root, live_path, "--tick", "live")
        adjuster_rc = r[0]
        println("│  ✓ phase_live_adjuster  rc=" + str(adjuster_rc))
        detail.push("live_adjuster_rc=" + str(adjuster_rc))
    } else {
        // Fallback: integrity_guard + best-effort auto_fix (check 2)
        let rig_path = _str(tools["roadmap_integrity_guard"])
        let r = _run_hexa(bin, root, rig_path, "--json", "live_rig")
        adjuster_rc = r[0]
        println("│  ⚠ phase_live_adjuster missing — fallback integrity_guard rc=" + str(adjuster_rc))
        detail.push("fallback_integrity_rc=" + str(adjuster_rc))

        let auto_fix_c2 = if policy.contains_key("auto_fix_check_2") {
            str(policy["auto_fix_check_2"]) == "true"
        } else { false }
        if adjuster_rc != 0 && auto_fix_c2 {
            let af_path = _str(tools["roadmap_mistake_auto_fix"])
            let afr = _run_hexa(bin, root, af_path, "--check 2", "live_af")
            println("│  · auto_fix_check_2  rc=" + str(afr[0]))
            detail.push("auto_fix_c2_rc=" + str(afr[0]))
        }
    }

    let live_ok = adjuster_rc == 0
    let sym = if live_ok { "✓ TICK_CLEAN" } else { "⚠ DRIFT_DETECTED" }
    println("└── Stage 3 " + sym)

    _append_live_log(root, cfg, adjuster_rc, live_ok, detail)
    return [live_ok, adjuster_rc, detail]
}

fn _append_live_log(root: string, cfg, rc: int, ok: bool, detail) {
    let out = cfg["output"]
    let rel = _str(out["live_log"])
    let path = root + "/" + rel
    let _ = _mkdir_p(_dirname(path))

    let existing = if _file_exists(path) { read_file(path) } else { "" }
    let mut parts = []
    if len(existing) > 0 {
        // simple append-JSONL style: each line = one tick event
        parts.push(existing)
        if !existing.ends_with("\n") { parts.push("\n") }
    }
    parts.push("{\"ts\":\"" + _ts_iso() + "\",\"rc\":" + str(rc) +
               ",\"ok\":" + _bool_s(ok) + ",\"detail\":[")
    let mut i = 0
    while i < len(detail) {
        let c = if i + 1 < len(detail) { "," } else { "" }
        parts.push("\"" + _json_escape(_str(detail[i])) + "\"" + c)
        i = i + 1
    }
    parts.push("]}\n")
    let _ = write_file(path, parts.join(""))
}

// ─── cert + raw-audit append ──────────────────────────────────────────

fn _emit_cert(root: string, cfg, stage: string, phase_num: int, exit_code: int,
              s1_pct: int, s2_ready: bool, s2_planned: int, s2_required: int,
              s3_rc: int, detail_all) {
    let rel = _str(cfg["output"]["cert_ssot"])
    let path = root + "/" + rel
    let _ = _mkdir_p(_dirname(path))

    let mut parts = []
    parts.push("{\n")
    parts.push("  \"schema\": \"anima.phase_progression.cert.v1\",\n")
    parts.push("  \"ts\": \"" + _ts_iso() + "\",\n")
    parts.push("  \"tool\": \"tool/phase_progression_controller.hexa\",\n")
    parts.push("  \"config\": \"" + _str(cfg["repo_root"]) + "\",\n")
    parts.push("  \"stage\": \"" + stage + "\",\n")
    parts.push("  \"phase\": " + str(phase_num) + ",\n")
    parts.push("  \"exit_code\": " + str(exit_code) + ",\n")
    parts.push("  \"stage_1_check\": { \"true_closure_pct\": " + str(s1_pct) + " },\n")
    parts.push("  \"stage_2_plan\":  { \"ready\": " + _bool_s(s2_ready) +
               ", \"planned\": " + str(s2_planned) + ", \"required\": " + str(s2_required) + " },\n")
    parts.push("  \"stage_3_live\":  { \"rc\": " + str(s3_rc) + " },\n")
    parts.push("  \"detail\": [")
    let mut i = 0
    while i < len(detail_all) {
        let c = if i + 1 < len(detail_all) { ", " } else { "" }
        parts.push("\"" + _json_escape(_str(detail_all[i])) + "\"" + c)
        i = i + 1
    }
    parts.push("],\n")
    // airgenome hook embed (CLI-only probe, raw#9 hexa-only, raw#15 no-hardcode)
    let _ag_avail = ag_probe_available()
    let _ag_chain = if _ag_avail { ag_probe_top_chain() } else { "" }
    let _ag_touch = if _ag_avail && _ag_chain != "" { ag_probe_touch_count(_ag_chain) } else { 0 }
    let _ag_chain_json = if _ag_chain == "" { "null" } else { "\"" + _ag_chain + "\"" }
    parts.push("  \"air_chain\": " + _ag_chain_json + ",\n")
    parts.push("  \"touch_count\": " + str(_ag_touch) + ",\n")
    parts.push("  \"air_schema_version\": \"" + ag_schema_version() + "\",\n")
    parts.push("  \"raw_strict\": \"raw#9 raw#10 raw#11 raw#12 raw#15 deterministic LLM=none\"\n")
    parts.push("}\n")
    let _ = write_file(path, parts.join(""))
}

fn _raw_audit_last_sha(root: string, cfg) -> string {
    let path = root + "/" + _str(cfg["output"]["audit_log"])
    if !_file_exists(path) { return "genesis" }
    let r = _exec_out("tail -n 1 " + _sh_quote(path) + " 2>/dev/null").trim()
    if r == "" { return "genesis" }
    let key = "\"entry_sha\":\""
    let i = r.index_of(key)
    if i < 0 { return _sha256_str(r) }
    let rest = r.substring(i + len(key), len(r))
    let e = rest.index_of("\"")
    if e < 0 { return _sha256_str(r) }
    return rest.substring(0, e)
}

fn _raw_audit_append(root: string, cfg, stage: string, phase_num: int, exit_code: int) -> string {
    let path = root + "/" + _str(cfg["output"]["audit_log"])
    let _ = _mkdir_p(_dirname(path))
    let prev = _raw_audit_last_sha(root, cfg)

    let body = "{\"ts\":\"" + _ts_iso() + "\",\"tool\":\"phase_progression_controller\"" +
               ",\"stage\":\"" + stage + "\",\"phase\":" + str(phase_num) +
               ",\"exit_code\":" + str(exit_code) + ",\"prev_sha\":\"" + prev + "\""
    let entry_sha = _sha256_str(body + prev)
    let line = body + ",\"entry_sha\":\"" + entry_sha + "\"}"

    // Migration 20260422: append-safe via tool/roadmap_with_unlock.hexa
    // (PR #25). The helper installs `trap '<relock>' EXIT INT TERM` so the
    // file is relocked even if the append is interrupted. Behavior parity:
    //   - bootstrap (no file yet) writes header inline (no lock to honor)
    //   - existing file: append via printf >>, wrapped through the helper
    //   - uappnd best-effort re-apply preserved post-edit
    let had_uchg = _exec_out("ls -lO " + _sh_quote(path) + " 2>/dev/null").index_of("uchg") >= 0
    if !_file_exists(path) {
        let header = "# .raw-audit/phase_progression.log — raw#10 hash-chain\n"
        let _w = write_file(path, header + line + "\n")
    } else {
        let append_cmd = "printf %s\\\\n " + _sh_quote(line) + " >> " + _sh_quote(path)
        if _file_exists(WITH_UNLOCK_TOOL) {
            let mut wrap = []
            wrap.push("hexa ")
            wrap.push(WITH_UNLOCK_TOOL)
            wrap.push(" --file ")
            wrap.push(_sh_quote(path))
            wrap.push(" -- bash -c ")
            wrap.push(_sh_quote(append_cmd))
            let _c = _exec_code(wrap.join(""))
        } else {
            // uchg_safe_edit:fallback-allow — legacy chflags dance retained
            // ONLY when the helper is absent (fresh checkout). Linter skips.
            if had_uchg { let _u = _exec_code("chflags nouchg " + _sh_quote(path)) }
            let _c = _exec_code(append_cmd)
            if had_uchg { let _u3 = _exec_code("chflags uchg " + _sh_quote(path)) }
        }
    }
    // re-apply uappnd (append-only) best-effort
    let _u2 = _exec_code("chflags uappnd " + _sh_quote(path) + " 2>/dev/null")
    return entry_sha
}

// ─── CLI ───────────────────────────────────────────────────────────────

fn _usage() {
    println("phase_progression_controller — 3-stage OS-level progression (check→plan→live)")
    println("")
    println("usage:")
    println("  hexa tool/phase_progression_controller.hexa --stage check")
    println("  hexa tool/phase_progression_controller.hexa --stage plan --phase N")
    println("  hexa tool/phase_progression_controller.hexa --stage live")
    println("  hexa tool/phase_progression_controller.hexa --stage all --phase N")
    println("")
    println("flags:")
    println("  --stage <check|plan|live|all>   mandatory")
    println("  --phase N                       phase number for plan / all (default 1)")
    println("  --config <path>                 override config (default: " + CONFIG_PATH_DEFAULT + ")")
    println("  --help / -h                     print this help")
}

fn main() -> int {
    let argv = _argv()
    if _arg_present(argv, "--help") || _arg_present(argv, "-h") {
        _usage()
        return 0
    }

    let stage = _arg_value(argv, "--stage", "")
    if stage == "" {
        eprintln("phase_progression_controller: --stage required (check|plan|live|all)")
        _usage()
        return 2
    }
    if stage != "check" && stage != "plan" && stage != "live" && stage != "all" {
        eprintln("phase_progression_controller: --stage must be check|plan|live|all, got: " + stage)
        return 2
    }

    let phase_s = _arg_value(argv, "--phase", "1")
    let phase_num = to_int(phase_s)

    let root = _resolve_root()
    let cfg_path = root + "/" + _arg_value(argv, "--config", CONFIG_PATH_DEFAULT)
    let cfg = _load_config(cfg_path)
    let bin = _resolve_hexa_bin(cfg)

    println("════════════════════════════════════════════════════════════════")
    println("  tool/phase_progression_controller.hexa — 3-stage OS-level")
    println("  raw#9 hexa-only · raw#11 snake_case · raw#15 no-hardcode · raw#10 hash-chain")
    println("  root=" + root)
    println("  hexa_bin=" + bin)
    println("  stage=" + stage + "  phase=" + str(phase_num))
    println("════════════════════════════════════════════════════════════════")

    let mut exit_code = 0
    let mut s1_pct = 0
    let mut s2_ready = false
    let mut s2_planned = 0
    let mut s2_required = 0
    let mut s3_rc = 0
    let mut detail_all = []

    if stage == "check" || stage == "all" {
        let r = stage_check(bin, root, cfg)
        let ok = r[0]
        s1_pct = r[1]
        for d in r[4] { detail_all.push(_str(d)) }
        if !ok {
            exit_code = 1
            if stage == "all" {
                println("")
                println("▶ Stage 1 FAILED — Stage 2 / 3 skipped (100% check gate blocks forward progression)")
            }
        }
    }

    if (stage == "plan" || (stage == "all" && exit_code == 0)) {
        let r = stage_plan(bin, root, cfg, phase_num)
        let ok = r[0]
        s2_planned = r[1]
        s2_required = r[2]
        s2_ready = ok
        for d in r[4] { detail_all.push(_str(d)) }
        if !ok {
            if exit_code == 0 { exit_code = 1 }
            if stage == "all" {
                println("")
                println("▶ Stage 2 NOT READY — Stage 3 still runs (live adjust tolerates partial plan)")
            }
        }
    }

    if (stage == "live" || stage == "all") {
        let r = stage_live(bin, root, cfg)
        let ok = r[0]
        s3_rc = r[1]
        for d in r[2] { detail_all.push(_str(d)) }
        if !ok {
            // live drift ≠ hard fail; controller returns 0 if live alone
            if stage == "all" && exit_code == 0 { exit_code = 1 }
        }
    }

    _emit_cert(root, cfg, stage, phase_num, exit_code, s1_pct, s2_ready,
               s2_planned, s2_required, s3_rc, detail_all)
    let sha = _raw_audit_append(root, cfg, stage, phase_num, exit_code)

    println("")
    println("▶ cert:       " + _str(cfg["output"]["cert_ssot"]))
    println("▶ audit_log:  " + _str(cfg["output"]["audit_log"]) +
            "  entry_sha=" + (if len(sha) >= 16 { sha.substring(0, 16) + "..." } else { sha }))
    println("▶ exit_code:  " + str(exit_code))
    return exit_code
}

exit(main())
