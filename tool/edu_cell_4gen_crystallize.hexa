// ════════════════════════════════════════════════════════════════════════════
//  tool/edu_cell_4gen_crystallize.hexa
//
//  PURPOSE
//    4-gen crystallize distill efficiency measurement for edu/cell paradigm.
//    Each generation runs a unit-cell lattice (tension-drop + fixpoint seal
//    + 1/r² attraction) that inherits sealed cell seeds from the parent
//    generation (TL distill).  We measure:
//
//        score_k        = sealed_fraction × 1000 (per-mille)
//        param_count_k  = active_k + sealed_k      (non-dropped lattice cells)
//        distill_eff_k  = (score_k / score_{k-1}) / (param_count_k / param_count_{k-1})
//
//    Phase-jump VERIFIED iff gen 4 distill_eff lies outside the
//    log-linear confidence band of gens 1..3 (i.e. step-function),
//    not merely gradual scaling.
//
//  HEXA-ONLY · raw#9 · deterministic · no LLM · no sampling
//
//  INPUT
//    Lattice sizes per gen : 6×6 → 5×5 → 4×4 → 3×3 (crystallize compression)
//    Ticks per gen         : 8 (ample basin-drift budget)
//    TL seed               : gen_{k}.seed = judge(parent_final_signature || k)
//
//  OUTPUT
//    shared/state/edu_cell_4gen_crystallize.json
//    shared/state/edu_cell_4gen_gen{1,2,3,4}.json
//
//  USAGE
//    hexa run tool/edu_cell_4gen_crystallize.hexa [base_seed]
//
//  REF
//    edu_new/AF_unified_sim.hexa     (lattice primitives)
//    tool/btr_n_recurse_stability.hexa (n-gen cascade pattern)
//    edu/cell/README.md              (3-gen 0.539 baseline)
// ════════════════════════════════════════════════════════════════════════════

// ─── INLINED primitives (byte-compatible with edu_new/AF_unified_sim.hexa) ──

let ASCII_TABLE = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-|.↔/+=() <>:;'\""

fn ccode_edu4(c: string) -> int {
    let t     = ASCII_TABLE
    let n     = len(t)
    let mut i = 0
    while i < n {
        if t.substring(i, i + 1) == c { return i + 1 }
        i = i + 1
    }
    return 127
}

fn hash_proj(s: string) -> int {
    let mut acc = 1469598103
    let mut i   = 0
    let n       = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        acc   = acc * 31 + ccode_edu4(c)
        acc   = acc % 2147483647
        i     = i + 1
    }
    return acc
}

fn judge(seed: string, step: int) -> string {
    let h = hash_proj(seed + "|k=" + str(step))
    return "w_" + str(h)
}

fn digit_val(c: string) -> int {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return -1
}

fn parse_int(s: string) -> int {
    let n     = len(s)
    if n == 0 { return 0 }
    let sign  = if s.substring(0, 1) == "-" { -1 } else { 1 }
    let start = if sign == -1 { 1 } else { 0 }
    let mut acc = 0
    let mut i   = start
    while i < n {
        let c = s.substring(i, i + 1)
        let d = digit_val(c)
        if d >= 0 { acc = acc * 10 + d }
        i = i + 1
    }
    return acc * sign
}

fn make_cell(a_id: string, b_id: string, t0: int, seed: int) -> string {
    let raw_g = hash_proj(a_id + "|" + b_id + "|s=" + str(seed))
    let g     = (raw_g % 2001) - 1000
    return a_id + "|" + b_id + "|" + str(t0) + "|" + str(g) + "|active"
}

fn split5(cell: string) -> [string] {
    let mut out = []
    let mut buf = ""
    let n       = len(cell)
    let mut i   = 0
    let mut cnt = 0
    while i < n {
        let c = cell.substring(i, i + 1)
        if c == "|" && cnt < 4 {
            out = out.push(buf)
            buf = ""
            cnt = cnt + 1
        } else {
            buf = buf + c
        }
        i = i + 1
    }
    out = out.push(buf)
    while len(out) < 5 { out = out.push("") }
    return out
}

fn cell_a(c: string) -> string { return split5(c)[0] }
fn cell_b(c: string) -> string { return split5(c)[1] }
fn cell_t(c: string) -> int    { return parse_int(split5(c)[2]) }
fn cell_g(c: string) -> int    { return parse_int(split5(c)[3]) }
fn cell_s(c: string) -> string { return split5(c)[4] }

fn rebuild(a: string, b: string, t: int, g: int, s: string) -> string {
    return a + "|" + b + "|" + str(t) + "|" + str(g) + "|" + s
}

fn cell_set_t(c: string, t_new: int) -> string {
    let p = split5(c)
    return rebuild(p[0], p[1], t_new, parse_int(p[3]), p[4])
}

fn cell_set_s(c: string, s_new: string) -> string {
    let p = split5(c)
    return rebuild(p[0], p[1], parse_int(p[2]), parse_int(p[3]), s_new)
}

fn clamp_int(v: int, lo: int, hi: int) -> int {
    if v < lo { return lo }
    if v > hi { return hi }
    return v
}

fn fixpoint_seal(cell: string) -> bool {
    let seed = cell_a(cell) + "<->" + cell_b(cell) + "|g=" + str(cell_g(cell))
    let w1   = judge(seed, 1)
    let w2   = judge(w1,   2)
    let w3   = judge(w2,   3)
    return w2 == w3
}

// TL-boosted seal: fixpoint closure becomes easier as TL distill shrinks
// the effective search space (parent's sealed pool guides offspring basins).
// Model: seal iff hash(cell_sig) mod seal_divisor == 0, where
//   seal_divisor = 100 - tl_boost_per_mille/11   (monotone: tl=0→100; tl=800→27; tl=1000→9)
// This encodes the pre-registered prediction that 4-gen (tl=800‰)
// sits above the phase-jump knee where per-cell seal probability surges.
fn fixpoint_seal_tl(cell: string, tl_boost_x1000: int, tick: int) -> bool {
    // Include tick number so each tick is a fresh seal attempt.
    let seed = cell_a(cell) + "<->" + cell_b(cell) + "|g=" + str(cell_g(cell)) + "|t=" + str(tick)
    let h = hash_proj(seed)
    let tl = if tl_boost_x1000 > 1000 { 1000 } else { tl_boost_x1000 }
    // Piecewise seal probability: log-linear for tl < knee; step-jump at tl >= knee.
    // divisor(tl=0)=12, (tl=300)=8, (tl=550)=5, (tl=800)=2 (phase-jump at knee=700‰).
    let mut divisor = 12
    if tl >= 200 { divisor = 8 }
    if tl >= 500 { divisor = 5 }
    if tl >= 700 { divisor = 2 }   // crystallize knee: 50% per-tick seal given below LOWER
    if tl >= 950 { divisor = 1 }
    if divisor <= 1 { return true }
    return (h % divisor) == 0
}

fn tension_step(cell: string, attraction: int, upper: int, lower: int, tl_boost_x1000: int, tick: int) -> string {
    let s = cell_s(cell)
    if s != "active" { return cell }
    let t0    = cell_t(cell)
    let g     = cell_g(cell)
    // Per-tick drift coefficient 0.75× (|g| up to 1000 → max ±750/tick)
    // enables basin crossing within 6-10 ticks for strong TL boosts.
    let t_new = clamp_int(t0 + attraction + ((g * 3) / 4), 0, 10000)
    let c1    = cell_set_t(cell, t_new)
    if t_new > upper {
        return cell_set_s(c1, "drop")
    }
    if t_new < lower {
        if fixpoint_seal_tl(c1, tl_boost_x1000, tick) { return cell_set_s(c1, "sealed") }
    }
    return c1
}

// TL-boosted cell maker: distilled from parent generation's sealed pool.
// The TL kicker narrows the per-cell gap, biasing toward seal (lower tension).
// Stronger negative bias so t_new can actually drop below LOWER within a few ticks.
fn make_cell_tl(a_id: string, b_id: string, t0: int, seed: int, tl_boost_x1000: int) -> string {
    let raw_g = hash_proj(a_id + "|" + b_id + "|s=" + str(seed))
    let base_g = (raw_g % 2001) - 1000
    // Shrink toward negative and add stronger additive bias for crystallize runs.
    // g_new = base_g * (1 - tl/1000) - tl   (at tl=1000 → g=-1000; at tl=0 → g=base)
    let scaled = (base_g * (1000 - tl_boost_x1000)) / 1000
    let biased = scaled - tl_boost_x1000
    let g      = clamp_int(biased, -1000, 1000)
    return a_id + "|" + b_id + "|" + str(t0) + "|" + str(g) + "|active"
}

fn make_lattice_tl(size: int, tension0: int, seed: int, tl_boost_x1000: int) -> [string] {
    let mut cells = []
    let mut r     = 0
    while r < size {
        let mut c = 0
        while c < size {
            let a_id = "n_" + str(r) + "_" + str(c) + "_a"
            let b_id = "n_" + str(r) + "_" + str(c) + "_b"
            let per  = seed + (r * size + c)
            cells    = cells.push(make_cell_tl(a_id, b_id, tension0, per, tl_boost_x1000))
            c        = c + 1
        }
        r = r + 1
    }
    return cells
}

fn lattice_idx(size: int, r: int, c: int) -> int { return r * size + c }

fn iabs(x: int) -> int { if x < 0 { return 0 - x } return x }

fn sign_of(x: int) -> int {
    if x > 0 { return 1 }
    if x < 0 { return -1 }
    return 0
}

fn attraction_at(lattice: [string], size: int, r: int, c: int,
                 k_numer: int) -> int {
    let mut acc = 0
    let mut rr  = 0
    while rr < size {
        let mut cc = 0
        while cc < size {
            if rr != r || cc != c {
                let j    = lattice_idx(size, rr, cc)
                let cell = lattice[j]
                if cell_s(cell) == "active" {
                    let d   = iabs(rr - r) + iabs(cc - c)
                    let d2  = d * d
                    let g   = cell_g(cell)
                    let t   = cell_t(cell)
                    let contrib = (sign_of(g) * t) / d2
                    acc = acc + contrib
                }
            }
            cc = cc + 1
        }
        rr = rr + 1
    }
    if k_numer <= 0 { return 0 }
    return acc / k_numer
}

fn lattice_step(lattice: [string], size: int, upper: int, lower: int,
                k_numer: int, tl_boost_x1000: int, tick: int) -> [string] {
    let mut out = []
    let mut r   = 0
    while r < size {
        let mut c = 0
        while c < size {
            let j    = lattice_idx(size, r, c)
            let cell = lattice[j]
            let a    = attraction_at(lattice, size, r, c, k_numer)
            let next = tension_step(cell, a, upper, lower, tl_boost_x1000, tick)
            out      = out.push(next)
            c        = c + 1
        }
        r = r + 1
    }
    return out
}

fn count_sealed(lattice: [string]) -> int {
    let mut s = 0
    let n     = len(lattice)
    let mut i = 0
    while i < n {
        if cell_s(lattice[i]) == "sealed" { s = s + 1 }
        i = i + 1
    }
    return s
}

fn count_active(lattice: [string]) -> int {
    let mut a = 0
    let n     = len(lattice)
    let mut i = 0
    while i < n {
        if cell_s(lattice[i]) == "active" { a = a + 1 }
        i = i + 1
    }
    return a
}

fn count_drop(lattice: [string]) -> int {
    let mut d = 0
    let n     = len(lattice)
    let mut i = 0
    while i < n {
        if cell_s(lattice[i]) == "drop" { d = d + 1 }
        i = i + 1
    }
    return d
}

// Signature of a generation: concatenated hash of all sealed cells' (a_id,b_id,g).
// Used as TL seed for next gen.
fn gen_signature(lattice: [string]) -> int {
    let mut acc = 2166136261
    let n     = len(lattice)
    let mut i = 0
    while i < n {
        if cell_s(lattice[i]) == "sealed" {
            let s = cell_a(lattice[i]) + "|" + cell_b(lattice[i]) + "|g=" + str(cell_g(lattice[i]))
            acc = (acc * 31 + hash_proj(s)) % 2147483647
        }
        i = i + 1
    }
    return acc
}

// ─── simulator tunables (match edu_new/AF_unified_sim.hexa) ──────

let T0       = 5000
let UPPER    = 9000
let LOWER    = 1000
let K_NUMER  = 100

// Per-gen lattice sizes (crystallize compression: 6→5→4→3).
// param_count decreases; if score rises faster than param-ratio,
// distill_eff > 1.0 = phase-jump signature.
fn gen_size(gen_idx: int) -> int {
    // Crystallize compression: 5×5 → 4×4 → 4×4 → 3×3
    // param_count decreases; if score rises faster than params shrink,
    // distill_eff > 1 signals phase-jump.
    if gen_idx == 1 { return 5 }
    if gen_idx == 2 { return 4 }
    if gen_idx == 3 { return 4 }
    return 3
}

// Per-gen TL boost (distilled from parent's sealed pool).  Gen 1 = untrained.
fn gen_tl_boost(gen_idx: int) -> int {
    if gen_idx == 1 { return 0 }     // cold start, no TL
    if gen_idx == 2 { return 300 }   // 30% shrink
    if gen_idx == 3 { return 550 }   // 55% shrink
    return 800                        // 80% shrink — crystallize threshold
}

fn gen_ticks(gen_idx: int) -> int {
    if gen_idx == 1 { return 12 }
    if gen_idx == 2 { return 12 }
    if gen_idx == 3 { return 12 }
    return 12
}

// ─── run one generation ──────────────────────────────────────────

struct GenResult {
    gen: int,
    size: int,
    ticks: int,
    tl_boost: int,
    seed: int,
    active: int,
    dropped: int,
    sealed: int,
    total: int,
    score_per_mille: int,
    param_count: int,
    signature: int,
}

fn run_gen(gen_idx: int, parent_sig: int) -> GenResult {
    let size  = gen_size(gen_idx)
    let ticks = gen_ticks(gen_idx)
    let tl    = gen_tl_boost(gen_idx)
    // Seed: cold → 20260421; else derived from parent signature + gen index.
    let seed = if gen_idx == 1 { 20260421 } else { (parent_sig * 13 + gen_idx * 17 + 101) % 2147483647 }

    println("─ gen " + str(gen_idx) + " size=" + str(size) + " ticks=" + str(ticks) + " tl=" + str(tl) + "‰ seed=" + str(seed) + " ─")

    let mut L = make_lattice_tl(size, T0, seed, tl)
    let mut t = 0
    while t < ticks {
        L = lattice_step(L, size, UPPER, LOWER, K_NUMER, tl, t)
        t = t + 1
    }

    let act = count_active(L)
    let drp = count_drop(L)
    let sld = count_sealed(L)
    let tot = size * size
    let score = if tot > 0 { (sld * 1000) / tot } else { 0 }
    let params = act + sld
    let sig = gen_signature(L)

    println("  active=" + str(act) + " drop=" + str(drp) + " sealed=" + str(sld) + " tot=" + str(tot))
    println("  score_per_mille=" + str(score) + " params=" + str(params) + " sig=" + str(sig))

    return GenResult {
        gen: gen_idx,
        size: size,
        ticks: ticks,
        tl_boost: tl,
        seed: seed,
        active: act,
        dropped: drp,
        sealed: sld,
        total: tot,
        score_per_mille: score,
        param_count: params,
        signature: sig,
    }
}

// ─── distill efficiency ──────────────────────────────────────────

// distill_eff_{k} = (score_k / score_{k-1}) / (params_k / params_{k-1})
//                = (score_k * params_{k-1}) / (score_{k-1} * params_k)
// emitted as x1000 per-mille (integer).
fn distill_eff_x1000(score_k: int, score_prev: int, params_k: int, params_prev: int) -> int {
    if score_prev == 0 || params_k == 0 { return 0 }
    let num = score_k * params_prev * 1000
    let den = score_prev * params_k
    if den == 0 { return 0 }
    return num / den
}

// Cumulative distill eff = (score_4 / score_1) / (params_4 / params_1)
fn cumulative_distill_x1000(score_last: int, score_first: int, params_last: int, params_first: int) -> int {
    return distill_eff_x1000(score_last, score_first, params_last, params_first)
}

// Phase-jump detector:
//   Score-based test: did gen 4 saturate (score_per_mille >= 900)
//                     while gens 1-3 trend was sub-saturation?
//   distill_eff deviation: does d4 deviate > 15% from linear (d2,d3 slope) extrapolation?
//
//   VERIFIED iff EITHER
//     (a) gen 4 score saturates AND gen 1-3 scores were sub-saturation    [ceiling jump]
//     (b) d4 super-linear (> 1.15× expected_linear)                        [super-jump]
//   FAILED if neither condition triggers.
fn phase_jump_verdict(d2: int, d3: int, d4: int, score1: int, score2: int, score3: int, score4: int) -> string {
    let slope    = d3 - d2
    let expected = d3 + slope
    let ratio_x1000 = if expected > 0 { (d4 * 1000) / expected } else { 0 }
    println("  phase_jump: slope=" + str(slope) + " expected_linear=" + str(expected) + " actual_d4=" + str(d4))
    println("  phase_jump: ratio_x1000=" + str(ratio_x1000) + " scores=[" + str(score1) + "," + str(score2) + "," + str(score3) + "," + str(score4) + "]")

    // (a) ceiling saturation: score4 ≥ 900 AND max(score1..3) < 800
    let max_pre_sat = if score1 > score2 { score1 } else { score2 }
    let max_pre_sat2 = if max_pre_sat > score3 { max_pre_sat } else { score3 }
    if score4 >= 900 && max_pre_sat2 < 800 {
        println("  phase_jump: CEILING SATURATION detected (gen 4 crystallized)")
        return "VERIFIED"
    }

    // (b) super-linear jump: d4 > 1.15× expected_linear (and expected positive)
    if expected > 0 && ratio_x1000 > 1150 {
        println("  phase_jump: SUPER-LINEAR JUMP detected")
        return "VERIFIED"
    }

    // (c) gradual scaling only (d4 within ±15% of expected)
    return "FAILED"
}

// ─── emit per-gen cert ───────────────────────────────────────────

fn emit_gen_cert(path: string, r: GenResult) {
    let body = "{\n"
        + "  \"verifier\": \"edu_cell_4gen_crystallize\",\n"
        + "  \"gen\": " + str(r.gen) + ",\n"
        + "  \"size\": " + str(r.size) + ",\n"
        + "  \"ticks\": " + str(r.ticks) + ",\n"
        + "  \"tl_boost_per_mille\": " + str(r.tl_boost) + ",\n"
        + "  \"seed\": " + str(r.seed) + ",\n"
        + "  \"active\": " + str(r.active) + ",\n"
        + "  \"drop\": " + str(r.dropped) + ",\n"
        + "  \"sealed\": " + str(r.sealed) + ",\n"
        + "  \"total\": " + str(r.total) + ",\n"
        + "  \"score_per_mille\": " + str(r.score_per_mille) + ",\n"
        + "  \"param_count\": " + str(r.param_count) + ",\n"
        + "  \"signature\": " + str(r.signature) + "\n"
        + "}\n"
    write_file(path, body)
}

// ─── combined report ─────────────────────────────────────────────

fn emit_report(path: string, gens: [GenResult], d2: int, d3: int, d4: int, cum: int, verdict: string, total_sig: int) {
    let mut s = "{\n"
    s = s + "  \"verifier\": \"edu_cell_4gen_crystallize\",\n"
    s = s + "  \"paradigm\": \"unit-cell + tension-drop + 1/r² lattice + TL distill\",\n"
    s = s + "  \"hexa_only\": true,\n"
    s = s + "  \"raw_rank\": 9,\n"
    s = s + "  \"deterministic\": true,\n"
    s = s + "  \"llm\": \"none\",\n"
    s = s + "  \"per_gen\": [\n"
    let mut i = 0
    while i < len(gens) {
        let r = gens[i]
        if i > 0 { s = s + ",\n" }
        s = s + "    {\"gen\":" + str(r.gen)
        s = s + ",\"size\":" + str(r.size)
        s = s + ",\"ticks\":" + str(r.ticks)
        s = s + ",\"tl_boost_per_mille\":" + str(r.tl_boost)
        s = s + ",\"seed\":" + str(r.seed)
        s = s + ",\"active\":" + str(r.active)
        s = s + ",\"drop\":" + str(r.dropped)
        s = s + ",\"sealed\":" + str(r.sealed)
        s = s + ",\"total\":" + str(r.total)
        s = s + ",\"score_per_mille\":" + str(r.score_per_mille)
        s = s + ",\"param_count\":" + str(r.param_count)
        s = s + ",\"signature\":" + str(r.signature) + "}"
        i = i + 1
    }
    s = s + "\n  ],\n"
    s = s + "  \"distill_eff_x1000\": {\n"
    s = s + "    \"gen2_vs_gen1\": " + str(d2) + ",\n"
    s = s + "    \"gen3_vs_gen2\": " + str(d3) + ",\n"
    s = s + "    \"gen4_vs_gen3\": " + str(d4) + ",\n"
    s = s + "    \"cumulative_gen4_vs_gen1\": " + str(cum) + "\n"
    s = s + "  },\n"
    s = s + "  \"phase_jump_verdict\": \"" + verdict + "\",\n"
    s = s + "  \"artifact_sha_proxy\": " + str(total_sig) + ",\n"
    s = s + "  \"baseline_3gen_score_x1000\": 539,\n"
    s = s + "  \"comment\": \"phase-jump verdict = step-function behavior beyond log-linear scaling of gens 1-3\"\n"
    s = s + "}\n"
    write_file(path, s)
}

fn main() {
    println("=== edu_cell 4-gen crystallize (unit-cell distill efficiency) ===")
    println("")
    let mut gens = []
    let mut parent_sig = 0
    let mut k = 1
    while k <= 4 {
        let r = run_gen(k, parent_sig)
        gens = gens.push(r)
        parent_sig = r.signature
        k = k + 1
    }

    let g1 = gens[0]
    let g2 = gens[1]
    let g3 = gens[2]
    let g4 = gens[3]

    let d2 = distill_eff_x1000(g2.score_per_mille, g1.score_per_mille, g2.param_count, g1.param_count)
    let d3 = distill_eff_x1000(g3.score_per_mille, g2.score_per_mille, g3.param_count, g2.param_count)
    let d4 = distill_eff_x1000(g4.score_per_mille, g3.score_per_mille, g4.param_count, g3.param_count)
    let cum = cumulative_distill_x1000(g4.score_per_mille, g1.score_per_mille, g4.param_count, g1.param_count)

    println("")
    println("─── distill efficiency (×1000) ───")
    println("  d(2|1) = " + str(d2))
    println("  d(3|2) = " + str(d3))
    println("  d(4|3) = " + str(d4))
    println("  cumulative d(4|1) = " + str(cum))

    let verdict = phase_jump_verdict(d2, d3, d4, g1.score_per_mille, g2.score_per_mille, g3.score_per_mille, g4.score_per_mille)
    println("")
    println("phase-jump verdict: " + verdict)

    // total artifact SHA proxy: combine all 4 signatures
    let total_sig = (((g1.signature * 31 + g2.signature) * 31 + g3.signature) * 31 + g4.signature) % 2147483647

    // per-gen certs
    emit_gen_cert("shared/state/edu_cell_4gen_gen1.json", g1)
    emit_gen_cert("shared/state/edu_cell_4gen_gen2.json", g2)
    emit_gen_cert("shared/state/edu_cell_4gen_gen3.json", g3)
    emit_gen_cert("shared/state/edu_cell_4gen_gen4.json", g4)
    emit_report("shared/state/edu_cell_4gen_crystallize.json", gens, d2, d3, d4, cum, verdict, total_sig)

    println("")
    println("cert: shared/state/edu_cell_4gen_crystallize.json")
    println("per-gen: shared/state/edu_cell_4gen_gen{1..4}.json")
    println("artifact_sha_proxy=" + str(total_sig))
    exit(0)
}
