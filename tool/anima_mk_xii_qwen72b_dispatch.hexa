    println("helper_emitted=" + HELPER_PATH)
    println("model_hf_repo=" + MODEL_HF_REPO)
    println("model_license=" + MODEL_HF_LICENSE)
    println("model_params_b=" + str(MODEL_PARAMS_B))
    println("model_fp16_gb=" + str(MODEL_FP16_GB) + " (>single H100 80GB → multi-GPU required)")
    println("dispatch_budget_total_usd=" + str(DISPATCH_BUDGET_USD_TOTAL))
    println("dispatch_budget_R1_cap=" + str(DISPATCH_BUDGET_USD_R1) + " R2_cap=" + str(DISPATCH_BUDGET_USD_R2))
