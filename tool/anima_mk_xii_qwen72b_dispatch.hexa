fn _plan() {
    println("__MK_XII_QWEN72B_DISPATCH_BEGIN__ plan")
    let _path = _emit_helper()
    let py = _detect_python3()
    println("helper_emitted=" + HELPER_PATH)
    println("python3_detected=" + py)
    println("__MK_XII_QWEN72B_DISPATCH_RESULT__ HELPER_READY")
    println("fix: 1) " + py + " " + HELPER_PATH + "  2) interpret JSON Pattern 6c plan + multi-GPU offers  3) review + fire R1 → R2")
    println("raw_10_caveat=NO ACTUAL DISPATCH — plan emit only.")
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_plan = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--plan" { has_plan = true }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_plan { _plan() }
    else {
        println("usage: hexa run tool/anima_mk_xii_qwen72b_dispatch.hexa --selftest | --plan")
        println("Mk.XII Phase 3b 70B+ class Qwen2.5-72B sub for gated Llama-3.1-70B. Pattern 6c 4-component relay.")
    }
    return 0
}
