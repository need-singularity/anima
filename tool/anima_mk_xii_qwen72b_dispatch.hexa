fn _detect_python3() -> str {
    let candidates = [
        "/opt/homebrew/bin/python3",
        "/usr/local/bin/python3",
        "/usr/bin/python3"
    ]
    let mut i = 0
    while i < candidates.len() {
        let p = candidates[i]
        if file_exists(p) { return p }
        i = i + 1
    }
    return "python3"
}

fn _emit_helper() -> str {
    let lines = [
        "#!/usr/bin/env python3",
        "# anima_mk_xii_qwen72b_dispatch_helper.py — raw#37 transient",
        "import os, sys, json, subprocess, datetime",
        "",
        "REPO = '/Users/ghost/core/anima'",
        "VASTAI_CLI = '/Users/ghost/.local/bin/vastai'",
        "SECRET_CLI = '/Users/ghost/core/secret/bin/secret'",
        "MODEL_HF_REPO = 'Qwen/Qwen2.5-72B'",
        "DISPATCH_LABEL_PREFIX = 'anima-mk-xii-qwen72b'",
        "BUDGET_R1_USD = 10",
        "BUDGET_R2_USD = 25",
        "",
        "def get_secret(key):",
        "    try:",
        "        return subprocess.check_output([SECRET_CLI, 'get', key], text=True).strip()",
        "    except Exception: return None",
        "",
        "def search_offers_multi_gpu(num_gpus=2, gpu='H100_SXM', max_price_per_hr=4.00, min_disk=300, min_reliability=0.97):",
        "    # Multi-GPU search: num_gpus instances of GPU, total $/hr <= max_price_per_hr",
        "    query = f'gpu_name={gpu} num_gpus={num_gpus} rentable=true reliability>{min_reliability} disk_space>={min_disk}'",
        "    try:",
        "        out = subprocess.check_output([VASTAI_CLI, 'search', 'offers', query, '--order', 'dph_total', '--limit', '5', '--raw'], text=True)",
        "        offers = json.loads(out) if out else []",
        "        return [o for o in offers if o.get('dph_total', 999) <= max_price_per_hr]",
        "    except Exception as e:",
        "        return [{'error': str(e)}]",
        "",
        "def emit_dispatch_plan():",
        "    api_key = get_secret('vast.api_key')",
        "    if not api_key: return {'error': 'vast.api_key missing in secret store'}",
        "    ssh_key_path = os.path.expanduser('~/.vast/ssh/vast-key')",
        "    if not os.path.exists(ssh_key_path):",
        "        return {'error': 'vast SSH key missing at ' + ssh_key_path}",
        "    offers_2gpu = search_offers_multi_gpu(num_gpus=2)",
        "    offers_4gpu = search_offers_multi_gpu(num_gpus=4)",
        "    plan = {",
        "        'tool': 'anima_mk_xii_qwen72b_dispatch',",
        "        'version': 'v1',",
        "        'ts': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),",
        "        'model_hf_repo': MODEL_HF_REPO,",
        "        'model_license': 'Apache-2.0 (open, HTTP 200, no gating)',",
        "        'model_params_b': 72,",
        "        'model_fp16_gb': 144,",
        "        'pattern_6c_4_component_relay': {",
        "            'R1_download_pod': {'gpu': 'H100 SXM 1x', 'cost_usd': 8, 'duration_h': 4, 'task': 'huggingface-cli download Qwen2.5-72B 144GB resume + 200GB persistent volume'},",
        "            'R2_measurement_pod_2gpu': {'gpu': 'H100 SXM 2x', 'cost_usd': 13, 'duration_h': 4, 'task': 'forward + tomography (model fits across 2 GPUs)'},",
        "            'R2_measurement_pod_4gpu_alt': {'gpu': 'H100 SXM 4x', 'cost_usd': 26, 'duration_h': 4, 'task': 'comfortable headroom for batch+context expansion'},",
        "            'R3_verifier': {'host': 'hetzner CPU', 'cost_usd': 0, 'task': 'post-emission verify per raw 91 honesty triad C1-C5'},",
        "            'R4_orchestrator': {'host': 'Mac local', 'cost_usd': 0, 'task': 'lifecycle management + watchdog + audit ledger emit per raw 86'},",
        "        },",
        "        'preflight_checks': {",
        "            'qwen25_72b_open_no_gating': True,  # HTTP 200 verified prior",
        "            'multi_gpu_required': '72B fp16 144GB > single H100 80GB → 2× minimum',",
        "            'pattern_6c_documented': True,  # docs/runpod_large_model_dispatch_template_20260427.md",
        "            'vast_api_key_present': True,",
        "            'vast_ssh_key_file_present': True,",
        "        },",
        "        'pre_registered_pass_predicates': {",
        "            'r1_download_complete_sha256_match': True,",
        "            'r2_forward_inference_no_cuda_oom': True,",
        "            'r3_verifier_raw_91_c1_c5_pass': True,",
        "            'r1_cap_usd': BUDGET_R1_USD,",
        "            'r2_cap_usd': BUDGET_R2_USD,",
        "            'auto_kill_min_per_pod': 240,",
        "        },",
        "        'cost_attribution_raw_86': {",
        "            'cost_center': 'anima-mk-xii-phase-3b-qwen72b-vast-pattern-6c',",
        "            'task_id_prefix': 'mk_xii_qwen72b_dispatch_' + datetime.datetime.utcnow().strftime('%Y%m%dT%H%M%SZ'),",
        "            'cost_estimate_usd_total': 35,",
        "            'cost_estimate_usd_breakdown': 'R1=8 R2_2gpu=13 R3=0 R4=0 buffer=14',",
        "            'vendor': 'vast.ai',",
        "            'gpu_class_2gpu': 'H100_SXM_2x',",
        "        },",
        "        'roadmap_dependencies': {",
        "            'mk_xii_phase_3b_70b_originally_blocked': 'state/blockers/runpod_pod_pre_ssh_orchestrator_stuck.json — RunPod 4-strike sustained fault',",
