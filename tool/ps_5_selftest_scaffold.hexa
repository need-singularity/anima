// tool/ps_5_selftest_scaffold.hexa — cl-rotate Step 5: 각 파일 self-test 내장
//
// For each entry in issue.unix_split, record a planned self-test target
// (issue.selftests = [{"file": "...", "planned": true, "assertion": "..."}]).
// Does NOT materialise .hexa files — that would require caller intent.
// Instead records the scaffold plan (raw#12 허용: plan 만).

let DEFAULT_CONFIG = "/Users/ghost/core/anima/config/problem_solving_protocol_config.json"

fn _sh_quote(s: string) -> string { let mut o = "'"; o = o + s.replace("'", "'\\''"); o = o + "'"; return o }
fn _file_exists(p: string) -> bool { return exec_with_status("test -e " + _sh_quote(p))[1] == 0 }
fn _ts_iso() -> string { return to_string(exec_with_status("date -u +%Y-%m-%dT%H:%M:%SZ")[0]).trim() }
fn _json_escape(s: string) -> string { return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") }
fn _load_config(p: string) { if !_file_exists(p) { eprintln("ps_5: config missing"); exit(2) }; return json_parse(read_file(p)) }
fn _cfg_str(cfg, k, d) -> string { if cfg.contains_key(k) { return to_string(cfg[k]) }; return d }
fn _argv() -> array { let a = args(); let mut o = []; let mut i = 2; while i < len(a) { o.push(a[i]); i = i + 1 }; return o }
fn _flag(av, k) -> bool { for x in av { if to_string(x) == k { return true } }; return false }
fn _opt(av, k, d) -> string { let mut i = 0; while i < len(av) { if to_string(av[i]) == k && i + 1 < len(av) { return to_string(av[i + 1]) }; i = i + 1 }; return d }
fn _issue_path(cfg, id) -> string { return _cfg_str(cfg, "issue_state_dir", "/Users/ghost/core/anima/state/issues") + "/" + id + ".json" }

fn _replace_array_inline(body, key, inline) -> string {
    let needle = "\"" + key + "\": ["
    let i = body.index_of(needle)
    if i < 0 { return body }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let e = rest.index_of("]")
    if e < 0 { return body }
    return body.substring(0, j) + inline + rest.substring(e, len(rest))
}
fn _replace_field_int(body, key, v) -> string {
    let needle = "\"" + key + "\": "
    let i = body.index_of(needle)
    if i < 0 { return body }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let mut k = 0
    while k < len(rest) { let ch = rest.substring(k, k + 1); if ch == "," || ch == "\n" || ch == "}" { break }; k = k + 1 }
    return body.substring(0, j) + to_string(v) + rest.substring(k, len(rest))
}
fn _replace_field_str(body, key, v) -> string {
    let needle = "\"" + key + "\": \""
    let i = body.index_of(needle)
    if i < 0 { return body }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let e = rest.index_of("\"")
    if e < 0 { return body }
    return body.substring(0, j) + _json_escape(v) + rest.substring(e, len(rest))
}

// Extract inline array (between "key": [ ... ]) as raw string payload.
fn _extract_array_inline(body, key) -> string {
    let needle = "\"" + key + "\": ["
    let i = body.index_of(needle)
    if i < 0 { return "" }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let e = rest.index_of("]")
    if e < 0 { return "" }
    return rest.substring(0, e)
}

// Split payload like `"a", "b", "c"` → ["a","b","c"]
fn _parse_str_array(payload: string) -> array {
    let mut out = []
    let n = len(payload)
    let mut i = 0
    while i < n {
        let ch = payload.substring(i, i + 1)
        if ch == "\"" {
            let mut j = i + 1
            let mut val = ""
            while j < n {
                let c2 = payload.substring(j, j + 1)
                if c2 == "\"" { break }
                val = val + c2
                j = j + 1
            }
            out.push(val)
            i = j + 1
        } else {
            i = i + 1
        }
    }
    return out
}

fn scaffold(cfg, id: string) -> int {
    let path = _issue_path(cfg, id)
    if !_file_exists(path) { eprintln("ps_5: missing " + id); return 2 }
    let body = read_file(path)
    let split_payload = _extract_array_inline(body, "unix_split")
    let files = _parse_str_array(split_payload)
    let mut inline = ""
    let mut i = 0
    while i < len(files) {
        let comma = if i + 1 < len(files) { ", " } else { "" }
        let fn_name = to_string(files[i])
        let entry = "{\"file\": \"" + _json_escape(fn_name) + "\", \"planned\": true, \"assertion\": \"self-test PASS\"}"
        inline = inline + entry + comma
        i = i + 1
    }
    let mut b2 = _replace_array_inline(body, "selftests", inline)
    b2 = _replace_field_str(b2, "updated", _ts_iso())
    b2 = _replace_field_int(b2, "current_step", 6)
    write_file(path, b2)
    println("ps_5_selftest_scaffold: issue=" + id + " scaffolds=" + to_string(len(files)) + " → step 6")
    return 0
}

fn self_test(cfg) -> int {
    println("── ps_5_selftest_scaffold self-test ──")
    let tid = "SELFTEST-PS5"
    let p = _issue_path(cfg, tid)
    let _r = exec_with_status("rm -f " + _sh_quote(p))
    write_file(p, "{\n  \"issue_id\": \"" + tid + "\",\n  \"unix_split\": [\"a.hexa\", \"b.hexa\"],\n  \"selftests\": [],\n  \"current_step\": 5,\n  \"updated\": \"\"\n}\n")
    let rc = scaffold(cfg, tid)
    if rc != 0 { return 1 }
    let b2 = read_file(p)
    if b2.index_of("a.hexa") < 0 || b2.index_of("planned") < 0 { eprintln("  FAIL scaffolds missing"); return 1 }
    if b2.index_of("\"current_step\": 6") < 0 { eprintln("  FAIL step != 6"); return 1 }
    let _c = exec_with_status("rm -f " + _sh_quote(p))
    println("  PASS: 2 scaffolds planned, step=6")
    return 0
}

fn main() -> int {
    let av = _argv()
    if _flag(av, "--help") { println("usage: hexa tool/ps_5_selftest_scaffold.hexa --issue <id>"); return 0 }
    let cfg = _load_config(_opt(av, "--config", DEFAULT_CONFIG))
    if _flag(av, "self-test") || _flag(av, "--self-test") { return self_test(cfg) }
    let id = _opt(av, "--issue", "")
    if id == "" { eprintln("--issue required"); return 2 }
    return scaffold(cfg, id)
}
