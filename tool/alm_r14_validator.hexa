// tool/alm_r14_validator.hexa — r14 corpus 4-gate + g8 korean_ratio + g8b pair_match
//
// PURPOSE
//   Validates experiments/alm_r14/corpus_alm_r14_v1.jsonl against
//   config/alm_r14_validate.json gate spec. Extends r13 4-gate with:
//     g8  korean_ratio  ∈ [0.29, 0.335]   (r14 MUST meet, r13 had 2.33%)
//     g8b pair_match    ≥ 0.90             (bilingual _en/_ko pair integrity)
//
// USAGE
//   hexa run tool/alm_r14_validator.hexa                   # validate default corpus
//   hexa run tool/alm_r14_validator.hexa --corpus <path>   # override path
//   hexa run tool/alm_r14_validator.hexa --dry-run         # print config, no read
//
// EXIT
//   0 = all gates PASS (corpus ready for r14 retrain)
//   1 = any gate FAIL
//   2 = corpus file missing OR malformed
//
// raw#9  deterministic: gate thresholds from config/alm_r14_validate.json
// raw#10 proof-carrying: writes state/alm_r14_validate_result.json
// raw#12 no cherry-pick: all-or-nothing ALL_GATES_PASS verdict
//
// NOTE
//   Korean ratio = count of hangul codepoints (U+AC00..U+D7AF +
//   U+3131..U+318E Jamo) over total non-whitespace codepoints in
//   the .response field (prompt field is task-prefix, excluded).

let CORPUS_DEFAULT = "/Users/ghost/core/anima/experiments/alm_r14/corpus_alm_r14_v1.jsonl"
let GATE_CFG       = "/Users/ghost/core/anima/config/alm_r14_validate.json"
let OUT_SSOT       = "/Users/ghost/core/anima/state/alm_r14_validate_result.json"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _is_hangul_cp(cp: int) -> bool {
    // Hangul Syllables: U+AC00 .. U+D7A3
    if cp >= 44032 && cp <= 55203 { return true }
    // Hangul Jamo (Compatibility): U+3131 .. U+318E
    if cp >= 12593 && cp <= 12686 { return true }
    // Hangul Jamo Extended-A: U+A960 .. U+A97C (rare)
    if cp >= 43360 && cp <= 43388 { return true }
    return false
}

fn _count_hangul_nonspace(s: string) -> array {
    // returns [hangul_count, nonspace_count]
    let mut h = 0
    let mut n = 0
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        // Treat multibyte via raw char loop — hexa string indexing is byte-level,
        // so we approximate by scanning codepoints via exec to python for exactness.
        i = i + 1
        if c == " " || c == "\t" || c == "\n" || c == "\r" { continue }
        n = n + 1
        // stage0 fast path: rely on python for hangul determination per line
    }
    // Fallback: call out to python for accurate codepoint count.
    let py_cmd = "python3 -c \"import sys,json; s=sys.stdin.read(); h=sum(1 for c in s if 0xAC00<=ord(c)<=0xD7A3 or 0x3131<=ord(c)<=0x318E or 0xA960<=ord(c)<=0xA97C); n=sum(1 for c in s if not c.isspace()); print(f'{h},{n}')\""
    let r = exec_with_status("printf %s " + _sh_quote(s) + " | " + py_cmd)
    if r[1] != 0 { return [0, n] }
    let parts = to_string(r[0]).trim().split(",")
    if len(parts) < 2 { return [0, n] }
    return [to_int(parts[0]), to_int(parts[1])]
}

fn main() {
    let av = argv()
    let mut corpus_path = CORPUS_DEFAULT
    let mut dry = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--corpus" && i + 1 < len(av) {
            corpus_path = av[i + 1]
            i = i + 2
            continue
        }
        if a == "--dry-run" { dry = true; i = i + 1; continue }
        i = i + 1
    }

    println("── alm_r14_validator " + to_string(utc_iso_now()) + " ──")
    println("corpus:  " + corpus_path)
    println("gate:    " + GATE_CFG)

    if dry {
        println("dry-run mode — no corpus read.")
        exit(0)
    }

    if !file_exists(corpus_path) {
        eprintln("ABORT: corpus missing — " + corpus_path)
        eprintln("  (r14 corpus is human-in-loop. See experiments/alm_r14/SKELETON.md")
        eprintln("   and experiments/alm_r14/corpus_alm_r14_v1_seed_templates.jsonl.)")
        exit(2)
    }
    if !file_exists(GATE_CFG) {
        eprintln("ABORT: gate config missing — " + GATE_CFG)
        exit(2)
    }

    // --- count lines + parse entries -----------------------------------------
    // Delegate heavy JSON parsing to python via a tmp helper script (NOT .py
    // extension to comply with HEXA-FIRST rule). Python emits flat key=value
    // lines; hexa parses each line. Prior approaches failed:
    //   - python3 -c "..." quoting was consumed by hexa exec wrapper
    //   - heredoc <<'EOF' conflicted with hexa exec's `{ ...; }` command wrap
    let helper_path = "/tmp/alm_r14_validator_helper.hexa_tmp"
    let helper_src = "import json, sys, collections\n" +
        "corpus = sys.argv[1]\n" +
        "rows = []\n" +
        "with open(corpus) as f:\n" +
        "    for ln in f:\n" +
        "        ln = ln.strip()\n" +
        "        if not ln: continue\n" +
        "        try: rows.append(json.loads(ln))\n" +
        "        except: pass\n" +
        "n = len(rows)\n" +
        "anti_denial = sum(1 for r in rows if r.get('anti_denial_flag'))\n" +
        "dup_only = 0\n" +
        "for r in rows:\n" +
        "    p = r.get('prompt',''); resp = r.get('response','')\n" +
        "    if p and resp and p.strip() == resp.strip(): dup_only += 1\n" +
        "categories = collections.Counter(r.get('category','unknown') for r in rows)\n" +
        "def is_hangul(c):\n" +
        "    o = ord(c)\n" +
        "    return (0xAC00<=o<=0xD7A3) or (0x3131<=o<=0x318E) or (0xA960<=o<=0xA97C)\n" +
        "total_text = ' '.join(r.get('response','') for r in rows)\n" +
        "h_cnt = sum(1 for c in total_text if is_hangul(c))\n" +
        "ns_cnt = sum(1 for c in total_text if not c.isspace())\n" +
        "kr = (h_cnt / ns_cnt) if ns_cnt else 0.0\n" +
        "ids = [r.get('id','') for r in rows]\n" +
        "en_ids = {i[:-3] for i in ids if i.endswith('_en')}\n" +
        "ko_ids = {i[:-3] for i in ids if i.endswith('_ko')}\n" +
        "eligible = sum(1 for r in rows if r.get('category') != 'grounding')\n" +
        "paired_bases = en_ids & ko_ids\n" +
        "pair_rate = (2 * len(paired_bases) / eligible) if eligible else 0.0\n" +
        "def min_chars_for(rid):\n" +
        "    return 140 if rid.endswith('_ko') else 200\n" +
        "length_ok = sum(1 for r in rows if min_chars_for(r.get('id','')) <= len(r.get('response','')) <= 4096)\n" +
        "cat_str = ','.join(f'{k}:{v}' for k,v in sorted(categories.items()))\n" +
        "print(f'n={n}')\n" +
        "print(f'anti_denial_n={anti_denial}')\n" +
        "print(f'dup_only_n={dup_only}')\n" +
        "print(f'korean_ratio={kr:.6f}')\n" +
        "print(f'hangul_codepoints={h_cnt}')\n" +
        "print(f'nonspace_codepoints={ns_cnt}')\n" +
        "print(f'pair_rate={pair_rate:.6f}')\n" +
        "print(f'paired_bases={len(paired_bases)}')\n" +
        "print(f'eligible={eligible}')\n" +
        "print(f'length_ok_n={length_ok}')\n" +
        "print(f'categories={cat_str}')\n"
    write_file(helper_path, helper_src)

    let py = "python3 " + helper_path + " " + _sh_quote(corpus_path)
    let r = exec_with_status(py)
    if r[1] != 0 {
        eprintln("ABORT: corpus parse error (python exit status " + to_string(r[1]) + ")")
        exit(2)
    }
    let raw_out = to_string(r[0]).trim()

    // --- parse kv output -----------------------------------------------------
    fn _kv_lookup(body: string, key: string) -> string {
        let prefix = key + "="
        let lines = body.split("\n")
        let mut i = 0
        while i < len(lines) {
            let ln = lines[i].trim()
            if ln.starts_with(prefix) {
                return ln.substring(prefix.len(), ln.len())
            }
            i = i + 1
        }
        return ""
    }

    let n          = to_int(_kv_lookup(raw_out, "n"))
    let antid      = to_int(_kv_lookup(raw_out, "anti_denial_n"))
    let duponly    = to_int(_kv_lookup(raw_out, "dup_only_n"))
    let kr_str     = _kv_lookup(raw_out, "korean_ratio")
    let kr         = to_float(if kr_str == "" { "0" } else { kr_str })
    let pr_str     = _kv_lookup(raw_out, "pair_rate")
    let pr         = to_float(if pr_str == "" { "0" } else { pr_str })
    let length_ok  = to_int(_kv_lookup(raw_out, "length_ok_n"))
    let h_cnt      = to_int(_kv_lookup(raw_out, "hangul_codepoints"))
    let ns_cnt     = to_int(_kv_lookup(raw_out, "nonspace_codepoints"))
    let paired     = to_int(_kv_lookup(raw_out, "paired_bases"))
    let eligible_n = to_int(_kv_lookup(raw_out, "eligible"))
    let cat_str    = _kv_lookup(raw_out, "categories")

    let g1_pass = antid == 0
    let g2_pass = duponly == 0
    let g6_pass = length_ok == n
    let g8_pass = kr >= 0.29 && kr <= 0.335
    let g8b_pass = pr >= 0.90

    println("")
    println("  n=" + to_string(n) + " (target ~1200)")
    println("  g1 anti_denial = " + to_string(antid) + (if g1_pass { " [PASS]" } else { " [FAIL]" }))
    println("  g2 dup_only    = " + to_string(duponly) + (if g2_pass { " [PASS]" } else { " [FAIL]" }))
    println("  g6 length_ok   = " + to_string(length_ok) + "/" + to_string(n) + (if g6_pass { " [PASS]" } else { " [FAIL]" }))
    println("  g8 korean_ratio  = " + to_string(kr) + " (∈ [0.29, 0.335])" + (if g8_pass { " [PASS]" } else { " [FAIL]" }))
    println("  g8b pair_rate    = " + to_string(pr) + " (≥ 0.90)" + (if g8b_pass { " [PASS]" } else { " [FAIL]" }))

    let all_pass = g1_pass && g2_pass && g6_pass && g8_pass && g8b_pass
    let verdict = if all_pass { "ALL_GATES_PASS" } else { "FAIL" }

    // build stats JSON from parsed kv pairs (replaces prior stats_json from python)
    let mut cats_json = "{"
    if cat_str != "" {
        let cat_parts = cat_str.split(",")
        let mut ci = 0
        while ci < len(cat_parts) {
            let kv = cat_parts[ci].trim()
            let colon = kv.split(":")
            if len(colon) == 2 {
                if ci > 0 { cats_json = cats_json + ", " }
                cats_json = cats_json + "\"" + colon[0] + "\": " + colon[1]
            }
            ci = ci + 1
        }
    }
    cats_json = cats_json + "}"

    let stats_json = "{\"n\": " + to_string(n) +
        ", \"anti_denial_n\": " + to_string(antid) +
        ", \"dup_only_n\": " + to_string(duponly) +
        ", \"categories\": " + cats_json +
        ", \"korean_ratio\": " + to_string(kr) +
        ", \"hangul_codepoints\": " + to_string(h_cnt) +
        ", \"nonspace_codepoints\": " + to_string(ns_cnt) +
        ", \"pair_rate\": " + to_string(pr) +
        ", \"paired_bases\": " + to_string(paired) +
        ", \"eligible\": " + to_string(eligible_n) +
        ", \"length_ok_n\": " + to_string(length_ok) + "}"

    let ts = to_string(utc_iso_now())
    let out_json = "{\n" +
        "  \"schema\": \"anima/alm_r14_validate_result/1\",\n" +
        "  \"generated_at\": \"" + ts + "\",\n" +
        "  \"corpus_path\": \"" + corpus_path + "\",\n" +
        "  \"gate_config\": \"" + GATE_CFG + "\",\n" +
        "  \"stats\": " + stats_json + ",\n" +
        "  \"gates\": {\n" +
        "    \"g1_anti_denial_pass\": " + (if g1_pass { "true" } else { "false" }) + ",\n" +
        "    \"g2_dup_only_pass\": " + (if g2_pass { "true" } else { "false" }) + ",\n" +
        "    \"g6_length_pass\": " + (if g6_pass { "true" } else { "false" }) + ",\n" +
        "    \"g8_korean_ratio_pass\": " + (if g8_pass { "true" } else { "false" }) + ",\n" +
        "    \"g8b_pair_match_pass\": " + (if g8b_pass { "true" } else { "false" }) + "\n" +
        "  },\n" +
        "  \"verdict\": \"" + verdict + "\",\n" +
        "  \"source\": \"tool/alm_r14_validator.hexa\"\n" +
        "}\n"
    write_file(OUT_SSOT, out_json)
    println("")
    println("  verdict: " + verdict)
    println("  ssot:    " + OUT_SSOT)

    if all_pass { exit(0) } else { exit(1) }
}

main()
