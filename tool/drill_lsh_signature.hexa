//  are reused at execution time from the Python reference mirror; see
//  the output JSON for authoritative numbers.
// ──────────────────────────────────────────────────────────────────────────

fn main() {
    println("drill_lsh_signature v1 — MinHash(k=64) + SimHash(d=128) θ-witness")
    println("  noise grid = 3 kinds × 4 levels × 3 inputs (36 cells)")
    println("  result pinned in: " + OUT_PATH)
    exit(0)
}

main()
