// tool/anima_eeg_brainflow_ingest.hexa — BrainFlow live-stream EEG ingest (raw#9 hexa-only, raw#37 emit).
//
// PURPOSE
//   OpenBCI Cyton+Daisy 16ch (125Hz canonical, 24-bit) live capture via BrainFlow SDK.
//   Synthetic mode (no hardware) and Cyton mode (auto-detect serial port).
//   Output: state/eeg_recording_<id>.json (schema: anima/eeg_recording/1) — same
//   schema as tool/an11_b_eeg_ingest.hexa so downstream verifiers (V_phen_LZ,
//   V_phen_GWT) can consume both post-recording (BDF/EDF) and live-stream paths.
//
// MODES
//   --selftest                     synthetic 16ch × 10s dry-run (BrainFlow SYNTHETIC=250Hz), no hardware
//   --mode synthetic               BrainFlow SYNTHETIC_BOARD stream (BoardIds=-1)
//   --mode cyton  --serial <port>  OpenBCI Cyton+Daisy via FTDI dongle (BoardIds=2)
//
// FLAGS
//   --duration <sec>               capture window seconds (default: 10)
//   --output <path.json>           output JSON path (required for non-selftest)
//   --serial <port>                serial port (e.g. /dev/cu.usbserial-DM00Q0QO)
//
// HARDWARE NOTES
//   - Cyton+Daisy uses BoardIds.CYTON_DAISY_BOARD = 2.
//   - macOS: requires FTDI VCP driver if dongle not enumerated as /dev/cu.usbserial-*.
//     Verify: ls /dev/cu.usbserial* — if missing, install FTDI VCP from ftdichip.com.
//   - Cyton+Daisy 16ch native sample rate = 125Hz per BrainFlow API
//     (BoardShim.get_sampling_rate(BoardIds.CYTON_DAISY_BOARD)). Not 250Hz.
//     SYNTHETIC_BOARD = 250Hz, CYTON 8ch = 250Hz, GANGLION 4ch = 200Hz.
//   - Helper queries fs dynamically via BoardShim.get_sampling_rate(bid)
//     — never hardcode. Selftest asserts mode-dependent expected fs.
//   - First 16 EEG channel indices in BoardShim.get_eeg_channels(2).
//
// raw#10 honest scope
//   - Hardware D-1 prep — synthetic dry-run validates pipeline only.
//   - Cyton mode 코드 경로는 작성하지만 실제 hardware 도착 후 검증.
//   - phenomenal correlate 측정용 prototype, Hard Problem 우회 X.
//
// PAIRS
//   tool/an11_b_eeg_ingest.hexa                   post-recording BDF/EDF/FIF ingest (MNE)
//   anima-clm-eeg/tool/clm_eeg_synthetic_fixture.hexa  hexa-native deterministic fixture
//   docs/eeg_cross_substrate_validation_plan_20260425.md  CP2 P1-P3 spec
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_eeg_brainflow_helper.hexa_tmp"
let SCHEMA      = "anima/eeg_recording/1"
let SPEC_DOC    = "docs/eeg_cross_substrate_validation_plan_20260425.md §1, §6.3"
let VENV_PY     = "/Users/ghost/core/anima/.venv-eeg/bin/python3"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let src = "#!/usr/bin/env python3\n" +
        "# auto-generated by tool/anima_eeg_brainflow_ingest.hexa (raw#37 transient)\n" +
        "import json, sys, os, time, datetime\n" +
        "import numpy as np\n" +
        "\n" +
        "HAVE_BRAINFLOW = False\n" +
        "BRAINFLOW_VERSION = None\n" +
        "BRAINFLOW_IMPORT_ERR = None\n" +
        "try:\n" +
        "    from brainflow.board_shim import BoardShim, BrainFlowInputParams, BoardIds\n" +
        "    import brainflow as _bf\n" +
        "    HAVE_BRAINFLOW = True\n" +
        "    # brainflow 5.21+ removed module-level __version__; use importlib.metadata.\n" +
        "    BRAINFLOW_VERSION = getattr(_bf, '__version__', None)\n" +
        "    if BRAINFLOW_VERSION is None:\n" +
        "        try:\n" +
        "            from importlib.metadata import version as _v\n" +
        "            BRAINFLOW_VERSION = _v('brainflow')\n" +
        "        except Exception:\n" +
        "            BRAINFLOW_VERSION = 'unknown'\n" +
        "except Exception as _e:\n" +
        "    BRAINFLOW_IMPORT_ERR = str(_e)\n" +
        "\n" +
        "def now_iso():\n" +
        "    return datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n" +
        "\n" +
        "def board_id_for(mode):\n" +
        "    if mode == 'synthetic':\n" +
        "        return BoardIds.SYNTHETIC_BOARD.value  # -1, fs=250Hz\n" +
        "    if mode == 'cyton':\n" +
        "        return BoardIds.CYTON_DAISY_BOARD.value  # 2, fs=125Hz (native, NOT 250)\n" +
        "    raise ValueError(f'unknown mode: {mode}; expected synthetic|cyton')\n" +
        "\n" +
        "def expected_fs(mode):\n" +
        "    # Authoritative: BrainFlow API. SYNTHETIC=250, CYTON_DAISY=125.\n" +
        "    return float(BoardShim.get_sampling_rate(board_id_for(mode)))\n" +
        "\n" +
        "def capture(mode, serial_port, duration_s):\n" +
        "    if not HAVE_BRAINFLOW:\n" +
        "        print('ABORT_NO_BRAINFLOW: pip install brainflow', file=sys.stderr); sys.exit(3)\n" +
        "    params = BrainFlowInputParams()\n" +
        "    if serial_port: params.serial_port = serial_port\n" +
        "    bid = board_id_for(mode)\n" +
        "    board = BoardShim(bid, params)\n" +
        "    fs = float(BoardShim.get_sampling_rate(bid))\n" +
        "    eeg_chans = BoardShim.get_eeg_channels(bid)\n" +
        "    eeg_names = list(BoardShim.get_eeg_names(bid))[:16]\n" +
        "    if len(eeg_chans) < 16:\n" +
        "        print(f'WARN: board exposes only {len(eeg_chans)} EEG channels; padding with zeros', file=sys.stderr)\n" +
        "    board.prepare_session()\n" +
        "    board.start_stream()\n" +
        "    time.sleep(float(duration_s))\n" +
        "    raw_all = board.get_board_data()\n" +
        "    board.stop_stream(); board.release_session()\n" +
        "    chans = eeg_chans[:16]\n" +
        "    eeg = raw_all[chans, :].astype(np.float32)\n" +
        "    if eeg.shape[0] < 16:\n" +
        "        pad = np.zeros((16 - eeg.shape[0], eeg.shape[1]), dtype=np.float32)\n" +
        "        eeg = np.vstack([eeg, pad])\n" +
        "        eeg_names = eeg_names + [f'PAD{i}' for i in range(16 - len(eeg_names))]\n" +
        "    return {\n" +
        "        'channels': eeg_names[:16],\n" +
        "        'channel_positions': None,\n" +
        "        'sample_rate': fs,\n" +
        "        'raw_arrays': eeg.tolist(),\n" +
        "        'metadata': {\n" +
        "            'recording_duration_s': float(eeg.shape[1]) / fs if fs > 0 else 0.0,\n" +
        "            'reference': 'brainflow_default',\n" +
        "            'filtering_applied': False,\n" +
        "            'filter_band_hz': None,\n" +
        "            'ica_applied': False,\n" +
        "            'asr_applied': False,\n" +
        "            'timestamp': now_iso(),\n" +
        "            'source_format': 'brainflow_live',\n" +
        "            'source_path': f'<brainflow:{mode}:{serial_port or \"\"}>',\n" +
        "            'brainflow_version': BRAINFLOW_VERSION,\n" +
        "            'board_id': board_id_for(mode),\n" +
        "            'channel_count': 16,\n" +
        "            'sample_count': int(eeg.shape[1])\n" +
        "        }\n" +
        "    }\n" +
        "\n" +
        "def cmd_run(mode, serial_port, duration_s, output_path, schema, spec_doc):\n" +
        "    out = capture(mode, serial_port, duration_s)\n" +
        "    out['schema'] = schema\n" +
        "    out['spec_doc'] = spec_doc\n" +
        "    out['mode'] = mode\n" +
        "    out['raw10_honest'] = 'BrainFlow live-stream prototype; phenomenal correlate only; Hard Problem 우회 X'\n" +
        "    with open(output_path, 'w') as f: json.dump(out, f, indent=2)\n" +
        "    print(f'output_path={output_path}')\n" +
        "    print(f'channels={out[\"metadata\"][\"channel_count\"]}')\n" +
        "    print(f'sample_rate={out[\"sample_rate\"]}')\n" +
        "    print(f'samples={out[\"metadata\"][\"sample_count\"]}')\n" +
        "    print(f'duration_s={out[\"metadata\"][\"recording_duration_s\"]:.3f}')\n" +
        "    print(f'mode={mode}')\n" +
        "    print(f'board_id={out[\"metadata\"][\"board_id\"]}')\n" +
        "    print(f'brainflow_version={BRAINFLOW_VERSION}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def cmd_selftest():\n" +
        "    if not HAVE_BRAINFLOW:\n" +
        "        print(f'brainflow_available=False'); print(f'import_err={BRAINFLOW_IMPORT_ERR}')\n" +
        "        print('selftest=skip'); print('DONE'); return\n" +
        "    out = capture('synthetic', '', 10.0)\n" +
        "    eeg = np.array(out['raw_arrays'], dtype=np.float32)\n" +
        "    fs_expected = expected_fs('synthetic')\n" +
        "    min_frames = int(0.95 * fs_expected * 10)\n" +
        "    assert eeg.shape[0] == 16, f'channel count != 16: {eeg.shape[0]}'\n" +
        "    assert eeg.shape[1] >= min_frames, f'frame count too low: {eeg.shape[1]} (expected ~{int(fs_expected*10)})'\n" +
        "    assert out['sample_rate'] == fs_expected, f'sample rate != {fs_expected}: {out[\"sample_rate\"]}'\n" +
        "    per_ch_std = [float(np.std(eeg[i])) for i in range(16)]\n" +
        "    nonzero = sum(1 for s in per_ch_std if s > 0.0)\n" +
        "    assert nonzero >= 14, f'too few nonzero channels: {nonzero}/16'\n" +
        "    print(f'selftest=ok')\n" +
        "    print(f'brainflow_available=True')\n" +
        "    print(f'brainflow_version={BRAINFLOW_VERSION}')\n" +
        "    print(f'channels={eeg.shape[0]}')\n" +
        "    print(f'sample_rate={out[\"sample_rate\"]}')\n" +
        "    print(f'samples={eeg.shape[1]}')\n" +
        "    print(f'nonzero_channels={nonzero}')\n" +
        "    print(f'mean_std={float(np.mean(per_ch_std)):.3f}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def main():\n" +
        "    if len(sys.argv) < 2:\n" +
        "        print('usage: helper <run|selftest> ...', file=sys.stderr); sys.exit(2)\n" +
        "    op = sys.argv[1]\n" +
        "    if op == 'run':\n" +
        "        # mode serial_port duration output schema spec_doc\n" +
        "        cmd_run(sys.argv[2], sys.argv[3], float(sys.argv[4]), sys.argv[5], sys.argv[6], sys.argv[7])\n" +
        "    elif op == 'selftest':\n" +
        "        cmd_selftest()\n" +
        "    else:\n" +
        "        print(f'unknown op: {op}', file=sys.stderr); sys.exit(2)\n" +
        "\n" +
        "if __name__ == '__main__': main()\n"
    write_file(HELPER_PATH, src)
}

fn _run_helper(args: string) -> list {
    let cmd = VENV_PY + " " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut mode = "synthetic"
    let mut serial_port = ""
    let mut duration = "10"
    let mut output = ""
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--mode" && i + 1 < len(av) { mode = av[i+1]; i = i + 2; continue }
        if a == "--serial" && i + 1 < len(av) { serial_port = av[i+1]; i = i + 2; continue }
        if a == "--duration" && i + 1 < len(av) { duration = av[i+1]; i = i + 2; continue }
        if a == "--output" && i + 1 < len(av) { output = av[i+1]; i = i + 2; continue }
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── anima_eeg_brainflow_ingest selftest (synthetic 10s) ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED (exit " + to_string(r[1]) + ")"); exit(1) }
        let marker = _kv_lookup(r[0], "selftest")
        if marker != "ok" && marker != "skip" {
            eprintln("selftest marker missing or invalid: " + marker); exit(1)
        }
        if marker == "skip" {
            eprintln("WARN: brainflow not installed in venv " + VENV_PY)
            eprintln("HINT: " + VENV_PY + " -m pip install brainflow")
            exit(2)
        }
        println("selftest: OK")
        exit(0)
    }

    if output == "" {
        eprintln("ABORT: --output <path.json> required (or --selftest).")
        exit(2)
    }
    if mode != "synthetic" && mode != "cyton" {
        eprintln("ABORT: --mode must be synthetic|cyton (got " + mode + ").")
        exit(2)
    }
    if mode == "cyton" && serial_port == "" {
        eprintln("ABORT: --serial <port> required for cyton mode.")
        eprintln("HINT: ls /dev/cu.usbserial-* (FTDI VCP driver required on macOS)")
        exit(2)
    }

    println("── anima_eeg_brainflow_ingest ──")
    println("mode:     " + mode)
    println("serial:   " + serial_port)
    println("duration: " + duration + "s")
    println("output:   " + output)

    let args = "run " +
        _sh_quote(mode) + " " +
        _sh_quote(serial_port) + " " +
        _sh_quote(duration) + " " +
        _sh_quote(output) + " " +
        _sh_quote(SCHEMA) + " " +
        _sh_quote(SPEC_DOC)
    let r = _run_helper(args)
    let out = r[0]
    let st  = r[1]
    if st == 3 {
        eprintln(out)
        eprintln("HINT: " + VENV_PY + " -m pip install brainflow")
        exit(3)
    }
    if st != 0 { eprintln("ABORT: helper run exited " + to_string(st)); eprintln(out); exit(2) }
    println(out)
    println("")
    println("wrote " + output)
    exit(0)
}

