// ════════════════════════════════════════════════════════════════════════════
//  tool/anima_dali_sli_v2_redesign.hexa
//
//  PURPOSE  (Mk.XII v2 §4 weighted-vote remediation candidate #2 —
//            substrate-aware metric redesign, mode-grouped DALI/SLI v2)
//
//    CONTEXT
//      이전 cycle:
//        anima_dali_sli_coupled.hexa     → JOINT_FAIL (DALI_min=236, SLI=240, COUPLED=237)
//        dali_sli_weighted_vote.hexa     → NOT_ELIGIBLE (4-bb weighted_score=237 < floor 250)
//      .roadmap #145 진단:
//        substrate backbone-conditional. CMT family-processing locus
//        backbone fundamentally different (Mistral late 87% vs Qwen3 early 11%).
//        S7 N=10 결과: 3-mode topology
//          mode 0 (input,  norm 0..50‰)  : small-2B backbones (Qwen2.5-1.5B / gemma2-2B) - sentinel
//          mode 1 (early,  norm 51..500‰): Qwen3 / Llama-mid
//          mode 2 (late,   norm 501..1000‰): Mistral / gemma-r14 / Llama-Hexad
//
//    REDESIGN HYPOTHESIS
//      DALI v2:
//        backbone-pair 비교 시 mode 그룹화 적용. intra-mode 비교만 valid,
//        inter-mode pair 는 NOT_APPLICABLE (mode-specific evidence 분리).
//        intra-mode DALI_min >= 700 if mode_size >= 2 else N/A.
//      SLI v2:
//        cusp_depth std/mean → mode 內 CV 측정. intra-mode CV <= 0.40
//        (intra-mode SLI >= 600).
//      COUPLED v2:
//        per-mode weighted_score = (400*intra_dali + 400*intra_sli + 200*coupled_intra) /1000
//        all-mode (size>=2) PASS ⇒ GREEN, partial ⇒ AMBER, none ⇒ FAIL.
//
//    Mk.XII §4 chain integration 자격
//      eligible_for_chain_integration =
//        (mode-eligible >= 1) AND (all eligible modes intra_pass)
//        AND (negative falsifier discriminates).
//      partial = (some mode pass, some fail)
//      not_eligible = (no mode pass)
//
//  RAW#9
//    pure hexa · deterministic · cmt.json read-only · no Python · no destructive
//    integer fixed-point ×1000 · byte-identical re-run (mod timestamp)
//
//  POSITIVE SELFTEST
//    4 backbone real cmt.json reuse. 측정값:
//      family_loc = [875, 111, 625, 857]  (Mistral, Qwen3, Llama, gemma)
//      cusp_depth = [875, 111, 125, 857]
//    mode 그룹화:
//      mode 0 (input  0..50)   : []                        (size 0, N/A)
//      mode 1 (early 51..500)  : [Qwen3, Llama(125)]       — cusp-based
//      mode 2 (late 501..1000) : [Mistral, Llama(625), gemma]
//    NOTE: Llama 의 family_loc(625) vs cusp_depth(125) 가 mode 분리 — 본 tool 은
//          family_loc-mode 와 cusp_depth-mode 를 따로 grouping (DALI 는 family_loc
//          기준, SLI 는 cusp_depth 기준). 동일 backbone 이 다른 axis 에서 다른
//          mode 일 수 있음 (raw#10 honest declaration).
//
//  NEGATIVE FALSIFY
//    single backbone outlier injection (N=4, 각 backbone 차례로 mode 0 으로 강제):
//      해당 mode 가 size 1 이면 → intra-pass = N/A
//      해당 mode 가 size >= 2 이지만 outlier 가 mode 변경 → mode 재구성 후
//      intra DALI/SLI 가 fail 하는지 확인. 기대: outlier 시 mode-conditional FAIL.
//
//  OUTPUT
//    anima-clm-eeg/state/dali_sli_v2_redesign_v1.json
// ════════════════════════════════════════════════════════════════════════════

let SCALE = 1000
let M32 = 4294967296
let POLY_PRIME = 2654435761

// mode boundary thresholds (×1000 normalized layer position)
let MODE0_HI = 50      // input mode: 0..50
let MODE1_HI = 500     // early mode: 51..500
// mode 2 (late): 501..SCALE

// intra-mode gates (×1000)
let INTRA_DALI_PASS = 700   // worst intra-mode pair >= 0.70
let INTRA_SLI_PASS  = 600   // intra-mode CV <= 0.40 → SLI >= 600
let INTRA_COUPLED_PASS = 600

// per-mode weighted gate
let MODE_WEIGHTED_GATE = 500

// mode-eligibility: minimum size to evaluate
let MODE_MIN_SIZE = 2

// negative discrimination: outlier-induced FAIL rate
let NEG_FAIL_GATE = 500   // expect >= 50% trials FAIL after outlier

fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }
fn now_stamp() -> string { return exec("date +%Y-%m-%dT%H:%M:%S").trim() }

fn str_list_json(xs: list) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(xs) {
        if i > 0 { s = s + "," }
        s = s + "\"" + xs[i] + "\""
        i = i + 1
    }
    return s + "]"
}
fn int_list_json(xs: list) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(xs) {
        if i > 0 { s = s + "," }
        s = s + str(xs[i])
        i = i + 1
    }
    return s + "]"
}

fn f1000(x) -> int {
    let scaled = x * SCALE
    let t = int(scaled)
    if t < 0 { return 0 }
    return t
}

fn isqrt(v: int) -> int {
    if v <= 0 { return 0 }
    let mut x = v
    let mut prev = 0
    let mut iter = 0
    while iter < 32 {
        prev = x
        x = (x + v / x) / 2
        if x == prev { iter = 32 }
        iter = iter + 1
    }
    return x
}

fn abs_int(v: int) -> int {
    if v < 0 { return -v }
    return v
}

// ─── parse cmt.json (mirrors anima_dali_sli_coupled.hexa) ──────────────────
fn read_cusp_depth(cmt_path: string) -> list {
    let raw = read_file(cmt_path)
    let cmt = json_parse(raw)
    let n_layers = cmt["n_layers"]
    let tomo = cmt["tomography"]
    let layer_keys = keys(tomo)

    let mut layer_ints = []
    let mut i = 0
    while i < len(layer_keys) {
        layer_ints = layer_ints.push(int(layer_keys[i]))
        i = i + 1
    }
    let mut sorted = []
    let mut a = 0
    while a < len(layer_ints) {
        let v = layer_ints[a]
        let mut placed = false
        let mut new_sorted = []
        let mut b = 0
        while b < len(sorted) {
            if !placed && v < sorted[b] {
                new_sorted = new_sorted.push(v)
                placed = true
            }
            new_sorted = new_sorted.push(sorted[b])
            b = b + 1
        }
        if !placed { new_sorted = new_sorted.push(v) }
        sorted = new_sorted
        a = a + 1
    }

    let families = ["Hexad", "Law", "Phi", "SelfRef"]
    let mut best_layer = sorted[0]
    let mut best_l2 = -1
    let mut s = 0
    while s < len(sorted) {
        let layer_key = str(sorted[s])
        let layer_obj = tomo[layer_key]
        let mut sum_sq = 0
        let mut f = 0
        while f < 4 {
            let fam_obj = layer_obj[families[f]]
            let abs_v = fam_obj["abs"]
            let av = f1000(abs_v)
            sum_sq = sum_sq + av * av
            f = f + 1
        }
        let l2 = isqrt(sum_sq)
        if l2 > best_l2 {
            best_l2 = l2
            best_layer = sorted[s]
        }
        s = s + 1
    }
    let cusp_x1000 = (best_layer * SCALE) / n_layers
    let mut out = []
    out = out.push(n_layers)
    out = out.push(best_layer)
    out = out.push(cusp_x1000)
    return out
}

fn family_loc_norm(cmt_path: string) -> int {
    let raw = read_file(cmt_path)
    let cmt = json_parse(raw)
    let n_layers = cmt["n_layers"]
    let dom = cmt["dominant_layer_per_family"]
    let families = ["Hexad", "Law", "Phi", "SelfRef"]
    let mut best = 0
    let mut i = 0
    while i < 4 {
        let entry = dom[families[i]]
        let lay = entry["layer"]
        let norm = (lay * SCALE) / n_layers
        if norm > best { best = norm }
        i = i + 1
    }
    return best
}

// ─── mode classifier ──────────────────────────────────────────────────────
//   norm in 0..SCALE → mode index (0,1,2)
fn classify_mode(norm: int) -> int {
    if norm <= MODE0_HI { return 0 }
    if norm <= MODE1_HI { return 1 }
    return 2
}

fn mode_label(m: int) -> string {
    if m == 0 { return "input" }
    if m == 1 { return "early" }
    return "late"
}

// ─── extract subset by mode ───────────────────────────────────────────────
fn subset_by_mode(values: list, modes: list, target_mode: int) -> list {
    let mut out = []
    let mut i = 0
    while i < len(values) {
        if modes[i] == target_mode {
            out = out.push(values[i])
        }
        i = i + 1
    }
    return out
}

fn subset_names_by_mode(names: list, modes: list, target_mode: int) -> list {
    let mut out = []
    let mut i = 0
    while i < len(names) {
        if modes[i] == target_mode {
            out = out.push(names[i])
        }
        i = i + 1
    }
    return out
}

// ─── intra-mode DALI: pair-wise within mode (family_loc) ──────────────────
fn intra_dali_min(family_locs_subset: list) -> int {
    let n = len(family_locs_subset)
    if n < 2 { return SCALE }   // size<2: trivial PASS sentinel (caller checks size)
    let mut min_dali = SCALE
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let d = abs_int(family_locs_subset[i] - family_locs_subset[j])
            let dali = SCALE - d
            if dali < min_dali { min_dali = dali }
            j = j + 1
        }
        i = i + 1
    }
    return min_dali
}

fn list_mean(xs: list) -> int {
    let n = len(xs)
    if n == 0 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n { s = s + xs[i]; i = i + 1 }
    return s / n
}

// ─── intra-mode SLI: cusp_depth CV within mode ────────────────────────────
fn intra_sli(cusp_subset: list) -> int {
    let n = len(cusp_subset)
    if n < 2 { return SCALE }
    let m = list_mean(cusp_subset)
    if m == 0 { return 0 }
    let mut sum_sq_dev = 0
    let mut i = 0
    while i < n {
        let dv = cusp_subset[i] - m
        sum_sq_dev = sum_sq_dev + dv * dv
        i = i + 1
    }
    let var = sum_sq_dev / n
    let std = isqrt(var)
    let cv_x1000 = (std * SCALE) / m
    let mut sli = SCALE - cv_x1000
    if sli < 0 { sli = 0 }
    if sli > SCALE { sli = SCALE }
    return sli
}

fn coupled_metric(d: int, s: int) -> int {
    if d <= 0 || s <= 0 { return 0 }
    let prod = d * s
    return isqrt(prod)
}

fn weighted_score(d: int, s: int, c: int) -> int {
    return (400 * d + 400 * s + 200 * c) / SCALE
}

// ─── per-mode evaluator ───────────────────────────────────────────────────
//   returns [mode_size, intra_dali, intra_sli, intra_coupled, weighted, intra_pass(0/1)]
fn eval_mode(family_locs: list, cusp_depths: list, modes_fl: list, modes_cd: list, target_mode: int) -> list {
    // For DALI use family_loc-based mode subset
    let fl_sub = subset_by_mode(family_locs, modes_fl, target_mode)
    let cd_sub = subset_by_mode(cusp_depths, modes_cd, target_mode)
    let size_fl = len(fl_sub)
    let size_cd = len(cd_sub)
    // Mode-eligible iff both axes have size >= MODE_MIN_SIZE
    let eligible = (size_fl >= MODE_MIN_SIZE) && (size_cd >= MODE_MIN_SIZE)
    let mut intra_d = SCALE
    let mut intra_s = SCALE
    if eligible {
        intra_d = intra_dali_min(fl_sub)
        intra_s = intra_sli(cd_sub)
    }
    let intra_c = coupled_metric(intra_d, intra_s)
    let ws = weighted_score(intra_d, intra_s, intra_c)
    let mut pass_flag = 0
    if eligible {
        let d_ok = intra_d >= INTRA_DALI_PASS
        let s_ok = intra_s >= INTRA_SLI_PASS
        let c_ok = intra_c >= INTRA_COUPLED_PASS
        if d_ok && s_ok && c_ok { pass_flag = 1 }
    }
    let mut out = []
    out = out.push(size_fl)
    out = out.push(size_cd)
    out = out.push(intra_d)
    out = out.push(intra_s)
    out = out.push(intra_c)
    out = out.push(ws)
    out = out.push(pass_flag)
    let mut elig = 0
    if eligible { elig = 1 }
    out = out.push(elig)
    return out
}

fn classify_overall(elig_count: int, pass_count: int) -> string {
    if elig_count == 0 { return "NO_ELIGIBLE_MODE" }
    if pass_count == elig_count { return "ALL_MODES_PASS_GREEN" }
    if pass_count > 0 { return "PARTIAL_AMBER" }
    return "ALL_MODES_FAIL_RED"
}

// ─── synthesize negative outlier: jitter family_loc + cusp_depth simultaneously ─
//   shift backbone by 'amount' (signed) within axis range, keeping mode label
//   if possible. This stresses intra-mode DALI (locus invariance) and SLI (CV)
//   inside the mode the backbone belongs to.
fn outlier_jitter(target_idx: int, base: list, amount: int) -> list {
    let mut out = []
    let mut i = 0
    while i < len(base) {
        if i == target_idx {
            let mut v = base[i] + amount
            if v < 0 { v = 0 }
            if v > SCALE { v = SCALE }
            out = out.push(v)
        } else {
            out = out.push(base[i])
        }
        i = i + 1
    }
    return out
}

// ─── main ───────────────────────────────────────────────────────────────────
fn main() {
    println("[anima_dali_sli_v2_redesign] Mk.XII v2 §4 substrate-aware metric redesign")
    println("  hypothesis: 3-mode topology (input/early/late) → intra-mode comparison only")
    println("  intra DALI gate >=" + str(INTRA_DALI_PASS) + " · intra SLI gate >=" + str(INTRA_SLI_PASS) + " · COUPLED >=" + str(INTRA_COUPLED_PASS))
    println("  mode_min_size=" + str(MODE_MIN_SIZE))
    println("")

    let backbone_names = ["Mistral", "Qwen3", "Llama", "gemma"]
    let cmt_paths = [
        "state/v10_benchmark_v4/mistral/cmt.json",
        "state/v10_benchmark_v4/qwen3/cmt.json",
        "state/v10_benchmark_v4/llama/cmt.json",
        "state/v10_benchmark_v4/gemma/cmt.json"
    ]

    // ─── 1. ingest 4-bb cmt.json ────────────────────────────────────────────
    let mut cusp_depths = []
    let mut family_locs = []
    let mut n_layers_list = []
    let mut peak_layers = []
    let mut n = 0
    while n < 4 {
        let cd = read_cusp_depth(cmt_paths[n])
        n_layers_list = n_layers_list.push(cd[0])
        peak_layers = peak_layers.push(cd[1])
        cusp_depths = cusp_depths.push(cd[2])
        family_locs = family_locs.push(family_loc_norm(cmt_paths[n]))
        n = n + 1
    }

    // ─── 2. mode classification (per-axis) ───────────────────────────────────
    let mut modes_fl = []
    let mut modes_cd = []
    let mut k = 0
    while k < 4 {
        modes_fl = modes_fl.push(classify_mode(family_locs[k]))
        modes_cd = modes_cd.push(classify_mode(cusp_depths[k]))
        k = k + 1
    }

    println("=== positive (4 real cmt.json) — mode classification ===")
    let mut ki = 0
    while ki < 4 {
        let line = "  " + backbone_names[ki]
                 + ": family_loc=" + str(family_locs[ki]) + " mode_fl=" + mode_label(modes_fl[ki])
                 + " | cusp_depth=" + str(cusp_depths[ki]) + " mode_cd=" + mode_label(modes_cd[ki])
        println(line)
        ki = ki + 1
    }
    println("")

    // ─── 3. evaluate each of 3 modes ─────────────────────────────────────────
    let mode_labels = ["input", "early", "late"]
    let mut mode_results = []   // list of result tuples
    let mut elig_count = 0
    let mut pass_count = 0
    let mut m = 0
    while m < 3 {
        let r = eval_mode(family_locs, cusp_depths, modes_fl, modes_cd, m)
        mode_results = mode_results.push(r)
        if r[7] == 1 { elig_count = elig_count + 1 }
        if r[6] == 1 { pass_count = pass_count + 1 }
        let names_fl = subset_names_by_mode(backbone_names, modes_fl, m)
        let names_cd = subset_names_by_mode(backbone_names, modes_cd, m)
        println("=== mode " + str(m) + " (" + mode_labels[m] + ") ===")
        println("  fl_size=" + str(r[0]) + " names_fl=" + str_list_json(names_fl))
        println("  cd_size=" + str(r[1]) + " names_cd=" + str_list_json(names_cd))
        println("  intra_dali=" + str(r[2]) + " intra_sli=" + str(r[3]) + " intra_coupled=" + str(r[4]))
        println("  weighted_score=" + str(r[5]) + " intra_pass=" + bool_s(r[6] == 1) + " eligible=" + bool_s(r[7] == 1))
        m = m + 1
    }
    println("")

    let overall = classify_overall(elig_count, pass_count)
    let positive_pass = (overall == "ALL_MODES_PASS_GREEN")

    println("=== overall positive verdict ===")
    println("  eligible_modes=" + str(elig_count) + " passing_modes=" + str(pass_count))
    println("  verdict=" + overall)
    println("")

    // ─── 4. negative falsify: jitter intra-mode backbone (DALI/SLI stress) ────
    //   For each backbone in an eligible mode, jitter its family_loc & cusp_depth
    //   by ±400 (large enough to break intra-DALI 700 gate). Expect: FAIL.
    //   Only backbones in eligible mode contribute valid trials. We always run
    //   4 trials but tag those with no eligible-mode membership separately.
    let n_neg_trials = 4
    let neg_jitter_amount = 400
    let mut neg_fail_count = 0
    let mut neg_first_overall = ""
    let mut neg_results_list = []
    let mut neg_valid_count = 0

    let mut nt = 0
    while nt < n_neg_trials {
        // determine the family_loc-mode of this backbone in baseline
        let base_mode_fl = modes_fl[nt]
        // Only jitter if backbone belongs to a mode of size >= 2 in fl axis
        // (otherwise jitter moves single-element mode trivially)
        let base_fl_subset = subset_by_mode(family_locs, modes_fl, base_mode_fl)
        let base_cd_subset = subset_by_mode(cusp_depths, modes_cd, modes_cd[nt])
        let base_eligible = (len(base_fl_subset) >= MODE_MIN_SIZE) && (len(base_cd_subset) >= MODE_MIN_SIZE)

        let neg_fl = outlier_jitter(nt, family_locs, neg_jitter_amount)
        let neg_cd = outlier_jitter(nt, cusp_depths, neg_jitter_amount)
        let mut neg_modes_fl = []
        let mut neg_modes_cd = []
        let mut nki = 0
        while nki < 4 {
            neg_modes_fl = neg_modes_fl.push(classify_mode(neg_fl[nki]))
            neg_modes_cd = neg_modes_cd.push(classify_mode(neg_cd[nki]))
            nki = nki + 1
        }
        let mut n_elig = 0
        let mut n_pass = 0
        let mut nm = 0
        while nm < 3 {
            let nr = eval_mode(neg_fl, neg_cd, neg_modes_fl, neg_modes_cd, nm)
            if nr[7] == 1 { n_elig = n_elig + 1 }
            if nr[6] == 1 { n_pass = n_pass + 1 }
            nm = nm + 1
        }
        let n_overall = classify_overall(n_elig, n_pass)
        if nt == 0 { neg_first_overall = n_overall }
        if base_eligible {
            neg_valid_count = neg_valid_count + 1
            if n_overall != "ALL_MODES_PASS_GREEN" { neg_fail_count = neg_fail_count + 1 }
        }
        let mut tag = ""
        if base_eligible { tag = "[valid] " } else { tag = "[trivial] " }
        neg_results_list = neg_results_list.push(tag + n_overall)
        nt = nt + 1
    }
    let mut neg_fail_rate = 0
    if neg_valid_count > 0 { neg_fail_rate = (neg_fail_count * SCALE) / neg_valid_count }
    let neg_detects = neg_valid_count > 0 && neg_fail_rate >= NEG_FAIL_GATE

    println("=== negative falsify (intra-mode jitter ±" + str(neg_jitter_amount) + ", N=" + str(n_neg_trials) + ") ===")
    let mut nri = 0
    while nri < len(neg_results_list) {
        println("  jitter=" + backbone_names[nri] + " → " + neg_results_list[nri])
        nri = nri + 1
    }
    println("  valid_trials=" + str(neg_valid_count) + " FAIL count=" + str(neg_fail_count) + " rate=" + str(neg_fail_rate) + "/1000")
    println("  jitter discriminates (FAIL rate >= " + str(NEG_FAIL_GATE) + "): " + bool_s(neg_detects))
    println("")

    // ─── 5. Mk.XII §4 chain integration eligibility classification ───────────
    let mut elig_class = "NOT_ELIGIBLE"
    if positive_pass && neg_detects { elig_class = "ELIGIBLE" }
    if !positive_pass && pass_count > 0 && neg_detects { elig_class = "PARTIAL_ELIGIBLE" }

    println("=== Mk.XII §4 chain integration eligibility ===")
    println("  positive ALL_PASS: " + bool_s(positive_pass))
    println("  partial mode pass: " + bool_s(pass_count > 0 && pass_count < elig_count))
    println("  negative discriminates: " + bool_s(neg_detects))
    println("  eligibility_class: " + elig_class)
    println("")

    // ─── 6. JSON emit ────────────────────────────────────────────────────────
    let mut out = "{\n"
    out = out + "  \"schema\": \"anima/dali_sli_v2_redesign/1\",\n"
    out = out + "  \"schema_version\": 1,\n"
    out = out + "  \"verifier_type\": \"dali_sli_v2_redesign\",\n"
    out = out + "  \"version\": \"v1\",\n"
    out = out + "  \"generated\": \"" + now_stamp() + "\",\n"
    out = out + "  \"source\": \"tool/anima_dali_sli_v2_redesign.hexa\",\n"
    out = out + "  \"design\": {\n"
    out = out + "    \"hypothesis\": \"3-mode topology (input/early/late) substrate-conditional intra-mode-only comparison\",\n"
    out = out + "    \"mode_boundaries\": \"input=[0," + str(MODE0_HI) + "] early=[" + str(MODE0_HI+1) + "," + str(MODE1_HI) + "] late=[" + str(MODE1_HI+1) + "," + str(SCALE) + "]\",\n"
    out = out + "    \"intra_dali_formula\": \"min over intra-mode pairs of SCALE - |L_loc(b1)-L_loc(b2)|\",\n"
    out = out + "    \"intra_sli_formula\": \"SCALE - (std(cusp_depth)*SCALE / mean(cusp_depth)) over intra-mode subset\",\n"
    out = out + "    \"intra_coupled_formula\": \"isqrt(intra_dali * intra_sli)\",\n"
    out = out + "    \"weighted_score_formula\": \"(400*intra_dali + 400*intra_sli + 200*intra_coupled) / 1000\",\n"
    out = out + "    \"per_mode_pass\": \"intra_dali>=" + str(INTRA_DALI_PASS) + " AND intra_sli>=" + str(INTRA_SLI_PASS) + " AND intra_coupled>=" + str(INTRA_COUPLED_PASS) + "\",\n"
    out = out + "    \"mode_min_size\": " + str(MODE_MIN_SIZE) + ",\n"
    out = out + "    \"overall_classification\": \"ALL_MODES_PASS_GREEN | PARTIAL_AMBER | ALL_MODES_FAIL_RED | NO_ELIGIBLE_MODE\"\n"
    out = out + "  },\n"
    out = out + "  \"thresholds\": {\n"
    out = out + "    \"intra_dali_pass\": " + str(INTRA_DALI_PASS) + ",\n"
    out = out + "    \"intra_sli_pass\": " + str(INTRA_SLI_PASS) + ",\n"
    out = out + "    \"intra_coupled_pass\": " + str(INTRA_COUPLED_PASS) + ",\n"
    out = out + "    \"mode_weighted_gate\": " + str(MODE_WEIGHTED_GATE) + ",\n"
    out = out + "    \"mode_min_size\": " + str(MODE_MIN_SIZE) + ",\n"
    out = out + "    \"neg_fail_gate_x1000\": " + str(NEG_FAIL_GATE) + ",\n"
    out = out + "    \"scale\": " + str(SCALE) + "\n"
    out = out + "  },\n"
    out = out + "  \"backbones\": " + str_list_json(backbone_names) + ",\n"
    out = out + "  \"cmt_sources\": " + str_list_json(cmt_paths) + ",\n"
    out = out + "  \"positive\": {\n"
    out = out + "    \"n_layers\": " + int_list_json(n_layers_list) + ",\n"
    out = out + "    \"peak_layers\": " + int_list_json(peak_layers) + ",\n"
    out = out + "    \"cusp_depth_x1000\": " + int_list_json(cusp_depths) + ",\n"
    out = out + "    \"family_loc_x1000\": " + int_list_json(family_locs) + ",\n"
    out = out + "    \"modes_family_loc\": " + int_list_json(modes_fl) + ",\n"
    out = out + "    \"modes_cusp_depth\": " + int_list_json(modes_cd) + ",\n"
    out = out + "    \"per_mode\": [\n"
    let mut mi = 0
    while mi < 3 {
        let r = mode_results[mi]
        let names_fl = subset_names_by_mode(backbone_names, modes_fl, mi)
        let names_cd = subset_names_by_mode(backbone_names, modes_cd, mi)
        out = out + "      {\n"
        out = out + "        \"mode\": " + str(mi) + ",\n"
        out = out + "        \"label\": \"" + mode_labels[mi] + "\",\n"
        out = out + "        \"fl_size\": " + str(r[0]) + ",\n"
        out = out + "        \"cd_size\": " + str(r[1]) + ",\n"
        out = out + "        \"names_fl\": " + str_list_json(names_fl) + ",\n"
        out = out + "        \"names_cd\": " + str_list_json(names_cd) + ",\n"
        out = out + "        \"intra_dali_x1000\": " + str(r[2]) + ",\n"
        out = out + "        \"intra_sli_x1000\": " + str(r[3]) + ",\n"
        out = out + "        \"intra_coupled_x1000\": " + str(r[4]) + ",\n"
        out = out + "        \"weighted_score_x1000\": " + str(r[5]) + ",\n"
        out = out + "        \"intra_pass\": " + bool_s(r[6] == 1) + ",\n"
        out = out + "        \"eligible\": " + bool_s(r[7] == 1) + "\n"
        out = out + "      }"
        if mi < 2 { out = out + "," }
        out = out + "\n"
        mi = mi + 1
    }
    out = out + "    ],\n"
    out = out + "    \"eligible_modes\": " + str(elig_count) + ",\n"
    out = out + "    \"passing_modes\": " + str(pass_count) + ",\n"
    out = out + "    \"overall_verdict\": \"" + overall + "\",\n"
    out = out + "    \"positive_pass\": " + bool_s(positive_pass) + "\n"
    out = out + "  },\n"
    out = out + "  \"negative\": {\n"
    out = out + "    \"strategy\": \"intra-mode jitter ±" + str(neg_jitter_amount) + " (family_loc + cusp_depth) per backbone — stresses intra-DALI/SLI\",\n"
    out = out + "    \"n_trials\": " + str(n_neg_trials) + ",\n"
    out = out + "    \"valid_trials\": " + str(neg_valid_count) + ",\n"
    out = out + "    \"per_trial_outcomes\": " + str_list_json(neg_results_list) + ",\n"
    out = out + "    \"first_trial_overall\": \"" + neg_first_overall + "\",\n"
    out = out + "    \"fail_count\": " + str(neg_fail_count) + ",\n"
    out = out + "    \"fail_rate_x1000\": " + str(neg_fail_rate) + ",\n"
    out = out + "    \"detects_outlier\": " + bool_s(neg_detects) + "\n"
    out = out + "  },\n"
    out = out + "  \"mk_xii_eligibility\": {\n"
    out = out + "    \"positive_all_modes_pass\": " + bool_s(positive_pass) + ",\n"
    out = out + "    \"partial_mode_pass\": " + bool_s(pass_count > 0 && pass_count < elig_count) + ",\n"
    out = out + "    \"negative_discriminates\": " + bool_s(neg_detects) + ",\n"
    out = out + "    \"eligibility_class\": \"" + elig_class + "\"\n"
    out = out + "  },\n"
    out = out + "  \"raw10_honest\": \"3-mode grouping = empirical 의존 (S7 PASS_SIGNIFICANT 후 도입). intra-mode 비교만 valid; inter-mode pair NOT_APPLICABLE — mode-specific evidence 분리 declarative.\",\n"
    out = out + "  \"cross_validate\": \".roadmap #145 (CMT backbone-conditional depth divergence) / state/dali_sli_coupled_v1.json (prior JOINT_FAIL) / state/dali_sli_weighted_vote_v1.json (prior NOT_ELIGIBLE)\"\n"
    out = out + "}\n"
    write_file("anima-clm-eeg/state/dali_sli_v2_redesign_v1.json", out)
    println("  wrote: anima-clm-eeg/state/dali_sli_v2_redesign_v1.json")

    let mk_xii_eligible = positive_pass && neg_detects
    if mk_xii_eligible { exit(0) }
    exit(1)
}
