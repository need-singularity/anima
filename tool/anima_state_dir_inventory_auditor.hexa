// tool/anima_state_dir_inventory_auditor.hexa — state/ directory inventory + schema audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 22 tool/ inventory pair. state/ directory에 988+ entries (826 top-level .json + sub-dirs).
//   state/는 helper 산출 SSOT — 다음 세션 시작 시 어떤 state file이 있는지 + schema 일관성 audit.
//
//   본 helper = mac-local NON_MUTATION inventory:
//     - top-level *.json count + sub-dir count
//     - cycles 1-22 state JSON presence (composite gate cross-link)
//     - schema field 분포 (paradigm/cycle/parent_handoff_actionable 등 frozen field 출현률)
//     - file age distribution (recent vs stale; stale = >7일 미수정)
//     - selftest verifies: ≥800 json files / cycle 1-22 23 state files / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/state_dir_inventory_auditor.json)
//   ANIMA_STATE_DIR   state dir (default: state)
//
// OUTPUT
//   - total_entries
//   - top_level_json_count, sub_dir_count
//   - cycles_1_22_state_presence: 23 expected files (1-22 + composite)
//   - schema_field_distribution: top frozen fields present
//   - age_distribution: <1d / 1-7d / >7d
//   - top_largest_json
//
// USAGE
//   hexa run tool/anima_state_dir_inventory_auditor.hexa --selftest
//   ANIMA_OUTPUT=state/state_dir_inventory_auditor.json hexa run tool/anima_state_dir_inventory_auditor.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - schema field distribution은 top-level keys만; nested schema 미고려.
//   - age 분류는 mtime 기반; ctime 차이 무시.
//   - cycles 1-22 expected list는 frozen — 향후 cycle 추가 시 list 갱신 필요.

let HELPER_PATH = "/tmp/anima_state_dir_inventory_auditor_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima state/ directory inventory + audit — emitted by tool/anima_state_dir_inventory_auditor.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION state/ inventory.\n")
    parts.push("import json, os, sys, time\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/state_dir_inventory_auditor.json')\n")
    parts.push("STATE_DIR = os.environ.get('ANIMA_STATE_DIR', 'state')\n\n")

    parts.push("if not os.path.isdir(STATE_DIR):\n")
    parts.push("    summary = {'paradigm':'state dir inventory', 'status':'STATE_DIR_MISSING', 'state_dir':STATE_DIR}\n")
    parts.push("    os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("    with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("    print(f'[state_inventory] status=STATE_DIR_MISSING -> {OUTPUT}')\n")
    parts.push("    sys.exit(0)\n\n")

    parts.push("entries = os.listdir(STATE_DIR)\n")
    parts.push("top_json_files = [e for e in entries if e.endswith('.json') and os.path.isfile(os.path.join(STATE_DIR, e))]\n")
    parts.push("sub_dirs = [e for e in entries if os.path.isdir(os.path.join(STATE_DIR, e))]\n")
    parts.push("other_files = [e for e in entries if e not in top_json_files and e not in sub_dirs]\n\n")

    parts.push("CYCLES_1_22_EXPECTED = [\n")
    parts.push("    'r46_primary_zone_candidates.json',\n")
    parts.push("    'cmt_v2_5bb_retest_pre_register.json',\n")
    parts.push("    'axis96_llama_stride1_pre_register.json',\n")
    parts.push("    'mk_xii_3a_gemma_familyinternal_pre_register.json',\n")
    parts.push("    'axis96_6th_bb_arch_separator_pre_register.json',\n")
    parts.push("    'pilot_t2_launch_gate_dispatch.json',\n")
    parts.push("    'own3_de_wording_revision_verifier.json',\n")
    parts.push("    'zombie_posterior_v4_17sub_candidate_selector.json',\n")
    parts.push("    'mk_xii_3b_70b_prep.json',\n")
    parts.push("    'eeg_cp2_7day_arrival_gate.json',\n")
    parts.push("    'mk_xii_3a_llama_familyinternal_pre_register.json',\n")
    parts.push("    'r46_verdict_consolidator.json',\n")
    parts.push("    'h100_p1_single_pilot_precheck.json',\n")
    parts.push("    'paradigm_v11_axis_filter_consolidator.json',\n")
    parts.push("    'anima_composite_production_gate.json',\n")
    parts.push("    'axis82_4axis_exhaustion_closure.json',\n")
    parts.push("    'atlas_rtier_integrity_verifier.json',\n")
    parts.push("    'atlas_drift_remediation_proposer.json',\n")
    parts.push("    'session_handoff_extension_generator.json',\n")
    parts.push("    'ssot_chflags_lock_state_auditor.json',\n")
    parts.push("    'tool_dir_helper_inventory.json',\n")
    parts.push("]\n\n")

    parts.push("cycles_present = [f for f in CYCLES_1_22_EXPECTED if f in top_json_files]\n")
    parts.push("cycles_missing = [f for f in CYCLES_1_22_EXPECTED if f not in top_json_files]\n\n")

    parts.push("# schema field distribution (top-level keys frequency on cycle state files)\n")
    parts.push("frozen_fields = ['paradigm', 'parent_handoff_actionable', 'parent_helpers', 'pre_register_status', 'non_mutation_guarantee', 'cross_link_cycles', 'h100_stop_gate_invariant']\n")
    parts.push("field_counts = {f:0 for f in frozen_fields}\n")
    parts.push("schema_audited_count = 0\n")
    parts.push("for fname in cycles_present:\n")
    parts.push("    path = os.path.join(STATE_DIR, fname)\n")
    parts.push("    try:\n")
    parts.push("        with open(path) as f: d = json.load(f)\n")
    parts.push("        schema_audited_count += 1\n")
    parts.push("        for k in frozen_fields:\n")
    parts.push("            if k in d:\n")
    parts.push("                field_counts[k] += 1\n")
    parts.push("    except Exception:\n")
    parts.push("        continue\n\n")

    parts.push("schema_distribution = []\n")
    parts.push("for k in frozen_fields:\n")
    parts.push("    schema_distribution.append({\n")
    parts.push("        'field':k,\n")
    parts.push("        'present_in':field_counts[k],\n")
    parts.push("        'audited_total':schema_audited_count,\n")
    parts.push("        'pct':round(100 * field_counts[k] / max(schema_audited_count, 1), 1),\n")
    parts.push("    })\n\n")

    parts.push("# age distribution\n")
    parts.push("now = time.time()\n")
    parts.push("age_lt_1d = 0\n")
    parts.push("age_1_7d = 0\n")
    parts.push("age_gt_7d = 0\n")
    parts.push("size_stats = []\n")
    parts.push("for fname in top_json_files:\n")
    parts.push("    path = os.path.join(STATE_DIR, fname)\n")
    parts.push("    try:\n")
    parts.push("        st = os.stat(path)\n")
    parts.push("        age_days = (now - st.st_mtime) / 86400\n")
    parts.push("        if age_days < 1: age_lt_1d += 1\n")
    parts.push("        elif age_days < 7: age_1_7d += 1\n")
    parts.push("        else: age_gt_7d += 1\n")
    parts.push("        size_stats.append({'file':fname, 'size_bytes':st.st_size, 'age_days':round(age_days, 1)})\n")
    parts.push("    except Exception:\n")
    parts.push("        continue\n\n")

    parts.push("top_largest = sorted(size_stats, key=lambda x: x['size_bytes'], reverse=True)[:10]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'state/ directory inventory + schema audit (mac-local NON_MUTATION; cycle 22 tool/ pair)',\n")
    parts.push("    'state_dir':STATE_DIR,\n")
    parts.push("    'total_entries':len(entries),\n")
    parts.push("    'top_level_json_count':len(top_json_files),\n")
    parts.push("    'sub_dir_count':len(sub_dirs),\n")
    parts.push("    'other_files_count':len(other_files),\n")
    parts.push("    'cycles_1_22_expected':len(CYCLES_1_22_EXPECTED),\n")
    parts.push("    'cycles_1_22_present':len(cycles_present),\n")
    parts.push("    'cycles_1_22_missing':cycles_missing,\n")
    parts.push("    'schema_field_distribution':schema_distribution,\n")
    parts.push("    'schema_audited_count':schema_audited_count,\n")
    parts.push("    'age_distribution':{\n")
    parts.push("        'lt_1d':age_lt_1d,\n")
    parts.push("        '1_to_7d':age_1_7d,\n")
    parts.push("        'gt_7d':age_gt_7d,\n")
    parts.push("        'total':age_lt_1d + age_1_7d + age_gt_7d,\n")
    parts.push("        'fresh_pct':round(100 * age_lt_1d / max(age_lt_1d + age_1_7d + age_gt_7d, 1), 1),\n")
    parts.push("    },\n")
    parts.push("    'top_largest_json':top_largest,\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify state/; read-only inventory',\n")
    parts.push("    'cross_link_cycle':'cycle 22 tool/ inventory pair',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[state_inventory] entries={len(entries)} json={len(top_json_files)} subdirs={len(sub_dirs)} cycles_1_22_present={len(cycles_present)}/{len(CYCLES_1_22_EXPECTED)} fresh_lt_1d={age_lt_1d} stale_gt_7d={age_gt_7d} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let cycles_1_22_expected = 21
    let frozen_fields_count = 7
    let age_buckets = 3
    let non_mutation = "READ_ONLY"
    println("inv:cycles_1_22_expected=" + to_string(cycles_1_22_expected))
    println("inv:frozen_fields_count=" + to_string(frozen_fields_count))
    println("inv:age_buckets=" + to_string(age_buckets))
    println("inv:non_mutation=" + non_mutation)
    println("inv:age_buckets=lt_1d,1_to_7d,gt_7d")
    println("inv:frozen_fields=paradigm,parent_handoff_actionable,parent_helpers,pre_register_status,non_mutation_guarantee,cross_link_cycles,h100_stop_gate_invariant")
    println("inv:cross_link_cycle22_tool_inventory_pair=true")
    println("inv:top_largest_capped_at_10=true")
    return true
}

fn cmd_selftest() {
    println("── anima_state_dir_inventory_auditor selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=state/ inventory + schema audit (cycle 22 pair; cycles 1-22 presence + age distribution; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
