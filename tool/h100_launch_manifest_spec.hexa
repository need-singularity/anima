    // eigenvec-16 basis verified
    o = push(o, _mk_jfield(ANIMA_ROOT + "/.meta2-cert/cell-eigenvec-16.json",
        "verdict", "VERIFIED",
        "cell-eigenvec-16 verdict=VERIFIED"))
    // mk.vi SSOT present (criteria anchor)
    o = push(o, _mk_file(ANIMA_ROOT + "/state/mk_vi_definition.json",
        "Mk.VI promotion-gate SSOT"))
    // phi extractor (used for post-launch AN11(b))
    o = push(o, _mk_file(ANIMA_ROOT + "/tool/phi_extractor_cpu.hexa",
        "phi_extractor_cpu.hexa"))
