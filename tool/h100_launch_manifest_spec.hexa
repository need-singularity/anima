    o = push(o, _mk_file(ANIMA_ROOT + "/edu/lora/cpgd_wrapper.hexa",
        "CPGD wrapper (edu/lora/cpgd_wrapper.hexa)"))
    o = push(o, _mk_file(ANIMA_ROOT + "/edu/lora/cpgd_minimal_proof.hexa",
        "CPGD minimal-proof driver (edu/lora/cpgd_minimal_proof.hexa)"))
