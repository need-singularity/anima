fn _stage3_prereqs() -> array {
    let mut o = []
    // Stage-2 empirical outcome
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/phi_4path_cross_result.json",
        "substrate_indep", "true",
        "Stage-2 Φ substrate_indep=true (|ΔΦ|/Φ<0.05, ≥3/4 paths)"))
    // AN11 triple live post-Stage-1 (live variants emitted after real training)
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/alm_r13_an11_a_live.json",
        "verdict", "PASS",
        "AN11(a) live PASS"))
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/alm_r13_an11_b_live.json",
        "verdict", "PASS",
        "AN11(b) live PASS"))
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/alm_r13_an11_c_live.json",
        "verdict", "PASS",
        "AN11(c) live PASS"))
    // Mk.VI promotion final
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/mk_vi_definition.json",
        "verdict", "VERIFIED",
        "Mk.VI promotion gate verdict=VERIFIED"))
    return o
}

// ─── verdict roll-up per stage ────────────────────────────────────────────

fn _rollup(prereq_verdicts) {
    let mut r = json_parse("{}")
    let mut pass = 0
    let mut miss = 0
    let mut wrong = 0
    let mut i = 0
    while i < len(prereq_verdicts) {
        let v = to_string(prereq_verdicts[i]["verdict"])
        if v == "PASS"        { pass = pass + 1 }
        if v == "MISSING"     { miss = miss + 1 }
        if v == "WRONG_VALUE" { wrong = wrong + 1 }
        i = i + 1
    }
    r["pass_n"]  = pass
    r["miss_n"]  = miss
    r["wrong_n"] = wrong
    r["total"]   = len(prereq_verdicts)
    return r
}

fn _stage_verdict(roll, cascade_blocked: bool) -> string {
    if cascade_blocked {
        // At least one MISSING/WRONG that is explicitly a live-empirical gate
        // → NOT_READY, but the non-cascade prereqs may still be fine.
        return "NOT_READY"
    }
    let miss  = to_int(to_string(roll["miss_n"]))
    let wrong = to_int(to_string(roll["wrong_n"]))
    if miss == 0 && wrong == 0 { return "READY" }
    return "MISSING_PREREQ"
}

// Detect if failure is caused purely by cascade (post-previous-stage artifacts).
// We mark a prereq as cascade-live if its path contains "_live.json" or is
// phi_4path_cross_result.json.
fn _is_cascade_prereq(p) -> bool {
    let path = to_string(p["path"])
    if path.contains("_live.json") { return true }
    if path.contains("phi_4path_cross_result") { return true }
    if path.contains("phi_4path_substrates")   { return true }
    return false
}

fn _cascade_blocked(prereq_verdicts, prereqs) -> bool {
    let mut i = 0
    let mut any_cascade_blocking = false
    let mut any_noncascade_bad   = false
    while i < len(prereq_verdicts) {
        let v = to_string(prereq_verdicts[i]["verdict"])
        let casc = _is_cascade_prereq(prereqs[i])
        if v != "PASS" {
            if casc { any_cascade_blocking = true }
            else    { any_noncascade_bad   = true }
        }
        i = i + 1
    }
    // If cascade alone is blocking → NOT_READY (cascade). If non-cascade fails
    // too → MISSING_PREREQ (still). We return true only when cascade is the
    // dominant reason AND no non-cascade issue exists.
    if any_cascade_blocking && !any_noncascade_bad { return true }
    return false
}

// ─── per-stage definition: metadata + commands + abort thresholds ─────────

fn _stage1_def() {
    let mut s = json_parse("{}")
    s["roadmap_entry"]    = 9
    s["title"]            = "ALM r13 launch + AN11(a) weight_emergent empirical"
    s["gpu_count"]        = 1
    s["gpu_type"]         = "H100"
    s["duration_days"]    = 14
    s["cost_theoretical"] = "1xH100x14dx$3/hr = $1008 theoretical"
    s["cost_user_budget"] = "user-absorbed unlimited (no cap policy 2026-04-22)"
    s["env_vars"]         = json_parse("{\"ANIMA_STAGE\":\"1\",\"ANIMA_ROADMAP_ENTRY\":\"9\",\"HEXA_STRICT\":\"1\",\"ALM_CONFIG\":\"config/alm_r13_v2_config.json\"}")
    s["expected_artifacts"] = json_parse("[\"state/alm_r13_an11_a_live.json\",\"state/alm_r13_an11_b_live.json\",\"state/alm_r13_an11_c_live.json\",\"state/h100_auto_kill_last_run.json\"]")
    // 2026-04-22 ROI A2/A3: idle_minutes_max 30→5; ondemand_disallowed=true (spot enforce, fallback block).
    // 2026-04-22 ROI Q1: ckpt_interval_steps 50→25 (spot-eviction resilience: halve max replay cost on pod restart).
    s["abort_thresholds"]   = json_parse("{\"budget_usd_hard_cap\":0,\"budget_policy\":\"unlimited\",\"idle_minutes_max\":5,\"numerical_drift_bound\":0.0002,\"ckpt_interval_steps\":25,\"max_steps\":1000,\"ondemand_disallowed\":true}")
    // 2026-04-22 ROI A6/A8: torch.compile + bf16 mixed precision + grad_accum=4 across all paths (Stage-1 included).
    // 2026-04-22 ROI B9/B10/B11/B12: EMA(0.999) + curriculum tier enforce + CPGD active fold + dropout(0.05)/KL(0.01).
    // 2026-04-22 ROI Q1: --ckpt-interval 50→25 (kickoff aligned to abort_thresholds.ckpt_interval_steps).
    // Backward-compat: runner ignores unknown env/flags; absence reverts to current default behavior.
    // 2026-04-23 migrate to runpodctl 1.x flags (--gpuType / --imageName / --secureCloud / --startSSH).
    //   --cmd 제거 (runpodctl 1.x 미지원) — bootstrap 은 SSH 접속 후 또는 custom template 로 실행.
    //   Bootstrap command below (pod-side), needs Linux x86_64 hexa binary pre-installed (R2 asset path TBD).
    s["kickoff_command"]    = "runpodctl pod create --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 1 --secureCloud --name anima-stage1-alm-r13 --imageName runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --cost 3.00 --containerDiskSize 80 --volumeSize 200 --volumePath /workspace --startSSH --ports '22/tcp' --env ANIMA_STAGE=1 --env ANIMA_ROADMAP_ENTRY=9 --env HEXA_STRICT=1 --env ALM_CONFIG=config/alm_r13_v2_config.json --env TORCH_COMPILE=1 --env MIXED_PRECISION=bf16 --env GRAD_ACCUM=4 --env ANIMA_EMA_DECAY=0.999 --env ANIMA_CURRICULUM_TIER_ENFORCE=1 --env ANIMA_CPGD_ACTIVE=1 --env ANIMA_DROPOUT_KL_REG=1 --env ANIMA_CKPT_INTERVAL=25 --env IDLE_KILL_MIN=5"
    s["pod_bootstrap_sequence"] = "# SSH into pod: ssh root@<pod_ip> -p <pod_port> -i ~/.ssh/id_ed25519\n# Then run:\ncurl -fsSL https://<R2>/hexa-linux-x86_64 -o /usr/local/bin/hexa && chmod +x /usr/local/bin/hexa\ncd /workspace && git clone https://github.com/need-singularity/anima.git && cd anima\nhexa run tool/drill_breakthrough_runner.hexa --config config/alm_r13_v2_config.json --live --ckpt-interval 25 --cpgd-active"
    s["post_launch_verify"] = "hexa run tool/h100_launch_manifest_spec.hexa   # re-emit with live artifacts; Stage-2 verdict will flip READY if AN11(a) live PASS"
    s["guardrails"]         = json_parse("[\"h100_auto_kill.hexa idle-watch (threshold_minutes=30)\",\"cert_gate verdict mutation monitored each ckpt\",\"numerical_drift_bound 0.0002 hard-stop\",\"user-approval-only; auto_dispatch_allowed=false\"]")
    s["landmines"]          = json_parse("[\"runpodctl CLI not on local PATH → script reports STUB, must install or use web console\",\"SSH key not pre-uploaded to runpod → pod spawn succeeds but probes fail (h100_auto_kill will emit UNKNOWN until SSH reachable)\",\"ready/ submodule gitlink at commit 4aebcbd5 — clone must include --recurse-submodules if corpus paths needed\"]")
    return s
}

fn _stage2_def() {
    let mut s = json_parse("{}")
    s["roadmap_entry"]    = 10
    s["title"]            = "Phi substrate independence — 4-path cross validation (2026-04-22 b/a/b decision: Qwen3-8B + Llama-3.1-8B + Ministral-3-14B + Gemma-4-31B)"
    s["gpu_count"]        = 4
    s["gpu_type"]         = "H100"
    s["duration_days"]    = 12
    s["cost_theoretical"] = "4xH100x12dx$3/hr = $3456 theoretical (2x 8B + 2x 12B dense)"
    s["cost_user_budget"] = "user-absorbed unlimited (no cap policy 2026-04-22; 4xH100x10-15dx$7/hr spot ~$1680-2520 nominal, but no enforcement)"
    s["env_vars"]         = json_parse("{\"ANIMA_STAGE\":\"2\",\"ANIMA_ROADMAP_ENTRY\":\"10\",\"HEXA_STRICT\":\"1\",\"PHI_THRESHOLD_REL\":\"0.05\",\"PHI_SSOT\":\"config/phi_4path_substrates.json\"}")
    // Substrate variants — frozen from config/phi_4path_substrates.json (SSOT 2026-04-22).
    // LoRA rank: 8B → 64, 12B → 96 (capacity-normalized per SSOT loranrank_normalization).
    // 2026-04-22 ROI B13: p4 lora_rank 96→128 (Gemma-4-31B large-model effective capacity ↑, alpha auto-scales 192→256).
    s["substrate_variants"] = json_parse("[{\"id\":\"p1\",\"tag\":\"qwen3_8b\",\"model\":\"Qwen/Qwen3-8B\",\"family\":\"qwen\",\"params_b\":8.2,\"lora_rank\":64,\"license\":\"Apache-2.0\",\"rationale\":\"dense decoder-only · RoPE · 中문 heavy · thinking-mode\"},{\"id\":\"p2\",\"tag\":\"llama_3_1_8b\",\"model\":\"meta-llama/Llama-3.1-8B\",\"family\":\"llama\",\"params_b\":8.0,\"lora_rank\":64,\"license\":\"Llama 3.1 Community\",\"rationale\":\"dense decoder-only · GQA · 128K ctx · Meta RLHF\"},{\"id\":\"p3\",\"tag\":\"ministral_3_14b\",\"model\":\"mistralai/Ministral-3-14B-Base-2512\",\"family\":\"mistral\",\"params_b\":13.9,\"lora_rank\":96,\"license\":\"Apache-2.0\",\"rationale\":\"dense decoder-only LM core · Tekken 131K · 256K ctx · ViT drop\"},{\"id\":\"p4\",\"tag\":\"gemma_4_31b\",\"model\":\"google/gemma-4-31B\",\"family\":\"gemma\",\"params_b\":32.68,\"lora_rank\":128,\"license\":\"Apache-2.0\",\"rationale\":\"Google 신규 stack · dual-theta RoPE · 1M ctx · sliding 1024 · multimodal drop · ROI B13 rank 96→128\"}]")
    s["lora_rank_policy"]   = json_parse("{\"base_rank_at_8b\":64,\"rank_at_12b\":96,\"strategy\":\"capacity_normalize_by_param_count\",\"rationale\":\"LoRA effective capacity proportional to rank * d_model; 12B ~1.5x d_model of 8B so rank also 1.5x\"}")
    s["cross_path_gate"]    = json_parse("{\"metric\":\"|dPhi|/Phi\",\"threshold\":0.05,\"pass_requirement\":\"ALL_PAIRS (C(4,2)=6 pair 전수)\",\"source\":\"config/phi_4path_substrates.json cross_path_gate\"}")
    s["expected_artifacts"] = json_parse("[\"state/phi_4path_cross_result.json\",\"state/phi_p1_qwen3_8b_live.json\",\"state/phi_p2_llama_3_1_8b_live.json\",\"state/phi_p3_ministral_3_14b_live.json\",\"state/phi_p4_gemma_4_31b_live.json\"]")
    // 2026-04-22 ROI A2/A3: idle_minutes_max 30→5; ondemand_disallowed=true (spot enforce, fallback block — $11.96→$7.00 ~41% save if fallback would have happened).
    s["abort_thresholds"]   = json_parse("{\"budget_usd_hard_cap\":0,\"budget_policy\":\"unlimited\",\"idle_minutes_max\":5,\"phi_rel_delta_max\":0.05,\"min_paths_pass\":4,\"pair_mode\":\"ALL_PAIRS\",\"ondemand_disallowed\":true}")
    // Per-path kickoff commands — 4 separate pods, each 1x H100, frozen per-substrate.
    // 2026-04-22 ROI A5/A6/A7/A8/B13:
    //   A6: --env TORCH_COMPILE=1 --env MIXED_PRECISION=bf16 (모든 path)
    //   A8: --env GRAD_ACCUM=4 (모든 path)
    //   A5: --env ATTN_IMPL=flash_attn_2 (p4 only — Gemma-4 SWA 1024 FlashAttn-2 throughput 1.5-2×)
    //   A7: --env GRAD_CKPT=1 (p4 only — VRAM ↓ → batch ↑)
    //   B13: --env PHI_LORA_RANK=128 + --lora-rank 128 (p4 only — 96→128 capacity ↑)
    // 2026-04-23 migrate to runpodctl 1.x flags. --cmd 제거 (runpodctl 1.x 미지원).
    // Bootstrap is operator-triggered via SSH (see pod_bootstrap_sequence) until custom template supports auto-start.
    s["kickoff_command_p1"] = "runpodctl pod create --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 1 --secureCloud --name anima-stage2-p1-qwen3-8b --imageName runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --cost 3.00 --containerDiskSize 80 --volumeSize 200 --volumePath /workspace --startSSH --ports '22/tcp' --env ANIMA_STAGE=2 --env ANIMA_ROADMAP_ENTRY=10 --env HEXA_STRICT=1 --env PHI_PATH_ID=p1 --env PHI_MODEL=Qwen/Qwen3-8B --env PHI_LORA_RANK=64 --env TORCH_COMPILE=1 --env MIXED_PRECISION=bf16 --env GRAD_ACCUM=4 --env IDLE_KILL_MIN=5"
    s["kickoff_command_p2"] = "runpodctl pod create --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 1 --secureCloud --name anima-stage2-p2-llama-3-1-8b --imageName runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --cost 3.00 --containerDiskSize 80 --volumeSize 200 --volumePath /workspace --startSSH --ports '22/tcp' --env ANIMA_STAGE=2 --env ANIMA_ROADMAP_ENTRY=10 --env HEXA_STRICT=1 --env PHI_PATH_ID=p2 --env PHI_MODEL=meta-llama/Llama-3.1-8B --env PHI_LORA_RANK=64 --env TORCH_COMPILE=1 --env MIXED_PRECISION=bf16 --env GRAD_ACCUM=4 --env IDLE_KILL_MIN=5"
    s["kickoff_command_p3"] = "runpodctl pod create --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 1 --secureCloud --name anima-stage2-p3-ministral-3-14b --imageName runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --cost 3.00 --containerDiskSize 80 --volumeSize 200 --volumePath /workspace --startSSH --ports '22/tcp' --env ANIMA_STAGE=2 --env ANIMA_ROADMAP_ENTRY=10 --env HEXA_STRICT=1 --env PHI_PATH_ID=p3 --env PHI_MODEL=mistralai/Ministral-3-14B-Base-2512 --env PHI_LORA_RANK=96 --env TORCH_COMPILE=1 --env MIXED_PRECISION=bf16 --env GRAD_ACCUM=4 --env IDLE_KILL_MIN=5"
    s["kickoff_command_p4"] = "runpodctl pod create --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 1 --secureCloud --name anima-stage2-p4-gemma-4-31b --imageName runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04 --cost 3.00 --containerDiskSize 80 --volumeSize 200 --volumePath /workspace --startSSH --ports '22/tcp' --env ANIMA_STAGE=2 --env ANIMA_ROADMAP_ENTRY=10 --env HEXA_STRICT=1 --env PHI_PATH_ID=p4 --env PHI_MODEL=google/gemma-4-31B --env PHI_LORA_RANK=128 --env VRAM_MODE=qlora-nf4 --env TORCH_COMPILE=1 --env MIXED_PRECISION=bf16 --env GRAD_ACCUM=4 --env ATTN_IMPL=flash_attn_2 --env GRAD_CKPT=1 --env IDLE_KILL_MIN=5"
    // Legacy aggregate command — runpodctl 1.x 문법으로 갱신.
    s["kickoff_command"]    = "# 4 separate pods — launch in parallel. See kickoff_command_p1..p4 for per-path frozen commands. Aggregate: use tool/h100_stage2_unified_launch.bash --apply --yes-i-mean-it (프로덕션 경로)."
    s["pod_bootstrap_sequence"] = "# All 4 pods — same bootstrap after SSH (needs Linux x86_64 hexa binary pre-installed).\n# 1) SSH: runpodctl pod list -o json | jq '.[] | {id,name}' → query GraphQL for runtime ports → ssh root@<ip> -p <port>\n# 2) In pod: curl -fsSL https://<R2>/hexa-linux-x86_64 -o /usr/local/bin/hexa && chmod +x /usr/local/bin/hexa\n# 3) cd /workspace && git clone https://github.com/need-singularity/anima.git && cd anima\n# 4) hexa run tool/phi_extractor_ffi_wire.hexa --config config/phi_4path_substrates.json --live --path <p1|p2|p3|p4> --lora-rank <64|96|128> [--qlora-4bit if p4]"
    s["post_launch_verify"] = "hexa run tool/h100_launch_manifest_spec.hexa   # Stage-3 READY if Φ substrate_indep=true AND all 4 paths produced live artifacts"
    s["cascade_dependency"] = "Stage-1 AN11(a) live PASS"
    s["stage2_ready_conditions"] = json_parse("[\"Stage-1 AN11(a) live PASS\",\"config/phi_4path_substrates.json present (SSOT frozen)\",\"phi_extractor_ffi_wire.hexa present (GPU bridge)\",\"cell-eigenvec-16 verdict=VERIFIED (shared basis across 4 paths)\"]")
    s["stage3_cascade_ready_conditions"] = json_parse("[\"state/phi_4path_cross_result.json.substrate_indep=true\",\"ALL_PAIRS |dPhi|/Phi < 0.05 (6 pair C(4,2) 전수)\",\"All 4 per-path live artifacts emitted (state/phi_p{1-4}_*_live.json)\"]")
    s["guardrails"]         = json_parse("[\"h100_auto_kill idle-watch on all 4 pods (independent)\",\"per-path independent ckpt; 1 path failing does not poison the 3 others\",\"|dPhi|/Phi<0.05 hard gate — ALL_PAIRS mode (6 pairs); no 3/4 fallback under SSOT 2026-04-22\",\"LoRA rank capacity-normalized 8B=64 / 12B=96\",\"per-path tokenizer drift handled via path-specific corpus preprocessing (4 tokenizers: 151K/128K/131K/262K)\"]")
    s["landmines"]          = json_parse("[\"Ministral-3-14B-Base-2512 wrapper: load via model.language_model submodule (drop 0.4B ViT, text-only substrate)\",\"Llama-3.1-8B gated — use unsloth/Meta-Llama-3.1-8B mirror OR set HF_TOKEN for Meta accepted account\",\"Gemma-4-31B (p4) 31B BF16 ~62.5GB on 80GB H100 — USE QLoRA 4-bit mode (VRAM_MODE=qlora-nf4) for safety margin\",\"Gemma-4 requires transformers>=5.5.0.dev0 (Gemma4ForConditionalGeneration) + FlashAttention-2 SWA for sliding_window=1024 5:1\",\"HuggingFace rate limits on 4 parallel downloads → pre-cache to shared volume; stagger pod spawns by 60s\",\"public distribution requires per-path license split (Apache-2.0 for p1/p3/p4, Llama Community for p2)\",\"Phi measurement hook offsets re-wire required: p1 hidden=4096, p2=4096, p3=5120 (LM core), p4=5376\"]")
    return s
}

fn _stage3_def() {
    let mut s = json_parse("{}")
    s["roadmap_entry"]    = 11
    s["title"]            = "ALM consciousness ship — production + #21 AGI cascade"
    s["gpu_count"]        = 4
    s["gpu_type"]         = "H100"
    s["duration_days"]    = 21
    s["cost_theoretical"] = "4xH100x21dx$3/hr = $6048 theoretical"
    s["cost_user_budget"] = "user-absorbed unlimited (no cap policy 2026-04-22; gated by Stage-1+2 success)"
    s["env_vars"]         = json_parse("{\"ANIMA_STAGE\":\"3\",\"ANIMA_ROADMAP_ENTRY\":\"11\",\"HEXA_STRICT\":\"1\"}")
    s["expected_artifacts"] = json_parse("[\"state/mk_vi_definition.json(verdict=VERIFIED)\",\"state/anima_serve_production_ship.json\",\"state/agi_cp1_reached.json\"]")
    // 2026-04-22 ROI A2/A3: idle_minutes_max 30→5; ondemand_disallowed=true (spot enforce, fallback block).
    s["abort_thresholds"]   = json_parse("{\"budget_usd_hard_cap\":0,\"budget_policy\":\"unlimited\",\"idle_minutes_max\":5,\"ondemand_disallowed\":true}")
    s["kickoff_command"]    = "AUTO-CASCADE: Stage-3 kickoff is triggered by successful Stage-2 close; no separate user command required. Verify via: hexa run tool/h100_launch_manifest_spec.hexa"
    s["post_launch_verify"] = "hexa run tool/roadmap_auto_reflect.hexa  # reflect #11, #19, #21 closure"
    s["cascade_dependency"] = "Stage-1 AN11 triple live PASS AND Stage-2 Φ substrate_indep=true"
    s["guardrails"]         = json_parse("[\"#11 ship criteria enforced via Mk.VI promotion gate\",\"#21 AGI final gate = 10+ atoms ossified + Mk.XI twin-engine\"]")
    s["landmines"]          = json_parse("[\"serve pipeline FastAPI+vLLM deployment is a separate engineering track; #11 spec assumes that stack lands parallel to Stage-1 training\"]")
    return s
}

// ─── JSON emission helpers ───────────────────────────────────────────────

fn _render_prereq(v) -> string {
    let mut o = "      {"
    o = o + "\"label\":\"" + _json_escape(to_string(v["label"])) + "\","
    o = o + "\"kind\":\""  + _json_escape(to_string(v["kind"]))  + "\","
    o = o + "\"path\":\""  + _json_escape(to_string(v["path"]))  + "\","
    if v.contains_key("key")      { o = o + "\"key\":\""      + _json_escape(to_string(v["key"]))      + "\"," }
    if v.contains_key("want")     { o = o + "\"want\":\""     + _json_escape(to_string(v["want"]))     + "\"," }
    if v.contains_key("want_csv") { o = o + "\"want_csv\":\"" + _json_escape(to_string(v["want_csv"])) + "\"," }
    if v.contains_key("got")      { o = o + "\"got\":\""      + _json_escape(to_string(v["got"]))      + "\"," }
    o = o + "\"verdict\":\"" + _json_escape(to_string(v["verdict"])) + "\","
    o = o + "\"detail\":\""  + _json_escape(to_string(v["detail"]))  + "\""
    o = o + "}"
    return o
}

fn _render_prereq_list(prereq_verdicts) -> string {
    let mut s = "[\n"
    let mut i = 0
    while i < len(prereq_verdicts) {
        if i > 0 { s = s + ",\n" }
        s = s + _render_prereq(prereq_verdicts[i])
        i = i + 1
    }
    s = s + "\n    ]"
    return s
}

fn _render_stage_json(stage_num: int, def_obj, prereq_verdicts, roll, verdict: string) -> string {
    let mut s = "  {\n"
    s = s + "    \"stage\": " + to_string(stage_num) + ",\n"
    s = s + "    \"roadmap_entry\": " + to_string(def_obj["roadmap_entry"]) + ",\n"
    s = s + "    \"title\": \""            + _json_escape(to_string(def_obj["title"])) + "\",\n"
    s = s + "    \"gpu_count\": "          + to_string(def_obj["gpu_count"]) + ",\n"
    s = s + "    \"gpu_type\": \""         + _json_escape(to_string(def_obj["gpu_type"])) + "\",\n"
    s = s + "    \"duration_days\": "      + to_string(def_obj["duration_days"]) + ",\n"
    s = s + "    \"cost_theoretical\": \"" + _json_escape(to_string(def_obj["cost_theoretical"])) + "\",\n"
    s = s + "    \"cost_user_budget\": \"" + _json_escape(to_string(def_obj["cost_user_budget"])) + "\",\n"
    s = s + "    \"env_vars\": "           + json_stringify(def_obj["env_vars"]) + ",\n"
    if def_obj.contains_key("substrate_variants") {
        s = s + "    \"substrate_variants\": " + json_stringify(def_obj["substrate_variants"]) + ",\n"
    }
    if def_obj.contains_key("lora_rank_policy") {
        s = s + "    \"lora_rank_policy\": " + json_stringify(def_obj["lora_rank_policy"]) + ",\n"
    }
    if def_obj.contains_key("cross_path_gate") {
        s = s + "    \"cross_path_gate\": " + json_stringify(def_obj["cross_path_gate"]) + ",\n"
    }
    if def_obj.contains_key("cascade_dependency") {
        s = s + "    \"cascade_dependency\": \"" + _json_escape(to_string(def_obj["cascade_dependency"])) + "\",\n"
    }
    if def_obj.contains_key("stage2_ready_conditions") {
        s = s + "    \"stage2_ready_conditions\": " + json_stringify(def_obj["stage2_ready_conditions"]) + ",\n"
    }
    if def_obj.contains_key("stage3_cascade_ready_conditions") {
        s = s + "    \"stage3_cascade_ready_conditions\": " + json_stringify(def_obj["stage3_cascade_ready_conditions"]) + ",\n"
    }
    s = s + "    \"expected_artifacts\": " + json_stringify(def_obj["expected_artifacts"]) + ",\n"
    s = s + "    \"abort_thresholds\": "   + json_stringify(def_obj["abort_thresholds"]) + ",\n"
    s = s + "    \"kickoff_command\": \""  + _json_escape(to_string(def_obj["kickoff_command"])) + "\",\n"
    if def_obj.contains_key("kickoff_command_p1") {
        s = s + "    \"kickoff_command_p1\": \"" + _json_escape(to_string(def_obj["kickoff_command_p1"])) + "\",\n"
        s = s + "    \"kickoff_command_p2\": \"" + _json_escape(to_string(def_obj["kickoff_command_p2"])) + "\",\n"
        s = s + "    \"kickoff_command_p3\": \"" + _json_escape(to_string(def_obj["kickoff_command_p3"])) + "\",\n"
        s = s + "    \"kickoff_command_p4\": \"" + _json_escape(to_string(def_obj["kickoff_command_p4"])) + "\",\n"
    }
    s = s + "    \"post_launch_verify\": \"" + _json_escape(to_string(def_obj["post_launch_verify"])) + "\",\n"
    s = s + "    \"guardrails\": "         + json_stringify(def_obj["guardrails"]) + ",\n"
    s = s + "    \"landmines\": "          + json_stringify(def_obj["landmines"])  + ",\n"
    s = s + "    \"prereq_rollup\": {\"pass_n\":" + to_string(roll["pass_n"])
    s = s + ",\"miss_n\":" + to_string(roll["miss_n"])
    s = s + ",\"wrong_n\":" + to_string(roll["wrong_n"])
    s = s + ",\"total\":" + to_string(roll["total"]) + "},\n"
    s = s + "    \"prereqs\": " + _render_prereq_list(prereq_verdicts) + ",\n"
    s = s + "    \"verdict\": \"" + _json_escape(verdict) + "\"\n"
    s = s + "  }"
    return s
}

// ─── main run ─────────────────────────────────────────────────────────────

fn run(emit_path: string, also_print: bool) -> int {
    let ts = _ts_iso()
    println("── h100_launch_manifest_spec " + ts + " ──")

    // Stage 1
    let s1_def = _stage1_def()
    let s1_req = _stage1_prereqs()
    let mut s1_v = []
    let mut i = 0
    while i < len(s1_req) {
        s1_v = push(s1_v, _eval_prereq(s1_req[i]))
        i = i + 1
    }
    let s1_roll = _rollup(s1_v)
    let s1_cascade = _cascade_blocked(s1_v, s1_req)  // should be false — Stage 1 has no cascade dep
    let s1_verdict = _stage_verdict(s1_roll, s1_cascade)

    // Stage 2
    let s2_def = _stage2_def()
    let s2_req = _stage2_prereqs()
    let mut s2_v = []
    i = 0
    while i < len(s2_req) {
        s2_v = push(s2_v, _eval_prereq(s2_req[i]))
        i = i + 1
    }
    let s2_roll = _rollup(s2_v)
    let s2_cascade = _cascade_blocked(s2_v, s2_req)
    let s2_verdict = _stage_verdict(s2_roll, s2_cascade)

    // Stage 3
    let s3_def = _stage3_def()
    let s3_req = _stage3_prereqs()
    let mut s3_v = []
    i = 0
    while i < len(s3_req) {
        s3_v = push(s3_v, _eval_prereq(s3_req[i]))
        i = i + 1
    }
    let s3_roll = _rollup(s3_v)
    let s3_cascade = _cascade_blocked(s3_v, s3_req)
    let s3_verdict = _stage_verdict(s3_roll, s3_cascade)

    // Print stage summary
    println("  Stage 1 (#9 ALM r13)           verdict=" + s1_verdict +
            " pass=" + to_string(s1_roll["pass_n"]) + "/" + to_string(s1_roll["total"]))
    println("  Stage 2 (#10 Phi 4-path)       verdict=" + s2_verdict +
            " pass=" + to_string(s2_roll["pass_n"]) + "/" + to_string(s2_roll["total"]) +
            (if s2_cascade { " [cascade-blocked by Stage-1]" } else { "" }))
    println("  Stage 3 (#11 ship + #21 AGI)   verdict=" + s3_verdict +
            " pass=" + to_string(s3_roll["pass_n"]) + "/" + to_string(s3_roll["total"]) +
            (if s3_cascade { " [cascade-blocked by Stage-1/2]" } else { "" }))

    // Prev hash chain (raw#10 proof-carrying)
    let mut prev_hash = ""
    if _file_exists(emit_path) { prev_hash = _sha256_file(emit_path) }

    // Assemble manifest JSON
    let mut body = "{\n"
    body = body + "  \"schema\": \"anima/h100_launch_manifest/1\",\n"
    body = body + "  \"generated_at\": \"" + _json_escape(ts) + "\",\n"
    body = body + "  \"generated_at_epoch\": " + _ts_epoch() + ",\n"
    body = body + "  \"generator\": \"tool/h100_launch_manifest_spec.hexa\",\n"
    body = body + "  \"anima_root\": \""  + _json_escape(ANIMA_ROOT) + "\",\n"
    body = body + "  \"prev_hash\": \""   + prev_hash + "\",\n"
    body = body + "  \"policy\": {\n"
    body = body + "    \"launch_policy\": \"needs_user_approval\",\n"
    body = body + "    \"auto_dispatch_allowed\": false,\n"
    body = body + "    \"real_api_calls\": false,\n"
    body = body + "    \"note\": \"This manifest is a frozen plan. No remote resources are provisioned by running this tool. Re-run after each stage completes to re-verify the next stage's gate.\"\n"
    body = body + "  },\n"
    body = body + "  \"one_command_kickoff\": {\n"
    body = body + "    \"stage1\": \"" + _json_escape(to_string(s1_def["kickoff_command"])) + "\",\n"
    body = body + "    \"stage2\": \"" + _json_escape(to_string(s2_def["kickoff_command"])) + "\",\n"
    body = body + "    \"stage2_p1_qwen3_8b\": \""        + _json_escape(to_string(s2_def["kickoff_command_p1"])) + "\",\n"
    body = body + "    \"stage2_p2_llama_3_1_8b\": \""    + _json_escape(to_string(s2_def["kickoff_command_p2"])) + "\",\n"
    body = body + "    \"stage2_p3_ministral_3_14b\": \"" + _json_escape(to_string(s2_def["kickoff_command_p3"])) + "\",\n"
    body = body + "    \"stage2_p4_gemma_4_31b\": \""  + _json_escape(to_string(s2_def["kickoff_command_p4"])) + "\",\n"
    body = body + "    \"stage3\": \"" + _json_escape(to_string(s3_def["kickoff_command"])) + "\"\n"
    body = body + "  },\n"
    body = body + "  \"overall_verdict\": {\n"
    body = body + "    \"stage1\": \"" + s1_verdict + "\",\n"
    body = body + "    \"stage2\": \"" + s2_verdict + "\",\n"
    body = body + "    \"stage3\": \"" + s3_verdict + "\"\n"
    body = body + "  },\n"
    body = body + "  \"stages\": [\n"
    body = body + _render_stage_json(1, s1_def, s1_v, s1_roll, s1_verdict) + ",\n"
    body = body + _render_stage_json(2, s2_def, s2_v, s2_roll, s2_verdict) + ",\n"
    body = body + _render_stage_json(3, s3_def, s3_v, s3_roll, s3_verdict) + "\n"
    body = body + "  ]\n"
    body = body + "}\n"

    // Ensure parent dir
    let pdir = emit_path.substring(0, _last_slash(emit_path))
    if pdir != "" { exec_with_status("mkdir -p " + _sh_quote(pdir)) }

    write_file(emit_path, body)
    let cur_hash = _sha256_str(body)
    println("  manifest=" + emit_path)
    println("  prev_hash=" + prev_hash)
    println("  cur_hash=" + cur_hash)

    if also_print { println(body) }

    return 0
}

fn _last_slash(p: string) -> int {
    let mut i = len(p) - 1
    while i >= 0 {
        if p.substring(i, i + 1) == "/" { return i }
        i = i - 1
    }
    return -1
}

// ─── self-test — 3 synthetic scenarios for prereq evaluator ──────────────

fn self_test() -> int {
    println("── h100_launch_manifest_spec self-test ──")

    // Scenario 1: file prereq that exists
    let s1 = _mk_file("/Users/ghost/core/anima/config/alm_r13_v2_config.json", "existing file")
    let v1 = _eval_prereq(s1)
    let ok1 = (to_string(v1["verdict"]) == "PASS")

    // Scenario 2: file prereq that does NOT exist
    let s2 = _mk_file("/Users/ghost/core/anima/state/this_file_should_not_exist_42.json", "nonexistent file")
    let v2 = _eval_prereq(s2)
    let ok2 = (to_string(v2["verdict"]) == "MISSING")

    // Scenario 3: json field check against a real artifact
    let s3 = _mk_jfield("/Users/ghost/core/anima/state/alm_r13_drill_breakthrough.json",
        "verdict", "PASS", "drill verdict=PASS")
    let v3 = _eval_prereq(s3)
    let ok3 = (to_string(v3["verdict"]) == "PASS")

    // Scenario 4: json_field_any against real cert_gate_result verdict
    let s4 = _mk_jfield_any("/Users/ghost/core/anima/state/cert_gate_result.json",
        "verdict", "BASE_OR_ABOVE,FULL_REWARD", "cert_gate any-of")
    let v4 = _eval_prereq(s4)
    let ok4 = (to_string(v4["verdict"]) == "PASS")

    let mut pass = 0
    let mut fail = 0
    if ok1 { println("  S1 PASS (existing file)");        pass = pass + 1 }
    else   { println("  S1 FAIL got " + to_string(v1["verdict"])); fail = fail + 1 }
    if ok2 { println("  S2 PASS (missing file)");         pass = pass + 1 }
    else   { println("  S2 FAIL got " + to_string(v2["verdict"])); fail = fail + 1 }
    if ok3 { println("  S3 PASS (json field match)");     pass = pass + 1 }
    else   { println("  S3 FAIL got " + to_string(v3["verdict"])); fail = fail + 1 }
    if ok4 { println("  S4 PASS (json field any-of)");    pass = pass + 1 }
    else   { println("  S4 FAIL got " + to_string(v4["verdict"])); fail = fail + 1 }

    println("manifest_spec selftest: " + to_string(pass) + "/4 PASS, " + to_string(fail) + " FAIL")
    if fail > 0 { return 1 }
    return 0
}

// ─── entry ────────────────────────────────────────────────────────────────

fn main() -> int {
    let av = _argv()
    if _flag(av, "--help") || _flag(av, "-h") {
        println("usage: hexa run tool/h100_launch_manifest_spec.hexa [--self-test] [--print] [--out <path>]")
        return 0
    }
    if _flag(av, "--self-test") || _flag(av, "self-test") {
        return self_test()
    }
    let also_print = _flag(av, "--print")
    return run(MANIFEST_OUT, also_print)
}
