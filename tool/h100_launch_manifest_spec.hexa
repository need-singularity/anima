// ─── STAGE 2: #10 Φ 4-path cross validation prereqs ──────────────────────
//
// Hard gating rule:
//   Stage-2 is only launchable AFTER #9 empirical AN11(a) PASS appears in
//   state/an11_weight_emergent_verdict.json (live field) OR an equivalent
//   post-H100 empirical artifact state/alm_r13_an11_a_live.json. At
//   manifest-emit time those will not yet exist — stage verdict becomes
//   NOT_READY with reason cascade_blocked. This is the intended design:
//   a single command emits the manifest; user sees verdicts; kicks off
//   Stage-1; re-runs this tool post-Stage-1 to re-verify Stage-2 gate.

fn _stage2_prereqs() -> array {
    let mut o = []
    // phi extractor FFI wire (required for 4-substrate live Φ)
    o = push(o, _mk_file(ANIMA_ROOT + "/tool/phi_extractor_ffi_wire.hexa",
        "phi_extractor_ffi_wire.hexa (GPU substrate bridge)"))
    // Stage-1 empirical outcome — must exist with verdict=PASS
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/alm_r13_an11_a_live.json",
        "verdict", "PASS",
        "Stage-1 AN11(a) live empirical verdict=PASS (cascade gate)"))
    // substrate variants config (enumerated 4 substrates)
    o = push(o, _mk_file(ANIMA_ROOT + "/config/phi_4path_substrates.json",
        "Φ 4-path substrate variants config (TBD — not yet landed)"))
    // eigenvec basis shared with Stage-1
    o = push(o, _mk_jfield(ANIMA_ROOT + "/.meta2-cert/cell-eigenvec-16.json",
        "verdict", "VERIFIED",
        "cell-eigenvec-16 verdict=VERIFIED (shared basis)"))
    return o
}

