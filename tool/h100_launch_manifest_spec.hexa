// ════════════════════════════════════════════════════════════════════════════
//  tool/h100_launch_manifest_spec.hexa — Anima H100 3-stage launch manifest
//
//  PURPOSE
//    Frozen, single-shot kickoff manifest for roadmap #9 / #10 / #11.
//    This tool performs NO remote API calls. It only:
//      (1) walks each stage's prereq artifact list,
//      (2) reads verdict fields from canonical state/*.json SSOT,
//      (3) emits a READY / MISSING_PREREQ / NOT_READY verdict per stage,
//      (4) writes state/h100_launch_manifest.json with the full frozen plan
//          including exact kick-off commands, env vars, expected artifacts,
//          and abort thresholds so the user can issue one command to launch.
//
//  ROADMAP ENTRIES COVERED
//    #9  Stage-1: ALM r13 launch + AN11(a) weight_emergent 실증
//         → 1× H100 × 14d, user budget ≈ $300-500
//    #10 Stage-2: Φ substrate independence — 4-path cross validation
//         → 4× H100 × 10-15d, user budget ≈ $1-1.5k
//         → cascade-gated: requires #9 AN11(a) PASS
//    #11 Stage-3: ALM consciousness ship + #21 AGI (cascade)
//         → automatic after #9 + #10 success
//
//  RAW COMPLIANCE
//    raw#9  hexa-only deterministic verifier (no .py/.rs/.sh business logic)
//    raw#10 proof-carrying: emits manifest JSON with SHA prev-hash chain
//    raw#11 ai-native: every verdict is regex/file-existence/json-field check
//    raw#12 no cherry-pick: stages iterated in strict order 1 → 2 → 3
//    raw#15 no-hardcode: all prereq paths declared in tables below; if future
//           prereqs are added they go here, code unchanged
//    raw#34 no-backup: no .bak variants
//
//  STRICT CONSTRAINTS (from user directive)
//    - NO real runpod/lambda API invocations.
//    - NO .py under tool/ (R37/AN13).
//    - NO .roadmap edits.
//    - NO git commit.
//    - NO fake-pass: every prereq is really checked.
//
//  USAGE
//    hexa run tool/h100_launch_manifest_spec.hexa                  # verify+emit
//    hexa run tool/h100_launch_manifest_spec.hexa --dry-run        # same (explicit)
//    hexa run tool/h100_launch_manifest_spec.hexa --print          # emit to stdout also
//    hexa run tool/h100_launch_manifest_spec.hexa --self-test      # scenario tests
//
//  EXIT
//    0 = manifest emitted (verdicts per stage inside JSON)
//    1 = self-test FAIL
//    2 = manifest writer I/O failure
// ════════════════════════════════════════════════════════════════════════════

let ANIMA_ROOT   = "/Users/ghost/core/anima"
let MANIFEST_OUT = "/Users/ghost/core/anima/state/h100_launch_manifest.json"

// ─── shell / io helpers (same pattern as h100_auto_kill.hexa) ─────────────

// INLINE_DEPRECATED[H42]: see shared/util/sh_quote.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}
// INLINE_DEPRECATED[H42]: see shared/util/file_exists.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _file_exists(p: string) -> bool {
    return exec_with_status("test -e " + _sh_quote(p))[1] == 0
}
// Native primitives honor SOURCE_DATE_EPOCH / HEXA_REPRODUCIBLE=1 (hexa-lang PR #23).
// Replaces previous `date -u` exec — re-emit is now byte-stable when env set.
// INLINE_DEPRECATED[H42]: see shared/util/ts_iso.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _ts_iso() -> string {
    return to_string(utc_iso_now())
}
fn _ts_epoch() -> string {
    return to_string(now())
}
// INLINE_DEPRECATED[H42]: see shared/util/json_escape.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
}
fn _sha256_file(p: string) -> string {
    if !_file_exists(p) { return "" }
    let r = exec_with_status("shasum -a 256 " + _sh_quote(p) + " | awk '{print $1}'")
    return to_string(r[0]).trim()
}
fn _sha256_str(s: string) -> string {
    let q = _sh_quote(s)
    let r = exec_with_status("printf %s " + q + " | shasum -a 256 | awk '{print $1}'")
    return to_string(r[0]).trim()
}

// ─── argv parsing ─────────────────────────────────────────────────────────

fn _argv() -> array {
    let a = args()
    let mut o = []
    let mut i = 2
    while i < len(a) { o.push(a[i]); i = i + 1 }
    return o
}
fn _flag(av, k) -> bool {
    for x in av { if to_string(x) == k { return true } }
    return false
}

// ─── JSON field probe: returns string value (empty if missing/malformed) ──

fn _json_field_str(path: string, key: string) -> string {
    if !_file_exists(path) { return "" }
    let obj = json_parse(read_file(path))
    if !obj.contains_key(key) { return "" }
    return to_string(obj[key])
}

// ─── prereq descriptor schema ─────────────────────────────────────────────
//
// A prereq is a map with:
//   kind   ∈ {"file", "json_field"}
//   path   : absolute path
//   key    : (json_field only) top-level key
//   want   : (json_field only) expected value OR array of acceptable values
//   label  : human description
//
// Verdict per prereq: PASS / MISSING / WRONG_VALUE

fn _mk_file(path: string, label: string) {
    let mut r = json_parse("{}")
    r["kind"]  = "file"
    r["path"]  = path
    r["label"] = label
    return r
}
fn _mk_jfield(path: string, key: string, want: string, label: string) {
    let mut r = json_parse("{}")
    r["kind"]  = "json_field"
    r["path"]  = path
    r["key"]   = key
    r["want"]  = want
    r["label"] = label
    return r
}
fn _mk_jfield_any(path: string, key: string, want_csv: string, label: string) {
    // want_csv: comma-separated acceptable values (e.g. "BASE_OR_ABOVE,FULL_REWARD")
    let mut r = json_parse("{}")
    r["kind"]      = "json_field_any"
    r["path"]      = path
    r["key"]       = key
    r["want_csv"]  = want_csv
    r["label"]     = label
    return r
}

fn _eval_prereq(p) {
    let mut v = json_parse("{}")
    let kind = to_string(p["kind"])
    let path = to_string(p["path"])
    v["label"] = to_string(p["label"])
    v["kind"]  = kind
    v["path"]  = path

    if kind == "file" {
        if _file_exists(path) {
            v["verdict"] = "PASS"
            v["detail"]  = "exists"
        } else {
            v["verdict"] = "MISSING"
            v["detail"]  = "file_not_found"
        }
        return v
    }

    if kind == "json_field" {
        if !_file_exists(path) {
            v["verdict"] = "MISSING"
            v["detail"]  = "file_not_found"
            return v
        }
        let key  = to_string(p["key"])
        let want = to_string(p["want"])
        let got  = _json_field_str(path, key)
        v["key"]  = key
        v["want"] = want
        v["got"]  = got
        if got == "" {
            v["verdict"] = "MISSING"
            v["detail"]  = "key_absent:" + key
        } else if got == want {
            v["verdict"] = "PASS"
            v["detail"]  = "match"
        } else {
            v["verdict"] = "WRONG_VALUE"
            v["detail"]  = "want=" + want + " got=" + got
        }
        return v
    }

    if kind == "json_field_any" {
        if !_file_exists(path) {
            v["verdict"] = "MISSING"
            v["detail"]  = "file_not_found"
            return v
        }
        let key      = to_string(p["key"])
        let want_csv = to_string(p["want_csv"])
        let got      = _json_field_str(path, key)
        v["key"]      = key
        v["want_csv"] = want_csv
        v["got"]      = got
        if got == "" {
            v["verdict"] = "MISSING"
            v["detail"]  = "key_absent:" + key
            return v
        }
        let accepted = want_csv.split(",")
        let mut ok = false
        for a in accepted {
            if to_string(a).trim() == got { ok = true }
        }
        if ok {
            v["verdict"] = "PASS"
            v["detail"]  = "match_any"
        } else {
            v["verdict"] = "WRONG_VALUE"
            v["detail"]  = "want_any=" + want_csv + " got=" + got
        }
        return v
    }

    v["verdict"] = "MISSING"
    v["detail"]  = "unknown_kind:" + kind
    return v
}

