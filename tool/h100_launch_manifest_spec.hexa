    o = push(o, _mk_file(ANIMA_ROOT + "/tool/cert_gate.hexa",
        "cert_gate.hexa reward-shaping gate present"))
    o = push(o, _mk_jfield_any(ANIMA_ROOT + "/state/cert_gate_result.json",
        "verdict", "BASE_OR_ABOVE,FULL_REWARD",
        "cert_gate verdict ∈ {BASE_OR_ABOVE, FULL_REWARD}"))
    // r13 config
    o = push(o, _mk_file(ANIMA_ROOT + "/config/alm_r13_v2_config.json",
        "config/alm_r13_v2_config.json frozen"))
    // drill breakthrough redesign PASS
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/alm_r13_drill_breakthrough.json",
        "verdict", "PASS",
        "drill_breakthrough_runner r13 redesign verdict=PASS"))
    // numerical bound within spec
    o = push(o, _mk_jfield(ANIMA_ROOT + "/state/numerical_bound_report.json",
        "within_bound", "true",
        "numerical_bound_report.within_bound=true"))
    // path_b e2e dry-run
