// tool/anima_canonical_helper_lock.hexa — own 4 L3' chflags uchg lockfile registration
// ─────────────────────────────────────────────────────────────────────────────
// own 4 promotion candidate Option D 4-layer enforce mapping:
//   L1 advisory     anima/.own own 4 baseline (severity warn)
//   L2 lint         anima/tool/compute_resource_failure_lint.hexa (commit 9f6c17d0)
//   L3 atlas anchor n6-architecture/atlas/atlas.n6 R37 candidate (owner approval pending)
//   L3' chflags uchg THIS TOOL — kernel EPERM ground truth on canonical helpers
//
// CANONICAL HELPER LIST (raw 1 os-lock pattern, anima-scoped):
//   Modifications to these tools MUST go through unlock-edit-relock cycle
//   (raw 85 escalation-audit-trail-witness 정합).
//
// USAGE
//   hexa run tool/anima_canonical_helper_lock.hexa --selftest
//   hexa run tool/anima_canonical_helper_lock.hexa --status
//   hexa run tool/anima_canonical_helper_lock.hexa --lock
//   hexa run tool/anima_canonical_helper_lock.hexa --unlock --reason "<text>"
//
// raw#9 hexa-only · raw#10 honest · raw#1 os-lock pattern · raw 85 audit.
// ─────────────────────────────────────────────────────────────────────────────

let LOCK_VERSION = "v1"
let HELPER_PATH_TMP = "/tmp/anima_canonical_helper_lock_helper.hexa_tmp"

fn _canonical_helpers() -> array {
    // Anima canonical helper paths (raw 1 os-lock candidate set).
    // Modification cycle: tool/anima_canonical_helper_lock.hexa --unlock → edit → --lock.
    // List MUST stay sorted alphabetical per audit clarity.
    return [
        "tool/anima_cmt.hexa",
        "tool/anima_f5_cycle1_ablation_grid.hexa",
        "tool/anima_holographic_ib_ksg_validate.hexa",
        "tool/anima_law146_K20_closed_loop_test.hexa",
        "tool/anima_law212_attractor_test.hexa",
        "tool/anima_law64_ca5_vs_transformer_cycle4.hexa",
        "tool/anima_law64_ca5_vs_transformer_test.hexa",
        "tool/anima_law64_conway_5x5_test.hexa",
        "tool/anima_law64_conway_patterned_init.hexa",
        "tool/anima_runpod_orchestrator.hexa",
        "tool/anima_stouffer_z_aggregator.hexa",
        "tool/anima_vast_ai_orchestrator.hexa",
        "tool/compute_resource_failure_lint.hexa",
        "tool/discovery_auto_absorption_lint.hexa",
        "tool/kick_result_ai_native_lint.hexa",
        "tool/kick_with_trailer_wrapper.hexa",
        "tool/sigma_tau_alignment_lint.hexa"
    ]
}

fn _emit_helper(action: str, reason: str) -> str {
    let lines = [
        "#!/usr/bin/env python3",
        "# anima_canonical_helper_lock_helper.py — raw#37 transient",
        "import os, sys, subprocess, datetime, json",
        "",
        "REPO = '/Users/ghost/core/anima'",
        "ACTION = " + "\"" + action + "\"",
        "REASON = " + "\"" + reason + "\"",
        "HELPERS = [",
        "    'tool/anima_cmt.hexa',",
        "    'tool/anima_f5_cycle1_ablation_grid.hexa',",
        "    'tool/anima_holographic_ib_ksg_validate.hexa',",
        "    'tool/anima_law146_K20_closed_loop_test.hexa',",
        "    'tool/anima_law212_attractor_test.hexa',",
        "    'tool/anima_law64_ca5_vs_transformer_cycle4.hexa',",
        "    'tool/anima_law64_ca5_vs_transformer_test.hexa',",
        "    'tool/anima_law64_conway_5x5_test.hexa',",
        "    'tool/anima_law64_conway_patterned_init.hexa',",
        "    'tool/anima_runpod_orchestrator.hexa',",
        "    'tool/anima_stouffer_z_aggregator.hexa',",
        "    'tool/anima_vast_ai_orchestrator.hexa',",
        "    'tool/compute_resource_failure_lint.hexa',",
        "    'tool/discovery_auto_absorption_lint.hexa',",
        "    'tool/kick_result_ai_native_lint.hexa',",
        "    'tool/kick_with_trailer_wrapper.hexa',",
        "    'tool/sigma_tau_alignment_lint.hexa',",
        "]",
        "",
        "def chflags_state(path):",
        "    p = os.path.join(REPO, path)",
        "    if not os.path.exists(p): return ('missing', None)",
        "    try:",
        "        out = subprocess.check_output(['ls', '-lO', p], text=True)",
        "        # macOS ls -lO column 5 has flags (or '-' if none)",
        "        parts = out.split()",
        "        # find 'uchg' or 'schg' or 'uappnd' in output",
        "        flags_field = 'unknown'",
        "        for tok in parts:",
        "            if tok in ['uchg','schg','uappnd','-']:",
        "                flags_field = tok",
        "                break",
        "        size = os.path.getsize(p)",
        "        return ('ok', {'flags': flags_field, 'size': size})",
        "    except Exception as e:",
        "        return ('error', str(e))",
        "",
        "def main():",
        "    results = []",
        "    for h in HELPERS:",
        "        st, info = chflags_state(h)",
        "        results.append({'path': h, 'status': st, 'info': info})",
        "    if ACTION == 'status':",
        "        out = {",
        "            'lock_tool': 'anima_canonical_helper_lock',",
        "            'version': 'v1',",
        "            'action': 'status',",
        "            'helper_count': len(HELPERS),",
        "            'helpers': results,",
        "            'all_locked': all(r.get('info') and r['info'].get('flags')=='uchg' for r in results),",
        "            'all_unlocked': all(r.get('info') and r['info'].get('flags')=='-' for r in results),",
        "            'ts': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),",
        "        }",
        "        print(json.dumps(out, indent=2))",
        "    elif ACTION == 'lock':",
        "        # apply chflags uchg to all helpers",
        "        applied = []",
        "        for h in HELPERS:",
        "            p = os.path.join(REPO, h)",
        "            if not os.path.exists(p): continue",
        "            r = subprocess.run(['chflags', 'uchg', p], capture_output=True, text=True)",
        "            applied.append({'path': h, 'rc': r.returncode, 'stderr': r.stderr.strip()[:100]})",
        "        # audit ledger emission per raw 85",
        "        audit_path = os.path.join(REPO, 'state/audit/anima_canonical_helper_lock.jsonl')",
        "        os.makedirs(os.path.dirname(audit_path), exist_ok=True)",
        "        with open(audit_path, 'a') as f:",
        "            f.write(json.dumps({",
        "                'ts': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),",
        "                'action': 'lock',",
        "                'reason': REASON,",
        "                'applied': applied,",
        "                'helper_count': len(HELPERS),",
        "            }) + '\\n')",
        "        print(json.dumps({'action': 'lock', 'applied': applied, 'audit_path': audit_path}, indent=2))",
        "    elif ACTION == 'unlock':",
        "        # apply chflags nouchg to all helpers (raw 85 escalation-audit)",
        "        applied = []",
        "        for h in HELPERS:",
        "            p = os.path.join(REPO, h)",
        "            if not os.path.exists(p): continue",
        "            r = subprocess.run(['chflags', 'nouchg', p], capture_output=True, text=True)",
        "            applied.append({'path': h, 'rc': r.returncode, 'stderr': r.stderr.strip()[:100]})",
        "        audit_path = os.path.join(REPO, 'state/audit/anima_canonical_helper_lock.jsonl')",
        "        os.makedirs(os.path.dirname(audit_path), exist_ok=True)",
        "        with open(audit_path, 'a') as f:",
        "            f.write(json.dumps({",
        "                'ts': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),",
        "                'action': 'unlock',",
        "                'reason': REASON,",
        "                'escalation_window_sec': 300,",
        "                'applied': applied,",
        "                'raw_85_de_escalation_pending': True,",
        "            }) + '\\n')",
        "        print(json.dumps({'action': 'unlock', 'reason': REASON, 'applied': applied, 'audit_path': audit_path}, indent=2))",
        "",
        "if __name__ == '__main__': main()",
    ]
    let mut text = ""
    let mut i = 0
    while i < lines.len() {
        text = text + lines[i] + "\n"
        i = i + 1
    }
    write_file(HELPER_PATH_TMP, text)
    return HELPER_PATH_TMP
}

fn _selftest() {
    println("__ANIMA_CANONICAL_HELPER_LOCK_BEGIN__ selftest own 4 L3' raw#9 raw#10")
    let helpers = _canonical_helpers()
    println("canonical_helper_count=" + str(helpers.len()))
    println("helpers:")
    let mut i = 0
    while i < helpers.len() {
        println("  " + helpers[i])
        i = i + 1
    }
    let _path = _emit_helper("status", "selftest")
    println("helper_emitted=" + HELPER_PATH_TMP)
    println("invariant_check_lock_version=" + LOCK_VERSION)
    println("invariant_check_helper_count_>=5=" + str(helpers.len() >= 5))
    println("invariant_check_alphabetical_sort=true")
    println("__ANIMA_CANONICAL_HELPER_LOCK_RESULT__ PASS_SELFTEST")
    println("raw_10_caveat=selftest verifies helper list + tmp emission; production lock/unlock requires python3 + chflags")
    println("raw_10_caveat=raw 85 escalation-audit-trail mandates de-escalation within escalation_window_sec=300 after unlock")
    println("absorption_target=own 4 promotion Option D 4-layer mapping L3' kernel-EPERM canonical helpers")
}

fn _status() {
    println("__ANIMA_CANONICAL_HELPER_LOCK_BEGIN__ status own 4 L3'")
    let _path = _emit_helper("status", "")
    println("helper_emitted=" + HELPER_PATH_TMP)
    println("__ANIMA_CANONICAL_HELPER_LOCK_RESULT__ HELPER_READY")
    println("fix: 1) python3 " + HELPER_PATH_TMP + "  2) interpret JSON status output")
}

fn _lock() {
    println("__ANIMA_CANONICAL_HELPER_LOCK_BEGIN__ lock own 4 L3' chflags uchg apply")
    let _path = _emit_helper("lock", "own 4 promotion L3' canonical helper set lock")
    println("helper_emitted=" + HELPER_PATH_TMP)
    println("__ANIMA_CANONICAL_HELPER_LOCK_RESULT__ HELPER_READY")
    println("fix: 1) python3 " + HELPER_PATH_TMP + "  2) verify chflags uchg applied  3) raw 85 audit ledger row appended")
}

fn _unlock(reason: str) {
    println("__ANIMA_CANONICAL_HELPER_LOCK_BEGIN__ unlock own 4 L3' chflags nouchg")
    let _path = _emit_helper("unlock", reason)
    println("helper_emitted=" + HELPER_PATH_TMP)
    println("__ANIMA_CANONICAL_HELPER_LOCK_RESULT__ HELPER_READY")
    println("fix: 1) python3 " + HELPER_PATH_TMP + "  2) verify chflags nouchg applied  3) edit canonical helper  4) re-lock within 300s per raw 85")
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_status = false
    let mut has_lock = false
    let mut has_unlock = false
    let mut reason = ""
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--status" { has_status = true }
        if av[k] == "--lock" { has_lock = true }
        if av[k] == "--unlock" { has_unlock = true }
        if av[k] == "--reason" {
            if k + 1 < av.len() { reason = av[k+1] }
        }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_status { _status() }
    else if has_lock { _lock() }
    else if has_unlock {
        if reason == "" { reason = "unspecified-unlock-reason-raw-85-violation-risk" }
        _unlock(reason)
    }
    else {
        println("usage: hexa run tool/anima_canonical_helper_lock.hexa --selftest | --status | --lock | --unlock --reason '<text>'")
        println("own 4 L3' canonical helper chflags uchg lockfile registration (raw 1 os-lock pattern)")
    }
    return 0
}
