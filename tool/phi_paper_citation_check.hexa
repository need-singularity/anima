// ════════════════════════════════════════════════════════════════════════════
//  tool/phi_paper_citation_check.hexa
//  B.3 Φ empirical paper v1 preliminary — internal cross-ref validator
//
//  PARENT
//    docs/papers/phi_paradigm_paper_v1_preliminary.md §8 References
//    docs/upstream_notes/b_axis_post_h100_mk_xii_r14_paper_20260422.md §B.3
//
//  PURPOSE
//    Validate that every internal anima reference cited in the v1 paper exists
//    as an actual file (or directory) on disk. External citations are tagged
//    [EXT-*-PLACEHOLDER] in the paper and are skipped here (v2 will substitute
//    during LaTeX typesetting).
//
//  CHECKS
//    For each expected internal path:
//      - path exists on disk (exec test -e)
//      - categorize: DOC / CONFIG / TOOL / STATE / UPSTREAM
//
//  OUTPUT
//    state/phi_paper_citation_check.json
//
//  RAW STRICT
//    hexa-only · deterministic · idempotent · NO .py
//
//  EXIT
//    0 = all internal references resolve
//    1 = one or more references missing
//
//  USAGE
//    /Users/ghost/.hx/bin/hexa run tool/phi_paper_citation_check.hexa
// ════════════════════════════════════════════════════════════════════════════

let SCHEMA      = "anima/phi_paper_citation_check/1"
let SEED_DATE   = "20260422"
let OUT_PATH    = "state/phi_paper_citation_check.json"
let PAPER_PATH  = "docs/papers/phi_paradigm_paper_v1_preliminary.md"

fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }

// exec test -e (exists, any type). Returns true if exit 0.
fn path_exists(p: string) -> bool {
    let cmd = "test -e '" + p + "' && echo YES || echo NO"
    let out = exec(cmd).trim()
    return out == "YES"
}

// ─── reference registry (mirrors docs/papers/phi_paradigm_paper_v1_preliminary.md §8) ──

fn ref_count() -> int { return 22 }

fn ref_path(i: int) -> string {
    if i ==  0 { return "docs/anima_three_paradigm_unified_20260422.md" }
    if i ==  1 { return "docs/cell_learning_method_paradigm_20260422.md" }
    if i ==  2 { return "docs/alm_r14_design_v1_20260422.md" }
    if i ==  3 { return "docs/phi_convergence_monitoring_spec.md" }
    if i ==  4 { return "docs/phi_4path_divergence_response.md" }
    if i ==  5 { return "config/phi_4path_substrates.json" }
    if i ==  6 { return "config/lora_rank_per_path.json" }
    if i ==  7 { return "config/phi_cpu_synthetic_spec.json" }
    if i ==  8 { return "tool/phi_cpu_synthetic_4path.hexa" }
    if i ==  9 { return "tool/phi_extractor_ffi_wire.hexa" }
    if i == 10 { return "tool/phi_substrate_probe.hexa" }
    if i == 11 { return "tool/phi_paper_figure_spec.hexa" }
    if i == 12 { return "tool/phi_paper_citation_check.hexa" }
    if i == 13 { return "state/phi_cpu_synthetic_4path_result.json" }
    if i == 14 { return "state/phi_cpu_synthetic_4path.jsonl" }
    if i == 15 { return "state/h100_launch_manifest.json" }
    if i == 16 { return "state/asset_archive_log.jsonl" }
    if i == 17 { return "docs/upstream_notes/b_axis_post_h100_mk_xii_r14_paper_20260422.md" }
    if i == 18 { return "docs/upstream_notes/cpu_superlimit_synthetic_4path_proposal_20260422.md" }
    if i == 19 { return "state/phi_paper_figures_spec.json" }
    if i == 20 { return "state/phi_paper_citation_check.json" }
    if i == 21 { return "docs/papers/phi_paradigm_paper_v1_preliminary.md" }
    return ""
}

fn ref_category(i: int) -> string {
    if i == 0 || i == 1 || i == 2 || i == 3 || i == 4 { return "DOC" }
    if i == 5 || i == 6 || i == 7 { return "CONFIG" }
    if i == 8 || i == 9 || i == 10 || i == 11 || i == 12 { return "TOOL" }
    if i == 13 || i == 14 || i == 15 || i == 16 || i == 19 || i == 20 { return "STATE" }
    if i == 17 || i == 18 { return "UPSTREAM" }
    if i == 21 { return "DOC" }
    return "UNKNOWN"
}

// Some references are "may_exist_after_this_run" (self-referential outputs).
// These are allowed to miss on first invocation — but warned.
fn ref_soft(i: int) -> bool {
    if i == 19 { return true }   // state/phi_paper_figures_spec.json — emitted by sibling tool
    if i == 20 { return true }   // state/phi_paper_citation_check.json — emitted by THIS tool
    return false
}

// ─── main ──────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let mut selftest_only = false
    let mut k = 0
    while k < argv.len() {
        if argv[k] == "--selftest" { selftest_only = true }
        k = k + 1
    }

    println("[phi_paper_cite] B.3 Φ paper v1 — internal cross-ref validator")
    println("[phi_paper_cite] paper=" + PAPER_PATH)

    let n = ref_count()
    let mut rows = []
    let mut ok_hard = 0
    let mut ok_soft = 0
    let mut miss_hard = 0
    let mut miss_soft = 0

    let mut doc_count = 0
    let mut config_count = 0
    let mut tool_count = 0
    let mut state_count = 0
    let mut upstream_count = 0

    let mut i = 0
    while i < n {
        let p = ref_path(i)
        let cat = ref_category(i)
        let soft = ref_soft(i)
        let ex = path_exists(p)
        let row = [p, cat, soft, ex]
        rows = rows.push(row)

        if cat == "DOC" { doc_count = doc_count + 1 }
        if cat == "CONFIG" { config_count = config_count + 1 }
        if cat == "TOOL" { tool_count = tool_count + 1 }
        if cat == "STATE" { state_count = state_count + 1 }
        if cat == "UPSTREAM" { upstream_count = upstream_count + 1 }

        if ex {
            if soft { ok_soft = ok_soft + 1 } else { ok_hard = ok_hard + 1 }
            println("[phi_paper_cite] OK    [" + cat + "] " + p)
        } else {
            if soft {
                miss_soft = miss_soft + 1
                println("[phi_paper_cite] SOFT  [" + cat + "] " + p + " (acceptable — self-output, re-run tools)")
            } else {
                miss_hard = miss_hard + 1
                println("[phi_paper_cite] MISS  [" + cat + "] " + p)
            }
        }
        i = i + 1
    }

    let all_hard_ok = miss_hard == 0
    let verdict = if all_hard_ok { "PASS" } else { "FAIL" }

    let mut body = "{\n"
    body = body + "  \"schema\":          \"" + SCHEMA + "\",\n"
    body = body + "  \"source\":          \"anima/tool/phi_paper_citation_check.hexa\",\n"
    body = body + "  \"paper_ref\":       \"" + PAPER_PATH + "\",\n"
    body = body + "  \"seed_date\":       \"" + SEED_DATE + "\",\n"
    body = body + "  \"raw_strict\":      \"hexa-only deterministic idempotent no_python\",\n"
    body = body + "  \"total_refs\":      " + to_string(n) + ",\n"
    body = body + "  \"category_counts\": {\n"
    body = body + "    \"DOC\":      " + to_string(doc_count) + ",\n"
    body = body + "    \"CONFIG\":   " + to_string(config_count) + ",\n"
    body = body + "    \"TOOL\":     " + to_string(tool_count) + ",\n"
    body = body + "    \"STATE\":    " + to_string(state_count) + ",\n"
    body = body + "    \"UPSTREAM\": " + to_string(upstream_count) + "\n"
    body = body + "  },\n"
    body = body + "  \"refs\": [\n"

    let m = rows.len()
    let mut j = 0
    while j < m {
        let r = rows[j]
        let line = "    { \"path\": \"" + to_string(r[0]) + "\", \"category\": \"" + to_string(r[1]) + "\", \"soft\": " + bool_s(to_bool(r[2])) + ", \"exists\": " + bool_s(to_bool(r[3])) + " }"
        body = body + line
        if j < m - 1 { body = body + "," }
        body = body + "\n"
        j = j + 1
    }

    body = body + "  ],\n"
    body = body + "  \"summary\": {\n"
    body = body + "    \"ok_hard\":    " + to_string(ok_hard) + ",\n"
    body = body + "    \"ok_soft\":    " + to_string(ok_soft) + ",\n"
    body = body + "    \"miss_hard\":  " + to_string(miss_hard) + ",\n"
    body = body + "    \"miss_soft\":  " + to_string(miss_soft) + "\n"
    body = body + "  },\n"
    body = body + "  \"external_policy\": \"paper uses [EXT-*-PLACEHOLDER] tags; v2 post-H100 substitutes real citations during LaTeX typesetting\",\n"
    body = body + "  \"all_hard_refs_ok\": " + bool_s(all_hard_ok) + ",\n"
    body = body + "  \"verdict\":         \"" + verdict + "\"\n"
    body = body + "}\n"

    write_file(OUT_PATH, body)

    println("[phi_paper_cite] wrote " + OUT_PATH)
    println("[phi_paper_cite] total=" + to_string(n) + " ok_hard=" + to_string(ok_hard) + " ok_soft=" + to_string(ok_soft) + " miss_hard=" + to_string(miss_hard) + " miss_soft=" + to_string(miss_soft))
    println("[phi_paper_cite] verdict=" + verdict)

    if all_hard_ok { exit(0) }
    exit(1)
}

main()
