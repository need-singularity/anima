// tool/anima_memory_workspace_freshness_audit.hexa — cycle 69 memory workspace 갱신 audit (raw#9 hexa-only).
//
// PURPOSE
//   memory project_workspace.md 갱신 — cycle 36/42/43에서 발견한 19 git repos
//   (기존 memory는 "7 core projects" 만 인지). 이번 audit은:
//     1) state/workspace_full_repo_inventory.json (cycle 36) 의 19 repo 사실 확인
//     2) memory project_workspace.md 갱신 (직접 Write tool로 수행, helper 외부)
//     3) MEMORY.md 인덱스 한 줄 갱신 (직접)
//     4) state JSON으로 cycle 69 evidence 기록 (이 helper)
//
//   본 helper = NON_MUTATION (anima repo state 외부 변경 없음). memory file
//   mutation은 이 helper 외부 Write tool로 수행됨.
//
// FINDING
//   prior memory text   : "$WS contains all 7 core projects (anima, hexa-lang,
//                          airgenome, nexus, n6-architecture, papers, void)"
//   reality (cycle 36) : 19 git repos (4 active core + 9 sister + 3 other + 3 archive)
//   correction class   : underclaim (memory 작성 시점에 실제 더 많이 있었으나 미인지)
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_memory_workspace_freshness_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima memory workspace freshness audit — emitted by tool/anima_memory_workspace_freshness_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION on anima repo.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/memory_workspace_freshness_audit.json')\n")
    parts.push("INV = os.environ.get('ANIMA_INVENTORY', 'state/workspace_full_repo_inventory.json')\n\n")

    parts.push("inv = {}\n")
    parts.push("if os.path.exists(INV):\n")
    parts.push("    try:\n")
    parts.push("        with open(INV, encoding='utf-8') as f: inv = json.load(f)\n")
    parts.push("    except Exception: pass\n\n")

    parts.push("repo_categories = {\n")
    parts.push("    'active_core': ['anima','hexa-lang','airgenome','nexus'],\n")
    parts.push("    'sister_supporting': ['n6-architecture','papers','void','hive','contact','pi-telegram','pixie','secret','gohive.sh'],\n")
    parts.push("    'other_utility': ['_github-org','hexa-os','skynet-timer'],\n")
    parts.push("    'archives_deprecated': ['archive-TECS-L','archive-brainwire','archive-sedi'],\n")
    parts.push("}\n\n")

    parts.push("category_counts = {k: len(v) for k,v in repo_categories.items()}\n")
    parts.push("total_categorized = sum(category_counts.values())\n\n")

    parts.push("prior_memory = {\n")
    parts.push("    'memory_file': '~/.claude-claude11/projects/-Users-ghost-core-anima/memory/project_workspace.md',\n")
    parts.push("    'prior_claim': '7 core projects',\n")
    parts.push("    'prior_listed': ['anima','hexa-lang','airgenome','nexus','n6-architecture','papers','void'],\n")
    parts.push("    'correction_class': 'underclaim',\n")
    parts.push("    'date_of_prior': 'pre-2026-04-23 (originSessionId 95b6a6ae)',\n")
    parts.push("}\n\n")

    parts.push("update_action = {\n")
    parts.push("    'action': 'OVERWRITTEN_2026_04_27',\n")
    parts.push("    'memory_file': prior_memory['memory_file'],\n")
    parts.push("    'index_file': '~/.claude-claude11/projects/-Users-ghost-core-anima/memory/MEMORY.md',\n")
    parts.push("    'index_line_updated': True,\n")
    parts.push("    'new_total': 19,\n")
    parts.push("    'audit_basis': 'state/workspace_full_repo_inventory.json (cycle 36) + cycles 37-46 deep audit',\n")
    parts.push("}\n\n")

    parts.push("uncategorized_repos = []\n")
    parts.push("if 'all_dirs' in inv:\n")
    parts.push("    known_set = set()\n")
    parts.push("    for cat, lst in repo_categories.items():\n")
    parts.push("        for r in lst: known_set.add(r)\n")
    parts.push("    for d in inv.get('all_dirs', []):\n")
    parts.push("        n = d.get('name','')\n")
    parts.push("        if d.get('is_git_repo') and n not in known_set:\n")
    parts.push("            uncategorized_repos.append(n)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm': 'cycle 69 — memory project_workspace.md freshness audit + 7 -> 19 repo 갱신',\n")
    parts.push("    'cycle': 69,\n")
    parts.push("    'inventory_source': INV,\n")
    parts.push("    'inventory_total_git_repos': inv.get('git_repos_count'),\n")
    parts.push("    'category_counts': category_counts,\n")
    parts.push("    'total_categorized': total_categorized,\n")
    parts.push("    'uncategorized_repos': uncategorized_repos,\n")
    parts.push("    'repo_categories': repo_categories,\n")
    parts.push("    'prior_memory': prior_memory,\n")
    parts.push("    'update_action': update_action,\n")
    parts.push("    'non_mutation_guarantee': 'helper does NOT modify anima repo state; memory file (외부) updated by Write tool separately',\n")
    parts.push("    'cross_link_cycles': ['cycle 36 inventory', 'cycle 37-46 sister deep audit', 'cycle 64 memory_h100_pending freshness (parallel pattern)'],\n")
    parts.push("    'pattern': 'governance audit chain layer 48 (memory underclaim correction)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[memory_workspace] cycle=69 prior=7 new=19 uncat={len(uncategorized_repos)} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_REPO_STATE")
    println("inv:cycle=69")
    println("inv:correction_class=underclaim")
    println("inv:prior_count=7")
    println("inv:new_count=19")
    println("inv:cross_link_cycles=36,37-46,64")
    return true
}

fn cmd_selftest() {
    println("── anima_memory_workspace_freshness_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 69 — memory workspace 7→19 repo correction; NON_MUTATION on anima repo")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
