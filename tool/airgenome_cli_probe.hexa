// ════════════════════════════════════════════════════════════════════════════
//  tool/airgenome_cli_probe.hexa — CLI-only airgenome hook probe (anima-local)
//
//  PURPOSE (raw#9 hexa-only, raw#11 snake_case, raw#15 no-hardcode)
//    anima cert writers 가 cert JSON 에 airgenome hook stack 의 top_chain /
//    touch_count / air_schema_version 을 embed 하기 위해 사용하는 읽기 전용
//    probe. airgenome 은 자신의 state 파일 (active.json / findings.jsonl /
//    resolved.jsonl) 을 owner 로 관리하므로 여기서 **절대로 state 파일을
//    직접 읽거나 쓰지 않는다**. 오직 `airgenome hook <sub>` CLI 만 호출.
//
//  CLI-ONLY 제약
//    · 설령 CLI 부재여도 state 파일 I/O 금지 — 전부 placeholder (null/0).
//    · AIRGENOME_BIN env override 지원 (raw#15 no-hardcode).
//    · hexa-lang main 에 tool/airgenome_hook.hexa 가 merge 되면 이 파일은
//      해당 wrapper 로 교체 가능 (동일 API 시그니처).
//
//  PUBLIC API (cert writers 가 사용)
//    ag_probe_available()                 -> bool
//    ag_probe_top_chain()                 -> string    ("" if unavailable)
//    ag_probe_touch_count(chain: string)  -> int       (0 if unavailable)
//    ag_schema_version()                  -> string    ("v1")
//
//  CERT JSON embed pattern (호출자 예시)
//    let avail = ag_probe_available()
//    let chain = if avail { ag_probe_top_chain() } else { "" }
//    let tc    = if avail && chain != "" { ag_probe_touch_count(chain) } else { 0 }
//    j = j + "  \"air_chain\": " + (if chain == "" { "null" } else { "\"" + chain + "\"" }) + ",\n"
//    j = j + "  \"touch_count\": " + str(tc) + ",\n"
//    j = j + "  \"air_schema_version\": \"" + ag_schema_version() + "\",\n"
//
//  RAW CONSTRAINTS
//    raw#9 hexa-only   raw#11 snake_case   raw#15 no-hardcode
//    raw#10 back-compat — cert_linker 는 이 필드 부재 시에도 동작해야 함.
// ════════════════════════════════════════════════════════════════════════════

fn _ag_str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _ag_sh_quote(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _ag_which_bin() -> string {
    let ov = _ag_str(env("AIRGENOME_BIN"))
    if ov != "" {
        let chk = _ag_str(exec("test -x " + _ag_sh_quote(ov) + " && echo 1 || echo 0")).trim()
        if chk == "1" { return ov }
        return ""
    }
    let w = _ag_str(exec("command -v airgenome 2>/dev/null")).trim()
    return w
}

pub fn ag_probe_available() -> bool {
    let bin = _ag_which_bin()
    if bin == "" { return false }
    // `airgenome hook status` must exit 0 when the hook subcommand is present.
    let rc = _ag_str(exec(_ag_sh_quote(bin) + " hook status >/dev/null 2>&1 && echo 0 || echo 1")).trim()
    return rc == "0"
}

pub fn ag_probe_top_chain() -> string {
    let bin = _ag_which_bin()
    if bin == "" { return "" }
    // Prefer jq on the JSON output of `hook status` (read-only, CLI-mediated).
    let has_jq = _ag_str(exec("command -v jq >/dev/null 2>&1 && echo 1 || echo 0")).trim()
    if has_jq == "1" {
        let cmd = _ag_sh_quote(bin) + " hook status 2>/dev/null | jq -r '.stack[0].chain // empty' 2>/dev/null"
        let out = _ag_str(exec(cmd)).trim()
        return out
    }
    // jq 부재 시 subcommand 재확인 (있으면 사용, 없으면 "").
    let alt = _ag_str(exec(_ag_sh_quote(bin) + " hook top-chain 2>/dev/null")).trim()
    return alt
}

pub fn ag_probe_touch_count(chain: string) -> int {
    if chain == "" { return 0 }
    let bin = _ag_which_bin()
    if bin == "" { return 0 }
    let cmd = _ag_sh_quote(bin) + " hook touch-count " + _ag_sh_quote(chain) + " 2>/dev/null"
    let out = _ag_str(exec(cmd)).trim()
    if out == "" { return 0 }
    // parse integer (guard non-numeric output).
    let n = to_int(out)
    return n
}

pub fn ag_schema_version() -> string {
    return "v1"
}
