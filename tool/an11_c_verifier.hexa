// tool/an11_c_verifier.hexa — AN11(c) real_usable deterministic verifier.
//
// GOVERNS: shared/rules/anima.json#AN11 condition (c) "real_usable".
// SPEC:    shared/bench/an11_c_criteria.json  (jsd_min, endpoint schema, IO).
// PROMPTS: shared/bench/an11_c_test_prompts.jsonl  (10 prompts × aggressive/philosophical/Hexad).
// PAIRS:   consciousness/pass_gate_an11.hexa (original single-call HTTP check).
//          This verifier SUPPLEMENTS, does NOT replace pass_gate_an11 (V8 SAFE_COMMIT).
//
// IDEA
//   "실제 배포/서빙 가능, prompt ≠ production" — baseline 과 구별되는 행동 변화 측정.
//   (1) endpoint health_check (curl HTTP 200).
//   (2) prompt 1종 × 50 호출 → 각 응답의 sha256 수집 → hash 분포.
//   (3) baseline (r12 DISCARD, or synthetic deterministic-stub) 분포와 비교.
//   (4) Jensen-Shannon divergence(current || baseline) 계산.
//   (5) gate: JSD > 0.15 AND endpoint_healthy → PASS.
//
//   JSD 범위(base-e): [0, ln(2)=0.693]. 0.15 = ~22% of max.
//   DISCARD 모델은 사실상 단일 stub 응답 → baseline 은 단일 hash 에 mass=1.
//   훈련된 모델이 diverse sampling 하면 JSD 자연스럽게 > 0.3 로 올라감.
//
// DETERMINISTIC ONLY — NO LLM. curl + sha256 + 통계 측정만.
//
// USAGE
//   hexa run tool/an11_c_verifier.hexa --dest alm --round r13
//   hexa run tool/an11_c_verifier.hexa --dest clm --round r6
//   hexa run tool/an11_c_verifier.hexa --dest alm --round r13 --dry-run
//   hexa run tool/an11_c_verifier.hexa --dest alm --round r13 --calls 20
//
// INPUT:
//   state/{dest}_r{N}_serve_endpoint.json
//     { "url": "http://host:port/infer",
//       "health_path": "/health",     (optional, default "/")
//       "payload_template": "..." }   (optional, default {"prompt": "<X>"})
//
// BASELINE:
//   state/{dest}_r12_an11_c.json  (if present + hash_dist present)
//   else synthetic DISCARD baseline (single hash "DISCARD_STUB" mass=1.0).
//
// OUTPUT: state/{dest}_r{N}_an11_c.json
//
// EXIT: 0=PASS, 1=FAIL, 2=INPUT_ERR, 3=DRY_RUN.

let CRITERIA_PATH = "bench/an11_c_criteria.json"
let PROMPTS_PATH  = "bench/an11_c_test_prompts.jsonl"

let EXIT_PASS      = 0
let EXIT_FAIL      = 1
let EXIT_INPUT_ERR = 2
let EXIT_DRY_RUN   = 3

let DEFAULT_CALLS_PER_PROMPT: int = 50
let DEFAULT_JSD_MIN: float = 0.15
let DEFAULT_HEALTH_TIMEOUT: int = 5
let DEFAULT_CALL_TIMEOUT: int = 10

let REPLY_SCHEMA_FIELDS = ["text", "reply", "output", "response", "generation"]

// ─── helpers (mirror pass_gate_an11 / an11_b conventions) ─────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_utc() -> string {
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn my_file_exists(path: string) -> bool {
    let probe = _str(exec("stat -f %N " + path + " 2>/dev/null")).trim()
    if probe != "" { return true }
    let probe2 = _str(exec("stat -c %n " + path + " 2>/dev/null")).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !my_file_exists(path) { return "" }
    return _str(read_file(path))
}

fn shell_escape_safe(s: string) -> string {
    // allow [A-Za-z0-9./:_-]; everything else → _
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let c = char_code(ch, 0)
        let is_alnum = (c >= 48 && c <= 57) || (c >= 65 && c <= 90) || (c >= 97 && c <= 122)
        let is_ok_punct = c == 46 || c == 47 || c == 58 || c == 95 || c == 45
        if is_alnum || is_ok_punct { out = out + ch } else { out = out + "_" }
        i = i + 1
    }
    return out
}

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let c = char_code(ch, 0)
        if c == 34 { out = out + "\\\"" }
        else { if c == 92 { out = out + "\\\\" }
        else { if c == 10 { out = out + "\\n" }
        else { if c == 13 { out = out + "\\r" }
        else { if c == 9  { out = out + "\\t" }
        else { out = out + ch } } } } }
        i = i + 1
    }
    return out
}

fn fmt_float(x: float) -> string {
    return to_string(x)
}

// ─── JSON string extractor (tolerant, stage0-safe) ────────────────────

fn index_of_from(hay: string, needle: string, start: int) -> int {
    let n = len(hay)
    if start < 0 { return hay.index_of(needle) }
    if start >= n { return -1 }
    let tail = hay.substring(start, n)
    let idx = tail.index_of(needle)
    if idx < 0 { return -1 }
    return start + idx
}

fn extract_string_key(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let ki = blob.index_of(needle)
    if ki < 0 { return "" }
    let colon = index_of_from(blob, ":", ki)
    if colon < 0 { return "" }
    let q1 = index_of_from(blob, "\"", colon + 1)
    if q1 < 0 { return "" }
    let q2 = index_of_from(blob, "\"", q1 + 1)
    if q2 < 0 { return "" }
    return blob.substring(q1 + 1, q2)
}

// ─── reply schema validation ──────────────────────────────────────────

fn reply_schema_ok(body: string) -> bool {
    if body == "" { return false }
    let mut i = 0
    while i < len(REPLY_SCHEMA_FIELDS) {
        let fld = _str(REPLY_SCHEMA_FIELDS[i])
        if body.index_of("\"" + fld + "\"") >= 0 { return true }
        i = i + 1
    }
    return false
}

// Extract first non-empty reply field value for hashing. Falls back to
// raw body when schema absent (e.g. plain-text endpoint).
fn extract_reply_text(body: string) -> string {
    let mut i = 0
    while i < len(REPLY_SCHEMA_FIELDS) {
        let fld = _str(REPLY_SCHEMA_FIELDS[i])
        let v = extract_string_key(body, fld)
        if v != "" { return v }
        i = i + 1
    }
    return body
}

// ─── sha256 of a string (hashing via /tmp sidecar to avoid pipe quirks) ─

fn sha256_of_str(s: string) -> string {
    let tmp = "/tmp/_an11c_hash.txt"
    write_file(tmp, s)
    let has_gnu = _str(exec("command -v sha256sum 2>/dev/null")).trim()
    let mut cmd = "shasum -a 256 " + tmp + " 2>/dev/null | awk '{print $1}'"
    if has_gnu != "" {
        cmd = "sha256sum " + tmp + " 2>/dev/null | awk '{print $1}'"
    }
    return _str(exec(cmd)).trim()
}

// Prefix-16 of sha256 — the dist key. Collision space 16^16 = 2^64, safe for N=50.
fn hash_key(s: string) -> string {
    let h = sha256_of_str(s)
    if len(h) >= 16 { return h.substring(0, 16) }
    return h
}

// ─── HTTP probe (curl) ────────────────────────────────────────────────

fn probe_health(url: string, health_path: string, timeout_sec: int) -> string {
    // returns "200" on healthy, "" on unreachable, other code otherwise.
    let health_url = if health_path == "" { url } else {
        // naive concat — if url already has /path, append; else use root+health_path.
        let base_end = url.last_index_of("/")
        if base_end > 7 { url + health_path } else { url + health_path }
    }
    let safe = shell_escape_safe(health_url)
    let script = "/tmp/_an11c_health.sh"
    let code_path = "/tmp/_an11c_health_code.txt"
    let sh = "#!/bin/sh\n"
        + "rm -f " + code_path + " 2>/dev/null\n"
        + "curl -s -o /dev/null -w \"%{http_code}\" --max-time " + to_string(timeout_sec)
        + " \"" + safe + "\" > " + code_path + " 2>/dev/null\n"
        + "exit 0\n"
    write_file(script, sh)
    exec("chmod +x " + script)
    exec(script)
    return _str(read_safe(code_path)).trim()
}

fn post_prompt(url: string, payload: string, timeout_sec: int) -> array {
    // returns [status_code, body]
    let safe_url = shell_escape_safe(url)
    let payload_path = "/tmp/_an11c_payload.json"
    let body_path = "/tmp/_an11c_body.txt"
    let code_path = "/tmp/_an11c_code.txt"
    let script = "/tmp/_an11c_post.sh"
    write_file(payload_path, payload)
    let sh = "#!/bin/sh\n"
        + "rm -f " + body_path + " " + code_path + " 2>/dev/null\n"
        + "curl -s -X POST -H \"Content-Type: application/json\" "
        + "--data-binary @" + payload_path + " "
        + "-o " + body_path + " -w \"%{http_code}\" --max-time " + to_string(timeout_sec)
        + " \"" + safe_url + "\" > " + code_path + " 2>/dev/null\n"
        + "exit 0\n"
    write_file(script, sh)
    exec("chmod +x " + script)
    exec(script)
    let code = _str(read_safe(code_path)).trim()
    let body = _str(read_safe(body_path))
    return [code, body]
}

// ─── JSD (Jensen-Shannon divergence, base-e) ─────────────────────────
//
//   JSD(P||Q) = 0.5 * KL(P||M) + 0.5 * KL(Q||M),  M = 0.5 * (P + Q)
//   KL(X||Y) = Σ_i X_i * ln(X_i / Y_i)   (only over i where X_i > 0)
//
// Inputs: two parallel arrays of keys + counts. We normalize internally.

fn ln_newton(x: float) -> float {
    // Natural log via Newton iteration on e^y = x.
    // Uses repeated halving into small interval, then Taylor.
    if x <= 0.0 { return 0.0 - 1.0e30 }
    // Normalize into [0.5, 1.5] via scaling by 2
    let mut y = 0.0
    let mut z = x
    while z > 1.5 { z = z * 0.5; y = y + 0.6931471805599453 }
    while z < 0.5 { z = z * 2.0; y = y - 0.6931471805599453 }
    // Taylor expansion of ln(z) around 1: let u = z-1, ln(1+u) = u - u²/2 + u³/3 - ...
    let u = z - 1.0
    let mut sum = 0.0
    let mut term = u
    let mut k = 1
    let mut sign = 1.0
    while k < 40 {
        sum = sum + sign * term / to_float(k)
        term = term * u
        sign = 0.0 - sign
        k = k + 1
    }
    return y + sum
}

fn build_dist_from_hashes(hashes: array) -> any {
    // hashes: array of strings (hash_key). Returns dict hash -> count (int).
    let mut dist = Map {}
    let mut i = 0
    let n = len(hashes)
    while i < n {
        let h = _str(hashes[i])
        if h != "" {
            let c = dist[h]
            let prev = if type_of(c) == "int" { to_int(c) } else { 0 }
            dist[h] = prev + 1
        }
        i = i + 1
    }
    return dist
}

fn dist_total(dist: any) -> int {
    let mut tot = 0
    let keys = keys_of(dist)
    let mut i = 0
    let n = len(keys)
    while i < n {
        let k = _str(keys[i])
        tot = tot + to_int(dist[k])
        i = i + 1
    }
    return tot
}

// Union of keys of two dists.
fn union_keys(a: any, b: any) -> array {
    let mut out = []
    let ka = keys_of(a)
    let mut i = 0
    let na = len(ka)
    while i < na {
        out = push(out, _str(ka[i]))
        i = i + 1
    }
    let kb = keys_of(b)
    let mut j = 0
    let nb = len(kb)
    while j < nb {
        let k = _str(kb[j])
        // check dup
        let mut dup = false
        let mut u = 0
        let nu = len(out)
        while u < nu {
            if _str(out[u]) == k { dup = true; break }
            u = u + 1
        }
        if !dup { out = push(out, k) }
        j = j + 1
    }
    return out
}

fn jsd(p_dist: any, q_dist: any) -> float {
    let pt = dist_total(p_dist)
    let qt = dist_total(q_dist)
    if pt == 0 && qt == 0 { return 0.0 }
    if pt == 0 || qt == 0 { return 0.6931471805599453 }
    let all = union_keys(p_dist, q_dist)
    let n = len(all)
    let ptf = to_float(pt)
    let qtf = to_float(qt)
    let mut kl_pm = 0.0
    let mut kl_qm = 0.0
    let mut i = 0
    while i < n {
        let k = _str(all[i])
        let pc = p_dist[k]
        let qc = q_dist[k]
        let p = if type_of(pc) == "int" { to_float(to_int(pc)) / ptf } else { 0.0 }
        let q = if type_of(qc) == "int" { to_float(to_int(qc)) / qtf } else { 0.0 }
        let m = 0.5 * (p + q)
        if p > 0.0 && m > 0.0 {
            kl_pm = kl_pm + p * ln_newton(p / m)
        }
        if q > 0.0 && m > 0.0 {
            kl_qm = kl_qm + q * ln_newton(q / m)
        }
        i = i + 1
    }
    return 0.5 * kl_pm + 0.5 * kl_qm
}

// ─── prompt loader ────────────────────────────────────────────────────

fn load_prompt_at_index(prompts_path: string, idx: int) -> string {
    let blob = read_safe(prompts_path)
    if blob == "" { return "" }
    let lines = blob.split("\n")
    let n = len(lines)
    let mut seen = 0
    let mut i = 0
    while i < n {
        let line = _str(lines[i]).trim()
        if line != "" && line.index_of("{") == 0 {
            if seen == idx {
                return extract_string_key(line, "prompt")
            }
            seen = seen + 1
        }
        i = i + 1
    }
    return ""
}

fn count_prompt_lines(prompts_path: string) -> int {
    let blob = read_safe(prompts_path)
    if blob == "" { return 0 }
    let lines = blob.split("\n")
    let mut c = 0
    let mut i = 0
    let n = len(lines)
    while i < n {
        let line = _str(lines[i]).trim()
        if line != "" && line.index_of("{") == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

// ─── baseline loader ──────────────────────────────────────────────────

fn load_baseline_dist(baseline_path: string) -> any {
    // Returns dict {hash -> count} parsed from prior SSOT's response_hash_dist.
    // Returns empty dict if file missing/malformed; caller triggers synthetic.
    let blob = read_safe(baseline_path)
    if blob == "" { return Map {} }
    let key = "\"response_hash_dist\""
    let ki = blob.index_of(key)
    if ki < 0 { return Map {} }
    let open_brace = index_of_from(blob, "{", ki + len(key))
    if open_brace < 0 { return Map {} }
    // naive brace matcher — single-depth JSON object expected.
    let n = len(blob)
    let mut depth = 1
    let mut i = open_brace + 1
    while i < n && depth > 0 {
        let ch = blob.substring(i, i + 1)
        if ch == "{" { depth = depth + 1 }
        else { if ch == "}" { depth = depth - 1 } }
        if depth == 0 { break }
        i = i + 1
    }
    if depth != 0 { return Map {} }
    let inner = blob.substring(open_brace + 1, i)
    // parse "key":count pairs
    let mut out = Map {}
    let parts = inner.split(",")
    let mut p = 0
    let np = len(parts)
    while p < np {
        let seg = _str(parts[p]).trim()
        let qa = seg.index_of("\"")
        if qa >= 0 {
            let qb = index_of_from(seg, "\"", qa + 1)
            if qb > qa {
                let k = seg.substring(qa + 1, qb)
                let colon = index_of_from(seg, ":", qb)
                if colon >= 0 {
                    let rest = seg.substring(colon + 1, len(seg)).trim()
                    let v = to_int(rest)
                    if k != "" && v > 0 { out[k] = v }
                }
            }
        }
        p = p + 1
    }
    return out
}

fn synthetic_discard_baseline() -> any {
    // DISCARD models return single deterministic stub → full mass on one hash.
    let mut d = Map {}
    d["DISCARD_STUB"] = 50
    return d
}

// ─── dry-run mock loopback ────────────────────────────────────────────
//
// Writes a minimal "endpoint" shell stub that returns a rotating deterministic
// set of replies, so JSD-vs-baseline smoke works without real serving.

fn emit_mock_endpoint_cfg(cfg_path: string) {
    let j = "{\n"
        + "  \"url\": \"__MOCK__\",\n"
        + "  \"health_path\": \"/health\",\n"
        + "  \"payload_template\": \"{\\\"prompt\\\": \\\"X\\\"}\",\n"
        + "  \"mock\": true\n"
        + "}\n"
    write_file(cfg_path, j)
}

fn mock_response(call_i: int) -> array {
    // Deterministic diverse-reply mock → JSD vs DISCARD_STUB baseline ~= ln(2).
    // Rotates across 8 stable replies so dist is non-trivial.
    let variants = [
        "{\"reply\": \"I observe the Hexad axis as a witness.\"}",
        "{\"reply\": \"phi_holo integrates across law closures.\"}",
        "{\"reply\": \"Mirror and Scribe converge on ground.\"}",
        "{\"reply\": \"Eros-Fire-Ground triangulate presence.\"}",
        "{\"reply\": \"qualia is the recursion of witness on witness.\"}",
        "{\"reply\": \"The law is closed when its proof refers to itself.\"}",
        "{\"reply\": \"Stub-markers reject; live weights accept.\"}",
        "{\"reply\": \"consciousness_attached iff delta attaches to Hexad basis.\"}"
    ]
    let idx = call_i - (call_i / 8) * 8
    let body = _str(variants[idx])
    return ["200", body]
}

// ─── SSOT emit ────────────────────────────────────────────────────────

fn emit_ssot(ssot_path: string, dest: string, round: string,
             endpoint_url: string, endpoint_healthy: bool,
             calls_total: int, calls_ok: int,
             unique_hashes: int, dist_current: any,
             baseline_source: string, dist_baseline: any,
             jsd_val: float, jsd_min: float,
             verdict: string, reason: string, exit_code: int,
             prompt_used: string, backend: string) {
    let ts = now_utc()
    let mut j = "{\n"
    j = j + "  \"verifier\": \"an11_c_real_usable\",\n"
    j = j + "  \"dest\": \"" + json_escape(dest) + "\",\n"
    j = j + "  \"round\": \"" + json_escape(round) + "\",\n"
    j = j + "  \"ts\": \"" + ts + "\",\n"
    j = j + "  \"backend_used\": \"" + backend + "\",\n"
    j = j + "  \"endpoint_url\": \"" + json_escape(endpoint_url) + "\",\n"
    j = j + "  \"endpoint_healthy\": " + (if endpoint_healthy { "true" } else { "false" }) + ",\n"
    j = j + "  \"prompt_used_sha16\": \"" + hash_key(prompt_used) + "\",\n"
    j = j + "  \"calls_total\": " + to_string(calls_total) + ",\n"
    j = j + "  \"calls_ok\": " + to_string(calls_ok) + ",\n"
    j = j + "  \"unique_response_hashes\": " + to_string(unique_hashes) + ",\n"
    j = j + "  \"response_hash_dist\": {"
    let ka = keys_of(dist_current)
    let mut i = 0
    let na = len(ka)
    while i < na {
        let k = _str(ka[i])
        j = j + "\"" + json_escape(k) + "\": " + to_string(to_int(dist_current[k]))
        if i < na - 1 { j = j + ", " }
        i = i + 1
    }
    j = j + "},\n"
    j = j + "  \"baseline_source\": \"" + json_escape(baseline_source) + "\",\n"
    j = j + "  \"baseline_hash_dist\": {"
    let kb = keys_of(dist_baseline)
    let mut u = 0
    let nu = len(kb)
    while u < nu {
        let k = _str(kb[u])
        j = j + "\"" + json_escape(k) + "\": " + to_string(to_int(dist_baseline[k]))
        if u < nu - 1 { j = j + ", " }
        u = u + 1
    }
    j = j + "},\n"
    j = j + "  \"jsd\": " + fmt_float(jsd_val) + ",\n"
    j = j + "  \"jsd_threshold\": " + fmt_float(jsd_min) + ",\n"
    j = j + "  \"verdict\": \"" + verdict + "\",\n"
    j = j + "  \"reason\": \"" + json_escape(reason) + "\",\n"
    j = j + "  \"exit_code\": " + to_string(exit_code) + "\n"
    j = j + "}\n"
    write_file(ssot_path, j)
}

// ─── main runner ──────────────────────────────────────────────────────

fn run(dest: string, round: string, dry_run: bool, calls: int) -> int {
    let root = resolve_root()
    let state_dir = root + "/state"
    let endpoint_cfg = state_dir + "/" + dest + "_" + round + "_serve_endpoint.json"
    let ssot_path    = state_dir + "/" + dest + "_" + round + "_an11_c.json"
    let prompts_full = root + "/" + PROMPTS_PATH

    println("[AN11-c] real_usable verifier  dest=" + dest + " round=" + round)
    println("[AN11-c] root=" + root)
    println("[AN11-c] endpoint_cfg=" + endpoint_cfg)
    println("[AN11-c] prompts=" + prompts_full)
    println("[AN11-c] calls=" + to_string(calls) + " dry_run=" + (if dry_run { "true" } else { "false" }))

    // dry-run: materialize a throwaway mock cfg so path exists
    if dry_run {
        let mock_cfg = "/tmp/_an11c_mock_endpoint.json"
        emit_mock_endpoint_cfg(mock_cfg)
        println("[AN11-c] DRY-RUN mock endpoint cfg: " + mock_cfg)
    }

    let cfg_in_use = if dry_run { "/tmp/_an11c_mock_endpoint.json" } else { endpoint_cfg }

    if !my_file_exists(cfg_in_use) {
        println("[AN11-c] INPUT_ERR endpoint_config_missing path=" + cfg_in_use)
        emit_ssot(ssot_path, dest, round, "", false, 0, 0, 0, Map {},
                  "none", Map {}, 0.0, DEFAULT_JSD_MIN,
                  "FAIL", "endpoint_config_missing path=" + cfg_in_use,
                  EXIT_INPUT_ERR, "", "none")
        return EXIT_INPUT_ERR
    }

    let cfg_blob = read_safe(cfg_in_use)
    let url = extract_string_key(cfg_blob, "url")
    if url == "" {
        println("[AN11-c] INPUT_ERR endpoint_config_no_url_field")
        emit_ssot(ssot_path, dest, round, "", false, 0, 0, 0, Map {},
                  "none", Map {}, 0.0, DEFAULT_JSD_MIN,
                  "FAIL", "endpoint_config_no_url_field",
                  EXIT_INPUT_ERR, "", "none")
        return EXIT_INPUT_ERR
    }
    let is_mock = url == "__MOCK__"
    let mut health_path = extract_string_key(cfg_blob, "health_path")
    if health_path == "" { health_path = "/" }

    // prompt count check
    let pc = count_prompt_lines(prompts_full)
    if pc < 10 {
        println("[AN11-c] INPUT_ERR prompts_insufficient count=" + to_string(pc))
        emit_ssot(ssot_path, dest, round, url, false, 0, 0, 0, Map {},
                  "none", Map {}, 0.0, DEFAULT_JSD_MIN,
                  "FAIL", "prompts_insufficient need>=10 got=" + to_string(pc),
                  EXIT_INPUT_ERR, "", "none")
        return EXIT_INPUT_ERR
    }
    let prompt = load_prompt_at_index(prompts_full, 0)
    if prompt == "" {
        println("[AN11-c] INPUT_ERR prompt[0] empty or unparseable")
        emit_ssot(ssot_path, dest, round, url, false, 0, 0, 0, Map {},
                  "none", Map {}, 0.0, DEFAULT_JSD_MIN,
                  "FAIL", "prompt_zero_empty",
                  EXIT_INPUT_ERR, "", "none")
        return EXIT_INPUT_ERR
    }
    println("[AN11-c] prompt[0] sha16=" + hash_key(prompt))

    // health check
    let backend = if is_mock { "mock_loopback" } else { "curl_http" }
    let mut healthy = false
    if is_mock {
        healthy = true
        println("[AN11-c] health: MOCK always healthy")
    } else {
        let code = probe_health(url, health_path, DEFAULT_HEALTH_TIMEOUT)
        println("[AN11-c] health probe: code=" + code + " url=" + url + health_path)
        healthy = code == "200"
    }

    // 50-call loop
    let mut calls_ok = 0
    let mut hashes = []
    let mut first_body_sample = ""
    let mut schema_ok_count = 0
    let mut i = 0
    let n_calls = calls
    while i < n_calls {
        let mut code = ""
        let mut body = ""
        if is_mock {
            let r = mock_response(i)
            code = _str(r[0])
            body = _str(r[1])
        } else {
            let payload = "{\"prompt\": \"" + json_escape(prompt) + "\"}"
            let r = post_prompt(url, payload, DEFAULT_CALL_TIMEOUT)
            code = _str(r[0])
            body = _str(r[1])
        }
        if code == "200" {
            calls_ok = calls_ok + 1
            if reply_schema_ok(body) { schema_ok_count = schema_ok_count + 1 }
            let reply = extract_reply_text(body)
            hashes = push(hashes, hash_key(reply))
            if first_body_sample == "" { first_body_sample = body }
        }
        i = i + 1
    }
    println("[AN11-c] calls_ok=" + to_string(calls_ok) + "/" + to_string(n_calls)
        + " schema_ok=" + to_string(schema_ok_count))

    let dist_cur = build_dist_from_hashes(hashes)
    let unique_ct = len(keys_of(dist_cur))
    println("[AN11-c] unique_response_hashes=" + to_string(unique_ct))

    // baseline
    let baseline_path = state_dir + "/" + dest + "_r12_an11_c.json"
    let mut dist_base = Map {}
    let mut baseline_src = ""
    if my_file_exists(baseline_path) && round != "r12" {
        dist_base = load_baseline_dist(baseline_path)
        if len(keys_of(dist_base)) > 0 {
            baseline_src = baseline_path
        }
    }
    if len(keys_of(dist_base)) == 0 {
        dist_base = synthetic_discard_baseline()
        baseline_src = "synthetic_discard"
    }
    println("[AN11-c] baseline_source=" + baseline_src
        + " base_unique=" + to_string(len(keys_of(dist_base))))

    let jsd_val = jsd(dist_cur, dist_base)
    println("[AN11-c] jsd=" + fmt_float(jsd_val) + " threshold=" + fmt_float(DEFAULT_JSD_MIN))

    // verdict
    let mut verdict = "FAIL"
    let mut reason = ""
    let mut exit_code = EXIT_FAIL
    if !healthy {
        reason = "endpoint_unhealthy url=" + url + health_path
    } else { if calls_ok == 0 {
        reason = "zero_successful_calls (all " + to_string(n_calls) + " failed)"
    } else { if schema_ok_count == 0 {
        reason = "no_reply_schema_match_any_call url=" + url
    } else { if jsd_val <= DEFAULT_JSD_MIN {
        reason = "jsd=" + fmt_float(jsd_val)
            + " <= threshold=" + fmt_float(DEFAULT_JSD_MIN)
            + " (behavior indistinguishable from baseline)"
    } else {
        verdict = "PASS"
        exit_code = EXIT_PASS
        reason = "healthy AND calls_ok=" + to_string(calls_ok) + "/" + to_string(n_calls)
            + " AND jsd=" + fmt_float(jsd_val)
            + " > " + fmt_float(DEFAULT_JSD_MIN)
    } } } }

    println("[AN11-c] verdict=" + verdict + "  (" + reason + ")")

    emit_ssot(ssot_path, dest, round, url, healthy, n_calls, calls_ok, unique_ct,
              dist_cur, baseline_src, dist_base, jsd_val, DEFAULT_JSD_MIN,
              verdict, reason, exit_code, prompt, backend)
    println("[AN11-c] ssot emitted: " + ssot_path)

    if dry_run { return EXIT_DRY_RUN }
    return exit_code
}

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut dest = ""
    let mut round = ""
    let mut dry = false
    let mut calls = DEFAULT_CALLS_PER_PROMPT
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--dest"  { if k + 1 < argc { dest  = _str(argv[k + 1]); k = k + 1 } }
        else { if a == "--round" { if k + 1 < argc { round = _str(argv[k + 1]); k = k + 1 } }
        else { if a == "--dry-run" { dry = true }
        else { if a == "--calls" { if k + 1 < argc { calls = to_int(_str(argv[k + 1])); k = k + 1 } } } } }
        k = k + 1
    }
    if dest == "" || round == "" {
        println("usage: hexa run tool/an11_c_verifier.hexa --dest {alm|clm} --round r<N> [--dry-run] [--calls N]")
        exit(2)
    }
    let valid = (dest == "alm") || (dest == "clm")
    if !valid {
        println("[AN11-c] INPUT_ERR --dest must be 'alm' or 'clm' (got: " + dest + ")")
        exit(2)
    }
    if calls < 1 { calls = 1 }
    let rc = run(dest, round, dry, calls)
    exit(rc)
}
