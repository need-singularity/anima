// ════════════════════════════════════════════════════════════════════════════
//  tool/l_ix_5term_stress_test.hexa — EXP-2: L_IX 5-term stress test
//
//  PURPOSE
//    H★ τ(6)=4 primitivity hypothesis — 2nd falsification test.
//
//    EXP-1 (commit 93f0c364) showed that substituting n=6 → n=28 collapses
//    the Hexad primary-quartet pass count 4/4 → 0/4 (H★ STRONGLY_SUPPORTED).
//    That test attacked the *category-count* side of τ(6)=4.
//
//    EXP-2 attacks the *Lagrangian-term-count* side of the same invariant:
//    the Mk.IX action S_IX carries exactly FOUR potential terms
//
//        L_IX  =  T − V_struct − V_sync − V_RG + λ·I_irr          (4-term)
//                 └──────┬───── 4 potentials (incl. signed I_irr)─┘
//
//    If τ(6)=4 is the deep reason that the 4-term closure is STATIONARY,
//    adding ANY fifth potential V_X should break STATIONARY_AT_FIXPOINT
//    on the canonical gen-5 fixture [40, 125, 687, 1000, 1000].
//
//    We pick V_X = V_hurst (Hurst-1951 long-memory regularizer) as the
//    physically cleanest 5th term:
//
//        V_hurst  =  δ · (H − 0.5)²
//
//    where H is the Hurst exponent of the W-trajectory computed via R/S
//    analysis (Hurst 1951; Mandelbrot & Wallis 1969).
//
//        H ≈ 0.5  ⇒  random walk       V_hurst ≈ 0       (no perturbation)
//        H > 0.5  ⇒  persistent        V_hurst > 0       (penalty)
//        H < 0.5  ⇒  anti-persistent   V_hurst > 0       (penalty)
//
//    δ = 10 (per-mille CE-scale; 0.01 absolute).  Chosen so that a
//    maximal deviation (H=1 or H=0) yields V_hurst = 10·(0.5)² = 2.5
//    per-mille, comparable to T_tension at gen-3 (157×10⁻³), i.e.
//    large enough to perturb STATIONARY if τ(6)=4 is merely "suggestive"
//    but NOT large enough to swamp the structural terms.
//
//  PRE-REGISTERED CRITERION (raw#12, fixed BEFORE run):
//
//      5-term STATIONARY_AT_FIXPOINT break (ΔL_IX_5 ≠ 0 OR fixpoint lost)
//         ⇒ H★ STRONGLY_SUPPORTED
//      5-term STATIONARY preserved (ΔL_IX_5 == 0 AND fixpoint preserved)
//         ⇒ H★ WEAK_OR_NONE
//      |Δ(4-term S_IX vs 5-term S_IX)| / |4-term| < 10%
//         ⇒ INCONCLUSIVE
//
//  BASELINE (commit 672610fc natural_gen5 seed 20260421):
//      W  = [40, 125, 687, 1000, 1000]  → STATIONARY_AT_FIXPOINT
//      S_IX_4term  = -8600  (from edu_cell_l_ix_integrator.json)
//      L_IX_5      = 0       (W_5 == W_4 = 1000, ΔW=0, I_irr=0)
//
//  OUTPUTS
//      stdout   per-gen 4-term vs 5-term table + verdict
//      json     state/l_ix_5term_stress_verdict.json
//
//  CONSTRAINTS
//      hexa-only (raw#9) · snake_case (raw#11) · measured-only (raw#12) ·
//      proof-carrying (raw#10: parameters, δ, fixture hash recorded) ·
//      no git hooks touched, no push.
// ════════════════════════════════════════════════════════════════════════════

use "airgenome_cli_probe"

let OUT_PATH = "state/l_ix_5term_stress_verdict.json"

// ── Fixture (seed 20260421 natural_gen5, commit 672610fc) ──────────────────
let WS = [40, 125, 687, 1000, 1000]
let N_GEN = 5

// V_hurst penalty scale (per-mille)
let DELTA_X1000 = 10   // δ = 0.01 absolute  (see header) — canonical test value

// Sensitivity scan δ values (×1000 scale) — probe test sensitivity at
// larger penalties to verify that any H_STAR_WEAK_OR_NONE finding at the
// canonical δ=10 is NOT an arithmetic-underflow artifact.  If a stress
// BREAK is ever observable at any δ in this list, the 4-term closure is
// demonstrably fragile to 5th-potential additions.
let DELTA_SCAN = [10, 100, 1000, 10000, 100000]

// λ_arrow default (matches l_ix_integrator.hexa)
let LAMBDA_X1000 = 1000

// Stationary tolerance (per-mille): |L_IX_5| <= 1 means fixpoint preserved.
let TOL_X1000 = 1

// Inconclusive band: |Δ S_IX| / |S_IX_4| ≥ 100 per-mille  ⇒  "significant"
let SIGNIFICANT_PCT_X1000 = 100  // 10%

// ── Mk.VIII inlined primitives (byte-equivalent to l_cell_integrator.hexa) ──

fn t_tension_x1000(w_k: int, w_prev: int) -> int {
    let dw = w_k - w_prev
    let sq = dw * dw
    return (sq / 2) / 1000
}

fn ln_perm_x1000(x: int) -> int {
    let mut v = x
    if v <= 0    { v = 1 }
    if v > 1000  { v = 1000 }
    if v >= 1000 { return 0 }
    if v >= 950  { return 0 - 51 }
    if v >= 900  { return 0 - 105 }
    if v >= 850  { return 0 - 163 }
    if v >= 800  { return 0 - 223 }
    if v >= 750  { return 0 - 288 }
    if v >= 700  { return 0 - 357 }
    if v >= 650  { return 0 - 431 }
    if v >= 600  { return 0 - 511 }
    if v >= 550  { return 0 - 598 }
    if v >= 500  { return 0 - 693 }
    if v >= 450  { return 0 - 799 }
    if v >= 400  { return 0 - 916 }
    if v >= 350  { return 0 - 1050 }
    if v >= 300  { return 0 - 1204 }
    if v >= 250  { return 0 - 1386 }
    if v >= 200  { return 0 - 1609 }
    if v >= 150  { return 0 - 1897 }
    if v >= 100  { return 0 - 2303 }
    if v >= 50   { return 0 - 2996 }
    return 0 - 6908
}

fn v_struct_x1000(w: int) -> int {
    if w >= 1000 { return 0 }
    let ln_val = ln_perm_x1000(w)
    return 0 - ln_val
}

fn v_sync_stub_x1000(w: int) -> int {
    let mut s = w
    if s < 0    { s = 0 }
    if s > 1000 { s = 1000 }
    return 1000 - s
}

fn i_irr_x1000(w_k: int, w_prev: int) -> int {
    let dw = w_k - w_prev
    if dw <= 0 { return 0 }
    let jitter_floor = 1
    return (dw * 1000) / (dw + jitter_floor)
}

// ── Helpers for V_hurst (integer fixed-point R/S analysis) ─────────────────
//
// R/S method (Hurst 1951):
//   1. Compute mean μ of the W-trajectory.
//   2. Deviations Y_i = W_i − μ.
//   3. Cumulative deviations Z_k = Σ_{i≤k} Y_i.
//   4. Range R = max(Z) − min(Z).
//   5. Standard deviation S = sqrt( (1/N) Σ Y_i² ).
//   6. H_est = log(R/S) / log(N)         (standard small-N approximation)
//
// All computations in integer per-mille (×1000).  log and sqrt are
// implemented via monotone lookup / Newton iteration to keep determinism.

fn abs_i(x: int) -> int { if x < 0 { return 0 - x } ;  return x }

fn mean_x1000(xs: list) -> int {
    // Inputs already in per-mille (scale of WS).  Mean ×1000 returned.
    let n = len(xs)
    let mut s = 0
    let mut i = 0
    while i < n { s = s + xs[i] ;  i = i + 1 }
    // Preserve one extra digit of precision by multiplying then dividing.
    return (s * 1000) / n
}

fn max_int(xs: list) -> int {
    let mut m = xs[0]
    let mut i = 1
    while i < len(xs) {
        if xs[i] > m { m = xs[i] }
        i = i + 1
    }
    return m
}

fn min_int(xs: list) -> int {
    let mut m = xs[0]
    let mut i = 1
    while i < len(xs) {
        if xs[i] < m { m = xs[i] }
        i = i + 1
    }
    return m
}

// Newton sqrt for non-negative int.  Result = floor(sqrt(x)).
fn isqrt(x: int) -> int {
    if x <= 0 { return 0 }
    if x < 4  { return 1 }
    let mut r = x
    let mut prev = 0 - 1
    // bound iterations (deterministic)
    let mut it = 0
    while it < 64 {
        let nr = (r + x / r) / 2
        if nr == r { return r }
        if nr == prev { return nr }
        prev = r
        r = nr
        it = it + 1
    }
    return r
}

// Natural log ×1000 for positive integer input interpreted as a per-mille
// ratio ≥ 1000 (i.e. x ≥ 1).  For 0 < x < 1000 we mirror: ln(1/u) = -ln(u).
// Lookup-table based for determinism & no import.
fn ln_x1000(x_x1000: int) -> int {
    if x_x1000 <= 0 { return 0 - 10000 }   // guard; caller must avoid
    // Normalize: express as x = 10^k · m where 1 ≤ m < 10
    let mut x = x_x1000
    let mut shift_log = 0   // Σ log(10) × 1000 factors = 2302 per decade
    // Reduce x down to [1000, 9999] range.
    while x >= 10000 {
        x = x / 10
        shift_log = shift_log + 2302
    }
    // Scale up if < 1000
    while x < 1000 {
        x = x * 10
        shift_log = shift_log - 2302
    }
    // Now x in [1000, 9999].  Piecewise monotone table (ln ×1000).
    let mut base = 0
    if x >= 9000      { base = 2197 }
    else if x >= 8000 { base = 2079 }
    else if x >= 7000 { base = 1946 }
    else if x >= 6000 { base = 1792 }
    else if x >= 5000 { base = 1609 }
    else if x >= 4000 { base = 1386 }
    else if x >= 3000 { base = 1099 }
    else if x >= 2500 { base =  916 }
    else if x >= 2000 { base =  693 }
    else if x >= 1500 { base =  405 }
    else if x >= 1200 { base =  182 }
    else if x >= 1100 { base =   95 }
    else if x >= 1050 { base =   49 }
    else if x >= 1010 { base =   10 }
    else              { base =    0 }
    return base + shift_log
}

// R/S Hurst: returns H × 1000.  N must be ≥ 2.
fn hurst_rs_x1000(ws: list) -> int {
    let n = len(ws)
    if n < 2 { return 500 }
    let mu_x1000 = mean_x1000(ws)   // ×1000 of per-mille integers ⇒ ×10^6 scale
    // Build Y_i (deviation ×1000 from per-mille mu) in integer per-mille:
    // W_i is per-mille; mu_x1000 is per-mille·×1000.  So dev_i×1000 = W_i·1000 − mu_x1000.
    let mut z_cum = []
    let mut cum = 0
    let mut sq_sum = 0   // Σ (dev_i)²   (scale: (per-mille·×1000)² = ×10^6)
    let mut i = 0
    while i < n {
        let dev_x1000 = ws[i] * 1000 - mu_x1000
        cum = cum + dev_x1000
        z_cum = z_cum.push(cum)
        sq_sum = sq_sum + (dev_x1000 / 1000) * (dev_x1000 / 1000)
        i = i + 1
    }
    let r_raw = max_int(z_cum) - min_int(z_cum)    // ×1000·per-mille = ×10^6 scale? (cum of ×10^3 devs over n) — same units as dev_x1000
    // Normalize R to per-mille.  dev_x1000 is per-mille × 1000 ⇒ divide by 1000.
    let r_permille = r_raw / 1000
    // Variance estimator (per-mille²) then sqrt → per-mille.
    let var_permille_sq = sq_sum / n
    let s_permille = isqrt(var_permille_sq)
    if s_permille <= 0 { return 1000 }   // degenerate: all equal ⇒ H≈1 (persistent constant)
    // R/S ratio in per-mille: r_permille / s_permille (unitless pure ratio),
    // then ×1000 to get ×1000 fixed-point.
    let rs_x1000 = (abs_i(r_permille) * 1000) / s_permille
    if rs_x1000 <= 0 { return 500 }
    // H = log(R/S) / log(N).   log in ×1000 scale.
    let log_rs = ln_x1000(rs_x1000)
    let log_n  = ln_x1000(n * 1000)
    if log_n <= 0 { return 500 }
    // H × 1000 = (log_rs ×1000) / log_n  [log_rs already ×1000]
    let h_x1000 = (log_rs * 1000) / log_n
    // Clamp [0, 1000]
    if h_x1000 < 0    { return 0 }
    if h_x1000 > 1000 { return 1000 }
    return h_x1000
}

// V_hurst_x1000 = δ · (H − 0.5)²    (both H and δ in ×1000 scale ⇒ dim check)
fn v_hurst_x1000(h_x1000: int, delta_x1000: int) -> int {
    let dev = h_x1000 - 500   // per-mille (×1000) deviation from 0.5
    let sq  = (dev * dev) / 1000  // (×1000)²/1000 = ×1000
    return (delta_x1000 * sq) / 1000   // ×1000 · ×1000 / 1000 = ×1000
}

// ── Core L_IX compute paths (4-term vs 5-term) ────────────────────────────

fn l_ix_4term_x1000(w_k: int, w_prev: int, lam_x1000: int) -> int {
    let t      = if w_prev < 0 { 0 } else { t_tension_x1000(w_k, w_prev) }
    let v_s    = v_struct_x1000(w_k)
    let v_sy   = v_sync_stub_x1000(w_k)
    let v_rg   = 0
    let i_irr  = if w_prev < 0 { 0 } else { i_irr_x1000(w_k, w_prev) }
    let arrow  = (lam_x1000 * i_irr) / 1000
    return t - v_s - v_sy - v_rg + arrow
}

fn l_ix_5term_x1000(w_k: int, w_prev: int, lam_x1000: int, v_h_x1000: int) -> int {
    let base_4 = l_ix_4term_x1000(w_k, w_prev, lam_x1000)
    // 5th potential V_hurst is subtracted like other V terms
    return base_4 - v_h_x1000
}

fn sum_list(xs: list) -> int {
    let mut s = 0
    let mut i = 0
    while i < len(xs) { s = s + xs[i] ;  i = i + 1 }
    return s
}

// ── Helpers ────────────────────────────────────────────────────────────────
fn now_stamp() -> string { return exec("date +%Y-%m-%dT%H:%M:%S").trim() }
fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }

fn int_list_json(xs: list) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(xs) {
        if i > 0 { s = s + "," }
        s = s + str(xs[i])
        i = i + 1
    }
    return s + "]"
}

// ── Main ───────────────────────────────────────────────────────────────────

fn main() {
    println("[l_ix_5term_stress_test] EXP-2: H★ τ(6)=4 primitivity — 5-term stress")
    println("  fixture (seed 20260421, commit 672610fc): ws = " + int_list_json(WS))
    println("  V_X choice    : V_hurst  (Hurst 1951; R/S analysis)")
    println("  formula       : V_hurst = delta * (H - 0.5)^2")
    println("  delta_x1000   : " + str(DELTA_X1000) + " (= 0.01 absolute)")
    println("  lambda_arrow  : " + str(LAMBDA_X1000))
    println("")

    // ── Step 1: compute Hurst exponent of WS ──
    let h_x1000 = hurst_rs_x1000(WS)
    let v_h_const_x1000 = v_hurst_x1000(h_x1000, DELTA_X1000)
    println("─── Hurst exponent (R/S analysis) ───")
    println("  H_x1000 (0=anti, 500=RW, 1000=persistent) = " + str(h_x1000))
    println("  |H - 0.5|_x1000                            = " + str(abs_i(h_x1000 - 500)))
    println("  V_hurst_x1000 (trajectory-wide constant)   = " + str(v_h_const_x1000))
    println("")

    // ── Step 2: per-gen 4-term vs 5-term tables ──
    let mut l4_list = []
    let mut l5_list = []
    let mut t_list = []
    let mut vs_list = []
    let mut vsy_list = []
    let mut iirr_list = []

    let mut i = 0
    while i < N_GEN {
        let w_prev = if i == 0 { 0 - 1 } else { WS[i - 1] }
        let t_val   = if w_prev < 0 { 0 } else { t_tension_x1000(WS[i], w_prev) }
        let v_s_val = v_struct_x1000(WS[i])
        let v_sy_val = v_sync_stub_x1000(WS[i])
        let i_irr_val = if w_prev < 0 { 0 } else { i_irr_x1000(WS[i], w_prev) }

        let l4 = l_ix_4term_x1000(WS[i], w_prev, LAMBDA_X1000)
        let l5 = l_ix_5term_x1000(WS[i], w_prev, LAMBDA_X1000, v_h_const_x1000)

        l4_list   = l4_list.push(l4)
        l5_list   = l5_list.push(l5)
        t_list    = t_list.push(t_val)
        vs_list   = vs_list.push(v_s_val)
        vsy_list  = vsy_list.push(v_sy_val)
        iirr_list = iirr_list.push(i_irr_val)
        i = i + 1
    }

    let s_ix_4 = sum_list(l4_list)
    let s_ix_5 = sum_list(l5_list)
    let delta_s = s_ix_5 - s_ix_4
    let delta_abs = abs_i(delta_s)
    let s4_abs = abs_i(s_ix_4)
    let delta_pct_x1000 = if s4_abs == 0 { 0 } else { (delta_abs * 1000) / s4_abs }

    println("─── per-gen L_IX (all x1000) ───")
    println("gen |    W |     T | V_struct | V_sync | I_irr |  V_hurst |  L_4term |  L_5term")
    println("----+------+-------+----------+--------+-------+----------+----------+----------")
    let mut k = 0
    while k < N_GEN {
        println(" " + str(k + 1)
            + "  | "  + str(WS[k])
            + "  |  " + str(t_list[k])
            + "  |   " + str(vs_list[k])
            + "   |  " + str(vsy_list[k])
            + "  |  " + str(iirr_list[k])
            + "  |   " + str(v_h_const_x1000)
            + "   |  " + str(l4_list[k])
            + "  |  " + str(l5_list[k]))
        k = k + 1
    }
    println("")

    // ── Step 3: STATIONARY_AT_FIXPOINT verdicts ──
    // Under 4-term: W_5 = W_4 = 1000 ⇒ ΔW=0 ⇒ T=0, V_struct=0, V_sync=0,
    //   V_RG=0, I_irr=0 ⇒ L_5 = 0.  |L_5| ≤ tol ⇒ STATIONARY.
    // Under 5-term: L_5 = 0 − V_hurst = -V_hurst.  If |V_hurst| > tol:
    //   STATIONARY_AT_FIXPOINT BREAK.
    let l4_at_5 = l4_list[N_GEN - 1]
    let l5_at_5 = l5_list[N_GEN - 1]

    let stationary_4 = if abs_i(l4_at_5) <= TOL_X1000 { 1 } else { 0 }
    let stationary_5 = if abs_i(l5_at_5) <= TOL_X1000 { 1 } else { 0 }

    let verdict_4 = if stationary_4 == 1 { "STATIONARY_AT_FIXPOINT" } else { "NON_STATIONARY" }
    let verdict_5 = if stationary_5 == 1 { "STATIONARY_AT_FIXPOINT" } else { "STATIONARY_BREAK" }

    println("─── STATIONARY_AT_FIXPOINT verdicts ───")
    println("  4-term:  L_IX_5 = " + str(l4_at_5) + "   |L_5| <= " + str(TOL_X1000) + "?  "
          + str(stationary_4) + "   verdict=" + verdict_4)
    println("  5-term:  L_IX_5 = " + str(l5_at_5) + "   |L_5| <= " + str(TOL_X1000) + "?  "
          + str(stationary_5) + "   verdict=" + verdict_5)
    println("  Δ(L_5)         = " + str(l5_at_5 - l4_at_5))
    println("")

    // ── Step 4: pre-registered H★ verdict ──
    // Rule (pre-registered, raw#12):
    //   STATIONARY_BREAK at 5-term AND |Δ S_IX|/|S_IX_4| ≥ 10%
    //      → H_STAR_STRONGLY_SUPPORTED
    //   STATIONARY preserved at 5-term
    //      → H_STAR_WEAK_OR_NONE
    //   Otherwise (break but perturbation < 10%)
    //      → H_STAR_INCONCLUSIVE
    let h_star = if stationary_5 == 0 {
        if delta_pct_x1000 >= SIGNIFICANT_PCT_X1000 { "H_STAR_STRONGLY_SUPPORTED" }
        else { "H_STAR_INCONCLUSIVE" }
    } else { "H_STAR_WEAK_OR_NONE" }

    println("─── S_IX summary + H★ verdict (pre-registered) ───")
    println("  S_IX_4term            = " + str(s_ix_4))
    println("  S_IX_5term            = " + str(s_ix_5))
    println("  Δ S_IX                = " + str(delta_s))
    println("  |Δ S_IX| / |S_4| x1000 = " + str(delta_pct_x1000) + " (>= " + str(SIGNIFICANT_PCT_X1000) + " ⇒ significant)")
    println("  H★ verdict             = " + h_star)
    println("")

    // ── Step 4b: δ-sensitivity scan ──
    // Check whether L_IX_5 breaks stationarity at any larger δ.  If the
    // canonical δ=10 finding is H_STAR_WEAK_OR_NONE we still want to know
    // at what δ the 4-term closure DOES break: this tells us how
    // structurally "locked" τ(6)=4 is.
    println("─── delta sensitivity scan (probes arithmetic-underflow artifact) ───")
    println("  delta_x1000 |  V_hurst |  L_5_5term |  stationary5 | verdict")
    let mut scan_breaks_any = 0
    let mut scan_min_break_delta = 0 - 1
    let mut scan_results = []   // list of lists [delta, v_h, l5, stationary5]
    let mut si = 0
    while si < len(DELTA_SCAN) {
        let d = DELTA_SCAN[si]
        let v_h_d = v_hurst_x1000(h_x1000, d)
        let w_prev_last = WS[N_GEN - 2]
        let l5_d = l_ix_5term_x1000(WS[N_GEN - 1], w_prev_last, LAMBDA_X1000, v_h_d)
        let stat_d = if abs_i(l5_d) <= TOL_X1000 { 1 } else { 0 }
        if stat_d == 0 {
            if scan_breaks_any == 0 { scan_min_break_delta = d }
            scan_breaks_any = 1
        }
        let row_d = []
        let row_d1 = row_d.push(d)
        let row_d2 = row_d1.push(v_h_d)
        let row_d3 = row_d2.push(l5_d)
        let row_d4 = row_d3.push(stat_d)
        scan_results = scan_results.push(row_d4)
        let vd = if stat_d == 1 { "STATIONARY_AT_FIXPOINT" } else { "STATIONARY_BREAK" }
        println("   " + str(d) + "        |   " + str(v_h_d)
              + "   |   " + str(l5_d) + "   |   " + str(stat_d) + "     | " + vd)
        si = si + 1
    }
    println("  any break in scan?            = " + str(scan_breaks_any))
    println("  min delta at break (x1000)    = " + str(scan_min_break_delta))
    println("")

    // ── Step 5: emit verdict JSON ──
    let mut out = "{\n"
    out = out + "  \"verifier_type\": \"l_ix_5term_stress_test\",\n"
    out = out + "  \"experiment_id\": \"EXP-2\",\n"
    out = out + "  \"generated\": \"" + now_stamp() + "\",\n"
    out = out + "  \"source\": \"tool/l_ix_5term_stress_test.hexa\",\n"
    out = out + "  \"hexa_only\": true,\n"
    out = out + "  \"raw\": [9, 10, 11, 12],\n"
    out = out + "  \"fixture\": {\n"
    out = out + "    \"name\": \"natural_gen5\",\n"
    out = out + "    \"seed\": 20260421,\n"
    out = out + "    \"source_commit\": \"672610fc\",\n"
    out = out + "    \"ws_per_mille\": " + int_list_json(WS) + "\n"
    out = out + "  },\n"
    out = out + "  \"v_x_choice\": {\n"
    out = out + "    \"name\": \"V_hurst\",\n"
    out = out + "    \"reference\": \"Hurst 1951 (R/S analysis); Mandelbrot & Wallis 1969\",\n"
    out = out + "    \"formula\": \"V_hurst = delta * (H - 0.5)^2\",\n"
    out = out + "    \"delta_x1000\": " + str(DELTA_X1000) + ",\n"
    out = out + "    \"delta_absolute\": 0.01,\n"
    out = out + "    \"rationale\": \"physically clean long-memory regularizer; 0.5 null hypothesis = random walk; scale chosen so max V_hurst ~ 2.5 per-mille, comparable to T_tension peak but not swamping V_struct\"\n"
    out = out + "  },\n"
    out = out + "  \"parameters\": {\n"
    out = out + "    \"lambda_arrow_x1000\": " + str(LAMBDA_X1000) + ",\n"
    out = out + "    \"tol_stationary_x1000\": " + str(TOL_X1000) + ",\n"
    out = out + "    \"significant_pct_x1000\": " + str(SIGNIFICANT_PCT_X1000) + "\n"
    out = out + "  },\n"
    out = out + "  \"hurst\": {\n"
    out = out + "    \"h_x1000\": " + str(h_x1000) + ",\n"
    out = out + "    \"dev_from_half_x1000\": " + str(abs_i(h_x1000 - 500)) + ",\n"
    out = out + "    \"v_hurst_x1000\": " + str(v_h_const_x1000) + "\n"
    out = out + "  },\n"
    out = out + "  \"per_gen\": [\n"
    let mut r = 0
    while r < N_GEN {
        if r > 0 { out = out + ",\n" }
        out = out + "    {\"gen\":" + str(r + 1)
        out = out + ",\"w\":" + str(WS[r])
        out = out + ",\"t\":" + str(t_list[r])
        out = out + ",\"v_struct\":" + str(vs_list[r])
        out = out + ",\"v_sync\":" + str(vsy_list[r])
        out = out + ",\"i_irr\":" + str(iirr_list[r])
        out = out + ",\"v_hurst\":" + str(v_h_const_x1000)
        out = out + ",\"l_4term\":" + str(l4_list[r])
        out = out + ",\"l_5term\":" + str(l5_list[r]) + "}"
        r = r + 1
    }
    out = out + "\n  ],\n"
    out = out + "  \"action_sum\": {\n"
    out = out + "    \"s_ix_4term_x1000\": " + str(s_ix_4) + ",\n"
    out = out + "    \"s_ix_5term_x1000\": " + str(s_ix_5) + ",\n"
    out = out + "    \"delta_s_x1000\": " + str(delta_s) + ",\n"
    out = out + "    \"delta_pct_x1000\": " + str(delta_pct_x1000) + "\n"
    out = out + "  },\n"
    out = out + "  \"stationary\": {\n"
    out = out + "    \"l_ix_5_4term_x1000\": " + str(l4_at_5) + ",\n"
    out = out + "    \"l_ix_5_5term_x1000\": " + str(l5_at_5) + ",\n"
    out = out + "    \"stationary_4term\": " + bool_s(stationary_4 == 1) + ",\n"
    out = out + "    \"stationary_5term\": " + bool_s(stationary_5 == 1) + ",\n"
    out = out + "    \"verdict_4term\": \"" + verdict_4 + "\",\n"
    out = out + "    \"verdict_5term\": \"" + verdict_5 + "\"\n"
    out = out + "  },\n"
    out = out + "  \"h_star_verdict\": \"" + h_star + "\",\n"
    out = out + "  \"pre_registered_rule\": \"5-term STATIONARY break AND |Δ S|/|S_4| ≥ 10% ⇒ STRONGLY_SUPPORTED; preserved ⇒ WEAK_OR_NONE; break but < 10% ⇒ INCONCLUSIVE\",\n"
    out = out + "  \"delta_sensitivity_scan\": {\n"
    out = out + "    \"deltas_x1000\": " + int_list_json(DELTA_SCAN) + ",\n"
    out = out + "    \"any_break\": " + bool_s(scan_breaks_any == 1) + ",\n"
    out = out + "    \"min_break_delta_x1000\": " + str(scan_min_break_delta) + ",\n"
    out = out + "    \"rows\": [\n"
    let mut sr = 0
    while sr < len(scan_results) {
        if sr > 0 { out = out + ",\n" }
        let rr = scan_results[sr]
        out = out + "      {\"delta_x1000\":" + str(rr[0])
        out = out + ",\"v_hurst_x1000\":" + str(rr[1])
        out = out + ",\"l_ix_5_5term_x1000\":" + str(rr[2])
        out = out + ",\"stationary\":" + bool_s(rr[3] == 1) + "}"
        sr = sr + 1
    }
    out = out + "\n    ]\n"
    out = out + "  },\n"
    // airgenome hook embed (CLI-only probe, raw#9 hexa-only, raw#15 no-hardcode)
    let _ag_avail = ag_probe_available()
    let _ag_chain = if _ag_avail { ag_probe_top_chain() } else { "" }
    let _ag_touch = if _ag_avail && _ag_chain != "" { ag_probe_touch_count(_ag_chain) } else { 0 }
    let _ag_chain_json = if _ag_chain == "" { "null" } else { "\"" + _ag_chain + "\"" }
    out = out + "  \"air_chain\": " + _ag_chain_json + ",\n"
    out = out + "  \"touch_count\": " + str(_ag_touch) + ",\n"
    out = out + "  \"air_schema_version\": \"" + ag_schema_version() + "\"\n"
    out = out + "}\n"

    write_file(OUT_PATH, out)
    println("  wrote: " + OUT_PATH)

    // exit code encodes verdict (match EXP-1 convention)
    if h_star == "H_STAR_STRONGLY_SUPPORTED" { exit(0) }
    if h_star == "H_STAR_WEAK_OR_NONE"       { exit(1) }
    exit(2)
}

main()
