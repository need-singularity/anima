// tool/anima_unknown_4_repos_deep_audit.hexa — cycle 83 잔여 4 미상 repo deep audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 70/82 후속. cycle 82가 pixie deep audit 마쳤고, 잔여 4 (secret /
//   gohive.sh / hexa-os / skynet-timer) batch inspection.
//
// FINDINGS (2026-04-27, README/CNAME/title inspection)
//
//   1) gohive.sh
//      domain    : gohive.sh (CNAME)
//      title     : "hive — limit-free multi-provider AI chat orchestra"
//      content   : "TUI + CLI. Self-hosted memory. Docker-style sandbox"
//      role      : hive repo의 marketing landing page
//      category  : static_landing_pages (cycle 70 그대로)
//
//   2) skynet-timer ⚠️ (anima cross-link 발견)
//      domain    : skynet-timer.com (CNAME)
//      tagline   : "Two attractors. One deadline."
//      proof_url : github.com/need-singularity/anima/blob/main/docs/singularity-heaven-or-skynet.md
//      role      : anima 작업의 external visualization / proof timer page
//      category  : static_landing_pages (cycle 70) but anima cross-link 추가 정보
//
//   3) hexa-os
//      title     : "🧊 HEXA-OS — AI Inference Appliance OS"
//      tagline   : "Not a Linux replacement. law-enforced · self-hosting · unikernel-first.
//                   Serving p99 30–50% ↓ is the whole point."
//      target    : unikernel · Firecracker
//      depends   : hexa-lang P7-9
//      stage     : design
//      DOI       : 10.5281/zenodo.19703256
//      category  : academic_output_zenodo (cycle 70 그대로)
//
//   4) secret
//      role      : workspace credentials vault (private)
//      contents  : cards.json, credentials/, gmail_credentials.json, gmail_token.json,
//                  project.hexa, proxy.json, ssh/
//      readme    : "Private repo — 민감 정보 포함. 절대 public 전환 금지"
//      category  : private_credentials_vault (cycle 70 그대로)
//      audit     : metadata-only invariant (cycle 62 / cycle 70 / cycle 83 동일)
//
// CATEGORY 변화 (cycle 70 → cycle 83)
//   active_dev_app(1)         pixie                                    [cycle 82 정밀화]
//   private_credentials_vault private  secret                          [cycle 83 confirm]
//   academic_output_zenodo(2) papers / hexa-os                         [cycle 83 정밀화: hexa-os AI Inference OS]
//   static_landing_pages(2)   gohive.sh / skynet-timer                 [cycle 83 anima cross-link 발견]
//
// 새 발견: skynet-timer가 anima docs/singularity-heaven-or-skynet.md를 proof URL로 link.
// 단순 landing이 아니라 anima 작업의 external visualization. 향후 anima 작업이 그 doc
// 갱신 시 timer page도 영향. operational coupling = light read-only reference.
//
// NON_MUTATION
//   4 repo 모두 안 건드림. memory project_workspace.md 라인 정밀화만 (외부).
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - secret repo는 cycle 62 metadata-only invariant 유지 (content read 안 함).
//   - skynet-timer ↔ anima cross-link는 README의 proof URL 단방향. anima → timer
//     자동 update 의존 없음. 단방향 reference만.

let HELPER_PATH = "/tmp/anima_unknown_4_repos_deep_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima unknown 4 repos deep audit — emitted by tool/anima_unknown_4_repos_deep_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/unknown_4_repos_deep_audit.json')\n\n")

    parts.push("findings = [\n")
    parts.push("    {\n")
    parts.push("        'repo':'gohive.sh', 'domain':'gohive.sh',\n")
    parts.push("        'title':'hive — limit-free multi-provider AI chat orchestra',\n")
    parts.push("        'content':'TUI + CLI; self-hosted memory; docker-style sandbox',\n")
    parts.push("        'role':'hive repo marketing landing page',\n")
    parts.push("        'category':'static_landing_pages (unchanged)',\n")
    parts.push("        'anima_cross_link':'none',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'skynet-timer', 'domain':'skynet-timer.com',\n")
    parts.push("        'tagline':'Two attractors. One deadline.',\n")
    parts.push("        'proof_url':'github.com/need-singularity/anima/blob/main/docs/singularity-heaven-or-skynet.md',\n")
    parts.push("        'role':'anima 작업 external visualization / countdown',\n")
    parts.push("        'category':'static_landing_pages (anima cross-link 발견)',\n")
    parts.push("        'anima_cross_link':'unidirectional reference to anima docs/singularity-heaven-or-skynet.md',\n")
    parts.push("        'note':'cycle 83 발견 — cycle 70 metadata-only에서 놓친 cross-link',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'hexa-os', 'doi':'10.5281/zenodo.19703256',\n")
    parts.push("        'title':'🧊 HEXA-OS — AI Inference Appliance OS',\n")
    parts.push("        'tagline':'Not a Linux replacement. law-enforced unikernel-first. Serving p99 30-50% ↓.',\n")
    parts.push("        'target':'unikernel · Firecracker',\n")
    parts.push("        'depends':'hexa-lang P7-9',\n")
    parts.push("        'stage':'design',\n")
    parts.push("        'role':'AI inference appliance OS (academic + spec stage)',\n")
    parts.push("        'category':'academic_output_zenodo (정밀화)',\n")
    parts.push("        'anima_cross_link':'none direct (hexa-lang sibling)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'secret', 'audit_mode':'METADATA_ONLY (cycle 62 invariant)',\n")
    parts.push("        'role':'workspace credentials vault (private)',\n")
    parts.push("        'contents':'cards.json + credentials/ + gmail/anthropic/runpod/discord/cloudflare/hf creds + ssh/',\n")
    parts.push("        'security':'private repo, README explicitly forbids public transition',\n")
    parts.push("        'category':'private_credentials_vault (unchanged)',\n")
    parts.push("        'anima_cross_link':'separate from anima/.secrets/ (workspace-level vault)',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("category_state_post_cycle_83 = {\n")
    parts.push("    'active_core': ['anima','hexa-lang','airgenome','nexus'],\n")
    parts.push("    'sister_supporting_science': ['n6-architecture','void','hive','contact','pi-telegram'],\n")
    parts.push("    'active_dev_app': ['pixie'],\n")
    parts.push("    'private_credentials_vault': ['secret'],\n")
    parts.push("    'academic_output_zenodo': ['papers','hexa-os'],\n")
    parts.push("    'static_landing_pages': ['gohive.sh','skynet-timer'],\n")
    parts.push("    'other_utility': ['_github-org'],\n")
    parts.push("    'archives_deprecated': ['archive-TECS-L','archive-brainwire','archive-sedi'],\n")
    parts.push("    'total': 19,\n")
    parts.push("}\n\n")

    parts.push("memory_actions = [\n")
    parts.push("    {'file':'project_workspace.md', 'edit':'gohive.sh / skynet-timer / hexa-os 라인 정밀화'},\n")
    parts.push("    {'file':'MEMORY.md', 'edit':'no change (라벨 그대로 유효)'},\n")
    parts.push("]\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'cycle 67 utility 2번째 적용 site (cascade.hexa post-launch — pod-side hexa) 검증', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("    {'action':'사용자 결정 4 항목 (atlas/own3/frontmatter/cron) 중 선택', 'priority':'medium', 'cost':'사용자 영역'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 83 — 잔여 4 미상 repo (cycle 70/82) deep audit batch',\n")
    parts.push("    'cycle': 83,\n")
    parts.push("    'findings': findings,\n")
    parts.push("    'category_state_post_cycle_83': category_state_post_cycle_83,\n")
    parts.push("    'memory_actions': memory_actions,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'new_discoveries':[\n")
    parts.push("        'skynet-timer ↔ anima/docs/singularity-heaven-or-skynet.md unidirectional proof URL (cycle 70 metadata에서 놓침)',\n")
    parts.push("        'hexa-os = AI Inference Appliance OS (unikernel/Firecracker target, hexa-lang P7-9 depends)',\n")
    parts.push("    ],\n")
    parts.push("    'non_mutation_guarantee':'4 repo 모두 안 건드림; secret repo cycle 62 metadata-only invariant 유지',\n")
    parts.push("    'cross_link_cycles':['cycle 36 inventory','cycle 62 secrets metadata invariant','cycle 70 5-repo metadata','cycle 82 pixie deep'],\n")
    parts.push("    'pattern':'governance audit chain layer 61 (cycle 70 미상 4/5 deep done; pixie+gohive+skynet+hexa-os+secret = 5/5)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[unknown_4_deep] cycle=83 repos=4 new_discoveries=2 anima_cross_link=skynet-timer -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_DEEP")
    println("inv:cycle=83")
    println("inv:repos_audited=4")
    println("inv:new_discoveries=2")
    println("inv:cross_link_skynet_timer=anima_proof_url")
    println("inv:cross_link_cycles=36,62,70,82")
    return true
}

fn cmd_selftest() {
    println("── anima_unknown_4_repos_deep_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 83 — 잔여 4 repo deep audit; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
