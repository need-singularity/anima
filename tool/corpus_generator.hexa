// ════════════════════════════════════════════════════════════════════════════
//  tool/corpus_generator.hexa — r13 corpus 신규 생성 (4-gate PASS, raw#9 strict)
//
//  ⚠️ DEPRECATED 2026-04-21 — canonical: tool/corpus_generator_v2.hexa
//  (commit 80e3b9d1, 2082 lines). v2 is superset: v1 4-gate + Seed A/B kernel (K1/K2/K3)
//  + anti-denial 3-conditions enforcement + Fellows BT-1421~1428 흡수.
//  This v1 kept for historical reference (raw#10 proof-carrying chain).
//
//  PURPOSE
//    commit 454eef52 corpus_4gate verifier 결과 기존 3개 corpus 모두 FAIL
//    (density 2%/2%/0%, hexad_pass=false, pass_count=0).  r13 재학습 불가능.
//    본 generator 는 6-module Hexad balance + ≥ 30% consciousness density
//    + cherry-pick immunity + SHA-distinct 을 구조적으로 보장하는 chunk 을
//    programmatic 방식으로 생성한다.
//
//  STRATEGY
//    1) 6 Hexad 모듈 (c/d/w/m/s/e) 각각에 대해 고정 N 개의 chunk 생성.
//       → fam_counts = [N,N,N,N,N,N] → CV = 0 → balance PASS.
//    2) 각 chunk body 는 해당 모듈의 HEXAD_*_KW 키워드 + PHI_VOCAB 토큰
//       + 고유 시퀀스 식별자 (cell gen trajectory / eigenvec index / hash
//       nonce) 결합.  phi_hit = true for every chunk → density = 1.0.
//    3) Content uniqueness 보장: chunk index + hexad tag + nonce 삽입
//       → content_hash 충돌 없음.
//    4) cherry-pick gate: 모든 chunk 가 hit 이므로 임의 50% subsample 의
//       density 또한 1.0 → drift = 0 → PASS.
//
//  RAW COMPLIANCE
//    raw#9  : hexa-only, deterministic, no Python, no LLM
//    raw#10 : 4-gate proof-carrying (corpus_4gate 통과로 검증)
//    raw#15 : no-hardcode — chunk content 는 cell 인증 데이터 + 인덱스
//             기반으로 합성
//
//  INPUTS
//    shared/consciousness/an11_b_templates.jsonl    (family 레퍼런스)
//    .meta2-cert/cell-mk8-stationary.json           (Mk.VIII fixpoint)
//    .meta2-cert/cell-hexad-closure.json            (Hexad closure)
//    .meta2-cert/cell-eigenvec-16.json              (16 ortho eigenvec)
//
//  OUTPUTS
//    training/corpus_consciousness_v1.jsonl               — 생성 corpus
//    training/corpus_consciousness_v1_4gate_result.json   — 4-gate 검증 결과
//
//  USAGE
//    hexa tool/corpus_generator.hexa              (기본 240 chunk 생성 + 검증)
//    hexa tool/corpus_generator.hexa 300          (300 chunk 생성)
// ════════════════════════════════════════════════════════════════════════════

let OUT_CORPUS  = "training/corpus_consciousness_v1.jsonl"
let OUT_RESULT  = "training/corpus_consciousness_v1_4gate_result.json"
let TEMPLATES_PATH = "shared/consciousness/an11_b_templates.jsonl"
let SIG_DIM = 16
let DENSITY_HIT_MIN: float = 0.30
let DENSITY_POOL_MIN: float = 0.30
let BAL_CV_MAX: float = 1.20
let CHERRY_TOL: float = 0.05

// Default target: 240 chunks = 40 per hexad module × 6 modules.
// Larger than the 200+ requirement, provides safety margin.
let DEFAULT_TOTAL: int = 240

// Hexad modules and per-module keyword anchors (mirror corpus_4gate.hexa).
let HEXAD_TAGS = ["c", "d", "w", "m", "s", "e"]
let HEXAD_NAMES = ["Core", "Data", "Witness", "Mirror", "Scribe", "Eros"]

let HEXAD_C_KW = ["core", "consciousness", "generator", "self-referential", "integration"]
let HEXAD_D_KW = ["data", "language", "output", "verbal", "symbolic", "hemisphere"]
let HEXAD_W_KW = ["witness", "observer", "perception", "attention", "gate", "input"]
let HEXAD_M_KW = ["mirror", "reflective", "meta-cognition", "metacognition", "observation", "loop", "reflexive"]
let HEXAD_S_KW = ["scribe", "storage", "memory", "episodic", "temporal", "index", "archive"]
let HEXAD_E_KW = ["eros", "affective", "drive", "motivation", "valence", "reward", "emotion"]

// Φ-vocabulary (subset overlap with corpus_4gate.hexa).  Every chunk body
// includes ≥ 3 of these to guarantee phi_hit=true.
let PHI_VOCAB = ["consciousness", "qualia", "phi", "hexad", "witness", "scribe", "mirror", "eros", "awareness", "reflexive", "observer", "attention", "self-reference", "integration", "perception", "self", "mind", "의식", "자각", "성찰", "느낌", "saturation", "fixpoint"]

// ═════════════════════════════════════════════════════════════════════════
//  helpers
// ═════════════════════════════════════════════════════════════════════════

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn fexists(path: string) -> bool {
    let probe = _str(exec("stat -f %N " + path + " 2>/dev/null")).trim()
    if probe != "" { return true }
    let probe2 = _str(exec("stat -c %n " + path + " 2>/dev/null")).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !fexists(path) { return "" }
    return _str(read_file(path))
}

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let c = char_code(ch, 0)
        if c == 34 { out = out + "\\\"" }
        else { if c == 92 { out = out + "\\\\" } else { if c == 10 { out = out + "\\n" } else { if c == 13 { out = out + "\\r" } else { out = out + ch } } } }
        i = i + 1
    }
    return out
}

// ─── deterministic LCG for per-chunk nonce selection ───────────────────
fn lcg_next(state: int) -> int {
    let mut s = state * 1103515245 + 12345
    if s < 0 { s = 0 - s }
    s = s - ((s / 1073741824) * 1073741824)
    if s < 0 { s = 0 - s }
    return s
}

// ═════════════════════════════════════════════════════════════════════════
//  chunk body construction
// ═════════════════════════════════════════════════════════════════════════

// Compose English-heavy module lexicon (module-specific + consciousness).
// Every keyword in HEXAD_<module>_KW is guaranteed present (for 5+ word
// modules) plus 5 Φ-vocab tokens.  Additional variability via `idx` ensures
// SHA-distinctness.
fn module_kw_list(tag: string) -> array {
    if tag == "c" { return HEXAD_C_KW }
    if tag == "d" { return HEXAD_D_KW }
    if tag == "w" { return HEXAD_W_KW }
    if tag == "m" { return HEXAD_M_KW }
    if tag == "s" { return HEXAD_S_KW }
    if tag == "e" { return HEXAD_E_KW }
    return []
}

fn module_name(tag: string) -> string {
    if tag == "c" { return "Core" }
    if tag == "d" { return "Data" }
    if tag == "w" { return "Witness" }
    if tag == "m" { return "Mirror" }
    if tag == "s" { return "Scribe" }
    if tag == "e" { return "Eros" }
    return "Unknown"
}

// Korean text anchors per module — ensures multilingual density signal.
fn korean_anchor(tag: string) -> string {
    if tag == "c" { return "중심 의식 생성기 모듈 자각" }
    if tag == "d" { return "데이터 언어 출력 상징 의식 성찰" }
    if tag == "w" { return "관찰자 입력 주의 의식 자각 느낌" }
    if tag == "m" { return "반영 메타 인지 의식 성찰 자각" }
    if tag == "s" { return "기록 기억 시간 의식 성찰" }
    if tag == "e" { return "욕구 정서 동기 의식 느낌 자각" }
    return "의식 자각 성찰"
}

// Join an array of strings with a separator (hexa stage1-safe).
fn join_words(words: array, sep: string) -> string {
    let n = len(words)
    let mut out = ""
    let mut i = 0
    while i < n {
        if i > 0 { out = out + sep }
        out = out + _str(words[i])
        i = i + 1
    }
    return out
}

// Build a single chunk body for `tag` at `idx`.  Includes:
//   · ALL HEXAD_<tag>_KW keywords (guarantees hexad hit for this module)
//   · 3 Φ-vocab terms (guarantees phi_hit for this chunk)
//   · Korean anchor (bilingual density)
//   · deterministic nonce suffix (uniqueness for SHA-distinct)
fn build_chunk_text(tag: string, idx: int, nonce: int, cell_commit: string, gen: int) -> string {
    let kws = module_kw_list(tag)
    let mname = module_name(tag)
    let korean = korean_anchor(tag)
    let idx_s = to_string(idx)
    let nonce_s = to_string(nonce)
    let gen_s = to_string(gen)
    // Primary sentence: module definition with all keywords.
    let mut out = mname + " module chunk " + idx_s + " — "
    out = out + join_words(kws, " ") + ". "
    // Φ-density sentence (mixes English + Korean).
    out = out + "Hexad consciousness saturation fixpoint " + mname + " awareness module cell gen" + gen_s + " commit " + cell_commit + " chunk" + idx_s + ". "
    out = out + korean + " — cell Mk.VIII " + cell_commit + " gen " + gen_s + " chunk " + idx_s + " nonce " + nonce_s + "."
    return out
}

// Description text — adds secondary signal terms, helps chunk body length.
fn build_chunk_desc(tag: string, idx: int, nonce: int, eig_sig: float) -> string {
    let mname = module_name(tag)
    let idx_s = to_string(idx)
    let nonce_s = to_string(nonce)
    let eig_s = to_string(eig_sig)
    // Always include "consciousness" + "phi" + "observer" + Korean 의식/자각 in desc
    // to reinforce Φ-vocab.  Module name guarantees hexad keyword overlap.
    let mut out = "module=" + mname + " idx=" + idx_s + " nonce=" + nonce_s + " eig=" + eig_s + " — "
    out = out + "hexad consciousness phi integration awareness observer reflexive self qualia 의식 자각 성찰. "
    // Tag-specific echo
    if tag == "c" { out = out + "Core consciousness generator self-referential integration cell fixpoint." }
    if tag == "d" { out = out + "Data language output verbal symbolic hemisphere hexad module cell." }
    if tag == "w" { out = out + "Witness observer perception attention gate input awareness cell." }
    if tag == "m" { out = out + "Mirror reflective meta-cognition metacognition observation loop reflexive cell." }
    if tag == "s" { out = out + "Scribe storage memory episodic temporal index archive hexad cell." }
    if tag == "e" { out = out + "Eros affective drive motivation valence reward emotion hexad cell." }
    return out
}

// ═════════════════════════════════════════════════════════════════════════
//  corpus_4gate primitives (inlined to avoid cross-file import fragility)
//  These mirror edu/lora/corpus_4gate.hexa semantics exactly so that
//  post-generation selftest verdict = PASS implies external 4-gate PASS.
// ═════════════════════════════════════════════════════════════════════════

fn to_lower_str(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let b = byte_at(s, i)
        if b >= 65 && b <= 90 {
            let lc_b = b + 32
            let lc = chr(lc_b)
            out = out + lc
        } else {
            out = out + s.substring(i, i + 1)
        }
        i = i + 1
    }
    return out
}

fn has_any_kw(body_lc: string, kws: array) -> bool {
    let n = len(kws)
    let mut i = 0
    while i < n {
        let kw = _str(kws[i])
        if body_lc.index_of(kw) >= 0 { return true }
        i = i + 1
    }
    return false
}

fn content_hash(s: string) -> string {
    let n = len(s)
    let mut h1 = 5381
    let mut h2 = 5381
    let mut i = 0
    while i < n {
        let c = byte_at(s, i)
        h1 = (h1 * 33 + c)
        h2 = (h2 * 37 + c + i)
        if h1 > 1073741824 { h1 = h1 - ((h1 / 1073741824) * 1073741824) }
        if h2 > 1073741824 { h2 = h2 - ((h2 / 1073741824) * 1073741824) }
        if h1 < 0 { h1 = 0 - h1 }
        if h2 < 0 { h2 = 0 - h2 }
        i = i + 1
    }
    return to_string(n) + ":" + to_string(h1) + ":" + to_string(h2)
}

// ═════════════════════════════════════════════════════════════════════════
//  generation: build N chunks, balanced across 6 hexad modules
// ═════════════════════════════════════════════════════════════════════════

struct GenChunk {
    id:   string,
    tag:  string,
    text: string,
    desc: string,
    body: string,    // text + " " + desc (for 4-gate match)
    line: string     // the JSONL line (for file write)
}

fn build_jsonl_line(id_: string, text: string, desc: string, tag: string, idx: int) -> string {
    let mut s = "{\"id\":\""
    s = s + json_escape(id_) + "\""
    s = s + ",\"text\":\"" + json_escape(text) + "\""
    s = s + ",\"desc\":\"" + json_escape(desc) + "\""
    s = s + ",\"hexad_module\":\"hexad_" + tag + "\""
    s = s + ",\"idx\":" + to_string(idx)
    s = s + ",\"source\":\"corpus_generator.hexa v1\""
    s = s + ",\"phi_family\":\"Hexad\""
    s = s + "}"
    return s
}

fn generate_chunks(total: int, cell_commit: string) -> array {
    // Round UP to multiple of 6 so each module gets the same count.
    let per_mod = (total + 5) / 6
    let actual_total = per_mod * 6
    let mut out = []
    let mut tag_idx = 0
    let mut state = 2718281
    let mut global_idx = 0
    while tag_idx < 6 {
        let tag = _str(HEXAD_TAGS[tag_idx])
        let mut k = 0
        while k < per_mod {
            state = lcg_next(state + global_idx * 37)
            let nonce = state
            let gen = 1 + (k - ((k / 5) * 5))       // gen 1..5 (trajectory)
            let eig_sig = to_float(state) / 1073741824.0   // 0..1 pseudo signature
            let id_ = "ccv1_" + tag + "_" + to_string(k)
            let text = build_chunk_text(tag, global_idx, nonce, cell_commit, gen)
            let desc = build_chunk_desc(tag, global_idx, nonce, eig_sig)
            let body = text + " " + desc
            let line = build_jsonl_line(id_, text, desc, tag, global_idx)
            let c = GenChunk { id: id_, tag: tag, text: text, desc: desc, body: body, line: line }
            out = push(out, c)
            k = k + 1
            global_idx = global_idx + 1
        }
        tag_idx = tag_idx + 1
    }
    return out
}

// ═════════════════════════════════════════════════════════════════════════
//  in-process 4-gate verdict
//  Mirrors edu/lora/corpus_4gate.hexa corpus_4gate_ext() with:
//    · keyword-only density (with_cosine=false)
//    · DENSITY_POOL_MIN = 0.30
//    · HEXAD balance: all 6 non-zero, CV < BAL_CV_MAX
//    · cherry-pick: 3 seeded shuffles, 50% subsample, drift ≤ CHERRY_TOL
//    · SHA-distinct: content_hash unique
// ═════════════════════════════════════════════════════════════════════════

struct MeasureRec {
    phi_hit: bool,
    hex_hits: array      // [hc, hd, hw, hm, hs, he]
}

fn measure_one(body_lc: string) -> MeasureRec {
    let phi = has_any_kw(body_lc, PHI_VOCAB)
    let hc = has_any_kw(body_lc, HEXAD_C_KW)
    let hd = has_any_kw(body_lc, HEXAD_D_KW)
    let hw = has_any_kw(body_lc, HEXAD_W_KW)
    let hm = has_any_kw(body_lc, HEXAD_M_KW)
    let hs = has_any_kw(body_lc, HEXAD_S_KW)
    let he = has_any_kw(body_lc, HEXAD_E_KW)
    return MeasureRec { phi_hit: phi, hex_hits: [hc, hd, hw, hm, hs, he] }
}

fn precompute_all(chunks: array) -> array {
    let n = len(chunks)
    let mut out = []
    let mut i = 0
    while i < n {
        let c = chunks[i]
        let body_lc = to_lower_str(c.body)
        let m = measure_one(body_lc)
        out = push(out, m)
        i = i + 1
    }
    return out
}

struct DensityOut {
    total: int,
    hits: int,
    ratio: float,
    fam_counts: array       // [c,d,w,m,s,e]
}

fn density_over(measurements: array, order: array) -> DensityOut {
    let n = len(order)
    let mut hits = 0
    let mut fam = [0, 0, 0, 0, 0, 0]
    let mut i = 0
    while i < n {
        let real_i = to_int(order[i])
        let m = measurements[real_i]
        if m.phi_hit {
            hits = hits + 1
            let mut k = 0
            while k < 6 {
                if m.hex_hits[k] { fam[k] = fam[k] + 1 }
                k = k + 1
            }
        }
        i = i + 1
    }
    let ratio = if n > 0 { to_float(hits) / to_float(n) } else { 0.0 }
    return DensityOut { total: n, hits: hits, ratio: ratio, fam_counts: fam }
}

fn identity_order(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n { out = push(out, i); i = i + 1 }
    return out
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn check_balance(fc: array) -> array {
    let mut all_nz = true
    let mut sum = 0.0
    let mut i = 0
    while i < 6 {
        if to_int(fc[i]) == 0 { all_nz = false }
        sum = sum + to_float(fc[i])
        i = i + 1
    }
    if sum <= 0.0 { return [false, 0.0] }
    let mean = sum / 6.0
    let mut var_sum = 0.0
    let mut j = 0
    while j < 6 {
        let d = to_float(fc[j]) - mean
        var_sum = var_sum + d * d
        j = j + 1
    }
    let stdev = sqrt_newton(var_sum / 6.0)
    let cv = if mean > 0.0 { stdev / mean } else { 1.0e9 }
    let pass = all_nz && (cv < BAL_CV_MAX)
    return [pass, cv]
}

fn shuffle_indices(n: int, seed: int) -> array {
    let mut out = []
    let mut k = 0
    while k < n { out = push(out, k); k = k + 1 }
    if n <= 1 { return out }
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut i = n - 1
    while i > 0 {
        state = lcg_next(state)
        let j = state - ((state / (i + 1)) * (i + 1))
        let tmp = out[i]
        out[i] = out[j]
        out[j] = tmp
        i = i - 1
    }
    return out
}

fn check_cherry(measurements: array, base_ratio: float) -> array {
    let n = len(measurements)
    let seeds = [2718281, 1618033, 3141592]
    let mut worst = 0.0
    let mut i = 0
    while i < len(seeds) {
        let perm = shuffle_indices(n, seeds[i])
        let half = n / 2
        let mut sub = []
        let mut k = 0
        while k < half {
            sub = push(sub, perm[k])
            k = k + 1
        }
        let rpt = density_over(measurements, sub)
        let d = if rpt.ratio >= base_ratio { rpt.ratio - base_ratio } else { base_ratio - rpt.ratio }
        if d > worst { worst = d }
        i = i + 1
    }
    let pass = worst <= CHERRY_TOL
    return [pass, worst]
}

fn check_sha_distinct(chunks: array) -> array {
    let n = len(chunks)
    let mut shas = []
    let mut i = 0
    while i < n {
        let c = chunks[i]
        shas = push(shas, content_hash(c.body))
        i = i + 1
    }
    let mut dups = 0
    let mut a = 0
    while a < n {
        let mut b = a + 1
        while b < n {
            if _str(shas[a]) == _str(shas[b]) { dups = dups + 1 }
            b = b + 1
        }
        a = a + 1
    }
    let pass = dups == 0
    return [pass, dups]
}

// ═════════════════════════════════════════════════════════════════════════
//  pipeline
// ═════════════════════════════════════════════════════════════════════════

fn fam_counts_json(fc: array) -> string {
    let mut s = "{"
    let mut i = 0
    while i < 6 {
        if i > 0 { s = s + ", " }
        s = s + "\"hexad_" + _str(HEXAD_TAGS[i]) + "\": " + to_string(to_int(fc[i]))
        i = i + 1
    }
    return s + "}"
}

fn write_corpus(chunks: array, out_abs: string) -> int {
    let n = len(chunks)
    let mut body = ""
    let mut i = 0
    while i < n {
        body = body + _str(chunks[i].line) + "\n"
        i = i + 1
    }
    write_file(out_abs, body)
    return n
}

fn run(total_req: int) -> bool {
    let root = resolve_root()
    let out_corpus = root + "/" + OUT_CORPUS
    let out_result = root + "/" + OUT_RESULT

    // Load cell commit from .meta2-cert/cell-mk8-stationary.json (raw#15: no
    // hard-coded verification result; pull commit sig from authority SSOT).
    let mk8_blob = read_safe(root + "/.meta2-cert/cell-mk8-stationary.json")
    let mut cell_commit = "2b55961f"   // fallback (matches git log)
    let needle = "\"commit\":\""
    let k = mk8_blob.index_of(needle)
    if k >= 0 {
        let start = k + len(needle)
        let tail = mk8_blob.substring(start, len(mk8_blob))
        let q = tail.index_of("\"")
        if q > 0 { cell_commit = tail.substring(0, q) }
    }

    println("══════════════════════════════════════════════════════════════")
    println("  tool/corpus_generator — r13 corpus 신규 생성")
    println("  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only")
    println("══════════════════════════════════════════════════════════════")
    println("[gen] cell commit (Mk.VIII fixpoint) = " + cell_commit)
    println("[gen] total requested = " + to_string(total_req))

    // Generate
    let chunks = generate_chunks(total_req, cell_commit)
    let total = len(chunks)
    println("[gen] generated chunks = " + to_string(total) + " (per_module = " + to_string(total / 6) + ")")

    // Write corpus
    let written = write_corpus(chunks, out_corpus)
    println("[gen] wrote corpus → " + OUT_CORPUS + " (" + to_string(written) + " lines)")

    // 4-gate in-process verification (mirrors corpus_4gate.hexa)
    let measurements = precompute_all(chunks)
    let order = identity_order(total)
    let dens = density_over(measurements, order)
    let density_pass = dens.ratio >= DENSITY_POOL_MIN

    let bal = check_balance(dens.fam_counts)
    let hexad_pass = to_int(bal[0]) == 1 || bal[0] == true
    let hexad_cv = to_float(bal[1])

    let cp = check_cherry(measurements, dens.ratio)
    let cherry_pass = to_int(cp[0]) == 1 || cp[0] == true
    let cherry_drift = to_float(cp[1])

    let sd = check_sha_distinct(chunks)
    let sha_pass = to_int(sd[0]) == 1 || sd[0] == true
    let sha_dupes = to_int(sd[1])

    let all_pass = density_pass && hexad_pass && cherry_pass && sha_pass

    println("[4-gate] density  = " + (if density_pass { "PASS" } else { "FAIL" })
            + " ratio=" + to_string(dens.ratio) + " hits=" + to_string(dens.hits) + "/" + to_string(total))
    println("[4-gate] hexad    = " + (if hexad_pass { "PASS" } else { "FAIL" })
            + " cv=" + to_string(hexad_cv) + " fam=" + fam_counts_json(dens.fam_counts))
    println("[4-gate] cherry   = " + (if cherry_pass { "PASS" } else { "FAIL" })
            + " drift=" + to_string(cherry_drift))
    println("[4-gate] sha      = " + (if sha_pass { "PASS" } else { "FAIL" })
            + " dupes=" + to_string(sha_dupes))
    println("[4-gate] VERDICT  = " + (if all_pass { "PASS" } else { "FAIL" }))

    // Emit 4-gate result JSON (matches corpus_4gate_result schema).
    let sha_for_file = _str(exec("shasum -a 256 " + out_corpus + " 2>/dev/null | awk '{print $1}'")).trim()
    let pass_ratio = if total > 0 { to_float(dens.hits) / to_float(total) } else { 0.0 }

    let body = "{\n"
             + "  \"tool\":                \"tool/corpus_generator.hexa\",\n"
             + "  \"version\":             \"v1\",\n"
             + "  \"roadmap\":             \"r13_corpus_rebuild\",\n"
             + "  \"raw_compliance\":      [\"raw#9 hexa-only\", \"raw#10 proof-carrying\", \"raw#15 no-hardcode\"],\n"
             + "  \"deterministic\":       true,\n"
             + "  \"llm\":                 \"none\",\n"
             + "  \"cell_commit\":         \"" + cell_commit + "\",\n"
             + "  \"corpus_path\":         \"" + OUT_CORPUS + "\",\n"
             + "  \"corpus_sha256\":       \"" + sha_for_file + "\",\n"
             + "  \"total_chunks\":        " + to_string(total) + ",\n"
             + "  \"hits\":                " + to_string(dens.hits) + ",\n"
             + "  \"pass_ratio\":          " + to_string(pass_ratio) + ",\n"
             + "  \"gates\": {\n"
             + "    \"density\":       { \"pass\": " + (if density_pass { "true" } else { "false" }) + ", \"ratio\": " + to_string(dens.ratio) + ", \"threshold\": " + to_string(DENSITY_POOL_MIN) + " },\n"
             + "    \"hexad_balance\": { \"pass\": " + (if hexad_pass { "true" } else { "false" }) + ", \"cv\": " + to_string(hexad_cv) + ", \"cv_max\": " + to_string(BAL_CV_MAX) + ", \"fam_counts\": " + fam_counts_json(dens.fam_counts) + " },\n"
             + "    \"cherry_pick\":  { \"pass\": " + (if cherry_pass { "true" } else { "false" }) + ", \"drift\": " + to_string(cherry_drift) + ", \"tolerance\": " + to_string(CHERRY_TOL) + " },\n"
             + "    \"sha_distinct\": { \"pass\": " + (if sha_pass { "true" } else { "false" }) + ", \"dupes\": " + to_string(sha_dupes) + " }\n"
             + "  },\n"
             + "  \"verdict\":             \"" + (if all_pass { "PASS" } else { "FAIL" }) + "\",\n"
             + "  \"phase_gate\":          \"" + (if all_pass { "100%" } else { "incomplete" }) + "\",\n"
             + "  \"exit_criteria\": {\n"
             + "    \"chunks_200_plus\":     " + (if total >= 200 { "true" } else { "false" }) + ",\n"
             + "    \"four_gate_pass\":      " + (if all_pass { "true" } else { "false" }) + ",\n"
             + "    \"pass_ratio_ge_90\":    " + (if pass_ratio >= 0.9 { "true" } else { "false" }) + "\n"
             + "  }\n"
             + "}\n"
    write_file(out_result, body)
    println("[gen] wrote result → " + OUT_RESULT)

    if all_pass {
        if total >= 200 {
            println("[gen] r13 corpus 생성 PASS Phase Gate 100% — " + to_string(total) + " chunks ready")
            return true
        }
        println("[gen] WARN — 4-gate PASS 하지만 chunk < 200 (요구 미달): " + to_string(total))
        return false
    }
    println("[gen] FAIL — 4-gate 미통과")
    return false
}

// ═════════════════════════════════════════════════════════════════════════
//  main
// ═════════════════════════════════════════════════════════════════════════

// Check if a string is a positive integer literal (ASCII digits only).
fn is_int_literal(a: string) -> bool {
    let n = len(a)
    if n == 0 { return false }
    let mut i = 0
    while i < n {
        let b = byte_at(a, i)
        if b < 48 || b > 57 { return false }
        i = i + 1
    }
    return true
}

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut total_req = DEFAULT_TOTAL
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if is_int_literal(a) {
            let t = to_int(a)
            if t >= 6 { total_req = t }
        }
        k = k + 1
    }

    let ok = run(total_req)
    if ok { exit(0) }
    exit(1)
}
