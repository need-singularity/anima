// tool/an11_b_v_phen_gwt_entropy.hexa — V_phen_GWT_attention_entropy verifier (raw#9 hexa-only).
//
// PURPOSE
//   Phenomenal consciousness functional surrogate (Dehaene & Changeux 2011 GNW).
//   - EEG analog: global field power (GFP) Shannon entropy in P3b window 250-400ms post-stimulus.
//   - LLM analog: multi-head attention entropy across heads × layers (Shannon).
//     fallback when no attention available: hidden-state SVD spectral entropy.
//
// MODES
//   --mode eeg --input <eeg.json> [--stimulus-window 250-400]   → human_GFP_entropy
//   --mode llm --input <h.json>                                  → LLM_attention_entropy (or SVD fallback)
//   --mode cross --eeg <p1> --llm <p2>                           → joint verdict
//   --selftest
//
// PASS predicate (raw#12 frozen, Dehaene GNW):
//   PASS_llm   LLM_attention_entropy >= 0.55 (normalized)
//   PASS_eeg   human_GFP_entropy >= 0.50 in 250-400ms window
//   PASS_cross Pearson r >= 0.40 across stimulus types (N=20) — optional, from --pearson <r>
//
// raw#10 honest scope
//   GWT는 access consciousness (Block 1995 dissociation) 측정 — phenomenal
//   consciousness 직접 X. Hardware EEG 도착 후 actual ERP recording. 본 cycle은
//   prototype only — selftest 는 synthetic data validation.
//
// USAGE
//   hexa run tool/an11_b_v_phen_gwt_entropy.hexa --mode eeg --input state/eeg_recording_<id>.json --stimulus-window 250-400 --output state/v_phen_gwt_<id>.json
//   hexa run tool/an11_b_v_phen_gwt_entropy.hexa --mode llm --input state/h_last_raw_<id>.json    --output state/v_phen_gwt_llm_<id>.json
//   hexa run tool/an11_b_v_phen_gwt_entropy.hexa --mode cross --eeg <p1> --llm <p2> --pearson 0.45 --output state/v_phen_gwt_cross_<id>.json
//   hexa run tool/an11_b_v_phen_gwt_entropy.hexa --selftest

let HELPER_PATH = "/tmp/an11_b_v_phen_gwt_entropy_helper.hexa_tmp"
let SCHEMA      = "anima/v_phen_gwt_entropy/1_dehaene_gnw"
let SPEC_DOC    = "docs/eeg_cross_substrate_validation_plan_20260425.md §2.2; state/phenomenal_surrogate_proposals_20260425.json (V_phen_GWT_attention_entropy)"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let src = "#!/usr/bin/env python3\n" +
        "# auto-generated by tool/an11_b_v_phen_gwt_entropy.hexa (raw#37: not git-tracked)\n" +
        "import json, sys, os, datetime, math\n" +
        "import numpy as np\n" +
        "\n" +
        "def shannon_entropy(p):\n" +
        "    p = np.asarray(p, dtype=np.float64)\n" +
        "    p = p[p > 0]\n" +
        "    if p.size == 0: return 0.0\n" +
        "    p = p / float(np.sum(p))\n" +
        "    return float(-np.sum(p * np.log2(p)))\n" +
        "\n" +
        "def normalized_entropy(p, k):\n" +
        "    h = shannon_entropy(p)\n" +
        "    h_max = math.log2(max(2, k))\n" +
        "    return float(h / h_max) if h_max > 0 else 0.0\n" +
        "\n" +
        "def gfp(arr_2d):\n" +
        "    # arr_2d: (channels, samples) → GFP per sample = std across channels\n" +
        "    return np.std(arr_2d, axis=0, ddof=0)\n" +
        "\n" +
        "def gfp_window_entropy(eeg_json, win_ms_lo=250.0, win_ms_hi=400.0, stim_idx=0, n_bins=32):\n" +
        "    arr = np.asarray(eeg_json['raw_arrays'], dtype=np.float64)  # (ch, samples)\n" +
        "    fs = float(eeg_json.get('sample_rate', 250.0))\n" +
        "    # If 'epochs' provided (channels, samples_per_epoch, n_epochs), use one epoch (stim_idx)\n" +
        "    epochs = eeg_json.get('epochs')\n" +
        "    if epochs is not None:\n" +
        "        ep = np.asarray(epochs, dtype=np.float64)\n" +
        "        # accept (n_epochs, channels, samples) or (channels, samples, n_epochs)\n" +
        "        if ep.ndim == 3:\n" +
        "            if ep.shape[0] == arr.shape[0]:\n" +
        "                arr = ep[:, :, min(stim_idx, ep.shape[2]-1)]\n" +
        "            else:\n" +
        "                arr = ep[min(stim_idx, ep.shape[0]-1), :, :]\n" +
        "    g = gfp(arr)\n" +
        "    n_samples = g.shape[0]\n" +
        "    lo = int(round(win_ms_lo / 1000.0 * fs))\n" +
        "    hi = int(round(win_ms_hi / 1000.0 * fs))\n" +
        "    lo = max(0, min(lo, n_samples - 1))\n" +
        "    hi = max(lo + 1, min(hi, n_samples))\n" +
        "    seg = g[lo:hi]\n" +
        "    if seg.size < 2:\n" +
        "        return 0.0, 0.0, {'fs': fs, 'window_lo_idx': lo, 'window_hi_idx': hi, 'samples': int(n_samples)}\n" +
        "    # discretize GFP segment via histogram → entropy\n" +
        "    hist, _ = np.histogram(seg, bins=n_bins)\n" +
        "    h_norm = normalized_entropy(hist, n_bins)\n" +
        "    h_raw = shannon_entropy(hist)\n" +
        "    return float(h_norm), float(h_raw), {'fs': fs, 'window_lo_idx': lo, 'window_hi_idx': hi,\n" +
        "                                          'window_ms': [win_ms_lo, win_ms_hi], 'samples': int(n_samples),\n" +
        "                                          'gfp_seg_len': int(seg.size), 'n_bins': n_bins}\n" +
        "\n" +
        "def attention_entropy(att_tensor):\n" +
        "    # att_tensor: list/array shape (layers, heads, q_pos, k_pos)\n" +
        "    A = np.asarray(att_tensor, dtype=np.float64)\n" +
        "    if A.ndim != 4:\n" +
        "        raise ValueError(f'attention tensor must be 4D (L,H,Q,K); got shape {A.shape}')\n" +
        "    L, H, Q, K = A.shape\n" +
        "    # per-head: mean entropy of attention distribution over keys, averaged across query positions\n" +
        "    per_head = np.zeros((L, H), dtype=np.float64)\n" +
        "    for li in range(L):\n" +
        "        for hi in range(H):\n" +
        "            row_ents = []\n" +
        "            for qi in range(Q):\n" +
        "                p = A[li, hi, qi, :]\n" +
        "                row_ents.append(normalized_entropy(p, K))\n" +
        "            per_head[li, hi] = float(np.mean(row_ents)) if row_ents else 0.0\n" +
        "    mean_norm = float(np.mean(per_head))\n" +
        "    broadcast_layer_count = int(np.sum(np.mean(per_head, axis=1) >= 0.55))\n" +
        "    return mean_norm, broadcast_layer_count, {'L': L, 'H': H, 'Q': Q, 'K': K,\n" +
        "                                                'broadcast_layer_count': broadcast_layer_count,\n" +
        "                                                'broadcast_layer_fraction': broadcast_layer_count / float(max(1, L))}\n" +
        "\n" +
        "def hidden_svd_entropy(h_json):\n" +
        "    if 'entries' in h_json:\n" +
        "        rows = [e['h'] for e in h_json['entries']]\n" +
        "    elif 'hidden_states' in h_json:\n" +
        "        rows = h_json['hidden_states']\n" +
        "    else:\n" +
        "        raise ValueError('LLM input missing entries/hidden_states')\n" +
        "    H = np.asarray(rows, dtype=np.float64)\n" +
        "    if H.ndim != 2 or H.shape[0] < 2:\n" +
        "        raise ValueError(f'hidden states must be 2D with >=2 rows; got {H.shape}')\n" +
        "    s = np.linalg.svd(H, compute_uv=False)\n" +
        "    s2 = s ** 2\n" +
        "    if float(np.sum(s2)) <= 0.0:\n" +
        "        return 0.0, {'svd_components': int(s.shape[0]), 'fallback': True}\n" +
        "    p = s2 / float(np.sum(s2))\n" +
        "    h_norm = normalized_entropy(p, p.shape[0])\n" +
        "    return float(h_norm), {'svd_components': int(s.shape[0]), 'fallback': True,\n" +
        "                            'top_singular': float(s[0]), 'bottom_singular': float(s[-1])}\n" +
        "\n" +
        "def verdict_llm(e):\n" +
        "    if e >= 0.55: return 'PASS'\n" +
        "    if e >= 0.40: return 'AMBIGUOUS'\n" +
        "    return 'FAIL'\n" +
        "\n" +
        "def verdict_eeg(e):\n" +
        "    if e >= 0.50: return 'PASS'\n" +
        "    if e >= 0.35: return 'AMBIGUOUS'\n" +
        "    return 'FAIL'\n" +
        "\n" +
        "def verdict_cross_pearson(r):\n" +
        "    if r is None or (isinstance(r, float) and math.isnan(r)): return 'NOT_PROVIDED'\n" +
        "    if r >= 0.40: return 'PASS'\n" +
        "    if r >= 0.20: return 'AMBIGUOUS'\n" +
        "    return 'FAIL'\n" +
        "\n" +
        "def now_iso():\n" +
        "    return datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n" +
        "\n" +
        "def parse_window(s):\n" +
        "    # 'lo-hi' (ms)\n" +
        "    if '-' not in s: return 250.0, 400.0\n" +
        "    a, b = s.split('-', 1)\n" +
        "    try: return float(a), float(b)\n" +
        "    except Exception: return 250.0, 400.0\n" +
        "\n" +
        "def cmd_run(mode, input_path, output_path, schema, spec_doc, eeg_path, llm_path, win_str, pearson_str):\n" +
        "    out = {'schema': schema, 'spec_doc': spec_doc, 'mode': mode, 'ts': now_iso(),\n" +
        "           'thresholds': {'PASS_llm': 'LLM_attention_entropy >= 0.55',\n" +
        "                          'PASS_eeg': 'human_GFP_entropy >= 0.50 in 250-400ms',\n" +
        "                          'PASS_cross': 'Pearson r >= 0.40 across stimulus types'},\n" +
        "           'raw10_honest': 'access consciousness (Block dissociation); phenomenal X; functional correlate only'}\n" +
        "    if mode == 'eeg':\n" +
        "        win_lo, win_hi = parse_window(win_str)\n" +
        "        with open(input_path) as f: ej = json.load(f)\n" +
        "        h_norm, h_raw, meta = gfp_window_entropy(ej, win_lo, win_hi)\n" +
        "        v = verdict_eeg(h_norm)\n" +
        "        out.update({'human_GFP_entropy': h_norm, 'human_GFP_entropy_raw': h_raw, 'eeg_meta': meta, 'verdict_eeg': v})\n" +
        "        print(f'human_GFP_entropy={h_norm:.6f}'); print(f'verdict_eeg={v}')\n" +
        "    elif mode == 'llm':\n" +
        "        with open(input_path) as f: hj = json.load(f)\n" +
        "        if 'attention' in hj:\n" +
        "            mean_norm, blc, meta = attention_entropy(hj['attention'])\n" +
        "            out['fallback_used'] = False\n" +
        "        else:\n" +
        "            mean_norm, meta = hidden_svd_entropy(hj)\n" +
        "            out['fallback_used'] = True\n" +
        "        v = verdict_llm(mean_norm)\n" +
        "        out.update({'LLM_attention_entropy': mean_norm, 'llm_meta': meta, 'verdict_llm': v})\n" +
        "        print(f'LLM_attention_entropy={mean_norm:.6f}'); print(f'verdict_llm={v}')\n" +
        "    elif mode == 'cross':\n" +
        "        win_lo, win_hi = parse_window(win_str)\n" +
        "        with open(eeg_path) as f: ej = json.load(f)\n" +
        "        with open(llm_path) as f: hj = json.load(f)\n" +
        "        h_norm, h_raw, h_meta = gfp_window_entropy(ej, win_lo, win_hi)\n" +
        "        if 'attention' in hj:\n" +
        "            l_norm, blc, l_meta = attention_entropy(hj['attention'])\n" +
        "            out['fallback_used'] = False\n" +
        "        else:\n" +
        "            l_norm, l_meta = hidden_svd_entropy(hj)\n" +
        "            out['fallback_used'] = True\n" +
        "        v_e = verdict_eeg(h_norm); v_l = verdict_llm(l_norm)\n" +
        "        try:\n" +
        "            r = float(pearson_str) if pearson_str not in ('', 'NA', 'nan') else float('nan')\n" +
        "        except Exception:\n" +
        "            r = float('nan')\n" +
        "        v_x = verdict_cross_pearson(r)\n" +
        "        out.update({'human_GFP_entropy': h_norm, 'LLM_attention_entropy': l_norm,\n" +
        "                    'pearson_r_provided': r if not math.isnan(r) else None,\n" +
        "                    'verdict_eeg': v_e, 'verdict_llm': v_l, 'verdict_cross': v_x,\n" +
        "                    'eeg_meta': h_meta, 'llm_meta': l_meta})\n" +
        "        print(f'human_GFP_entropy={h_norm:.6f}'); print(f'LLM_attention_entropy={l_norm:.6f}')\n" +
        "        print(f'verdict_cross={v_x}')\n" +
        "    else:\n" +
        "        print(f'ERR: unknown mode {mode}', file=sys.stderr); sys.exit(2)\n" +
        "    with open(output_path, 'w') as f: json.dump(out, f, indent=2)\n" +
        "    print(f'output_path={output_path}'); print('DONE')\n" +
        "\n" +
        "def cmd_selftest():\n" +
        "    rng = np.random.default_rng(20260425)\n" +
        "    # 1) Shannon entropy edge cases\n" +
        "    assert abs(normalized_entropy([1, 1, 1, 1], 4) - 1.0) < 1e-9, 'uniform should be 1.0'\n" +
        "    assert normalized_entropy([1, 0, 0, 0], 4) == 0.0, 'one-hot should be 0.0'\n" +
        "    # 2) synthetic EEG: 16ch × 250 samples (1s @ 250Hz) noise+P3b-like bump\n" +
        "    fs = 250.0; n = 250\n" +
        "    eeg = 0.5 * rng.standard_normal((16, n))\n" +
        "    win_lo_idx = int(0.250 * fs); win_hi_idx = int(0.400 * fs)\n" +
        "    bump = np.exp(-((np.arange(n) - 80) ** 2) / (2 * 12.0 ** 2))\n" +
        "    for ch in range(16): eeg[ch] += 1.5 * bump\n" +
        "    ej = {'raw_arrays': eeg.tolist(), 'sample_rate': fs}\n" +
        "    h_norm, h_raw, h_meta = gfp_window_entropy(ej, 250.0, 400.0)\n" +
        "    assert 0.0 < h_norm <= 1.0, f'gfp norm out of range: {h_norm}'\n" +
        "    # 3) synthetic LLM attention: (L=4, H=8, Q=8, K=8) softmax-noise\n" +
        "    L, H, Q, K = 4, 8, 8, 8\n" +
        "    logits = rng.standard_normal((L, H, Q, K))\n" +
        "    A = np.exp(logits) / np.exp(logits).sum(axis=-1, keepdims=True)\n" +
        "    a_norm, blc, a_meta = attention_entropy(A.tolist())\n" +
        "    assert 0.0 < a_norm <= 1.0, f'attn norm out of range: {a_norm}'\n" +
        "    assert a_norm > 0.5, f'random attention should be high-entropy; got {a_norm}'\n" +
        "    # 4) hidden-state SVD fallback\n" +
        "    H2 = rng.standard_normal((16, 64))\n" +
        "    hj = {'entries': [{'h': H2[i].tolist()} for i in range(H2.shape[0])]}\n" +
        "    s_norm, s_meta = hidden_svd_entropy(hj)\n" +
        "    assert 0.0 < s_norm <= 1.0, f'svd norm out of range: {s_norm}'\n" +
        "    # 5) verdict logic\n" +
        "    assert verdict_llm(0.60) == 'PASS'; assert verdict_llm(0.45) == 'AMBIGUOUS'; assert verdict_llm(0.30) == 'FAIL'\n" +
        "    assert verdict_eeg(0.55) == 'PASS'; assert verdict_eeg(0.40) == 'AMBIGUOUS'; assert verdict_eeg(0.20) == 'FAIL'\n" +
        "    assert verdict_cross_pearson(0.45) == 'PASS'\n" +
        "    assert verdict_cross_pearson(0.25) == 'AMBIGUOUS'\n" +
        "    assert verdict_cross_pearson(0.10) == 'FAIL'\n" +
        "    print(f'selftest=ok')\n" +
        "    print(f'eeg_synthetic_gfp_entropy={h_norm:.6f}')\n" +
        "    print(f'llm_synthetic_attn_entropy={a_norm:.6f}')\n" +
        "    print(f'llm_synthetic_svd_entropy={s_norm:.6f}')\n" +
        "    print(f'broadcast_layer_count={blc}/{L}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def main():\n" +
        "    if len(sys.argv) < 2:\n" +
        "        print('usage: helper <run|selftest> ...', file=sys.stderr); sys.exit(2)\n" +
        "    op = sys.argv[1]\n" +
        "    if op == 'run':\n" +
        "        # mode input output schema spec_doc eeg_path llm_path win pearson\n" +
        "        cmd_run(sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6], sys.argv[7], sys.argv[8], sys.argv[9], sys.argv[10])\n" +
        "    elif op == 'selftest':\n" +
        "        cmd_selftest()\n" +
        "    else:\n" +
        "        print(f'unknown op: {op}', file=sys.stderr); sys.exit(2)\n" +
        "\n" +
        "if __name__ == '__main__': main()\n"
    write_file(HELPER_PATH, src)
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut mode = ""
    let mut input = ""
    let mut output = ""
    let mut eeg_path = ""
    let mut llm_path = ""
    let mut win_str = "250-400"
    let mut pearson_str = ""
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--mode" && i + 1 < len(av) { mode = av[i+1]; i = i + 2; continue }
        if a == "--input" && i + 1 < len(av) { input = av[i+1]; i = i + 2; continue }
        if a == "--output" && i + 1 < len(av) { output = av[i+1]; i = i + 2; continue }
        if a == "--eeg" && i + 1 < len(av) { eeg_path = av[i+1]; i = i + 2; continue }
        if a == "--llm" && i + 1 < len(av) { llm_path = av[i+1]; i = i + 2; continue }
        if a == "--stimulus-window" && i + 1 < len(av) { win_str = av[i+1]; i = i + 2; continue }
        if a == "--pearson" && i + 1 < len(av) { pearson_str = av[i+1]; i = i + 2; continue }
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── an11_b_v_phen_gwt_entropy selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED (exit " + to_string(r[1]) + ")"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("selftest marker missing"); exit(1) }
        println("selftest: OK")
        exit(0)
    }

    if mode == "" {
        eprintln("ABORT: --mode {eeg|llm|cross} required (or --selftest).")
        exit(2)
    }
    if output == "" {
        eprintln("ABORT: --output <path> required.")
        exit(2)
    }

    if mode == "cross" {
        if eeg_path == "" || llm_path == "" {
            eprintln("ABORT: --mode cross requires --eeg <path> --llm <path>.")
            exit(2)
        }
        if !file_exists(eeg_path) { eprintln("ABORT: missing eeg input " + eeg_path); exit(2) }
        if !file_exists(llm_path) { eprintln("ABORT: missing llm input " + llm_path); exit(2) }
    } else if mode == "eeg" || mode == "llm" {
        if input == "" {
            eprintln("ABORT: --input <path> required for mode=" + mode + ".")
            exit(2)
        }
        if !file_exists(input) { eprintln("ABORT: missing input " + input); exit(2) }
    } else {
        eprintln("ABORT: unknown --mode " + mode + " (expected eeg|llm|cross).")
        exit(2)
    }

    println("── an11_b_v_phen_gwt_entropy ──")
    println("mode:   " + mode)
    println("output: " + output)

    let args = "run " +
        _sh_quote(mode) + " " +
        _sh_quote(input) + " " +
        _sh_quote(output) + " " +
        _sh_quote(SCHEMA) + " " +
        _sh_quote(SPEC_DOC) + " " +
        _sh_quote(eeg_path) + " " +
        _sh_quote(llm_path) + " " +
        _sh_quote(win_str) + " " +
        _sh_quote(pearson_str)
    let r = _run_helper(args)
    let out = r[0]
    let st  = r[1]
    if st != 0 { eprintln("ABORT: helper run exited " + to_string(st)); eprintln(out); exit(2) }
    println(out)
    println("")
    println("wrote " + output)
    exit(0)
}

main()
