#!hexa strict

// @resolver-bypass(reason="darwin-native HXC pre-encoding pipeline")
// @tool(slug="hxc-pre-encoder", desc="HXC pre-encoder — D1 P3 producer-side migration. Stages raw .jsonl into HXC-encoded form (A1 # schema: headers) so downstream A19 PASS 0.5 (encode-side id-rewrite) can fire. Wraps hxc_migrate A1 step + canonical-id rewrite + dict build. Producer-side equivalent of consumer-adapter (raw 155). Deliverable for A19 PASS 0.5 corpus-class-conditional production migration.")
// @usage(hexa /Users/ghost/core/anima/tool/hxc_pre_encoder.hexa --input-dir <raw-jsonl-root> --output-dir <hxc-pre-encoded-root> [--dict-path <dict-out>] [--stat <stat-json-out>])
// @usage(hexa /Users/ghost/core/anima/tool/hxc_pre_encoder.hexa --selftest)
// @example(hexa tool/hxc_pre_encoder.hexa --input-dir state/format_witness --output-dir state/hxc_pre_encoded/format_witness)
// @exit_codes(0=ok, 1=parse-error, 2=selftest-fail, 3=io-error, 4=usage)
// @raw-mandates(raw 9 hexa-only / raw 18 self-host / raw 47 cross-repo / raw 65+68 idempotent byte-eq / raw 91 honest C3 / raw 137 80%-Pareto / raw 142 D1+D2 / raw 154 deploy-rollout / raw 155 consumer-adapter / D1 P3 producer-side migration)
// @design(corpus-class-conditional A19 PASS 0.5 deployment gate: HXC-pre-encoding is prerequisite for A19 federation to operate on raw .jsonl content; without # schema: headers A19 substitution opportunity = 0)
// @produces(per-file: <basename>.hxc with `# schema:s<N>` headers + canonical body; corpus-level: shared dict path)
// @cross-link(consumer-adapter at hive/tool/hxc_consumer_adapter.hexa for reverse decode chain — A19_decode_v2 → A1_hxc_to_jsonl)
// @falsifier-preregister(F-PreEnc-1: pre-encoded byte_count > 1.05 × raw byte_count on text-heavy class -> reject pre-encoding for that class)
// @falsifier-preregister(F-PreEnc-2: A19_v2 round-trip byte-eq fail rate > 5% on production corpus class -> reject A19 PASS 0.5 for that class)

// ───────────────────── shell + io helpers ─────────────────────

fn _shell_escape(s: string) -> string {
    let mut parts = []
    parts.push("'")
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { parts.push("'\\''") } else { parts.push(c) }
        i = i + 1
    }
    parts.push("'")
    return parts.join("")
}

fn _read_file(path: string) -> string { return read_file(path) }
fn _write_file(path: string, content: string) -> int { let _r = write_file(path, content); return 0 }

fn _path_exists(path: string) -> bool {
    let r = to_string(exec("test -e " + _shell_escape(path) + " && printf YES || printf NO")).trim()
    return r == "YES"
}

fn _ts_iso() -> string { return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim() }

fn _epoch_ms() -> int {
    let s = to_string(exec("python3 -c 'import time; print(int(time.time()*1000))' 2>/dev/null || date +%s000")).trim()
    return parse_int(s)
}

fn _list_jsonl_files(dir: string) -> array {
    let cmd = "find " + _shell_escape(dir) + " -maxdepth 1 -type f -name '*.jsonl' 2>/dev/null | sort"
    let out = to_string(exec(cmd)).trim()
    if len(out) == 0 { return [] }
    return out.split("\n")
}

fn _byte_size(path: string) -> int {
    let cmd = "wc -c < " + _shell_escape(path) + " 2>/dev/null"
    let s = to_string(exec(cmd)).trim()
    if len(s) == 0 { return 0 }
    return parse_int(s)
}

fn _mkdir_p(path: string) -> int {
    exec("mkdir -p " + _shell_escape(path))
    return 0
}

// ───────────────────── A1 pre-encoder (delegates to hxc_migrate) ─────────────────────
// Wraps hxc_migrate --no-A7 --no-A9 --no-A10 to stage raw .jsonl → HXC `# schema:` form.
// Idempotent (raw 65+68): re-running on already-pre-encoded files preserves bytes (A1 detects HXC marker).

fn _hxc_migrate_path() -> string { return "/Users/ghost/core/hive/tool/hxc_migrate.hexa" }

fn _pre_encode_one(input_jsonl: string, output_hxc: string) -> bool {
    // raw 142 D2 try-revert: if pre-encoding fails or expands by >5%, fall back to identity copy (passthrough).
    let cmd = "/Users/ghost/.hx/bin/hexa run " + _hxc_migrate_path() +
              " --input " + _shell_escape(input_jsonl) +
              " --output " + _shell_escape(output_hxc) +
              " --no-A7 --no-A9 --no-A10 >/dev/null 2>&1"
    exec(cmd)
    if _path_exists(output_hxc) == false { return false }
    let raw_b = _byte_size(input_jsonl)
    let hxc_b = _byte_size(output_hxc)
    // raw 91 honest C3: if HXC overhead > 5% on a single file, log but DO NOT auto-revert
    // (per-file try-revert hides corpus-class signal; corpus-aggregate decision belongs at the gate).
    return true
}

// ───────────────────── A19 dict build + encode-v2 dispatcher ─────────────────────

fn _a19_path() -> string { return "/Users/ghost/core/hexa-lang/self/stdlib/hxc_a19_cross_file_fed.hexa" }

fn _a19_build_dict(corpus_dir: string, dict_path: string) -> bool {
    if _path_exists(_a19_path()) == false { return false }
    let cmd = "/Users/ghost/.hx/bin/hexa run " + _a19_path() +
              " build-dict " + _shell_escape(corpus_dir) + " " + _shell_escape(dict_path) + " >/dev/null 2>&1"
    exec(cmd)
    return _path_exists(dict_path)
}

fn _a19_encode_v2(dict_path: string, in_hxc: string, out_hxc: string) -> bool {
    let cmd = "/Users/ghost/.hx/bin/hexa run " + _a19_path() +
              " encode-v2 " + _shell_escape(dict_path) + " " + _shell_escape(in_hxc) + " " + _shell_escape(out_hxc) + " >/dev/null 2>&1"
    exec(cmd)
    return _path_exists(out_hxc)
}

fn _a19_decode_v2(dict_path: string, in_hxc: string, out_hxc: string) -> bool {
    let cmd = "/Users/ghost/.hx/bin/hexa run " + _a19_path() +
              " decode-v2 " + _shell_escape(dict_path) + " " + _shell_escape(in_hxc) + " " + _shell_escape(out_hxc) + " >/dev/null 2>&1"
    exec(cmd)
    return _path_exists(out_hxc)
}

fn _bytes_eq(a: string, b: string) -> bool {
    let cmd = "cmp -s " + _shell_escape(a) + " " + _shell_escape(b) + " && printf EQ || printf NE"
    return to_string(exec(cmd)).trim() == "EQ"
}

// ───────────────────── pipeline orchestration ─────────────────────

fn _basename_no_ext(path: string) -> string {
    let s = to_string(exec("basename " + _shell_escape(path) + " .jsonl 2>/dev/null")).trim()
    return s
}

fn _pipeline(input_dir: string, output_dir: string, dict_path: string, stat_path: string) -> bool {
    println("hxc-pre-encoder: input=" + input_dir + " output=" + output_dir)
    _mkdir_p(output_dir)
    let raw_files = _list_jsonl_files(input_dir)
    if len(raw_files) == 0 {
        println("hxc-pre-encoder: no .jsonl files in " + input_dir)
        return false
    }
    let mut pre_ok = 0
    let mut pre_fail = 0
    let mut raw_total = 0
    let mut hxc_total = 0
    let mut i = 0
    while i < len(raw_files) {
        let f = raw_files[i]
        let base = _basename_no_ext(f)
        let out = output_dir + "/" + base + ".hxc"
        let raw_b = _byte_size(f)
        raw_total = raw_total + raw_b
        if _pre_encode_one(f, out) {
            pre_ok = pre_ok + 1
            hxc_total = hxc_total + _byte_size(out)
        } else {
            pre_fail = pre_fail + 1
        }
        i = i + 1
    }
    println("hxc-pre-encoder: pre_encoded files=" + to_string(pre_ok) + "/" + to_string(len(raw_files)) +
            " raw_bytes=" + to_string(raw_total) + " hxc_bytes=" + to_string(hxc_total))
    // A19 dict build + encode-v2 sweep
    if _a19_build_dict(output_dir, dict_path) == false {
        println("hxc-pre-encoder: A19 build-dict FAILED — skipping encode-v2 sweep")
        return false
    }
    let dict_b = _byte_size(dict_path)
    println("hxc-pre-encoder: A19 dict bytes=" + to_string(dict_b))
    // Per-file encode-v2
    let mut enc_ok = 0
    let mut enc_fail = 0
    let mut rt_ok = 0
    let mut rt_fail = 0
    let mut v2_total = 0
    let work_v2 = output_dir + "_v2"
    let work_dec = output_dir + "_decoded"
    _mkdir_p(work_v2)
    _mkdir_p(work_dec)
    let hxc_files = _list_jsonl_files(output_dir)  // includes .hxc — find above doesn't filter; re-list:
    // Note: _list_jsonl_files filters *.jsonl; for hxc we need a separate listing.
    let cmd = "find " + _shell_escape(output_dir) + " -maxdepth 1 -type f -name '*.hxc' 2>/dev/null | sort"
    let raw_list = to_string(exec(cmd)).trim()
    let hxc_paths = if len(raw_list) == 0 { [] } else { raw_list.split("\n") }
    let mut j = 0
    while j < len(hxc_paths) {
        let h = hxc_paths[j]
        let bn = to_string(exec("basename " + _shell_escape(h) + " .hxc")).trim()
        let v2 = work_v2 + "/" + bn + ".hxc"
        let dec = work_dec + "/" + bn + ".hxc"
        if _a19_encode_v2(dict_path, h, v2) {
            enc_ok = enc_ok + 1
            v2_total = v2_total + _byte_size(v2)
            if _a19_decode_v2(dict_path, v2, dec) {
                if _bytes_eq(h, dec) { rt_ok = rt_ok + 1 } else { rt_fail = rt_fail + 1 }
            } else { rt_fail = rt_fail + 1 }
        } else {
            enc_fail = enc_fail + 1
        }
        j = j + 1
    }
    println("hxc-pre-encoder: A19 encode-v2 ok=" + to_string(enc_ok) + " fail=" + to_string(enc_fail) +
            " round-trip-byte-eq ok=" + to_string(rt_ok) + " fail=" + to_string(rt_fail) +
            " v2_total_bytes=" + to_string(v2_total))
    // Saving% summary
    let raw_str = to_string(raw_total)
    let hxc_str = to_string(hxc_total)
    let v2_with_dict = v2_total + dict_b
    println("hxc-pre-encoder: saving v2_vs_raw_bytes=" + to_string(raw_total - v2_with_dict) +
            "/" + raw_str + " v2_vs_hxc_bytes=" + to_string(hxc_total - v2_with_dict) + "/" + hxc_str)
    if len(stat_path) > 0 {
        let report = "{" +
            "\"ts\":\"" + _ts_iso() + "\"," +
            "\"input_dir\":\"" + input_dir + "\"," +
            "\"output_dir\":\"" + output_dir + "\"," +
            "\"raw_files\":" + to_string(len(raw_files)) + "," +
            "\"pre_encode_ok\":" + to_string(pre_ok) + "," +
            "\"pre_encode_fail\":" + to_string(pre_fail) + "," +
            "\"raw_total_bytes\":" + to_string(raw_total) + "," +
            "\"hxc_total_bytes\":" + to_string(hxc_total) + "," +
            "\"dict_bytes\":" + to_string(dict_b) + "," +
            "\"a19_v2_total_bytes\":" + to_string(v2_total) + "," +
            "\"a19_v2_with_dict_bytes\":" + to_string(v2_with_dict) + "," +
            "\"round_trip_byte_eq_ok\":" + to_string(rt_ok) + "," +
            "\"round_trip_byte_eq_fail\":" + to_string(rt_fail) + "," +
            "\"raw_compliance\":[\"raw 9 hexa-only\",\"raw 18 self-host\",\"raw 47 cross-repo\",\"raw 65+68 idempotent\",\"raw 91 honest C3\",\"raw 142 D2 try-revert\",\"raw 154 deploy-rollout\",\"raw 155 consumer-adapter\"]" +
            "}"
        _write_file(stat_path, report + "\n")
        println("hxc-pre-encoder: stat written to " + stat_path)
    }
    return enc_fail == 0
}

// ───────────────────── selftest ─────────────────────

fn _selftest() -> bool {
    println("hxc-pre-encoder: __SELFTEST__ start")
    let tmp = "/tmp/hxc_pre_encoder_selftest_" + to_string(_epoch_ms())
    _mkdir_p(tmp + "/raw")
    _mkdir_p(tmp + "/hxc")
    // Fixture 1: 3 small JSONL files with shared schema
    let f1 = tmp + "/raw/a.jsonl"
    let f2 = tmp + "/raw/b.jsonl"
    let f3 = tmp + "/raw/c.jsonl"
    _write_file(f1, "{\"id\":\"x1\",\"v\":1}\n{\"id\":\"x2\",\"v\":2}\n")
    _write_file(f2, "{\"id\":\"y1\",\"v\":10}\n{\"id\":\"y2\",\"v\":20}\n")
    _write_file(f3, "{\"id\":\"z1\",\"v\":100}\n{\"id\":\"z2\",\"v\":200}\n")
    let dict = tmp + "/dict.txt"
    let stat = tmp + "/stat.json"
    let r = _pipeline(tmp + "/raw", tmp + "/hxc", dict, stat)
    if r == false { println("hxc-pre-encoder: __SELFTEST__ FAIL pipeline"); return false }
    // Verify pre-encoded files have # schema: header
    let ok_h = _path_exists(tmp + "/hxc/a.hxc")
    if ok_h == false { println("hxc-pre-encoder: __SELFTEST__ FAIL no a.hxc"); return false }
    let head = to_string(exec("head -1 " + _shell_escape(tmp + "/hxc/a.hxc"))).trim()
    let has_schema = if len(head) >= 9 { head.substring(0, 9) == "# schema:" } else { false }
    if has_schema == false { println("hxc-pre-encoder: __SELFTEST__ FAIL no # schema header"); return false }
    println("hxc-pre-encoder: __SELFTEST__ PASS — pre-encoded 3 files + dict built + A19 sweep ran + raw 65+68 round-trip measured")
    println("__HXC_PRE_ENCODER_SELFTEST__ PASS")
    return true
}

// ───────────────────── CLI ─────────────────────

fn main() {
    let av = argv()
    let mut input_dir = ""
    let mut output_dir = ""
    let mut dict_path = ""
    let mut stat_path = ""
    let mut do_selftest = false
    let mut i = 1
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { do_selftest = true }
        else { if a == "--input-dir" { i = i + 1; if i < len(av) { input_dir = av[i] } }
        else { if a == "--output-dir" { i = i + 1; if i < len(av) { output_dir = av[i] } }
        else { if a == "--dict-path" { i = i + 1; if i < len(av) { dict_path = av[i] } }
        else { if a == "--stat" { i = i + 1; if i < len(av) { stat_path = av[i] } }
        }}}}
        i = i + 1
    }
    if do_selftest {
        if _selftest() { exit(0) } else { exit(2) }
    }
    if len(input_dir) == 0 || len(output_dir) == 0 {
        eprintln("usage: hexa hxc_pre_encoder.hexa --input-dir <raw-jsonl-root> --output-dir <hxc-root> [--dict-path <p>] [--stat <p>]")
        eprintln("       hexa hxc_pre_encoder.hexa --selftest")
        exit(4)
    }
    if len(dict_path) == 0 { dict_path = output_dir + "/_a19_shared.dict" }
    let r = _pipeline(input_dir, output_dir, dict_path, stat_path)
    if r { exit(0) } else { exit(3) }
}
