// tool/evolution_twin_drill_runner.hexa — Mk.X G3 twin-drill iter 75 verifier (#116).
//
// PURPOSE
//   CP2 G3 게이트: evolution_twin_drill iter 75 result.new_atom_count == 0
//   AND nexus_delta_1_1_witness_count >= 1.
//
//   anima ↔ nexus coupling: anima 측 iter 75 atom growth saturation +
//   nexus 측 delta_1_1 witness emission cross-reference.
//
//   spec: state/cp2_mk_x_evaluation_protocol_20260425.json §G3_twin_drill_protocol
//
// PASS predicate (raw#12 frozen):
//   anima_new_atom_count == 0 AND nexus_delta_1_1_witness_count >= 1
//
// USAGE
//   hexa run tool/evolution_twin_drill_runner.hexa --selftest
//   hexa run tool/evolution_twin_drill_runner.hexa mock --output <path>
//   hexa run tool/evolution_twin_drill_runner.hexa run \
//     --anima-iter75 <state/evolution_twin_drill_p4_iter75.json> \
//     --nexus-witness <shared/blowup/audit/delta_1_1_witnesses.jsonl> \
//     --output <state/cp2_g3_evidence.json>

let HELPER_PATH = "/tmp/evolution_twin_drill_runner_helper.hexa_tmp"
let SCHEMA = "anima/cp2_g3_twin_drill/1"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) { return ln.substring(prefix.len(), ln.len()) }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("import json, os, sys, datetime, argparse\n\n")
    parts.push("THRESHOLDS = {'anima_new_atom_max': 0, 'nexus_witness_min': 1, 'iter_target': 75}\n\n")
    parts.push("def evaluate_g3(anima_iter75, nexus_witnesses):\n")
    parts.push("    new_atoms = anima_iter75.get('new_atom_count')\n")
    parts.push("    iter_num = anima_iter75.get('iter')\n")
    parts.push("    witness_count = len(nexus_witnesses)\n")
    parts.push("    pass_anima = new_atoms is not None and int(new_atoms) <= THRESHOLDS['anima_new_atom_max']\n")
    parts.push("    pass_nexus = witness_count >= THRESHOLDS['nexus_witness_min']\n")
    parts.push("    pass_iter = iter_num == THRESHOLDS['iter_target']\n")
    parts.push("    overall = 'PASS' if (pass_anima and pass_nexus and pass_iter) else 'FAIL'\n")
    parts.push("    return {\n")
    parts.push("        'verdict': overall,\n")
    parts.push("        'pass_anima_atom_saturation': pass_anima,\n")
    parts.push("        'pass_nexus_witness_emission': pass_nexus,\n")
    parts.push("        'pass_iter_number': pass_iter,\n")
    parts.push("        'anima_new_atom_count': new_atoms,\n")
    parts.push("        'anima_iter_observed': iter_num,\n")
    parts.push("        'nexus_witness_count': witness_count\n")
    parts.push("    }\n\n")
    parts.push("def cmd_run(args):\n")
    parts.push("    anima = json.load(open(args.anima_iter75))\n")
    parts.push("    witnesses = []\n")
    parts.push("    if os.path.exists(args.nexus_witness):\n")
    parts.push("        with open(args.nexus_witness) as f:\n")
    parts.push("            for line in f:\n")
    parts.push("                line = line.strip()\n")
    parts.push("                if not line: continue\n")
    parts.push("                try: witnesses.append(json.loads(line))\n")
    parts.push("                except json.JSONDecodeError: pass\n")
    parts.push("    result = evaluate_g3(anima, witnesses)\n")
    parts.push("    ts = datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n")
    parts.push("    out = {\n")
    parts.push("        'schema': 'anima/cp2_g3_twin_drill/1',\n")
    parts.push("        'spec_doc': 'state/cp2_mk_x_evaluation_protocol_20260425.json',\n")
    parts.push("        'ts': ts, 'thresholds': THRESHOLDS, **result,\n")
    parts.push("        'anima_iter75_path': args.anima_iter75,\n")
    parts.push("        'nexus_witness_path': args.nexus_witness,\n")
    parts.push("        'raw10_honest': 'twin-drill = anima atom saturation + nexus witness emission 양 검증. 한 쪽만 PASS는 FAIL — 두 substrate 동시 증거 요구.'\n")
    parts.push("    }\n")
    parts.push("    with open(args.output, 'w') as f: json.dump(out, f, indent=2)\n")
    parts.push("    print(f'verdict={result[\"verdict\"]} new_atoms={result[\"anima_new_atom_count\"]} witnesses={result[\"nexus_witness_count\"]}')\n")
    parts.push("    print('DONE')\n\n")
    parts.push("def cmd_mock(args):\n")
    parts.push("    anima = {'iter': 75, 'new_atom_count': 0, 'note': 'mock saturated'}\n")
    parts.push("    witnesses = [{'witness_id': 'mock-w1', 'delta_1_1': True}, {'witness_id': 'mock-w2', 'delta_1_1': True}]\n")
    parts.push("    result = evaluate_g3(anima, witnesses)\n")
    parts.push("    ts = datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n")
    parts.push("    out = {\n")
    parts.push("        'schema': 'anima/cp2_g3_twin_drill/1', 'mode': 'mock', 'ts': ts,\n")
    parts.push("        'thresholds': THRESHOLDS, **result,\n")
    parts.push("        'raw10_honest': 'mock = synthetic anima saturated + 2 nexus witnesses → expect PASS verdict.'\n")
    parts.push("    }\n")
    parts.push("    with open(args.output, 'w') as f: json.dump(out, f, indent=2)\n")
    parts.push("    print(f'mock verdict={result[\"verdict\"]}')\n")
    parts.push("    print('DONE')\n\n")
    parts.push("def cmd_selftest():\n")
    parts.push("    pass_case = evaluate_g3({'iter': 75, 'new_atom_count': 0}, [{'w': 1}])\n")
    parts.push("    fail_anima = evaluate_g3({'iter': 75, 'new_atom_count': 3}, [{'w': 1}])\n")
    parts.push("    fail_nexus = evaluate_g3({'iter': 75, 'new_atom_count': 0}, [])\n")
    parts.push("    fail_iter = evaluate_g3({'iter': 50, 'new_atom_count': 0}, [{'w': 1}])\n")
    parts.push("    print('selftest=ok')\n")
    parts.push("    print(f'pass_case={pass_case[\"verdict\"]}')\n")
    parts.push("    print(f'fail_anima={fail_anima[\"verdict\"]}')\n")
    parts.push("    print(f'fail_nexus={fail_nexus[\"verdict\"]}')\n")
    parts.push("    print(f'fail_iter={fail_iter[\"verdict\"]}')\n")
    parts.push("    if pass_case['verdict'] != 'PASS' or fail_anima['verdict'] != 'FAIL' or fail_nexus['verdict'] != 'FAIL' or fail_iter['verdict'] != 'FAIL':\n")
    parts.push("        print('selftest_assertion=FAIL'); sys.exit(1)\n")
    parts.push("    print('DONE')\n\n")
    parts.push("def main():\n")
    parts.push("    p = argparse.ArgumentParser()\n")
    parts.push("    sub = p.add_subparsers(dest='cmd', required=True)\n")
    parts.push("    sub.add_parser('selftest')\n")
    parts.push("    m = sub.add_parser('mock'); m.add_argument('--output', required=True)\n")
    parts.push("    r = sub.add_parser('run')\n")
    parts.push("    r.add_argument('--anima-iter75', dest='anima_iter75', required=True)\n")
    parts.push("    r.add_argument('--nexus-witness', dest='nexus_witness', required=True)\n")
    parts.push("    r.add_argument('--output', required=True)\n")
    parts.push("    args = p.parse_args()\n")
    parts.push("    if args.cmd == 'selftest': cmd_selftest()\n")
    parts.push("    elif args.cmd == 'mock': cmd_mock(args)\n")
    parts.push("    else: cmd_run(args)\n\n")
    parts.push("if __name__ == '__main__': main()\n")
    write_file(HELPER_PATH, parts.join(""))
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) { if av[i] == "--selftest" { selftest = true; break }; i = i + 1 }
    _write_helper()
    if selftest {
        println("── evolution_twin_drill_runner selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("FAILED"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { exit(1) }
        println("selftest: OK")
        exit(0)
    }
    let mut a = ""; let mut j = 2
    while j < len(av) { a = a + " " + _sh_quote(av[j]); j = j + 1 }
    let r = _run_helper(a.trim())
    println(r[0])
    exit(r[1])
}
