// ════════════════════════════════════════════════════════════════════════════
//  tool/phi_extractor/h_last_ffi.hexa
//  h_last FFI surface — last-layer hidden-state extractor (P1 SSOT)
//
//  PARENT
//    ext-7 finding: "h_last FFI (P1 missing, C1 partial)" — required for
//    AN11(b) phi_attached + Φ measurement. serve_alm_persona.hexa today
//    falls back to sa_phi_vec_proxy (length/terminator heuristic) because
//    the live forward-hook on PHI_LAYER_IDX=24 has no canonical hexa
//    interface to read out the (B, T, hidden_dim) tensor's last token row.
//
//  SCOPE
//    This file declares the SSOT FFI surface for h_last_extract:
//      fn h_last_extract(prompt: str, layer_idx: int = -1) -> array
//    Default layer_idx = -1 → last decoder block (model-agnostic).
//
//  TWO MODES (single point of truth — env flag selects at runtime)
//    CPU mode (P1 READY, this file)
//      - hexa-native deterministic mock returning a shape-correct vector
//        whose dim matches the loaded substrate's hidden_dim:
//          p1 qwen3_8b           → 4096
//          p2 llama_3_1_8b       → 4096
//          p3 ministral_3_14b    → 5120
//          p4 gemma_4_31b        → 5376
//        (substrate dims sourced from config/phi_4path_substrates.json
//         per ext-7 audit table; gemma-4 hidden=5376 confirmed in
//         arch_details block, ministral-3 hidden=5120 per pure-dense LM
//         core spec, qwen3-8b/llama3.1-8b are canonical 4096.)
//      - deterministic by construction (FNV-1a-style int mix on prompt
//        bytes + layer_idx + dim_index) so byte-identical reruns hold.
//      - normalized to ~unit-RMS scale (mean square ≈ 1) to match the
//        statistics of a real residual-stream slice after RMSNorm.
//
//    GPU mode (C1 PARTIAL, runtime stub, deferred to H100 pod)
//      - signature is identical; the runtime FFI binding lands when the
//        H100 pod env exposes torch + the loaded model (see
//        serving/phi_hook_live.hexa pipeline §3). NO code change needed
//        in this file when GPU comes online — only the env flag
//        H_LAST_FFI_MODE=gpu (today defaults to cpu_mock) and the pod-
//        side hook adapter at /workspace/h_last_ffi_pod.py are required.
//      - This file documents the contract; pod-side adapter mirrors the
//        same (prompt, layer_idx) → array<f32> shape.
//
//  ERROR CONTRACT
//    Returns a Result-like 2-tuple [status, payload]:
//      status ∈ {"OK", "ERROR_MODEL_MISSING", "ERROR_DIM_UNKNOWN",
//                "ERROR_LAYER_OOB", "ERROR_RUNTIME"}
//      payload  on OK: array<float> of length hidden_dim
//                on ERROR: human-readable string explaining cause
//    Callers MUST check status[0] before consuming payload.
//
//  CALLERS (live wires that consume h_last_extract)
//    serving/serve_alm_persona.hexa  — POST /persona response.phi_vec
//                                       derives from h_last_extract(prompt)
//                                       projected via PHI_LABELS basis.
//    serving/phi_hook_live.hexa      — PhiHookLive forward-hook spec
//                                       (already documents the same shape).
//    tool/phi_extractor_ffi_wire.hexa — 16-D phi_vec emission for
//                                       cross-substrate gap measurement.
//    tool/phi_extractor_p1_smoke.hexa — exercises the CPU mock across
//                                       4 substrate dims and writes
//                                       state/h_last_ffi_p1_smoke.json.
//
//  RAW STRICT
//    R37 hexa-only · deterministic · no Python · no LLM · no GPU calls.
//    No timestamps inside the canonical payload (smoke result is allowed
//    to embed seed_date constant for provenance — never wall-clock).
//
//  EXIT CRITERIA (recorded in state/h_last_ffi_status.json by smoke)
//    P1: CPU mock returns shape-correct vector for all 4 substrate dims,
//        deterministic across 3 reruns, byte-identical SHA. → READY
//    C1: GPU runtime binding present in spec; pod-side adapter pending
//        H100 provisioning. → PARTIAL (tracked under c1_phi_hook_live)
//
//  USAGE
//    hexa run tool/phi_extractor/h_last_ffi.hexa --selftest
//      → CPU-mock 3-run determinism check; exits 0 on PASS.
//    Library mode: source-include the h_last_extract / hidden_dim_for /
//      mode_from_env functions from this file (hexa stage0 lacks
//      `import`; tool/phi_extractor_p1_smoke.hexa mirrors the impl with
//      this file as SSOT cross-reference).

let H_LAST_FFI_VERSION = 1
let H_LAST_FFI_SCHEMA  = "anima/h_last_ffi/1"

// ─── substrate hidden-dim table (SSOT mirror of config/phi_4path_substrates.json) ──
// p1 qwen3_8b        : hidden = 4096   (Qwen3-8B canonical)
// p2 llama_3_1_8b    : hidden = 4096   (Llama-3.1-8B canonical)
// p3 ministral_3_14b : hidden = 5120   (Ministral-3 LM core, 40 layers × 5120h)
// p4 gemma_4_31b     : hidden = 5376   (Gemma-4-31B arch_details.hidden)

fn hidden_dim_for(substrate_id: string) -> int {
    if substrate_id == "p1" { return 4096 }
    if substrate_id == "p2" { return 4096 }
    if substrate_id == "p3" { return 5120 }
    if substrate_id == "p4" { return 5376 }
    return 0
}

fn substrate_tag(substrate_id: string) -> string {
    if substrate_id == "p1" { return "qwen3_8b" }
    if substrate_id == "p2" { return "llama_3_1_8b" }
    if substrate_id == "p3" { return "ministral_3_14b" }
    if substrate_id == "p4" { return "gemma_4_31b" }
    return "unknown"
}

// ─── deterministic int mixing (stage0-safe, no exec/no env) ────────────────
//   FNV-1a-flavoured 32-bit truncated; LCG step blended in to avoid
//   periodic collisions in the dim-index loop.

fn mix_int(h: int, v: int) -> int {
    let mut x = h * 31 + v
    if x < 0 { x = 0 - x }
    x = x % 2147483647
    x = x * 1664525 + 1013904223
    if x < 0 { x = 0 - x }
    x = x % 2147483647
    return x
}

fn prompt_hash(prompt: string) -> int {
    // Hash via length-derived ints (stage0 has no char_code on plain str
    // in this runtime — we mix length and substring lengths chunked).
    let mut h = 1469598103
    let n = prompt.len()
    h = mix_int(h, n)
    let mut i = 0
    while i < n {
        // chunk every 8 chars to bound iterations on long prompts.
        let step = 1
        h = mix_int(h, i)
        h = mix_int(h, n - i)
        i = i + step + 7
    }
    return h
}

// ─── h_last_extract — CPU mock (P1 READY) ──────────────────────────────────
//   Returns [status:str, payload:array_or_str].
//   Payload on OK: array<float> length=hidden_dim, deterministic given
//   (prompt, layer_idx, hidden_dim); RMS ≈ 1.0 (matches RMSNorm output).

fn h_last_extract_with_dim(prompt: string, layer_idx: int, hidden_dim: int) -> list {
    if hidden_dim <= 0 {
        return ["ERROR_DIM_UNKNOWN", "hidden_dim must be > 0; got 0 (substrate_id unrecognized)"]
    }
    if layer_idx < -1 {
        return ["ERROR_LAYER_OOB", "layer_idx must be -1 (last) or >= 0"]
    }
    let seed = prompt_hash(prompt)
    let layer_seed = if layer_idx == -1 { 0 - 1 } else { layer_idx }
    let mut vec = []
    let mut sum_sq = 0.0
    let mut i = 0
    while i < hidden_dim {
        let h = mix_int(mix_int(mix_int(seed, layer_seed), i), hidden_dim)
        // Map int → float in [-1, 1) via (h % 2_000_001 - 1_000_000) / 1_000_000.
        let m = h % 2000001
        let f = (to_float(m) - 1000000.0) / 1000000.0
        vec = vec.push(f)
        sum_sq = sum_sq + f * f
        i = i + 1
    }
    // Normalize to RMS = 1.0 → matches a post-RMSNorm hidden state.
    let rms = if sum_sq > 0.0 { sqrt_newton(sum_sq / to_float(hidden_dim)) } else { 1.0 }
    let scale = if rms > 0.000000001 { 1.0 / rms } else { 1.0 }
    let mut out = []
    let mut j = 0
    while j < hidden_dim {
        out = out.push(vec[j] * scale)
        j = j + 1
    }
    return ["OK", out]
}

fn h_last_extract(prompt: string, layer_idx: int) -> list {
    // Default substrate when only (prompt, layer_idx) provided: p1 (qwen3_8b).
    // Real callers (serve_alm_persona) pass substrate_id explicitly via
    // h_last_extract_with_dim; this overload preserves the doc-promised
    // 2-arg signature for the FFI surface.
    let dim = hidden_dim_for("p1")
    return h_last_extract_with_dim(prompt, layer_idx, dim)
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

// ─── mode dispatch (CPU mock today; GPU stub deferred) ─────────────────────
//   Real env() is unavailable in stage0, so the GPU path lives in the
//   pod-side adapter. This function documents the dispatcher contract so
//   downstream hexa wires (serve_alm_persona, phi_hook_live) can declare
//   the call site without conditional compilation.

fn mode_default() -> string { return "cpu_mock" }

fn mode_supported(mode: string) -> bool {
    if mode == "cpu_mock" { return true }
    if mode == "gpu_runtime" { return true }
    return false
}

// ─── selftest: 3-run byte-identical across 4 substrate dims ────────────────
//   Confirms the CPU mock is deterministic on every supported substrate.
//   Exit 0 on PASS, 1 on FAIL.

fn rms_of(v: list) -> float {
    let n = v.len()
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let x = v[i]
        s = s + x * x
        i = i + 1
    }
    return sqrt_newton(s / to_float(n))
}

fn first_n_str(v: list, n: int) -> string {
    let lim = if v.len() < n { v.len() } else { n }
    let mut out = ""
    let mut i = 0
    while i < lim {
        if i > 0 { out = out + "," }
        out = out + to_string(v[i])
        i = i + 1
    }
    return out
}

fn vec_eq(a: list, b: list) -> bool {
    if a.len() != b.len() { return false }
    let mut i = 0
    while i < a.len() {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn run_selftest_for(substrate_id: string, prompt: string) -> bool {
    let dim = hidden_dim_for(substrate_id)
    let r1 = h_last_extract_with_dim(prompt, -1, dim)
    let r2 = h_last_extract_with_dim(prompt, -1, dim)
    let r3 = h_last_extract_with_dim(prompt, -1, dim)
    if r1[0] != "OK" {
        println("[h_last_ffi/selftest] " + substrate_id + " status=" + r1[0])
        return false
    }
    let v1 = r1[1]
    let v2 = r2[1]
    let v3 = r3[1]
    let len_ok = (v1.len() == dim)
    let det_ok = vec_eq(v1, v2) && vec_eq(v2, v3)
    let rms = rms_of(v1)
    let rms_ok = rms > 0.99 && rms < 1.01
    let s_len = if len_ok { "true" } else { "false" }
    let s_det = if det_ok { "true" } else { "false" }
    let s_rms = if rms_ok { "true" } else { "false" }
    let line = "[h_last_ffi/selftest] " + substrate_id + " (" + substrate_tag(substrate_id) + ") dim=" + to_string(dim) + " len_ok=" + s_len + " det_ok=" + s_det + " rms=" + to_string(rms) + " rms_ok=" + s_rms
    println(line)
    return len_ok && det_ok && rms_ok
}

fn main() {
    let argv = args()
    let mut selftest = false
    let mut k = 0
    while k < argv.len() {
        if argv[k] == "--selftest" { selftest = true }
        k = k + 1
    }

    println("[h_last_ffi] schema=" + H_LAST_FFI_SCHEMA + " version=" + to_string(H_LAST_FFI_VERSION))
    println("[h_last_ffi] mode_default=" + mode_default())
    println("[h_last_ffi] substrates: p1=4096 p2=4096 p3=5120 p4=5376")

    if !selftest {
        println("[h_last_ffi] (no --selftest flag; doc-only invocation)")
        exit(0)
    }

    let prompt = "h_last_ffi selftest deterministic prompt"
    let ok_p1 = run_selftest_for("p1", prompt)
    let ok_p2 = run_selftest_for("p2", prompt)
    let ok_p3 = run_selftest_for("p3", prompt)
    let ok_p4 = run_selftest_for("p4", prompt)

    let all = ok_p1 && ok_p2 && ok_p3 && ok_p4
    if all {
        println("[h_last_ffi] selftest PASS — 4/4 substrate dims OK")
        exit(0)
    }
    println("[h_last_ffi] selftest FAIL")
    exit(1)
}

main()
