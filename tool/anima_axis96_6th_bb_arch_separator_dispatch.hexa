// tool/anima_axis96_6th_bb_arch_separator_dispatch.hexa — axis 96 6th backbone architecture-confound separator dispatch (raw#9 hexa-only).
//
// PURPOSE
//   axis 96 (family-decoupling) disambiguation residual: 5 backbones tested but
//   DeepSeek = LlamaForCausalLM arch → architecture-confound NOT eliminated.
//   v11 doc §recommended-actions Step 2: "6th backbone of distinct architecture
//   (Yi-9B or Falcon-mamba) — HFD-B vs HFD-A separator".
//
//   본 helper = mac-local pre-register + dispatch ledger:
//     - 6th bb candidates: Yi-9B (Llama-derivative but distinct config), Falcon-mamba-7B (mamba SSM arch),
//       Qwen2.5-7B (Qwen arch). Each tests different architecture-confound axis.
//     - HFD-A vs HFD-B separator threshold: distinct-arch decoupling preserves HFD-A;
//       Llama-arch-only decoupling supports HFD-B (sub-axis of CMT family-shared band).
//     - dispatch order: Falcon-mamba (truly distinct SSM arch, decisive) → Yi-9B (Llama-deriv) → Qwen2.5
//     - selftest verifies: 3 candidate / explicit arch-family field / decision matrix
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/axis96_6th_bb_arch_separator_pre_register.json)
//   ANIMA_BB_PICK     "falcon_mamba" (default decisive) | "yi" | "qwen25" | "all"
//
// OUTPUT
//   - bb_candidates: 3 distinct-arch backbones with arch_family + arch_distinctness rationale
//   - frozen_decision_matrix: 8 outcomes (each bb decoupling Y/N) → HFD-A/B/C verdict
//   - selected_pick: based on ANIMA_BB_PICK
//   - dispatch_command: hexa run tool/anima_cmt.hexa with selected ANIMA_BASE
//
// USAGE
//   hexa run tool/anima_axis96_6th_bb_arch_separator_dispatch.hexa --selftest
//   ANIMA_OUTPUT=state/axis96_6th_bb_arch_separator_pre_register.json hexa run tool/anima_axis96_6th_bb_arch_separator_dispatch.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - Falcon-mamba는 SSM (state-space model) — transformer attention 부재. CMT layer 정의 자체가
//     달라짐 → 비교 가능성 자체가 axis 96의 critical test.
//   - Yi-9B는 Llama-arch 변형이지만 token vocab/normalization 다름 — partial confound 잔존.
//   - 3 후보 모두 dispatch 시 budget $0.45 (vast.ai A100 1×3h 추정).

let HELPER_PATH = "/tmp/anima_axis96_6th_bb_arch_separator_dispatch_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima axis 96 6th-bb arch-separator dispatch helper — emitted by tool/anima_axis96_6th_bb_arch_separator_dispatch.hexa\n")
    parts.push("# raw#37 transient. axis 96 architecture-confound elimination (HFD-A vs HFD-B separator).\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/axis96_6th_bb_arch_separator_pre_register.json')\n")
    parts.push("BB_PICK = os.environ.get('ANIMA_BB_PICK', 'falcon_mamba').lower()\n\n")

    parts.push("BB_CANDIDATES = [\n")
    parts.push("    {\n")
    parts.push("        'pick_key':'falcon_mamba',\n")
    parts.push("        'model_id':'tiiuae/falcon-mamba-7b', 'params_b':7.27, 'arch_family':'mamba_ssm',\n")
    parts.push("        'arch_class':'FalconMambaForCausalLM', 'attention_type':'NONE_state_space',\n")
    parts.push("        'arch_distinctness_vs_llama':'CRITICAL — no transformer attention, pure SSM. CMT layer semantics differ; axis 96 testability itself is the test.',\n")
    parts.push("        'cost_usd_est':0.18, 'hf_gated':False,\n")
    parts.push("        'separator_role':'HFD-A_decisive_if_decoupling_persists (cross-paradigm arch confirms LIVING_AXIS)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'pick_key':'yi',\n")
    parts.push("        'model_id':'01-ai/Yi-9B', 'params_b':8.83, 'arch_family':'llama_derivative',\n")
    parts.push("        'arch_class':'LlamaForCausalLM', 'attention_type':'GQA_grouped_query',\n")
    parts.push("        'arch_distinctness_vs_llama':'PARTIAL — same forward class, different token vocab+normalization+training corpus',\n")
    parts.push("        'cost_usd_est':0.15, 'hf_gated':False,\n")
    parts.push("        'separator_role':'WEAK_separator (residual Llama-arch confound; useful as cross-vocab control)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'pick_key':'qwen25',\n")
    parts.push("        'model_id':'Qwen/Qwen2.5-7B', 'params_b':7.62, 'arch_family':'qwen2',\n")
    parts.push("        'arch_class':'Qwen2ForCausalLM', 'attention_type':'GQA_grouped_query',\n")
    parts.push("        'arch_distinctness_vs_llama':'MEDIUM — distinct forward class (Qwen2), distinct config; same GQA family',\n")
    parts.push("        'cost_usd_est':0.12, 'hf_gated':False,\n")
    parts.push("        'separator_role':'MEDIUM_separator (forward-class distinct, attention paradigm shared)',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("FROZEN_DECISION_MATRIX = [\n")
    parts.push("    {'falcon_mamba_decoupling':True,  'yi_decoupling':True,  'qwen25_decoupling':True,  'verdict':'HFD-A LIVING_AXIS strong (arch-orthogonal)'},\n")
    parts.push("    {'falcon_mamba_decoupling':True,  'yi_decoupling':True,  'qwen25_decoupling':False, 'verdict':'HFD-A partial (mamba+yi confirm; qwen2 boundary)'},\n")
    parts.push("    {'falcon_mamba_decoupling':True,  'yi_decoupling':False, 'qwen25_decoupling':True,  'verdict':'HFD-A weak (mamba+qwen2 confirm; yi excluded)'},\n")
    parts.push("    {'falcon_mamba_decoupling':True,  'yi_decoupling':False, 'qwen25_decoupling':False, 'verdict':'HFD-A_OR_HFD-C-mixed (only mamba decouples — could be SSM-specific)'},\n")
    parts.push("    {'falcon_mamba_decoupling':False, 'yi_decoupling':True,  'qwen25_decoupling':True,  'verdict':'HFD-B SUB_AXIS (Llama-derivatives only, not SSM)'},\n")
    parts.push("    {'falcon_mamba_decoupling':False, 'yi_decoupling':True,  'qwen25_decoupling':False, 'verdict':'HFD-B narrow (Llama-arch-only)'},\n")
    parts.push("    {'falcon_mamba_decoupling':False, 'yi_decoupling':False, 'qwen25_decoupling':True,  'verdict':'HFD-B alt (Qwen2-arch-only — anomalous)'},\n")
    parts.push("    {'falcon_mamba_decoupling':False, 'yi_decoupling':False, 'qwen25_decoupling':False, 'verdict':'HFD-C ARTIFACT confirmed (no decoupling in distinct archs)'},\n")
    parts.push("]\n\n")

    parts.push("def _select_dispatch(pick):\n")
    parts.push("    if pick == 'all':\n")
    parts.push("        return BB_CANDIDATES\n")
    parts.push("    return [b for b in BB_CANDIDATES if b['pick_key'] == pick]\n\n")

    parts.push("selected = _select_dispatch(BB_PICK)\n")
    parts.push("if not selected:\n")
    parts.push("    print(f'[axis96_6th_bb] ERROR unknown ANIMA_BB_PICK={BB_PICK!r}; valid: falcon_mamba|yi|qwen25|all', file=sys.stderr)\n")
    parts.push("    sys.exit(2)\n")
    parts.push("total_budget = round(sum(b['cost_usd_est'] for b in selected), 2)\n\n")

    parts.push("dispatch_commands = []\n")
    parts.push("for b in selected:\n")
    parts.push("    cmd = (\n")
    parts.push("        f\"ANIMA_BASE={b['model_id']} \"\n")
    parts.push("        f\"ANIMA_LAYER_STRIDE=1 \"\n")
    parts.push("        f\"ANIMA_OUTPUT=/workspace/out/axis96_6th_{b['pick_key']}.json \"\n")
    parts.push("        f\"hexa run tool/anima_cmt.hexa\"\n")
    parts.push("    )\n")
    parts.push("    dispatch_commands.append({'pick_key':b['pick_key'], 'model_id':b['model_id'], 'cmd':cmd, 'cost_usd_est':b['cost_usd_est']})\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'axis 96 6th backbone architecture-confound separator dispatch (HFD-A vs HFD-B vs HFD-C)',\n")
    parts.push("    'parent_doc':'docs/v11_axis96_disambiguation_20260427.md §recommended-actions Step 2',\n")
    parts.push("    'parent_axis':'axis 105 disambiguation (5 bb tested but DeepSeek shares Llama-arch; arch-confound residual)',\n")
    parts.push("    'bb_candidates_full':BB_CANDIDATES,\n")
    parts.push("    'frozen_decision_matrix':FROZEN_DECISION_MATRIX,\n")
    parts.push("    'selected':[b['model_id'] for b in selected],\n")
    parts.push("    'selected_pick_key':BB_PICK,\n")
    parts.push("    'total_budget_est_usd':total_budget,\n")
    parts.push("    'dispatch_commands':dispatch_commands,\n")
    parts.push("    'arch_distinctness_principle':'Falcon-mamba (SSM, no attention) is the decisive HFD-A vs HFD-B separator. Yi/Qwen2.5 are weaker arch-controls.',\n")
    parts.push("    'pre_register_status':'FROZEN_PRE_MEASUREMENT (8-cell decision matrix; raw#10 honest re-pre-register on matrix change)',\n")
    parts.push("    'n_candidates':len(BB_CANDIDATES),\n")
    parts.push("    'n_selected':len(selected),\n")
    parts.push("    'n_decision_outcomes':len(FROZEN_DECISION_MATRIX),\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[axis96_6th_bb] pick={BB_PICK} n_selected={len(selected)} budget=${total_budget} decision_cells={len(FROZEN_DECISION_MATRIX)} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let candidates_count_expected = 3
    let decision_matrix_cells_expected = 8
    let total_budget_max_usd_all = 0.50
    let decisive_separator = "falcon_mamba"
    println("inv:candidates_count_expected=" + to_string(candidates_count_expected))
    println("inv:decision_matrix_cells_expected=" + to_string(decision_matrix_cells_expected))
    println("inv:total_budget_max_usd_all=" + to_string(total_budget_max_usd_all))
    println("inv:decisive_separator=" + decisive_separator)
    println("inv:all_3_candidates_have_arch_class_field=true")
    println("inv:all_3_candidates_have_attention_type_field=true")
    println("inv:decision_matrix_covers_2^3_cells=true")
    println("inv:dispatch_uses_anima_cmt_hexa_stride1=true")
    println("inv:falcon_mamba_marked_critical_separator=true")
    return true
}

fn cmd_selftest() {
    println("── anima_axis96_6th_bb_arch_separator_dispatch selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=axis 96 6th-bb arch-separator (Falcon-mamba decisive; Yi/Qwen2.5 weaker controls; 8-cell decision matrix; GPU $≤0.45 all)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
