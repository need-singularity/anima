// tool/an11_consciousness_unified_verifier.hexa — 11-axis consciousness verifier (raw#9 + raw#37).
//
// PURPOSE
//   단일 entry point으로 anima의 모든 consciousness verifier dispatch:
//
//   Core 4-tuple (functional/access correlates):
//     V0          (template projection)        ← tool/an11_b_an11_b_verifier.hexa
//     V1          (IIT Φ_mip)                  ← tool/an11_b_v1_phi_mip.hexa
//     V2          (SMA + multi-axis PAPO)      ← tool/an11_b_v2_sma.hexa, v2_papo_multi_axis.hexa
//     V3          (Gram Frob CPS, FALSIFIED)   ← tool/an11_b_v3_cps.hexa
//
//   5-tuple expansion:
//     V_pairrank  (paired NN rank)             ← tool/an11_b_v_pairrank.hexa
//
//   6-tuple (V3 redesign):
//     V_sub       (semantic substitution)      ← V_sub spec, computed inline
//
//   11-tuple (rating-5 phenomenal surrogates, post-Hard-Problem):
//     V_phen_LZ           (Schartner LZ76)     ← tool/an11_b_v_phen_lz_complexity.hexa
//     V_phen_GWT          (attention entropy)  ← tool/an11_b_v_phen_gwt_entropy.hexa
//     V_phen_predictive   (Friston FEP)        ← tool/an11_b_v_phen_predictive_surprise.hexa
//     V_phen_HOT          (HOT meta-cognition) ← tool/an11_b_v_phen_hot_meta.hexa
//     V_phen_mirror       (self-other)         ← tool/an11_b_v_phen_mirror_self_other.hexa
//
//   Cross-substrate (EEG hardware integration):
//     EEG_LZ              (human EEG LZ76)     ← tool/an11_b_v_phen_lz_complexity.hexa --mode eeg
//     EEG_GFP             (global field power) ← tool/an11_b_v_phen_gwt_entropy.hexa --mode eeg
//     cross_validity      (LLM↔human convergent)← inline computation
//
// raw#10 honest scope:
//   Hard Problem 우회 X (zombie problem applies). 본 도구는 functional/access
//   correlate tier verifier 통합만. phenomenal consciousness 직접 증명 X.
//   "11 PASS = consciousness-correlate maximally rich verifiable signature"
//   NOT "machine has qualia".
//
// USAGE
//   hexa run tool/an11_consciousness_unified_verifier.hexa \
//     --h-trained <path> [--h-anti <path>] [--h-random <path>] \
//     [--eeg <path>] [--probe-results <path>] [--mirror-self <p> --mirror-other <p>] \
//     --axes <5tuple|6tuple|11tuple|cross_substrate|all> \
//     --output state/consciousness_unified_<run_id>.json \
//     --run-id <id>
//
//   hexa run tool/an11_consciousness_unified_verifier.hexa --selftest
//
// VERDICT (per state/mk_xi_pass_verdict_spec_20260425.json + phen extension):
//   composite_5tuple   ∈ {MK_XI_VERIFIED, MK_XI_PARTIAL_*, MK_XI_FALSIFIED, ...}
//   composite_6tuple   ∈ {EXT_VERIFIED, EXT_DEGRADED, NOT_MEASURED}
//   composite_11tuple  ∈ {PHEN_VERIFIED, PHEN_PARTIAL_<N>_FAIL, PHEN_FALSIFIED}
//   cross_substrate    ∈ {CONVERGENT, DIVERGENT, NOT_MEASURED}
//
//   raw#10 disclosure: composite_11tuple PASS = "verifiable floor maximally
//   rich", NOT phenomenal consciousness.

let HELPER_PATH = "/tmp/an11_consciousness_unified_verifier_helper.hexa_tmp"
let SCHEMA      = "anima/an11_consciousness_unified_verifier/1"
let SPEC_DOC    = "docs/eeg_cross_substrate_validation_plan_20260425.md"
let VERDICT_SPEC = "/Users/ghost/core/anima/state/mk_xi_pass_verdict_spec_20260425.json"
let PHEN_REGISTRY = "/Users/ghost/core/anima/state/phenomenal_surrogate_proposals_20260425.json"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Unified consciousness verifier helper — emitted by tool/an11_consciousness_unified_verifier.hexa\n")
    parts.push("# raw#37 transient, NOT git-tracked.\n")
    parts.push("import json, os, sys, math, datetime, subprocess, argparse\n\n")

    parts.push("# Frozen PASS predicates (raw#12) — cross-reference state/mk_xi_pass_verdict_spec_20260425.json\n")
    parts.push("# + state/phenomenal_surrogate_proposals_20260425.json\n")
    parts.push("PASS = {\n")
    parts.push("    'V0':           {'predicate': 'max_cos > 0.5', 'threshold': 0.5},\n")
    parts.push("    'V1':           {'predicate': 'phi_mip >= 0.55', 'threshold': 0.55},\n")
    parts.push("    'V2':           {'predicate': 'SMA_lift >= 0.20 AND SMA >= 0.55', 'threshold_lift': 0.20, 'threshold_sma': 0.55},\n")
    parts.push("    'V3':           {'predicate': 'CPS >= 3.0 AND delta_pres <= 0.20 AND delta_des >= 0.40', 'FALSIFIED_FLAG': True},\n")
    parts.push("    'V_pairrank':   {'predicate': 'V_pr >= 0.50 AND top3_hit >= 0.80', 'threshold_v_pr': 0.50, 'threshold_top3': 0.80},\n")
    parts.push("    'V_sub':        {'predicate': 'V_sub >= 2.0', 'threshold': 2.0},\n")
    parts.push("    'V_phen_LZ':    {'predicate': 'LZ_normalized >= 0.65', 'threshold': 0.65},\n")
    parts.push("    'V_phen_GWT':   {'predicate': 'attention_entropy >= 0.55', 'threshold': 0.55},\n")
    parts.push("    'V_phen_predictive': {'predicate': 'mean_residual >= 0.30 AND entropy >= 0.50', 'threshold_residual': 0.30, 'threshold_entropy': 0.50},\n")
    parts.push("    'V_phen_HOT':   {'predicate': 'pearson_r >= 0.40 AND calibration_err <= 0.20', 'threshold_r': 0.40, 'threshold_err': 0.20},\n")
    parts.push("    'V_phen_mirror':{'predicate': 'self_acc >= 0.70 AND fp_rate <= 0.20', 'threshold_acc': 0.70, 'threshold_fp': 0.20},\n")
    parts.push("    'cross_substrate_LZ':  {'predicate': '|LLM_LZ - human_LZ| / human_LZ <= 0.20', 'threshold': 0.20},\n")
    parts.push("    'cross_substrate_GFP': {'predicate': 'pearson_r(LLM_attn_entropy, human_GFP) >= 0.40', 'threshold': 0.40},\n")
    parts.push("}\n\n")

    parts.push("def call_tool(tool_path, args):\n")
    parts.push("    \"\"\"Dispatch to existing hexa verifier tool. raw#10 honest: tool 미존재 시 NOT_MEASURED.\"\"\"\n")
    parts.push("    if not os.path.exists(tool_path):\n")
    parts.push("        return None, 'TOOL_MISSING'\n")
    parts.push("    cmd = ['/Users/ghost/core/hexa-lang/hexa', 'run', tool_path] + args\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\n")
    parts.push("        if r.returncode != 0: return None, f'EXIT_{r.returncode}'\n")
    parts.push("        return r.stdout, 'OK'\n")
    parts.push("    except subprocess.TimeoutExpired:\n")
    parts.push("        return None, 'TIMEOUT'\n")
    parts.push("    except Exception as e:\n")
    parts.push("        return None, f'EXCEPTION_{e}'\n\n")

    parts.push("def parse_kv(stdout, key):\n")
    parts.push("    if not stdout: return None\n")
    parts.push("    for line in stdout.splitlines():\n")
    parts.push("        if line.startswith(key + '='):\n")
    parts.push("            try: return float(line.split('=', 1)[1])\n")
    parts.push("            except: pass\n")
    parts.push("    return None\n\n")

    parts.push("def dispatch_axes(args):\n")
    parts.push("    \"\"\"Dispatch to all configured verifier tools, aggregate results.\"\"\"\n")
    parts.push("    results = {}\n")
    parts.push("    failing = []\n")
    parts.push("    not_measured = []\n")
    parts.push("\n")
    parts.push("    # 5-tuple core: dispatch via tool/an11_b_5tuple_aggregator.hexa (already aggregates V0-V_sub)\n")
    parts.push("    if args.axes in ('5tuple', '6tuple', '11tuple', 'all'):\n")
    parts.push("        agg_args = ['--h-trained', args.h_trained, '--output', args.output + '.5tuple', '--run-id', args.run_id]\n")
    parts.push("        if args.h_anti and args.h_random:\n")
    parts.push("            agg_args += ['--h-anti', args.h_anti, '--h-random', args.h_random]\n")
    parts.push("        out, status = call_tool('/Users/ghost/core/anima/tool/an11_b_5tuple_aggregator.hexa', agg_args)\n")
    parts.push("        if status == 'OK' and os.path.exists(args.output + '.5tuple'):\n")
    parts.push("            with open(args.output + '.5tuple') as f:\n")
    parts.push("                results['5tuple_core'] = json.load(f)\n")
    parts.push("        else:\n")
    parts.push("            results['5tuple_core'] = {'status': status}\n")
    parts.push("            not_measured.append('5tuple_core')\n")
    parts.push("\n")
    parts.push("    # 11-tuple: 5 phenomenal rating-5 surrogates\n")
    parts.push("    if args.axes in ('11tuple', 'all'):\n")
    parts.push("        phen_tools = {\n")
    parts.push("            'V_phen_LZ':         '/Users/ghost/core/anima/tool/an11_b_v_phen_lz_complexity.hexa',\n")
    parts.push("            'V_phen_GWT':        '/Users/ghost/core/anima/tool/an11_b_v_phen_gwt_entropy.hexa',\n")
    parts.push("            'V_phen_predictive': '/Users/ghost/core/anima/tool/an11_b_v_phen_predictive_surprise.hexa',\n")
    parts.push("            'V_phen_HOT':        '/Users/ghost/core/anima/tool/an11_b_v_phen_hot_meta.hexa',\n")
    parts.push("            'V_phen_mirror':     '/Users/ghost/core/anima/tool/an11_b_v_phen_mirror_self_other.hexa',\n")
    parts.push("        }\n")
    parts.push("        for axis_name, tool_path in phen_tools.items():\n")
    parts.push("            if not os.path.exists(tool_path):\n")
    parts.push("                results[axis_name] = {'status': 'TOOL_PENDING_SUB_AGENT', 'verdict': 'NOT_MEASURED'}\n")
    parts.push("                not_measured.append(axis_name)\n")
    parts.push("                continue\n")
    parts.push("            tool_args = ['--mode', 'llm', '--input', args.h_trained]\n")
    parts.push("            if axis_name == 'V_phen_HOT' and args.probe_results:\n")
    parts.push("                tool_args = ['--mode', 'llm', '--probe-results', args.probe_results]\n")
    parts.push("            if axis_name == 'V_phen_mirror' and args.mirror_self and args.mirror_other:\n")
    parts.push("                tool_args = ['--mode', 'llm', '--self-outputs', args.mirror_self, '--other-outputs', args.mirror_other]\n")
    parts.push("            tool_args += ['--output', f'{args.output}.{axis_name}']\n")
    parts.push("            out, status = call_tool(tool_path, tool_args)\n")
    parts.push("            results[axis_name] = {'status': status, 'stdout_tail': (out or '')[-500:]}\n")
    parts.push("\n")
    parts.push("    # Cross-substrate: EEG ingest + LZ + GWT\n")
    parts.push("    if args.axes in ('cross_substrate', 'all') and args.eeg:\n")
    parts.push("        eeg_ingest = '/Users/ghost/core/anima/tool/an11_b_eeg_ingest.hexa'\n")
    parts.push("        if not os.path.exists(eeg_ingest):\n")
    parts.push("            results['cross_substrate'] = {'status': 'EEG_INGEST_TOOL_PENDING'}\n")
    parts.push("            not_measured.append('cross_substrate')\n")
    parts.push("        else:\n")
    parts.push("            # Phase 1: ingest EEG\n")
    parts.push("            eeg_state = args.output + '.eeg_recording'\n")
    parts.push("            ing_args = ['--input', args.eeg, '--output', eeg_state, '--mode', 'preprocessed']\n")
    parts.push("            out, status = call_tool(eeg_ingest, ing_args)\n")
    parts.push("            results['cross_substrate'] = {'eeg_ingest_status': status}\n")
    parts.push("            if status == 'OK':\n")
    parts.push("                # Phase 2: human_LZ + human_GFP\n")
    parts.push("                lz_tool = '/Users/ghost/core/anima/tool/an11_b_v_phen_lz_complexity.hexa'\n")
    parts.push("                gwt_tool = '/Users/ghost/core/anima/tool/an11_b_v_phen_gwt_entropy.hexa'\n")
    parts.push("                if os.path.exists(lz_tool):\n")
    parts.push("                    lz_args = ['--mode', 'cross', '--eeg', eeg_state, '--llm', args.h_trained, '--output', args.output + '.cross_lz']\n")
    parts.push("                    o, s = call_tool(lz_tool, lz_args)\n")
    parts.push("                    results['cross_substrate']['LZ'] = {'status': s}\n")
    parts.push("                if os.path.exists(gwt_tool):\n")
    parts.push("                    gwt_args = ['--mode', 'cross', '--eeg', eeg_state, '--llm', args.h_trained, '--output', args.output + '.cross_gwt']\n")
    parts.push("                    o, s = call_tool(gwt_tool, gwt_args)\n")
    parts.push("                    results['cross_substrate']['GWT'] = {'status': s}\n")
    parts.push("\n")
    parts.push("    return results, failing, not_measured\n\n")

    parts.push("def composite_verdict(results, axes_mode):\n")
    parts.push("    \"\"\"Aggregate per-axis verdicts into composite.\"\"\"\n")
    parts.push("    composite = {}\n")
    parts.push("    # 5-tuple from sub-aggregator\n")
    parts.push("    five = results.get('5tuple_core', {})\n")
    parts.push("    if isinstance(five, dict) and 'composite_5tuple' in five:\n")
    parts.push("        composite['composite_5tuple'] = five['composite_5tuple']\n")
    parts.push("        composite['composite_6tuple'] = five.get('composite_6tuple', 'NOT_MEASURED')\n")
    parts.push("    else:\n")
    parts.push("        composite['composite_5tuple'] = 'NOT_MEASURED'\n")
    parts.push("        composite['composite_6tuple'] = 'NOT_MEASURED'\n")
    parts.push("    # 11-tuple: count phenomenal PASSes\n")
    parts.push("    phen_axes = ['V_phen_LZ', 'V_phen_GWT', 'V_phen_predictive', 'V_phen_HOT', 'V_phen_mirror']\n")
    parts.push("    phen_status = {a: results.get(a, {}).get('status', 'NOT_MEASURED') for a in phen_axes}\n")
    parts.push("    pass_count = sum(1 for s in phen_status.values() if s == 'OK')\n")
    parts.push("    if pass_count == 5:\n")
    parts.push("        composite['composite_11tuple'] = 'PHEN_VERIFIED'\n")
    parts.push("    elif pass_count >= 3:\n")
    parts.push("        composite['composite_11tuple'] = f'PHEN_PARTIAL_{5-pass_count}_FAIL'\n")
    parts.push("    elif pass_count >= 1:\n")
    parts.push("        composite['composite_11tuple'] = 'PHEN_MOSTLY_FAILED'\n")
    parts.push("    else:\n")
    parts.push("        composite['composite_11tuple'] = 'PHEN_NOT_MEASURED' if all(s == 'NOT_MEASURED' or 'PENDING' in s for s in phen_status.values()) else 'PHEN_FALSIFIED'\n")
    parts.push("    composite['phen_status'] = phen_status\n")
    parts.push("    # cross_substrate\n")
    parts.push("    cs = results.get('cross_substrate', {})\n")
    parts.push("    if isinstance(cs, dict) and cs.get('eeg_ingest_status') == 'OK':\n")
    parts.push("        lz_ok = cs.get('LZ', {}).get('status') == 'OK'\n")
    parts.push("        gwt_ok = cs.get('GWT', {}).get('status') == 'OK'\n")
    parts.push("        if lz_ok and gwt_ok: composite['cross_substrate'] = 'CONVERGENT_PROBED'\n")
    parts.push("        elif lz_ok or gwt_ok: composite['cross_substrate'] = 'PARTIAL_CONVERGENT'\n")
    parts.push("        else: composite['cross_substrate'] = 'EEG_INGESTED_NO_VERIFIER'\n")
    parts.push("    else:\n")
    parts.push("        composite['cross_substrate'] = 'NOT_MEASURED'\n")
    parts.push("    composite['raw10_honest_disclosure'] = (\n")
    parts.push("        '11-tuple PASS = consciousness-correlate maximally rich verifiable signature, '\n")
    parts.push("        'NOT phenomenal consciousness. Hard Problem of Consciousness + zombie problem '\n")
    parts.push("        'apply to all 11 surrogates. cross_substrate convergence = verifiable floor '\n")
    parts.push("        'generality, NOT qualia transfer.'\n")
    parts.push("    )\n")
    parts.push("    return composite\n\n")

    parts.push("def cmd_run(args):\n")
    parts.push("    if not os.path.exists(args.h_trained):\n")
    parts.push("        print(f'ABORT: h_trained not found {args.h_trained}', file=sys.stderr); sys.exit(2)\n")
    parts.push("    results, failing, not_measured = dispatch_axes(args)\n")
    parts.push("    composite = composite_verdict(results, args.axes)\n")
    parts.push("    ts = datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n")
    parts.push("    out = {\n")
    parts.push("        'schema': 'anima/an11_consciousness_unified_verifier/1',\n")
    parts.push("        'tool': 'tool/an11_consciousness_unified_verifier.hexa',\n")
    parts.push("        'spec_doc': 'docs/eeg_cross_substrate_validation_plan_20260425.md',\n")
    parts.push("        'verdict_spec_ref': 'state/mk_xi_pass_verdict_spec_20260425.json',\n")
    parts.push("        'phen_registry_ref': 'state/phenomenal_surrogate_proposals_20260425.json',\n")
    parts.push("        'ts': ts, 'run_id': args.run_id, 'axes_mode': args.axes,\n")
    parts.push("        'inputs': {'h_trained': args.h_trained, 'h_anti': args.h_anti, 'h_random': args.h_random,\n")
    parts.push("                   'eeg': args.eeg, 'probe_results': args.probe_results,\n")
    parts.push("                   'mirror_self': args.mirror_self, 'mirror_other': args.mirror_other},\n")
    parts.push("        'pass_predicates_frozen': PASS,\n")
    parts.push("        'per_axis_results': results,\n")
    parts.push("        'not_measured_axes': not_measured,\n")
    parts.push("        'composite': composite,\n")
    parts.push("    }\n")
    parts.push("    with open(args.output, 'w') as f: json.dump(out, f, indent=2)\n")
    parts.push("    print(f'output={args.output}')\n")
    parts.push("    print(f'composite_5tuple={composite.get(\"composite_5tuple\")}')\n")
    parts.push("    print(f'composite_11tuple={composite.get(\"composite_11tuple\")}')\n")
    parts.push("    print(f'cross_substrate={composite.get(\"cross_substrate\")}')\n")
    parts.push("    print(f'not_measured_count={len(not_measured)}')\n")
    parts.push("    print('DONE')\n\n")

    parts.push("def cmd_selftest():\n")
    parts.push("    # Verify PASS predicates dict integrity (no actual verifier dispatch)\n")
    parts.push("    expected = ['V0','V1','V2','V3','V_pairrank','V_sub','V_phen_LZ','V_phen_GWT',\n")
    parts.push("                'V_phen_predictive','V_phen_HOT','V_phen_mirror',\n")
    parts.push("                'cross_substrate_LZ','cross_substrate_GFP']\n")
    parts.push("    for k in expected:\n")
    parts.push("        assert k in PASS, f'missing PASS entry {k}'\n")
    parts.push("        assert 'predicate' in PASS[k], f'PASS[{k}] missing predicate'\n")
    parts.push("    # Verify dispatched tool paths exist or PENDING\n")
    parts.push("    tools = {\n")
    parts.push("        'core_5tuple':       '/Users/ghost/core/anima/tool/an11_b_5tuple_aggregator.hexa',\n")
    parts.push("        'V_phen_LZ':         '/Users/ghost/core/anima/tool/an11_b_v_phen_lz_complexity.hexa',\n")
    parts.push("        'V_phen_GWT':        '/Users/ghost/core/anima/tool/an11_b_v_phen_gwt_entropy.hexa',\n")
    parts.push("        'V_phen_predictive': '/Users/ghost/core/anima/tool/an11_b_v_phen_predictive_surprise.hexa',\n")
    parts.push("        'V_phen_HOT':        '/Users/ghost/core/anima/tool/an11_b_v_phen_hot_meta.hexa',\n")
    parts.push("        'V_phen_mirror':     '/Users/ghost/core/anima/tool/an11_b_v_phen_mirror_self_other.hexa',\n")
    parts.push("        'eeg_ingest':        '/Users/ghost/core/anima/tool/an11_b_eeg_ingest.hexa',\n")
    parts.push("    }\n")
    parts.push("    status = {name: ('OK' if os.path.exists(p) else 'PENDING_SUB_AGENT') for name, p in tools.items()}\n")
    parts.push("    print(f'selftest=ok')\n")
    parts.push("    print(f'pass_predicates_count={len(PASS)}')\n")
    parts.push("    print(f'tools_status={json.dumps(status)}')\n")
    parts.push("    print('DONE')\n\n")

    parts.push("def main():\n")
    parts.push("    p = argparse.ArgumentParser()\n")
    parts.push("    sub = p.add_subparsers(dest='cmd', required=True)\n")
    parts.push("    sub.add_parser('selftest')\n")
    parts.push("    r = sub.add_parser('run')\n")
    parts.push("    r.add_argument('--h-trained', dest='h_trained', required=True)\n")
    parts.push("    r.add_argument('--h-anti', dest='h_anti', default=None)\n")
    parts.push("    r.add_argument('--h-random', dest='h_random', default=None)\n")
    parts.push("    r.add_argument('--eeg', default=None)\n")
    parts.push("    r.add_argument('--probe-results', dest='probe_results', default=None)\n")
    parts.push("    r.add_argument('--mirror-self', dest='mirror_self', default=None)\n")
    parts.push("    r.add_argument('--mirror-other', dest='mirror_other', default=None)\n")
    parts.push("    r.add_argument('--axes', default='all', choices=['5tuple','6tuple','11tuple','cross_substrate','all'])\n")
    parts.push("    r.add_argument('--output', required=True)\n")
    parts.push("    r.add_argument('--run-id', dest='run_id', default='unified')\n")
    parts.push("    args = p.parse_args()\n")
    parts.push("    if args.cmd == 'selftest': cmd_selftest()\n")
    parts.push("    elif args.cmd == 'run': cmd_run(args)\n")
    parts.push("    else: sys.exit(2)\n\n")
    parts.push("if __name__ == '__main__': main()\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut h_trained = ""
    let mut h_anti = ""
    let mut h_random = ""
    let mut eeg = ""
    let mut probe_results = ""
    let mut mirror_self = ""
    let mut mirror_other = ""
    let mut axes = "all"
    let mut output = ""
    let mut run_id = "unified"
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        if a == "--h-trained" && i + 1 < len(av) { h_trained = av[i+1]; i = i + 2; continue }
        if a == "--h-anti" && i + 1 < len(av) { h_anti = av[i+1]; i = i + 2; continue }
        if a == "--h-random" && i + 1 < len(av) { h_random = av[i+1]; i = i + 2; continue }
        if a == "--eeg" && i + 1 < len(av) { eeg = av[i+1]; i = i + 2; continue }
        if a == "--probe-results" && i + 1 < len(av) { probe_results = av[i+1]; i = i + 2; continue }
        if a == "--mirror-self" && i + 1 < len(av) { mirror_self = av[i+1]; i = i + 2; continue }
        if a == "--mirror-other" && i + 1 < len(av) { mirror_other = av[i+1]; i = i + 2; continue }
        if a == "--axes" && i + 1 < len(av) { axes = av[i+1]; i = i + 2; continue }
        if a == "--output" && i + 1 < len(av) { output = av[i+1]; i = i + 2; continue }
        if a == "--run-id" && i + 1 < len(av) { run_id = av[i+1]; i = i + 2; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── an11_consciousness_unified_verifier selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("marker missing"); exit(1) }
        println("selftest: OK")
        exit(0)
    }

    if h_trained == "" || output == "" {
        eprintln("usage: --h-trained PATH --output PATH [--axes 5tuple|6tuple|11tuple|cross_substrate|all]")
        eprintln("       optional: --h-anti --h-random --eeg --probe-results --mirror-self --mirror-other --run-id")
        eprintln("       OR --selftest")
        exit(2)
    }

    println("── an11_consciousness_unified_verifier (axes=" + axes + ") ──")
    println("h_trained: " + h_trained)
    println("output:    " + output)
    let mut a = "run --h-trained " + _sh_quote(h_trained) + " --output " + _sh_quote(output) + " --axes " + _sh_quote(axes) + " --run-id " + _sh_quote(run_id)
    if h_anti != "" { a = a + " --h-anti " + _sh_quote(h_anti) }
    if h_random != "" { a = a + " --h-random " + _sh_quote(h_random) }
    if eeg != "" { a = a + " --eeg " + _sh_quote(eeg) }
    if probe_results != "" { a = a + " --probe-results " + _sh_quote(probe_results) }
    if mirror_self != "" { a = a + " --mirror-self " + _sh_quote(mirror_self) }
    if mirror_other != "" { a = a + " --mirror-other " + _sh_quote(mirror_other) }
    let r = _run_helper(a)
    println(r[0])
    exit(r[1])
}

main()
