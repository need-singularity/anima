// ════════════════════════════════════════════════════════════════════════════
//  tool/anima_cli/weight.hexa — anima CLI `weight` topic
//
//  PURPOSE
//    Thin wrapper over existing weight-precache tools. Surfaces status /
//    apply / strategy as idempotent subcommands under `anima weight`.
//
//  SUBCOMMANDS
//    status                summarize state/h100_weight_precache_completion.json
//    apply [--path P]      h100_weight_precache.bash --apply
//    strategy              view config/h100_weight_precache_strategy.json
//    --selftest            read-only synthetic probe
//    --help
// ════════════════════════════════════════════════════════════════════════════

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _fexists(p: string) -> bool {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    return _str(env("HOME")) + "/core/anima"
}

fn _json_field(path: string, key: string) -> string {
    if !_fexists(path) { return "" }
    return _str(exec("jq -r '" + key + " // \"\"' " + path + " 2>/dev/null")).trim()
}

fn _arg_present(argv, key: string) -> bool {
    let i = 0
    while i < len(argv) {
        if _str(argv[i]) == key { return true }
        i = i + 1
    }
    return false
}

fn _arg_value(argv, key: string, dflt: string) -> string {
    let i = 0
    while i < len(argv) {
        if _str(argv[i]) == key && i + 1 < len(argv) {
            return _str(argv[i + 1])
        }
        i = i + 1
    }
    return dflt
}

fn _user_argv(raw) -> array {
    let out = []
    let i = 0
    while i < len(raw) {
        let s = _str(raw[i])
        if !s.contains("/.hexa-cache/") {
            out = out + [s]
        }
        i = i + 1
    }
    return out
}

fn sub_help() {
    println("anima weight — weight precache (compute-agnostic)")
    println("")
    println("  status              precache completion summary")
    println("  apply [--path P]    run weight precache (writes)")
    println("  strategy            view precache strategy config")
    println("")
    println("  --selftest  --help")
}

fn sub_status() {
    let root = _resolve_root()
    let done = root + "/state/h100_weight_precache_completion.json"
    let tok  = root + "/state/h100_weight_precache_tokenizer_sha.json"
    if !_fexists(done) {
        println("weight status: no completion report (" + done + ")")
        return
    }
    let status = _json_field(done, ".status")
    let paths  = _json_field(done, ".paths_cached_count")
    let size   = _json_field(done, ".total_size_gb")
    let ts_c   = _json_field(done, ".generated_at")
    let tok_sha = _json_field(tok,  ".sha256")
    println("anima weight status")
    println("─────────────────────────────")
    println("status        : " + (if status == "" { "?" } else { status }))
    println("paths_cached  : " + (if paths  == "" { "?" } else { paths }))
    println("total_size_gb : " + (if size   == "" { "?" } else { size }))
    println("tokenizer_sha : " + (if tok_sha == "" { "?" } else { tok_sha }))
    println("generated_at  : " + (if ts_c   == "" { "?" } else { ts_c }))
}

fn sub_apply(path: string) {
    let root = _resolve_root()
    let tool = root + "/tool/h100_weight_precache.bash"
    if !_fexists(tool) { println("weight apply: tool missing"); exit(1) }
    let extra = if path == "" { "" } else { " --path " + path }
    println("weight apply: delegating")
    exec("bash " + tool + " --apply" + extra)
}

fn sub_strategy() {
    let root = _resolve_root()
    let cfg = root + "/config/h100_weight_precache_strategy.json"
    if !_fexists(cfg) { println("weight strategy: config missing"); exit(1) }
    println("anima weight strategy")
    println("─────────────────────────────")
    exec("jq . " + cfg)
}

fn sub_selftest() {
    let root = _resolve_root()
    if root == "" { println("FAIL anima_cli/weight selftest"); exit(1) }
    // tolerant probe
    let _ = _json_field(root + "/state/h100_weight_precache_completion.json", ".status")
    println("PASS anima_cli/weight selftest")
    exit(0)
}

fn main() {
    let argv = _user_argv(args())
    if _arg_present(argv, "--selftest") { sub_selftest(); return }
    if _arg_present(argv, "--help") || len(argv) == 0 { sub_help(); return }
    let sub = _str(argv[0])
    if sub == "status"   { sub_status(); return }
    if sub == "apply"    {
        let p = _arg_value(argv, "--path", "")
        sub_apply(p); return
    }
    if sub == "strategy" { sub_strategy(); return }
    println("weight: unknown subcmd '" + sub + "'")
    sub_help()
    exit(2)
}

main()
