// ════════════════════════════════════════════════════════════════════════════
//  tool/anima_cli/serve.hexa — anima CLI `serve` topic
//
//  SUBCOMMANDS
//    persona [--dry]     delegate to tool/serve_alm_persona.hexa
//    api                 print openapi + docs/api location
//    --selftest  --help
// ════════════════════════════════════════════════════════════════════════════

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _fexists(p: string) -> bool {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _dexists(p: string) -> bool {
    return _str(exec("test -d " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    return _str(env("HOME")) + "/core/anima"
}

fn _arg_present(argv, key: string) -> bool {
    let i = 0
    while i < len(argv) {
        if _str(argv[i]) == key { return true }
        i = i + 1
    }
    return false
}

fn _user_argv(raw) -> array {
    let out = []
    let i = 0
    while i < len(raw) {
        let s = _str(raw[i])
        if !s.contains("/.hexa-cache/") {
            out = out + [s]
        }
        i = i + 1
    }
    return out
}

fn _hexa() -> string { return "/Users/ghost/.hx/bin/hexa" }

fn sub_help() {
    println("anima serve — serving layer")
    println("")
    println("  persona [--dry]   serve_alm_persona (CP1 dest1)")
    println("  api               openapi + docs/api listing")
    println("")
    println("  --selftest  --help")
}

fn sub_persona(dry: bool) {
    let root = _resolve_root()
    let tool = root + "/tool/serve_alm_persona.hexa"
    if !_fexists(tool) { println("serve persona: tool missing"); exit(1) }
    let tail = if dry { "--dry" } else { "--cpu" }
    let out = _str(exec(_hexa() + " run " + tool + " " + tail))
    println(out)
}

fn sub_api() {
    let root = _resolve_root()
    let docs = root + "/docs/api"
    let openapi = root + "/docs/api/openapi.yaml"
    if _fexists(openapi) {
        println("anima serve api")
        println("─────────────────────────────")
        println("openapi : " + openapi)
        if _fexists(root + "/docs/api/README.md") {
            println("readme  : " + root + "/docs/api/README.md")
        }
        exec("wc -l " + openapi)
        return
    }
    if _dexists(docs) {
        println("docs/api exists but openapi.yaml absent — run openapi_emit")
        exec("ls " + docs)
        return
    }
    println("anima serve api: docs/api not found (openapi not emitted yet)")
}

fn sub_selftest() {
    let root = _resolve_root()
    let ok = _fexists(root + "/tool/serve_alm_persona.hexa")
    if ok { println("PASS anima_cli/serve selftest"); exit(0) }
    println("FAIL anima_cli/serve selftest (serve_alm_persona.hexa missing)")
    exit(1)
}

fn main() {
    let argv = _user_argv(args())
    if _arg_present(argv, "--selftest") { sub_selftest(); return }
    if _arg_present(argv, "--help") || len(argv) == 0 { sub_help(); return }
    let sub = _str(argv[0])
    if sub == "persona" { sub_persona(_arg_present(argv, "--dry")); return }
    if sub == "api"     { sub_api(); return }
    println("serve: unknown subcmd '" + sub + "'")
    sub_help()
    exit(2)
}

main()
