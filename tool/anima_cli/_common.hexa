// ════════════════════════════════════════════════════════════════════════════
//  tool/anima_cli/_common.hexa — shared helpers for anima CLI topic modules
//
//  PURPOSE
//    Reusable primitives (arg parse, fs probe, json field extraction,
//    table row rendering, iso timestamp) that every tool/anima_cli/*.hexa
//    module includes via `include()` or duplicates (hexa has no cross-file
//    import — modules copy these helpers by the vendored pattern). Kept
//    isolated for single-source-of-truth review.
//
//  DESIGN
//    raw#9  hexa-only    raw#11 snake_case    raw#15 no-hardcode
//    LLM=none, deterministic.
//
//  NOTE
//    Topic modules duplicate the helper bodies below to keep each file
//    self-contained (hexa-lang import semantics vary by release). This
//    file is the canonical reference & selftest host.
// ════════════════════════════════════════════════════════════════════════════

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _trim(s: string) -> string { return s.trim() }

fn _ts_iso() -> string {
    let rep = _str(env("HEXA_REPRODUCIBLE"))
    if rep == "1" { return "REDACTED" }
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn _fexists(p: string) -> bool {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _dexists(p: string) -> bool {
    return _str(exec("test -d " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn _exec_line(cmd: string) -> string {
    return _str(exec(cmd)).trim()
}

fn _json_field(path: string, key: string) -> string {
    // returns raw string value (no quotes) via jq; empty string if missing
    if !_fexists(path) { return "" }
    let out = _str(exec("jq -r '" + key + " // \"\"' " + path + " 2>/dev/null"))
    return out.trim()
}

fn _user_argv(raw) -> array {
    let out = []
    let i = 0
    while i < len(raw) {
        let s = _str(raw[i])
        if !s.contains("/.hexa-cache/") {
            out = out + [s]
        }
        i = i + 1
    }
    return out
}

fn _arg_present(argv, key: string) -> bool {
    let i = 0
    while i < len(argv) {
        if _str(argv[i]) == key { return true }
        i = i + 1
    }
    return false
}

fn _arg_value(argv, key: string, dflt: string) -> string {
    let i = 0
    while i < len(argv) {
        if _str(argv[i]) == key && i + 1 < len(argv) {
            return _str(argv[i + 1])
        }
        i = i + 1
    }
    return dflt
}

fn _table_row(cells) -> string {
    let s = ""
    let i = 0
    while i < len(cells) {
        if i > 0 { s = s + "  " }
        s = s + _str(cells[i])
        i = i + 1
    }
    return s
}

fn _selftest() -> bool {
    // exercise all helpers on a tmp file + synthetic inputs
    let tmp = "/tmp/anima_cli_common_selftest.json"
    exec("printf '%s' '{\"k\":\"v\",\"n\":42}' > " + tmp)
    let v = _json_field(tmp, ".k")
    let n = _json_field(tmp, ".n")
    exec("rm -f " + tmp)
    if v != "v" { return false }
    if n != "42" { return false }
    let ts = _ts_iso()
    if ts == "" { return false }
    let row = _table_row(["a","b","c"])
    if row != "a  b  c" { return false }
    return true
}

fn main() {
    let argv = _user_argv(args())
    if _arg_present(argv, "--selftest") {
        let ok = _selftest()
        if ok {
            println("PASS anima_cli/_common selftest")
            exit(0)
        }
        println("FAIL anima_cli/_common selftest")
        exit(1)
    }
    println("tool/anima_cli/_common.hexa — shared helpers (use --selftest)")
    exit(0)
}

main()
