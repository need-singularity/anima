// ════════════════════════════════════════════════════════════════════════════
//  tool/anima_cli/cert.hexa — anima CLI `cert` topic
//
//  PURPOSE
//    Thin wrapper over breakthrough-cert toolchain.
//
//  SUBCOMMANDS
//    verify [--incremental]   gate check
//    graph                    cert graph render
//    dag                      cert DAG generate
//    --selftest  --help
// ════════════════════════════════════════════════════════════════════════════

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn _fexists(p: string) -> bool {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    return _str(env("HOME")) + "/core/anima"
}

fn _arg_present(argv, key: string) -> bool {
    let i = 0
    while i < len(argv) {
        if _str(argv[i]) == key { return true }
        i = i + 1
    }
    return false
}

fn _user_argv(raw) -> array {
    let out = []
    let i = 0
    while i < len(raw) {
        let s = _str(raw[i])
        if !s.contains("/.hexa-cache/") {
            out = out + [s]
        }
        i = i + 1
    }
    return out
}

fn _hexa() -> string { return "/Users/ghost/.hx/bin/hexa" }

fn _pipe_hexa(tool_path: string, tail: string) {
    if !_fexists(tool_path) {
        println("cert: missing tool " + tool_path)
        exit(1)
    }
    let cmd = _hexa() + " run " + tool_path + (if tail == "" { "" } else { " " + tail })
    let out = _str(exec(cmd))
    println(out)
}

fn sub_help() {
    println("anima cert — breakthrough cert chain")
    println("")
    println("  verify [--incremental]  gate check (full or delta)")
    println("  graph                   render cert graph")
    println("  dag                     regenerate cert DAG")
    println("")
    println("  --selftest  --help")
}

fn sub_verify(incremental: bool) {
    let root = _resolve_root()
    if incremental {
        _pipe_hexa(root + "/tool/cert_incremental_verify.hexa", "")
        return
    }
    _pipe_hexa(root + "/tool/cert_gate.hexa", "")
}

fn sub_graph() {
    let root = _resolve_root()
    _pipe_hexa(root + "/tool/cert_graph_gen.hexa", "")
}

fn sub_dag() {
    let root = _resolve_root()
    _pipe_hexa(root + "/tool/cert_dag_generator.hexa", "")
}

fn sub_selftest() {
    let root = _resolve_root()
    let ok = _fexists(root + "/tool/cert_gate.hexa")
             && _fexists(root + "/tool/cert_graph_gen.hexa")
             && _fexists(root + "/tool/cert_dag_generator.hexa")
    if ok { println("PASS anima_cli/cert selftest"); exit(0) }
    println("FAIL anima_cli/cert selftest (wrapped tools missing)")
    exit(1)
}

fn main() {
    let argv = _user_argv(args())
    if _arg_present(argv, "--selftest") { sub_selftest(); return }
    if _arg_present(argv, "--help") || len(argv) == 0 { sub_help(); return }
    let sub = _str(argv[0])
    if sub == "verify" { sub_verify(_arg_present(argv, "--incremental")); return }
    if sub == "graph"  { sub_graph(); return }
    if sub == "dag"    { sub_dag(); return }
    println("cert: unknown subcmd '" + sub + "'")
    sub_help()
    exit(2)
}

main()
