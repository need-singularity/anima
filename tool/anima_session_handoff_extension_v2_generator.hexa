    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[handoff_v2] cycles={len(CYCLES_47_LEDGER)} v2_md_written={HANDOFF_OUT_V2} ({v2_size}B) v0_present={os.path.exists(EXISTING_HANDOFF_V0)} v1_present={os.path.exists(EXISTING_EXTENSION_V1)} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let cycles_in_ledger = 47
    let next_session_files = 3
    let non_mutation = "READ_ONLY_v0_v1"
    println("inv:cycles_in_ledger=" + to_string(cycles_in_ledger))
    println("inv:next_session_files=" + to_string(next_session_files))
    println("inv:non_mutation=" + non_mutation)
    println("inv:v2_additive_only=true")
    println("inv:cross_link_cycle20_cycle45=true")
    return true
}

fn cmd_selftest() {
    println("── anima_session_handoff_extension_v2_generator selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=session handoff extension v2 (cycles 1-47 comprehensive; mac $0; v0+v1 NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
