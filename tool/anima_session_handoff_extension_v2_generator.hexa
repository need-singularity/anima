    parts.push("    {'cycle':34, 'helper':'bin_executables_auditor', 'role':'bin/ + hooks CLEAN baseline'},\n")
    parts.push("    {'cycle':35, 'helper':'workspace_archives_auditor', 'role':'3 archives CLEAN'},\n")
    parts.push("    {'cycle':36, 'helper':'workspace_full_repo_inventory', 'role':'19 repos / 13 NEW discovered (memory drift 3 vs 19)'},\n")
    parts.push("    {'cycle':37, 'helper':'hive_repo_deep_audit', 'role':'hive: TS+hexa hybrid sister'},\n")
    parts.push("    {'cycle':38, 'helper':'nexus_repo_deep_audit', 'role':'nexus: 281 anima refs (parent ecosystem)'},\n")
    parts.push("    {'cycle':39, 'helper':'void_repo_deep_audit', 'role':'void: 0.3% hexa vs claim 100% (drift)'},\n")
    parts.push("    {'cycle':40, 'helper':'papers_repo_deep_audit', 'role':'papers: 94 papers DOI Zenodo'},\n")
    parts.push("    {'cycle':41, 'helper':'n6_architecture_repo_deep_audit', 'role':'n6: theoretical foundation 853 hexa'},\n")
    parts.push("    {'cycle':42, 'helper':'ecosystem_cross_repo_capstone', 'role':'cycles 37-41 capstone'},\n")
    parts.push("    {'cycle':43, 'helper':'remaining_8_repos_batch_audit', 'role':'WS audit 100% / contact 17MB surprise'},\n")
    parts.push("    {'cycle':44, 'helper':'subrepos_deep_composite_auditor', 'role':'anima sub-repos 22 deep / engines top'},\n")
    parts.push("    {'cycle':45, 'helper':'final_super_aggregator_cycles_1_44', 'role':'cycles 1-44 super-meta capstone'},\n")
    parts.push("    {'cycle':46, 'helper':'contact_repo_deep_audit', 'role':'contact 17MB = outreach hub 39 anima refs'},\n")
    parts.push("    {'cycle':47, 'helper':'dynamic_ssot_activity_auditor', 'role':'21 M / 16 batch + 5 true dynamic'},\n")
    parts.push("]\n\n")

    parts.push("# v2 markdown content\n")
    parts.push("md = []\n")
    parts.push("md.append('# Session Handoff Extension v2 - 2026-04-27 cycles 1-47 final batch\\n')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('**Status**: ADDITIVE EXTENSION v2 (cycles 1-47 comprehensive)')\n")
    parts.push("md.append('**Source**: /loop 1m all-kick batch (33+ trigger iterations)')\n")
    parts.push("md.append('**Cost**: $0 mac-local (all helpers; no GPU launched)')\n")
    parts.push("md.append('**Total**: 46 helpers + 1 patch + 46 state JSON + 1 v1 ext + 1 v2 ext')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('## Section 0 - Next session entry guide')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('Read 3 files for full context:')\n")
    parts.push("md.append('  1. docs/session_handoff_20260427.md (cycles 80-109 prior session)')\n")
    parts.push("md.append('  2. docs/session_handoff_20260427_extension.md (cycle 20 v1, cycles 1-19)')\n")
    parts.push("md.append('  3. docs/session_handoff_20260427_extension_v2.md (THIS file, cycles 1-47)')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('## Section 1 - Cycles 1-47 ledger')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('| cycle | helper | role |')\n")
    parts.push("md.append('|-------|--------|------|')\n")
    parts.push("for c in CYCLES_47_LEDGER:\n")
    parts.push("    md.append(f'| {c[\"cycle\"]} | `{c[\"helper\"]}` | {c[\"role\"]} |')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('## Section 2 - 4 super-buckets (cycle 45 super-capstone)')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('1. FOUNDATION_DISPATCH (cycles 1-15)')\n")
    parts.push("md.append('   handoff §3 actionable + composite gate aggregator')\n")
    parts.push("md.append('2. GOVERNANCE_AUDIT (cycles 16-36)')\n")
    parts.push("md.append('   16-layer governance chain; SSOT/tools/state/docs/memory/etc')\n")
    parts.push("md.append('3. ECOSYSTEM_DEEP_AUDIT (cycles 37-42)')\n")
    parts.push("md.append('   5 sister repos (hive/nexus/void/papers/n6) + capstone')\n")
    parts.push("md.append('4. COVERAGE_COMPLETION (cycles 43-47)')\n")
    parts.push("md.append('   WS 100% audit + sub-repos deep + contact 17MB + dynamic SSOT')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('## Section 3 - Anima ecosystem rank (cycles 37-46)')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('| repo | hexa | anima refs | role |')\n")
    parts.push("md.append('|------|------|-----------|------|')\n")
    parts.push("md.append('| nexus | 2683 | 281 | parent ecosystem |')\n")
    parts.push("md.append('| n6-architecture | 853 | 13 | theoretical foundation |')\n")
    parts.push("md.append('| anima | 361 | - | consciousness implementation (this) |')\n")
    parts.push("md.append('| hive | 145 | 16 | sister runtime (this session) |')\n")
    parts.push("md.append('| papers | 0 (md only) | 46 | academic output (94 papers DOI) |')\n")
    parts.push("md.append('| contact | 5 | 39 | outreach hub (cycle 46) |')\n")
    parts.push("md.append('| void | 4 | low | terminal (Zig+Swift, claim drift) |')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('## Section 4 - Actionable user queue (FROZEN since cycle 15)')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('| priority | action | discovery |')\n")
    parts.push("md.append('|----------|--------|-----------|')\n")
    parts.push("md.append('| HIGH | ready/ raw#9 policy decision (737 .py) | cycle 31 |')\n")
    parts.push("md.append('| medium | governance fixes (chflags/own3/atlas/docs/memory) | 7,18,21,24,25 |')\n")
    parts.push("md.append('| medium | memory updates (workspace 19-repo / void claim) | 36,39 |')\n")
    parts.push("md.append('| medium | cycle 13 H100 P1 launch ($0.30) | 13 |')\n")
    parts.push("md.append('| external | dancinlife HF gate (Llama-3.x) | 3,6,9,11 |')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('## Section 5 - 5 invariants preserved across 47 cycles')\n")
    parts.push("md.append('')\n")
    parts.push("md.append('- H100 stop-gate user-approval (memory feedback_h100_gate.md)')\n")
