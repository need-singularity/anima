    parts.push("md.append('- NON_MUTATION on all SSOT files')\n")
    parts.push("md.append('')\n\n")

    parts.push("# Write v2\n")
    parts.push("os.makedirs(os.path.dirname(HANDOFF_OUT_V2) or '.', exist_ok=True)\n")
    parts.push("with open(HANDOFF_OUT_V2, 'w', encoding='utf-8') as f:\n")
    parts.push("    f.write('\\n'.join(md))\n")
    parts.push("v2_size = os.path.getsize(HANDOFF_OUT_V2)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'session handoff extension v2 (cycles 1-47 comprehensive)',\n")
    parts.push("    'existing_handoff_v0':{'path':EXISTING_HANDOFF_V0, 'present':os.path.exists(EXISTING_HANDOFF_V0)},\n")
    parts.push("    'existing_extension_v1':{'path':EXISTING_EXTENSION_V1, 'present':os.path.exists(EXISTING_EXTENSION_V1)},\n")
