    parts.push("HANDOFF_OUT_V2 = os.environ.get('ANIMA_HANDOFF_OUT', 'docs/session_handoff_20260427_extension_v2.md')\n")
    parts.push("EXISTING_HANDOFF_V0 = 'docs/session_handoff_20260427.md'\n")
    parts.push("EXISTING_EXTENSION_V1 = 'docs/session_handoff_20260427_extension.md'\n\n")

    parts.push("CYCLES_47_LEDGER = [\n")
    parts.push("    # cycles 1-19 (cycle 20 v1 covered)\n")
    parts.push("    {'cycle':1, 'helper':'r46_primary_zone_resolver', 'role':'R46 PRIMARY zone candidate registry'},\n")
    parts.push("    {'cycle':2, 'helper':'cmt_v2_5bb_retest_dispatch', 'role':'CMT v2 retest pre-register'},\n")
    parts.push("    {'cycle':3, 'helper':'axis96_llama_stride1_dispatch', 'role':'HFD-C ruling-out (HF gated)'},\n")
