    parts.push("    {'cycle':7, 'helper':'own3_de_wording_revision_verifier', 'role':'own#3 (d)+(e) drift'},\n")
    parts.push("    {'cycle':8, 'helper':'zombie_posterior_v4_17sub_candidate_selector', 'role':'R45 v3->v4 selector'},\n")
    parts.push("    {'cycle':9, 'helper':'mk_xii_3b_70b_prep_dispatch', 'role':'Mk.XII Phase 3b 70B prep'},\n")
    parts.push("    {'cycle':10, 'helper':'eeg_cp2_7day_arrival_gate_dispatch', 'role':'EEG CP2 hardware gate'},\n")
    parts.push("    {'cycle':11, 'helper':'mk_xii_3a_llama_familyinternal_dispatch', 'role':'Llama family-internal'},\n")
