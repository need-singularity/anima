// tool/anima_session_handoff_extension_v2_generator.hexa — session handoff extension v2 (cycles 1-47, raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 20 generated docs/session_handoff_20260427_extension.md (cycles 1-19).
//   cycle 48 update to v2 covering cycles 1-47 — comprehensive next-session entry guide.
//
//   본 helper = mac-local NON_MUTATION (existing v1 + handoff preserved):
//     - writes docs/session_handoff_20260427_extension_v2.md (NEW file, 별도)
//     - 47 cycles 4-bucket aggregation
//     - actionable queue + invariants preserved
//     - selftest verifies: 47 cycle ledger / NON_MUTATION on existing
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/session_handoff_extension_v2_generator.json)
//   ANIMA_HANDOFF_OUT v2 MD path (default: docs/session_handoff_20260427_extension_v2.md)
//
// OUTPUT
//   - existing_files_status: {v0 base, v1 extension, v2 new}
//   - cycles_summary_47
//   - extension_v2_md_written
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_session_handoff_extension_v2_generator.hexa --selftest
//   ANIMA_OUTPUT=state/session_handoff_extension_v2_generator.json hexa run tool/anima_session_handoff_extension_v2_generator.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - v2는 cycles 20-47 추가; v1 extension (cycle 20) 보존.
//   - existing handoff (cycle 80-109)는 untouched.
//   - 다음 세션 entry 시 v0+v1+v2 3 files read 권장.

let HELPER_PATH = "/tmp/anima_session_handoff_extension_v2_generator_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
