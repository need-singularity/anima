#!hexa strict
// tool/proof_carrying_lint.hexa — verify state/proof_carrying/anima_roadmap.json
//
// @tool(slug="proof_carrying_lint", desc="raw#10 proof-carrying SSOT verifier — walks state/proof_carrying/anima_roadmap.json, re-verifies each file_path entry against disk, summarizes commit_sha and prose entries. Pure report (advisory exit 0; --severity block → exit 1 on mismatch).")
// @usage(hexa tool/proof_carrying_lint.hexa [--ssot <path>] [--severity advisory|warn|block])
// @usage(hexa tool/proof_carrying_lint.hexa --selftest)
// @example(hexa tool/proof_carrying_lint.hexa)
// @exit_codes(0=PASS or advisory, 1=mismatch in warn/block, 5=selftest fail)
// @omega-saturation-exempt("operational utility — single-pass disk verification; no convergence semantic")
//
// PURPOSE
//   `.roadmap` carries proof/evidence refs as free-form text. raw#10
//   demands these refs be machine-auditable. This tool walks the SSOT
//   JSON (anima_roadmap.json, generated by tool/proof_carrying_extract
//   or the equivalent migration script) and confirms every file_path
//   entry still exists on disk. commit_sha entries are flagged for
//   future git-walk verification; prose entries are reported but not
//   verified.
//
// SCHEMA: anima.proof_carrying.v1
//   {
//     "schema": "anima.proof_carrying.v1",
//     "ssot_for": ".roadmap",
//     "generated_at": "YYYY-MM-DD",
//     "verifier": "tool/proof_carrying_lint.hexa",
//     "summary": { "entry_count": N, ... },
//     "records": [
//       {
//         "rule_slug": "roadmap_<id>",
//         "claim": "<title>",
//         "status": "done|active|...",
//         "track": "...", "phase": "P0|P1|...",
//         "completed": "YYYY-MM-DD" or null,
//         "eta": "..." or null,
//         "proofs":    [ {type, value, ...} ],
//         "evidences": [ {type, value, ...} ]
//       }, ...
//     ]
//   }
//
// VERIFY MODES
//   type=file_path   stat the path under /Users/ghost/core/anima/<value>
//   type=commit_sha  log to summary (git verify deferred — interp has no
//                    libgit binding); user can run `git cat-file -e` manually.
//   type=prose       log to summary (free-form witness; not falsifiable here).

let SSOT_DEFAULT = "/Users/ghost/core/anima/state/proof_carrying/anima_roadmap.json"
let ANIMA_ROOT   = "/Users/ghost/core/anima"

fn _exec_silent(cmd: string) -> string {
    try { return exec(cmd) } catch e { return "" }
}

fn _file_exists(p: string) -> bool {
    let r = _exec_silent("test -f '" + p + "' && echo Y || echo N").trim()
    return r == "Y"
}

fn _path_exists(p: string) -> bool {
    let r = _exec_silent("test -e '" + p + "' && echo Y || echo N").trim()
    return r == "Y"
}

fn _slurp(path: string) -> string {
    if !_file_exists(path) { return "" }
    return _exec_silent("cat '" + path + "' 2>/dev/null")
}

// ─── minimal JSON walk ───────────────────────────────────────────
//
// hexa stage1 has json_parse — try it; if absent, the tool degrades to
// "could not parse" and emits exit 5 (selftest) or fail-safe exit 1.

fn _json_load(path: string) -> string {
    // Returns raw JSON string (parse below). Caller invokes json_parse.
    return _slurp(path)
}

fn _abs_anima(rel: string) -> string {
    if rel.starts_with("/") { return rel }
    return ANIMA_ROOT + "/" + rel
}

// ─── selftest ────────────────────────────────────────────────────

fn cmd_selftest() -> int {
    println("[proof_carrying_lint selftest]")

    // Synthesize a minimal SSOT in /tmp + verify round-trip.
    let tmp = _exec_silent("d=\"/tmp/proof_carrying_lint_st_$$\"; mkdir -p \"$d/state/proof_carrying\" \"$d/tool\"; touch \"$d/tool/foo.hexa\"; echo \"$d\"").trim()
    if tmp == "" {
        println("[proof_carrying_lint selftest] FAIL tmp setup")
        return 5
    }

    let payload = "{\"schema\":\"anima.proof_carrying.v1\",\"records\":[" +
        "{\"rule_slug\":\"roadmap_1\",\"claim\":\"x\",\"status\":\"done\",\"proofs\":[{\"type\":\"file_path\",\"value\":\"tool/foo.hexa\"}],\"evidences\":[]}," +
        "{\"rule_slug\":\"roadmap_2\",\"claim\":\"y\",\"status\":\"done\",\"proofs\":[{\"type\":\"file_path\",\"value\":\"tool/missing.hexa\"}],\"evidences\":[]}" +
        "]}"
    _exec_silent("printf '%s' " + _shell_escape_simple(payload) + " > '" + tmp + "/state/proof_carrying/anima_roadmap.json'")

    // Parse + verify.
    let raw = _slurp(tmp + "/state/proof_carrying/anima_roadmap.json")
    if raw == "" {
        _exec_silent("rm -rf '" + tmp + "' 2>/dev/null")
        println("[proof_carrying_lint selftest] FAIL slurp empty")
        return 5
    }

    // path-exists checks (override ANIMA_ROOT to tmp).
    let p1 = tmp + "/tool/foo.hexa"
    let p2 = tmp + "/tool/missing.hexa"
    if !_path_exists(p1) {
        _exec_silent("rm -rf '" + tmp + "' 2>/dev/null")
        println("[proof_carrying_lint selftest] FAIL p1 not found")
        return 5
    }
    if _path_exists(p2) {
        _exec_silent("rm -rf '" + tmp + "' 2>/dev/null")
        println("[proof_carrying_lint selftest] FAIL p2 unexpectedly present")
        return 5
    }

    _exec_silent("rm -rf '" + tmp + "' 2>/dev/null")
    println("[proof_carrying_lint selftest] OK")
    return 0
}

fn _shell_escape_simple(s: string) -> string {
    // Quick single-quote wrap; assumes no embedded single-quote (selftest fixture only).
    return "'" + s + "'"
}

// ─── main verify pass (no JSON parser) ────────────────────────────
//
// Stage1 hexa lacks a robust json_parse — we shell out to `python3 -c`
// to count and verify. This keeps the tool single-binary while honoring
// raw#10 (machine-auditable). Python is universally available on the
// host (used elsewhere in anima/tool/* via FFI).

fn cmd_verify(ssot: string, severity: string) -> int {
    if !_file_exists(ssot) {
        println("proof_carrying_lint: FAIL — SSOT not found at " + ssot)
        return 1
    }

    // Drive verification through python — counts records, verifies each
    // file_path entry against ANIMA_ROOT, returns one summary line.
    let py = "import json,os,sys\n" +
        "d=json.load(open('" + ssot + "'))\n" +
        "root='" + ANIMA_ROOT + "'\n" +
        "n_rec=len(d.get('records',[]))\n" +
        "n_p=n_e=n_path=n_sha=n_prose=0\n" +
        "ok=miss=0; missing=[]\n" +
        "for r in d.get('records',[]):\n" +
        "    for kind in ('proofs','evidences'):\n" +
        "        for ent in r.get(kind,[]):\n" +
        "            t=ent.get('type')\n" +
        "            if kind=='proofs': n_p+=1\n" +
        "            else: n_e+=1\n" +
        "            if t=='file_path':\n" +
        "                n_path+=1\n" +
        "                v=ent.get('value','')\n" +
        "                p=v if v.startswith('/') else os.path.join(root,v)\n" +
        "                if os.path.exists(p): ok+=1\n" +
        "                else:\n" +
        "                    miss+=1\n" +
        "                    missing.append((r['rule_slug'],v))\n" +
        "            elif t=='commit_sha': n_sha+=1\n" +
        "            elif t=='prose': n_prose+=1\n" +
        "print(f'records={n_rec} proofs={n_p} evidences={n_e} file_paths={n_path} commit_shas={n_sha} prose={n_prose}')\n" +
        "print(f'paths_present={ok} paths_missing={miss}')\n" +
        "for slug,v in missing[:32]: print(f'  MISS {slug}: {v}')\n" +
        "sys.exit(1 if miss>0 else 0)\n"
    let cmd = "python3 -c " + _shell_escape_simple(py.replace("'", "'\\''"))
    let out = _exec_silent(cmd)
    println("proof_carrying_lint (schema=anima.proof_carrying.v1)")
    println(out.trim())

    // Determine exit. "paths_missing=N" with N>0 means mismatch.
    let mut have_miss = false
    let lines = out.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if ln.starts_with("paths_present=") {
            // line format: paths_present=X paths_missing=Y
            let parts = ln.split("paths_missing=")
            if len(parts) >= 2 {
                let miss_str = parts[1].trim()
                if miss_str != "0" { have_miss = true }
            }
        }
        i = i + 1
    }
    if have_miss && (severity == "warn" || severity == "block") {
        return 1
    }
    return 0
}

fn _usage() {
    eprintln("usage: hexa tool/proof_carrying_lint.hexa [--ssot <path>] [--severity advisory|warn|block]")
    eprintln("       hexa tool/proof_carrying_lint.hexa --selftest")
}

fn main() {
    let argv = args()
    let mut i = 2
    let mut ssot = SSOT_DEFAULT
    let mut severity = "advisory"
    while i < len(argv) {
        let a = argv[i]
        if a == "--selftest" || a == "selftest" { exit(cmd_selftest()) }
        if a == "--help" || a == "-h" { _usage(); exit(0) }
        if a == "--ssot" && i + 1 < len(argv) { ssot = argv[i + 1]; i = i + 2; continue }
        if a == "--severity" && i + 1 < len(argv) { severity = argv[i + 1]; i = i + 2; continue }
        i = i + 1
    }
    exit(cmd_verify(ssot, severity))
}

main()
