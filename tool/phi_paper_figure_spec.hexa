// ════════════════════════════════════════════════════════════════════════════
//  tool/phi_paper_figure_spec.hexa
//  B.3 Φ empirical paper v1 preliminary — figure spec emitter
//
//  PARENT
//    docs/papers/phi_paradigm_paper_v1_preliminary.md
//    docs/upstream_notes/b_axis_post_h100_mk_xii_r14_paper_20260422.md §B.3
//
//  PURPOSE
//    Emit a deterministic machine-readable spec for the 3 paper figures
//    (LaTeX typesetting happens in an external session — we only declare
//    the ASCII-art / tabular skeleton + data anchors here).
//
//  FIGURES (3)
//    Fig 1: 4-substrate hidden_dim + LoRA rank table
//    Fig 2: CPU synthetic |ΔΦ|/Φ 6-pair heatmap (4×4 symmetric, diag=0)
//    Fig 3: cert-chain projection diagram (ASCII art first; LaTeX later)
//
//  OUTPUT
//    state/phi_paper_figures_spec.json
//
//  RAW STRICT
//    hexa-only · deterministic · idempotent · NO .py · NO external deps
//
//  EXIT
//    0 = PASS (3 figures emitted, JSON valid, sanity checks pass)
//    1 = FAIL (any sanity check failed)
//
//  USAGE
//    /Users/ghost/.hx/bin/hexa run tool/phi_paper_figure_spec.hexa
// ════════════════════════════════════════════════════════════════════════════

let SCHEMA        = "anima/phi_paper_figures_spec/1"
let SEED_DATE     = "20260422"
let OUT_PATH      = "state/phi_paper_figures_spec.json"
let PAPER_PATH    = "docs/papers/phi_paradigm_paper_v1_preliminary.md"
let SSOT_PATH     = "docs/upstream_notes/b_axis_post_h100_mk_xii_r14_paper_20260422.md"

// ─── helpers ───────────────────────────────────────────────────────────────

fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }

fn esc_json(s: string) -> string {
    // minimal escape: backslash + double-quote + newline
    let mut out = ""
    let n = s.len()
    let mut i = 0
    while i < n {
        let ch = s.slice(i, i + 1)
        if ch == "\\" { out = out + "\\\\" }
        else { if ch == "\"" { out = out + "\\\"" }
        else { if ch == "\n" { out = out + "\\n" }
        else { out = out + ch } } }
        i = i + 1
    }
    return out
}

// ─── figure 1 — substrate table ────────────────────────────────────────────

fn fig1_ascii() -> string {
    let mut s = ""
    s = s + "+------+---------------------+----------+---------+----------+-------+--------+\n"
    s = s + "| path | model               | family   | params  | hidden   | rank  | alpha  |\n"
    s = s + "+------+---------------------+----------+---------+----------+-------+--------+\n"
    s = s + "|  p1  | Qwen3-8B            | Qwen     |  8.2 B  |   4096   |  64   |  128   |\n"
    s = s + "|  p2  | Llama-3.1-8B        | Llama    |  8.0 B  |   4096   |  64   |  128   |\n"
    s = s + "|  p3  | Ministral-3-14B     | Mistral  | 13.5 B  |   5120   |  96   |  192   |\n"
    s = s + "|  p4  | Gemma-4-31B         | Gemma    | 31.3 B  |   5376   |  96   |  192   |\n"
    s = s + "+------+---------------------+----------+---------+----------+-------+--------+\n"
    return s
}

// ─── figure 2 — 4x4 ΔΦ/Φ heatmap (from phi_cpu_synthetic_4path_result.json) ─

fn fig2_ascii() -> string {
    // Ratios pre-computed from state/phi_cpu_synthetic_4path_result.json (§5.2).
    // Symmetric matrix; diagonal = 0. Row = i, Col = j.
    let mut s = ""
    s = s + "        p1        p2        p3        p4\n"
    s = s + "  p1  0.000000  0.053567  0.006326  0.028917    [MARGIN @ p1p2]\n"
    s = s + "  p2  0.053567  0.000000  0.047244  0.082452    [MARGIN @ p2p4]\n"
    s = s + "  p3  0.006326  0.047244  0.000000  0.035242\n"
    s = s + "  p4  0.028917  0.082452  0.035242  0.000000\n"
    s = s + "\n"
    s = s + "legend:  < 0.05  PASS      [0.05,0.10)  MARGIN      >= 0.10  FAIL\n"
    return s
}

// ─── figure 3 — cert-chain projection ASCII diagram ────────────────────────

fn fig3_ascii() -> string {
    let mut s = ""
    s = s + "   base W_S  (frozen)                 +----------------------+\n"
    s = s + "       |                              |  AN11 triple         |\n"
    s = s + "       |  freeze                      |   a operator-adm     |\n"
    s = s + "       v                              |   b path-consistency |\n"
    s = s + "   +--------+    LoRA delta           |   c terminal JSD     |\n"
    s = s + "   | W_S    | ---------------->  gate +----------------------+\n"
    s = s + "   +--------+    rank r, s=2.0              |\n"
    s = s + "       |                                    |  cert chain append\n"
    s = s + "       |                                    v\n"
    s = s + "       |                          +--------------------+\n"
    s = s + "       +------ CPGD step -------> |  meta^2 triple     |\n"
    s = s + "         (rollback iff            |  (chain closure)   |\n"
    s = s + "          cert FAIL)              +--------------------+\n"
    s = s + "                                        |\n"
    s = s + "                                        v\n"
    s = s + "                            +--------------------------+\n"
    s = s + "                            |  Phi_S  (integrated info) |\n"
    s = s + "                            +--------------------------+\n"
    s = s + "\n"
    s = s + "gate:  ALL_PAIRS |dPhi|/Phi_avg < 0.05   (6 pairs over C(4,2))\n"
    return s
}

// ─── LaTeX stubs (placeholders; full render is an external typesetting job) ─

fn fig1_latex_stub() -> string {
    let mut s = ""
    s = s + "\\begin{table}[t]\n"
    s = s + "\\centering\n"
    s = s + "\\caption{4-substrate panel: family, scale, hidden\\_dim, LoRA rank.}\n"
    s = s + "\\label{tab:substrate-panel}\n"
    s = s + "\\begin{tabular}{llllrrr}\n"
    s = s + "\\toprule\n"
    s = s + "path & model & family & params & hidden & rank & alpha \\\\\n"
    s = s + "\\midrule\n"
    s = s + "p1 & Qwen3-8B & Qwen & 8.2B & 4096 & 64 & 128 \\\\\n"
    s = s + "p2 & Llama-3.1-8B & Llama & 8.0B & 4096 & 64 & 128 \\\\\n"
    s = s + "p3 & Ministral-3-14B & Mistral & 13.5B & 5120 & 96 & 192 \\\\\n"
    s = s + "p4 & Gemma-4-31B & Gemma & 31.3B & 5376 & 96 & 192 \\\\\n"
    s = s + "\\bottomrule\n"
    s = s + "\\end{tabular}\n"
    s = s + "\\end{table}\n"
    return s
}

fn fig2_latex_stub() -> string {
    let mut s = ""
    s = s + "% Heatmap (tikz / pgfplots matrix plot) — 4x4 symmetric\n"
    s = s + "% data anchor: state/phi_cpu_synthetic_4path_result.json :: pairs[*].ratio\n"
    s = s + "% external typesetting session shall render with matrix plot + color gradient\n"
    s = s + "% (PASS green < 0.05, MARGIN yellow [0.05,0.10), FAIL red >= 0.10)\n"
    return s
}

fn fig3_latex_stub() -> string {
    let mut s = ""
    s = s + "% Cert-chain projection diagram (tikz node/arrow)\n"
    s = s + "% Render guideline: ASCII layout in state/phi_paper_figures_spec.json :: figures[2].ascii\n"
    s = s + "% Nodes: W_S (base frozen), LoRA delta, AN11 triple, meta^2, Phi_S\n"
    s = s + "% Edges: freeze, gate, CPGD step (rollback), cert chain append\n"
    return s
}

// ─── main ──────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let mut selftest_only = false
    let mut k = 0
    while k < argv.len() {
        if argv[k] == "--selftest" { selftest_only = true }
        k = k + 1
    }

    println("[phi_paper_fig] B.3 Φ empirical paper v1 — figure spec emitter")
    println("[phi_paper_fig] paper=" + PAPER_PATH)
    println("[phi_paper_fig] ssot=" + SSOT_PATH)

    let f1_ascii = fig1_ascii()
    let f2_ascii = fig2_ascii()
    let f3_ascii = fig3_ascii()

    let f1_latex = fig1_latex_stub()
    let f2_latex = fig2_latex_stub()
    let f3_latex = fig3_latex_stub()

    // sanity: each figure has non-empty ascii + latex (placeholder or full)
    let c1 = f1_ascii.len() > 0 && f1_latex.len() > 0
    let c2 = f2_ascii.len() > 0 && f2_latex.len() > 0
    let c3 = f3_ascii.len() > 0 && f3_latex.len() > 0
    let all_ok = c1 && c2 && c3

    let figure_count = 3

    let mut body = "{\n"
    body = body + "  \"schema\":           \"" + SCHEMA + "\",\n"
    body = body + "  \"source\":           \"anima/tool/phi_paper_figure_spec.hexa\",\n"
    body = body + "  \"paper_ref\":        \"" + PAPER_PATH + "\",\n"
    body = body + "  \"ssot_ref\":         \"" + SSOT_PATH + "\",\n"
    body = body + "  \"seed_date\":        \"" + SEED_DATE + "\",\n"
    body = body + "  \"raw_strict\":       \"hexa-only deterministic idempotent no_python no_external\",\n"
    body = body + "  \"latex_out_of_scope\": true,\n"
    body = body + "  \"figure_count\":     " + to_string(figure_count) + ",\n"
    body = body + "  \"figures\": [\n"

    body = body + "    {\n"
    body = body + "      \"id\":            1,\n"
    body = body + "      \"label\":         \"tab:substrate-panel\",\n"
    body = body + "      \"kind\":          \"table\",\n"
    body = body + "      \"title\":         \"4-substrate hidden_dim + LoRA rank table\",\n"
    body = body + "      \"data_anchor\":   \"config/phi_4path_substrates.json + config/lora_rank_per_path.json\",\n"
    body = body + "      \"ascii\":         \"" + esc_json(f1_ascii) + "\",\n"
    body = body + "      \"latex_stub\":    \"" + esc_json(f1_latex) + "\",\n"
    body = body + "      \"sanity_pass\":   " + bool_s(c1) + "\n"
    body = body + "    },\n"

    body = body + "    {\n"
    body = body + "      \"id\":            2,\n"
    body = body + "      \"label\":         \"fig:phi-heatmap-6pair\",\n"
    body = body + "      \"kind\":          \"heatmap\",\n"
    body = body + "      \"title\":         \"CPU synthetic |ΔΦ|/Φ 6-pair heatmap\",\n"
    body = body + "      \"data_anchor\":   \"state/phi_cpu_synthetic_4path_result.json :: pairs[*].ratio\",\n"
    body = body + "      \"matrix_shape\":  \"4x4 symmetric, diag=0\",\n"
    body = body + "      \"pass_green\":    0.05,\n"
    body = body + "      \"margin_yellow\": 0.10,\n"
    body = body + "      \"ascii\":         \"" + esc_json(f2_ascii) + "\",\n"
    body = body + "      \"latex_stub\":    \"" + esc_json(f2_latex) + "\",\n"
    body = body + "      \"sanity_pass\":   " + bool_s(c2) + "\n"
    body = body + "    },\n"

    body = body + "    {\n"
    body = body + "      \"id\":            3,\n"
    body = body + "      \"label\":         \"fig:cert-projection\",\n"
    body = body + "      \"kind\":          \"diagram\",\n"
    body = body + "      \"title\":         \"cert-chain projection diagram (W_S → LoRA Δ → AN11 → meta² → Φ_S)\",\n"
    body = body + "      \"data_anchor\":   \"docs/phi_convergence_monitoring_spec.md + docs/phi_4path_divergence_response.md\",\n"
    body = body + "      \"ascii\":         \"" + esc_json(f3_ascii) + "\",\n"
    body = body + "      \"latex_stub\":    \"" + esc_json(f3_latex) + "\",\n"
    body = body + "      \"sanity_pass\":   " + bool_s(c3) + "\n"
    body = body + "    }\n"

    body = body + "  ],\n"
    body = body + "  \"all_figures_ok\":   " + bool_s(all_ok) + ",\n"
    body = body + "  \"verdict\":          \"" + (if all_ok { "PASS" } else { "FAIL" }) + "\"\n"
    body = body + "}\n"

    write_file(OUT_PATH, body)

    println("[phi_paper_fig] wrote " + OUT_PATH)
    println("[phi_paper_fig] figures=" + to_string(figure_count) + " all_ok=" + bool_s(all_ok))

    if all_ok { exit(0) }
    exit(1)
}

main()
