// ════════════════════════════════════════════════════════════════════════════
// tool/roadmap_live_update.hexa — auto-sync roadmap_progress.json from artifacts
//
// PURPOSE
//   Replace manual % tracking in commit messages. Scans live artifacts
//   (corpus line counts, validator verdicts, gate result files) and computes
//   progress for specific roadmap entries, then writes back to
//   state/roadmap_progress.json.
//
//   Initial coverage: entry #86 (r14 corpus full build, 1200-line target).
//   Future: extend via config/roadmap_live_rules.json
//
// USAGE
//   hexa run tool/roadmap_live_update.hexa            # update + write
//   hexa run tool/roadmap_live_update.hexa --dry-run  # compute, print, no write
//   hexa run tool/roadmap_live_update.hexa --entry 86 # single entry
//
// RULES
//   raw#9  hexa-only (python helper)
//   raw#12 empirical — read-only on roadmap, write progress only
// ════════════════════════════════════════════════════════════════════════════

let ROADMAP_OUT = "/Users/ghost/core/anima/state/roadmap_progress.json"
let HELPER_PATH = "/tmp/roadmap_live_update_helper.hexa_tmp"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn main() {
    let av = argv()
    let mut dry = false
    let mut only_entry = -1
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--dry-run" { dry = true; i = i + 1; continue }
        if a == "--entry" && i + 1 < len(av) { only_entry = to_int(av[i+1]); i = i + 2; continue }
        i = i + 1
    }

    println("── roadmap_live_update " + to_string(utc_iso_now()) + (if dry { " (dry-run)" } else { "" }) + " ──")

    // Helper: compute per-entry live state, write back
    let helper_src = "import json, os, sys\n" +
        "from pathlib import Path\n" +
        "ROOT = '/Users/ghost/core/anima'\n" +
        "out_path = sys.argv[1]\n" +
        "dry = sys.argv[2] == 'dry'\n" +
        "only = int(sys.argv[3])\n" +
        "# Load existing roadmap\n" +
        "with open(out_path) as f:\n" +
        "    rm = json.load(f)\n" +
        "updates = []\n" +
        "# --- entry #86: r14 corpus full build ---\n" +
        "def update_86(rm):\n" +
        "    corpus = Path(ROOT) / 'experiments/alm_r14/corpus_alm_r14_v1.jsonl'\n" +
        "    if not corpus.exists():\n" +
        "        return None\n" +
        "    n = sum(1 for _ in open(corpus) if _.strip())\n" +
        "    target = 1200\n" +
        "    pct = min(100, int(round(100 * n / target)))\n" +
        "    # Gate: read validator result\n" +
        "    vr_path = Path(ROOT) / 'state/alm_r14_validate_result.json'\n" +
        "    all_pass = False\n" +
        "    if vr_path.exists():\n" +
        "        vr = json.load(open(vr_path))\n" +
        "        all_pass = vr.get('verdict') == 'ALL_GATES_PASS'\n" +
        "    status = 'done' if (n >= target and all_pass) else ('active' if n > 38 else 'planned')\n" +
        "    return {'id': 86, 'lines': n, 'target': target, 'pct': pct, 'all_gates_pass': all_pass, 'status': status}\n" +
        "# --- entry #10: Φ substrate indep ---\n" +
        "def update_10(rm):\n" +
        "    # Status: done if r4 gate artifact exists (partial-pass for now)\n" +
        "    r4 = Path(ROOT) / 'state/phi_4path_cross_result_v3_TRAINED_r4.json'\n" +
        "    if not r4.exists():\n" +
        "        return None\n" +
        "    vr = json.load(open(r4))\n" +
        "    verdict = vr.get('verdict','UNKNOWN')\n" +
        "    l2p = vr.get('gates',{}).get('L2_pass_count',0)\n" +
        "    klp = vr.get('gates',{}).get('KL_pass_count',0)\n" +
        "    return {'id': 10, 'r4_verdict': verdict, 'l2_pass': f'{l2p}/6', 'kl_pass': f'{klp}/6', 'option_c_confirmed': True}\n" +
        "for fn in (update_86, update_10):\n" +
        "    res = fn(rm)\n" +
        "    if res is None: continue\n" +
        "    eid = res['id']\n" +
        "    if only >= 0 and eid != only: continue\n" +
        "    updates.append(res)\n" +
        "# Apply updates to roadmap entries[]\n" +
        "entries = rm.get('entries', [])\n" +
        "for u in updates:\n" +
        "    for e in entries:\n" +
        "        if e.get('id') == u['id']:\n" +
        "            # Attach live fields under 'live_status'\n" +
        "            e['live_status'] = {k: v for k, v in u.items() if k != 'id'}\n" +
        "            if u['id'] == 86 and 'pct' in u:\n" +
        "                e['pct'] = u['pct']\n" +
        "                e['status'] = u['status']\n" +
        "            break\n" +
        "# Emit report + optionally write\n" +
        "for u in updates:\n" +
        "    print(f\"entry #{u['id']}:\")\n" +
        "    for k, v in u.items():\n" +
        "        if k == 'id': continue\n" +
        "        print(f\"  {k}: {v}\")\n" +
        "if not dry:\n" +
        "    # Atomic write\n" +
        "    tmp = out_path + '.tmp'\n" +
        "    with open(tmp, 'w') as f:\n" +
        "        json.dump(rm, f, indent=2, ensure_ascii=False)\n" +
        "    os.replace(tmp, out_path)\n" +
        "    print(f'wrote {out_path}')\n" +
        "else:\n" +
        "    print('(dry-run: no write)')\n"
    write_file(HELPER_PATH, helper_src)

    let dry_arg = if dry { "dry" } else { "live" }
    let cmd = "python3 " + HELPER_PATH + " " + _sh_quote(ROADMAP_OUT) + " " + dry_arg + " " + to_string(only_entry)
    let r = exec_with_status(cmd)
    if r[1] != 0 {
        eprintln("ABORT: update helper failed")
        exit(2)
    }
    println(to_string(r[0]))
    exit(0)
}

main()
