let DEFAULT_OUTPUT = "state/zombie_posterior_v2_11substrate.json"
let SELFTEST_OUTPUT = "/tmp/anima_zombie_posterior_v2_selftest.json"

let SCALE = 10000
let HALF = 5000
let MOD_PRIME = 2147483647
let FNV_OFFSET = 1469598103

// 11 substrate Φ* v3 evidence (×10000 fixed-point, sign explicit).
// Source: atlas R45_UPDATE round 48 corrected inventory (state/atlas_convergence_witness.jsonl line 39).
