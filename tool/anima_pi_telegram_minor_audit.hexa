// tool/anima_pi_telegram_minor_audit.hexa — pi-telegram minor repo audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 43 saw 5MB but only 1 md detected. cycle 49 deep verifies tiny content.
//   pi-telegram = Telegram DM bridge for pi (1 ts source).
//
//   본 helper = mac-local NON_MUTATION:
//     - file count + size breakdown by extension + asset
//     - 5MB explanation (likely .git history + screenshot.png)
//     - selftest verifies: ≤10 source files / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/pi_telegram_minor_audit.json)
//   ANIMA_PT_DIR      pi-telegram dir (default: /Users/ghost/core/pi-telegram)
//
// OUTPUT
//   - file_type_counts
//   - asset_files (png/screenshot etc)
//   - characterization
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_pi_telegram_minor_audit.hexa --selftest
//   ANIMA_OUTPUT=state/pi_telegram_minor_audit.json hexa run tool/anima_pi_telegram_minor_audit.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - 5MB는 source code 아님 — assets + git history.
//   - tiny project = essentially Telegram bot wrapper.

let HELPER_PATH = "/tmp/anima_pi_telegram_minor_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima pi-telegram minor audit — emitted by tool/anima_pi_telegram_minor_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/pi_telegram_minor_audit.json')\n")
    parts.push("PT_DIR = os.environ.get('ANIMA_PT_DIR', '/Users/ghost/core/pi-telegram')\n\n")

    parts.push("if not os.path.isdir(PT_DIR):\n")
    parts.push("    summary = {'paradigm':'pi-telegram audit', 'status':'PT_DIR_MISSING'}\n")
    parts.push("    os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("    with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("    print(f'[pt_audit] status=PT_DIR_MISSING -> {OUTPUT}')\n")
    parts.push("    sys.exit(0)\n\n")

    parts.push("# Count by ext\n")
    parts.push("def _count(path, ext, max_depth=4):\n")
    parts.push("    base_depth = path.rstrip('/').count('/')\n")
    parts.push("    count = 0\n")
    parts.push("    for root, dirs, files in os.walk(path):\n")
    parts.push("        depth = root.count('/') - base_depth\n")
    parts.push("        if depth > max_depth: dirs.clear(); continue\n")
    parts.push("        dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__')]\n")
    parts.push("        for f in files:\n")
    parts.push("            if f.endswith(ext): count += 1\n")
    parts.push("    return count\n\n")

    parts.push("file_type_counts = {\n")
    parts.push("    'md':_count(PT_DIR, '.md'),\n")
    parts.push("    'json':_count(PT_DIR, '.json'),\n")
    parts.push("    'ts':_count(PT_DIR, '.ts'),\n")
    parts.push("    'js':_count(PT_DIR, '.js'),\n")
    parts.push("    'py':_count(PT_DIR, '.py'),\n")
    parts.push("    'png':_count(PT_DIR, '.png'),\n")
    parts.push("    'mp3':_count(PT_DIR, '.mp3'),\n")
    parts.push("    'mp4':_count(PT_DIR, '.mp4'),\n")
    parts.push("}\n\n")

    parts.push("# Total size including .git\n")
    parts.push("total_size = 0\n")
    parts.push("git_size = 0\n")
    parts.push("for root, dirs, files in os.walk(PT_DIR):\n")
    parts.push("    is_git = '.git' in root\n")
    parts.push("    for f in files:\n")
    parts.push("        try:\n")
    parts.push("            sz = os.path.getsize(os.path.join(root, f))\n")
    parts.push("            total_size += sz\n")
    parts.push("            if is_git: git_size += sz\n")
    parts.push("        except Exception: continue\n\n")

    parts.push("source_files_total = sum(file_type_counts.values())\n")
    parts.push("git_pct_of_total = round(100 * git_size / max(total_size, 1), 1)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'pi-telegram minor repo audit (cycle 43 5MB explanation)',\n")
    parts.push("    'pt_dir':PT_DIR,\n")
    parts.push("    'file_type_counts':file_type_counts,\n")
    parts.push("    'source_files_total':source_files_total,\n")
    parts.push("    'total_size_kb':round(total_size / 1024, 1),\n")
    parts.push("    'git_history_size_kb':round(git_size / 1024, 1),\n")
    parts.push("    'git_pct_of_total':git_pct_of_total,\n")
    parts.push("    'characterization':'pi-telegram = Telegram DM bridge for pi (1 ts source). 5MB total mostly .git history + 2 png assets, not source code.',\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify pi-telegram; read-only audit',\n")
    parts.push("    'cross_link_cycles':['cycle 43 remaining 8 batch (pi-telegram 5MB initial discovery)','cycle 36 ws full inventory'],\n")
    parts.push("    'pattern':'governance audit chain layer 29 (cycles 21-48 + this) — last minor repo characterized',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[pt_audit] source_files={source_files_total} total_kb={round(total_size / 1024, 1)} git_kb={round(git_size / 1024, 1)} git_pct={git_pct_of_total}% -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let source_files_max = 10
    let non_mutation = "READ_ONLY"
    println("inv:source_files_max=" + to_string(source_files_max))
    println("inv:non_mutation=" + non_mutation)
    println("inv:cycle_43_5MB_explanation_target=true")
    println("inv:cross_link_cycle43_cycle36=true")
    return true
}

fn cmd_selftest() {
    println("── anima_pi_telegram_minor_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=pi-telegram minor audit (5MB = git history + assets explanation; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
