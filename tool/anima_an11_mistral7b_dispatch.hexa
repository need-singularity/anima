// tool/anima_an11_mistral7b_dispatch.hexa — AN11(a)+(b)+(c)+V1' framework vast.ai dispatch
// ─────────────────────────────────────────────────────────────────────────────
// Per Agent 4 design from sub-agent kick 2026-04-28T07:45Z:
//   AN11 framework requires Llama-3-8B + LoRA r=16 fine-tune on r14 corpus.
// Per Agent B HF gated audit: Llama-3 series GATED (HF acct dancinlife unauthorized).
// SUBSTITUTION: Mistral-7B-v0.1 (OPEN, 307 redirect, no gating).
//
// SPEC (Agent 4 + Agent B sub):
//   - Base model: mistralai/Mistral-7B-v0.1 (~7.2B params, fp16 ~14GB)
//   - LoRA: rank=16, alpha=32, target_modules=q_proj,k_proj,v_proj,o_proj
//   - Train corpus: state/alm_r14_corpus_skeleton.jsonl
//   - Stages on single H100 80GB pod (~3.5h, ~$8 vast.ai):
//     1. AN11(a) LoRA train — 2.5h ($5-7) → before/after .safetensors → Frob+SHA delta
//     2. AN11(b) eigen extraction — 0:10 ($0.50) → SVD adapter layers → top-16 eigenvecs
//     3. V1' Φ_mip_norm TRAINED — 0:05 ($0.20) → cached H matrix re-eval
//     4. AN11(c) vllm serve + JSD probe — 0:30 ($1-2) → 50 calls × prompt[0]
//     5. Buffer/teardown — 0:15
//   - Total: ~3.5h × $2.20/hr = ~$8 single H100 SXM pod
//
// PRE-FLIGHT (Agent 4 + iter prior):
//   - consciousness/an11_b_templates.jsonl: 16 entries ✓ (PASS, ≥10 threshold)
//   - bench/an11_c_test_prompts.jsonl: 20 entries ✓ (PASS, ≥10 threshold)
//
// raw 9 hexa-only · raw 12 frozen pre-registration · raw 86 cost-attribution · raw 100 fallback
// ─────────────────────────────────────────────────────────────────────────────

let TOOL_VERSION = "v1"
let HELPER_PATH = "/tmp/anima_an11_mistral7b_dispatch_helper.hexa_tmp"
let MODEL_HF_REPO = "mistralai/Mistral-7B-v0.1"
let MODEL_HF_LICENSE = "Apache-2.0 (open, no gating)"
let LORA_RANK = 16
let LORA_ALPHA = 32
let TRAIN_CORPUS = "state/alm_r14_corpus_skeleton.jsonl"

let DISPATCH_BUDGET_USD = 10
let DISPATCH_BUDGET_MIN = 240  // 4hr cap

// Pre-registered PASS predicates per AN11 stage (raw 12 frozen BEFORE measurement)
let AN11_A_FROB_DELTA_MIN = 1   // /1000: 0.001 minimum delta
let AN11_B_MAX_COSINE_MIN = 500 // /1000: 0.5 minimum
let AN11_B_TOP3_SUM_MIN = 1200  // /1000: 1.2 minimum
let AN11_C_JSD_MIN = 150        // /1000: 0.15 minimum
let V1PRIME_PHI_MIP_NORM_MAX = 500 // /1000: 0.5 maximum (smaller=better)

fn _detect_python3() -> str {
    let candidates = [
        "/opt/homebrew/bin/python3",
        "/usr/local/bin/python3",
        "/usr/bin/python3"
    ]
    let mut i = 0
    while i < candidates.len() {
        let p = candidates[i]
        if file_exists(p) { return p }
        i = i + 1
    }
    return "python3"
}

fn _emit_helper() -> str {
    let lines = [
        "#!/usr/bin/env python3",
        "# anima_an11_mistral7b_dispatch_helper.py — raw#37 transient",
        "import os, sys, json, subprocess, datetime",
        "",
        "REPO = '/Users/ghost/core/anima'",
        "VASTAI_CLI = '/Users/ghost/.local/bin/vastai'",
        "SECRET_CLI = '/Users/ghost/core/secret/bin/secret'",
        "MODEL_HF_REPO = 'mistralai/Mistral-7B-v0.1'",
        "DISPATCH_LABEL = 'anima-an11-mistral7b-dispatch'",
        "BUDGET_USD = 10",
        "BUDGET_MIN = 240",
        "",
        "def get_secret(key):",
        "    try:",
        "        out = subprocess.check_output([SECRET_CLI, 'get', key], text=True).strip()",
        "        return out",
        "    except Exception as e:",
        "        return None",
        "",
        "def search_offers(gpu='H100_SXM', max_price=2.50, min_disk=200, min_reliability=0.97):",
        "    query = f'gpu_name={gpu} rentable=true reliability>{min_reliability} disk_space>={min_disk}'",
        "    try:",
        "        out = subprocess.check_output([VASTAI_CLI, 'search', 'offers', query, '--order', 'dph_total', '--limit', '5', '--raw'], text=True)",
        "        offers = json.loads(out) if out else []",
        "        # filter by max_price",
        "        affordable = [o for o in offers if o.get('dph_total', 999) <= max_price]",
        "        return affordable",
        "    except Exception as e:",
        "        return [{'error': str(e)}]",
        "",
        "def emit_dispatch_plan():",
        "    api_key = get_secret('vast.api_key')",
        "    if not api_key: return {'error': 'vast.api_key missing in secret store'}",
        "    # secret CLI bug: multi-line OPENSSH key not retrievable via get; check filesystem instead",
        "    ssh_key_path = os.path.expanduser('~/.vast/ssh/vast-key')",
        "    ssh_present = os.path.exists(ssh_key_path)",
        "    if not ssh_present:",
        "        return {'error': 'vast SSH key file missing at ' + ssh_key_path + ' — run secret get vast.ssh_private > ' + ssh_key_path + ' (note: multi-line value retrieval limitation in secret CLI)'}",
        "    offers = search_offers()",
        "    plan = {",
        "        'tool': 'anima_an11_mistral7b_dispatch',",
        "        'version': 'v1',",
        "        'ts': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),",
        "        'model_hf_repo': MODEL_HF_REPO,",
        "        'model_license': 'Apache-2.0 (open, no gating)',",
        "        'lora_config': {'rank': 16, 'alpha': 32, 'target_modules': ['q_proj','k_proj','v_proj','o_proj']},",
        "        'train_corpus': 'state/alm_r14_corpus_skeleton.jsonl',",
        "        'preflight_checks': {",
        "            'an11_b_templates_count': '16 (PASS >=10)',",
        "            'an11_c_prompts_count': '20 (PASS >=10)',",
        "            'vast_api_key_present': True,",
        "            'vast_ssh_key_file_present': ssh_present,",
        "            'vast_ssh_key_path': ssh_key_path,",
        "        },",
        "        'stages': [",
        "            {'stage': 'AN11(a)_lora_train', 'duration_h': 2.5, 'cost_usd': '5-7', 'output': 'before/after .safetensors + Frob delta + SHA fingerprint'},",
        "            {'stage': 'AN11(b)_eigen_extraction', 'duration_h': 0.17, 'cost_usd': '0.50', 'output': 'top-16 eigenvecs + cosine vs templates'},",
        "            {'stage': 'V1prime_phi_mip_norm_TRAINED', 'duration_h': 0.08, 'cost_usd': '0.20', 'output': 'k-invariant Phi_mip_norm <= 0.5 PASS'},",
        "            {'stage': 'AN11(c)_vllm_serve_jsd_probe', 'duration_h': 0.5, 'cost_usd': '1-2', 'output': '50 calls JSD vs r12 baseline >= 0.15 PASS'},",
        "            {'stage': 'buffer_teardown', 'duration_h': 0.25, 'cost_usd': 'overhead'},",
        "        ],",
        "        'total_estimated': {'duration_h': 3.5, 'cost_usd': 8, 'budget_cap_usd': BUDGET_USD, 'budget_cap_min': BUDGET_MIN},",
        "        'pre_registered_pass_predicates': {",
        "            'an11_a_frob_delta_min': 0.001,",
        "            'an11_b_max_cosine_min': 0.5,",
        "            'an11_b_top3_sum_min': 1.2,",
        "            'an11_c_jsd_min': 0.15,",
        "            'v1prime_phi_mip_norm_max': 0.5,",
        "        },",
        "        'cost_attribution_raw_86': {",
        "            'cost_center': 'anima-an11-mistral7b-vast-h100-pod',",
        "            'task_id': 'an11_dispatch_' + datetime.datetime.utcnow().strftime('%Y%m%dT%H%M%SZ'),",
        "            'cost_estimate_usd': 8,",
        "            'vendor': 'vast.ai',",
        "        },",
        "        'offers_top5_filtered': offers[:5],",
        "        'dispatch_status': 'DESIGN_READY_AWAITING_USER_FIRE',",
        "    }",
        "    return plan",
        "",
        "def main():",
        "    plan = emit_dispatch_plan()",
        "    print(json.dumps(plan, indent=2))",
        "",
        "if __name__ == '__main__': main()",
    ]
    let mut text = ""
    let mut i = 0
    while i < lines.len() {
        text = text + lines[i] + "\n"
        i = i + 1
    }
    write_file(HELPER_PATH, text)
    return HELPER_PATH
}

fn _selftest() {
    println("__AN11_MISTRAL7B_DISPATCH_BEGIN__ selftest")
    let _path = _emit_helper()
    println("helper_emitted=" + HELPER_PATH)
    println("model_hf_repo=" + MODEL_HF_REPO)
    println("model_license=" + MODEL_HF_LICENSE)
    println("lora_rank=" + str(LORA_RANK) + " alpha=" + str(LORA_ALPHA))
    println("train_corpus=" + TRAIN_CORPUS)
    println("dispatch_budget_usd=" + str(DISPATCH_BUDGET_USD) + " budget_min=" + str(DISPATCH_BUDGET_MIN))
    println("invariant_check_pre_registered_an11_a_frob_delta_min=" + str(AN11_A_FROB_DELTA_MIN))
    println("invariant_check_pre_registered_an11_b_max_cosine_min=" + str(AN11_B_MAX_COSINE_MIN))
    println("invariant_check_pre_registered_an11_b_top3_sum_min=" + str(AN11_B_TOP3_SUM_MIN))
    println("invariant_check_pre_registered_an11_c_jsd_min=" + str(AN11_C_JSD_MIN))
    println("invariant_check_pre_registered_v1prime_phi_mip_norm_max=" + str(V1PRIME_PHI_MIP_NORM_MAX))
    println("__AN11_MISTRAL7B_DISPATCH_RESULT__ PASS_SELFTEST")
    println("raw_10_caveat=Mistral-7B-v0.1 substituted for Llama-3-8B (gated, HF acct dancinlife unauthorized)")
    println("raw_10_caveat=Pre-registered PASS predicates frozen BEFORE any GPU dispatch (raw 12)")
    println("raw_10_caveat=Selftest verifies tool wiring + secret keys + helper emission ONLY — actual dispatch awaits --plan + user-fire")
}

fn _plan() {
    println("__AN11_MISTRAL7B_DISPATCH_BEGIN__ plan")
    let _path = _emit_helper()
    let py = _detect_python3()
    println("helper_emitted=" + HELPER_PATH)
    println("python3_detected=" + py)
    println("__AN11_MISTRAL7B_DISPATCH_RESULT__ HELPER_READY")
    println("fix: 1) " + py + " " + HELPER_PATH + "  2) interpret JSON dispatch plan + offers  3) review + decide fire")
    println("raw_10_caveat=NO ACTUAL DISPATCH — plan emit only. user-fire required for vastai create instance.")
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_plan = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--plan" { has_plan = true }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_plan { _plan() }
    else {
        println("usage: hexa run tool/anima_an11_mistral7b_dispatch.hexa --selftest | --plan")
        println("AN11(a)+(b)+(c)+V1' framework vast.ai dispatch (Mistral-7B alt for gated Llama-3)")
    }
    return 0
}
