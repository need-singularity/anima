// tool/anima_pixie_deep_audit.hexa — cycle 82 pixie deep audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 70에서 "Discord translator + brand + worker" 분류 → 미세 부정확.
//   cycle 82 deep audit: pixie의 정확한 역할 + anima cross-link 측정.
//
// FINDINGS (2026-04-27)
//
//   Identity: "Pixie — Channel secretary for the need-singularity Discord server"
//             Hand-run (not autonomous). Cloudflare Workers platform.
//
//   Commands (README §"What it does"):
//     pixie topic-sync   : 8 project channels의 canonical topic 적용 (config/topics.json)
//     pixie channels     : 현재 서버 channel tree + topics 출력
//     pixie welcome <id> : 신규 onboarding DM
//     pixie apply-full   : one-shot bootstrap (2026-04-24)
//
//   Managed channels (8):
//     🧠-anima           Consciousness implementation
//     🔭-nexus           Universal Discovery Engine
//     🏗️-n6-architecture  Architecture from perfect number 6
//     💎-hexa-lang       The Perfect Number Programming Language
//     🐝-hive            pi-mono fork — AI-agent swarm
//     🕳️-void            Ghostty fork — AI-native terminal
//     🧬-airgenome       OS genome scanner — hexagon projection
//     🔥-campfire        off-work hangout
//
//   Subdirs:
//     bin/                : CLI entry
//     brand/              : assets
//     config/             : topics.json + bot config
//     discord-translator/ : translator sub-app
//     worker/             : Cloudflare Workers source
//
//   File extension counts (excluding .git):
//     1172 js / 884 ts / 289 md
//     (cycle 70 reported 4183 — node_modules 또는 dist 포함; 실 source ~2345)
//
//   Cross-link to anima: 1 file containing "anima|ANIMA" in *.md/*.ts/*.hexa
//                        = Discord channel description ONLY. anima governance
//                        / SSOT / .own 와 직접 의존 0.
//
// CATEGORY (cycle 70 정밀화)
//   기존: active_dev_app — Discord translator + brand + worker
//   갱신: active_dev_app — Discord channel secretary (8-channel) on Cloudflare Workers
//                          + discord-translator subdir + brand assets
//
// NON_MUTATION
//   pixie 안 건드림. memory project_workspace.md만 라인 정밀화.
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - cycle 70 분류는 metadata-only (subdirs 이름 추정). cycle 82 README inspection으로
//     "Discord translator"가 아니라 "Discord channel secretary" 더 정확.
//   - 4183 → 2345 source files difference는 node_modules/dist 포함 여부.
//   - pixie는 anima의 운영 의존 0 (Discord 채널 description 외에 무관).

let HELPER_PATH = "/tmp/anima_pixie_deep_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima pixie deep audit — emitted by tool/anima_pixie_deep_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/pixie_deep_audit.json')\n\n")

    parts.push("identity = {\n")
    parts.push("    'name':'Pixie',\n")
    parts.push("    'role':'Channel secretary for need-singularity Discord server',\n")
    parts.push("    'execution_model':'hand-run (not autonomous)',\n")
    parts.push("    'platform':'Cloudflare Workers',\n")
    parts.push("    'license':'MIT',\n")
    parts.push("}\n\n")

    parts.push("commands = [\n")
    parts.push("    {'cmd':'pixie topic-sync', 'role':'8 channel topics 적용 (config/topics.json idempotent)'},\n")
    parts.push("    {'cmd':'pixie channels', 'role':'channel tree + topics 출력'},\n")
    parts.push("    {'cmd':'pixie welcome <user_id>', 'role':'신규 onboarding DM'},\n")
    parts.push("    {'cmd':'pixie apply-full', 'role':'one-shot bootstrap (2026-04-24)'},\n")
    parts.push("]\n\n")

    parts.push("managed_channels = [\n")
    parts.push("    {'channel':'🧠-anima', 'topic':'Consciousness implementation'},\n")
    parts.push("    {'channel':'🔭-nexus', 'topic':'Universal Discovery Engine'},\n")
    parts.push("    {'channel':'🏗️-n6-architecture', 'topic':'Architecture from perfect number 6'},\n")
    parts.push("    {'channel':'💎-hexa-lang', 'topic':'Perfect Number Programming Language'},\n")
    parts.push("    {'channel':'🐝-hive', 'topic':'pi-mono fork AI-agent swarm'},\n")
    parts.push("    {'channel':'🕳️-void', 'topic':'Ghostty fork AI-native terminal'},\n")
    parts.push("    {'channel':'🧬-airgenome', 'topic':'OS genome scanner hexagon projection'},\n")
    parts.push("    {'channel':'🔥-campfire', 'topic':'off-work hangout'},\n")
    parts.push("]\n\n")

    parts.push("file_metrics = {\n")
    parts.push("    'cycle_70_reported_total': 4183,\n")
    parts.push("    'cycle_82_source_count': 2345,\n")
    parts.push("    'discrepancy_explanation':'cycle 70 includes node_modules + dist (build artifacts)',\n")
    parts.push("    'source_breakdown':{'js':1172, 'ts':884, 'md':289},\n")
    parts.push("    'size_total':'320M',\n")
    parts.push("}\n\n")

    parts.push("anima_cross_link = {\n")
    parts.push("    'files_with_anima_string': 1,\n")
    parts.push("    'context':'Discord channel topic description ONLY',\n")
    parts.push("    'governance_dependency': 'NONE (anima/.own / SSOT 와 무관)',\n")
    parts.push("    'operational_coupling': 'minimal — pixie가 anima Discord 채널의 topic만 관리',\n")
    parts.push("}\n\n")

    parts.push("memory_action = {\n")
    parts.push("    'memory_file':'~/.claude-claude11/projects/-Users-ghost-core-anima/memory/project_workspace.md',\n")
    parts.push("    'edit':'pixie 라인 정밀화: Discord translator → Discord channel secretary (8-channel)',\n")
    parts.push("    'rationale':'cycle 70 metadata-only 분류를 README inspection으로 정확화',\n")
    parts.push("}\n\n")

    parts.push("category_revision = {\n")
    parts.push("    'cycle_70_classification': 'active_dev_app: Discord translator + brand + worker',\n")
    parts.push("    'cycle_82_revised':'active_dev_app: Discord channel secretary on Cloudflare Workers + discord-translator subdir + brand assets',\n")
    parts.push("    'category_unchanged': True,\n")
    parts.push("}\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'다른 4 미상 repo (secret/gohive.sh/hexa-os/skynet-timer) deep audit', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("    {'action':'cycle 70 helper의 file count 분모 (node_modules 포함 여부) memory note', 'priority':'very-low'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 82 — pixie deep audit (cycle 70 metadata 위)',\n")
    parts.push("    'cycle': 82,\n")
    parts.push("    'identity': identity,\n")
    parts.push("    'commands': commands,\n")
    parts.push("    'managed_channels': managed_channels,\n")
    parts.push("    'file_metrics': file_metrics,\n")
    parts.push("    'anima_cross_link': anima_cross_link,\n")
    parts.push("    'memory_action': memory_action,\n")
    parts.push("    'category_revision': category_revision,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'non_mutation_guarantee':'pixie 안 건드림; memory edit는 main session 직접',\n")
    parts.push("    'cross_link_cycles':['cycle 36 inventory','cycle 70 5-repo metadata categorization','cycle 77 void claim drift verification (similar deep audit pattern)'],\n")
    parts.push("    'pattern':'governance audit chain layer 60 (cycle 70 미상 5 repo 중 1 deep audit — pixie 정밀화)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[pixie_deep] cycle=82 role=channel_secretary channels=8 anima_cross_link=light category=active_dev_app -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_DEEP")
    println("inv:cycle=82")
    println("inv:identity=Discord_channel_secretary")
    println("inv:managed_channels=8")
    println("inv:anima_cross_link=light")
    println("inv:category_unchanged=true")
    println("inv:cross_link_cycles=36,70,77")
    return true
}

fn cmd_selftest() {
    println("── anima_pixie_deep_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 82 — pixie deep audit; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
