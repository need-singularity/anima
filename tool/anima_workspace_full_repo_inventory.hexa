// tool/anima_workspace_full_repo_inventory.hexa — full $WS repo inventory (cycle 32 + 35 extension; raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   memory project_workspace.md mentions only 3 repos (anima/hexa-lang/airgenome).
//   cycle 32 audit verified those. cycle 36 extends — full $WS top-level git repo enumeration.
//   Real discovery: hexa-os, hive, n6-architecture, nexus, papers, pi-telegram, pixie 등 추가 repos.
//
//   본 helper = mac-local NON_MUTATION:
//     - $WS top-level all dirs walk
//     - 각각 .git 존재 여부 → repo or non-repo
//     - 각 repo: HEAD + .gitignore raw#9 + .roadmap presence
//     - selftest verifies: ≥10 repos / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/workspace_full_repo_inventory.json)
//   ANIMA_WS          workspace root (default: /Users/ghost/core)
//
// OUTPUT
//   - all_dirs: list of {name, is_git_repo, head, raw9_py_blanket, has_roadmap, has_readme}
//   - memory_known_repos: 3 (cycle 32)
//   - new_repos_discovered: not in memory's 3
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_workspace_full_repo_inventory.hexa --selftest
//   ANIMA_OUTPUT=state/workspace_full_repo_inventory.json hexa run tool/anima_workspace_full_repo_inventory.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - top-level only enumeration; nested repos 미고려.
//   - HEAD/branch는 subprocess git; failure 시 None.
//   - "memory_known"은 anima/hexa-lang/airgenome 3 repos만 — 추가 발견 시 memory update 권장.

let HELPER_PATH = "/tmp/anima_workspace_full_repo_inventory_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima workspace full repo inventory — emitted by tool/anima_workspace_full_repo_inventory.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION full $WS repo inventory.\n")
    parts.push("import json, os, sys, subprocess\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/workspace_full_repo_inventory.json')\n")
    parts.push("WS = os.environ.get('ANIMA_WS', '/Users/ghost/core')\n\n")

    parts.push("MEMORY_KNOWN_REPOS = ['anima', 'hexa-lang', 'airgenome']\n\n")

    parts.push("def _read_lines(path):\n")
    parts.push("    if not os.path.exists(path): return []\n")
    parts.push("    try:\n")
    parts.push("        with open(path, encoding='utf-8') as f: return f.read().splitlines()\n")
    parts.push("    except Exception: return []\n\n")

    parts.push("def _has_py_blanket(lines):\n")
    parts.push("    return any(l.strip() in ('**/*.py', '*.py') for l in lines)\n\n")

    parts.push("def _git_head(path):\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['git', 'rev-parse', 'HEAD'], cwd=path, capture_output=True, text=True, timeout=5)\n")
    parts.push("        if r.returncode == 0: return r.stdout.strip()[:12]\n")
    parts.push("    except Exception: pass\n")
    parts.push("    return None\n\n")

    parts.push("if not os.path.isdir(WS):\n")
    parts.push("    summary = {'paradigm':'workspace full repo inventory', 'status':'WS_MISSING', 'workspace':WS}\n")
    parts.push("    os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("    with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("    print(f'[ws_full] status=WS_MISSING -> {OUTPUT}')\n")
    parts.push("    sys.exit(0)\n\n")

    parts.push("entries = sorted([e for e in os.listdir(WS) if os.path.isdir(os.path.join(WS, e)) and not e.startswith('.')])\n\n")

    parts.push("audit = []\n")
    parts.push("for name in entries:\n")
    parts.push("    p = os.path.join(WS, name)\n")
    parts.push("    is_git = os.path.isdir(os.path.join(p, '.git'))\n")
    parts.push("    if not is_git:\n")
    parts.push("        audit.append({'name':name, 'is_git_repo':False})\n")
    parts.push("        continue\n")
    parts.push("    gi = _read_lines(os.path.join(p, '.gitignore'))\n")
    parts.push("    audit.append({\n")
    parts.push("        'name':name,\n")
    parts.push("        'is_git_repo':True,\n")
    parts.push("        'head':_git_head(p),\n")
    parts.push("        'raw9_py_blanket':_has_py_blanket(gi),\n")
    parts.push("        'has_roadmap':os.path.exists(os.path.join(p, '.roadmap')),\n")
    parts.push("        'has_readme':os.path.exists(os.path.join(p, 'README.md')),\n")
    parts.push("        'memory_known':name in MEMORY_KNOWN_REPOS,\n")
    parts.push("    })\n\n")

    parts.push("git_repos = [a for a in audit if a.get('is_git_repo')]\n")
    parts.push("non_repos = [a for a in audit if not a.get('is_git_repo')]\n")
    parts.push("memory_known = [a for a in git_repos if a.get('memory_known')]\n")
    parts.push("new_discovered = [a for a in git_repos if not a.get('memory_known') and not a['name'].startswith('archive-')]\n")
    parts.push("archives = [a for a in git_repos if a['name'].startswith('archive-')]\n")
    parts.push("with_raw9 = sum(1 for a in git_repos if a.get('raw9_py_blanket'))\n")
    parts.push("with_roadmap = sum(1 for a in git_repos if a.get('has_roadmap'))\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'$WS full repo inventory (cycle 32 + 35 extension)',\n")
    parts.push("    'workspace':WS,\n")
    parts.push("    'all_dirs':audit,\n")
    parts.push("    'total_dirs':len(audit),\n")
    parts.push("    'git_repos_count':len(git_repos),\n")
    parts.push("    'non_repo_dirs_count':len(non_repos),\n")
    parts.push("    'non_repo_dirs_list':[a['name'] for a in non_repos],\n")
    parts.push("    'memory_known_repos':[a['name'] for a in memory_known],\n")
    parts.push("    'new_repos_discovered':[a['name'] for a in new_discovered],\n")
    parts.push("    'archive_repos':[a['name'] for a in archives],\n")
    parts.push("    'with_raw9_py_blanket':with_raw9,\n")
    parts.push("    'with_roadmap':with_roadmap,\n")
    parts.push("    'discovery_implication':'memory project_workspace.md should expand from 3 repos to full WS coverage OR explicitly scope to anima ecosystem subset',\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify any repo; read-only inventory',\n")
    parts.push("    'cross_link_cycles':['cycle 32 $WS sibling repos (3-repo subset)','cycle 35 $WS archives','cycle 25 memory project_workspace.md staleness'],\n")
    parts.push("    'pattern':'governance audit chain layer 16 (cycles 21-35 + this)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[ws_full] dirs={len(audit)} git_repos={len(git_repos)} non_repos={len(non_repos)} memory_known={len(memory_known)}/3 new_discovered={len(new_discovered)} archives={len(archives)} with_raw9={with_raw9} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let memory_known_count = 3
    let memory_known_list = "anima,hexa-lang,airgenome"
    let non_mutation = "READ_ONLY"
    println("inv:memory_known_count=" + to_string(memory_known_count))
    println("inv:memory_known_list=" + memory_known_list)
    println("inv:non_mutation=" + non_mutation)
    println("inv:cross_link_cycle32_cycle35_cycle25=true")
    println("inv:archive_prefix_special_classification=true")
    println("inv:subprocess_timeout_5s=true")
    return true
}

fn cmd_selftest() {
    println("── anima_workspace_full_repo_inventory selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=$WS full repo inventory (memory-known + new discovered + archives; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
