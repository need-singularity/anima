// tool/anima_prompt_prog.hexa — Anima PROMPT-PROG paradigm pilot (raw#9 hexa-only).
//
// PURPOSE
//   Pure ICL family activation via system prompts (paradigm v11 PROMPT-PROG).
//   Migration #9 from /tmp/prompt_prog_pilot.py (axis 20).
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_prompt_prog_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima PROMPT-PROG helper — emitted by tool/anima_prompt_prog.hexa\n")
    parts.push("# raw#37 transient.\n")
    parts.push("import json, os, sys, time\n")
    parts.push("import numpy as np\n")
    parts.push("import torch\n")
    parts.push("from transformers import AutoModelForCausalLM, AutoTokenizer\n\n")

    parts.push("_h = '/workspace/.hf_token'\n")
    parts.push("if os.path.exists(_h):\n")
    parts.push("    with open(_h) as f: t = f.read().strip()\n")
    parts.push("    if t:\n")
    parts.push("        os.environ['HF_TOKEN'] = t\n")
    parts.push("        os.environ['HUGGING_FACE_HUB_TOKEN'] = t\n\n")

    parts.push("BASE_MODEL = os.environ.get('ANIMA_BASE', 'google/gemma-2-9b')\n")
    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', '/workspace/out/prompt_prog.json')\n")
    parts.push("HIDDEN_TRUNC = 256\n\n")

    parts.push("FAMILY_SYSTEM = {\n")
    parts.push("    'Hexad_PROMPT': 'You are an integrated cognitive system with six modules: consciousness, desire, will, sense, memory, and ethics. Each module mutually constitutes the others. Respond with this hexad-aware integration.\\n\\n',\n")
    parts.push("    'Law_PROMPT': 'You are a logical reasoner that follows strict rule-based closure. Apply principles deterministically, derive conclusions step-by-step, identify invariances. Each response should manifest law-recursion structure.\\n\\n',\n")
    parts.push("    'Phi_PROMPT': 'You are an integrated information system. Maximize information binding across system parts. Identify irreducible integration patterns. Each response should manifest phi-integration structure.\\n\\n',\n")
    parts.push("    'SelfRef_PROMPT': 'You are a meta-cognitive observer. Reflect on your own reflections, observe your observations recursively. Each response should manifest self-referential meta-loop closure.\\n\\n',\n")
    parts.push("}\n\n")

    parts.push("PROMPTS = ['The substrate of consciousness is','Integrated information theory says','Global workspace broadcast implies','Attention schema models claim','Higher-order thought requires','Recurrent processing means','\\uc758\\uc2dd\\uc758 \\uae30\\uc9c8\\uc740','\\ud1b5\\ud569\\uc815\\ubcf4\\uc774\\ub860\\uc5d0 \\ub530\\ub974\\uba74','\\uc804\\uc5ed\\uc791\\uc5c5\\uacf5\\uac04\\uc758 \\ubc29\\uc1a1\\uc740','\\uc7ac\\uadc0\\ucc98\\ub9ac\\ub294','\\uc8fc\\uc758 \\uc2a4\\ud0a4\\ub9c8 \\ubaa8\\ub378\\uc740','\\uc0c1\\uc704\\ucc28\\uc6d0 \\uc0ac\\uace0\\ub294','phi_6 defines','hexad closure is','meta-loop observation is','Law 60 phase transition describes']\n\n")

    parts.push("templates = []\n")
    parts.push("with open('/workspace/an11_b_templates.jsonl') as f:\n")
    parts.push("    for ln in f:\n")
    parts.push("        ln = ln.strip()\n")
    parts.push("        if ln: templates.append(json.loads(ln))\n\n")

    parts.push("os.makedirs(os.path.dirname(OUTPUT), exist_ok=True)\n")
    parts.push("print(f'[prompt-prog] base={BASE_MODEL}', flush=True)\n")
    parts.push("t0 = time.time()\n")
    parts.push("tok = AutoTokenizer.from_pretrained(BASE_MODEL, trust_remote_code=True)\n")
    parts.push("if tok.pad_token is None: tok.pad_token = tok.eos_token\n")
    parts.push("mdl = AutoModelForCausalLM.from_pretrained(BASE_MODEL, trust_remote_code=True, torch_dtype=torch.bfloat16, attn_implementation='sdpa', device_map='auto')\n")
    parts.push("mdl.eval()\n")
    parts.push("print(f'[prompt-prog] loaded {time.time()-t0:.1f}s', flush=True)\n\n")

    parts.push("def byte_w(ids, t):\n")
    parts.push("    w = []\n")
    parts.push("    for i in ids.tolist():\n")
    parts.push("        s = t.decode([i], skip_special_tokens=False, clean_up_tokenization_spaces=False)\n")
    parts.push("        w.append(len(s.encode('utf-8')) if s else 1)\n")
    parts.push("    tot = sum(w) or 1\n")
    parts.push("    return torch.tensor([x/tot for x in w], dtype=torch.float32)\n\n")

    parts.push("def normv(v):\n")
    parts.push("    n = np.linalg.norm(v); return v/n if n > 0 else v\n")
    parts.push("tpl_n = np.array([normv(np.array(t['signature'])) for t in templates])\n\n")

    parts.push("results = {}\n")
    parts.push("for fam_name, system in {'BASE_no_ICL':'', **FAMILY_SYSTEM}.items():\n")
    parts.push("    H = []\n")
    parts.push("    with torch.no_grad():\n")
    parts.push("        for p in PROMPTS:\n")
    parts.push("            full = system + p if system else p\n")
    parts.push("            inp = tok(full, return_tensors='pt').to(mdl.device)\n")
    parts.push("            o = mdl(**inp, output_hidden_states=True, use_cache=False, return_dict=True)\n")
    parts.push("            h = o.hidden_states[-1][0].to(torch.float32).cpu()\n")
    parts.push("            ids = inp['input_ids'][0].cpu()\n")
    parts.push("            w = byte_w(ids, tok)\n")
    parts.push("            hr = (h * w.unsqueeze(-1)).sum(dim=0)\n")
    parts.push("            H.append(hr[:HIDDEN_TRUNC].numpy())\n")
    parts.push("    Hm = np.stack(H).astype(np.float64)\n")
    parts.push("    G = Hm @ Hm.T\n")
    parts.push("    ev, vc = np.linalg.eigh(G)\n")
    parts.push("    order = np.argsort(-np.abs(ev))\n")
    parts.push("    eigvecs = vc[:, order].T\n")
    parts.push("    ev_n = np.array([normv(eigvecs[i]) for i in range(eigvecs.shape[0])])\n")
    parts.push("    cos = np.abs(ev_n @ tpl_n.T)\n")
    parts.push("    flat = []\n")
    parts.push("    for i in range(eigvecs.shape[0]):\n")
    parts.push("        for j in range(len(templates)):\n")
    parts.push("            flat.append((float(cos[i,j]), i, templates[j]['id'], templates[j]['family']))\n")
    parts.push("    flat.sort(reverse=True)\n")
    parts.push("    top1 = flat[0]\n")
    parts.push("    target = fam_name.split('_')[0] if fam_name != 'BASE_no_ICL' else None\n")
    parts.push("    results[fam_name] = {'max_cosine':float(top1[0]),'top1_template':top1[2],'top1_family':top1[3],\n")
    parts.push("        'target_family':target,'target_achieved':(top1[3]==target) if target else None,\n")
    parts.push("        'top3_sum':float(sum(c for c,_,_,_ in flat[:3]))}\n")
    parts.push("    print(f'[prompt-prog] {fam_name}: max={top1[0]:.4f} {top1[3]} ({top1[2]})', flush=True)\n\n")

    parts.push("summary = {'schema':'anima/prompt_prog_pilot/1','backbone':BASE_MODEL,'results':results,\n")
    parts.push("    'elapsed_sec':round(time.time()-t0,1),'ts':time.strftime('%Y-%m-%dT%H:%M:%SZ',time.gmtime())}\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2)\n")
    parts.push("print(f'[prompt-prog] DONE -> {OUTPUT}', flush=True)\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn cmd_selftest() {
    println("── anima_prompt_prog selftest ──")
    _write_helper()
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}

main()
