//   - 본 helper는 mutation을 main session Edit으로 수행했고 evidence 기록만 (NON_MUTATION).

let HELPER_PATH = "/tmp/anima_memory_broken_refs_remediation_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima memory broken refs remediation — emitted by tool/anima_memory_broken_refs_remediation.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION on anima repo.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/memory_broken_refs_remediation.json')\n\n")

    parts.push("verification_results = [\n")
    parts.push("    {\n")
    parts.push("        'memory_file':'feedback_admin_merge.md',\n")
    parts.push("        'cycle_25_count':4,\n")
    parts.push("        'real_broken':0,\n")
    parts.push("        'classification':'cycle_25_false_positive (glob + valid relative paths)',\n")
    parts.push("        'action':'no edit',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'memory_file':'feedback_batch_minpath.md',\n")
    parts.push("        'cycle_25_count':1,\n")
    parts.push("        'real_broken':1,\n")
    parts.push("        'broken_path':'shared/tool/minimal_path.json',\n")
    parts.push("        'classification':'real_broken — file 부재',\n")
    parts.push("        'action':'edit — ref 텍스트 갱신 (live policy 직접 기술)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'memory_file':'project_aot_push_gotcha.md',\n")
    parts.push("        'cycle_25_count':1,\n")
    parts.push("        'real_broken':0,\n")
    parts.push("        'classification':'cycle_25_false_positive (valid hexa path)',\n")
    parts.push("        'action':'no edit',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'memory_file':'project_h100_launch_pending.md',\n")
    parts.push("        'cycle_25_count':1,\n")
    parts.push("        'real_broken':0,\n")
    parts.push("        'classification':'self_resolved_via_cycle_64_66 (full overwrite)',\n")
    parts.push("        'action':'no edit (이전 cycles에서 처리)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'memory_file':'project_hexa_toolchain.md',\n")
    parts.push("        'cycle_25_count':1,\n")
    parts.push("        'real_broken':1,\n")
    parts.push("        'broken_path':'/opt/homebrew/bin/hexa',\n")
    parts.push("        'classification':'real_broken — homebrew hexa 부재 (live wrapper at /Users/ghost/core/hexa-lang/hexa)',\n")
    parts.push("        'action':'edit — path 갱신',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'memory_file':'project_workspace.md',\n")
    parts.push("        'cycle_25_count':7,\n")
    parts.push("        'real_broken':0,\n")
    parts.push("        'classification':'self_resolved_via_cycle_69_70 (full rewrite)',\n")
    parts.push("        'action':'no edit (이전 cycles에서 처리)',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("classification_counts = {\n")
    parts.push("    'cycle_25_false_positive': 2,\n")
    parts.push("    'self_resolved_prior_cycles': 2,\n")
    parts.push("    'real_broken_resolved_cycle_74': 2,\n")
    parts.push("    'remaining_broken': 0,\n")
    parts.push("}\n\n")

    parts.push("cycle_25_helper_critique = {\n")
    parts.push("    'helper':'tool/anima_memory_dir_staleness_auditor.hexa (cycle 25)',\n")
    parts.push("    'finding':'15 BROKEN_PATH_REFS reported across 6 files; cycle 74 verification → 2 real broken',\n")
    parts.push("    'false_positive_class':'glob patterns (iter_*.json), relative paths (config/growth_state.json), valid hexa paths',\n")
    parts.push("    'recommendation':'cycle 25 helper의 path resolution을 cycle 74 fs-check 패턴으로 재구현 — 별개 cluster',\n")
    parts.push("}\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'cycle 25 helper validation logic 재구현 (glob + relative path 정확 처리)', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("    {'action':'cycle 25 audit 재실행으로 staleness=0 검증', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 74 — memory broken_refs 정리 (cycle 25 finding 검증 + 정밀화)',\n")
    parts.push("    'cycle': 74,\n")
    parts.push("    'cycle_25_initial_count': 15,\n")
    parts.push("    'cycle_74_real_broken_count': 2,\n")
    parts.push("    'cycle_74_resolved_count': 2,\n")
    parts.push("    'verification_results': verification_results,\n")
    parts.push("    'classification_counts': classification_counts,\n")
    parts.push("    'cycle_25_helper_critique': cycle_25_helper_critique,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'non_mutation_guarantee':'본 helper는 anima repo state 수정 안 함; memory file edits는 main session Edit tool으로 직접 수행',\n")
    parts.push("    'cross_link_cycles':['cycle 25 staleness audit (initial)','cycle 64 h100 memory rewrite','cycle 66 h100 closure','cycle 69 workspace rewrite','cycle 70 5-repo categorization'],\n")
    parts.push("    'pattern':'governance audit chain layer 53 (cycle 25 finding 검증 + 정밀 해결)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[memory_broken_refs] cycle=74 cycle25_initial=15 real_broken=2 resolved_cycle74=2 remaining=0 -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_EVIDENCE")
    println("inv:cycle=74")
    println("inv:cycle25_initial_count=15")
    println("inv:real_broken=2")
    println("inv:resolved_cycle74=2")
    println("inv:remaining=0")
    println("inv:cross_link_cycles=25,64,66,69,70")
    return true
}

fn cmd_selftest() {
    println("── anima_memory_broken_refs_remediation selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 74 — memory broken_refs verify+fix; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
