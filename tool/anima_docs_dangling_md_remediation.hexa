// tool/anima_docs_dangling_md_remediation.hexa — cycle 73 docs/TOC.md 22 dangling links 정리 (raw#9 hexa-only).
//
// PURPOSE
//   cycle 24 audit (state/docs_dir_md_integrity_auditor.json) 발견:
//     22 dangling internal links — 모두 source = docs/TOC.md
//
//   cycle 73에서 직접 Edit tool로 docs/TOC.md 정리 후 본 helper는 evidence 기록.
//
// FINDINGS (cycle 73 직접 inspection)
//   3 broken section heads in docs/TOC.md:
//     1) ## CLAUDE.md (line 53)              — CLAUDE.md retired (memory)
//     2) ## airgenome_roadmap_integration... (line 175) — file 부재 (worktree 안에만)
//     3) ## discovery-algorithm-anima-anima... (line 914) — file 부재 (ready/ 안에만)
//
//   broken target file 위치:
//     - airgenome_roadmap_integration_design_20260421.md
//         → .claude/worktrees/agent-*/docs/  (5+ worktree에만 있음)
//     - discovery-algorithm-anima-anima.md
//         → ready/docs/, .claude/worktrees/agent-*/docs/  (main repo 부재)
//     - CLAUDE.md
//         → 모든 위치에서 retired (memory project_claude_md_retired)
//
// ACTION TAKEN
//   3 sections 통째 제거 (heading + sub-bullets + trailing blank).
//   docs/TOC.md: 2377 lines → 2350 lines (-27 lines, -22 dangling links + 5 blank/heading)
//
// VERIFICATION
//   grep "airgenome_roadmap_integration_design_20260421\|discovery-algorithm-anima-anima\|^## CLAUDE\.md\|CLAUDE\.md#docs----" docs/TOC.md
//   → 0 matches (cycle 73 직접 검증)
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - file 부재 cause는 worktree/ready/ 분리 — main repo TOC가 미발표 docs를
//     pre-register했던 결과로 추정.
//   - 향후 docs가 main repo에 promote되면 TOC.md 다시 추가 (재생성 helper 또는 manual).
//   - cycle 24 helper 재실행으로 dangling=0 검증은 별도 cycle에서 가능.

let HELPER_PATH = "/tmp/anima_docs_dangling_md_remediation_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima docs dangling md remediation — emitted by tool/anima_docs_dangling_md_remediation.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION (cycle 73 직접 Edit으로 TOC.md 수정 완료; 본 helper는 evidence 기록).\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/docs_dangling_md_remediation.json')\n\n")

    parts.push("removed_sections = [\n")
    parts.push("    {\n")
    parts.push("        'heading':'## CLAUDE.md',\n")
    parts.push("        'lines_estimated':3,\n")
    parts.push("        'links_removed':1,\n")
    parts.push("        'reason':'CLAUDE.md retired per memory project_claude_md_retired',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'heading':'## airgenome_roadmap_integration_design_20260421.md',\n")
    parts.push("        'lines_estimated':10,\n")
    parts.push("        'links_removed':9,\n")
    parts.push("        'reason':'file 부재 in main repo; .claude/worktrees/agent-*/docs/ 에만 존재',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'heading':'## discovery-algorithm-anima-anima.md',\n")
    parts.push("        'lines_estimated':14,\n")
    parts.push("        'links_removed':12,\n")
    parts.push("        'reason':'file 부재 in main repo; ready/docs/ 와 worktrees에 있음',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("file_metrics = {\n")
    parts.push("    'file':'docs/TOC.md',\n")
    parts.push("    'lines_before':2377,\n")
    parts.push("    'lines_after':2350,\n")
    parts.push("    'lines_delta':-27,\n")
    parts.push("    'dangling_links_before':22,\n")
    parts.push("    'dangling_links_after':0,\n")
    parts.push("    'verification':'grep returned 0 matches for all 3 broken patterns',\n")
    parts.push("}\n\n")

    parts.push("preserved_invariants = [\n")
    parts.push("    'docs/TOC.md 다른 sections 모두 그대로 (407 md files 중 22 broken만 제거)',\n")
    parts.push("    'frontmatter_compliance unchanged (cycle 24 finding 0% compliance — 별개 issue)',\n")
    parts.push("    'no other md files modified',\n")
    parts.push("]\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'cycle 24 helper 재실행으로 dangling=0 cross-verify', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("    {'action':'frontmatter 0% compliance — 별도 cluster', 'priority':'medium', 'cost':'mac $0 (각 md 헤더 추가)'},\n")
    parts.push("    {'action':'worktree/ready docs main promote 정책 — TOC pre-register 정책 결정', 'priority':'low', 'cost':'사용자 정책 영역'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 73 — docs/TOC.md 22 dangling internal links 정리 (cycle 24 finding 해결)',\n")
    parts.push("    'cycle': 73,\n")
    parts.push("    'helper_role':'evidence record only (mutation 직접 Edit tool으로 cycle 73 main session에서)',\n")
    parts.push("    'removed_sections': removed_sections,\n")
    parts.push("    'file_metrics': file_metrics,\n")
    parts.push("    'preserved_invariants': preserved_invariants,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'non_mutation_guarantee':'본 helper는 어떤 파일도 modify 안 함; mutation은 main session Edit tool 직접 수행',\n")
    parts.push("    'cross_link_cycles':['cycle 24 docs integrity audit (initial finding)','memory project_claude_md_retired (CLAUDE.md retired evidence)'],\n")
    parts.push("    'pattern':'governance audit chain layer 52 (cycle 24 finding 실 해결)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[docs_dangling] cycle=73 sections_removed=3 links_removed=22 lines_delta=-27 -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_EVIDENCE")
    println("inv:cycle=73")
    println("inv:dangling_before=22")
    println("inv:dangling_after=0")
    println("inv:sections_removed=3")
    println("inv:cross_link_cycles=24,memory_claude_md_retired")
    return true
}

fn cmd_selftest() {
    println("── anima_docs_dangling_md_remediation selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 73 — docs/TOC.md 22 dangling 해결 (cycle 24 finding); NON_MUTATION on this helper")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
