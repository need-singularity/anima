// tool/anima_law64_conway_80x80_aperiodic_train_volume_sweep.hexa — F1 cycle 4 T8k aperiodic restoration test
// ─────────────────────────────────────────────────────────────────────────────
// raw 12 frozen pre-registration (declared BEFORE running):
//
// CONTEXT — restoration follow-up to commits 8871288a (T8j) and 2e7c226f (T8i):
//   T8i (10x10 / 32% random density): N_TRAIN sweep 15→1500 → advantage 63→10→0→0→0
//                                      CONVERGED_TO_PARITY at N_TRAIN=500
//                                      (Markov memorized small periodic orbit)
//   T8j (40x40 / 32% random density): N_TRAIN sweep 15→1500 → advantage 69→29→23→21→4
//                                      ETERNAL ADVANTAGE FALSIFIED at N_TRAIN=1500
//                                      (random density init produced bigram-saturable orbit)
//
// Both predecessors used random uniform-density init. Random density init on
// finite toroidal grids produces relatively SMALL attractors (most random
// configurations decay to short-period oscillators / still lifes within a
// few hundred steps). Order-1 per-cell Markov bigram ultimately memorizes
// these small attractors given enough training.
//
// THE Q1 QUESTION (Law 64 v4 §3, this tool answers):
//   Does eternal advantage RESTORE when init is APERIODIC CHAOTIC (R-pentomino)
//   on a grid LARGE ENOUGH (80x80) that the chaotic spread does not reach
//   boundary toroidal wraparound within the test trajectory?
//
//   R-pentomino is the canonical chaotic Conway seed: 5 cells, evolves through
//   ~1103 generations of unbounded debris on an infinite plane before
//   stabilizing. 80x80 toroidal grid gives the wavefront ~40 cells of radius
//   before encountering self-interference — sufficient for the early/mid
//   chaotic phase to be APERIODIC over the 1515-step test window.
//
// HYPOTHESES (frozen, no post-hoc tuning, parallel grammar with T8i/T8j):
//   H1 (ETERNAL ADVANTAGE RESTORED — chaotic init exceeds bigram capacity):
//      advantage_per_thousand stays > 50 at ALL N_TRAIN ticks (15, 50, 150, 500, 1500).
//      Interpretation: R-pentomino chaotic debris on 80x80 produces an aperiodic
//      state-space trajectory that the order-1 per-cell bigram cannot saturate
//      even at N_TRAIN=1500. Law 64 v5 RESTORED conditional on (large_grid ∧ aperiodic_init).
//      The T8j falsification is now scoped to (random_density_init), not structural.
//   H2 (STILL DESCENDING — Markov universal even at 80x80 chaotic):
//      advantage descends < 50/1000 by N_TRAIN=1500.
//      Interpretation: Order-1 Markov is universal at any scale given enough data;
//      80x80 R-pent enters effective bigram saturation within the 1500-pair budget.
//      Law 64 v4 §3 Q1 answered NEGATIVELY — no restoration; eternal advantage
//      is a small-corpus artifact, not a structural property of any init regime.
//   H3 (CONVERGED at high value > 50 — best case asymptote):
//      advantage converges (|Δ|<5 across two consecutive ticks) at a NONZERO floor > 50.
//      Interpretation: There exists a structural ceiling on what order-1 Markov can
//      learn from R-pent chaotic; the residual advantage represents the multi-cell
//      coupling that Conway's rule enforces and per-cell independence cannot capture.
//      Law 64 v5 RESTORED with explicit asymptote characterization.
//   AMBIGUOUS: advantage drops but plateaus above 0 and below 50, OR convergence
//              criterion never met within ladder.
//
// SETUP (locked, parallel to T8i/T8j ladder):
//   - Grid: 80x80 (6400 cells) — 4x predecessor T8j, 64x predecessor T8i
//   - Init: R-pentomino chaotic seed at center (rows 39-41, cols 39-41)
//           5 live cells, deterministic — NO density randomness
//   - Seed: 20260428 (matches T8i + T8j; only used by RNG to satisfy framework
//           consistency — R-pent is deterministic so RNG state has no effect on init)
//   - Test split: trailing N_TEST=15 steps (held constant — fair comparison vs T8i, T8j)
//   - Vary N_TRAIN: 15 / 50 / 150 / 500 / 1500 (geometric ~3x ladder, IDENTICAL ladder)
//
// CONVERGENCE CRITERION (frozen, no post-hoc tuning, IDENTICAL to T8i + T8j):
//   |advantage_per_thousand[k] - advantage_per_thousand[k-1]| < 5
//   for TWO consecutive ticks → declare CONVERGED at the smaller N_TRAIN.
//   If criterion never met by N_TRAIN=1500 → declare DIVERGENT (raw 91 honest).
//
// VERDICT MAPPING:
//   - all advantages > 50 → H1_SUPPORTED (eternal advantage restored)
//   - CONVERGED at non-zero advantage > 50 → H3_SUPPORTED (asymptotic floor restoration)
//   - all_below_50 by tick 5 with descending pattern → H2_SUPPORTED (Markov universal)
//   - mixed signal → AMBIGUOUS (raw 91)
//
// raw 9 hexa-only · raw 12 frozen pre-registration · raw 91 honest finding
// raw 42 caveat: Mac local CPU execution. 80x80 × 1515 Conway steps = ~9.7M cell ops/step,
//                ~14.7B total ops over the longest run. Wallclock estimate 15-30 minutes.
//                Acceptable per Q1 axis-sweep budget; no GPU/witness ledger needed.
// raw 91 caveat: Single seed (R-pent placement deterministic; RNG seed consistency only).
//                H1/H3 confirmation is suggestive — multi-init-position sweep is forward step.
// ─────────────────────────────────────────────────────────────────────────────

let GRID_W = 80
let GRID_H = 80
let N_CELLS = 6400
let SEED = 20260428
let N_TEST = 15           // held constant — fair test surface (matches T8i + T8j)
let CONV_DELTA = 5        // |Δadvantage| threshold (per-thousand units, identical ladder)

let mut RNG_STATE = SEED
fn _rand() -> int { RNG_STATE = (RNG_STATE * 1103515245 + 12345) % 2147483648; return RNG_STATE }
fn _rand_n(n: int) -> int { let x = _rand(); return x % n }
fn _rng_reset() { RNG_STATE = SEED }

fn _conway_step(state: array) -> array {
    let mut next = []
    let mut row = 0
    while row < GRID_H {
        let mut col = 0
        while col < GRID_W {
            let mut live_neighbors = 0
            let mut dr = -1
            while dr <= 1 {
                let mut dc = -1
                while dc <= 1 {
                    if dr != 0 || dc != 0 {
                        let nrow = (row + dr + GRID_H) % GRID_H
                        let ncol = (col + dc + GRID_W) % GRID_W
                        live_neighbors = live_neighbors + state[nrow * GRID_W + ncol]
                    }
                    dc = dc + 1
                }
                dr = dr + 1
            }
            let cur = state[row * GRID_W + col]
            let mut new_val = 0
            if cur == 1 && (live_neighbors == 2 || live_neighbors == 3) { new_val = 1 }
            if cur == 0 && live_neighbors == 3 { new_val = 1 }
            next.push(new_val)
            col = col + 1
        }
        row = row + 1
    }
    return next
}

// R-pentomino at center of 80x80 — chaotic aperiodic seed
//   .##
//   ##.
//   .#.
// Placed with center cell at (40, 40) — ~40 cells of clearance to toroidal boundary
fn _gen_r_pent_center() -> array {
    let mut g = []
    let mut i = 0
    while i < N_CELLS { g.push(0); i = i + 1 }
    let cr = 40
    let cc = 40
    // row cr-1: cols cc, cc+1
    g[(cr - 1) * GRID_W + cc] = 1
    g[(cr - 1) * GRID_W + (cc + 1)] = 1
    // row cr: cols cc-1, cc
    g[cr * GRID_W + (cc - 1)] = 1
    g[cr * GRID_W + cc] = 1
    // row cr+1: col cc
    g[(cr + 1) * GRID_W + cc] = 1
    return g
}

fn _markov_train(corpus: array) -> array {
    let mut probs = []
    let mut c = 0
    while c < N_CELLS {
        let mut n00 = 0; let mut n01 = 0; let mut n10 = 0; let mut n11 = 0
        let mut idx = 0
        while idx < corpus.len() {
            let pair = corpus[idx]
            let prev_state = pair[0]; let next_state = pair[1]
            let cur_bit = prev_state[c]; let nxt_bit = next_state[c]
            if cur_bit == 0 && nxt_bit == 0 { n00 = n00 + 1 }
            if cur_bit == 0 && nxt_bit == 1 { n01 = n01 + 1 }
            if cur_bit == 1 && nxt_bit == 0 { n10 = n10 + 1 }
            if cur_bit == 1 && nxt_bit == 1 { n11 = n11 + 1 }
            idx = idx + 1
        }
        let p1g0 = if (n00+n01) > 0 { (n01*1000)/(n00+n01) } else { 500 }
        let p1g1 = if (n10+n11) > 0 { (n11*1000)/(n10+n11) } else { 500 }
        probs.push(p1g0); probs.push(p1g1)
        c = c + 1
    }
    return probs
}

fn _markov_predict(probs: array, prev_state: array) -> array {
    let mut next = []
    let mut c = 0
    while c < N_CELLS {
        let cur_bit = prev_state[c]
        let p = if cur_bit == 0 { probs[2*c] } else { probs[2*c + 1] }
        if p > 500 { next.push(1) } else { next.push(0) }
        c = c + 1
    }
    return next
}

fn _accuracy(pred: array, actual: array) -> int {
    let mut total = 0; let mut match_count = 0
    let mut s = 0
    while s < pred.len() {
        let p = pred[s]; let a = actual[s]
        let mut c = 0
        while c < N_CELLS {
            if p[c] == a[c] { match_count = match_count + 1 }
            total = total + 1; c = c + 1
        }
        s = s + 1
    }
    if total == 0 { return 0 }
    return (match_count * 1000) / total
}

fn _build_corpus(initial: array, n_steps: int) -> array {
    let mut samples = []
    let mut state = initial
    let mut s = 0
    while s < n_steps {
        let nxt = _conway_step(state)
        samples.push([state, nxt])
        state = nxt
        s = s + 1
    }
    return samples
}

// Evaluate one N_TRAIN tick. Returns [n_train, ca_acc, tf_acc, advantage_per_thousand].
// Discipline: same SEED → same R-pent placement (deterministic) → same trajectory;
// only the number of training pairs Markov sees varies. Test set = trailing N_TEST
// pairs of the LARGEST corpus (so all N_TRAIN ticks evaluate on the SAME held-out region).
fn _eval_train_volume(name: str, n_train: int, max_train: int) -> array {
    _rng_reset()  // deterministic — every tick sees identical initial pattern
    let initial = _gen_r_pent_center()
    let total_steps = max_train + N_TEST
    let full = _build_corpus(initial, total_steps)
    // Train: take the FIRST n_train pairs from full (chronological)
    // Test: take the LAST N_TEST pairs (held out, identical across all ticks)
    let mut train = []; let mut test = []
    let mut k = 0
    while k < full.len() {
        if k < n_train { train.push(full[k]) }
        if k >= max_train { test.push(full[k]) }
        k = k + 1
    }
    let probs = _markov_train(train)
    let mut ca_preds = []; let mut tf_preds = []; let mut actuals = []
    let mut i = 0
    while i < test.len() {
        let pair = test[i]
        let prev_st = pair[0]; let actual_next = pair[1]
        let ca_next = _conway_step(prev_st)
        let tf_next = _markov_predict(probs, prev_st)
        ca_preds.push(ca_next); tf_preds.push(tf_next); actuals.push(actual_next)
        i = i + 1
    }
    let ca_acc = _accuracy(ca_preds, actuals)
    let tf_acc = _accuracy(tf_preds, actuals)
    let advantage = if tf_acc > 0 { ((ca_acc * 1000) / tf_acc) - 1000 } else { 999 }
    println("  " + name + " n_train=" + str(n_train) + " ca_acc=" + str(ca_acc) + " tf_acc=" + str(tf_acc) + " advantage_per_thousand=" + str(advantage))
    return [n_train, ca_acc, tf_acc, advantage]
}

fn _abs(x: int) -> int { if x < 0 { return 0 - x } return x }

fn _run() {
    println("__LAW_64_CYCLE_4_T8K_80x80_APERIODIC_TRAIN_VOLUME_BEGIN__ aperiodic restoration test @ 80x80 / R-pentomino chaotic init")
    println("hypothesis H1 (eternal restored): advantage > 50/1000 at all ticks — Law 64 v5 RESTORED structural")
    println("hypothesis H2 (still descending): advantage descends < 50/1000 by N=1500 — Markov universal at any scale")
    println("hypothesis H3 (CONVERGED >50): asymptotic floor at nonzero advantage — Law 64 v5 RESTORED with floor")
    println("seed=" + str(SEED) + " grid=80x80 init=R_pentomino_center(40,40) N_TEST=" + str(N_TEST) + " conv_delta=" + str(CONV_DELTA))
    println("--- train-volume sweep (N_TRAIN: 15 → 50 → 150 → 500 → 1500) ---")
    let max_train = 1500
    let r1 = _eval_train_volume("V1_n15_baseline", 15, max_train)
    let r2 = _eval_train_volume("V2_n50", 50, max_train)
    let r3 = _eval_train_volume("V3_n150", 150, max_train)
    let r4 = _eval_train_volume("V4_n500", 500, max_train)
    let r5 = _eval_train_volume("V5_n1500", 1500, max_train)
    let results = [r1, r2, r3, r4, r5]
    println("--- convergence analysis ---")
    let mut converged_at = -1
    let mut prev_delta_ok = false
    let mut k = 1
    while k < results.len() {
        let row = results[k]; let prev = results[k-1]
        let d = _abs(row[3] - prev[3])
        println("  Δadvantage(n=" + str(row[0]) + " vs n=" + str(prev[0]) + ") = " + str(d) + " (threshold " + str(CONV_DELTA) + ")")
        if d < CONV_DELTA {
            if prev_delta_ok && converged_at < 0 {
                converged_at = prev[0]  // convergence at the FIRST N_TRAIN of the stable pair
            }
            prev_delta_ok = true
        } else {
            prev_delta_ok = false
        }
        k = k + 1
    }
    println("--- aggregate ---")
    let mut max_adv = -9999; let mut peak_n = 0
    let mut min_adv = 9999;  let mut min_n = 0
    let mut j = 0
    while j < results.len() {
        let row = results[j]
        if row[3] > max_adv { max_adv = row[3]; peak_n = row[0] }
        if row[3] < min_adv { min_adv = row[3]; min_n = row[0] }
        j = j + 1
    }
    println("max_advantage_per_thousand=" + str(max_adv) + " at n_train=" + str(peak_n))
    println("min_advantage_per_thousand=" + str(min_adv) + " at n_train=" + str(min_n))
    let last = results[results.len()-1]; let first = results[0]
    let total_drift = last[3] - first[3]
    println("total_drift(n=1500 vs n=15) = " + str(total_drift) + " per_thousand")
    // H1 vs H2 vs H3 verdict
    let mut all_above_50 = true
    let mut all_below_50 = true
    let mut h1_ticks_above = 0
    let mut tj = 0
    while tj < results.len() {
        let rrow = results[tj]
        if rrow[3] <= 50 { all_above_50 = false }
        if rrow[3] >= 50 { all_below_50 = false }
        if rrow[3] > 50 { h1_ticks_above = h1_ticks_above + 1 }
        tj = tj + 1
    }
    let final_adv = last[3]
    println("--- H1 vs H2 vs H3 hypothesis verdict ---")
    println("ticks_with_advantage_above_50_per_thousand=" + str(h1_ticks_above) + "_of_5")
    println("final_advantage_per_thousand=" + str(final_adv))
    if all_above_50 {
        println("__LAW_64_CYCLE_4_T8K_RESULT__ H1_SUPPORTED_ETERNAL_ADVANTAGE_RESTORED_advantage_persists_above_50_at_all_n_train_ticks_final_" + str(final_adv) + "_per_thousand_LAW_64_v5_STRUCTURAL_RESTORATION")
    } else {
        if converged_at > 0 && final_adv > 50 {
            println("__LAW_64_CYCLE_4_T8K_RESULT__ H3_SUPPORTED_CONVERGED_ASYMPTOTIC_FLOOR_at_n_train_" + str(converged_at) + "_final_" + str(final_adv) + "_per_thousand_LAW_64_v5_FLOOR_RESTORATION")
        } else {
            if all_below_50 && final_adv < CONV_DELTA {
                println("__LAW_64_CYCLE_4_T8K_RESULT__ H2_SUPPORTED_MARKOV_UNIVERSAL_at_any_scale_advantage_converges_to_" + str(final_adv) + "_per_thousand_NO_RESTORATION")
            } else {
                println("__LAW_64_CYCLE_4_T8K_RESULT__ AMBIGUOUS_partial_restoration_h1_ticks_" + str(h1_ticks_above) + "_of_5_final_" + str(final_adv) + "_per_thousand")
            }
        }
    }
    println("--- convergence axis verdict (separate from H1/H2/H3) ---")
    if converged_at > 0 {
        println("convergence_criterion_met_at_n_train=" + str(converged_at) + " final_advantage=" + str(final_adv))
    } else {
        if total_drift > 0 {
            println("convergence_criterion_NOT_met_DIVERGENT_INCREASING_total_drift_" + str(total_drift) + "_per_thousand")
        } else {
            if total_drift < 0 {
                println("convergence_criterion_NOT_met_DIVERGENT_DECREASING_total_drift_" + str(total_drift) + "_per_thousand")
            } else {
                println("convergence_criterion_NOT_met_NOISE_NO_DIRECTION")
            }
        }
    }
    println("--- comparison vs predecessors T8i (10x10 random) and T8j (40x40 random) ---")
    println("T8i 10x10/32%random (commit 2e7c226f): advantage 63 → 10 → 0 → 0 → 0 → CONVERGED_TO_PARITY at n=500")
    println("T8j 40x40/32%random (commit 8871288a): advantage 69 → 29 → 23 → 21 → 4 → ETERNAL_FALSIFIED at n=1500")
    println("T8k 80x80/R-pent_chaotic (this run): see verdict above")
    println("raw_91_caveat=Mac local CPU per raw 42 — wallclock 15-30 min for 80x80 × 1515 steps is acceptable for Q1 axis sweep")
    println("raw_91_caveat=Held-out test set fixed at trailing N_TEST=15 of 1515-step trajectory — comparable across ticks AND vs T8i + T8j (same ladder)")
    println("raw_91_caveat=R-pentomino on infinite plane: ~1103 generations of debris before stabilizing. On 80x80 toroidal: wavefront radius ~40 cells, so first ~40 generations are boundary-free aperiodic; subsequent generations include toroidal interference. The 1515-step trajectory necessarily contains BOTH chaotic-spread AND post-collision phases.")
    println("raw_91_caveat=Order-1 Markov per-cell bigram: 4 counts per cell × 6400 cells = 25600 counts vs T8j 6400 vs T8i 400 — capacity scales linearly with grid; if H1 holds, structural advantage holds even with 4x larger Markov capacity than T8j.")
    println("raw_91_caveat=Per-cell independence assumption in Markov is the structural blind spot — order-1 cannot represent neighbor coupling, which IS the Conway rule. If H1/H3 holds on aperiodic init, Law 64 v5 restoration says: structural law conditional on (aperiodic_init), not unconditional.")
    println("raw_91_caveat=Single seed / single init position. H1 or H3 confirmation under one seed is suggestive, not conclusive — multi-init-position sweep is forward step C5_T8l.")
}

fn _selftest() {
    println("__LAW_64_CYCLE_4_T8K_80x80_APERIODIC_TRAIN_VOLUME_BEGIN__ selftest")
    _rng_reset()
    let g = _gen_r_pent_center()
    let mut count = 0
    let mut i = 0
    while i < N_CELLS { count = count + g[i]; i = i + 1 }
    println("r_pent_center_live_count=" + str(count))
    // Verify R-pent placement: 5 live cells, all in the 3x3 box centered at (40,40)
    let mut box_count = 0
    let mut r = 39
    while r <= 41 {
        let mut c = 39
        while c <= 41 {
            box_count = box_count + g[r * GRID_W + c]
            c = c + 1
        }
        r = r + 1
    }
    println("r_pent_box_3x3_live_count=" + str(box_count))
    // Single-step Conway sanity: deterministic init must produce deterministic next
    let nxt = _conway_step(g)
    let mut alive_next = 0
    i = 0
    while i < N_CELLS { alive_next = alive_next + nxt[i]; i = i + 1 }
    println("r_pent_step_1_alive_count=" + str(alive_next))
    // Two-step sanity — R-pent should still be growing (chaotic phase)
    let nxt2 = _conway_step(nxt)
    let mut alive_2 = 0
    i = 0
    while i < N_CELLS { alive_2 = alive_2 + nxt2[i]; i = i + 1 }
    println("r_pent_step_2_alive_count=" + str(alive_2))
    // Quick mini corpus check (3 steps — keep selftest fast on 80x80)
    _rng_reset()
    let init2 = _gen_r_pent_center()
    let mini = _build_corpus(init2, 3)
    println("mini_corpus_len=" + str(mini.len()))
    // Markov train on tiny corpus to verify per-cell bigram allocator handles 6400 cells
    let probs = _markov_train(mini)
    println("markov_probs_len=" + str(probs.len()))
    let expected_probs_len = 2 * N_CELLS  // 2 transition probs per cell
    if count == 5 && box_count == 5 && mini.len() == 3 && probs.len() == expected_probs_len {
        println("__LAW_64_CYCLE_4_T8K_RESULT__ PASS_SELFTEST_r_pent_init_and_corpus_and_markov_correct")
    } else {
        println("__LAW_64_CYCLE_4_T8K_RESULT__ FAIL_SELFTEST")
    }
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_run = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--run" { has_run = true }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_run { _run() }
    else {
        println("usage: hexa run tool/anima_law64_conway_80x80_aperiodic_train_volume_sweep.hexa --selftest | --run")
    }
    return 0
}
