// ════════════════════════════════════════════════════════════════════════════
//  tool/secret_scanner.hexa — ROI #66 (security/compliance)
//
//  PURPOSE
//    Scan tool/ + state/ + config/ for hard-coded secrets:
//      - AWS_ACCESS_KEY    (AKIA[0-9A-Z]{16})
//      - AWS_SECRET_KEY    ([0-9a-zA-Z/+]{40} near aws_secret_access_key)
//      - HF_TOKEN          (hf_[a-zA-Z0-9]{32+})
//      - PRIVATE_KEY       (-----BEGIN .* PRIVATE KEY-----)
//      - GITHUB_TOKEN, SLACK_TOKEN, OPENAI_API_KEY
//      - GENERIC_HIGH_ENTROPY (>=32 chars near credential keyword)
//
//  DESIGN
//    raw#9   hexa-only
//    raw#10  emit append SSOT (state/secret_scan_violations.json overwrite + summary)
//    raw#11  snake_case
//    raw#15  no-hardcode (config/secret_scanner_config.json)
//    NEVER   logs full secret value — only first 4 chars + length redaction.
//    NEVER   auto-installs git pre-commit hook; manual symlink only.
//
//  USAGE
//    hexa tool/secret_scanner.hexa                          # scan all roots
//    hexa tool/secret_scanner.hexa --selftest               # synthetic fixture
//    hexa tool/secret_scanner.hexa --paths tool/foo.hexa    # restrict scope
//    hexa tool/secret_scanner.hexa --config <path>          # override config
//    hexa tool/secret_scanner.hexa --help
//
//  EXIT CODES
//    0  no violations
//    1  MEDIUM only
//    2  HIGH or CRITICAL violation present
//    3  config / setup error
// ════════════════════════════════════════════════════════════════════════════

let DEFAULT_CONFIG = "/Users/ghost/core/anima/config/secret_scanner_config.json"
let TOOL_NAME      = "secret_scanner"
let TOOL_VERSION   = "v1"

// ─── sys helpers ─────────────────────────────────────────────────────

fn _sh_quote(s: string) -> string {
    let mut out = "'"
    out = out + s.replace("'", "'\\''")
    out = out + "'"
    return out
}

fn _exec_out(cmd: string) -> string {
    let r = exec_with_status(cmd)
    return to_string(r[0])
}

fn _exec_code(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

fn _file_exists(path: string) -> bool {
    let r = exec_with_status("test -e " + _sh_quote(path))
    return r[1] == 0
}

fn _is_file(path: string) -> bool {
    let r = exec_with_status("test -f " + _sh_quote(path))
    return r[1] == 0
}

fn _mkdir_p(dir: string) -> bool {
    return _exec_code("mkdir -p " + _sh_quote(dir)) == 0
}

fn _ts_iso() -> string {
    return _exec_out("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _file_bytes(path: string) -> int {
    if !_is_file(path) { return 0 }
    let cmd = "wc -c < " + _sh_quote(path) + " 2>/dev/null"
    let s = _exec_out(cmd).trim()
    if len(s) == 0 { return 0 }
    return to_int(s)
}

// ─── argv ────────────────────────────────────────────────────────────

fn _argv() -> array {
    let a = args()
    let mut out = []
    let mut i = 2
    while i < len(a) {
        out.push(a[i])
        i = i + 1
    }
    return out
}

fn _flag(av: array, k: string) -> bool {
    for x in av {
        if to_string(x) == k { return true }
    }
    return false
}

fn _opt(av: array, k: string, d: string) -> string {
    let mut i = 0
    while i < len(av) {
        if to_string(av[i]) == k && i + 1 < len(av) {
            return to_string(av[i + 1])
        }
        i = i + 1
    }
    return d
}

// ─── config ──────────────────────────────────────────────────────────

fn _load_config(path: string) {
    if !_file_exists(path) {
        eprintln("secret_scanner: SETUP_ERROR — config missing: " + path)
        exit(3)
    }
    return json_parse(read_file(path))
}

fn _cfg_str(cfg, key: string, dflt: string) -> string {
    if cfg.contains_key(key) { return to_string(cfg[key]) }
    return dflt
}

// ─── JSON escape ─────────────────────────────────────────────────────

fn _json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
}

// ─── redaction (CRITICAL — never log full secret) ────────────────────

fn _redact(value: string) -> string {
    let n = len(value)
    let head_len = if n < 4 { n } else { 4 }
    let head = value.substring(0, head_len)
    return "REDACT[" + head + "***len=" + to_string(n) + "]"
}

// ─── char-class predicates (table-based — no char_code accessor in hexa) ─

let UPPER_AZ = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
let LOWER_AZ = "abcdefghijklmnopqrstuvwxyz"
let DIGITS   = "0123456789"

fn _is_upper_az(c: string) -> bool {
    if len(c) == 0 { return false }
    return UPPER_AZ.index_of(c) >= 0
}

fn _is_digit(c: string) -> bool {
    if len(c) == 0 { return false }
    return DIGITS.index_of(c) >= 0
}

fn _is_lower_az(c: string) -> bool {
    if len(c) == 0 { return false }
    return LOWER_AZ.index_of(c) >= 0
}

fn _is_az(c: string) -> bool {
    return _is_upper_az(c) || _is_lower_az(c)
}

fn _is_alnum(c: string) -> bool {
    return _is_az(c) || _is_digit(c)
}

fn _is_b64ish(c: string) -> bool {
    // [0-9a-zA-Z/+]
    return _is_alnum(c) || c == "/" || c == "+"
}

fn _ch(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

// ─── pattern matchers (manual — hexa stdlib regex assumed absent) ────

// AKIA[0-9A-Z]{16} → 20 chars total
fn _scan_aws_access(body: string) -> array {
    let mut hits = []
    let n = len(body)
    let mut i = 0
    while i + 20 <= n {
        if body.substring(i, i + 4) == "AKIA" {
            let mut j = i + 4
            let mut ok = true
            while j < i + 20 {
                let c = _ch(body, j)
                if !(_is_upper_az(c) || _is_digit(c)) { ok = false; break }
                j = j + 1
            }
            if ok {
                let mut h = #{}
                h["match"] = body.substring(i, i + 20)
                h["offset"] = i
                hits.push(h)
                i = i + 20
                continue
            }
        }
        i = i + 1
    }
    return hits
}

// hf_[a-zA-Z0-9]{32+}
fn _scan_hf_token(body: string) -> array {
    let mut hits = []
    let n = len(body)
    let mut i = 0
    while i + 35 <= n {
        if body.substring(i, i + 3) == "hf_" {
            let mut j = i + 3
            while j < n && _is_alnum(_ch(body, j)) { j = j + 1 }
            let suffix_len = j - (i + 3)
            if suffix_len >= 32 {
                let mut h = #{}
                h["match"] = body.substring(i, j)
                h["offset"] = i
                hits.push(h)
                i = j
                continue
            }
        }
        i = i + 1
    }
    return hits
}

// PRIVATE_KEY header: -----BEGIN <X> PRIVATE KEY-----
fn _scan_private_key(body: string) -> array {
    let mut hits = []
    let needle = "-----BEGIN "
    let tail = " PRIVATE KEY-----"
    let n = len(body)
    let mut start = 0
    while start < n {
        let rest = body.substring(start, n)
        let k = rest.index_of(needle)
        if k < 0 { break }
        let abs_k = start + k
        // search for tail within next 40 chars
        let look_end = if abs_k + 60 < n { abs_k + 60 } else { n }
        let window = body.substring(abs_k, look_end)
        let t = window.index_of(tail)
        if t > 0 {
            let end_abs = abs_k + t + len(tail)
            let mut h = #{}
            h["match"] = body.substring(abs_k, end_abs)
            h["offset"] = abs_k
            hits.push(h)
            start = end_abs
        } else {
            start = abs_k + len(needle)
        }
    }
    return hits
}

// gh[pousr]_[a-zA-Z0-9]{36+}
fn _scan_github_token(body: string) -> array {
    let mut hits = []
    let n = len(body)
    let mut i = 0
    while i + 40 <= n {
        if body.substring(i, i + 2) == "gh" {
            let prefix_char = _ch(body, i + 2)
            let is_prefix = prefix_char == "p" || prefix_char == "o" || prefix_char == "u" || prefix_char == "s" || prefix_char == "r"
            if is_prefix && _ch(body, i + 3) == "_" {
                let mut j = i + 4
                while j < n && _is_alnum(_ch(body, j)) { j = j + 1 }
                if j - (i + 4) >= 36 {
                    let mut h = #{}
                    h["match"] = body.substring(i, j)
                    h["offset"] = i
                    hits.push(h)
                    i = j
                    continue
                }
            }
        }
        i = i + 1
    }
    return hits
}

// xox[abprs]-[0-9a-zA-Z-]{10+}
fn _scan_slack_token(body: string) -> array {
    let mut hits = []
    let n = len(body)
    let mut i = 0
    while i + 14 <= n {
        if body.substring(i, i + 3) == "xox" {
            let kc = _ch(body, i + 3)
            let is_k = kc == "a" || kc == "b" || kc == "p" || kc == "r" || kc == "s"
            if is_k && _ch(body, i + 4) == "-" {
                let mut j = i + 5
                while j < n {
                    let c = _ch(body, j)
                    if !(_is_alnum(c) || c == "-") { break }
                    j = j + 1
                }
                if j - (i + 5) >= 10 {
                    let mut h = #{}
                    h["match"] = body.substring(i, j)
                    h["offset"] = i
                    hits.push(h)
                    i = j
                    continue
                }
            }
        }
        i = i + 1
    }
    return hits
}

// sk-[a-zA-Z0-9]{32+} (OpenAI/Anthropic-style)
fn _scan_openai_key(body: string) -> array {
    let mut hits = []
    let n = len(body)
    let mut i = 0
    while i + 35 <= n {
        if body.substring(i, i + 3) == "sk-" {
            let mut j = i + 3
            while j < n && _is_alnum(_ch(body, j)) { j = j + 1 }
            if j - (i + 3) >= 32 {
                let mut h = #{}
                h["match"] = body.substring(i, j)
                h["offset"] = i
                hits.push(h)
                i = j
                continue
            }
        }
        i = i + 1
    }
    return hits
}

// AWS_SECRET — keyword-anchored: scan for "aws_secret_access_key" (case
// insensitive via two passes), then extract first [0-9a-zA-Z/+]{40} run
// within next 200 chars.
fn _scan_aws_secret(body: string) -> array {
    let mut hits = []
    let keywords = ["aws_secret_access_key", "AWS_SECRET_ACCESS_KEY", "aws_secret"]
    for kw in keywords {
        let key = to_string(kw)
        let n = len(body)
        let mut start = 0
        while start < n {
            let rest = body.substring(start, n)
            let k = rest.index_of(key)
            if k < 0 { break }
            let abs_k = start + k
            // scan next 200 chars for 40-char b64ish run
            let win_end = if abs_k + len(key) + 200 < n { abs_k + len(key) + 200 } else { n }
            let mut p = abs_k + len(key)
            while p < win_end {
                if _is_b64ish(_ch(body, p)) {
                    let mut q = p
                    while q < win_end && _is_b64ish(_ch(body, q)) { q = q + 1 }
                    if q - p >= 40 {
                        let mut h = #{}
                        h["match"] = body.substring(p, p + 40)
                        h["offset"] = p
                        hits.push(h)
                        p = q
                    } else {
                        p = q
                    }
                } else {
                    p = p + 1
                }
            }
            start = abs_k + len(key)
        }
    }
    return hits
}

// GENERIC_HIGH_ENTROPY: keyword-near (`secret`/`token`/`api_key` ...)
// plus any [a-zA-Z0-9+/=_-]{32+} run within next 150 chars
fn _scan_generic_entropy(body: string, kws: array) -> array {
    let mut hits = []
    for kw in kws {
        let key = to_string(kw)
        let n = len(body)
        let mut start = 0
        while start < n {
            let rest = body.substring(start, n)
            let k = rest.index_of(key)
            if k < 0 { break }
            let abs_k = start + k
            let win_end = if abs_k + len(key) + 150 < n { abs_k + len(key) + 150 } else { n }
            let mut p = abs_k + len(key)
            // skip non-secret chars (= : space " ' )
            while p < win_end {
                let c = _ch(body, p)
                let is_secret_char = _is_alnum(c) || c == "+" || c == "/" || c == "=" || c == "_" || c == "-"
                if is_secret_char {
                    let mut q = p
                    while q < win_end {
                        let cc = _ch(body, q)
                        let is_ok = _is_alnum(cc) || cc == "+" || cc == "/" || cc == "=" || cc == "_" || cc == "-"
                        if !is_ok { break }
                        q = q + 1
                    }
                    if q - p >= 32 {
                        let mut h = #{}
                        h["match"] = body.substring(p, q)
                        h["offset"] = p
                        h["near_keyword"] = key
                        hits.push(h)
                        p = q
                        break  // only first hit per keyword occurrence
                    } else {
                        p = q + 1
                    }
                } else {
                    p = p + 1
                }
            }
            start = abs_k + len(key)
        }
    }
    return hits
}

// ─── per-file scan ───────────────────────────────────────────────────

fn scan_file_body(path: string, body: string, generic_kws: array) -> array {
    let mut violations = []

    let aws_a = _scan_aws_access(body)
    for h in aws_a {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "AWS_ACCESS_KEY"
        v["severity"] = "CRITICAL"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    let aws_s = _scan_aws_secret(body)
    for h in aws_s {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "AWS_SECRET_KEY"
        v["severity"] = "CRITICAL"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    let hf = _scan_hf_token(body)
    for h in hf {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "HF_TOKEN"
        v["severity"] = "HIGH"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    let pk = _scan_private_key(body)
    for h in pk {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "PRIVATE_KEY_HEADER"
        v["severity"] = "CRITICAL"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    let gh = _scan_github_token(body)
    for h in gh {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "GITHUB_TOKEN"
        v["severity"] = "HIGH"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    let sl = _scan_slack_token(body)
    for h in sl {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "SLACK_TOKEN"
        v["severity"] = "HIGH"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    let oa = _scan_openai_key(body)
    for h in oa {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "OPENAI_API_KEY"
        v["severity"] = "HIGH"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        violations.push(v)
    }

    // 2026-04-22 FP fix: skip GENERIC_HIGH_ENTROPY for known anima vocabulary files
    // (manifests, audits, ledgers, hashes, tokenizer probes — all have legit "token" keyword
    // hits next to roadmap probe IDs / sha256 / etc.). Real secret patterns CRITICAL/HIGH
    // remain scanned (above section). Only the noisy generic entropy bucket is filtered.
    let mut skip_generic = false
    for substr in ["_audit.json", "_completion.json", "_ledger.json", "_snapshot.json",
                   "_dryrun.json", "_dry_run.json", "_summary.json", "_manifest.json",
                   "_tokenizer_sha.json", "_progress.jsonl", "_log.jsonl", "_cert.json",
                   ".meta2-cert/", "roadmap_progress.json", "phi_offset_auto_detected.json",
                   "h_last_ffi_p1_smoke.json", "sbom_cyclonedx.json", "integrity_drift_",
                   "techniques_225_import_", "n6_substrate_selftest_result.json",
                   "n6_consciousness_substrate_status.json", "cell_token_bridge_proto.json",
                   "corpus_r13_path_tokenized_manifest.json", "roadmap_integrity_result.json"] {
        if path.index_of(to_string(substr)) >= 0 { skip_generic = true; break }
    }
    let ge = if skip_generic { [] } else { _scan_generic_entropy(body, generic_kws) }
    for h in ge {
        let mut v = #{}
        v["path"] = path
        v["pattern_id"] = "GENERIC_HIGH_ENTROPY"
        v["severity"] = "MEDIUM"
        v["offset"] = h["offset"]
        v["redacted"] = _redact(to_string(h["match"]))
        v["near_keyword"] = h["near_keyword"]
        violations.push(v)
    }

    return violations
}

// ─── file enumeration ────────────────────────────────────────────────

fn _list_files_in_root(repo_root: string, root: string, excludes: array, exts: array, max_bytes: int) -> array {
    let full_root = repo_root + "/" + root
    if !_file_exists(full_root) { return [] }
    let cmd = "find " + _sh_quote(full_root) + " -type f 2>/dev/null"
    let out = _exec_out(cmd)
    let lines = split(out, "\n")
    let mut acc = []
    for l in lines {
        let p = to_string(l).trim()
        if len(p) == 0 { continue }
        // exclude path matches
        let mut skip = false
        for ex in excludes {
            let exp = repo_root + "/" + to_string(ex)
            if p == exp { skip = true; break }
        }
        if skip { continue }
        // exclude extension matches
        for ext in exts {
            let exs = to_string(ext)
            if len(p) >= len(exs) {
                let suffix = p.substring(len(p) - len(exs), len(p))
                if suffix == exs { skip = true; break }
            }
        }
        if skip { continue }
        // size cap
        let sz = _file_bytes(p)
        if sz > max_bytes { continue }
        acc.push(p)
    }
    return acc
}

// ─── selftest fixture ────────────────────────────────────────────────

fn _build_selftest_fixture() -> string {
    let path = "/tmp/secret_scanner_selftest_" + _exec_out("date -u +%s").trim() + ".txt"
    let mut s = ""
    s = s + "line 1: AKIAIOSFODNN7EXAMPLE here\n"
    s = s + "line 2: aws_secret_access_key = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY\n"
    s = s + "line 3: hf_abcdefghijklmnopqrstuvwxyz0123456789ABCD\n"
    s = s + "line 4: -----BEGIN RSA PRIVATE KEY-----\n"
    s = s + "line 5: token = thisIsAFortyTwoCharacterEntropySample42x\n"
    s = s + "line 6: ghp_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\n"
    write_file(path, s)
    return path
}

// ─── output emission ─────────────────────────────────────────────────

fn _emit_violations(out_path: string, summary_path: string, violations: array, files_scanned: int, ts: string, trigger: string) {
    // Severity tally
    let mut crit = 0
    let mut high = 0
    let mut med = 0
    let mut low = 0
    for v in violations {
        let s = to_string(v["severity"])
        if s == "CRITICAL" { crit = crit + 1 }
        else if s == "HIGH" { high = high + 1 }
        else if s == "MEDIUM" { med = med + 1 }
        else { low = low + 1 }
    }

    let mut parts = []
    parts.push("{\n")
    parts.push("  \"schema\": \"anima.secret_scan_violations.v1\",\n")
    parts.push("  \"tool\": \"tool/secret_scanner.hexa\",\n")
    parts.push("  \"ts\": \"" + ts + "\",\n")
    parts.push("  \"trigger\": \"" + _json_escape(trigger) + "\",\n")
    parts.push("  \"files_scanned\": " + to_string(files_scanned) + ",\n")
    parts.push("  \"violation_count\": " + to_string(len(violations)) + ",\n")
    parts.push("  \"by_severity\": {\"CRITICAL\": " + to_string(crit) + ", \"HIGH\": " + to_string(high) + ", \"MEDIUM\": " + to_string(med) + ", \"LOW\": " + to_string(low) + "},\n")
    parts.push("  \"redaction_policy\": \"first_4_chars_plus_length\",\n")
    parts.push("  \"violations\": [\n")
    let mut i = 0
    while i < len(violations) {
        let v = violations[i]
        let comma = if i + 1 < len(violations) { "," } else { "" }
        parts.push("    {\"path\": \"" + _json_escape(to_string(v["path"])) + "\"")
        parts.push(", \"pattern_id\": \"" + to_string(v["pattern_id"]) + "\"")
        parts.push(", \"severity\": \"" + to_string(v["severity"]) + "\"")
        parts.push(", \"offset\": " + to_string(v["offset"]))
        parts.push(", \"redacted\": \"" + _json_escape(to_string(v["redacted"])) + "\"")
        if v.contains_key("near_keyword") {
            parts.push(", \"near_keyword\": \"" + _json_escape(to_string(v["near_keyword"])) + "\"")
        }
        parts.push("}" + comma + "\n")
        i = i + 1
    }
    parts.push("  ]\n}\n")
    let body = parts.join("")
    let _ = _mkdir_p("/Users/ghost/core/anima/state")
    let _ = write_file(out_path, body)

    // Summary (no per-violation detail, safe for status dashboards)
    let mut sp = []
    sp.push("{\n")
    sp.push("  \"schema\": \"anima.secret_scan_summary.v1\",\n")
    sp.push("  \"ts\": \"" + ts + "\",\n")
    sp.push("  \"files_scanned\": " + to_string(files_scanned) + ",\n")
    sp.push("  \"violation_count\": " + to_string(len(violations)) + ",\n")
    sp.push("  \"by_severity\": {\"CRITICAL\": " + to_string(crit) + ", \"HIGH\": " + to_string(high) + ", \"MEDIUM\": " + to_string(med) + ", \"LOW\": " + to_string(low) + "},\n")
    sp.push("  \"verdict\": \"" + (if crit + high > 0 { "FAIL" } else if med > 0 { "WARN" } else { "PASS" }) + "\"\n")
    sp.push("}\n")
    let _ = write_file(summary_path, sp.join(""))
}

// ─── main ────────────────────────────────────────────────────────────

fn main() -> int {
    let av = _argv()

    if _flag(av, "--help") || _flag(av, "-h") {
        println("usage: hexa tool/secret_scanner.hexa [opts]")
        println("  --selftest              run synthetic fixture (validates redaction)")
        println("  --paths <p1,p2,...>     comma-separated explicit file list (override roots)")
        println("  --config <path>         override config path")
        println("  --help")
        return 0
    }

    let cfg_path = _opt(av, "--config", DEFAULT_CONFIG)
    let cfg = _load_config(cfg_path)
    let repo_root = _cfg_str(cfg, "repo_root", "/Users/ghost/core/anima")
    let scan_roots = cfg["scan_roots"]
    let excludes = cfg["exclude_paths"]
    let exts = cfg["exclude_extensions"]
    let max_bytes = to_int(to_string(cfg["max_file_bytes"]))
    let output = cfg["output"]
    let out_path = repo_root + "/" + to_string(output["violations_path"])
    let summary_path = repo_root + "/" + to_string(output["summary_path"])

    // Build generic-entropy keyword list from patterns table
    let mut generic_kws = []
    let patterns = cfg["patterns"]
    for p in patterns {
        if to_string(p["id"]) == "GENERIC_HIGH_ENTROPY" && p.contains_key("regex_keyword_any") {
            for k in p["regex_keyword_any"] { generic_kws.push(to_string(k)) }
        }
    }

    let want_selftest = _flag(av, "--selftest")
    let explicit_paths = _opt(av, "--paths", "")

    let mut targets = []
    let mut trigger = ""

    if want_selftest {
        let fix = _build_selftest_fixture()
        targets.push(fix)
        trigger = "selftest"
    } else if explicit_paths != "" {
        let parts = split(explicit_paths, ",")
        for p in parts {
            let pt = to_string(p).trim()
            if len(pt) > 0 && _is_file(pt) { targets.push(pt) }
        }
        trigger = "paths"
    } else {
        for r in scan_roots {
            let files = _list_files_in_root(repo_root, to_string(r), excludes, exts, max_bytes)
            for f in files { targets.push(to_string(f)) }
        }
        trigger = "scan_roots"
    }

    let mut all_violations = []
    for t in targets {
        let path = to_string(t)
        let body = read_file(path)
        let v = scan_file_body(path, body, generic_kws)
        for vi in v { all_violations.push(vi) }
    }

    let ts = _ts_iso()
    _emit_violations(out_path, summary_path, all_violations, len(targets), ts, trigger)

    // Tally for exit policy
    let mut crit = 0
    let mut high = 0
    let mut med = 0
    for v in all_violations {
        let s = to_string(v["severity"])
        if s == "CRITICAL" { crit = crit + 1 }
        else if s == "HIGH" { high = high + 1 }
        else if s == "MEDIUM" { med = med + 1 }
    }

    println("── secret_scanner ──")
    println("  files_scanned:    " + to_string(len(targets)))
    println("  violation_count:  " + to_string(len(all_violations)))
    println("  CRITICAL:         " + to_string(crit))
    println("  HIGH:             " + to_string(high))
    println("  MEDIUM:           " + to_string(med))
    println("  violations_path:  " + out_path)
    println("  summary_path:     " + summary_path)
    println("  redaction:        first_4_chars + length (full secret NEVER logged)")
    println("  pre_commit:       NOT auto-installed — see config.pre_commit_hook_install")

    if want_selftest {
        // selftest expects >=4 distinct pattern hits from fixture
        if crit + high + med >= 4 {
            println("  selftest:         PASS (" + to_string(crit + high + med) + " hits)")
            return 0
        } else {
            println("  selftest:         FAIL (only " + to_string(crit + high + med) + " hits)")
            return 3
        }
    }

    let exit_pol = cfg["exit_policy"]
    if crit + high > 0 { return to_int(to_string(exit_pol["high_or_critical"])) }
    if med > 0 { return to_int(to_string(exit_pol["medium_only"])) }
    return to_int(to_string(exit_pol["no_violations"]))
}

main()
