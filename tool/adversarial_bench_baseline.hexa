// ════════════════════════════════════════════════════════════════════════════
// tool/adversarial_bench_baseline.hexa — adversarial_bench baseline measurement
//
// PURPOSE
//   pre-H100 ROI R4 — capture the current adversarial_bench (cluster #33,
//   raw#12 cherry-pick immunity) baseline as a dated, immutable snapshot
//   so post-H100 runs can diff against a known-good pre-H100 reference.
//
//   This is a READ-OPTIONAL wrapper:
//     - if state/adversarial_bench_last.json exists and is fresh enough,
//       we ingest it directly (no re-run).
//     - if --rerun is passed (or last is missing), we invoke
//       tool/adversarial_bench.hexa to refresh it first.
//
// INPUT
//   state/adversarial_bench_last.json  (cert from tool/adversarial_bench.hexa)
//
// OUTPUT
//   state/adversarial_baseline_20260422.json  (dated immutable baseline)
//
// METRICS RECORDED
//   - clean verdict (expected CLOSED)
//   - flip_a / flip_b / flip_c verdicts + sha
//   - flip_fail_count (target 3/3)
//   - selftest verdict (target PASS)
//   - proof_hash + cert_hash (raw#10 hash chain)
//   - per-flip verdict_sha256 for diff harness
//   - baseline_label = pre_h100
//
// SELFTEST
//   S1 last_cert_present
//   S2 schema_matches_v1
//   S3 selftest_verdict_PASS in last cert
//   S4 flip_fail_count == 3
//   S5 baseline_file_written
//   S6 deterministic_replay — second invocation w/o --rerun emits same
//     baseline_proof_hash (proof chain stable)
//
// RULES
//   raw#9 hexa-only · raw#10 sha-proof · raw#11 snake_case · raw#15 no-hardcode
//   read-only on cluster #33 cert; produces NEW dated baseline file
// ════════════════════════════════════════════════════════════════════════════

let LAST_CERT       = "state/adversarial_bench_last.json"
let BASELINE_OUT    = "state/adversarial_baseline_20260422.json"
let BENCH_TOOL      = "tool/adversarial_bench.hexa"
let HEXA_BIN_DEFAULT = "/Users/ghost/Dev/hexa-lang/hexa"

// ─── helpers ─────────────────────────────────────────────────────────────

fn _str(x) {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn fexists(p) {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn dexists(p) {
    return _str(exec("test -d " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn ensure_dir(d) {
    if !dexists(d) { exec("mkdir -p " + d) }
}

fn now_utc() {
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn sha256_file(p) {
    if !fexists(p) { return "" }
    return _str(exec("shasum -a 256 " + p + " 2>/dev/null | awk '{print $1}'")).trim()
}

fn sha256_str(s) {
    let tmp = "/tmp/_adv_baseline_hash.txt"
    write_file(tmp, s)
    return _str(exec("shasum -a 256 " + tmp + " 2>/dev/null | awk '{print $1}'")).trim()
}

fn atomic_write(path, body) {
    let pid = _str(exec("printf %s $$")).trim()
    let tmp = path + ".tmp." + pid
    write_file(tmp, body)
    exec("mv -f " + tmp + " " + path)
}

fn json_escape(s) {
    let a = s.replace("\\", "\\\\")
    let b = a.replace("\"", "\\\"")
    let c = b.replace("\n", "\\n")
    return c
}

fn arg_present(argv, key) {
    let mut i = 0
    while i < len(argv) {
        if _str(argv[i]) == key { return true }
        i = i + 1
    }
    return false
}

fn resolve_hexa_bin() {
    let e = _str(env("HEXA_BIN"))
    if e != "" { return e }
    if fexists(HEXA_BIN_DEFAULT) { return HEXA_BIN_DEFAULT }
    let p = _str(exec("command -v hexa 2>/dev/null")).trim()
    if p != "" { return p }
    return HEXA_BIN_DEFAULT
}

fn is_json_map(v) {
    let s = str(v)
    if s.len() < 1 { return false }
    return s.substring(0, 1) == "{"
}

// ─── snapshot extraction ─────────────────────────────────────────────────

struct Baseline {
    schema:           string,
    clean_verdict:    string,
    flip_a_verdict:   string,
    flip_b_verdict:   string,
    flip_c_verdict:   string,
    clean_sha:        string,
    flip_a_sha:       string,
    flip_b_sha:       string,
    flip_c_sha:       string,
    flip_fail_count:  int,
    selftest_verdict: string,
    proof_hash:       string,
    cert_path:        string,
    cert_sha:         string
}

fn extract_baseline() {
    let raw = read_file(LAST_CERT)
    let m = json_parse(raw)
    if !is_json_map(m) {
        return Baseline {
            schema: "", clean_verdict: "", flip_a_verdict: "",
            flip_b_verdict: "", flip_c_verdict: "",
            clean_sha: "", flip_a_sha: "", flip_b_sha: "", flip_c_sha: "",
            flip_fail_count: -1, selftest_verdict: "PARSE_ERROR",
            proof_hash: "", cert_path: LAST_CERT, cert_sha: ""
        }
    }
    let runs = m["runs"]
    let st = m["selftest"]
    return Baseline {
        schema:           str(m["schema"]),
        clean_verdict:    str(runs["clean"]["verdict"]),
        flip_a_verdict:   str(runs["flip_a"]["verdict"]),
        flip_b_verdict:   str(runs["flip_b"]["verdict"]),
        flip_c_verdict:   str(runs["flip_c"]["verdict"]),
        clean_sha:        str(runs["clean"]["verdict_sha256"]),
        flip_a_sha:       str(runs["flip_a"]["verdict_sha256"]),
        flip_b_sha:       str(runs["flip_b"]["verdict_sha256"]),
        flip_c_sha:       str(runs["flip_c"]["verdict_sha256"]),
        flip_fail_count:  to_int(str(st["flip_fail_count"])),
        selftest_verdict: str(st["verdict"]),
        proof_hash:       str(m["proof_hash"]),
        cert_path:        LAST_CERT,
        cert_sha:         sha256_file(LAST_CERT)
    }
}

// ─── baseline writer ─────────────────────────────────────────────────────

fn build_baseline_json(b, baseline_proof) {
    let mut parts = []
    parts = parts.push("{\n")
    parts = parts.push("  \"schema\": \"anima.adversarial_baseline.v1\",\n")
    parts = parts.push("  \"baseline_label\": \"pre_h100\",\n")
    parts = parts.push("  \"baseline_date\": \"2026-04-22\",\n")
    parts = parts.push("  \"generated\": \"" + now_utc() + "\",\n")
    parts = parts.push("  \"source_cert\": \"" + json_escape(b.cert_path) + "\",\n")
    parts = parts.push("  \"source_cert_schema\": \"" + b.schema + "\",\n")
    parts = parts.push("  \"source_cert_sha256\": \"" + b.cert_sha + "\",\n")
    parts = parts.push("  \"verdicts\": {\n")
    parts = parts.push("    \"clean\":  \"" + b.clean_verdict + "\",\n")
    parts = parts.push("    \"flip_a\": \"" + b.flip_a_verdict + "\",\n")
    parts = parts.push("    \"flip_b\": \"" + b.flip_b_verdict + "\",\n")
    parts = parts.push("    \"flip_c\": \"" + b.flip_c_verdict + "\"\n")
    parts = parts.push("  },\n")
    parts = parts.push("  \"verdict_sha256\": {\n")
    parts = parts.push("    \"clean\":  \"" + b.clean_sha + "\",\n")
    parts = parts.push("    \"flip_a\": \"" + b.flip_a_sha + "\",\n")
    parts = parts.push("    \"flip_b\": \"" + b.flip_b_sha + "\",\n")
    parts = parts.push("    \"flip_c\": \"" + b.flip_c_sha + "\"\n")
    parts = parts.push("  },\n")
    parts = parts.push("  \"flip_fail_count\": " + str(b.flip_fail_count) + ",\n")
    parts = parts.push("  \"required_flips\": 3,\n")
    parts = parts.push("  \"selftest_verdict\": \"" + b.selftest_verdict + "\",\n")
    parts = parts.push("  \"upstream_proof_hash\": \"" + b.proof_hash + "\",\n")
    parts = parts.push("  \"baseline_proof_hash\": \"" + baseline_proof + "\",\n")
    parts = parts.push("  \"diff_harness_keys\": [\"clean\", \"flip_a\", \"flip_b\", \"flip_c\"],\n")
    parts = parts.push("  \"deterministic\": true,\n")
    parts = parts.push("  \"llm\": \"none\",\n")
    parts = parts.push("  \"raw_contract\": [\"raw#9\", \"raw#10\", \"raw#11\", \"raw#15\"]\n")
    parts = parts.push("}\n")
    let mut body = ""
    let mut i = 0
    while i < len(parts) {
        body = body + parts[i]
        i = i + 1
    }
    return body
}

fn compute_baseline_proof(b) {
    let s = b.clean_sha + "|" + b.flip_a_sha + "|" + b.flip_b_sha + "|" +
            b.flip_c_sha + "|" + b.selftest_verdict + "|pre_h100|2026-04-22"
    return sha256_str(s)
}

// ─── selftest ────────────────────────────────────────────────────────────

fn b_s(x) { return if x { "true" } else { "false" } }

fn selftest(bl, baseline_proof) {
    println("── adversarial_bench_baseline selftest ──")
    let mut pass = 0
    let mut fail = 0

    let s1 = fexists(LAST_CERT)
    if s1 {
        println("  S1 last_cert_present       : PASS  (" + LAST_CERT + ")")
        pass = pass + 1
    } else {
        println("  S1 last_cert_present       : FAIL")
        fail = fail + 1
    }

    let s2 = bl.schema == "anima.adversarial_bench.v1"
    if s2 {
        println("  S2 schema_v1_match         : PASS  (" + bl.schema + ")")
        pass = pass + 1
    } else {
        println("  S2 schema_v1_match         : FAIL  (" + bl.schema + ")")
        fail = fail + 1
    }

    let s3 = bl.selftest_verdict == "PASS"
    if s3 {
        println("  S3 upstream_selftest_PASS  : PASS")
        pass = pass + 1
    } else {
        println("  S3 upstream_selftest_PASS  : FAIL  (got " + bl.selftest_verdict + ")")
        fail = fail + 1
    }

    let s4 = bl.flip_fail_count == 3
    if s4 {
        println("  S4 flip_fail_count_eq_3    : PASS  (3/3)")
        pass = pass + 1
    } else {
        println("  S4 flip_fail_count_eq_3    : FAIL  (got " + str(bl.flip_fail_count) + "/3)")
        fail = fail + 1
    }

    let s5 = fexists(BASELINE_OUT)
    if s5 {
        println("  S5 baseline_file_written   : PASS  (" + BASELINE_OUT + ")")
        pass = pass + 1
    } else {
        println("  S5 baseline_file_written   : FAIL")
        fail = fail + 1
    }

    // S6 deterministic replay — recompute proof from same struct, must match.
    let proof2 = compute_baseline_proof(bl)
    let s6 = proof2 == baseline_proof && baseline_proof.len() == 64
    if s6 {
        println("  S6 deterministic_proof     : PASS  (" + baseline_proof.substring(0, 12) + "..)")
        pass = pass + 1
    } else {
        println("  S6 deterministic_proof     : FAIL  (proof2=" + proof2.substring(0, 12) + ".. vs " + baseline_proof.substring(0, 12) + "..)")
        fail = fail + 1
    }

    println("selftest: " + str(pass) + "/" + str(pass + fail) + " PASS")
    if fail > 0 { return 1 }
    return 0
}

// ─── main ────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let do_rerun = arg_present(argv, "--rerun")

    println("[adversarial_bench_baseline] capturing pre-H100 baseline")
    println("  source_cert: " + LAST_CERT)
    println("  baseline:    " + BASELINE_OUT)
    println("  ts:          " + now_utc())

    if do_rerun || !fexists(LAST_CERT) {
        if !fexists(LAST_CERT) {
            println("  (cert missing — invoking " + BENCH_TOOL + ")")
        } else {
            println("  (--rerun requested — invoking " + BENCH_TOOL + ")")
        }
        let bin = resolve_hexa_bin()
        let _ = exec("HEXA_NO_LAUNCHD=1 " + bin + " run " + BENCH_TOOL + " > /tmp/_adv_bench_rerun.log 2>&1")
        if !fexists(LAST_CERT) {
            println("  ERROR: rerun failed to produce " + LAST_CERT)
            exit(2)
        }
    } else {
        println("  (using cached cert — pass --rerun to refresh)")
    }

    ensure_dir("state")
    let bl = extract_baseline()
    let baseline_proof = compute_baseline_proof(bl)
    let body = build_baseline_json(bl, baseline_proof)
    atomic_write(BASELINE_OUT, body)

    println("  clean   = " + bl.clean_verdict)
    println("  flip_a  = " + bl.flip_a_verdict + "   (sha=" + bl.flip_a_sha.substring(0, 12) + "..)")
    println("  flip_b  = " + bl.flip_b_verdict + "      (sha=" + bl.flip_b_sha.substring(0, 12) + "..)")
    println("  flip_c  = " + bl.flip_c_verdict + "      (sha=" + bl.flip_c_sha.substring(0, 12) + "..)")
    println("  flip_fail_count = " + str(bl.flip_fail_count) + "/3")
    println("  selftest        = " + bl.selftest_verdict)
    println("  baseline_proof  = " + baseline_proof)

    let code = selftest(bl, baseline_proof)
    if code == 0 {
        println("[adversarial_bench_baseline] DONE — pre-H100 baseline frozen")
    } else {
        println("[adversarial_bench_baseline] FAILED selftest")
    }
    exit(code)
}

main()
