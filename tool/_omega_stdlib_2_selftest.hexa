// ω-stdlib-2 selftest: verify rt_file_size + rt_file_exists fix
// Compares (a) small file (b) missing path (c) directory path
// against pfs_file_size / pfs_file_exists for parity.

import "../../hexa-lang/stdlib/portable_fs.hexa"

fn main() {
    // (a) small known file: this script itself
    let small = "/Users/ghost/core/anima/tool/_omega_stdlib_2_selftest.hexa"
    // (b) non-existent path
    let missing = "/Users/ghost/core/anima/tool/_omega_stdlib_2_DOES_NOT_EXIST_xyz.hexa"
    // (c) directory path
    let dir = "/Users/ghost/core/anima/tool"

    println("=== ω-stdlib-2 builtin file_size/file_exists selftest ===")

    // ── builtin ──
    let bsz_small   = file_size(small)
    let bsz_miss    = file_size(missing)
    let bsz_dir     = file_size(dir)
    let bex_small   = file_exists(small)
    let bex_miss    = file_exists(missing)
    let bex_dir     = file_exists(dir)

    // ── pfs_ alias ──
    let psz_small   = pfs_file_size(small)
    let psz_miss    = pfs_file_size(missing)
    let psz_dir     = pfs_file_size(dir)
    let pex_small   = pfs_file_exists(small)
    let pex_miss    = pfs_file_exists(missing)
    let pex_dir     = pfs_file_exists(dir)

    println("small file:")
    println("  builtin file_size  = " + to_string(bsz_small))
    println("  pfs_file_size      = " + to_string(psz_small))
    println("  builtin file_exists= " + to_string(bex_small))
    println("  pfs_file_exists    = " + to_string(pex_small))

    println("missing path:")
    println("  builtin file_size  = " + to_string(bsz_miss))
    println("  pfs_file_size      = " + to_string(psz_miss))
    println("  builtin file_exists= " + to_string(bex_miss))
    println("  pfs_file_exists    = " + to_string(pex_miss))

    println("directory path:")
    println("  builtin file_size  = " + to_string(bsz_dir))
    println("  pfs_file_size      = " + to_string(psz_dir))
    println("  builtin file_exists= " + to_string(bex_dir))
    println("  pfs_file_exists    = " + to_string(pex_dir))

    // ── parity assertions ──
    let mut pass = true
    let mut notes = ""

    // small: sizes equal, both exist
    if bsz_small != psz_small { pass = false; notes = notes + "small_size_mismatch;" }
    if bsz_small <= 0          { pass = false; notes = notes + "small_size_nonpositive;" }
    if !bex_small              { pass = false; notes = notes + "small_exists_false;" }
    if !pex_small              { pass = false; notes = notes + "small_pfs_exists_false;" }

    // missing: both 0/false
    if bsz_miss != 0           { pass = false; notes = notes + "missing_builtin_size_nonzero(" + to_string(bsz_miss) + ");" }
    if psz_miss != 0           { pass = false; notes = notes + "missing_pfs_size_nonzero(" + to_string(psz_miss) + ");" }
    if bex_miss                { pass = false; notes = notes + "missing_builtin_exists_true;" }
    if pex_miss                { pass = false; notes = notes + "missing_pfs_exists_true;" }

    // directory: builtin should now report 0/false (S_ISREG-aware)
    if bsz_dir != 0            { pass = false; notes = notes + "dir_builtin_size_nonzero(" + to_string(bsz_dir) + ");" }
    if bex_dir                 { pass = false; notes = notes + "dir_builtin_exists_true;" }
    // pfs_file_exists("dir") via `test -f` is also false; pfs_file_size("dir") via `wc -c <dir` errors → 0
    if pex_dir                 { pass = false; notes = notes + "dir_pfs_exists_true;" }
    if psz_dir != 0            { pass = false; notes = notes + "dir_pfs_size_nonzero(" + to_string(psz_dir) + ");" }

    println("---")
    if pass {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL  notes=" + notes)
    }
}
