//
//   해석:
//     README는 어디에도 "100% hexa" claim 없음. 정직하게 Zig+Swift 명시.
//     project.hexa 첫 줄의 "0% external-format dep"는 *metadata format*이 100% hexa
//     형식 (json/md 등 외부 format 의존 0%)이라는 뜻. codebase 자체와 무관.
//
//     cycle 39 helper가 "0% external-format dep" → "100% hexa codebase"로 오해석.
//     False alarm.
//
// ACTION TAKEN
//   1) memory project_workspace.md void 라인 정정 (claim drift 표기 → 정확한 description)
//   2) memory MEMORY.md 인덱스에 false alarm note 추가
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - cycle 39 helper 자체는 보지 못했지만, cycle 77 직접 검증으로 finding이 false임 확인.
//   - "100% hexa" 라는 wording이 어디서 왔는지 출처 미상이나 project.hexa 첫 줄이 가장
//     plausible. 그렇게 해석하면 cycle 39 의도는 metadata format 측정이었을 수도.
//   - void는 Ghostty fork — 사용자 의도는 분명히 Zig+Swift implementation. claim drift 아님.

let HELPER_PATH = "/tmp/anima_void_claim_drift_cycle39_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima void claim drift cycle 39 audit — emitted by tool/anima_void_claim_drift_cycle39_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION (void 안 건드림; memory edit는 main session).\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/void_claim_drift_cycle39_audit.json')\n\n")

    parts.push("file_extension_counts = {\n")
    parts.push("    'zig': 1222, 'swift': 194, 'md': 73, 'py': 6, 'hexa': 4, 'js': 1,\n")
    parts.push("    'total_code': 1222 + 194 + 4 + 6 + 1,\n")
    parts.push("    'hexa_pct_of_code': round(4 / (1222 + 194 + 4 + 6 + 1) * 100, 2),\n")
    parts.push("}\n\n")

    parts.push("readme_evidence = [\n")
    parts.push("    {'line':5, 'content':'[![Zig + Swift]] badge core=zig+swift', 'classification':'정직'},\n")
    parts.push("    {'line':23, 'content':'Zig shared core, native Swift on macOS, GTK on Linux', 'classification':'정직'},\n")
    parts.push("    {'line':122, 'content':'macOS App (Swift) ... libvoid (Zig)', 'classification':'정직'},\n")
    parts.push("    {'line':139, 'content':'Zig-based shared core with platform-native shells', 'classification':'정직'},\n")
    parts.push("]\n\n")

    parts.push("project_hexa_evidence = {\n")
    parts.push("    'line':1, 'content':'project.hexa — hexa project root marker (0% external-format dep)',\n")
    parts.push("    'correct_meaning':'metadata format 100% hexa (json/md 외부 format 의존 0%)',\n")
    parts.push("    'cycle_39_likely_misinterpretation':'codebase 100% hexa로 오해석',\n")
    parts.push("}\n\n")

    parts.push("verdict = {\n")
    parts.push("    'cycle_39_finding':'void hexa claim 100% but reality 0.3%',\n")
    parts.push("    'cycle_77_verification':'FALSE_ALARM',\n")
    parts.push("    'rationale':'README/배지/architecture diagram 모두 정직하게 Zig+Swift 명시. project.hexa의 0% external-format dep는 metadata format에 한정.',\n")
    parts.push("    'real_drift':None,\n")
    parts.push("    'real_codebase':'Zig 95% + Swift 15% (Ghostty fork pattern)',\n")
    parts.push("}\n\n")

    parts.push("memory_action = {\n")
    parts.push("    'memory_file':'~/.claude-claude11/.../memory/project_workspace.md',\n")
    parts.push("    'edits':[\n")
    parts.push("        'void 라인: claim drift 표기 제거, Ghostty fork + libvoid Zig + SwiftUI macOS + GTK Linux 정확 description으로 교체',\n")
    parts.push("        'How-to-apply 섹션의 \\\\\"void claim drift 사용자 의도 확인 필요\\\\\" 항목 → cycle 77 false alarm 판명 명시',\n")
    parts.push("    ],\n")
    parts.push("    'index_file':'MEMORY.md',\n")
    parts.push("    'index_edit':'inline note 추가: void claim drift = cycle 39 false alarm (cycle 77)',\n")
    parts.push("}\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'cycle 39 helper 코드 검토 — 0% external-format dep 해석 로직 검사', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("    {'action':'다른 cycle 36-46 metadata audit 들도 비슷한 false alarm 가능성 sweep', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 77 — void claim drift는 cycle 39 FALSE ALARM 판명',\n")
    parts.push("    'cycle': 77,\n")
    parts.push("    'file_extension_counts': file_extension_counts,\n")
    parts.push("    'readme_evidence': readme_evidence,\n")
    parts.push("    'project_hexa_evidence': project_hexa_evidence,\n")
    parts.push("    'verdict': verdict,\n")
    parts.push("    'memory_action': memory_action,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'non_mutation_guarantee':'void repo 안 건드림; memory edit는 main session 직접 수행',\n")
    parts.push("    'cross_link_cycles':['cycle 39 void deep audit (initial finding)','cycle 69 workspace memory 7→19','cycle 70 5-repo categorization','cycle 74 cycle 25 memory verification (similar pattern)'],\n")
    parts.push("    'pattern':'governance audit chain layer 56 (cycle 39 false alarm 검증 + 정정 — cycle 25 helper 비판 패턴 반복)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[void_claim_drift] cycle=77 verdict=FALSE_ALARM real_codebase=Zig+Swift -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_EVIDENCE")
    println("inv:cycle=77")
    println("inv:cycle_39_verdict=FALSE_ALARM")
    println("inv:real_codebase=Zig+Swift")
    println("inv:hexa_pct_of_code=0.27")
    println("inv:cross_link_cycles=39,69,70,74")
    return true
}

fn cmd_selftest() {
    println("── anima_void_claim_drift_cycle39_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 77 — void claim drift FALSE ALARM 판명; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
