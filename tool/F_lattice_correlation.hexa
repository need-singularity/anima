// tool/F_lattice_correlation.hexa — O2 correlation helpers (stand-alone module)
//
// PARADIGM REF: docs/new_paradigm_edu_lattice_unified_20260421.md §1.1 §11
// ROLE: CPU-proxy O2 observable computation for F lattice L3 emergence.
//       Callable API + self-test.  Byte-identical helpers also inlined in
//       tool/F_lattice_cpu_proxy.hexa (stage0 fallback strips imports).
//
// EXPORTED API (for documentation — stage0 inlines these by copy):
//   correlation_decay(ss, size)       -> [int]  // C(r) ppm for r ∈ [1..size/2]
//   power_law_alpha(cs)               -> int    // α × 1000 via 2-point log-linear fit
//   xi_over_e(cs)                     -> int    // r × 1000 where C(r) ≈ C(1)/e
//
// PAIRS WITH: edu_new/F_l3_emergence_measure.hexa (physics truth) and
//             tool/F_lattice_cpu_proxy.hexa (N=16 runner).
//
// DETERMINISM: pure functions of integer state arrays.

// ─── integer primitives (same as F_lattice_unified.hexa) ──────────────

fn iabs(x: int) -> int { if x < 0 { return 0 - x } return x }

fn sign_of(x: int) -> int {
    if x > 0 { return 1 }
    if x < 0 { return -1 }
    return 0
}

fn clamp_int(v: int, lo: int, hi: int) -> int {
    if v < lo { return lo }
    if v > hi { return hi }
    return v
}

// integer log2 × 1000 approximation (small-argument table + bit-shift fallback).
fn log2k(n: int) -> int {
    if n <= 1 { return 0 }
    if n == 2 { return 1000 }
    if n == 3 { return 1585 }
    if n == 4 { return 2000 }
    if n == 5 { return 2322 }
    if n == 6 { return 2585 }
    if n == 7 { return 2807 }
    if n == 8 { return 3000 }
    if n == 9 { return 3170 }
    if n == 10 { return 3322 }
    if n == 11 { return 3459 }
    if n == 12 { return 3585 }
    if n == 13 { return 3700 }
    if n == 14 { return 3807 }
    if n == 15 { return 3907 }
    if n == 16 { return 4000 }
    let mut m = n
    let mut k = 0
    while m > 1 {
        m = m / 2
        k = k + 1
    }
    let base = k * 1000
    let mut lo = 1
    let mut p  = 0
    while p < k { lo = lo * 2 ; p = p + 1 }
    let hi   = lo * 2
    let frac = if hi > lo { ((n - lo) * 1000) / (hi - lo) } else { 0 }
    return base + frac
}

// ─── correlation: C(r) on parallel state array ─────────────────────────
//
// ss[] = flat row-major state codes: 0=active, 1=drop, 2=sealed.
// C(r) = mean over cell-pairs at Manhattan distance r of indicator
//        { both non-active AND same state }.  Returned in ppm (0..1000).
fn correlation_at(ss: [int], size: int, r_target: int) -> int {
    let mut pairs = 0
    let mut same  = 0
    let mut r = 0
    while r < size {
        let mut c = 0
        while c < size {
            let mut rr = r
            while rr < size {
                let c_start = if rr == r { c + 1 } else { 0 }
                let mut cc  = c_start
                while cc < size {
                    let d = iabs(rr - r) + iabs(cc - c)
                    if d == r_target {
                        let si = ss[r * size + c]
                        let sj = ss[rr * size + cc]
                        pairs = pairs + 1
                        if si != 0 && si == sj { same = same + 1 }
                    }
                    cc = cc + 1
                }
                rr = rr + 1
            }
            c = c + 1
        }
        r = r + 1
    }
    if pairs == 0 { return 0 }
    return (same * 1000) / pairs
}

// correlation_decay(ss, size) → [C(1), C(2), …, C(size/2)] in ppm.
fn correlation_decay(ss: [int], size: int) -> [int] {
    let r_max   = size / 2
    let mut out = []
    let mut r   = 1
    while r <= r_max {
        out = out.push(correlation_at(ss, size, r))
        r   = r + 1
    }
    return out
}

// Power-law fit: α × 1000 via 2-point log-linear (first and last r).
// C(r) ~ r^(-α)  ⇒  α = (log C(1) - log C(r_max)) / log(r_max).
// Returns 0 if any sample is zero or if C decreases to zero (no decay detected).
fn power_law_alpha(cs: [int]) -> int {
    let n = len(cs)
    if n < 2 { return 0 }
    let c1 = cs[0]
    let cn = cs[n - 1]
    if c1 <= 0 || cn <= 0 { return 0 }
    if cn >= c1 { return 0 }
    let r_max = n     // r in [1..n], so last r = n
    let num   = log2k(c1) - log2k(cn)
    let den   = log2k(r_max)
    if den <= 0 { return 0 }
    return (num * 1000) / den
}

// ξ (correlation length) × 1000, defined as smallest r where C(r) ≤ C(1)/e.
// Uses e≈2.718 → C(1)/e ≈ C(1) * 368/1000 (integer arithmetic).
// If no r satisfies, extrapolate linearly on the last segment.
fn xi_over_e(cs: [int]) -> int {
    let n = len(cs)
    if n < 1 { return 0 }
    let c1 = cs[0]
    if c1 <= 0 { return 0 }
    let thresh = (c1 * 368) / 1000
    let mut i  = 0
    while i < n {
        if cs[i] <= thresh {
            // Linear interpolation between (i, cs[i]) and (i-1, cs[i-1])
            // where r_index = i + 1 (since r = i+1 in our array).
            if i == 0 { return 1000 }
            let prev = cs[i - 1]
            let cur  = cs[i]
            if prev == cur { return (i + 1) * 1000 }
            let frac = ((prev - thresh) * 1000) / (prev - cur)
            return i * 1000 + frac
        }
        i = i + 1
    }
    // Never crossed threshold — return r_max * 1000 as floor.
    return n * 1000
}

// ─── self-test ──────────────────────────────────────────────────────────

fn assert_c(name: string, cond: bool) -> int {
    if cond { println("  OK  " + name) ; return 0 }
    println("  FAIL " + name) ; return 1
}

fn main() {
    println("F_lattice_correlation selftest")
    let mut fails = 0

    // T1: synthetic 4x4 with sealed diag (state=2 at positions (0,0),(1,1),(2,2),(3,3))
    //     and drop at (0,3),(3,0).  C(r=1) should be low (neighbours differ),
    //     C(r=2) moderate, C(r=3) should include (0,0)↔(3,3) diag sealed pair → ≥0.
    let size = 4
    let mut ss = []
    let mut i  = 0
    while i < size * size {
        let r = i / size
        let c = i - r * size
        if r == c { ss = ss.push(2) }
        else {
            if (r == 0 && c == 3) || (r == 3 && c == 0) { ss = ss.push(1) }
            else { ss = ss.push(0) }
        }
        i = i + 1
    }

    let cs = correlation_decay(ss, size)
    fails = fails + assert_c("decay array length", len(cs) == size / 2)
    println("  cs = " + str(cs[0]) + " " + str(cs[1]))

    // α fit should be 0 when cn >= c1 (no decay) or positive when decaying.
    let a1 = power_law_alpha(cs)
    fails = fails + assert_c("alpha non-negative", a1 >= 0)
    println("  alpha_x1000 = " + str(a1))

    // ξ on synthetic series: strictly decaying [800, 400, 200, 100] → crosses 368
    //   of 800 = 294 between r=2 (400) and r=3 (200), closer to r≈2.3.
    let synth = [800, 400, 200, 100]
    let xi    = xi_over_e(synth)
    fails = fails + assert_c("xi > 1000 (crosses after r=1)", xi >= 1000)
    fails = fails + assert_c("xi < 4000 (crosses before r=4)", xi <= 4000)
    println("  xi_x1000 (synth) = " + str(xi))

    // Power-law on clean synthetic with C(r) = 1000/r (α=1):
    let clean = [1000, 500, 333, 250]
    let a_c   = power_law_alpha(clean)
    fails = fails + assert_c("alpha clean in [800, 1200]", a_c >= 800 && a_c <= 1200)
    println("  alpha_x1000 (clean) = " + str(a_c))

    if fails == 0 {
        println("F_lattice_correlation: PASS")
        exit(0)
    } else {
        println("F_lattice_correlation: FAIL (" + str(fails) + " assertions)")
        exit(1)
    }
}
