// tool/kick_with_trailer_wrapper.hexa — Pattern 7c kick CLI wrapper (raw 136 enforcement)
// ─────────────────────────────────────────────────────────────
// raw 136 kick-result-return-ai-native-trailer enforcement via WRAPPER
// (low-risk alternative to direct kick_dispatch.hexa edit).
//
// USAGE
//   hexa run tool/kick_with_trailer_wrapper.hexa --selftest
//   hexa run tool/kick_with_trailer_wrapper.hexa --emit-trailer-from-witness <witness_path>
//
// PATTERN
//   1. Caller fires nexus kick → emits __KICK_RESULT__ <PASS|FAIL> ...
//   2. Caller invokes this wrapper with witness path
//   3. Wrapper reads witness JSON, extracts fixpoint_marker (reason equiv) +
//      tier_1_promotions[].absorption_target (fix equiv)
//   4. Wrapper emits raw 66-style trailer:
//      reason: <fixpoint_marker[:80]>
//      fix: 1) absorb tier_1 to <repo>/state/discovery_absorption/registry.jsonl
//           2) review witness JSON
//           3) carry_forward to next cycle
//
// raw#9 hexa-only.
// raw#10 honest: post-hoc trailer emission (after sentinel) not at-emission.
//   For at-emission, kick_dispatch.hexa direct edit needed (deferred per risk).
// raw#37 transient — emit /tmp helper.
// ─────────────────────────────────────────────────────────────

let HELPER_PATH = "/tmp/kick_with_trailer_wrapper_helper.hexa_tmp"
let WRAPPER_VERSION = "v1_pattern_7c"

fn _emit_helper() -> str {
    let lines = [
        "#!/usr/bin/env python3",
        "import os, sys, json",
        "",
        "def emit_trailer(witness_path):",
        "    if not os.path.exists(witness_path):",
        "        print(f'reason: witness-not-found: {witness_path}')",
        "        print(f'fix: 1) verify path 2) check kick FAIL log 3) consider raw 100 fallback in-context synthesis')",
        "        return 1",
        "    try:",
        "        with open(witness_path) as f: d = json.load(f)",
        "    except Exception as e:",
        "        print(f'reason: witness-parse-fail: {e}')",
        "        print(f'fix: 1) inspect JSON syntax 2) repair manually 3) re-fire kick')",
        "        return 1",
        "    fixpoint = d.get('fixpoint_marker', '')",
        "    if not fixpoint:",
        "        k5 = d.get('core_5_op_kernel', {})",
        "        if isinstance(k5, dict): fixpoint = k5.get('fixpoint_marker', '')",
        "    if not fixpoint: fixpoint = 'no-fixpoint-marker'",
        "    fixpoint_short = fixpoint[:120] + ('...' if len(fixpoint) > 120 else '')",
        "    tier1 = d.get('tier_1_promotions', [])",
        "    if not tier1:",
        "        k5 = d.get('core_5_op_kernel', {})",
        "        if isinstance(k5, dict): tier1 = k5.get('tier_1_promotions', [])",
        "    n_tier1 = len(tier1) if isinstance(tier1, list) else 0",
        "    repo_dir = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(witness_path))))",
        "    registry = os.path.join(repo_dir, 'state/discovery_absorption/registry.jsonl')",
        "    print(f'reason: {fixpoint_short}')",
        "    print(f'fix: 1) absorb {n_tier1} tier_1 to {registry}')",
        "    print(f'     2) review witness {os.path.basename(witness_path)}')",
        "    print(f'     3) carry_forward to next cycle per witness.carry_forward_to_next_cycle field')",
        "    return 0",
        "",
        "if __name__ == '__main__':",
        "    if len(sys.argv) < 2:",
        "        print('usage: kick_with_trailer_wrapper_helper.py <witness_path>')",
        "        sys.exit(1)",
        "    sys.exit(emit_trailer(sys.argv[1]))",
    ]
    let mut text = ""
    let mut i = 0
    while i < lines.len() {
        text = text + lines[i] + "\n"
        i = i + 1
    }
    write_file(HELPER_PATH, text)
    return HELPER_PATH
}

fn _selftest() {
    println("__KICK_TRAILER_WRAPPER_BEGIN__ selftest raw 136 Pattern 7c raw#9 raw#10 raw#37")
    let path = _emit_helper()
    println("helper emitted to " + path)
    println("invariant_check_wrapper_version=" + WRAPPER_VERSION)
    println("invariant_check_raw_136_trailer_emission=post-hoc")
    println("invariant_check_at_emission_NOT_satisfied=true (kick_dispatch direct edit deferred)")
    println("invariant_check_low_risk_alternative=true")
    println("__KICK_TRAILER_WRAPPER_RESULT__ PASS_SELFTEST")
    // raw 136 self-applied trailer
    println("reason: Pattern 7c wrapper provides post-hoc raw 136 trailer emission as low-risk alt to kick_dispatch.hexa edit (gap 3 closure)")
    println("fix: 1) python3 " + path + " <witness_path> to emit trailer  2) caller scripts wrap nexus kick + invoke this  3) future cycle for kick_dispatch direct edit at-emission compliance")
    println("raw_10_caveat=post-hoc emission not at-emission per raw 136 strict; wrapper mitigates risk vs cli edit")
    println("raw_10_caveat=requires caller integration; not auto-active until wrappers wire kick fires")
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        k = k + 1
    }
    if has_selftest {
        _selftest()
        return
    }
    println("usage: kick_with_trailer_wrapper.hexa --selftest | --emit-trailer-from-witness <path>")
}
