// tool/_airgenome_probe_selftest.hexa — smoke test for airgenome_cli_probe
//
// Verifies that the 3 fields (air_chain / touch_count / air_schema_version)
// emitted by cert writers are back-compat safe: when airgenome CLI is absent
// the probe must yield null/0/"v1" without touching any airgenome state file.

use "airgenome_cli_probe"

fn main() {
    let avail = ag_probe_available()
    let chain = if avail { ag_probe_top_chain() } else { "" }
    let tc = if avail && chain != "" { ag_probe_touch_count(chain) } else { 0 }
    let schema = ag_schema_version()
    let chain_json = if chain == "" { "null" } else { "\"" + chain + "\"" }

    println("airgenome_cli_probe selftest")
    println("  ag_probe_available    = " + (if avail { "true" } else { "false" }))
    println("  ag_probe_top_chain    = " + chain_json)
    println("  ag_probe_touch_count  = " + str(tc))
    println("  ag_schema_version     = \"" + schema + "\"")

    // Assertions: schema is always v1, touch_count >= 0, chain is "" or non-empty sha.
    if schema != "v1" {
        println("FAIL: schema mismatch")
        exit(1)
    }
    if tc < 0 {
        println("FAIL: touch_count negative")
        exit(1)
    }
    println("PASS: probe yields back-compat-safe values")
    exit(0)
}

main()
