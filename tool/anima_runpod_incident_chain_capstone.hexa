// tool/anima_runpod_incident_chain_capstone.hexa — cycles 52-58 RunPod incident chain capstone (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycles 52-58 = 7-cycle runaway cost incident root cause chain. cycle 59 capstone:
//   single-artifact user reference (다음 세션 + 사용자 즉시 결정용).
//
//   본 helper = mac-local NON_MUTATION:
//     - chain timeline (cycles 52-58)
//     - incident facts frozen (pods, costs, root cause)
//     - 5-step user playbook (cycle 58 mirror)
//     - prevention cron entry
//     - selftest verifies: 7-cycle chain / 5-step playbook / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/runpod_incident_chain_capstone.json)
//
// OUTPUT
//   - chain_timeline (7 cycles)
//   - incident_facts
//   - user_playbook (5 steps)
//   - prevention_cron_entry
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_runpod_incident_chain_capstone.hexa --selftest
//   ANIMA_OUTPUT=state/runpod_incident_chain_capstone.json hexa run tool/anima_runpod_incident_chain_capstone.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - chain timeline은 cycles 52-58 commits + state JSON 기반.
//   - incident facts는 cycle 55 patched values (cumulative $122.96).
//   - user playbook은 cycle 58 5-step에서 derived.

let HELPER_PATH = "/tmp/anima_runpod_incident_chain_capstone_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima RunPod incident chain capstone — emitted by tool/anima_runpod_incident_chain_capstone.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION 7-cycle chain consolidation.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/runpod_incident_chain_capstone.json')\n\n")

    parts.push("CHAIN_TIMELINE = [\n")
    parts.push("    {'cycle':52, 'discovery':'2 H100 SXM RUNNING ($5.98/hr)', 'state_file':'runpod_active_pods_auditor.json'},\n")
    parts.push("    {'cycle':53, 'discovery':'cycle 13 false-negative correction (creds in config files)', 'state_file':'external_gpu_combined_auditor.json'},\n")
    parts.push("    {'cycle':54, 'discovery':'runaway incident formal record (caps 61.5x escape)', 'state_file':'runpod_runaway_cost_incident_auditor.json'},\n")
    parts.push("    {'cycle':55, 'discovery':'cycle 54 datetime parser patch (cumulative $122.96 accurate)', 'patch':True},\n")
    parts.push("    {'cycle':56, 'discovery':'ssh activity (Pod 1 IDLE, Pod 2 transitional)', 'state_file':'runpod_pods_ssh_activity_auditor.json'},\n")
    parts.push("    {'cycle':57, 'discovery':'cap enforcement root cause (env set, no runtime attach)', 'state_file':'h100_cap_enforcement_root_cause_auditor.json'},\n")
    parts.push("    {'cycle':58, 'discovery':'config root cause (pods.json EMPTY + sync.bash NOT in cron)', 'state_file':'h100_full_chain_remediation.json'},\n")
    parts.push("]\n\n")

    parts.push("INCIDENT_FACTS = {\n")
    parts.push("    'pods_active':2,\n")
    parts.push("    'pod_1':{\n")
    parts.push("        'id':'bnabak3i4r38bg',\n")
    parts.push("        'name':'anima-sae-steer-pilot',\n")
    parts.push("        'ip':'103.207.149.52',\n")
    parts.push("        'port':19147,\n")
    parts.push("        'created_utc':'2026-04-26 05:29:47',\n")
    parts.push("        'env_caps':'COST_CAP=$1, RUNTIME_CAP_MIN=15',\n")
    parts.push("        'gpu_util_now':'0% (IDLE confirmed via ssh)',\n")
    parts.push("        'cost_per_hr':2.99,\n")
    parts.push("    },\n")
    parts.push("    'pod_2':{\n")
    parts.push("        'id':'1an0fdtr2mrif1',\n")
    parts.push("        'name':'anima-gwt-deepseek-c2-long',\n")
    parts.push("        'ssh_status':'pod not ready (transitional)',\n")
    parts.push("        'created_utc':'2026-04-26 03:44:40',\n")
    parts.push("        'env_caps':'COST_CAP=$1, RUNTIME_CAP_MIN=12',\n")
    parts.push("        'cost_per_hr':2.99,\n")
    parts.push("    },\n")
    parts.push("    'cumulative_spent_usd':122.96,\n")
    parts.push("    'intended_cap_usd':2.00,\n")
    parts.push("    'escape_ratio':61.5,\n")
    parts.push("    'current_burn_per_hr':5.98,\n")
    parts.push("    'account_balance_usd':347.26,\n")
    parts.push("    'hours_until_balance_zero':57.5,\n")
    parts.push("    'days_until_balance_zero':2.4,\n")
    parts.push("}\n\n")

    parts.push("ROOT_CAUSE_LAYERS = [\n")
    parts.push("    {'layer':1, 'finding':'launch helpers SET caps as env vars but do NOT auto-attach guard runtime'},\n")
    parts.push("    {'layer':2, 'finding':'tool/h100_auto_kill.hexa exists but reads config/h100_pods.json (empty)'},\n")
    parts.push("    {'layer':3, 'finding':'tool/h100_pods_sync.bash exists but NOT in cron (config 3-day stale)'},\n")
    parts.push("]\n\n")

    parts.push("USER_PLAYBOOK = [\n")
    parts.push("    {\n")
    parts.push("        'step':1, 'priority':'IMMEDIATE',\n")
    parts.push("        'action':'sync config from current runpod state',\n")
    parts.push("        'command':'bash tool/h100_pods_sync.bash',\n")
    parts.push("        'risk':'NONE (read-only refresh)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'step':2, 'priority':'IMMEDIATE',\n")
    parts.push("        'action':'verify config has 2 active pods',\n")
    parts.push("        'command':'cat config/h100_pods.json | python3 -m json.tool | head -30',\n")
    parts.push("        'risk':'NONE (read-only)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'step':3, 'priority':'IMMEDIATE',\n")
    parts.push("        'action':'dry-run h100_auto_kill (preview which pods would terminate)',\n")
    parts.push("        'command':'hexa run tool/h100_auto_kill.hexa',\n")
    parts.push("        'risk':'NONE (dry-run default)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'step':4, 'priority':'USER_DECISION',\n")
    parts.push("        'action':'apply termination (irreversible — pods stop and lose state)',\n")
    parts.push("        'command':'hexa run tool/h100_auto_kill.hexa --apply',\n")
    parts.push("        'risk':'MEDIUM — IDLE pods safe to terminate; in-progress work lost if any',\n")
    parts.push("        'safety':'run step 3 dry-run first; if Pod 2 is doing real work it should NOT be in stop list (5min idle threshold)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'step':5, 'priority':'PREVENTION',\n")
    parts.push("        'action':'add hourly cron entry for prevention',\n")
    parts.push("        'command':'(crontab -l 2>/dev/null; echo \"7 * * * * cd /Users/ghost/core/anima && bash tool/h100_pods_sync.bash >/dev/null 2>&1 && hexa run tool/h100_auto_kill.hexa --apply >/dev/null 2>&1\") | crontab -',\n")
    parts.push("        'risk':'LOW — cron auto-runs hourly with 5-min idle threshold',\n")
    parts.push("        'savings_estimate':'$143/2d incidents prevented per roadmap motivation',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("PREVENTION_CRON_ENTRY = '7 * * * * cd /Users/ghost/core/anima && bash tool/h100_pods_sync.bash >/dev/null 2>&1 && hexa run tool/h100_auto_kill.hexa --apply >/dev/null 2>&1'\n\n")

    parts.push("MEMORY_UPDATE_RECOMMENDED = {\n")
    parts.push("    'file':'/Users/ghost/.claude-claude11/projects/-Users-ghost-core-anima/memory/project_h100_launch_pending.md',\n")
    parts.push("    'current_state':'h100 출발은 아직 대기 (2026-04-22)',\n")
    parts.push("    'reality':'2 H100 RUNNING since 2026-04-26 (5 days, $122.96 spent, $5.98/hr)',\n")
    parts.push("    'update_action':'either remove memory (if pods terminated) OR update to reflect ongoing burn (if intentional)',\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycles 52-58 RunPod incident chain capstone (single user-action artifact)',\n")
    parts.push("    'chain_timeline':CHAIN_TIMELINE,\n")
    parts.push("    'chain_length_cycles':len(CHAIN_TIMELINE),\n")
    parts.push("    'incident_facts':INCIDENT_FACTS,\n")
    parts.push("    'root_cause_layers':ROOT_CAUSE_LAYERS,\n")
    parts.push("    'user_playbook':USER_PLAYBOOK,\n")
    parts.push("    'prevention_cron_entry':PREVENTION_CRON_ENTRY,\n")
    parts.push("    'memory_update_recommended':MEMORY_UPDATE_RECOMMENDED,\n")
    parts.push("    'urgency':'CRITICAL — $5.98/hr burn ongoing; 57.5 hours until balance zero',\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT execute any remediation; user manual playbook required',\n")
    parts.push("    'cross_link_cycles':['cycles 52-58 (7-cycle chain)','cycle 13 H100 P1 precheck'],\n")
    parts.push("    'pattern':'governance audit chain layer 38 (cycles 21-58 + this) — incident chain consolidation',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[incident_capstone] chain_cycles={len(CHAIN_TIMELINE)} root_layers={len(ROOT_CAUSE_LAYERS)} playbook_steps={len(USER_PLAYBOOK)} cumulative=${INCIDENT_FACTS[\"cumulative_spent_usd\"]} balance=${INCIDENT_FACTS[\"account_balance_usd\"]} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let chain_cycles = 7
    let root_layers = 3
    let playbook_steps = 5
    let urgency = "CRITICAL"
    let non_mutation = "READ_ONLY"
    println("inv:chain_cycles=" + to_string(chain_cycles))
    println("inv:root_layers=" + to_string(root_layers))
    println("inv:playbook_steps=" + to_string(playbook_steps))
    println("inv:urgency=" + urgency)
    println("inv:non_mutation=" + non_mutation)
    println("inv:cross_link_cycles_52_to_58=true")
    return true
}

fn cmd_selftest() {
    println("── anima_runpod_incident_chain_capstone selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=RunPod incident chain capstone (7-cycle / 3-layer root / 5-step playbook; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
