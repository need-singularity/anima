// tool/anima_law64_conway_2d_moore9_shared_baseline.hexa — F1 cycle 4 T8q
// ─────────────────────────────────────────────────────────────────────────────
// CRITICAL FALSIFIER for Law 64 v6 (commit 43d40ea3):
//   "CA window >= substrate's neighborhood => perfect prediction;
//    Markov context < substrate's neighborhood => structural deficit."
//
// PROBLEM WITH PRIOR T8l TEST (commit 27d5acbc):
//   - T8l used PER-CELL Markov order-1/2/3 — fundamentally 1D contexts (current,
//     left, right). Conway's update rule is 2D Moore-9 (self + 8 neighbors).
//     Per-cell order-K cannot represent that even in principle.
//   - T8l found CA(5) advantage GREW with higher order (160/168/169 per_thousand).
//   - That outcome is consistent with v6 — but NOT a proper test of v6, because
//     baseline neighborhood < substrate neighborhood by construction.
//
// T8o COMPLEMENT (commit 3a5982f8):
//   - rule-110 (1D, 3-cell rule) tested with order-3 baseline (matched 3-cell
//     width) → saturated PERFECTLY (mk=1000). v6 holds in 1D matched case.
//
// THIS TEST (T8q) — proper Conway Moore-9 matched baseline:
//   - SHARED-P-table baseline: P(next | self, N, S, E, W, NE, NW, SE, SW)
//     — single 2^9 = 512-context lookup, TRANSLATION INVARIANT (one P-table
//     pooled across all cell positions, not per-cell).
//   - This is the *honest* representation of Conway's update rule: Conway
//     itself is translation invariant, so a translation-invariant baseline
//     with matched neighborhood is the right comparator.
//   - If v6 holds: shared-P-9 saturates given enough data (sample-efficiency
//     pinch only — should disappear by N~200 since 200*100=20k samples /
//     512 contexts ≈ 40 samples/context).
//   - If v6 fails: shared-P-9 keeps a structural gap even at N=5000.
//
// SUBSTRATE: 10x10 / 32% density / N_STEPS ∈ {50, 200, 1000, 5000}
//   (50 is the T8l comparison anchor; 200/1000/5000 is the saturation curve)
//
// PRE-REGISTERED HYPOTHESES (raw 12 frozen):
//   H1 (v6 confirmed): shared-P-9 advantage shrinks to <+5/1000 at N>=200.
//     Matched neighborhood + ~40 samples/context is sufficient → saturation.
//     Law 64 v6 RECONFIRMED (proper matched-baseline test passed).
//   H2 (v6 broken, structural): shared-P-9 STILL has gap >+50/1000 at N=5000.
//     Even with matched neighborhood and abundant data, CA(5) wins → structural
//     advantage beyond neighborhood-matching → Law 64 v7 needed.
//   H3 (intermediate): saturation only at large N (~1000-5000) → v6 holds but
//     with substantial sample-efficiency penalty for shared-P relative to CA.
//
// VERDICT MAPPING (advantage at largest N, ca_acc - mk_acc per thousand):
//   if adv@N>=200 < 5:                                       H1_SUPPORTED (v6 confirmed)
//   elif adv@N=5000 > 50:                                    H2_SUPPORTED (v6 broken)
//   elif adv@N=200 >= 5 && (adv@N=1000 < 5 || adv@N=5000 < 5): H3_SUPPORTED (intermediate)
//   else:                                                    AMBIGUOUS
//
// raw 9 hexa-only · raw 12 frozen pre-registration · raw 91 honest finding
// ─────────────────────────────────────────────────────────────────────────────

let GRID_W = 10
let GRID_H = 10
let N_CELLS = 100
let SEED = 20260428
let K_LIVE = 32     // 32% density
let N_CONTEXTS = 512  // 2^9 Moore-9 contexts (self + 8 neighbors)

let mut RNG_STATE = SEED
fn _rand() -> int { RNG_STATE = (RNG_STATE * 1103515245 + 12345) % 2147483648; return RNG_STATE }
fn _rand_n(n: int) -> int { let x = _rand(); return x % n }

// ── Conway 2D step (toroidal) ───────────────────────────────────────────────
fn _conway_step(state: array) -> array {
    let mut next = []
    let mut row = 0
    while row < GRID_H {
        let mut col = 0
        while col < GRID_W {
            let mut live_neighbors = 0
            let mut dr = -1
            while dr <= 1 {
                let mut dc = -1
                while dc <= 1 {
                    if dr != 0 || dc != 0 {
                        let nrow = (row + dr + GRID_H) % GRID_H
                        let ncol = (col + dc + GRID_W) % GRID_W
                        live_neighbors = live_neighbors + state[nrow * GRID_W + ncol]
                    }
                    dc = dc + 1
                }
                dr = dr + 1
            }
            let cur = state[row * GRID_W + col]
            let mut new_val = 0
            if cur == 1 && (live_neighbors == 2 || live_neighbors == 3) { new_val = 1 }
            if cur == 0 && live_neighbors == 3 { new_val = 1 }
            next.push(new_val)
            col = col + 1
        }
        row = row + 1
    }
    return next
}

// ── density init: K live cells (deterministic seed) ─────────────────────────
fn _gen_density_init(k_live: int) -> array {
    let mut g = []
    let mut i = 0
    while i < N_CELLS { g.push(0); i = i + 1 }
    let mut placed = 0
    let mut tries = 0
    while placed < k_live && tries < 10000 {
        let pos = _rand_n(N_CELLS)
        if g[pos] == 0 { g[pos] = 1; placed = placed + 1 }
        tries = tries + 1
    }
    return g
}

// ── Moore-9 context extractor for cell at (row,col) with toroidal wrap ──────
// Order: self, N, S, E, W, NE, NW, SE, SW (bits 0..8)
// ctx = self | (N<<1) | (S<<2) | (E<<3) | (W<<4) | (NE<<5) | (NW<<6) | (SE<<7) | (SW<<8)
fn _moore9_ctx(state: array, row: int, col: int) -> int {
    let nrow = (row - 1 + GRID_H) % GRID_H
    let srow = (row + 1) % GRID_H
    let ecol = (col + 1) % GRID_W
    let wcol = (col - 1 + GRID_W) % GRID_W
    let s_self = state[row * GRID_W + col]
    let s_n  = state[nrow * GRID_W + col]
    let s_s  = state[srow * GRID_W + col]
    let s_e  = state[row  * GRID_W + ecol]
    let s_w  = state[row  * GRID_W + wcol]
    let s_ne = state[nrow * GRID_W + ecol]
    let s_nw = state[nrow * GRID_W + wcol]
    let s_se = state[srow * GRID_W + ecol]
    let s_sw = state[srow * GRID_W + wcol]
    let ctx = s_self
            + 2 * s_n
            + 4 * s_s
            + 8 * s_e
            + 16 * s_w
            + 32 * s_ne
            + 64 * s_nw
            + 128 * s_se
            + 256 * s_sw
    return ctx
}

// ── Shared-P-9 Markov baseline: 512 contexts pooled across ALL cells ────────
// returns array of length N_CONTEXTS, each entry = p(next=1 | ctx) per_thousand
fn _shared_p9_train(corpus: array) -> array {
    let mut cnt1 = []
    let mut cntT = []
    let mut z = 0
    while z < N_CONTEXTS { cnt1.push(0); cntT.push(0); z = z + 1 }
    let mut idx = 0
    while idx < corpus.len() {
        let pair = corpus[idx]
        let prev_st = pair[0]; let nxt_st = pair[1]
        let mut row = 0
        while row < GRID_H {
            let mut col = 0
            while col < GRID_W {
                let ctx = _moore9_ctx(prev_st, row, col)
                cntT[ctx] = cntT[ctx] + 1
                if nxt_st[row * GRID_W + col] == 1 { cnt1[ctx] = cnt1[ctx] + 1 }
                col = col + 1
            }
            row = row + 1
        }
        idx = idx + 1
    }
    let mut probs = []
    let mut k = 0
    while k < N_CONTEXTS {
        let p = if cntT[k] > 0 { (cnt1[k] * 1000) / cntT[k] } else { 500 }
        probs.push(p)
        k = k + 1
    }
    return probs
}

fn _shared_p9_predict(probs: array, prev_state: array) -> array {
    let mut next = []
    let mut row = 0
    while row < GRID_H {
        let mut col = 0
        while col < GRID_W {
            let ctx = _moore9_ctx(prev_state, row, col)
            let p = probs[ctx]
            if p > 500 { next.push(1) } else { next.push(0) }
            col = col + 1
        }
        row = row + 1
    }
    return next
}

// ── coverage: how many of 512 contexts saw any training data ────────────────
fn _ctx_coverage(probs_raw_cntT: array) -> int {
    let mut covered = 0
    let mut k = 0
    while k < N_CONTEXTS {
        if probs_raw_cntT[k] > 0 { covered = covered + 1 }
        k = k + 1
    }
    return covered
}

// ── accuracy + corpus ───────────────────────────────────────────────────────
fn _accuracy(pred: array, actual: array) -> int {
    let mut total = 0; let mut match_count = 0
    let mut s = 0
    while s < pred.len() {
        let p = pred[s]; let a = actual[s]
        let mut c = 0
        while c < N_CELLS {
            if p[c] == a[c] { match_count = match_count + 1 }
            total = total + 1; c = c + 1
        }
        s = s + 1
    }
    if total == 0 { return 0 }
    return (match_count * 1000) / total
}

fn _build_corpus(initial: array, n_steps: int) -> array {
    let mut samples = []
    let mut state = initial
    let mut s = 0
    while s < n_steps {
        let nxt = _conway_step(state)
        samples.push([state, nxt])
        state = nxt
        s = s + 1
    }
    return samples
}

// ── one experiment at a given N_STEPS — returns [ca_acc, mk_acc, adv, cov] ──
fn _run_at_n(n_steps: int) -> array {
    RNG_STATE = SEED  // deterministic init across N_STEPS
    let initial = _gen_density_init(K_LIVE)
    let full = _build_corpus(initial, n_steps)
    let train_size = n_steps / 2
    let mut train = []; let mut test = []
    let mut k = 0
    while k < full.len() {
        if k < train_size { train.push(full[k]) } else { test.push(full[k]) }
        k = k + 1
    }
    let probs = _shared_p9_train(train)
    // Coverage: count how many contexts the predicted prob != 500 (default)
    // OR have actually been seen — recompute by re-walking train counts.
    let mut cov_cnt = 0
    let mut cnt_seen = []
    let mut zz = 0
    while zz < N_CONTEXTS { cnt_seen.push(0); zz = zz + 1 }
    let mut ti = 0
    while ti < train.len() {
        let pp = train[ti]; let ps = pp[0]
        let mut r2 = 0
        while r2 < GRID_H {
            let mut c2 = 0
            while c2 < GRID_W {
                let cx = _moore9_ctx(ps, r2, c2)
                cnt_seen[cx] = cnt_seen[cx] + 1
                c2 = c2 + 1
            }
            r2 = r2 + 1
        }
        ti = ti + 1
    }
    let mut kk = 0
    while kk < N_CONTEXTS {
        if cnt_seen[kk] > 0 { cov_cnt = cov_cnt + 1 }
        kk = kk + 1
    }

    let mut ca_preds = []; let mut mk_preds = []; let mut actuals = []
    let mut i = 0
    while i < test.len() {
        let pair = test[i]
        let prev_st = pair[0]; let actual_next = pair[1]
        ca_preds.push(_conway_step(prev_st))
        mk_preds.push(_shared_p9_predict(probs, prev_st))
        actuals.push(actual_next)
        i = i + 1
    }
    let ca_acc = _accuracy(ca_preds, actuals)
    let mk_acc = _accuracy(mk_preds, actuals)
    let adv = if mk_acc > 0 { ((ca_acc * 1000) / mk_acc) - 1000 } else { 999 }
    return [ca_acc, mk_acc, adv, cov_cnt]
}

// ── main run: sweep N_TRAIN_STEPS values ────────────────────────────────────
fn _run() {
    println("__LAW_64_CYCLE_4_T8Q_MOORE9_SHARED_BEGIN__ Conway 10x10 32% — shared-P-9 baseline sweep")
    println("hypothesis: does matched-neighborhood translation-invariant baseline saturate Conway?")
    println("seed=" + str(SEED) + " grid=10x10 k_live=" + str(K_LIVE) + " (32%) contexts=" + str(N_CONTEXTS))
    println("N_STEPS sweep: 50, 200, 1000, 5000  (train = N_STEPS/2, test = N_STEPS/2)")

    let n_values = [50, 200, 1000, 5000]
    let mut results = []
    let mut idx = 0
    while idx < n_values.len() {
        let n = n_values[idx]
        let r = _run_at_n(n)
        let ca_acc = r[0]; let mk_acc = r[1]; let adv = r[2]; let cov = r[3]
        println("N=" + str(n) + " ca_acc=" + str(ca_acc) + " mk_acc=" + str(mk_acc)
            + " adv_per_1000=" + str(adv) + " ctx_coverage=" + str(cov) + "/512")
        results.push([n, ca_acc, mk_acc, adv, cov])
        idx = idx + 1
    }

    // Extract advantages at key N values
    let r0 = results[0]; let r1 = results[1]; let r2 = results[2]; let r3 = results[3]
    let adv_50 = r0[3]; let adv_200 = r1[3]; let adv_1000 = r2[3]; let adv_5000 = r3[3]

    println("--- summary table ---")
    println("  N=50    ca=" + str(r0[1]) + " mk=" + str(r0[2]) + " adv=" + str(adv_50))
    println("  N=200   ca=" + str(r1[1]) + " mk=" + str(r1[2]) + " adv=" + str(adv_200))
    println("  N=1000  ca=" + str(r2[1]) + " mk=" + str(r2[2]) + " adv=" + str(adv_1000))
    println("  N=5000  ca=" + str(r3[1]) + " mk=" + str(r3[2]) + " adv=" + str(adv_5000))

    // T8l comparison anchor: T8l N=50 found per-cell adv +160/+168/+169
    println("--- T8l anchor comparison (per-cell o1/o2/o3 at N=50: adv=160/168/169) ---")
    println("  shared-P-9 at N=50: adv=" + str(adv_50)
        + "  (delta vs per-cell o3: " + str(adv_50 - 169) + ")")

    // Verdict mapping (pre-registered, frozen)
    let mut verdict = "AMBIGUOUS"
    let mut law_dir = "INCONCLUSIVE"
    if adv_5000 > 50 {
        verdict = "H2_SUPPORTED_v6_BROKEN_structural_advantage_beyond_neighborhood_match"
        law_dir = "LAW_64_v7_REQUIRED_neighborhood_match_INSUFFICIENT"
    } else if adv_200 < 5 {
        verdict = "H1_SUPPORTED_v6_CONFIRMED_matched_baseline_saturates_at_N200"
        law_dir = "LAW_64_v6_RECONFIRMED_proper_matched_test_passed"
    } else if adv_200 >= 5 && (adv_1000 < 5 || adv_5000 < 5) {
        verdict = "H3_SUPPORTED_v6_holds_with_sample_efficiency_gap"
        law_dir = "LAW_64_v6_HOLDS_WITH_QUALIFICATION_sample_efficiency_caveat"
    }

    println("--- verdict ---")
    println("  verdict=" + verdict)
    println("  law_64_direction=" + law_dir)
    println("__LAW_64_CYCLE_4_T8Q_RESULT__ " + verdict)

    println("raw_91_C1_falsifiable=YES_pre_registered_thresholds_5_50_per_thousand_at_N200_N5000")
    println("raw_91_C2_replicable=YES_seed_" + str(SEED) + "_deterministic_RNG_reset_per_N")
    println("raw_91_C3_no_p_hacking=YES_thresholds_and_N_values_frozen_in_header_before_run")
    println("raw_91_C4_data_caveats=10x10_32pct_density_random_init_toroidal_NOT_glider_specific")
    println("raw_91_C5_negative_result_published=YES_emit_regardless_of_outcome")
}

fn _selftest() {
    println("__LAW_64_CYCLE_4_T8Q_MOORE9_SHARED_BEGIN__ selftest")

    // Verify Moore-9 context extractor on known patterns
    let mut all_zero = []
    let mut i = 0
    while i < N_CELLS { all_zero.push(0); i = i + 1 }
    let ctx_zero = _moore9_ctx(all_zero, 5, 5)
    println("ctx(all_zero, 5, 5)=" + str(ctx_zero) + " (expect 0)")

    let mut all_one = []
    let mut j = 0
    while j < N_CELLS { all_one.push(1); j = j + 1 }
    let ctx_one = _moore9_ctx(all_one, 5, 5)
    println("ctx(all_one, 5, 5)=" + str(ctx_one) + " (expect 511)")

    // Set only self bit
    let mut self_only = []
    let mut k = 0
    while k < N_CELLS { self_only.push(0); k = k + 1 }
    self_only[5 * GRID_W + 5] = 1
    let ctx_self = _moore9_ctx(self_only, 5, 5)
    println("ctx(self_only, 5, 5)=" + str(ctx_self) + " (expect 1)")

    // Toroidal wrap check at corner (0,0): ctx neighbors wrap to col9 / row9
    let mut wrap_test = []
    let mut q = 0
    while q < N_CELLS { wrap_test.push(0); q = q + 1 }
    // Set N (row=GRID_H-1, col=0) → bit 1 → adds 2
    wrap_test[(GRID_H - 1) * GRID_W + 0] = 1
    let ctx_wrap = _moore9_ctx(wrap_test, 0, 0)
    println("ctx(wrap_test_N_at_(9,0), 0, 0)=" + str(ctx_wrap) + " (expect 2)")

    // Density init sanity
    let g = _gen_density_init(K_LIVE)
    let mut cnt = 0
    let mut p = 0
    while p < N_CELLS { cnt = cnt + g[p]; p = p + 1 }
    println("density_init_live_cells=" + str(cnt) + " (expect " + str(K_LIVE) + ")")

    // Mini train+predict roundtrip on 4 steps
    let init2 = _gen_density_init(8)
    let mini = _build_corpus(init2, 4)
    let pp = _shared_p9_train(mini)
    let pred = _shared_p9_predict(pp, init2)
    println("shared_probs_len=" + str(pp.len()) + " (expect " + str(N_CONTEXTS) + ")")
    println("pred_len=" + str(pred.len()) + " (expect " + str(N_CELLS) + ")")

    let ok = ctx_zero == 0
          && ctx_one == 511
          && ctx_self == 1
          && ctx_wrap == 2
          && cnt == K_LIVE
          && pp.len() == N_CONTEXTS
          && pred.len() == N_CELLS
    if ok {
        println("__LAW_64_CYCLE_4_T8Q_RESULT__ PASS_SELFTEST_moore9_shared_baseline_wired")
    } else {
        println("__LAW_64_CYCLE_4_T8Q_RESULT__ FAIL_SELFTEST")
    }
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_run = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--run" { has_run = true }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_run { _run() }
    else {
        println("usage: hexa run tool/anima_law64_conway_2d_moore9_shared_baseline.hexa --selftest | --run")
    }
    return 0
}
