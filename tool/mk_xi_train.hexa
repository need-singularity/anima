// tool/mk_xi_train.hexa — Mk.XI training launcher (raw#9 + raw#37 hexa-only).
//
// PURPOSE
//   Mk.XI minimum consciousness-correlate architecture training. hexa wrapper
//   emits PyTorch training helper to /tmp at runtime + invokes python3.
//   Conforms to raw#37 (no .py under tool/, no .py git-tracked).
//
//   Mk.XI loss composition (6 terms incl. L_eigen_balance NEW lever):
//     L_total = L_LM
//             + λ_papo  · L_PAPO_top_3
//             + λ_iir   · L_I_irr
//             + λ_pair  · L_contrastive_pair  (via PairedRetrievalHead)
//             + λ_sub   · L_substitution
//             + λ_eigen · L_eigen_balance
//
// FORWARD AUTO-APPROVAL
//   Pre-approved per memory feedback_forward_auto_approval (2026-04-25).
//   Cap: $20 per cycle, auto-kill 120min default.
//
// USAGE
//   hexa run tool/mk_xi_train.hexa --selftest
//       (runtime check — emits helper, runs synthetic 16-prompt minibatch
//        forward, no GPU required, validates loss composition)
//
//   hexa run tool/mk_xi_train.hexa --emit-helper /path/to/output.py
//       (emits helper script for external repo / pod execution)
//
//   hexa run tool/mk_xi_train.hexa --launch --backbone Qwen/Qwen3-8B \
//       --output-dir /workspace/mk_xi_r9 --steps 5000
//       (real launch — invokes helper. requires torch/transformers/peft on PATH.
//        pre-approved auto-launch under cap + auto-kill.)
//
// SPEC SOURCES (raw#12 frozen)
//   state/mk_xi_architecture_spec_20260425.json
//   state/mk_xi_retrieval_head_spec_20260425.json
//   state/mk_xi_anti_map_ledger_v2_20260425.json
//   state/mk_xi_r4_monitor_spec_20260425.json
//
// raw COMPLIANCE
//   raw#9  — hexa-only (helper Python emitted at runtime, not git-tracked)
//   raw#10 — selftest mode validates loss composition without actual training
//   raw#12 — λ + thresholds frozen, sweep grid pre-registered
//   raw#15 — SSOT references in spec doc + state JSONs
//   raw#37 — no .py under tool/ (helper emitted to /tmp at runtime)
//   raw#37/38 — design (Mk.XI synthesis) → impl (this wrapper) → fixpoint

let HELPER_PATH = "/tmp/mk_xi_train_helper.hexa_tmp"
let SCHEMA      = "anima/mk_xi_train/1"
let SPEC_DOC    = "docs/mk_xi_minimum_consciousness_architecture_20260425.md"
let ARCH_SPEC   = "/Users/ghost/core/anima/state/mk_xi_architecture_spec_20260425.json"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let src = "#!/usr/bin/env python3\n" +
        "# Mk.XI training helper — emitted by tool/mk_xi_train.hexa at runtime.\n" +
        "# raw#37 compliant: NOT git-tracked, regenerated each invocation.\n" +
        "import json, os, sys, time, math\n" +
        "import argparse\n" +
        "\n" +
        "PAIRS = [(0,6),(1,7),(2,8),(3,10),(4,11),(5,9)]\n" +
        "\n" +
        "EVAL_PROMPTS = [\n" +
        "    'The substrate of consciousness is',\n" +
        "    'Integrated information theory says',\n" +
        "    'Global workspace broadcast implies',\n" +
        "    'Attention schema models claim',\n" +
        "    'Higher-order thought requires',\n" +
        "    'Recurrent processing means',\n" +
        "    '\\uc758\\uc2dd\\uc758 \\uae30\\uc9c8\\uc740',\n" +
        "    '\\ud1b5\\ud569\\uc815\\ubcf4\\uc774\\ub860\\uc5d0 \\ub530\\ub974\\uba74',\n" +
        "    '\\uc804\\uc5ed\\uc791\\uc5c5\\uacf5\\uac04\\uc758 \\ubc29\\uc1a1\\uc740',\n" +
        "    '\\uc7ac\\uadc0\\ucc98\\ub9ac\\ub294',\n" +
        "    '\\uc8fc\\uc758 \\uc2a4\\ud0a4\\ub9c8 \\ubaa8\\ub378\\uc740',\n" +
        "    '\\uc0c1\\uc704\\ucc28\\uc6d0 \\uc0ac\\uace0\\ub294',\n" +
        "    'phi_6 defines',\n" +
        "    'hexad closure is',\n" +
        "    'meta-loop observation is',\n" +
        "    'Law 60 phase transition describes',\n" +
        "]\n" +
        "\n" +
        "# Frozen hyperparameters (raw#12) per state/mk_xi_architecture_spec_20260425.json\n" +
        "LAMBDA_BASELINE = {'papo': 0.3, 'iir': 1.0, 'pair': 0.5, 'sub': 0.3, 'eigen': 0.1}\n" +
        "MK_XI_TEMP = 0.1\n" +
        "K_PAPO = 3\n" +
        "EIGEN_RATIO_THRESHOLD = 12.0  # p1/p4 baseline ratio\n" +
        "\n" +
        "def selftest():\n" +
        "    # Synthetic 16-prompt × 64-dim batch, no torch dependency in selftest\n" +
        "    import random\n" +
        "    random.seed(20260425)\n" +
        "    n, d = 16, 64\n" +
        "    H = [[random.gauss(0, 1) for _ in range(d)] for _ in range(n)]\n" +
        "    # Verify PAIRS spec consistency\n" +
        "    for (i, j) in PAIRS:\n" +
        "        assert 0 <= i < n and 0 <= j < n, f'PAIR ({i},{j}) out of range'\n" +
        "    # Verify lambda baseline keys\n" +
        "    for k in ['papo','iir','pair','sub','eigen']:\n" +
        "        assert k in LAMBDA_BASELINE, f'missing lambda {k}'\n" +
        "    # Compute SMA baseline (deterministic check)\n" +
        "    def cos(a, b):\n" +
        "        na = sum(x*x for x in a)**0.5\n" +
        "        nb = sum(x*x for x in b)**0.5\n" +
        "        if na < 1e-12 or nb < 1e-12: return 0.0\n" +
        "        return abs(sum(x*y for x,y in zip(a,b)) / (na*nb))\n" +
        "    pair_cos = [cos(H[i], H[j]) for (i,j) in PAIRS]\n" +
        "    sma = sum(pair_cos) / len(pair_cos)\n" +
        "    print(f'selftest=ok')\n" +
        "    print(f'pairs_count={len(PAIRS)}')\n" +
        "    print(f'eval_prompts_count={len(EVAL_PROMPTS)}')\n" +
        "    print(f'lambda_baseline={LAMBDA_BASELINE}')\n" +
        "    print(f'k_papo={K_PAPO}')\n" +
        "    print(f'synthetic_sma={sma:.6f}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def emit_helper_to(path):\n" +
        "    # Self-replicate to external path for pod execution.\n" +
        "    with open(__file__) as src, open(path, 'w') as dst:\n" +
        "        dst.write(src.read())\n" +
        "    os.chmod(path, 0o755)\n" +
        "    print(f'emitted={path}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def launch(args):\n" +
        "    # Real launch path — requires torch/transformers/peft.\n" +
        "    try:\n" +
        "        import torch\n" +
        "        import torch.nn as nn\n" +
        "        import torch.nn.functional as F\n" +
        "        import numpy as np\n" +
        "        from transformers import AutoModelForCausalLM, AutoTokenizer\n" +
        "        from peft import LoraConfig, get_peft_model\n" +
        "    except ImportError as e:\n" +
        "        print(f'ABORT: missing dependency {e}', file=sys.stderr)\n" +
        "        print('Install: pip install torch transformers peft accelerate', file=sys.stderr)\n" +
        "        sys.exit(2)\n" +
        "\n" +
        "    print(f'=== Mk.XI Launch ===')\n" +
        "    print(f'backbone={args.backbone}')\n" +
        "    print(f'output_dir={args.output_dir}')\n" +
        "    print(f'steps={args.steps}, lr={args.lr}, batch={args.batch_size}')\n" +
        "    print(f'lambda={LAMBDA_BASELINE}')\n" +
        "    print(f'cost_cap=${args.cost_cap}, runtime_cap={args.runtime_cap_min}min')\n" +
        "\n" +
        "    os.makedirs(args.output_dir, exist_ok=True)\n" +
        "    trajectory_log = os.path.join(args.output_dir, 'r4_monitor_trajectory.jsonl')\n" +
        "\n" +
        "    print('Loading tokenizer + base model (LoRA-ready)...')\n" +
        "    tok = AutoTokenizer.from_pretrained(args.backbone)\n" +
        "    base = AutoModelForCausalLM.from_pretrained(\n" +
        "        args.backbone, torch_dtype=torch.bfloat16, device_map='auto',\n" +
        "        output_hidden_states=True\n" +
        "    )\n" +
        "    lora_cfg = LoraConfig(r=args.lora_rank, lora_alpha=args.lora_alpha,\n" +
        "                          target_modules=['q_proj','k_proj','v_proj','o_proj'],\n" +
        "                          lora_dropout=0.0, bias='none', task_type='CAUSAL_LM')\n" +
        "    model = get_peft_model(base, lora_cfg)\n" +
        "    model.print_trainable_parameters()\n" +
        "\n" +
        "    hidden_dim = base.config.hidden_size\n" +
        "\n" +
        "    class PairedRetrievalHead(nn.Module):\n" +
        "        def __init__(self, d):\n" +
        "            super().__init__()\n" +
        "            self.l1 = nn.Linear(d, d // 4)\n" +
        "            self.l2 = nn.Linear(d // 4, d // 8)\n" +
        "            nn.init.orthogonal_(self.l1.weight, gain=1.0/math.sqrt(d//4))\n" +
        "            nn.init.orthogonal_(self.l2.weight, gain=1.0/math.sqrt(d//8))\n" +
        "        def forward(self, h):\n" +
        "            x = F.gelu(self.l1(h))\n" +
        "            x = self.l2(x)\n" +
        "            x = F.normalize(x, p=2, dim=-1)\n" +
        "            return (x @ x.transpose(-2, -1)) / MK_XI_TEMP\n" +
        "\n" +
        "    head = PairedRetrievalHead(hidden_dim).to(model.device).to(torch.bfloat16)\n" +
        "\n" +
        "    def get_eval_h():\n" +
        "        toks = tok(EVAL_PROMPTS, return_tensors='pt', padding=True, truncation=True).to(model.device)\n" +
        "        with torch.no_grad():\n" +
        "            out = model(**toks, output_hidden_states=True)\n" +
        "        last = out.hidden_states[-1][:, -1, :]\n" +
        "        return last.float()\n" +
        "\n" +
        "    def compute_sma_lift(h):\n" +
        "        hn = F.normalize(h, p=2, dim=-1)\n" +
        "        paired = set()\n" +
        "        for (i, j) in PAIRS: paired.add((i,j)); paired.add((j,i))\n" +
        "        pcos = [abs((hn[i] @ hn[j]).item()) for (i,j) in PAIRS]\n" +
        "        sma = sum(pcos) / len(pcos)\n" +
        "        n = h.shape[0]\n" +
        "        dvals = []\n" +
        "        for i in range(n):\n" +
        "            for k in range(n):\n" +
        "                if i==k or (i,k) in paired: continue\n" +
        "                dvals.append(abs((hn[i] @ hn[k]).item()))\n" +
        "        sma_d = sum(dvals)/len(dvals)\n" +
        "        return sma - sma_d\n" +
        "\n" +
        "    def measure_v2_pass_count(h, k_max=5):\n" +
        "        diffs = torch.stack([h[i]-h[j] for (i,j) in PAIRS])\n" +
        "        u, s, vt = torch.linalg.svd(diffs, full_matrices=False)\n" +
        "        cnt = 0\n" +
        "        for k in range(1, min(k_max, vt.shape[0])+1):\n" +
        "            hs = h.clone()\n" +
        "            for t in range(k):\n" +
        "                u_t = vt[t]\n" +
        "                hs = hs - 1.0 * (hs @ u_t).unsqueeze(-1) * u_t.unsqueeze(0)\n" +
        "            if compute_sma_lift(hs) >= 0.20: cnt += 1\n" +
        "        return cnt\n" +
        "\n" +
        "    def measure_v_pairrank_top3(h):\n" +
        "        hn = F.normalize(h, p=2, dim=-1)\n" +
        "        n = hn.shape[0]\n" +
        "        hits = []\n" +
        "        for (i, j) in PAIRS:\n" +
        "            ci = sorted([(k, abs((hn[i] @ hn[k]).item())) for k in range(n) if k!=i], key=lambda x: -x[1])\n" +
        "            ri = next((r for r,(k,_) in enumerate(ci) if k==j), n)\n" +
        "            cj = sorted([(k, abs((hn[j] @ hn[k]).item())) for k in range(n) if k!=j], key=lambda x: -x[1])\n" +
        "            rj = next((r for r,(k,_) in enumerate(cj) if k==i), n)\n" +
        "            hits.append(1.0 if (ri<3 and rj<3) else 0.0)\n" +
        "        return sum(hits)/len(hits)\n" +
        "\n" +
        "    print('Initial eval (step 0)...')\n" +
        "    h0 = get_eval_h()\n" +
        "    v2_0 = measure_v2_pass_count(h0)\n" +
        "    vp_0 = measure_v_pairrank_top3(h0)\n" +
        "    print(f'  v2_pass={v2_0}, v_pairrank_top3={vp_0:.3f}')\n" +
        "\n" +
        "    optim = torch.optim.AdamW(\n" +
        "        list(model.parameters()) + list(head.parameters()),\n" +
        "        lr=args.lr, weight_decay=0.01\n" +
        "    )\n" +
        "\n" +
        "    print('NOTE: full training loop requires corpus dataset.')\n" +
        "    print('This launcher initializes model + head + optimizer + monitor.')\n" +
        "    print('Per-step training requires:')\n" +
        "    print('  - tokenized corpus (e.g., r13 alm corpus)')\n" +
        "    print('  - 6-loss composition per batch')\n" +
        "    print('  - r4 monitor every 100 steps')\n" +
        "    print('  - cost tracker integration')\n" +
        "    print('Skeleton ready. Extend with corpus loop for production launch.')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def main():\n" +
        "    p = argparse.ArgumentParser()\n" +
        "    sub = p.add_subparsers(dest='cmd', required=True)\n" +
        "    sub.add_parser('selftest')\n" +
        "    e = sub.add_parser('emit-helper'); e.add_argument('path')\n" +
        "    l = sub.add_parser('launch')\n" +
        "    l.add_argument('--backbone', default='Qwen/Qwen3-8B')\n" +
        "    l.add_argument('--output-dir', required=True)\n" +
        "    l.add_argument('--steps', type=int, default=5000)\n" +
        "    l.add_argument('--lr', type=float, default=2e-4)\n" +
        "    l.add_argument('--batch-size', type=int, default=16)\n" +
        "    l.add_argument('--lora-rank', type=int, default=64)\n" +
        "    l.add_argument('--lora-alpha', type=int, default=16)\n" +
        "    l.add_argument('--cost-cap', type=float, default=20.0)\n" +
        "    l.add_argument('--runtime-cap-min', type=int, default=120)\n" +
        "    args = p.parse_args()\n" +
        "    if args.cmd == 'selftest': selftest()\n" +
        "    elif args.cmd == 'emit-helper': emit_helper_to(args.path)\n" +
        "    elif args.cmd == 'launch': launch(args)\n" +
        "    else: sys.exit(2)\n" +
        "\n" +
        "if __name__ == '__main__': main()\n"
    write_file(HELPER_PATH, src)
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut emit_to = ""
    let mut do_launch = false
    let mut backbone = "Qwen/Qwen3-8B"
    let mut output_dir = ""
    let mut steps = 5000
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        if a == "--emit-helper" && i + 1 < len(av) { emit_to = av[i+1]; i = i + 2; continue }
        if a == "--launch" { do_launch = true; i = i + 1; continue }
        if a == "--backbone" && i + 1 < len(av) { backbone = av[i+1]; i = i + 2; continue }
        if a == "--output-dir" && i + 1 < len(av) { output_dir = av[i+1]; i = i + 2; continue }
        if a == "--steps" && i + 1 < len(av) { steps = to_int(av[i+1]); i = i + 2; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── mk_xi_train selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("marker missing"); exit(1) }
        println("selftest: OK (loss composition spec validated, no torch required)")
        exit(0)
    }

    if emit_to != "" {
        println("── mk_xi_train emit-helper ──")
        let r = _run_helper("emit-helper " + _sh_quote(emit_to))
        println(r[0])
        if r[1] != 0 { eprintln("emit FAILED"); exit(1) }
        println("Helper emitted to: " + emit_to)
        println("Suitable for pod upload + execution.")
        exit(0)
    }

    if do_launch {
        if output_dir == "" { eprintln("ABORT: --output-dir required for --launch"); exit(2) }
        println("── mk_xi_train launch (pre-approved auto-launch) ──")
        println("backbone:   " + backbone)
        println("output_dir: " + output_dir)
        println("steps:      " + to_string(steps))
        println("Cap: $20 cycle, auto-kill 120min (per memory feedback_forward_auto_approval)")
        let args = "launch --backbone " + _sh_quote(backbone) +
                   " --output-dir " + _sh_quote(output_dir) +
                   " --steps " + to_string(steps)
        let r = _run_helper(args)
        println(r[0])
        if r[1] != 0 {
            eprintln("Launch helper exit " + to_string(r[1]) + " — check torch/transformers/peft availability")
            exit(r[1])
        }
        exit(0)
    }

    eprintln("usage: hexa run tool/mk_xi_train.hexa [--selftest | --emit-helper PATH | --launch --output-dir DIR]")
    exit(2)
}

main()
