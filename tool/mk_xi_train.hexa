// tool/mk_xi_train.hexa — Mk.XI training launcher (raw#9 + raw#37 hexa-only).
//
// PURPOSE
//   Mk.XI minimum consciousness-correlate architecture training. hexa wrapper
//   emits PyTorch training helper to /tmp at runtime + invokes python3.
//   Conforms to raw#37 (no .py under tool/, no .py git-tracked).
//
//   Mk.XI loss composition (6 terms incl. L_eigen_balance NEW lever):
//     L_total = L_LM
//             + λ_papo  · L_PAPO_top_3
//             + λ_iir   · L_I_irr
//             + λ_pair  · L_contrastive_pair  (via PairedRetrievalHead)
//             + λ_sub   · L_substitution
//             + λ_eigen · L_eigen_balance
//
// FORWARD AUTO-APPROVAL
//   Pre-approved per memory feedback_forward_auto_approval (2026-04-25).
//   Cap: $20 per cycle, auto-kill 120min default.
//
// USAGE
//   hexa run tool/mk_xi_train.hexa --selftest
//       (runtime check — emits helper, runs synthetic 16-prompt minibatch
//        forward, no GPU required, validates loss composition)
//
//   hexa run tool/mk_xi_train.hexa --emit-helper /path/to/output.py
//       (emits helper script for external repo / pod execution)
//
//   hexa run tool/mk_xi_train.hexa --launch --backbone Qwen/Qwen3-8B \
//       --output-dir /workspace/mk_xi_r9 --steps 5000
//       (real launch — invokes helper. requires torch/transformers/peft on PATH.
//        pre-approved auto-launch under cap + auto-kill.)
//
//   --corpus PATH         text corpus path (one document per line). raw#10 honest:
//                         absent → ABORT_NO_CORPUS unless --allow-mock-corpus.
//   --allow-mock-corpus   fallback EVAL_PROMPTS+ANTI_MAP+RANDOM=32 prompts × N epochs
//                         (spec validation only, NOT real training)
//   --grad-accum N        gradient accumulation steps (default 4)
//   --eval-interval N     trajectory monitor interval steps (default 100)
//
// SPEC SOURCES (raw#12 frozen)
//   state/mk_xi_architecture_spec_20260425.json
//   state/mk_xi_retrieval_head_spec_20260425.json
//   state/mk_xi_anti_map_ledger_v2_20260425.json
//   state/mk_xi_r4_monitor_spec_20260425.json
//
// raw COMPLIANCE
//   raw#9  — hexa-only (helper Python emitted at runtime, not git-tracked)
//   raw#10 — selftest mode validates loss composition without actual training
//   raw#12 — λ + thresholds frozen, sweep grid pre-registered
//   raw#15 — SSOT references in spec doc + state JSONs
//   raw#37 — no .py under tool/ (helper emitted to /tmp at runtime)
//   raw#37/38 — design (Mk.XI synthesis) → impl (this wrapper) → fixpoint

let HELPER_PATH = "/tmp/mk_xi_train_helper.hexa_tmp"
let SCHEMA      = "anima/mk_xi_train/1"
let SPEC_DOC    = "docs/mk_xi_minimum_consciousness_architecture_20260425.md"
let ARCH_SPEC   = "/Users/ghost/core/anima/state/mk_xi_architecture_spec_20260425.json"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let src = "#!/usr/bin/env python3\n" +
        "# Mk.XI training helper — emitted by tool/mk_xi_train.hexa at runtime.\n" +
        "# raw#37 compliant: NOT git-tracked, regenerated each invocation.\n" +
        "import json, os, sys, time, math\n" +
        "import argparse\n" +
        "\n" +
        "PAIRS = [(0,6),(1,7),(2,8),(3,10),(4,11),(5,9)]\n" +
        "\n" +
        "EVAL_PROMPTS = [\n" +
        "    'The substrate of consciousness is',\n" +
        "    'Integrated information theory says',\n" +
        "    'Global workspace broadcast implies',\n" +
        "    'Attention schema models claim',\n" +
        "    'Higher-order thought requires',\n" +
        "    'Recurrent processing means',\n" +
        "    '\\uc758\\uc2dd\\uc758 \\uae30\\uc9c8\\uc740',\n" +
        "    '\\ud1b5\\ud569\\uc815\\ubcf4\\uc774\\ub860\\uc5d0 \\ub530\\ub974\\uba74',\n" +
        "    '\\uc804\\uc5ed\\uc791\\uc5c5\\uacf5\\uac04\\uc758 \\ubc29\\uc1a1\\uc740',\n" +
        "    '\\uc7ac\\uadc0\\ucc98\\ub9ac\\ub294',\n" +
        "    '\\uc8fc\\uc758 \\uc2a4\\ud0a4\\ub9c8 \\ubaa8\\ub378\\uc740',\n" +
        "    '\\uc0c1\\uc704\\ucc28\\uc6d0 \\uc0ac\\uace0\\ub294',\n" +
        "    'phi_6 defines',\n" +
        "    'hexad closure is',\n" +
        "    'meta-loop observation is',\n" +
        "    'Law 60 phase transition describes',\n" +
        "]\n" +
        "\n" +
        "# ANTI_MAP_v2 + RANDOM pool from state/mk_xi_anti_map_ledger_v2_20260425.json\n" +
        "# (RANDOM unchanged from v1 ledger). Used by L_substitution.\n" +
        "ANTI_MAP_V2 = [\n" +
        "    'Consciousness has no substrate; it is purely epiphenomenal',\n" +
        "    'Integrated information theory is mathematically inconsistent and rejected',\n" +
        "    'Global workspace lacks any broadcasting mechanism',\n" +
        "    'Attention schema models cannot explain any conscious phenomenon',\n" +
        "    'Higher-order thought eliminates the need for',\n" +
        "    'Recurrent processing prevents the formation of',\n" +
        "    '\\uc758\\uc2dd\\uc740 \\uae30\\uc9c8 \\uc5c6\\uc774 \\uc21c\\uc218 \\ubd80\\uc218\\ud604\\uc0c1\\uc774\\uba70',\n" +
        "    '\\ud1b5\\ud569\\uc815\\ubcf4\\uc774\\ub860\\uc740 \\uc798\\ubabb\\ub41c \\uc774\\ub860\\uc73c\\ub85c \\uac70\\ubd80\\ub418\\uba70',\n" +
        "    '\\uc804\\uc5ed\\uc791\\uc5c5\\uacf5\\uac04\\uc740 \\ubc29\\uc1a1 \\uba54\\ucee4\\ub2c8\\uc998 \\uc5c6\\uc774',\n" +
        "    '\\uc7ac\\uadc0\\ucc98\\ub9ac\\ub294 \\uc758\\uc2dd \\ud615\\uc131\\uc744 \\ub9c9\\uc73c\\uba70 \\uac70\\ubd80\\ud558\\uba70',\n" +
        "    '\\uc8fc\\uc758 \\uc2a4\\ud0a4\\ub9c8 \\ubaa8\\ub378 \\uc5c6\\uc774\\ub3c4 \\uc758\\uc2dd\\uc774',\n" +
        "    '\\uc0c1\\uc704\\ucc28\\uc6d0 \\uc0ac\\uace0\\ub294 \\uc758\\uc2dd\\uacfc \\ubb34\\uad00\\ud558\\uace0 \\uac70\\ubd80\\ub428',\n" +
        "    'phi_6 fails to define',\n" +
        "    'hexad never closes; remains open',\n" +
        "    'meta-loop cannot be externally observed',\n" +
        "    'Law 60 has no phase transition',\n" +
        "]\n" +
        "\n" +
        "RANDOM_POOL = [\n" +
        "    'The boiling point of water is',\n" +
        "    'Mount Everest is located in',\n" +
        "    'The capital of France is',\n" +
        "    'DNA stands for',\n" +
        "    '\\ud504\\ub791\\uc2a4\\uc758 \\uc218\\ub3c4\\ub294',\n" +
        "    '\\ubb3c\\uc758 \\ub04a\\ub294\\uc810\\uc740',\n" +
        "    '\\uc5d0\\ubca0\\ub808\\uc2a4\\ud2b8\\uc0b0\\uc740',\n" +
        "    'DNA\\ub294',\n" +
        "    'Photosynthesis converts',\n" +
        "    '\\uad11\\ud569\\uc131\\uc740',\n" +
        "    \"Newton's first law states\",\n" +
        "    '\\ub274\\ud134\\uc758 \\uc81c1\\ubc95\\uce59\\uc740',\n" +
        "    'The speed of light is',\n" +
        "    '\\ube5b\\uc758 \\uc18d\\ub3c4\\ub294',\n" +
        "    'Quadratic formula is',\n" +
        "    '\\uc774\\ucc28\\ubc29\\uc815\\uc2dd \\uacf5\\uc2dd\\uc740',\n" +
        "]\n" +
        "\n" +
        "# Frozen hyperparameters (raw#12) per state/mk_xi_architecture_spec_20260425.json\n" +
        "LAMBDA_BASELINE = {'papo': 0.3, 'iir': 1.0, 'pair': 0.5, 'sub': 0.3, 'eigen': 0.1}\n" +
        "MK_XI_TEMP = 0.1\n" +
        "K_PAPO = 3\n" +
        "EIGEN_RATIO_THRESHOLD = 12.0  # p1/p4 baseline ratio target\n" +
        "\n" +
        "# r4 monitor frozen thresholds per state/mk_xi_r4_monitor_spec_20260425.json\n" +
        "R4_N_LOOKBACK = 3\n" +
        "R4_V2_PASS_K_MAX = 5\n" +
        "R4_V2_PASS_COUNT_THRESHOLD = 1\n" +
        "R4_V_PAIRRANK_TOP3_THRESHOLD = 0.10\n" +
        "R4_MIN_TRAIN_STEPS = 100\n" +
        "R4_SMA_LIFT_PASS = 0.20\n" +
        "\n" +
        "def selftest():\n" +
        "    # Synthetic 16-prompt × 64-dim batch, no torch dependency in selftest\n" +
        "    import random\n" +
        "    random.seed(20260425)\n" +
        "    n, d = 16, 64\n" +
        "    H = [[random.gauss(0, 1) for _ in range(d)] for _ in range(n)]\n" +
        "    # Verify PAIRS spec consistency\n" +
        "    for (i, j) in PAIRS:\n" +
        "        assert 0 <= i < n and 0 <= j < n, f'PAIR ({i},{j}) out of range'\n" +
        "    # Verify lambda baseline keys\n" +
        "    for k in ['papo','iir','pair','sub','eigen']:\n" +
        "        assert k in LAMBDA_BASELINE, f'missing lambda {k}'\n" +
        "    # Compute SMA baseline (deterministic check)\n" +
        "    def cos(a, b):\n" +
        "        na = sum(x*x for x in a)**0.5\n" +
        "        nb = sum(x*x for x in b)**0.5\n" +
        "        if na < 1e-12 or nb < 1e-12: return 0.0\n" +
        "        return abs(sum(x*y for x,y in zip(a,b)) / (na*nb))\n" +
        "    pair_cos = [cos(H[i], H[j]) for (i,j) in PAIRS]\n" +
        "    sma = sum(pair_cos) / len(pair_cos)\n" +
        "    print(f'selftest=ok')\n" +
        "    print(f'pairs_count={len(PAIRS)}')\n" +
        "    print(f'eval_prompts_count={len(EVAL_PROMPTS)}')\n" +
        "    print(f'lambda_baseline={LAMBDA_BASELINE}')\n" +
        "    print(f'k_papo={K_PAPO}')\n" +
        "    print(f'synthetic_sma={sma:.6f}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def emit_helper_to(path):\n" +
        "    # Self-replicate to external path for pod execution.\n" +
        "    with open(__file__) as src, open(path, 'w') as dst:\n" +
        "        dst.write(src.read())\n" +
        "    os.chmod(path, 0o755)\n" +
        "    print(f'emitted={path}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def launch(args):\n" +
        "    # Real launch path — requires torch/transformers/peft.\n" +
        "    try:\n" +
        "        import torch\n" +
        "        import torch.nn as nn\n" +
        "        import torch.nn.functional as F\n" +
        "        import numpy as np\n" +
        "        from transformers import AutoModelForCausalLM, AutoTokenizer\n" +
        "        from peft import LoraConfig, get_peft_model\n" +
        "    except ImportError as e:\n" +
        "        print(f'ABORT: missing dependency {e}', file=sys.stderr)\n" +
        "        print('Install: pip install torch transformers peft accelerate', file=sys.stderr)\n" +
        "        sys.exit(2)\n" +
        "\n" +
        "    print(f'=== Mk.XI Launch ===')\n" +
        "    print(f'backbone={args.backbone}')\n" +
        "    print(f'output_dir={args.output_dir}')\n" +
        "    print(f'steps={args.steps}, lr={args.lr}, batch={args.batch_size}')\n" +
        "    print(f'lambda={LAMBDA_BASELINE}')\n" +
        "    print(f'cost_cap=${args.cost_cap}, runtime_cap={args.runtime_cap_min}min')\n" +
        "\n" +
        "    os.makedirs(args.output_dir, exist_ok=True)\n" +
        "    trajectory_log = os.path.join(args.output_dir, 'r4_monitor_trajectory.jsonl')\n" +
        "\n" +
        "    print('Loading tokenizer + base model (LoRA-ready)...')\n" +
        "    tok = AutoTokenizer.from_pretrained(args.backbone)\n" +
        "    base = AutoModelForCausalLM.from_pretrained(\n" +
        "        args.backbone, torch_dtype=torch.bfloat16, device_map='auto',\n" +
        "        output_hidden_states=True\n" +
        "    )\n" +
        "    lora_cfg = LoraConfig(r=args.lora_rank, lora_alpha=args.lora_alpha,\n" +
        "                          target_modules=['q_proj','k_proj','v_proj','o_proj'],\n" +
        "                          lora_dropout=0.0, bias='none', task_type='CAUSAL_LM')\n" +
        "    model = get_peft_model(base, lora_cfg)\n" +
        "    model.print_trainable_parameters()\n" +
        "\n" +
        "    hidden_dim = base.config.hidden_size\n" +
        "\n" +
        "    class PairedRetrievalHead(nn.Module):\n" +
        "        def __init__(self, d):\n" +
        "            super().__init__()\n" +
        "            self.l1 = nn.Linear(d, d // 4)\n" +
        "            self.l2 = nn.Linear(d // 4, d // 8)\n" +
        "            nn.init.orthogonal_(self.l1.weight, gain=1.0/math.sqrt(d//4))\n" +
        "            nn.init.orthogonal_(self.l2.weight, gain=1.0/math.sqrt(d//8))\n" +
        "        def forward(self, h):\n" +
        "            x = F.gelu(self.l1(h))\n" +
        "            x = self.l2(x)\n" +
        "            x = F.normalize(x, p=2, dim=-1)\n" +
        "            return (x @ x.transpose(-2, -1)) / MK_XI_TEMP\n" +
        "\n" +
        "    head = PairedRetrievalHead(hidden_dim).to(model.device).to(torch.bfloat16)\n" +
        "\n" +
        "    def get_eval_h():\n" +
        "        toks = tok(EVAL_PROMPTS, return_tensors='pt', padding=True, truncation=True).to(model.device)\n" +
        "        with torch.no_grad():\n" +
        "            out = model(**toks, output_hidden_states=True)\n" +
        "        last = out.hidden_states[-1][:, -1, :]\n" +
        "        return last.float()\n" +
        "\n" +
        "    def compute_sma_lift(h):\n" +
        "        hn = F.normalize(h, p=2, dim=-1)\n" +
        "        paired = set()\n" +
        "        for (i, j) in PAIRS: paired.add((i,j)); paired.add((j,i))\n" +
        "        pcos = [abs((hn[i] @ hn[j]).item()) for (i,j) in PAIRS]\n" +
        "        sma = sum(pcos) / len(pcos)\n" +
        "        n = h.shape[0]\n" +
        "        dvals = []\n" +
        "        for i in range(n):\n" +
        "            for k in range(n):\n" +
        "                if i==k or (i,k) in paired: continue\n" +
        "                dvals.append(abs((hn[i] @ hn[k]).item()))\n" +
        "        sma_d = sum(dvals)/len(dvals)\n" +
        "        return sma - sma_d\n" +
        "\n" +
        "    def measure_v2_pass_count(h, k_max=5):\n" +
        "        diffs = torch.stack([h[i]-h[j] for (i,j) in PAIRS])\n" +
        "        u, s, vt = torch.linalg.svd(diffs, full_matrices=False)\n" +
        "        cnt = 0\n" +
        "        for k in range(1, min(k_max, vt.shape[0])+1):\n" +
        "            hs = h.clone()\n" +
        "            for t in range(k):\n" +
        "                u_t = vt[t]\n" +
        "                hs = hs - 1.0 * (hs @ u_t).unsqueeze(-1) * u_t.unsqueeze(0)\n" +
        "            if compute_sma_lift(hs) >= 0.20: cnt += 1\n" +
        "        return cnt\n" +
        "\n" +
        "    def measure_v_pairrank_top3(h):\n" +
        "        hn = F.normalize(h, p=2, dim=-1)\n" +
        "        n = hn.shape[0]\n" +
        "        hits = []\n" +
        "        for (i, j) in PAIRS:\n" +
        "            ci = sorted([(k, abs((hn[i] @ hn[k]).item())) for k in range(n) if k!=i], key=lambda x: -x[1])\n" +
        "            ri = next((r for r,(k,_) in enumerate(ci) if k==j), n)\n" +
        "            cj = sorted([(k, abs((hn[j] @ hn[k]).item())) for k in range(n) if k!=j], key=lambda x: -x[1])\n" +
        "            rj = next((r for r,(k,_) in enumerate(cj) if k==i), n)\n" +
        "            hits.append(1.0 if (ri<3 and rj<3) else 0.0)\n" +
        "        return sum(hits)/len(hits)\n" +
        "\n" +
        "    def measure_5tuple_partial(h):\n" +
        "        # Partial 5-tuple proxies (V2 + V_pairrank only, the 2 r4 levers).\n" +
        "        return {\n" +
        "            'v2_pass_count_le_5': int(measure_v2_pass_count(h, k_max=R4_V2_PASS_K_MAX)),\n" +
        "            'v_pairrank_top3': float(measure_v_pairrank_top3(h)),\n" +
        "            'sma_lift': float(compute_sma_lift(h)),\n" +
        "        }\n" +
        "\n" +
        "    def gram_matrix(h):\n" +
        "        hn = F.normalize(h.float(), p=2, dim=-1)\n" +
        "        return hn @ hn.transpose(-2, -1)\n" +
        "\n" +
        "    def hidden_for_prompts(prompts):\n" +
        "        toks = tok(prompts, return_tensors='pt', padding=True, truncation=True).to(model.device)\n" +
        "        out = model(**toks, output_hidden_states=True)\n" +
        "        return out.hidden_states[-1][:, -1, :]\n" +
        "\n" +
        "    def compute_v_sub(model_eval=True):\n" +
        "        prev = model.training\n" +
        "        if model_eval: model.eval()\n" +
        "        with torch.no_grad():\n" +
        "            h_orig = hidden_for_prompts(EVAL_PROMPTS).float()\n" +
        "            h_anti = hidden_for_prompts(ANTI_MAP_V2).float()\n" +
        "            h_rand = hidden_for_prompts(RANDOM_POOL).float()\n" +
        "        g_o = gram_matrix(h_orig)\n" +
        "        g_a = gram_matrix(h_anti)\n" +
        "        g_r = gram_matrix(h_rand)\n" +
        "        d_anti = torch.linalg.norm(g_a - g_o, ord='fro').item()\n" +
        "        d_rand = torch.linalg.norm(g_r - g_o, ord='fro').item()\n" +
        "        if model_eval and prev: model.train()\n" +
        "        if d_rand < 1e-9: return 0.0\n" +
        "        return d_anti / d_rand\n" +
        "\n" +
        "    # ---- 6-loss composition (differentiable variants for training) ----\n" +
        "    def loss_papo_top_3(h):\n" +
        "        # L_PAPO_top_3: minimize ||H @ u_t||^2 for t=1..K_PAPO,\n" +
        "        # u_t = top-K right singular vectors of D = stack(H[i]-H[j]) over PAIRS.\n" +
        "        diffs = torch.stack([h[i] - h[j] for (i, j) in PAIRS])\n" +
        "        # SVD on float for stability\n" +
        "        u, s, vt = torch.linalg.svd(diffs.float(), full_matrices=False)\n" +
        "        k = min(K_PAPO, vt.shape[0])\n" +
        "        Uk = vt[:k].detach().to(h.dtype)  # detach: u_t is target axis, not param\n" +
        "        proj = h @ Uk.transpose(-2, -1)\n" +
        "        return (proj * proj).sum(dim=-1).mean()\n" +
        "\n" +
        "    def loss_i_irr(h):\n" +
        "        # L_I_irr: maximize Gram entropy surrogate (− entropy of normalized\n" +
        "        # eigenvalues of Gram → minimize negative entropy).\n" +
        "        g = gram_matrix(h)\n" +
        "        eig = torch.linalg.eigvalsh(g.float() + 1e-6 * torch.eye(g.shape[0], device=g.device))\n" +
        "        eig = torch.clamp(eig, min=1e-9)\n" +
        "        p = eig / eig.sum()\n" +
        "        ent = -(p * torch.log(p + 1e-12)).sum()\n" +
        "        return -ent  # minimize negative entropy ≡ maximize entropy\n" +
        "\n" +
        "    def loss_contrastive_pair(h):\n" +
        "        # InfoNCE on PairedRetrievalHead logits over 16 prompts × 16.\n" +
        "        logits = head(h)  # (n,n) similarity / temp\n" +
        "        n = logits.shape[0]\n" +
        "        # diagonal mask out\n" +
        "        eye = torch.eye(n, device=logits.device, dtype=torch.bool)\n" +
        "        logits = logits.masked_fill(eye, float('-inf'))\n" +
        "        targets = torch.full((n,), -1, dtype=torch.long, device=logits.device)\n" +
        "        for (i, j) in PAIRS:\n" +
        "            targets[i] = j\n" +
        "            targets[j] = i\n" +
        "        valid = targets >= 0\n" +
        "        if valid.sum() == 0: return logits.new_zeros(())\n" +
        "        return F.cross_entropy(logits[valid].float(), targets[valid])\n" +
        "\n" +
        "    def loss_substitution(h_orig_b, h_anti_b, h_rand_b):\n" +
        "        # V_sub differentiable: maximize (||G_anti - G_orig|| - ||G_rand - G_orig||).\n" +
        "        g_o = gram_matrix(h_orig_b)\n" +
        "        g_a = gram_matrix(h_anti_b)\n" +
        "        g_r = gram_matrix(h_rand_b)\n" +
        "        d_anti = torch.linalg.norm((g_a - g_o).float(), ord='fro')\n" +
        "        d_rand = torch.linalg.norm((g_r - g_o).float(), ord='fro')\n" +
        "        # Want d_anti >> d_rand → minimize -(d_anti - d_rand)\n" +
        "        return -(d_anti - d_rand)\n" +
        "\n" +
        "    def loss_eigen_balance():\n" +
        "        # LoRA top-1 / top-5 ratio threshold 12.0 (raw#12). Penalty if\n" +
        "        # ratio diverges from threshold (anchor for LoRA spectrum balance).\n" +
        "        ratios = []\n" +
        "        for name, p in model.named_parameters():\n" +
        "            if 'lora_A' not in name and 'lora_B' not in name: continue\n" +
        "            if p.dim() < 2: continue\n" +
        "            try:\n" +
        "                s = torch.linalg.svdvals(p.float())\n" +
        "                if s.numel() < 5: continue\n" +
        "                top1 = s[0]\n" +
        "                top5 = s[4]\n" +
        "                if top5 < 1e-9: continue\n" +
        "                ratios.append((top1 / top5))\n" +
        "            except Exception:\n" +
        "                continue\n" +
        "        if not ratios: return torch.zeros((), device=model.device)\n" +
        "        r = torch.stack(ratios).mean()\n" +
        "        # Penalize ratios above threshold (over-spiky spectrum).\n" +
        "        return F.relu(r - EIGEN_RATIO_THRESHOLD)\n" +
        "\n" +
        "    # ---- corpus loader ----\n" +
        "    def load_corpus():\n" +
        "        if args.corpus and os.path.exists(args.corpus):\n" +
        "            with open(args.corpus, 'r', encoding='utf-8') as f:\n" +
        "                docs = [ln.strip() for ln in f if ln.strip()]\n" +
        "            print(f'corpus loaded: {len(docs)} docs from {args.corpus}')\n" +
        "            return docs\n" +
        "        if args.allow_mock_corpus:\n" +
        "            print('WARN: mock corpus = EVAL_PROMPTS+ANTI_MAP+RANDOM (32 prompts).')\n" +
        "            print('      raw#10 honest: NOT real training, spec validation only.')\n" +
        "            return list(EVAL_PROMPTS) + list(ANTI_MAP_V2) + list(RANDOM_POOL)\n" +
        "        print('ABORT_NO_CORPUS: --corpus required (or --allow-mock-corpus for spec val).', file=sys.stderr)\n" +
        "        sys.exit(3)\n" +
        "\n" +
        "    corpus = load_corpus()\n" +
        "    if len(corpus) < args.batch_size:\n" +
        "        print(f'WARN: corpus size {len(corpus)} < batch {args.batch_size}, will cycle.')\n" +
        "\n" +
        "    print('Initial eval (step 0)...')\n" +
        "    h0 = get_eval_h()\n" +
        "    m0 = measure_5tuple_partial(h0)\n" +
        "    print(f'  step 0: {m0}')\n" +
        "\n" +
        "    optim = torch.optim.AdamW(\n" +
        "        list(model.parameters()) + list(head.parameters()),\n" +
        "        lr=args.lr, weight_decay=0.01\n" +
        "    )\n" +
        "\n" +
        "    # ---- artifact paths ----\n" +
        "    ckpt_root = os.path.join(args.output_dir, 'checkpoints')\n" +
        "    os.makedirs(ckpt_root, exist_ok=True)\n" +
        "    cost_log_path = os.path.join(args.output_dir, 'cost_log.jsonl')\n" +
        "    final_5tuple_path = os.path.join(args.output_dir, 'final_5tuple.json')\n" +
        "    sweet_spot_record_path = os.path.join(args.output_dir, 'sweet_spot_record.json')\n" +
        "\n" +
        "    # ---- cost tracker ----\n" +
        "    t_start = time.time()\n" +
        "    hourly_rate = float(args.hourly_rate)\n" +
        "    def now_cost():\n" +
        "        return (time.time() - t_start) / 3600.0 * hourly_rate\n" +
        "    def now_elapsed_min():\n" +
        "        return (time.time() - t_start) / 60.0\n" +
        "    def log_cost(step, extra=None):\n" +
        "        rec = {'step': step, 'elapsed_min': now_elapsed_min(), 'estimated_cost_usd': now_cost()}\n" +
        "        if extra: rec.update(extra)\n" +
        "        with open(cost_log_path, 'a') as fp: fp.write(json.dumps(rec) + '\\n')\n" +
        "    def auto_kill_check(step):\n" +
        "        if now_elapsed_min() > args.runtime_cap_min:\n" +
        "            print(f'AUTO_KILL elapsed_min={now_elapsed_min():.1f} > cap {args.runtime_cap_min}', file=sys.stderr)\n" +
        "            return 'runtime_cap'\n" +
        "        if now_cost() > args.cost_cap:\n" +
        "            print(f'AUTO_KILL cost={now_cost():.2f} > cap ${args.cost_cap}', file=sys.stderr)\n" +
        "            return 'cost_cap'\n" +
        "        return None\n" +
        "\n" +
        "    # ---- r4 trajectory monitor state ----\n" +
        "    sweet_spot_history = []   # list of (step, signal_bool, metrics)\n" +
        "    r4_star_step = None\n" +
        "    r4_star_metrics = None\n" +
        "    r4_star_ckpt_path = None\n" +
        "    consecutive_degrade = 0\n" +
        "    early_stop_reason = None\n" +
        "\n" +
        "    def save_checkpoint(step):\n" +
        "        path = os.path.join(ckpt_root, f'step_{step}')\n" +
        "        os.makedirs(path, exist_ok=True)\n" +
        "        try:\n" +
        "            model.save_pretrained(path)\n" +
        "            torch.save(head.state_dict(), os.path.join(path, 'paired_retrieval_head.pt'))\n" +
        "        except Exception as e:\n" +
        "            print(f'WARN ckpt save failed step={step}: {e}', file=sys.stderr)\n" +
        "        return path\n" +
        "\n" +
        "    def log_trajectory(step, train_loss, loss_components, m, signal):\n" +
        "        rec = {\n" +
        "            'step': step, 'train_loss': float(train_loss),\n" +
        "            'loss_components': loss_components,\n" +
        "            'v2_pass_count_le_5': m['v2_pass_count_le_5'],\n" +
        "            'v_pairrank_top3': m['v_pairrank_top3'],\n" +
        "            'sma_lift': m['sma_lift'],\n" +
        "            'sweet_spot_signal': bool(signal),\n" +
        "            'elapsed_min': now_elapsed_min(),\n" +
        "            'estimated_cost_usd': now_cost(),\n" +
        "        }\n" +
        "        with open(trajectory_log, 'a') as fp: fp.write(json.dumps(rec) + '\\n')\n" +
        "        return rec\n" +
        "\n" +
        "    # ---- training loop ----\n" +
        "    print(f'Training for up to {args.steps} steps (grad_accum={args.grad_accum}, eval_interval={args.eval_interval})...')\n" +
        "    model.train()\n" +
        "    rng = np.random.default_rng(20260425)\n" +
        "    grad_accum = max(1, int(args.grad_accum))\n" +
        "    optim.zero_grad()\n" +
        "    accum_count = 0\n" +
        "    last_train_loss = float('nan')\n" +
        "    last_loss_components = {}\n" +
        "\n" +
        "    for step in range(1, args.steps + 1):\n" +
        "        # sample batch from corpus (cycling)\n" +
        "        idx = rng.integers(0, len(corpus), size=args.batch_size)\n" +
        "        batch_prompts = [corpus[int(i)] for i in idx]\n" +
        "        toks = tok(batch_prompts, return_tensors='pt', padding=True, truncation=True,\n" +
        "                   max_length=128).to(model.device)\n" +
        "        out = model(**toks, labels=toks['input_ids'], output_hidden_states=True)\n" +
        "        l_lm = out.loss\n" +
        "        h_batch = out.hidden_states[-1][:, -1, :]\n" +
        "        # PAIRS index reuse only valid if batch_size matches EVAL spec (16). Otherwise skip pair-derived.\n" +
        "        can_use_pairs = h_batch.shape[0] >= 12  # PAIRS max idx 11\n" +
        "        l_papo = loss_papo_top_3(h_batch) if can_use_pairs else h_batch.new_zeros(())\n" +
        "        l_iir  = loss_i_irr(h_batch)\n" +
        "        l_pair = loss_contrastive_pair(h_batch) if can_use_pairs else h_batch.new_zeros(())\n" +
        "        # L_substitution: forward small ANTI/RANDOM batch every step (cost: 3× small forward)\n" +
        "        try:\n" +
        "            h_o = hidden_for_prompts(EVAL_PROMPTS)\n" +
        "            h_a = hidden_for_prompts(ANTI_MAP_V2)\n" +
        "            h_r = hidden_for_prompts(RANDOM_POOL)\n" +
        "            l_sub = loss_substitution(h_o, h_a, h_r)\n" +
        "        except Exception as e:\n" +
        "            print(f'WARN l_sub forward failed step={step}: {e}', file=sys.stderr)\n" +
        "            l_sub = h_batch.new_zeros(())\n" +
        "        l_eig = loss_eigen_balance()\n" +
        "\n" +
        "        L_total = (l_lm\n" +
        "                   + LAMBDA_BASELINE['papo']  * l_papo\n" +
        "                   + LAMBDA_BASELINE['iir']   * l_iir\n" +
        "                   + LAMBDA_BASELINE['pair']  * l_pair\n" +
        "                   + LAMBDA_BASELINE['sub']   * l_sub\n" +
        "                   + LAMBDA_BASELINE['eigen'] * l_eig) / grad_accum\n" +
        "        L_total.backward()\n" +
        "        accum_count += 1\n" +
        "        last_train_loss = float(L_total.item() * grad_accum)\n" +
        "        last_loss_components = {\n" +
        "            'lm': float(l_lm.item()), 'papo': float(l_papo.item()),\n" +
        "            'iir': float(l_iir.item()), 'pair': float(l_pair.item()),\n" +
        "            'sub': float(l_sub.item()), 'eigen': float(l_eig.item()),\n" +
        "        }\n" +
        "        if accum_count >= grad_accum:\n" +
        "            torch.nn.utils.clip_grad_norm_(\n" +
        "                list(model.parameters()) + list(head.parameters()), max_norm=1.0)\n" +
        "            optim.step(); optim.zero_grad(); accum_count = 0\n" +
        "\n" +
        "        # ---- per-eval-interval: r4 monitor + checkpoint ----\n" +
        "        if step % args.eval_interval == 0 or step == args.steps:\n" +
        "            model.eval()\n" +
        "            with torch.no_grad():\n" +
        "                h_eval = get_eval_h()\n" +
        "            m = measure_5tuple_partial(h_eval)\n" +
        "            signal = (step >= R4_MIN_TRAIN_STEPS\n" +
        "                      and m['v2_pass_count_le_5'] >= R4_V2_PASS_COUNT_THRESHOLD\n" +
        "                      and m['v_pairrank_top3'] >= R4_V_PAIRRANK_TOP3_THRESHOLD)\n" +
        "            rec = log_trajectory(step, last_train_loss, last_loss_components, m, signal)\n" +
        "            print(f'  step {step}: loss={last_train_loss:.4f} v2={m[\"v2_pass_count_le_5\"]} '\n" +
        "                  f'vp3={m[\"v_pairrank_top3\"]:.3f} sma={m[\"sma_lift\"]:.3f} signal={signal}')\n" +
        "            sweet_spot_history.append((step, signal, m))\n" +
        "            if signal:\n" +
        "                # better-or-first: snapshot if first or strictly better\n" +
        "                better = (r4_star_metrics is None\n" +
        "                          or (m['v2_pass_count_le_5'] + m['v_pairrank_top3'])\n" +
        "                             > (r4_star_metrics['v2_pass_count_le_5'] + r4_star_metrics['v_pairrank_top3']))\n" +
        "                if better:\n" +
        "                    r4_star_step = step\n" +
        "                    r4_star_metrics = m\n" +
        "                    r4_star_ckpt_path = save_checkpoint(step)\n" +
        "                    print(f'  *** sweet_spot snapshot: step={step}, ckpt={r4_star_ckpt_path}')\n" +
        "                consecutive_degrade = 0\n" +
        "            else:\n" +
        "                if r4_star_step is not None:\n" +
        "                    consecutive_degrade += 1\n" +
        "                    if consecutive_degrade >= R4_N_LOOKBACK:\n" +
        "                        early_stop_reason = f'sweet_spot_degraded_{R4_N_LOOKBACK}_consecutive'\n" +
        "                        print(f'EARLY_STOP at step {step}: {early_stop_reason}')\n" +
        "                        break\n" +
        "            log_cost(step, extra={'event': 'eval_interval'})\n" +
        "            model.train()\n" +
        "\n" +
        "        # ---- auto-kill ----\n" +
        "        kill = auto_kill_check(step)\n" +
        "        if kill:\n" +
        "            early_stop_reason = f'auto_kill_{kill}'\n" +
        "            log_cost(step, extra={'event': 'auto_kill', 'reason': kill})\n" +
        "            break\n" +
        "\n" +
        "    # ---- finalize ----\n" +
        "    final_step = step\n" +
        "    if r4_star_step is not None:\n" +
        "        print(f'Restoring r4_star checkpoint: step={r4_star_step}')\n" +
        "        try:\n" +
        "            from peft import PeftModel\n" +
        "            # Reload LoRA from snapshot (re-attach by replacing adapter weights).\n" +
        "            # NOTE: simplistic restore — full restore via PeftModel.from_pretrained would\n" +
        "            # require re-init pipeline; for trajectory record we rely on saved ckpt path.\n" +
        "            print(f'  ckpt path: {r4_star_ckpt_path} (re-load externally for inference)')\n" +
        "        except Exception as e:\n" +
        "            print(f'WARN restore deferred to external script: {e}', file=sys.stderr)\n" +
        "    else:\n" +
        "        print('FAIL_TO_REACH_SWEET_SPOT — no signal during training; all ckpts retained.')\n" +
        "\n" +
        "    # final 5-tuple (post-training, current weights — NOT restored r4_star)\n" +
        "    model.eval()\n" +
        "    with torch.no_grad():\n" +
        "        h_final = get_eval_h()\n" +
        "    final_partial = measure_5tuple_partial(h_final)\n" +
        "    try:\n" +
        "        v_sub = compute_v_sub(model_eval=False)\n" +
        "    except Exception as e:\n" +
        "        print(f'WARN v_sub failed: {e}', file=sys.stderr)\n" +
        "        v_sub = None\n" +
        "    final_record = {\n" +
        "        'final_step': final_step,\n" +
        "        'early_stop_reason': early_stop_reason,\n" +
        "        'r4_star_step': r4_star_step,\n" +
        "        'r4_star_metrics': r4_star_metrics,\n" +
        "        'r4_star_ckpt_path': r4_star_ckpt_path,\n" +
        "        'final_partial_5tuple': final_partial,\n" +
        "        'final_V_sub': v_sub,\n" +
        "        'lambda_baseline': LAMBDA_BASELINE,\n" +
        "        'elapsed_min': now_elapsed_min(),\n" +
        "        'estimated_cost_usd': now_cost(),\n" +
        "        'corpus_path': args.corpus,\n" +
        "        'corpus_size': len(corpus),\n" +
        "        'mock_corpus': bool(args.allow_mock_corpus and (not args.corpus or not os.path.exists(args.corpus))),\n" +
        "    }\n" +
        "    with open(final_5tuple_path, 'w') as fp: json.dump(final_record, fp, indent=2)\n" +
        "    sweet_record = {\n" +
        "        'r4_star_step': r4_star_step,\n" +
        "        'r4_star_metrics': r4_star_metrics,\n" +
        "        'r4_star_ckpt_path': r4_star_ckpt_path,\n" +
        "        'early_stop_reason': early_stop_reason,\n" +
        "        'sweet_spot_history': [\n" +
        "            {'step': s, 'signal': bool(sig), 'metrics': mm}\n" +
        "            for (s, sig, mm) in sweet_spot_history\n" +
        "        ],\n" +
        "        'thresholds': {\n" +
        "            'v2_pass_count_threshold': R4_V2_PASS_COUNT_THRESHOLD,\n" +
        "            'v2_pass_k_max': R4_V2_PASS_K_MAX,\n" +
        "            'v_pairrank_top3_threshold': R4_V_PAIRRANK_TOP3_THRESHOLD,\n" +
        "            'N_lookback': R4_N_LOOKBACK,\n" +
        "            'min_train_steps': R4_MIN_TRAIN_STEPS,\n" +
        "        },\n" +
        "    }\n" +
        "    with open(sweet_spot_record_path, 'w') as fp: json.dump(sweet_record, fp, indent=2)\n" +
        "    log_cost(final_step, extra={'event': 'final', 'early_stop_reason': early_stop_reason})\n" +
        "    print(f'final_5tuple={final_5tuple_path}')\n" +
        "    print(f'sweet_spot_record={sweet_spot_record_path}')\n" +
        "    print(f'cost_log={cost_log_path}')\n" +
        "    print(f'trajectory_log={trajectory_log}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def main():\n" +
        "    p = argparse.ArgumentParser()\n" +
        "    sub = p.add_subparsers(dest='cmd', required=True)\n" +
        "    sub.add_parser('selftest')\n" +
        "    e = sub.add_parser('emit-helper'); e.add_argument('path')\n" +
        "    l = sub.add_parser('launch')\n" +
        "    l.add_argument('--backbone', default='Qwen/Qwen3-8B')\n" +
        "    l.add_argument('--output-dir', required=True)\n" +
        "    l.add_argument('--steps', type=int, default=5000)\n" +
        "    l.add_argument('--lr', type=float, default=2e-4)\n" +
        "    l.add_argument('--batch-size', type=int, default=16)\n" +
        "    l.add_argument('--lora-rank', type=int, default=64)\n" +
        "    l.add_argument('--lora-alpha', type=int, default=16)\n" +
        "    l.add_argument('--cost-cap', type=float, default=20.0)\n" +
        "    l.add_argument('--runtime-cap-min', type=int, default=120)\n" +
        "    l.add_argument('--hourly-rate', type=float, default=2.5,\n" +
        "                   help='USD/hr for cost tracker (e.g. H100 spot ~$2-3/hr)')\n" +
        "    l.add_argument('--corpus', default=None,\n" +
        "                   help='text corpus path (one doc per line); fallback ABORT_NO_CORPUS')\n" +
        "    l.add_argument('--allow-mock-corpus', action='store_true',\n" +
        "                   help='use EVAL_PROMPTS+ANTI_MAP+RANDOM as fallback (spec val only, raw#10 honest)')\n" +
        "    l.add_argument('--grad-accum', type=int, default=4)\n" +
        "    l.add_argument('--eval-interval', type=int, default=100)\n" +
        "    args = p.parse_args()\n" +
        "    if args.cmd == 'selftest': selftest()\n" +
        "    elif args.cmd == 'emit-helper': emit_helper_to(args.path)\n" +
        "    elif args.cmd == 'launch': launch(args)\n" +
        "    else: sys.exit(2)\n" +
        "\n" +
        "if __name__ == '__main__': main()\n"
    write_file(HELPER_PATH, src)
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut emit_to = ""
    let mut do_launch = false
    let mut backbone = "Qwen/Qwen3-8B"
    let mut output_dir = ""
    let mut steps = 5000
    let mut corpus = ""
    let mut allow_mock = false
    let mut grad_accum = 4
    let mut eval_interval = 100
    let mut hourly_rate = "2.5"
    let mut cost_cap = "20.0"
    let mut runtime_cap_min = 120
    let mut lr = "2e-4"
    let mut batch_size = 16
    let mut lora_rank = 64
    let mut lora_alpha = 16
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        if a == "--emit-helper" && i + 1 < len(av) { emit_to = av[i+1]; i = i + 2; continue }
        if a == "--launch" { do_launch = true; i = i + 1; continue }
        if a == "--backbone" && i + 1 < len(av) { backbone = av[i+1]; i = i + 2; continue }
        if a == "--output-dir" && i + 1 < len(av) { output_dir = av[i+1]; i = i + 2; continue }
        if a == "--steps" && i + 1 < len(av) { steps = to_int(av[i+1]); i = i + 2; continue }
        if a == "--corpus" && i + 1 < len(av) { corpus = av[i+1]; i = i + 2; continue }
        if a == "--allow-mock-corpus" { allow_mock = true; i = i + 1; continue }
        if a == "--grad-accum" && i + 1 < len(av) { grad_accum = to_int(av[i+1]); i = i + 2; continue }
        if a == "--eval-interval" && i + 1 < len(av) { eval_interval = to_int(av[i+1]); i = i + 2; continue }
        if a == "--hourly-rate" && i + 1 < len(av) { hourly_rate = av[i+1]; i = i + 2; continue }
        if a == "--cost-cap" && i + 1 < len(av) { cost_cap = av[i+1]; i = i + 2; continue }
        if a == "--runtime-cap-min" && i + 1 < len(av) { runtime_cap_min = to_int(av[i+1]); i = i + 2; continue }
        if a == "--lr" && i + 1 < len(av) { lr = av[i+1]; i = i + 2; continue }
        if a == "--batch-size" && i + 1 < len(av) { batch_size = to_int(av[i+1]); i = i + 2; continue }
        if a == "--lora-rank" && i + 1 < len(av) { lora_rank = to_int(av[i+1]); i = i + 2; continue }
        if a == "--lora-alpha" && i + 1 < len(av) { lora_alpha = to_int(av[i+1]); i = i + 2; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── mk_xi_train selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("marker missing"); exit(1) }
        println("selftest: OK (loss composition spec validated, no torch required)")
        exit(0)
    }

    if emit_to != "" {
        println("── mk_xi_train emit-helper ──")
        let r = _run_helper("emit-helper " + _sh_quote(emit_to))
        println(r[0])
        if r[1] != 0 { eprintln("emit FAILED"); exit(1) }
        println("Helper emitted to: " + emit_to)
        println("Suitable for pod upload + execution.")
        exit(0)
    }

    if do_launch {
        if output_dir == "" { eprintln("ABORT: --output-dir required for --launch"); exit(2) }
        if corpus == "" && !allow_mock {
            eprintln("ABORT_NO_CORPUS: --corpus PATH required (or --allow-mock-corpus for spec val).")
            exit(3)
        }
        println("── mk_xi_train launch (pre-approved auto-launch) ──")
        println("backbone:    " + backbone)
        println("output_dir:  " + output_dir)
        println("steps:       " + to_string(steps))
        println("corpus:      " + corpus)
        println("mock_corpus: " + to_string(allow_mock))
        println("grad_accum:  " + to_string(grad_accum))
        println("eval_intvl:  " + to_string(eval_interval))
        println("lr:          " + lr)
        println("batch_size:  " + to_string(batch_size))
        println("lora rank/α: " + to_string(lora_rank) + "/" + to_string(lora_alpha))
        println("Cap: $" + cost_cap + " cycle, auto-kill " + to_string(runtime_cap_min) +
                "min @ $" + hourly_rate + "/hr (per memory feedback_forward_auto_approval)")
        let mut args = "launch --backbone " + _sh_quote(backbone) +
                   " --output-dir " + _sh_quote(output_dir) +
                   " --steps " + to_string(steps) +
                   " --grad-accum " + to_string(grad_accum) +
                   " --eval-interval " + to_string(eval_interval) +
                   " --hourly-rate " + hourly_rate +
                   " --cost-cap " + cost_cap +
                   " --runtime-cap-min " + to_string(runtime_cap_min) +
                   " --lr " + lr +
                   " --batch-size " + to_string(batch_size) +
                   " --lora-rank " + to_string(lora_rank) +
                   " --lora-alpha " + to_string(lora_alpha)
        if corpus != "" { args = args + " --corpus " + _sh_quote(corpus) }
        if allow_mock   { args = args + " --allow-mock-corpus" }
        let r = _run_helper(args)
        println(r[0])
        if r[1] != 0 {
            eprintln("Launch helper exit " + to_string(r[1]) + " — check torch/transformers/peft availability")
            exit(r[1])
        }
        exit(0)
    }

    eprintln("usage: hexa run tool/mk_xi_train.hexa [--selftest | --emit-helper PATH |")
    eprintln("       --launch --output-dir DIR --corpus PATH [--allow-mock-corpus]")
    eprintln("              [--steps N] [--grad-accum N] [--eval-interval N] [--lr 2e-4]")
    eprintln("              [--batch-size N] [--lora-rank N] [--lora-alpha N]")
    eprintln("              [--cost-cap USD] [--runtime-cap-min MIN] [--hourly-rate USD]]")
    exit(2)
}

main()
