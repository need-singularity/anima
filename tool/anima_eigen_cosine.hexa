// tool/anima_eigen_cosine.hexa — Anima AN11(b) cosine compute (raw#9 hexa-only).
//
// PURPOSE
//   Mac-local cosine computation for AN11(b) eigen × template alignment.
//   Migration #5 from inline python cosine compute (axis 14/15/16/17/22/23 cycles).
//   Pairs with tool/anima_an11b_eigen.hexa (eigen output → cosine compute).
//
// ENV
//   ANIMA_EIGEN_PATH       eigen JSON file (required)
//   ANIMA_TEMPLATES_PATH   templates jsonl (default: ~/core/anima/consciousness/an11_b_templates.jsonl)
//   ANIMA_OUTPUT           cosine analysis output JSON (default: stdout-only)
//   ANIMA_TOP_K            top-K cosine pairs to report (default: 5)
//
// USAGE
//   hexa run tool/anima_eigen_cosine.hexa --selftest
//   hexa run tool/anima_eigen_cosine.hexa run    # emits + computes
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_eigen_cosine_helper.hexa_tmp"
let SCHEMA      = "anima/anima_eigen_cosine/1"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima AN11(b) cosine helper — emitted by tool/anima_eigen_cosine.hexa\n")
    parts.push("# raw#37 transient. Mac-local execution.\n")
    parts.push("import json, os, sys\n")
    parts.push("import numpy as np\n\n")

    parts.push("EIGEN = os.environ.get('ANIMA_EIGEN_PATH', '')\n")
    parts.push("TEMPLATES = os.environ.get('ANIMA_TEMPLATES_PATH', '/Users/ghost/core/anima/consciousness/an11_b_templates.jsonl')\n")
    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', '')\n")
    parts.push("TOP_K = int(os.environ.get('ANIMA_TOP_K', '5'))\n\n")

    parts.push("if not EIGEN:\n")
    parts.push("    print('ERROR: ANIMA_EIGEN_PATH required'); sys.exit(2)\n\n")

    parts.push("with open(EIGEN) as f: eig = json.load(f)\n")
    parts.push("ev = np.array(eig['eigenvectors'])\n")
    parts.push("templates = []\n")
    parts.push("with open(TEMPLATES) as f:\n")
    parts.push("    for ln in f:\n")
    parts.push("        ln = ln.strip()\n")
    parts.push("        if ln: templates.append(json.loads(ln))\n\n")

    parts.push("def normv(v):\n")
    parts.push("    n = np.linalg.norm(v); return v/n if n > 0 else v\n\n")

    parts.push("ev_n = np.array([normv(ev[i]) for i in range(ev.shape[0])])\n")
    parts.push("tpl_n = np.array([normv(np.array(t['signature'])) for t in templates])\n")
    parts.push("cos = np.abs(ev_n @ tpl_n.T)\n\n")

    parts.push("flat = []\n")
    parts.push("for i in range(ev.shape[0]):\n")
    parts.push("    for j in range(len(templates)):\n")
    parts.push("        flat.append((float(cos[i,j]), i, templates[j]['id'], templates[j]['family']))\n")
    parts.push("flat.sort(reverse=True)\n\n")

    parts.push("top_k_pairs = [{'cos': c, 'eigen_i': i, 'tpl': t, 'family': f} for c,i,t,f in flat[:TOP_K]]\n")
    parts.push("max_cos = flat[0][0]\n")
    parts.push("top1_family = flat[0][3]\n")
    parts.push("top1_template = flat[0][2]\n")
    parts.push("top3_sum = sum(c for c,_,_,_ in flat[:3])\n\n")

    parts.push("# Family activation top-8 aggregation (per-family sum)\n")
    parts.push("fam_act = {'Hexad': 0.0, 'Law': 0.0, 'Phi': 0.0, 'SelfRef': 0.0}\n")
    parts.push("for c, i, t, f in flat[:8]:\n")
    parts.push("    if f in fam_act: fam_act[f] += c\n\n")

    parts.push("result = {\n")
    parts.push("    'schema': 'anima/an11b_cosine_analysis/1',\n")
    parts.push("    'eigen_path': EIGEN, 'templates_path': TEMPLATES,\n")
    parts.push("    'n_eigenvectors': int(ev.shape[0]), 'n_templates': len(templates),\n")
    parts.push("    'max_cosine': max_cos, 'top1_family': top1_family, 'top1_template': top1_template,\n")
    parts.push("    'top3_cosine_sum': top3_sum,\n")
    parts.push("    'top_k_pairs': top_k_pairs,\n")
    parts.push("    'family_activation_top8': fam_act,\n")
    parts.push("    'gate_max_geq_0_5': max_cos >= 0.5,\n")
    parts.push("    'gate_top3_geq_1_2': top3_sum >= 1.2,\n")
    parts.push("    'gate_PASS': max_cos >= 0.5 and top3_sum >= 1.2,\n")
    parts.push("}\n\n")

    parts.push("print(f'AN11(b) cosine analysis:')\n")
    parts.push("print(f'  max_cosine: {max_cos:.4f} family={top1_family} ({top1_template})')\n")
    parts.push("print(f'  top3_sum:   {top3_sum:.4f}')\n")
    parts.push("for c, i, t, f in flat[:TOP_K]:\n")
    parts.push("    print(f'    cos={c:.4f} eigen_i={i} tpl={t} family={f}')\n")
    parts.push("print(f'  family_top8: {fam_act}')\n")
    parts.push("print(f'  Gate (max>=0.5 AND top3>=1.2): {result[\"gate_PASS\"]}')\n\n")

    parts.push("if OUTPUT:\n")
    parts.push("    with open(OUTPUT, 'w') as f: json.dump(result, f, indent=2)\n")
    parts.push("    print(f'  saved -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn cmd_selftest() {
    println("── anima_eigen_cosine selftest ──")
    _write_helper()
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("usage: ANIMA_EIGEN_PATH=<path> python3 " + HELPER_PATH)
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }

    if selftest {
        cmd_selftest()
        exit(0)
    }

    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}

main()
