// tool/anima_ready_raw9_policy_proposer.hexa — cycle 71 ready/ raw#9 policy options (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 31 ready_dir_audit 발견: ready/는 anima와 별개 git repo (branch
//   ssot-hexa-first-fix, 매우 시사적 이름). 737 .py가 raw#9 strict 위반.
//   cycle 71 = 5 policy 옵션 정밀화 + 사용자 결정 입력 정리.
//
//   본 helper는 NON_MUTATION proposer — 정책 결정은 사용자 영역.
//
// CONTEXT (cycle 31 + 71 inspection)
//   ready dir branch    : ssot-hexa-first-fix (이름이 의도 시사: SSOT raw#9 강화)
//   file inventory      : 802 hexa / 737 py / 1077 json / 536 md / 1.5GB total
//   .gitignore          : ready/는 .py 허용 (main anima는 **/*.py ban)
//   py top-level 분포   : 457 .claude / 369 anima / 203 tests / 88 bench /
//                          80 experiments / 31 models / 25 scripts / 13 training / 6 core
//
// 5 POLICY OPTIONS
//
//   OPT_A_STRICT_CONVERT  : 737 .py 전부 .hexa 변환 OR 삭제
//                            cost: very-high (수백 MD파일 변환)
//                            risk: numpy/torch 의존 .py 변환 막힘 (cycle 32 known)
//                            invariant: full alignment with main repo raw#9
//
//   OPT_B_DOCUMENTED_DIV  : ready/ raw#9 면제 zone으로 정책 문서화
//                            cost: low ($0 mac, 단순 doc edit)
//                            risk: slippery slope (other dirs도 면제 요청)
//                            invariant: explicitly weakened in named scope
//
//   OPT_C_QUARANTINE      : 737 .py를 ready/research/ 등 dedicated subdir로 격리
//                            cost: medium (재구성 + import path 갱신)
//                            risk: 변환 cost 회피하면서 invariant 격리
//                            invariant: main repo raw#9 + isolated exempt zone
//
//   OPT_D_HYBRID_CATEGORY : 737 .py를 카테고리별 다른 처리
//                            categories suggested: tests / bench / experiments /
//                              .claude tooling / anima mirror / training / models /
//                              scripts / core
//                            policy per-category:
//                              .claude tooling   → exempt (claude-side runtime)
//                              tests/bench/exp   → quarantine in research/
//                              anima mirror      → STRICT_CONVERT (raw#9 strict)
//                              training/models   → numpy-blocked exempt list
//                            cost: high (분류 + 카테고리별 작업)
//                            risk: 분류 결정 자체가 정책
//                            invariant: per-category fine-grained
//
//   OPT_E_DEFER           : 현 상태 유지 (사용자 의도 확인 보류)
//                            cost: zero
//                            risk: cycle 31부터 frozen 지속
//                            invariant: status quo
//
// BRANCH NAME 단서
//   ready/ branch = "ssot-hexa-first-fix" — "SSOT hexa-first" 라는 명명은
//   사용자가 이미 OPT_A 또는 OPT_C 방향을 의도했음을 시사 (작업 중인 branch).
//   사용자 의도 확인은 "ready/는 점진적 raw#9 alignment 진행 중"으로 추정.
//
// NON_MUTATION
//   본 helper는 ready/ 어떤 파일도 수정하지 않음. policy options 제안 +
//   state JSON 기록만.
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - 5 옵션 모두 가능; 사용자 의도 (branch name) 기준으로는 OPT_A/C 가 가장 적합.
//   - OPT_D는 hybrid라서 ROI 가장 높을 가능성, but 분류 cost 큼.
//   - cycle 31에서부터 frozen — 결정 보류 자체가 OPT_E (default).

let HELPER_PATH = "/tmp/anima_ready_raw9_policy_proposer_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima ready/ raw#9 policy proposer — emitted by tool/anima_ready_raw9_policy_proposer.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/ready_raw9_policy_proposer.json')\n\n")

    parts.push("context = {\n")
    parts.push("    'ready_dir': '/Users/ghost/core/anima/ready',\n")
    parts.push("    'ready_separate_git': True,\n")
    parts.push("    'ready_branch': 'ssot-hexa-first-fix',\n")
    parts.push("    'branch_intent_signal': '브랜치 이름이 SSOT hexa-first 작업 중임을 시사',\n")
    parts.push("    'file_inventory': {\n")
    parts.push("        'hexa': 802, 'py': 737, 'json': 1077, 'md': 536, 'total_size_kb': 1525396,\n")
    parts.push("    },\n")
    parts.push("    'py_topdir_distribution': {\n")
    parts.push("        '.claude': 457, 'anima': 369, 'tests': 203, 'bench': 88,\n")
    parts.push("        'experiments': 80, 'models': 31, 'scripts': 25, 'training': 13, 'core': 6,\n")
    parts.push("    },\n")
    parts.push("    'main_repo_raw9_strict': True,\n")
    parts.push("    'ready_gitignore_allows_py': True,\n")
    parts.push("    'cycle_31_findings':[\n")
    parts.push("        'RAW9_PY_DIVERGENCE (medium)','PY_FILES_PRESENT_IN_READY (high)',\n")
    parts.push("    ],\n")
    parts.push("}\n\n")

    parts.push("policy_options = [\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_A_STRICT_CONVERT',\n")
    parts.push("        'description':'737 .py 전부 .hexa 변환 또는 삭제',\n")
    parts.push("        'cost':'very-high (수백 file 변환 + 검증)',\n")
    parts.push("        'risk':'numpy/torch 의존 .py 일부는 변환 막힘 (cycle 32 known: 3 active_redteam research + p_s_projector)',\n")
    parts.push("        'invariant':'main repo와 full alignment',\n")
    parts.push("        'time_estimate':'2-4 sessions 자동화 보조 시',\n")
    parts.push("        'aligns_with_branch_intent':'high (ssot-hexa-first-fix)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_B_DOCUMENTED_DIV',\n")
    parts.push("        'description':'ready/ raw#9 면제 zone으로 명시 문서화',\n")
    parts.push("        'cost':'low ($0 mac, doc edit + memory entry)',\n")
    parts.push("        'risk':'slippery slope; invariant 영구 weakening',\n")
    parts.push("        'invariant':'main raw#9 strict + named exempt zone',\n")
    parts.push("        'time_estimate':'1 cycle',\n")
    parts.push("        'aligns_with_branch_intent':'low (branch는 fix 의도 시사)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_C_QUARANTINE',\n")
    parts.push("        'description':'737 .py 전체를 ready/research/ 등 dedicated subdir로 격리',\n")
    parts.push("        'cost':'medium (재구성 + import path 갱신)',\n")
    parts.push("        'risk':'변환 cost 회피하면서 invariant 격리; import path 깨짐 검증 필요',\n")
    parts.push("        'invariant':'main raw#9 + isolated subdir exempt',\n")
    parts.push("        'time_estimate':'2-3 sessions',\n")
    parts.push("        'aligns_with_branch_intent':'medium-high (fix 방향 진행 + 점진적)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_D_HYBRID_CATEGORY',\n")
    parts.push("        'description':'737 .py를 9 카테고리별 다른 처리 (per-topdir)',\n")
    parts.push("        'cost':'high (분류 + 9 카테고리별 작업)',\n")
    parts.push("        'risk':'분류 결정 자체가 정책 — 잘못 분류 시 부분 비효율',\n")
    parts.push("        'invariant':'per-category fine-grained',\n")
    parts.push("        'time_estimate':'4-6 sessions',\n")
    parts.push("        'aligns_with_branch_intent':'high (정밀 fix)',\n")
    parts.push("        'per_category_recommended':{\n")
    parts.push("            '.claude (457)':'exempt (claude-side runtime)',\n")
    parts.push("            'anima (369)':'STRICT_CONVERT (raw#9 mirror)',\n")
    parts.push("            'tests (203)':'quarantine in research/tests/',\n")
    parts.push("            'bench (88)':'quarantine in research/bench/',\n")
    parts.push("            'experiments (80)':'quarantine in research/experiments/',\n")
    parts.push("            'models (31)':'numpy-blocked exempt list (cycle 32 pattern)',\n")
    parts.push("            'scripts (25)':'STRICT_CONVERT or shell migration',\n")
    parts.push("            'training (13)':'numpy-blocked exempt list',\n")
    parts.push("            'core (6)':'STRICT_CONVERT (raw#9 mirror)',\n")
    parts.push("        },\n")
    parts.push("        'roi_high_picks':['anima(369) STRICT_CONVERT first — biggest invariant gain', 'tests/bench/exp QUARANTINE second — fast wins'],\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_E_DEFER',\n")
    parts.push("        'description':'사용자 의도 확인 보류 (현 상태 유지)',\n")
    parts.push("        'cost':'zero',\n")
    parts.push("        'risk':'cycle 31부터 frozen 지속; invariant divergence 누적',\n")
    parts.push("        'invariant':'status quo',\n")
    parts.push("        'time_estimate':'0',\n")
    parts.push("        'aligns_with_branch_intent':'low (action 없음)',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("helper_recommendation = {\n")
    parts.push("    'branch_name_signal':'ssot-hexa-first-fix → 사용자 의도는 OPT_A/C/D 중 하나',\n")
    parts.push("    'roi_picked':'OPT_D_HYBRID_CATEGORY',\n")
    parts.push("    'first_action_proposed':'anima(369) STRICT_CONVERT — main repo와 mirror 일치 가장 우선',\n")
    parts.push("    'second_action_proposed':'tests(203) + bench(88) + experiments(80) → research/ subtree QUARANTINE (single rename op)',\n")
    parts.push("    'rationale':'OPT_D는 정밀하지만 cost 분산; 첫 두 action만 끝내도 raw#9 invariant 회복도 ~62% (anima+tests+bench+experiments=740/737~100% .py touched, 일부 변환/일부 격리)',\n")
    parts.push("    'user_decision_required':True,\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 71 — ready/ raw#9 policy 5 options + branch-intent inference',\n")
    parts.push("    'cycle': 71,\n")
    parts.push("    'context': context,\n")
    parts.push("    'policy_options': policy_options,\n")
    parts.push("    'helper_recommendation': helper_recommendation,\n")
    parts.push("    'non_mutation_guarantee':'helper proposes only; ready/ 어떤 파일도 modify 안 함',\n")
    parts.push("    'cross_link_cycles':['cycle 31 ready_dir_audit (initial finding)', 'cycle 32 raw#9 anima-only scope confirmation'],\n")
    parts.push("    'pattern':'governance audit chain layer 50 (high-priority queue item — frozen since cycle 31)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[ready_raw9_policy] cycle=71 options=5 recommended=OPT_D first=anima(369)_STRICT_CONVERT -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_PROPOSER")
    println("inv:cycle=71")
    println("inv:options_count=5")
    println("inv:recommendation=OPT_D_HYBRID_CATEGORY")
    println("inv:branch_intent_signal=ssot-hexa-first-fix")
    println("inv:cross_link_cycles=31,32")
    return true
}

fn cmd_selftest() {
    println("── anima_ready_raw9_policy_proposer selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 71 — ready/ raw#9 policy 5 options proposer; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
