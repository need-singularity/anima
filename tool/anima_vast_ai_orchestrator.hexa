// tool/anima_vast_ai_orchestrator.hexa — Anima vast.ai pod lifecycle orchestrator (raw#9 + raw#37).
//
// PURPOSE
//   NEW tool (NOT extend tool/anima_runpod_orchestrator.hexa which hard-codes
//   runpodctl path L75-76). Per Agent B + Agent 2 sub-agent kicks
//   (anima-cmd-loop session 2026-04-28T07:25Z + 07:45Z), vast.ai is the
//   winner alt-vendor for CP2 trio dispatch ($32-35 single-shared-pod target).
//
//   Pre-built scaffold so when user signs up vast.ai, dispatch is immediately
//   ready (Pattern 6c R1 download + R2 measure templates wired).
//
// USAGE
//   Selftest:
//     hexa run tool/anima_vast_ai_orchestrator.hexa --selftest
//
//   Pattern 6c R1 download_pod:
//     hexa run tool/anima_vast_ai_orchestrator.hexa dispatch-r1-download \
//       --instance-name r1-gemma27b-download \
//       --gpu-name "RTX_3090" --disk-gb 200 \
//       --hf-repo google/gemma-2-27b-it \
//       --max-cost 5 --max-runtime-min 60 \
//       --cost-center anima-cmd-loop --task-id cp2-r1-download \
//       --output state/vast_r1_<id>.json --run-id <id>
//
//   Pattern 6c R2 measurement_pod (attach R1 volume OR scp model):
//     hexa run tool/anima_vast_ai_orchestrator.hexa dispatch-r2-measure \
//       --instance-name r2-gemma27b-measure \
//       --gpu-name "H100_SXM" --r1-instance-id <id> \
//       --hexa-script tool/h100_run_gemma_27b.hexa \
//       --max-cost 30 --max-runtime-min 120 \
//       --cost-center anima-cmd-loop --task-id cp2-r2-measure \
//       --output state/vast_r2_<id>.json --run-id <id>
//
//   Lifecycle subcommands (mirror RunPod orchestrator surface):
//     create-instance / list-instances / status / terminate
//
// SAFETY (raw 86 cost-attribution + raw 91 honest disclosure)
//   --max-cost N            cost cap USD (default $30 per cycle)
//   --max-runtime-min M     auto-kill if elapsed > M (default 120min)
//   --cost-center            audit field — emitted to state/audit when wired
//   --task-id                audit field — Pattern 6c R1/R2 attribution
//   --auto-terminate         instance destroy after run (default true)
//   --dry-run                spec validation only, no actual API calls
//
// raw 91 C3 HONEST DISCLOSURE
//   Pricing targets ($32-35) are EXTRAPOLATED from Agent B sub-agent
//   findings + vast.ai public pricing pages, NOT cited from invoiced
//   transactions. Actual cost will be confirmed post-dispatch.

let HELPER_PATH = "/tmp/anima_vast_ai_orchestrator_helper.hexa_tmp"
let SCHEMA      = "anima/anima_vast_ai_orchestrator/1"
let SPEC_DOC    = "docs/runbooks/runpod_alt_vendor_vast_ai.md"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima vast.ai orchestrator helper — emitted by tool/anima_vast_ai_orchestrator.hexa\n")
    parts.push("# raw#37 transient.\n")
    parts.push("import json, os, sys, subprocess, time, datetime, shlex, argparse, signal\n\n")

    // Vendor abstraction — try canonical paths in priority order
    parts.push("def _resolve_vastai_cli():\n")
    parts.push("    candidates = [\n")
    parts.push("        '/Users/ghost/.local/bin/vastai',\n")
    parts.push("        '/opt/homebrew/bin/vastai',\n")
    parts.push("        '/usr/local/bin/vastai',\n")
    parts.push("    ]\n")
    parts.push("    for p in candidates:\n")
    parts.push("        if os.path.exists(p): return p\n")
    parts.push("    # Fallback: PATH lookup\n")
    parts.push("    from shutil import which\n")
    parts.push("    w = which('vastai')\n")
    parts.push("    return w or candidates[0]\n\n")

    parts.push("VASTAI_CLI = _resolve_vastai_cli()\n")
    parts.push("VAST_SSH_KEY = os.environ.get('VAST_SSH_KEY', '/Users/ghost/.vast/ssh/vast-key')\n")
    parts.push("AUDIT_DIR = 'state/audit/vast_ai'\n\n")

    parts.push("def vastai_json(*args):\n")
    parts.push("    r = subprocess.run([VASTAI_CLI] + list(args), capture_output=True, text=True, timeout=60)\n")
    parts.push("    if r.returncode != 0: raise RuntimeError(f'vastai failed: {r.stderr}')\n")
    parts.push("    try: return json.loads(r.stdout)\n")
    parts.push("    except: return r.stdout\n\n")

    // raw 86 cost-attribution audit emitter
    parts.push("def _emit_audit(event, payload):\n")
    parts.push("    try:\n")
    parts.push("        os.makedirs(AUDIT_DIR, exist_ok=True)\n")
    parts.push("        ts = datetime.datetime.now(datetime.timezone.utc).isoformat()\n")
    parts.push("        rec = {'ts': ts, 'event': event, **payload}\n")
    parts.push("        path = os.path.join(AUDIT_DIR, f'vast_audit_{datetime.date.today().isoformat()}.jsonl')\n")
    parts.push("        with open(path, 'a') as f: f.write(json.dumps(rec) + '\\n')\n")
    parts.push("    except Exception as e:\n")
    parts.push("        print(f'  WARN: audit emit failed: {e}')\n\n")

    parts.push("def search_offers(gpu_name, max_price=None, disk_gb=None):\n")
    parts.push("    \"\"\"vast.ai search query — returns first matching offer\"\"\"\n")
    parts.push("    q = f'gpu_name={gpu_name} rentable=true verified=true'\n")
    parts.push("    if max_price: q += f' dph_total<{max_price}'\n")
    parts.push("    if disk_gb: q += f' disk_space>={disk_gb}'\n")
    parts.push("    cmd = [VASTAI_CLI, 'search', 'offers', q, '--raw']\n")
    parts.push("    r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)\n")
    parts.push("    if r.returncode != 0: raise RuntimeError(f'search failed: {r.stderr}')\n")
    parts.push("    try: return json.loads(r.stdout)\n")
    parts.push("    except: return []\n\n")

    parts.push("def instance_create(args):\n")
    parts.push("    print(f'[create] instance={args.instance_name} gpu={args.gpu_name}')\n")
    parts.push("    _emit_audit('create_request', {'instance_name': args.instance_name,\n")
    parts.push("        'gpu_name': args.gpu_name, 'cost_center': args.cost_center,\n")
    parts.push("        'task_id': args.task_id, 'cost_estimate_usd': args.max_cost,\n")
    parts.push("        'run_id': args.run_id})\n")
    parts.push("    if args.dry_run:\n")
    parts.push("        print(f'[dry-run] would search offers gpu={args.gpu_name} disk={args.disk_gb}GB')\n")
    parts.push("        return {'id': 'DRY_RUN_INSTANCE', 'dry_run': True}\n")
    parts.push("    offers = search_offers(args.gpu_name, max_price=args.max_cost/max(args.max_runtime_min/60.0, 0.5), disk_gb=args.disk_gb)\n")
    parts.push("    if not offers: raise RuntimeError(f'no offers matched gpu={args.gpu_name}')\n")
    parts.push("    offer = offers[0] if isinstance(offers, list) else offers\n")
    parts.push("    offer_id = offer.get('id') if isinstance(offer, dict) else offer\n")
    parts.push("    cmd = [VASTAI_CLI, 'create', 'instance', str(offer_id),\n")
    parts.push("           '--image', args.image,\n")
    parts.push("           '--disk', str(args.disk_gb),\n")
    parts.push("           '--ssh', '--direct',\n")
    parts.push("           '--label', args.instance_name,\n")
    parts.push("           '--env', f'-e RUN_ID={args.run_id} -e COST_CAP={args.max_cost} -e RUNTIME_CAP_MIN={args.max_runtime_min}']\n")
    parts.push("    r = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\n")
    parts.push("    if r.returncode != 0: raise RuntimeError(f'create failed: {r.stderr}')\n")
    parts.push("    try: info = json.loads(r.stdout)\n")
    parts.push("    except: info = {'raw_stdout': r.stdout}\n")
    parts.push("    print(f'  instance_id={info.get(\"new_contract\") or info.get(\"id\")}')\n")
    parts.push("    _emit_audit('create_ack', {'instance_id': info.get('new_contract') or info.get('id'),\n")
    parts.push("        'cost_center': args.cost_center, 'task_id': args.task_id, 'run_id': args.run_id})\n")
    parts.push("    return info\n\n")

    parts.push("def instance_list():\n")
    parts.push("    cmd = [VASTAI_CLI, 'show', 'instances', '--raw']\n")
    parts.push("    r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)\n")
    parts.push("    if r.returncode != 0: raise RuntimeError(f'list failed: {r.stderr}')\n")
    parts.push("    try: return json.loads(r.stdout)\n")
    parts.push("    except: return r.stdout\n\n")

    parts.push("def instance_status(instance_id):\n")
    parts.push("    cmd = [VASTAI_CLI, 'show', 'instance', str(instance_id), '--raw']\n")
    parts.push("    r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)\n")
    parts.push("    if r.returncode != 0: raise RuntimeError(f'status failed: {r.stderr}')\n")
    parts.push("    try: return json.loads(r.stdout)\n")
    parts.push("    except: return r.stdout\n\n")

    parts.push("def instance_ssh_wait(instance_id, max_wait=240):\n")
    parts.push("    print(f'[ssh-wait] instance={instance_id}')\n")
    parts.push("    t0 = time.time()\n")
    parts.push("    while time.time() - t0 < max_wait:\n")
    parts.push("        try:\n")
    parts.push("            info = instance_status(instance_id)\n")
    parts.push("            if isinstance(info, dict):\n")
    parts.push("                ip = info.get('ssh_host') or info.get('public_ipaddr')\n")
    parts.push("                port = info.get('ssh_port') or info.get('direct_port_start')\n")
    parts.push("                if ip and port:\n")
    parts.push("                    r = subprocess.run(['ssh', '-i', VAST_SSH_KEY, '-o', 'StrictHostKeyChecking=no',\n")
    parts.push("                                         '-o', 'ConnectTimeout=10', '-p', str(port),\n")
    parts.push("                                         f'root@{ip}', 'echo READY'],\n")
    parts.push("                                        capture_output=True, text=True, timeout=15)\n")
    parts.push("                    if 'READY' in r.stdout:\n")
    parts.push("                        print(f'  ip={ip} port={port}')\n")
    parts.push("                        return ip, port\n")
    parts.push("        except Exception: pass\n")
    parts.push("        time.sleep(10)\n")
    parts.push("    raise RuntimeError(f'instance {instance_id} not SSH-ready in {max_wait}s')\n\n")

    parts.push("def instance_ssh_exec(ip, port, command, dry_run=False, timeout=600):\n")
    parts.push("    print(f'[exec] {command[:100]}')\n")
    parts.push("    if dry_run: return {'returncode': 0, 'stdout': '[dry-run]', 'stderr': ''}\n")
    parts.push("    r = subprocess.run(['ssh', '-i', VAST_SSH_KEY, '-o', 'StrictHostKeyChecking=no',\n")
    parts.push("                         '-p', str(port), f'root@{ip}', command],\n")
    parts.push("                        capture_output=True, text=True, timeout=timeout)\n")
    parts.push("    return {'returncode': r.returncode, 'stdout': r.stdout, 'stderr': r.stderr}\n\n")

    parts.push("def instance_scp_upload(ip, port, mappings, dry_run=False):\n")
    parts.push("    for m in mappings:\n")
    parts.push("        if ':' not in m: continue\n")
    parts.push("        local, remote = m.split(':', 1)\n")
    parts.push("        if not os.path.exists(local):\n")
    parts.push("            print(f'  WARN: local missing {local}'); continue\n")
    parts.push("        print(f'[scp] {local} -> {ip}:{remote}')\n")
    parts.push("        if dry_run: continue\n")
    parts.push("        r = subprocess.run(['scp', '-i', VAST_SSH_KEY, '-o', 'StrictHostKeyChecking=no',\n")
    parts.push("                             '-P', str(port), '-r', local, f'root@{ip}:{remote}'],\n")
    parts.push("                            capture_output=True, text=True, timeout=600)\n")
    parts.push("        if r.returncode != 0: raise RuntimeError(f'scp failed: {r.stderr}')\n\n")

    parts.push("def instance_scp_download(ip, port, mappings, dry_run=False):\n")
    parts.push("    for m in mappings:\n")
    parts.push("        if ':' not in m: continue\n")
    parts.push("        remote, local = m.split(':', 1)\n")
    parts.push("        os.makedirs(os.path.dirname(local) or '.', exist_ok=True)\n")
    parts.push("        print(f'[download] {ip}:{remote} -> {local}')\n")
    parts.push("        if dry_run: continue\n")
    parts.push("        r = subprocess.run(['scp', '-i', VAST_SSH_KEY, '-o', 'StrictHostKeyChecking=no',\n")
    parts.push("                             '-P', str(port), '-r', f'root@{ip}:{remote}', local],\n")
    parts.push("                            capture_output=True, text=True, timeout=600)\n")
    parts.push("        if r.returncode != 0: print(f'  WARN: download {r.stderr}')\n\n")

    parts.push("def instance_terminate(instance_id, dry_run=False):\n")
    parts.push("    print(f'[terminate] instance={instance_id}')\n")
    parts.push("    _emit_audit('terminate', {'instance_id': instance_id})\n")
    parts.push("    if dry_run: return {'destroyed': True, 'dry_run': True}\n")
    parts.push("    r = subprocess.run([VASTAI_CLI, 'destroy', 'instance', str(instance_id)],\n")
    parts.push("                        capture_output=True, text=True, timeout=60)\n")
    parts.push("    if r.returncode != 0: print(f'  WARN: terminate {r.stderr}')\n")
    parts.push("    try: return json.loads(r.stdout)\n")
    parts.push("    except: return {'returncode': r.returncode}\n\n")

    // Pattern 6c R1 download_pod
    parts.push("def cmd_dispatch_r1_download(args):\n")
    parts.push("    \"\"\"Pattern 6c R1: cheap GPU + 200GB persistent volume + huggingface-cli resume-download\"\"\"\n")
    parts.push("    t0 = time.time()\n")
    parts.push("    log = {'tool': 'tool/anima_vast_ai_orchestrator.hexa', 'cmd': 'dispatch-r1-download',\n")
    parts.push("           'pattern': '6c-r1', 'run_id': args.run_id,\n")
    parts.push("           'cost_center': args.cost_center, 'task_id': args.task_id,\n")
    parts.push("           'cost_estimate_usd': args.max_cost,\n")
    parts.push("           'started_at': datetime.datetime.now(datetime.timezone.utc).isoformat(),\n")
    parts.push("           'caps': {'max_cost': args.max_cost, 'max_runtime_min': args.max_runtime_min}}\n")
    parts.push("    info = instance_create(args)\n")
    parts.push("    log['instance_create'] = info\n")
    parts.push("    instance_id = info.get('new_contract') or info.get('id')\n")
    parts.push("    if args.dry_run:\n")
    parts.push("        log['dry_run'] = True\n")
    parts.push("    else:\n")
    parts.push("        ip, port = instance_ssh_wait(instance_id)\n")
    parts.push("        log['ssh'] = {'ip': ip, 'port': port}\n")
    parts.push("        # huggingface-cli resume-download\n")
    parts.push("        cmd = (f'pip install -q huggingface_hub && '\n")
    parts.push("               f'mkdir -p /workspace/models && cd /workspace/models && '\n")
    parts.push("               f'huggingface-cli download {args.hf_repo} --local-dir ./{args.hf_repo.replace(\"/\",\"_\")} --resume-download')\n")
    parts.push("        r = instance_ssh_exec(ip, port, cmd, args.dry_run, timeout=int(args.max_runtime_min*60))\n")
    parts.push("        log['hf_download'] = {'rc': r['returncode'], 'stdout_tail': r['stdout'][-2000:]}\n")
    parts.push("        if args.auto_terminate:\n")
    parts.push("            log['terminate'] = instance_terminate(instance_id, args.dry_run)\n")
    parts.push("    elapsed = (time.time() - t0) / 60.0\n")
    parts.push("    log['elapsed_min'] = elapsed\n")
    parts.push("    log['ended_at'] = datetime.datetime.now(datetime.timezone.utc).isoformat()\n")
    parts.push("    with open(args.output, 'w') as f: json.dump(log, f, indent=2)\n")
    parts.push("    print(f'\\n[done] R1 elapsed={elapsed:.2f}min')\n")
    parts.push("    print(f'wrote {args.output}')\n")
    parts.push("    print('DONE')\n\n")

    // Pattern 6c R2 measurement_pod
    parts.push("def cmd_dispatch_r2_measure(args):\n")
    parts.push("    \"\"\"Pattern 6c R2: H100 + attach R1 volume OR scp model + run hexa interpretation\"\"\"\n")
    parts.push("    t0 = time.time()\n")
    parts.push("    log = {'tool': 'tool/anima_vast_ai_orchestrator.hexa', 'cmd': 'dispatch-r2-measure',\n")
    parts.push("           'pattern': '6c-r2', 'run_id': args.run_id,\n")
    parts.push("           'cost_center': args.cost_center, 'task_id': args.task_id,\n")
    parts.push("           'cost_estimate_usd': args.max_cost,\n")
    parts.push("           'r1_instance_id': args.r1_instance_id,\n")
    parts.push("           'started_at': datetime.datetime.now(datetime.timezone.utc).isoformat(),\n")
    parts.push("           'caps': {'max_cost': args.max_cost, 'max_runtime_min': args.max_runtime_min}}\n")
    parts.push("    info = instance_create(args)\n")
    parts.push("    log['instance_create'] = info\n")
    parts.push("    instance_id = info.get('new_contract') or info.get('id')\n")
    parts.push("    if args.dry_run:\n")
    parts.push("        log['dry_run'] = True\n")
    parts.push("    else:\n")
    parts.push("        ip, port = instance_ssh_wait(instance_id)\n")
    parts.push("        log['ssh'] = {'ip': ip, 'port': port}\n")
    parts.push("        # Either R1 volume attached OR scp model from R1\n")
    parts.push("        if args.r1_instance_id and args.r1_model_path:\n")
    parts.push("            # scp from R1 to R2 (assumes R1 still alive)\n")
    parts.push("            r1_info = instance_status(args.r1_instance_id)\n")
    parts.push("            r1_ip = r1_info.get('ssh_host') or r1_info.get('public_ipaddr') if isinstance(r1_info, dict) else None\n")
    parts.push("            r1_port = r1_info.get('ssh_port') or r1_info.get('direct_port_start') if isinstance(r1_info, dict) else None\n")
    parts.push("            if r1_ip and r1_port:\n")
    parts.push("                relay = (f'mkdir -p /workspace/models && '\n")
    parts.push("                         f'scp -o StrictHostKeyChecking=no -P {r1_port} -r '\n")
    parts.push("                         f'root@{r1_ip}:{args.r1_model_path} /workspace/models/')\n")
    parts.push("                r = instance_ssh_exec(ip, port, relay, args.dry_run, timeout=1800)\n")
    parts.push("                log['model_relay'] = {'rc': r['returncode']}\n")
    parts.push("        # Upload hexa script if provided\n")
    parts.push("        if args.hexa_script:\n")
    parts.push("            instance_scp_upload(ip, port, [f'{args.hexa_script}:/workspace/measure.hexa'], args.dry_run)\n")
    parts.push("        # Run measurement\n")
    parts.push("        run_cmd = args.run_command or 'cd /workspace && python3 measure.py'\n")
    parts.push("        r = instance_ssh_exec(ip, port, run_cmd, args.dry_run, timeout=int(args.max_runtime_min*60))\n")
    parts.push("        log['measure'] = {'rc': r['returncode'], 'stdout_tail': r['stdout'][-2000:]}\n")
    parts.push("        # Download artifacts\n")
    parts.push("        if args.download:\n")
    parts.push("            instance_scp_download(ip, port, args.download, args.dry_run)\n")
    parts.push("        if args.auto_terminate:\n")
    parts.push("            log['terminate'] = instance_terminate(instance_id, args.dry_run)\n")
    parts.push("    elapsed = (time.time() - t0) / 60.0\n")
    parts.push("    log['elapsed_min'] = elapsed\n")
    parts.push("    log['ended_at'] = datetime.datetime.now(datetime.timezone.utc).isoformat()\n")
    parts.push("    with open(args.output, 'w') as f: json.dump(log, f, indent=2)\n")
    parts.push("    print(f'\\n[done] R2 elapsed={elapsed:.2f}min')\n")
    parts.push("    print(f'wrote {args.output}')\n")
    parts.push("    print('DONE')\n\n")

    // Lifecycle subcommands
    parts.push("def cmd_create_instance(args):\n")
    parts.push("    info = instance_create(args)\n")
    parts.push("    if args.output:\n")
    parts.push("        with open(args.output, 'w') as f: json.dump(info, f, indent=2)\n")
    parts.push("    print('DONE')\n\n")

    parts.push("def cmd_list_instances(args):\n")
    parts.push("    info = instance_list()\n")
    parts.push("    print(json.dumps(info, indent=2) if isinstance(info, (dict, list)) else info)\n")
    parts.push("    print('DONE')\n\n")

    parts.push("def cmd_status(args):\n")
    parts.push("    info = instance_status(args.instance_id)\n")
    parts.push("    print(json.dumps(info, indent=2) if isinstance(info, (dict, list)) else info)\n")
    parts.push("    print('DONE')\n\n")

    parts.push("def cmd_terminate(args):\n")
    parts.push("    info = instance_terminate(args.instance_id, args.dry_run)\n")
    parts.push("    print(json.dumps(info, indent=2) if isinstance(info, dict) else str(info))\n")
    parts.push("    print('DONE')\n\n")

    // Selftest with graceful degradation
    parts.push("def cmd_selftest():\n")
    parts.push("    print('selftest=ok')\n")
    parts.push("    print(f'vastai_cli_path={VASTAI_CLI}')\n")
    parts.push("    cli_present = os.path.exists(VASTAI_CLI)\n")
    parts.push("    print(f'vastai_cli_installed={str(cli_present).lower()}')\n")
    parts.push("    if cli_present:\n")
    parts.push("        try:\n")
    parts.push("            r = subprocess.run([VASTAI_CLI, '--version'], capture_output=True, text=True, timeout=10)\n")
    parts.push("            print(f'vastai_cli_version={r.stdout.strip() or r.stderr.strip()}')\n")
    parts.push("        except Exception as e:\n")
    parts.push("            print(f'vastai_cli_version=ERROR_{type(e).__name__}')\n")
    parts.push("    else:\n")
    parts.push("        print('vastai_cli_version=NOT_INSTALLED')\n")
    parts.push("        print('# Graceful: scaffold ready, install vastai via: pip install --user vastai')\n")
    parts.push("    print(f'ssh_key_present={str(os.path.exists(VAST_SSH_KEY)).lower()}')\n")
    parts.push("    print(f'ssh_key_path={VAST_SSH_KEY}')\n")
    parts.push("    print(f'audit_dir={AUDIT_DIR}')\n")
    parts.push("    print('subcommands=selftest,create-instance,list-instances,status,terminate,dispatch-r1-download,dispatch-r2-measure')\n")
    parts.push("    print('pattern_6c_r1_template=wired')\n")
    parts.push("    print('pattern_6c_r2_template=wired')\n")
    parts.push("    print('cost_attribution_raw86=wired')\n")
    parts.push("    print('honest_disclosure_raw91=pricing_extrapolated_not_invoiced')\n")
    parts.push("    print('DONE')\n\n")

    parts.push("def main():\n")
    parts.push("    p = argparse.ArgumentParser()\n")
    parts.push("    sub = p.add_subparsers(dest='cmd', required=True)\n")
    parts.push("    sub.add_parser('selftest')\n")

    // create-instance subparser
    parts.push("    c = sub.add_parser('create-instance')\n")
    parts.push("    c.add_argument('--instance-name', dest='instance_name', required=True)\n")
    parts.push("    c.add_argument('--gpu-name', dest='gpu_name', default='RTX_3090')\n")
    parts.push("    c.add_argument('--image', default='pytorch/pytorch:2.4.0-cuda12.4-cudnn9-devel')\n")
    parts.push("    c.add_argument('--disk-gb', dest='disk_gb', type=int, default=100)\n")
    parts.push("    c.add_argument('--max-cost', dest='max_cost', type=float, default=30.0)\n")
    parts.push("    c.add_argument('--max-runtime-min', dest='max_runtime_min', type=int, default=120)\n")
    parts.push("    c.add_argument('--cost-center', dest='cost_center', default='unspecified')\n")
    parts.push("    c.add_argument('--task-id', dest='task_id', default='unspecified')\n")
    parts.push("    c.add_argument('--run-id', dest='run_id', default='unnamed')\n")
    parts.push("    c.add_argument('--dry-run', dest='dry_run', action='store_true')\n")
    parts.push("    c.add_argument('--output', default='')\n")

    // list-instances subparser
    parts.push("    sub.add_parser('list-instances')\n")

    // status subparser
    parts.push("    s = sub.add_parser('status')\n")
    parts.push("    s.add_argument('--instance-id', dest='instance_id', required=True)\n")

    // terminate subparser
    parts.push("    t = sub.add_parser('terminate')\n")
    parts.push("    t.add_argument('--instance-id', dest='instance_id', required=True)\n")
    parts.push("    t.add_argument('--dry-run', dest='dry_run', action='store_true')\n")

    // dispatch-r1-download subparser
    parts.push("    r1 = sub.add_parser('dispatch-r1-download')\n")
    parts.push("    r1.add_argument('--instance-name', dest='instance_name', required=True)\n")
    parts.push("    r1.add_argument('--gpu-name', dest='gpu_name', default='RTX_3090')\n")
    parts.push("    r1.add_argument('--image', default='pytorch/pytorch:2.4.0-cuda12.4-cudnn9-devel')\n")
    parts.push("    r1.add_argument('--disk-gb', dest='disk_gb', type=int, default=200)\n")
    parts.push("    r1.add_argument('--hf-repo', dest='hf_repo', required=True)\n")
    parts.push("    r1.add_argument('--max-cost', dest='max_cost', type=float, default=5.0)\n")
    parts.push("    r1.add_argument('--max-runtime-min', dest='max_runtime_min', type=int, default=60)\n")
    parts.push("    r1.add_argument('--cost-center', dest='cost_center', default='unspecified')\n")
    parts.push("    r1.add_argument('--task-id', dest='task_id', default='unspecified')\n")
    parts.push("    r1.add_argument('--run-id', dest='run_id', default='unnamed')\n")
    parts.push("    r1.add_argument('--auto-terminate', dest='auto_terminate', action='store_true', default=True)\n")
    parts.push("    r1.add_argument('--dry-run', dest='dry_run', action='store_true')\n")
    parts.push("    r1.add_argument('--output', required=True)\n")

    // dispatch-r2-measure subparser
    parts.push("    r2 = sub.add_parser('dispatch-r2-measure')\n")
    parts.push("    r2.add_argument('--instance-name', dest='instance_name', required=True)\n")
    parts.push("    r2.add_argument('--gpu-name', dest='gpu_name', default='H100_SXM')\n")
    parts.push("    r2.add_argument('--image', default='pytorch/pytorch:2.4.0-cuda12.4-cudnn9-devel')\n")
    parts.push("    r2.add_argument('--disk-gb', dest='disk_gb', type=int, default=200)\n")
    parts.push("    r2.add_argument('--r1-instance-id', dest='r1_instance_id', default='')\n")
    parts.push("    r2.add_argument('--r1-model-path', dest='r1_model_path', default='/workspace/models')\n")
    parts.push("    r2.add_argument('--hexa-script', dest='hexa_script', default='')\n")
    parts.push("    r2.add_argument('--run-command', dest='run_command', default='')\n")
    parts.push("    r2.add_argument('--download', action='append', default=[], help='remote:local, repeatable')\n")
    parts.push("    r2.add_argument('--max-cost', dest='max_cost', type=float, default=30.0)\n")
    parts.push("    r2.add_argument('--max-runtime-min', dest='max_runtime_min', type=int, default=120)\n")
    parts.push("    r2.add_argument('--cost-center', dest='cost_center', default='unspecified')\n")
    parts.push("    r2.add_argument('--task-id', dest='task_id', default='unspecified')\n")
    parts.push("    r2.add_argument('--run-id', dest='run_id', default='unnamed')\n")
    parts.push("    r2.add_argument('--auto-terminate', dest='auto_terminate', action='store_true', default=True)\n")
    parts.push("    r2.add_argument('--dry-run', dest='dry_run', action='store_true')\n")
    parts.push("    r2.add_argument('--output', required=True)\n")

    parts.push("    args = p.parse_args()\n")
    parts.push("    if args.cmd == 'selftest': cmd_selftest()\n")
    parts.push("    elif args.cmd == 'create-instance': cmd_create_instance(args)\n")
    parts.push("    elif args.cmd == 'list-instances': cmd_list_instances(args)\n")
    parts.push("    elif args.cmd == 'status': cmd_status(args)\n")
    parts.push("    elif args.cmd == 'terminate': cmd_terminate(args)\n")
    parts.push("    elif args.cmd == 'dispatch-r1-download': cmd_dispatch_r1_download(args)\n")
    parts.push("    elif args.cmd == 'dispatch-r2-measure': cmd_dispatch_r2_measure(args)\n")
    parts.push("    else: sys.exit(2)\n\n")
    parts.push("if __name__ == '__main__': main()\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── anima_vast_ai_orchestrator selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("marker missing"); exit(1) }
        println("selftest: OK (graceful — scaffold ready regardless of vastai CLI install state)")
        exit(0)
    }

    if len(av) < 3 {
        eprintln("usage: hexa run tool/anima_vast_ai_orchestrator.hexa <subcommand> [...]")
        eprintln("subcommands:")
        eprintln("  selftest                    — graceful (PASS even without vastai CLI)")
        eprintln("  create-instance             — create vast.ai instance")
        eprintln("  list-instances              — list active instances")
        eprintln("  status                      — instance status (--instance-id)")
        eprintln("  terminate                   — destroy instance (--instance-id)")
        eprintln("  dispatch-r1-download        — Pattern 6c R1 (cheap GPU + HF download)")
        eprintln("  dispatch-r2-measure         — Pattern 6c R2 (H100 + measure)")
        eprintln("see header comment for examples + raw 86 cost-attribution flags")
        exit(2)
    }

    // Pass through to helper
    let mut a = ""
    let mut j = 2
    while j < len(av) {
        a = a + " " + _sh_quote(av[j])
        j = j + 1
    }
    let r = _run_helper(a.trim())
    println(r[0])
    exit(r[1])
}

main()
