// tool/anima_pod_termination_path_c_landing.hexa — cycle 65 path C landing (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   사용자가 cycle 63 권장 path C ("Pod 1 즉시 stop / Pod 2 web UI inspect") 승인
//   ("C 권장 go", 2026-04-27). Pod 1 stop 실행 후 Pod 2 추가 inspect에서 stuck
//   evidence 발견. cycle 65 = 결과 landing + Pod 2 stuck evidence 기록.
//
// PATH C 실행 결과
//   Pod 1 (bnabak3i4r38bg = anima-sae-steer-pilot):
//     - cmd     : runpodctl stop pod bnabak3i4r38bg  (deprecated form, succeeded)
//     - result  : "pod \"bnabak3i4r38bg\" stopped"
//     - savings : $2.99/hr 즉시 정지
//
//   Pod 2 (1an0fdtr2mrif1 = anima-gwt-deepseek-c2-long):
//     - inspect : runpodctl pod get 1an0fdtr2mrif1
//     - finding : desiredStatus=RUNNING / uptimeSeconds=0 / ssh.error="pod not ready"
//                  / createdAt=2026-04-26 03:44:40 UTC (22.5시간 경과)
//                  / RUNTIME_CAP_MIN=12 (cap 1875% escape) / COST_CAP=1.0 ($1 cap, ~$66 estimated burn 22h)
//     - 해석    : host 못 잡고 reschedule 반복, billing 발생 + active runtime 0초.
//                 사실상 stuck. work-in-progress 가능성 매우 낮음.
//     - status  : 사용자 결정 영역 (path C 정의대로 user web UI inspect 후 결정)
//
// BURN RATE 변화
//   Pre  : $5.98/hr (2 pods × $2.99)
//   Post : $2.99/hr (Pod 1 stopped) — 절반 절감
//   Pod 2 stop 시 : $0/hr
//
// NON_MUTATION
//   이 helper는 stop을 실행하지 않음. 위 결과는 helper 외부에서 사용자 승인 후
//   직접 실행됨 (`runpodctl pod stop`). 이 helper는 결과를 state JSON으로 기록.
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - cycle 1-62 capstone 5-step playbook 중 step 4는 cycle 63 발견대로 비기능.
//     실제 termination은 직접 `runpodctl pod stop` 으로 우회 (path A 형태). path
//     C는 "A를 Pod 1만 적용 + Pod 2 user inspect" 의 의미였음을 명확히 함.

let HELPER_PATH = "/tmp/anima_pod_termination_path_c_landing_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima path C termination landing — emitted by tool/anima_pod_termination_path_c_landing.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/pod_termination_path_c_landing.json')\n\n")

    parts.push("pod_1_action = {\n")
    parts.push("    'pod_id':'bnabak3i4r38bg',\n")
    parts.push("    'name':'anima-sae-steer-pilot',\n")
    parts.push("    'cmd':'runpodctl stop pod bnabak3i4r38bg',\n")
    parts.push("    'cmd_canonical':'runpodctl pod stop bnabak3i4r38bg (cmd is deprecated form)',\n")
    parts.push("    'result':'STOPPED',\n")
    parts.push("    'cycle_56_idle_basis':'IDLE confirmed via ssh nvidia-smi (gpu 0%)',\n")
    parts.push("    'savings_usd_per_hr':2.99,\n")
    parts.push("    'user_approval':'C 권장 go (2026-04-27 KST)',\n")
    parts.push("}\n\n")

    parts.push("pod_2_inspect = {\n")
    parts.push("    'pod_id':'1an0fdtr2mrif1',\n")
    parts.push("    'name':'anima-gwt-deepseek-c2-long',\n")
    parts.push("    'desired_status':'RUNNING',\n")
    parts.push("    'uptime_seconds':0,\n")
    parts.push("    'ssh_error':'pod not ready',\n")
    parts.push("    'created_at_utc':'2026-04-26 03:44:40',\n")
    parts.push("    'hours_since_created':22.5,\n")
    parts.push("    'runtime_cap_min':12,\n")
    parts.push("    'runtime_cap_escape_ratio':112.5,\n")
    parts.push("    'cost_cap_usd':1.0,\n")
    parts.push("    'estimated_billed_usd':66.0,\n")
    parts.push("    'estimated_billed_basis':'22.5h * 2.99/hr (no uptime evidence but billing accrued)',\n")
    parts.push("    'interpretation':'STUCK — host 못 잡고 reschedule 반복; active runtime 0초이나 billing 발생',\n")
    parts.push("    'work_in_progress_likelihood':'매우 낮음 (uptime=0 22.5h)',\n")
    parts.push("    'recommended_user_action':'사용자 web UI 확인 후 stop 결정 (https://www.runpod.io/console/pods)',\n")
    parts.push("    'second_recommendation':'stuck evidence 기준 stop 권장 — but path C 정의 따라 user 결정 영역',\n")
    parts.push("}\n\n")

    parts.push("burn_delta = {\n")
    parts.push("    'pre_usd_per_hr':5.98,\n")
    parts.push("    'post_pod1_stop_usd_per_hr':2.99,\n")
    parts.push("    'post_pod2_stop_usd_per_hr':0.0,\n")
    parts.push("    'reduction_now_pct':50,\n")
    parts.push("    'days_until_zero_balance_pre':2.4,\n")
    parts.push("    'days_until_zero_balance_post_pod1':4.8,\n")
    parts.push("    'days_until_zero_balance_post_both':'infinity (no burn)',\n")
    parts.push("}\n\n")

    parts.push("playbook_amendment = {\n")
    parts.push("    'cycle_59_capstone_step_4_status':'BYPASSED (helper bug per cycle 63; direct runpodctl pod stop used)',\n")
    parts.push("    'cycle_59_step_5_cron':'NOT_APPLIED (would propagate cycle 63 helper bug)',\n")
    parts.push("    'remaining_user_decisions':[\n")
    parts.push("        'Pod 2 stop (stuck evidence ground)',\n")
    parts.push("        'Path B helper patch (probe-exec gap fix; raw#9 strict)',\n")
    parts.push("        'cron prevention 재논의 — path B 완료 전제',\n")
    parts.push("    ],\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm': 'cycle 65 — path C termination landing + Pod 2 stuck evidence',\n")
    parts.push("    'cycle': 65,\n")
    parts.push("    'pod_1_action': pod_1_action,\n")
    parts.push("    'pod_2_inspect': pod_2_inspect,\n")
    parts.push("    'burn_delta': burn_delta,\n")
    parts.push("    'playbook_amendment': playbook_amendment,\n")
    parts.push("    'non_mutation_guarantee': 'helper records outcomes only; pod stop executed externally with explicit user approval',\n")
    parts.push("    'cross_link_cycles': ['cycle 56 ssh activity (Pod 1 IDLE)', 'cycle 59 capstone (5-step playbook)', 'cycle 63 probe-exec gap', 'cycle 64 memory freshness'],\n")
    parts.push("    'pattern': 'governance audit chain layer 44 (RunPod incident chain closure event 1: Pod 1 stopped)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[path_c_landing] cycle=65 pod_1=STOPPED pod_2=STUCK_USER_DECISION burn=$5.98->$2.99/hr -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_LANDING")
    println("inv:cycle=65")
    println("inv:pod_1_action=STOPPED")
    println("inv:pod_2_action=USER_DECISION_RECOMMENDED")
    println("inv:burn_reduction=50pct_now")
    println("inv:cross_link_cycles=56,59,63,64")
    return true
}

fn cmd_selftest() {
    println("── anima_pod_termination_path_c_landing selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 65 — path C termination landing; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
