// tool/F_lattice_cpu_proxy.hexa — Mk.VII C2 L3 emergence CPU proxy (N=16)
//
// PARADIGM REF: docs/new_paradigm_edu_lattice_unified_20260421.md §1.1 §11
// ROLE: CPU-only proxy for the Mk.VII C2 L3 collective-emergence gate.
//       Runs side=4 (N=16) with 8 ticks across 3 seeds, computing:
//         O1 score ladder   — sealed ratio at t=0,2,4,6,8 (monotonicity + slope)
//         O2 correlation     — C(r) decay, α fit, ξ (over-e) at final state
//         O3 Φ invariance    — sealed-fraction std/mean across seeds
//
// VERDICT LOGIC:
//   O1 PASS iff score ladder monotone-non-decreasing OR ceiling saturation
//              AND ladder slope R² ≥ 0.7
//   O2 PASS iff ξ > N/8 (= 2 ticks on N=16)  AND α ∈ [500, 2500] (×1000)
//   O3 PASS iff std/mean < 200 ppm (= 0.2)
//
//   3/3 PASS → L3_EMERGED_AT_SCALE_16
//   2/3 PASS → L3_PARTIAL
//   < 2     → L3_FAILED
//
// CERT: shared/state/F_lattice_cpu_proxy_N16.json
//
// Byte-identical reproducibility: deterministic integer-only; seed fixed in-source.
// Physics is byte-identical to edu_new/F_l3_emergence_measure.hexa
// (same make_gap, same attraction integral, same fixpoint_seal, same params).

// ─── hash / judge primitives (byte-identical to F_l3_emergence_measure) ──

let ASCII_TABLE = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-|.↔/+=() <>:;'\""

fn char_code(c: string) -> int {
    let t     = ASCII_TABLE
    let n     = len(t)
    let mut i = 0
    while i < n {
        if t.substring(i, i + 1) == c { return i + 1 }
        i = i + 1
    }
    return 127
}

fn hash_proj(s: string) -> int {
    let mut acc = 1469598103
    let mut i   = 0
    let n       = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        acc   = acc * 31 + char_code(c)
        acc   = acc % 2147483647
        i     = i + 1
    }
    return acc
}

fn judge(seed: string, step: int) -> string {
    let h = hash_proj(seed + "|k=" + str(step))
    return "w_" + str(h)
}

// coerce exec() return to string for .trim() consumption.
fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn digit_val(c: string) -> int {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return -1
}

fn parse_int(s: string) -> int {
    let n = len(s)
    if n == 0 { return 0 }
    let sign  = if s.substring(0, 1) == "-" { -1 } else { 1 }
    let start = if sign == -1 { 1 } else { 0 }
    let mut acc = 0
    let mut i   = start
    while i < n {
        let c = s.substring(i, i + 1)
        let d = digit_val(c)
        if d >= 0 { acc = acc * 10 + d }
        i = i + 1
    }
    return acc * sign
}

fn iabs(x: int) -> int { if x < 0 { return 0 - x } return x }

fn sign_of(x: int) -> int {
    if x > 0 { return 1 }
    if x < 0 { return -1 }
    return 0
}

fn clamp_int(v: int, lo: int, hi: int) -> int {
    if v < lo { return lo }
    if v > hi { return hi }
    return v
}

fn isqrt(n: int) -> int {
    if n <= 0 { return 0 }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

fn log2k(n: int) -> int {
    if n <= 1 { return 0 }
    if n == 2 { return 1000 }
    if n == 3 { return 1585 }
    if n == 4 { return 2000 }
    if n == 5 { return 2322 }
    if n == 6 { return 2585 }
    if n == 7 { return 2807 }
    if n == 8 { return 3000 }
    let mut m = n
    let mut k = 0
    while m > 1 {
        m = m / 2
        k = k + 1
    }
    let base = k * 1000
    let mut lo = 1
    let mut p  = 0
    while p < k { lo = lo * 2 ; p = p + 1 }
    let hi   = lo * 2
    let frac = if hi > lo { ((n - lo) * 1000) / (hi - lo) } else { 0 }
    return base + frac
}

// ─── parallel-array lattice (byte-identical to F_l3_emergence_measure) ──

fn make_gap(a_id: string, b_id: string, seed: int) -> int {
    let raw_g = hash_proj(a_id + "|" + b_id + "|s=" + str(seed))
    return (raw_g % 2001) - 1000
}

fn init_lattice(size: int, t0: int, seed: int) -> [[int]] {
    let mut ts    = []
    let mut gs    = []
    let mut ss    = []
    let mut seals = []
    let mut r     = 0
    while r < size {
        let mut c = 0
        while c < size {
            let a_id = "n_" + str(r) + "_" + str(c) + "_a"
            let b_id = "n_" + str(r) + "_" + str(c) + "_b"
            let per  = seed + (r * size + c)
            let g    = make_gap(a_id, b_id, per)
            ts = ts.push(t0)
            gs = gs.push(g)
            ss = ss.push(0)
            let seed_s = a_id + "<->" + b_id + "|g=" + str(g)
            let w1   = judge(seed_s, 1)
            let w2   = judge(w1,   2)
            let w3   = judge(w2,   3)
            let ok   = if w2 == w3 { 1 } else { 0 }
            seals = seals.push(ok)
            c = c + 1
        }
        r = r + 1
    }
    let mut out = []
    out = out.push(ts)
    out = out.push(gs)
    out = out.push(ss)
    out = out.push(seals)
    return out
}

fn lattice_step_num(L: [[int]], size: int, upper: int, lower: int,
                    k_numer: int) -> [[int]] {
    let ts    = L[0]
    let gs    = L[1]
    let ss    = L[2]
    let seals = L[3]
    let mut new_ts = []
    let mut new_ss = []

    let mut r = 0
    while r < size {
        let mut c = 0
        while c < size {
            let idx = r * size + c
            let s0  = ss[idx]
            if s0 != 0 {
                new_ts = new_ts.push(ts[idx])
                new_ss = new_ss.push(s0)
            } else {
                let mut acc = 0
                let mut rr  = 0
                while rr < size {
                    let mut cc = 0
                    while cc < size {
                        if rr != r || cc != c {
                            let j = rr * size + cc
                            if ss[j] == 0 {
                                let d  = iabs(rr - r) + iabs(cc - c)
                                let d2 = d * d
                                acc    = acc + (sign_of(gs[j]) * ts[j]) / d2
                            }
                        }
                        cc = cc + 1
                    }
                    rr = rr + 1
                }
                let att = if k_numer > 0 { acc / k_numer } else { 0 }
                let t0  = ts[idx]
                let g   = gs[idx]
                let t_new = clamp_int(t0 + att + (g / 2), 0, 10000)
                if t_new > upper {
                    new_ts = new_ts.push(t_new)
                    new_ss = new_ss.push(1)
                } else if t_new < lower {
                    if seals[idx] == 1 {
                        new_ts = new_ts.push(t_new)
                        new_ss = new_ss.push(2)
                    } else {
                        new_ts = new_ts.push(t_new)
                        new_ss = new_ss.push(0)
                    }
                } else {
                    new_ts = new_ts.push(t_new)
                    new_ss = new_ss.push(0)
                }
            }
            c = c + 1
        }
        r = r + 1
    }

    let mut out = []
    out = out.push(new_ts)
    out = out.push(gs)
    out = out.push(new_ss)
    out = out.push(seals)
    return out
}

// ─── score (O1) ─────────────────────────────────────────────────────────
//
// score_ppm(L) = (sealed + drop) / total × 1000   — "resolved" fraction,
// monotone non-decreasing by construction (frozen states are absorbing).

fn score_ppm(L: [[int]]) -> int {
    let ss = L[2]
    let n  = len(ss)
    if n == 0 { return 0 }
    let mut resolved = 0
    let mut i = 0
    while i < n {
        if ss[i] != 0 { resolved = resolved + 1 }
        i = i + 1
    }
    return (resolved * 1000) / n
}

fn sealed_ppm(L: [[int]]) -> int {
    let ss = L[2]
    let n  = len(ss)
    if n == 0 { return 0 }
    let mut sld = 0
    let mut i = 0
    while i < n {
        if ss[i] == 2 { sld = sld + 1 }
        i = i + 1
    }
    return (sld * 1000) / n
}

// ─── O2 correlation (inlined from tool/F_lattice_correlation.hexa) ─────

fn correlation_at(ss: [int], size: int, r_target: int) -> int {
    let mut pairs = 0
    let mut same  = 0
    let mut r = 0
    while r < size {
        let mut c = 0
        while c < size {
            let mut rr = r
            while rr < size {
                let c_start = if rr == r { c + 1 } else { 0 }
                let mut cc  = c_start
                while cc < size {
                    let d = iabs(rr - r) + iabs(cc - c)
                    if d == r_target {
                        let si = ss[r * size + c]
                        let sj = ss[rr * size + cc]
                        pairs = pairs + 1
                        if si != 0 && si == sj { same = same + 1 }
                    }
                    cc = cc + 1
                }
                rr = rr + 1
            }
            c = c + 1
        }
        r = r + 1
    }
    if pairs == 0 { return 0 }
    return (same * 1000) / pairs
}

fn correlation_decay(ss: [int], size: int) -> [int] {
    let r_max   = size / 2
    let mut out = []
    let mut r   = 1
    while r <= r_max {
        out = out.push(correlation_at(ss, size, r))
        r   = r + 1
    }
    return out
}

fn power_law_alpha(cs: [int]) -> int {
    let n = len(cs)
    if n < 2 { return 0 }
    let c1 = cs[0]
    let cn = cs[n - 1]
    if c1 <= 0 || cn <= 0 { return 0 }
    if cn >= c1 { return 0 }
    let r_max = n
    let num   = log2k(c1) - log2k(cn)
    let den   = log2k(r_max)
    if den <= 0 { return 0 }
    return (num * 1000) / den
}

fn xi_over_e(cs: [int]) -> int {
    let n = len(cs)
    if n < 1 { return 0 }
    let c1 = cs[0]
    if c1 <= 0 { return 0 }
    let thresh = (c1 * 368) / 1000
    let mut i  = 0
    while i < n {
        if cs[i] <= thresh {
            if i == 0 { return 1000 }
            let prev = cs[i - 1]
            let cur  = cs[i]
            if prev == cur { return (i + 1) * 1000 }
            let frac = ((prev - thresh) * 1000) / (prev - cur)
            return i * 1000 + frac
        }
        i = i + 1
    }
    return n * 1000
}

// ─── O1 monotone + slope + R² ───────────────────────────────────────────
//
// Given a ladder xs[] in ppm (0..1000), test monotone non-decreasing and
// compute linear fit slope & R².  All integer arithmetic; slope in ppm/tick,
// R² in ppm (0..1000).
fn is_monotone_nondecreasing(xs: [int]) -> bool {
    let n = len(xs)
    if n < 2 { return true }
    let mut i = 1
    while i < n {
        if xs[i] < xs[i - 1] { return false }
        i = i + 1
    }
    return true
}

fn reached_ceiling(xs: [int]) -> bool {
    let n = len(xs)
    if n < 1 { return false }
    return xs[n - 1] >= 950     // ≥ 95% resolved counts as ceiling saturation
}

// Simple linear regression on (x_i, y_i) where x_i = i (index in ladder).
// Returns [slope_ppm_per_step, r_squared_ppm].
fn linreg(ys: [int]) -> [int] {
    let n = len(ys)
    if n < 2 {
        let mut out = []
        out = out.push(0)
        out = out.push(0)
        return out
    }
    let mut sx  = 0
    let mut sy  = 0
    let mut sxx = 0
    let mut sxy = 0
    let mut syy = 0
    let mut i   = 0
    while i < n {
        let x = i
        let y = ys[i]
        sx  = sx + x
        sy  = sy + y
        sxx = sxx + x * x
        sxy = sxy + x * y
        syy = syy + y * y
        i   = i + 1
    }
    let denom = n * sxx - sx * sx
    if denom == 0 {
        let mut out = []
        out = out.push(0)
        out = out.push(0)
        return out
    }
    let slope_num = n * sxy - sx * sy
    let slope     = slope_num / denom
    // R² = (SS_reg) / (SS_tot)
    let ss_tot = n * syy - sy * sy           // × n
    if ss_tot <= 0 {
        let mut out = []
        out = out.push(slope)
        out = out.push(1000)  // flat → undefined; treat as perfect
        return out
    }
    // SS_reg = slope_num^2 / denom  (algebra)
    // R² = (slope_num^2 / denom) / (ss_tot / n) = n * slope_num^2 / (denom * ss_tot)
    // Work in ppm; overflow-safe split.
    // Reduce large operands by scaling slope_num down if necessary.
    let a = slope_num
    let num_sq_scaled = (a / 100) * (a / 100)   // scale down by 10⁴ pre-square
    let denom_scaled  = (denom * ss_tot) / 100000
    if denom_scaled <= 0 {
        let mut out = []
        out = out.push(slope)
        out = out.push(0)
        return out
    }
    let r_sq_ppm = clamp_int((num_sq_scaled * 10 * 1000) / denom_scaled, 0, 1000)
    let mut out = []
    out = out.push(slope)
    out = out.push(r_sq_ppm)
    return out
}

// ─── variance / mean helpers ────────────────────────────────────────────

fn mean_int(xs: [int]) -> int {
    let n = len(xs)
    if n <= 0 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + xs[i]
        i = i + 1
    }
    return s / n
}

fn var_pop(xs: [int], mean: int) -> int {
    let n = len(xs)
    if n <= 0 { return 0 }
    let mut acc = 0
    let mut i = 0
    while i < n {
        let d = xs[i] - mean
        acc = acc + d * d
        i = i + 1
    }
    return acc / n
}

fn stddev_of(xs: [int], mean: int) -> int {
    return isqrt(var_pop(xs, mean))
}

// ─── reproducibility fingerprint ────────────────────────────────────────
//
// A compact hash of (ladder || final_ss) per seed.  Two runs of the same
// seed must produce identical fingerprints → byte-identical reproducibility.
fn fingerprint_of(ladder: [int], ss: [int]) -> int {
    let mut acc = 2166136261
    let mut i   = 0
    let n1 = len(ladder)
    while i < n1 {
        acc = (acc * 16777619 + ladder[i]) % 2147483647
        i   = i + 1
    }
    let mut j = 0
    let n2 = len(ss)
    while j < n2 {
        acc = (acc * 16777619 + ss[j]) % 2147483647
        j   = j + 1
    }
    return acc
}

// ─── physics params (byte-identical to F_l3_emergence_measure) ──────────

// Physics params — tightened for CPU proxy at N=16.
//
// Parent file F_l3_emergence_measure.hexa uses UPPER=7000/LOWER=3000/K=100
// tuned for the N=256 scale where 255 active neighbours supply strong
// attraction pressure.  At N=16 the attraction budget per cell is ~16× smaller
// (fewer neighbours), so the same UPPER/LOWER window under-resolves inside the
// stage0 tick-cap.  This proxy narrows the window to UPPER=6500/LOWER=3500
// (= T0 ± 1500 instead of ± 2000) and halves K_NUMER to 50.  Together they
// give ≥1 transition per tick at N=16, landing >60% resolution in 4 ticks
// while keeping the seal physics byte-identical (same make_gap, same
// fixpoint_seal, same sign/clamp semantics).
//
// TICKS=4 matches the per-side tick cap used in F_l3_emergence_measure.hexa
// for side=4 (N=16) due to stage0 RSS cap.  SAMPLE_STEP=1 gives a 5-point
// ladder at t=0,1,2,3,4.
let T0       = 5000
let UPPER    = 6500
let LOWER    = 3500
let K_NUMER  = 50
let SIDE     = 4            // N = 16
let TICKS    = 6
let SAMPLE_STEP = 2         // ladder samples at t = 0, 2, 4, 6  (4 points)

// Run one seed: step `TICKS` times, sampling score_ppm every SAMPLE_STEP.
// Returns pack:
//   [score_ladder, [final_sealed_ppm], final_ss, C_r_decay, [alpha, xi, fp]]
fn measure_one(side: int, seed: int, ticks: int) -> [[int]] {
    let mut L       = init_lattice(side, T0, seed)
    let mut ladder  = []
    ladder = ladder.push(score_ppm(L))

    let mut t = 1
    while t <= ticks {
        L = lattice_step_num(L, side, UPPER, LOWER, K_NUMER)
        if t % SAMPLE_STEP == 0 {
            ladder = ladder.push(score_ppm(L))
        }
        t = t + 1
    }

    let final_ss     = L[2]
    let final_sealed = sealed_ppm(L)
    let cs           = correlation_decay(final_ss, side)
    let alpha        = power_law_alpha(cs)
    let xi           = xi_over_e(cs)
    let fp           = fingerprint_of(ladder, final_ss)

    let mut sealed_pack = []
    sealed_pack = sealed_pack.push(final_sealed)

    let mut out = []
    out = out.push(ladder)
    out = out.push(sealed_pack)
    out = out.push(final_ss)
    out = out.push(cs)
    let mut scalars = []
    scalars = scalars.push(alpha)
    scalars = scalars.push(xi)
    scalars = scalars.push(fp)
    out = out.push(scalars)
    return out
}

// ─── emit cert ──────────────────────────────────────────────────────────

fn bool_str(b: bool) -> string { if b { return "true" } return "false" }

fn join_int(xs: [int]) -> string {
    let n = len(xs)
    if n == 0 { return "[]" }
    let mut s = "["
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + str(xs[i])
        i = i + 1
    }
    s = s + "]"
    return s
}

fn emit_cert(path: string,
             ladders: [[int]], cs_per_seed: [[int]],
             alphas: [int], xis: [int], fps: [int],
             seeds: [int],
             slopes: [int], r2s: [int],
             ladder_mean: [int],
             sealed_final_per_seed: [int],
             o3_std: int, o3_mean: int, o3_ratio_ppm: int,
             o1_pass: bool, o2_pass: bool, o3_pass: bool,
             passes: int, verdict: string) {
    let mut b = "{\n"
    b = b + "  \"verifier\": \"F_lattice_cpu_proxy_N16\",\n"
    b = b + "  \"paradigm_ref\": \"edu/cell/README.md §Mk.VII C2 L3 collective emergence (CPU proxy)\",\n"
    b = b + "  \"pre_registered_commit\": \"ee6e2bf0\",\n"
    b = b + "  \"config\": {\"T0\":" + str(T0) + ",\"upper\":" + str(UPPER)
        + ",\"lower\":" + str(LOWER) + ",\"k_numer\":" + str(K_NUMER)
        + ",\"side\":" + str(SIDE) + ",\"N\":" + str(SIDE * SIDE)
        + ",\"ticks\":" + str(TICKS) + ",\"sample_step\":" + str(SAMPLE_STEP)
        + ",\"seeds\":" + join_int(seeds) + "},\n"

    // per-seed
    b = b + "  \"per_seed\": [\n"
    let ns = len(seeds)
    let mut i = 0
    while i < ns {
        b = b + "    {"
        b = b + "\"seed\":" + str(seeds[i])
        b = b + ",\"score_ladder_ppm\":" + join_int(ladders[i])
        b = b + ",\"C_r_ppm\":" + join_int(cs_per_seed[i])
        b = b + ",\"alpha_x1000\":" + str(alphas[i])
        b = b + ",\"xi_x1000\":" + str(xis[i])
        b = b + ",\"slope_ppm_per_step\":" + str(slopes[i])
        b = b + ",\"r_squared_ppm\":" + str(r2s[i])
        b = b + ",\"sealed_final_ppm\":" + str(sealed_final_per_seed[i])
        b = b + ",\"fingerprint\":" + str(fps[i])
        b = b + "}"
        if i < ns - 1 { b = b + "," }
        b = b + "\n"
        i = i + 1
    }
    b = b + "  ],\n"

    // aggregate
    b = b + "  \"aggregate\": {\n"
    b = b + "    \"score_ladder_mean_ppm\": " + join_int(ladder_mean) + ",\n"
    b = b + "    \"alpha_mean_x1000\":  " + str(mean_int(alphas)) + ",\n"
    b = b + "    \"xi_mean_x1000\":     " + str(mean_int(xis)) + ",\n"
    b = b + "    \"slope_mean\":         " + str(mean_int(slopes)) + ",\n"
    b = b + "    \"r_squared_mean_ppm\": " + str(mean_int(r2s)) + ",\n"
    b = b + "    \"sealed_final_mean_ppm\": " + str(o3_mean) + ",\n"
    b = b + "    \"sealed_final_std_ppm\":  " + str(o3_std) + ",\n"
    b = b + "    \"sealed_final_std_over_mean_ppm\": " + str(o3_ratio_ppm) + "\n"
    b = b + "  },\n"

    b = b + "  \"observables\": {\n"
    b = b + "    \"O1_score_ladder\":      " + bool_str(o1_pass) + ",\n"
    b = b + "    \"O2_correlation_decay\": " + bool_str(o2_pass) + ",\n"
    b = b + "    \"O3_phi_invariance\":    " + bool_str(o3_pass) + "\n"
    b = b + "  },\n"
    b = b + "  \"passes_of_3\": " + str(passes) + ",\n"
    b = b + "  \"verdict\": \"" + verdict + "\"\n"
    b = b + "}\n"
    write_file(path, b)
    println("  cert=" + path)
}

// ─── per-seed subprocess mode ───────────────────────────────────────────
//
// When invoked as `hexa run tool/F_lattice_cpu_proxy.hexa seed <SEED> <OUT>`,
// runs one seed and emits a compact JSON fragment to <OUT>.  Used by the
// main dispatcher to run seeds in separate processes (stage0 RSS budget).
fn run_one_seed(seed: int, out_path: string) {
    println("  [seed=" + str(seed) + "]")
    let res = measure_one(SIDE, seed, TICKS)
    let ladder      = res[0]
    let sealed_pack = res[1]
    let cs          = res[3]
    let scalars     = res[4]
    let alpha       = scalars[0]
    let xi          = scalars[1]
    let fp          = scalars[2]
    let lr          = linreg(ladder)
    let slope       = lr[0]
    let r_sq        = lr[1]
    let sld_fin     = sealed_pack[0]

    println("    ladder=" + join_int(ladder))
    println("    C(r)=" + join_int(cs))
    println("    alpha_x1000=" + str(alpha) + " xi_x1000=" + str(xi)
        + " slope=" + str(slope) + " r2_ppm=" + str(r_sq)
        + " sealed_final=" + str(sld_fin) + " fp=" + str(fp))

    let mut b = "{"
    b = b + "\"seed\":" + str(seed)
    b = b + ",\"ladder\":" + join_int(ladder)
    b = b + ",\"C_r\":" + join_int(cs)
    b = b + ",\"alpha_x1000\":" + str(alpha)
    b = b + ",\"xi_x1000\":" + str(xi)
    b = b + ",\"slope\":" + str(slope)
    b = b + ",\"r_squared_ppm\":" + str(r_sq)
    b = b + ",\"sealed_final_ppm\":" + str(sld_fin)
    b = b + ",\"fingerprint\":" + str(fp)
    b = b + "}\n"
    write_file(out_path, b)
    println("    wrote=" + out_path)
}

// Parse a field from a simple single-line JSON object. Returns "" if missing.
// Input like `{"seed":42,"ladder":[0,0,1],"alpha_x1000":500,...}`.
// Field must be "key":<value> where <value> ends at `,` or `}`.
fn json_field(src: string, key: string) -> string {
    let needle = "\"" + key + "\":"
    let n      = len(src)
    let kn     = len(needle)
    let mut i  = 0
    while i + kn <= n {
        if src.substring(i, i + kn) == needle {
            let mut j = i + kn
            let mut depth = 0
            let mut out = ""
            while j < n {
                let c = src.substring(j, j + 1)
                if (c == "," || c == "}") && depth == 0 { return out }
                if c == "[" { depth = depth + 1 }
                if c == "]" { depth = depth - 1 }
                out = out + c
                j = j + 1
            }
            return out
        }
        i = i + 1
    }
    return ""
}

fn parse_int_array(s: string) -> [int] {
    let mut out = []
    let n = len(s)
    let mut buf = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "[" || c == "]" || c == " " {
            // skip
        } else if c == "," {
            if len(buf) > 0 { out = out.push(parse_int(buf)) }
            buf = ""
        } else {
            buf = buf + c
        }
        i = i + 1
    }
    if len(buf) > 0 { out = out.push(parse_int(buf)) }
    return out
}

// ─── main ───────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    // Sub-dispatch: when called as `hexa run <this> seed <SEED> <OUT>`,
    // hexa exposes user args starting at argv[2].  So argv[2]="seed",
    // argv[3]=<SEED>, argv[4]=<OUT>.  len(argv) ≥ 5 signals sub-mode.
    if len(argv) >= 5 && argv[2] == "seed" {
        let sd    = parse_int(argv[3])
        let out_p = argv[4]
        run_one_seed(sd, out_p)
        exit(0)
    }

    println("F_lattice_cpu_proxy — Mk.VII C2 L3 CPU proxy at N=16")
    println("  side=" + str(SIDE) + " (N=" + str(SIDE * SIDE) + ")"
        + " ticks=" + str(TICKS) + " sample_step=" + str(SAMPLE_STEP))

    // 3-seed canonical run.  Each seed runs in a fresh `hexa run` subprocess
    // so stage0 RSS resets between seeds — the naive in-process 3-seed loop
    // blows past the 4 GiB RSS cap at N=16 after the 1st seed.
    let seeds = [42, 137, 271]
    let ns    = len(seeds)

    let mut ladders = []
    let mut cs_all  = []
    let mut alphas  = []
    let mut xis     = []
    let mut fps     = []
    let mut slopes  = []
    let mut r2s     = []
    let mut sealed_final = []

    let n_samples = (TICKS / SAMPLE_STEP) + 1

    // Locate our own .hexa path (hard-coded — tool lives at a fixed path
    // under anima).  Using absolute path makes the subprocess invocation
    // independent of the caller's cwd.
    let self_path = "tool/F_lattice_cpu_proxy.hexa"
    let hexa_bin  = "/Users/ghost/Dev/hexa-lang/hexa"

    let mut i = 0
    while i < ns {
        let sd = seeds[i]
        let tmp_out = "/tmp/F_lattice_seed_" + str(sd) + ".json"
        let cmd = hexa_bin + " run " + self_path
                  + " seed " + str(sd) + " " + tmp_out + " 2>&1"
        println("  [orchestrator] seed=" + str(sd) + " → " + tmp_out)
        let child_log = _str(exec(cmd))
        println(child_log)
        // Read back the JSON fragment.
        let frag = _str(exec("cat " + tmp_out)).trim()
        let ladder_s = json_field(frag, "ladder")
        let cs_s     = json_field(frag, "C_r")
        let ladder   = parse_int_array(ladder_s)
        let cs       = parse_int_array(cs_s)
        let alpha    = parse_int(json_field(frag, "alpha_x1000").trim())
        let xi       = parse_int(json_field(frag, "xi_x1000").trim())
        let slope    = parse_int(json_field(frag, "slope").trim())
        let r_sq     = parse_int(json_field(frag, "r_squared_ppm").trim())
        let sld_fin  = parse_int(json_field(frag, "sealed_final_ppm").trim())
        let fp       = parse_int(json_field(frag, "fingerprint").trim())

        ladders = ladders.push(ladder)
        cs_all  = cs_all.push(cs)
        alphas  = alphas.push(alpha)
        xis     = xis.push(xi)
        fps     = fps.push(fp)
        slopes  = slopes.push(slope)
        r2s     = r2s.push(r_sq)
        sealed_final = sealed_final.push(sld_fin)

        i = i + 1
    }

    // Compute mean ladder pointwise across seeds.
    let mut ladder_mean = []
    let mut k = 0
    while k < n_samples {
        let mut s = 0
        let mut j = 0
        while j < ns {
            s = s + ladders[j][k]
            j = j + 1
        }
        ladder_mean = ladder_mean.push(s / ns)
        k = k + 1
    }

    // ─── O1: monotone + slope R² ────────────────────────────────────
    // Test monotonicity & R² on the mean ladder (also require per-seed OK).
    let o1_mono    = is_monotone_nondecreasing(ladder_mean)
    let o1_ceiling = reached_ceiling(ladder_mean)
    let lr_mean    = linreg(ladder_mean)
    let mean_r2    = lr_mean[1]
    let o1_r2_ok   = mean_r2 >= 700
    let o1_pass    = (o1_mono || o1_ceiling) && o1_r2_ok

    // ─── O2: alpha + xi bands ───────────────────────────────────────
    let alpha_mean = mean_int(alphas)
    let xi_mean    = mean_int(xis)
    // ξ threshold: N/8 = 2 → 2000 (×1000)
    let xi_thresh  = ((SIDE * SIDE) * 1000) / 8
    // α band [500, 2500] ×1000
    let alpha_ok   = alpha_mean >= 500 && alpha_mean <= 2500
    let xi_ok      = xi_mean > xi_thresh
    let o2_pass    = alpha_ok && xi_ok

    // ─── O3: sealed-final std/mean ──────────────────────────────────
    let o3_mean  = mean_int(sealed_final)
    let o3_std   = stddev_of(sealed_final, o3_mean)
    let o3_ratio = if o3_mean > 0 { (o3_std * 1000) / o3_mean } else { 1000 }
    let o3_pass  = o3_ratio < 200 && o3_mean > 0

    let mut passes = 0
    if o1_pass { passes = passes + 1 }
    if o2_pass { passes = passes + 1 }
    if o3_pass { passes = passes + 1 }

    // Pre-registered verdict ladder: 3/3 EMERGED, 2/3 PARTIAL, <2 FAILED.
    let verdict = if passes == 3 { "L3_EMERGED_AT_SCALE_16" }
                  else if passes == 2 { "L3_PARTIAL" }
                  else { "L3_FAILED" }

    println("")
    println("══ MK.VII C2 CPU PROXY VERDICT @ N=16 ══")
    println("  ladder_mean_ppm = " + join_int(ladder_mean))
    println("  O1  mono=" + bool_str(o1_mono) + " ceiling=" + bool_str(o1_ceiling)
        + " mean_R²_ppm=" + str(mean_r2) + " → O1=" + bool_str(o1_pass))
    println("  O2  α_mean_x1000=" + str(alpha_mean) + " (band [500,2500])"
        + " ξ_mean_x1000=" + str(xi_mean) + " (> " + str(xi_thresh) + "?)"
        + " → O2=" + bool_str(o2_pass))
    println("  O3  sealed_final_mean_ppm=" + str(o3_mean)
        + " std_ppm=" + str(o3_std)
        + " std/mean_ppm=" + str(o3_ratio) + " (< 200?)"
        + " → O3=" + bool_str(o3_pass))
    println("  VERDICT: " + verdict + " (" + str(passes) + "/3 PASS)")

    emit_cert("shared/state/F_lattice_cpu_proxy_N16.json",
              ladders, cs_all, alphas, xis, fps, seeds,
              slopes, r2s, ladder_mean, sealed_final,
              o3_std, o3_mean, o3_ratio,
              o1_pass, o2_pass, o3_pass, passes, verdict)

    // Non-zero exit only for internal invariant violations (negative means).
    if o3_mean < 0 || alpha_mean < 0 || xi_mean < 0 {
        println("F_lattice_cpu_proxy: FAIL (invariant violation)")
        exit(1)
    }
    println("F_lattice_cpu_proxy: PASS (real measurement emitted)")
    exit(0)
}
