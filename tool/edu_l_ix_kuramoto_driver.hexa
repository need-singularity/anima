// ============================================================================
//  tool/edu_l_ix_kuramoto_driver.hexa
//
//  PURPOSE
//    Mk.IX L_cell trajectory test with V_sync_Kuramoto on the gen-5 closure
//    corpus (ws = [40, 125, 687, 1000, 1000]).  Verifies:
//
//      * stub path: matches the historical STATIONARY_AT_FIXPOINT record
//        (Mk.VIII Lagrangian mvp).
//      * kuramoto path: when all cells are fully phase-locked at the
//        fixpoint (theta_j = theta*) V_sync_kuramoto_x1000 = 0 identically,
//        so L_5 = 0 and ACTION/RESIDUAL aggregates reproduce the stub
//        verdict exactly.  This is the L_IX regression test.
//
//  Corpus phases
//    gen 1..4: a single-cell phase list (nn=1) -> stub fallback per
//              lagrangian_trajectory_kuramoto contract.
//    gen 5   : 3-cell locked lattice thetas = [1571, 1571, 1571]
//              (all cells in phase at theta = pi/2 per-mille); V_sync = 0.
//
//  HEXA-only (raw#9) - no LLM - deterministic - V8 SAFE_COMMIT.
// ============================================================================

// Inlined primitives (byte-equivalent to l_cell_integrator.hexa).  We do not
// use `import` because hexa 0.2.0's stage-0 module loader is fragile; the
// mvp_lagrangian.hexa inlining pattern is preserved here.

fn _t_tension_x1000(w_k: int, w_prev: int) -> int {
    let dw = w_k - w_prev
    let sq = dw * dw
    return (sq / 2) / 1000
}

fn _ln_perm_x1000(x: int) -> int {
    let mut v = x
    if v <= 0    { v = 1 }
    if v > 1000  { v = 1000 }
    if v >= 1000 { return 0 }
    if v >= 950  { return 0 - 51 }
    if v >= 900  { return 0 - 105 }
    if v >= 850  { return 0 - 163 }
    if v >= 800  { return 0 - 223 }
    if v >= 750  { return 0 - 288 }
    if v >= 700  { return 0 - 357 }
    if v >= 650  { return 0 - 431 }
    if v >= 600  { return 0 - 511 }
    if v >= 550  { return 0 - 598 }
    if v >= 500  { return 0 - 693 }
    if v >= 450  { return 0 - 799 }
    if v >= 400  { return 0 - 916 }
    if v >= 350  { return 0 - 1050 }
    if v >= 300  { return 0 - 1204 }
    if v >= 250  { return 0 - 1386 }
    if v >= 200  { return 0 - 1609 }
    if v >= 150  { return 0 - 1897 }
    if v >= 100  { return 0 - 2303 }
    if v >= 50   { return 0 - 2996 }
    return 0 - 6908
}

fn _v_struct_x1000(w: int) -> int {
    if w >= 1000 { return 0 }
    let ln_val = _ln_perm_x1000(w)
    return 0 - ln_val
}

fn _v_sync_stub_x1000(w: int) -> int {
    let mut s = w
    if s < 0    { s = 0 }
    if s > 1000 { s = 1000 }
    return 1000 - s
}

// ---- Kuramoto V_sync -------------------------------------------------------
let TAU_PERM     = 6283
let HALF_PI_PERM = 1571

fn _cos_x1000(theta_perm: int) -> int {
    let mut t = theta_perm % TAU_PERM
    if t < 0 { t = t + TAU_PERM }
    if t < 131  { return 1000 }
    if t < 393  { return 966 }
    if t < 655  { return 866 }
    if t < 916  { return 707 }
    if t < 1178 { return 500 }
    if t < 1440 { return 259 }
    if t < 1702 { return 0 }
    if t < 1963 { return 0 - 259 }
    if t < 2225 { return 0 - 500 }
    if t < 2487 { return 0 - 707 }
    if t < 2749 { return 0 - 866 }
    if t < 3010 { return 0 - 966 }
    if t < 3272 { return 0 - 1000 }
    if t < 3534 { return 0 - 966 }
    if t < 3796 { return 0 - 866 }
    if t < 4057 { return 0 - 707 }
    if t < 4319 { return 0 - 500 }
    if t < 4581 { return 0 - 259 }
    if t < 4843 { return 0 }
    if t < 5104 { return 259 }
    if t < 5366 { return 500 }
    if t < 5628 { return 707 }
    if t < 5890 { return 866 }
    if t < 6151 { return 966 }
    return 1000
}

fn _v_sync_kuramoto(thetas: list, nn: int, k_x1000: int) -> int {
    if nn <= 1 { return 0 }
    let pairs = nn * (nn - 1) / 2
    let mut acc = 0
    let mut i = 0
    while i < nn {
        let mut j = i + 1
        while j < nn {
            let dtheta = thetas[i] - thetas[j]
            let v_ij = (1000 - _cos_x1000(dtheta)) / 2
            acc = acc + v_ij
            j = j + 1
        }
        i = i + 1
    }
    let avg = acc / pairs
    let v = (k_x1000 * avg) / 1000
    if v < 0 { return 0 }
    return v
}

// ---- itoa ------------------------------------------------------------------
fn digit_char(d: int) -> string {
    if d == 0 { return "0" } else {
        if d == 1 { return "1" } else {
            if d == 2 { return "2" } else {
                if d == 3 { return "3" } else {
                    if d == 4 { return "4" } else {
                        if d == 5 { return "5" } else {
                            if d == 6 { return "6" } else {
                                if d == 7 { return "7" } else {
                                    if d == 8 { return "8" } else { return "9" }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
fn itoa(n: int) -> string {
    if n == 0 { return "0" }
    let mut s = ""
    let mut neg = false
    let mut x = n
    if x < 0 { neg = true  x = 0 - x }
    while x > 0 {
        let d = x % 10
        s = digit_char(d) + s
        x = x / 10
    }
    if neg { return "-" + s }
    return s
}

// ---- corpus ----------------------------------------------------------------
let ws = [40, 125, 687, 1000, 1000]
let K_COUPLING = 1000

// Per-gen phases for the Kuramoto path.  Gen 1..4: singleton (stub fallback).
// Gen 5: 3-cell lattice locked at theta = pi/2 per-mille (perfect phase-lock).
let phases_g1 = [0]
let phases_g2 = [0]
let phases_g3 = [0]
let phases_g4 = [0]
let phases_g5 = [1571, 1571, 1571]

// Compute per-gen T / V_struct / V_sync(stub) / V_sync(kura) / L for each path.
let n = ws.len()
let mut stub_l = []
let mut kura_l = []
let mut stub_t = []
let mut stub_vs = []
let mut stub_vy = []
let mut kura_vy = []

let mut i = 0
while i < n {
    let t = if i == 0 { 0 } else { _t_tension_x1000(ws[i], ws[i - 1]) }
    let vs = _v_struct_x1000(ws[i])
    let vy_stub = _v_sync_stub_x1000(ws[i])
    let phases = if i == 0 { phases_g1 } else {
        if i == 1 { phases_g2 } else {
            if i == 2 { phases_g3 } else {
                if i == 3 { phases_g4 } else { phases_g5 }
            }
        }
    }
    let nn = phases.len()
    let vy_kura = if nn <= 1 { vy_stub } else { _v_sync_kuramoto(phases, nn, K_COUPLING) }
    let l_stub = t - vs - vy_stub
    let l_kura = t - vs - vy_kura
    stub_t = stub_t.push(t)
    stub_vs = stub_vs.push(vs)
    stub_vy = stub_vy.push(vy_stub)
    kura_vy = kura_vy.push(vy_kura)
    stub_l = stub_l.push(l_stub)
    kura_l = kura_l.push(l_kura)
    i = i + 1
}

let mut action_stub = 0
let mut action_kura = 0
let mut k = 0
while k < n {
    action_stub = action_stub + stub_l[k]
    action_kura = action_kura + kura_l[k]
    k = k + 1
}

// Stationary-action verdict: gen n = 5 step.
// (A) ΔW = 0
// (B) W_n = 1000
// (C) V_sync(5) = 0 and V_struct(5) = 0 -> L_5 = 0
let delta_w_final = ws[n - 1] - ws[n - 2]
let kinetic_fix = if delta_w_final == 0 { 1 } else { 0 }
let w_at_wall = if ws[n - 1] >= 1000 { 1 } else { 0 }
let plateau_stub = if stub_l[n - 1] == 0 { 1 } else { 0 }
let plateau_kura = if kura_l[n - 1] == 0 { 1 } else { 0 }

let verdict_stub = if kinetic_fix == 1 {
    if w_at_wall == 1 {
        if plateau_stub == 1 { "STATIONARY_AT_FIXPOINT" } else { "STATIONARY_BOUNDARY" }
    } else { "NON_STATIONARY" }
} else { "NON_STATIONARY" }

let verdict_kura = if kinetic_fix == 1 {
    if w_at_wall == 1 {
        if plateau_kura == 1 { "STATIONARY_AT_FIXPOINT" } else { "STATIONARY_BOUNDARY" }
    } else { "NON_STATIONARY" }
} else { "NON_STATIONARY" }

// ---- output -----------------------------------------------------------------
println("=== Mk.IX L_cell gen-5 closure : stub vs Kuramoto ===")
println("ws = [40, 125, 687, 1000, 1000]")
println("K_coupling_x1000 = " + itoa(K_COUPLING))
println("phases_gen_5 = [1571, 1571, 1571]  (pi/2 per-mille, locked)")
println("")
println("gen |  W  |   T   |  V_struct |  V_sync(stub) | V_sync(kura) | L(stub) | L(kura)")
println("----+-----+-------+-----------+---------------+--------------+---------+---------")
let mut r = 0
while r < n {
    let g = r + 1
    println("  " + itoa(g) + " | " + itoa(ws[r]) + " | " + itoa(stub_t[r]) + " | " + itoa(stub_vs[r]) + " | " + itoa(stub_vy[r]) + " | " + itoa(kura_vy[r]) + " | " + itoa(stub_l[r]) + " | " + itoa(kura_l[r]))
    r = r + 1
}
println("")
println("action (stub) = " + itoa(action_stub))
println("action (kura) = " + itoa(action_kura))
println("delta_w_final = " + itoa(delta_w_final))
println("kinetic_fixpoint = " + itoa(kinetic_fix))
println("w_at_wall = " + itoa(w_at_wall))
println("plateau (stub) = " + itoa(plateau_stub))
println("plateau (kura) = " + itoa(plateau_kura))
println("verdict (stub) = " + verdict_stub)
println("verdict (kura) = " + verdict_kura)
println("")

let regression = if verdict_stub == verdict_kura { "PASS" } else { "FAIL" }
println("L_IX regression vs Mk.VIII : " + regression)

// ---- emit cert -------------------------------------------------------------
let mut cert = "{\n"
cert = cert + "  \"verifier\": \"edu_l_ix_kuramoto_driver\",\n"
cert = cert + "  \"paradigm\": \"Mk.IX L_cell with V_sync Kuramoto\",\n"
cert = cert + "  \"hexa_only\": true,\n"
cert = cert + "  \"raw_rank\": 9,\n"
cert = cert + "  \"deterministic\": true,\n"
cert = cert + "  \"llm\": \"none\",\n"
cert = cert + "  \"K_coupling_x1000\": " + itoa(K_COUPLING) + ",\n"
cert = cert + "  \"ws\": [40,125,687,1000,1000],\n"
cert = cert + "  \"phases_gen_5\": [1571,1571,1571],\n"
cert = cert + "  \"action_stub_x1000\": " + itoa(action_stub) + ",\n"
cert = cert + "  \"action_kura_x1000\": " + itoa(action_kura) + ",\n"
cert = cert + "  \"verdict_stub\": \"" + verdict_stub + "\",\n"
cert = cert + "  \"verdict_kura\": \"" + verdict_kura + "\",\n"
cert = cert + "  \"regression\": \"" + regression + "\",\n"
cert = cert + "  \"L_stub\": ["
let mut p = 0
while p < n {
    if p > 0 { cert = cert + "," }
    cert = cert + itoa(stub_l[p])
    p = p + 1
}
cert = cert + "],\n"
cert = cert + "  \"L_kura\": ["
let mut q = 0
while q < n {
    if q > 0 { cert = cert + "," }
    cert = cert + itoa(kura_l[q])
    q = q + 1
}
cert = cert + "]\n"
cert = cert + "}\n"

write_file("shared/state/edu_l_ix_kuramoto.json", cert)
println("cert: shared/state/edu_l_ix_kuramoto.json")
exit(0)
