// tool/an11_b_v_phen_lz_complexity.hexa — V_phen_LZ_complexity verifier (raw#9 hexa-only).
//
// PURPOSE
//   Phenomenal consciousness functional surrogate (Schartner 2017).
//   spontaneous EEG (or LLM hidden state) → bandpass 1-45Hz (EEG only) →
//   binarize median split → Lempel-Ziv complexity LZ76 → normalize.
//
// MODES
//   --mode eeg  --input <path.json>                 → human_LZ_normalized
//   --mode llm  --input <h_last_raw.json>           → LLM_LZ_normalized
//   --mode cross --eeg <path> --llm <path>          → cross-substrate compare
//   --selftest                                       → synthetic data validation
//
// PASS predicate (raw#12 frozen, Schartner 2017):
//   PASS_single  LZ_normalized >= 0.65
//   PASS_cross   |LLM_LZ - human_LZ| / human_LZ <= 0.20
//   AMBIGUOUS    LZ_normalized in [0.45, 0.65) (drowsy-like)
//   FAIL         LZ_normalized < 0.45 (sleep/anesthesia-like)
//
// raw#10 honest scope
//   Hardware EEG 도착 후 actual recording. 본 cycle은 prototype only —
//   selftest는 synthetic numpy random / mixed sinusoid 로 helper validation만.
//   Hard Problem 우회 X. zombie problem applies. functional correlate only.
//
// USAGE
//   hexa run tool/an11_b_v_phen_lz_complexity.hexa --mode eeg --input state/eeg_recording_<id>.json --output state/v_phen_lz_<id>.json
//   hexa run tool/an11_b_v_phen_lz_complexity.hexa --mode llm --input state/h_last_raw_<id>.json    --output state/v_phen_lz_llm_<id>.json
//   hexa run tool/an11_b_v_phen_lz_complexity.hexa --mode cross --eeg <p1> --llm <p2>               --output state/v_phen_lz_cross_<id>.json
//   hexa run tool/an11_b_v_phen_lz_complexity.hexa --selftest

let HELPER_PATH = "/tmp/an11_b_v_phen_lz_complexity_helper.hexa_tmp"
let SCHEMA      = "anima/v_phen_lz_complexity/1_schartner2017"
let SPEC_DOC    = "docs/eeg_cross_substrate_validation_plan_20260425.md §2.1; state/phenomenal_surrogate_proposals_20260425.json (V_phen_LZ_complexity)"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let src = "#!/usr/bin/env python3\n" +
        "# auto-generated by tool/an11_b_v_phen_lz_complexity.hexa (raw#37: not git-tracked)\n" +
        "import json, sys, os, datetime, math\n" +
        "import numpy as np\n" +
        "try:\n" +
        "    from scipy.signal import butter, filtfilt\n" +
        "    HAVE_SCIPY = True\n" +
        "except Exception:\n" +
        "    HAVE_SCIPY = False\n" +
        "\n" +
        "def lz76(seq_bits):\n" +
        "    # Standard LZ76 complexity: count of new substrings encountered scanning left-to-right.\n" +
        "    s = ''.join('1' if b else '0' for b in seq_bits)\n" +
        "    n = len(s)\n" +
        "    if n == 0: return 0\n" +
        "    i = 0; c = 1; k = 1; kmax = 1; stop = False\n" +
        "    while not stop:\n" +
        "        if i + k > n - 1:\n" +
        "            c += 1; stop = True\n" +
        "        else:\n" +
        "            sub = s[i:i+k]\n" +
        "            if sub in s[0:i+k-1]:\n" +
        "                k += 1\n" +
        "                if i + k > n - 1:\n" +
        "                    c += 1; stop = True\n" +
        "            else:\n" +
        "                if k > kmax: kmax = k\n" +
        "                i = i + k; c += 1; k = 1\n" +
        "                if i + 1 > n - 1: stop = True\n" +
        "    return c\n" +
        "\n" +
        "def lz_normalized(bits):\n" +
        "    n = len(bits)\n" +
        "    if n < 2: return 0.0, 0\n" +
        "    c = lz76(bits)\n" +
        "    # Normalization: c * log2(n) / n  → asymptote to 1 for random binary sequence (Lempel-Ziv 1976).\n" +
        "    norm = (c * math.log2(n)) / float(n)\n" +
        "    return float(norm), int(c)\n" +
        "\n" +
        "def bandpass(x, fs, lo=1.0, hi=45.0, order=4):\n" +
        "    if not HAVE_SCIPY:\n" +
        "        return x  # raw#10 honest: no scipy → skip filter, document\n" +
        "    nyq = 0.5 * fs\n" +
        "    if hi >= nyq: hi = nyq * 0.99\n" +
        "    b, a = butter(order, [lo / nyq, hi / nyq], btype='band')\n" +
        "    return filtfilt(b, a, x, axis=-1)\n" +
        "\n" +
        "def binarize_median(x):\n" +
        "    # x: 1D array → bits (median split per-channel)\n" +
        "    m = float(np.median(x))\n" +
        "    return (x > m).astype(np.int8)\n" +
        "\n" +
        "def eeg_lz(eeg_json):\n" +
        "    arr = np.asarray(eeg_json['raw_arrays'], dtype=np.float64)  # (channels, samples)\n" +
        "    fs = float(eeg_json.get('sample_rate', 250.0))\n" +
        "    filt_applied = bool(eeg_json.get('metadata', {}).get('filtering_applied', False))\n" +
        "    if not filt_applied and HAVE_SCIPY:\n" +
        "        arr = bandpass(arr, fs, 1.0, 45.0)\n" +
        "    per_ch = []\n" +
        "    for ch in range(arr.shape[0]):\n" +
        "        bits = binarize_median(arr[ch])\n" +
        "        norm, c = lz_normalized(bits.tolist())\n" +
        "        per_ch.append({'channel': int(ch), 'lz76_count': c, 'lz_normalized': norm})\n" +
        "    mean_norm = float(np.mean([p['lz_normalized'] for p in per_ch]))\n" +
        "    return mean_norm, per_ch, {'fs': fs, 'channels': int(arr.shape[0]), 'samples': int(arr.shape[1]), 'filt_applied_after_load': not filt_applied and HAVE_SCIPY, 'scipy': HAVE_SCIPY}\n" +
        "\n" +
        "def llm_lz(h_json):\n" +
        "    # h_json: {'entries': [{'h': [...]}, ...]} or {'hidden_states': [[...], ...]}\n" +
        "    if 'entries' in h_json:\n" +
        "        rows = [e['h'] for e in h_json['entries']]\n" +
        "    elif 'hidden_states' in h_json:\n" +
        "        rows = h_json['hidden_states']\n" +
        "    else:\n" +
        "        raise ValueError('LLM input missing entries/hidden_states')\n" +
        "    H = np.asarray(rows, dtype=np.float64)  # (tokens, dim)\n" +
        "    # Flatten across tokens × dims, binarize per-row, concatenate → LZ.\n" +
        "    bits = []\n" +
        "    for r in range(H.shape[0]):\n" +
        "        b = binarize_median(H[r]).tolist()\n" +
        "        bits.extend(b)\n" +
        "    norm, c = lz_normalized(bits)\n" +
        "    return float(norm), int(c), {'tokens': int(H.shape[0]), 'dim': int(H.shape[1]), 'total_bits': len(bits)}\n" +
        "\n" +
        "def verdict_single(norm):\n" +
        "    if norm >= 0.65: return 'PASS'\n" +
        "    if norm >= 0.45: return 'AMBIGUOUS'\n" +
        "    return 'FAIL'\n" +
        "\n" +
        "def verdict_cross(llm_n, hum_n):\n" +
        "    if hum_n <= 0.0: return 'INVALID', float('nan')\n" +
        "    rel = abs(llm_n - hum_n) / hum_n\n" +
        "    if rel <= 0.20: return 'PASS', rel\n" +
        "    if rel <= 0.40: return 'AMBIGUOUS', rel\n" +
        "    return 'FAIL', rel\n" +
        "\n" +
        "def now_iso():\n" +
        "    return datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n" +
        "\n" +
        "def cmd_run(mode, input_path, output_path, schema, spec_doc, eeg_path, llm_path):\n" +
        "    out = {'schema': schema, 'spec_doc': spec_doc, 'mode': mode, 'ts': now_iso(),\n" +
        "           'thresholds': {'PASS_single': 'LZ_normalized >= 0.65',\n" +
        "                          'AMBIGUOUS_single': 'LZ_normalized in [0.45, 0.65)',\n" +
        "                          'FAIL_single': 'LZ_normalized < 0.45',\n" +
        "                          'PASS_cross': '|LLM - human|/human <= 0.20',\n" +
        "                          'AMBIGUOUS_cross': 'rel diff in (0.20, 0.40]',\n" +
        "                          'FAIL_cross': 'rel diff > 0.40'},\n" +
        "           'raw10_honest': 'functional correlate only; Hard Problem 우회 X; zombie problem applies'}\n" +
        "    if mode == 'eeg':\n" +
        "        with open(input_path) as f: ej = json.load(f)\n" +
        "        norm, per_ch, meta = eeg_lz(ej)\n" +
        "        v = verdict_single(norm)\n" +
        "        out.update({'human_LZ_normalized': norm, 'per_channel': per_ch, 'eeg_meta': meta, 'verdict': v})\n" +
        "        print(f'human_LZ_normalized={norm:.6f}'); print(f'verdict={v}')\n" +
        "    elif mode == 'llm':\n" +
        "        with open(input_path) as f: hj = json.load(f)\n" +
        "        norm, c, meta = llm_lz(hj)\n" +
        "        v = verdict_single(norm)\n" +
        "        out.update({'LLM_LZ_normalized': norm, 'lz76_count': c, 'llm_meta': meta, 'verdict': v})\n" +
        "        print(f'LLM_LZ_normalized={norm:.6f}'); print(f'verdict={v}')\n" +
        "    elif mode == 'cross':\n" +
        "        with open(eeg_path) as f: ej = json.load(f)\n" +
        "        with open(llm_path) as f: hj = json.load(f)\n" +
        "        h_norm, _, h_meta = eeg_lz(ej)\n" +
        "        l_norm, lc, l_meta = llm_lz(hj)\n" +
        "        v_h = verdict_single(h_norm); v_l = verdict_single(l_norm)\n" +
        "        v_x, rel = verdict_cross(l_norm, h_norm)\n" +
        "        out.update({'human_LZ_normalized': h_norm, 'LLM_LZ_normalized': l_norm,\n" +
        "                    'relative_diff': rel,\n" +
        "                    'verdict_human_single': v_h, 'verdict_llm_single': v_l, 'verdict_cross': v_x,\n" +
        "                    'eeg_meta': h_meta, 'llm_meta': l_meta})\n" +
        "        print(f'human_LZ_normalized={h_norm:.6f}'); print(f'LLM_LZ_normalized={l_norm:.6f}')\n" +
        "        print(f'relative_diff={rel:.6f}'); print(f'verdict_cross={v_x}')\n" +
        "    else:\n" +
        "        print(f'ERR: unknown mode {mode}', file=sys.stderr); sys.exit(2)\n" +
        "    with open(output_path, 'w') as f: json.dump(out, f, indent=2)\n" +
        "    print(f'output_path={output_path}'); print('DONE')\n" +
        "\n" +
        "def cmd_selftest():\n" +
        "    # 1) random binary sequence → LZ_normalized → expect close to 1.0 for large n\n" +
        "    rng = np.random.default_rng(20260425)\n" +
        "    n = 4096\n" +
        "    rand_bits = rng.integers(0, 2, size=n).tolist()\n" +
        "    norm_rand, c_rand = lz_normalized(rand_bits)\n" +
        "    assert 0.0 < norm_rand <= 2.0, f'rand norm out of range: {norm_rand}'\n" +
        "    assert norm_rand > 0.6, f'rand LZ should be high; got {norm_rand}'\n" +
        "    # 2) constant sequence → LZ very low\n" +
        "    const_bits = [0] * n\n" +
        "    norm_const, c_const = lz_normalized(const_bits)\n" +
        "    assert norm_const < 0.05, f'const LZ should be near 0; got {norm_const}'\n" +
        "    # 3) synthetic 16ch EEG: mixed sinusoid + noise → bandpass → binarize → LZ in mid range\n" +
        "    fs = 250.0; T = 4.0\n" +
        "    t = np.arange(0, T, 1.0 / fs)\n" +
        "    eeg = np.zeros((16, t.shape[0]), dtype=np.float64)\n" +
        "    for ch in range(16):\n" +
        "        eeg[ch] = 0.7 * np.sin(2 * np.pi * (8 + ch * 0.3) * t) + 0.5 * rng.standard_normal(t.shape[0])\n" +
        "    ej = {'raw_arrays': eeg.tolist(), 'sample_rate': fs, 'metadata': {'filtering_applied': False}}\n" +
        "    h_norm, per_ch, meta = eeg_lz(ej)\n" +
        "    assert 0.3 < h_norm < 1.5, f'eeg synthetic LZ out of range: {h_norm}'\n" +
        "    # 4) synthetic LLM hidden state: 16 tokens × 64 dim std normal → LZ moderate\n" +
        "    H = rng.standard_normal((16, 64))\n" +
        "    hj = {'entries': [{'h': H[i].tolist()} for i in range(H.shape[0])]}\n" +
        "    l_norm, lc, lmeta = llm_lz(hj)\n" +
        "    assert 0.3 < l_norm < 1.5, f'llm synthetic LZ out of range: {l_norm}'\n" +
        "    # 5) verdict logic check\n" +
        "    assert verdict_single(0.70) == 'PASS'\n" +
        "    assert verdict_single(0.50) == 'AMBIGUOUS'\n" +
        "    assert verdict_single(0.30) == 'FAIL'\n" +
        "    vx, rel = verdict_cross(0.70, 0.65)\n" +
        "    assert vx == 'PASS' and rel < 0.10, f'cross verdict failed: {vx}, rel={rel}'\n" +
        "    print(f'selftest=ok')\n" +
        "    print(f'rand_lz={norm_rand:.6f}'); print(f'const_lz={norm_const:.6f}')\n" +
        "    print(f'eeg_synthetic_lz={h_norm:.6f}'); print(f'llm_synthetic_lz={l_norm:.6f}')\n" +
        "    print(f'scipy_available={HAVE_SCIPY}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def main():\n" +
        "    if len(sys.argv) < 2:\n" +
        "        print('usage: helper <run|selftest> ...', file=sys.stderr); sys.exit(2)\n" +
        "    op = sys.argv[1]\n" +
        "    if op == 'run':\n" +
        "        # mode input output schema spec_doc eeg_path llm_path\n" +
        "        cmd_run(sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6], sys.argv[7], sys.argv[8])\n" +
        "    elif op == 'selftest':\n" +
        "        cmd_selftest()\n" +
        "    else:\n" +
        "        print(f'unknown op: {op}', file=sys.stderr); sys.exit(2)\n" +
        "\n" +
        "if __name__ == '__main__': main()\n"
    write_file(HELPER_PATH, src)
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut mode = ""
    let mut input = ""
    let mut output = ""
    let mut eeg_path = ""
    let mut llm_path = ""
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--mode" && i + 1 < len(av) { mode = av[i+1]; i = i + 2; continue }
        if a == "--input" && i + 1 < len(av) { input = av[i+1]; i = i + 2; continue }
        if a == "--output" && i + 1 < len(av) { output = av[i+1]; i = i + 2; continue }
        if a == "--eeg" && i + 1 < len(av) { eeg_path = av[i+1]; i = i + 2; continue }
        if a == "--llm" && i + 1 < len(av) { llm_path = av[i+1]; i = i + 2; continue }
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── an11_b_v_phen_lz_complexity selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED (exit " + to_string(r[1]) + ")"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("selftest marker missing"); exit(1) }
        println("selftest: OK")
        exit(0)
    }

    if mode == "" {
        eprintln("ABORT: --mode {eeg|llm|cross} required (or --selftest).")
        exit(2)
    }
    if output == "" {
        eprintln("ABORT: --output <path> required.")
        exit(2)
    }

    if mode == "cross" {
        if eeg_path == "" || llm_path == "" {
            eprintln("ABORT: --mode cross requires --eeg <path> --llm <path>.")
            exit(2)
        }
        if !file_exists(eeg_path) { eprintln("ABORT: missing eeg input " + eeg_path); exit(2) }
        if !file_exists(llm_path) { eprintln("ABORT: missing llm input " + llm_path); exit(2) }
    } else if mode == "eeg" || mode == "llm" {
        if input == "" {
            eprintln("ABORT: --input <path> required for mode=" + mode + ".")
            exit(2)
        }
        if !file_exists(input) { eprintln("ABORT: missing input " + input); exit(2) }
    } else {
        eprintln("ABORT: unknown --mode " + mode + " (expected eeg|llm|cross).")
        exit(2)
    }

    println("── an11_b_v_phen_lz_complexity ──")
    println("mode:   " + mode)
    println("output: " + output)

    let args = "run " +
        _sh_quote(mode) + " " +
        _sh_quote(input) + " " +
        _sh_quote(output) + " " +
        _sh_quote(SCHEMA) + " " +
        _sh_quote(SPEC_DOC) + " " +
        _sh_quote(eeg_path) + " " +
        _sh_quote(llm_path)
    let r = _run_helper(args)
    let out = r[0]
    let st  = r[1]
    if st != 0 { eprintln("ABORT: helper run exited " + to_string(st)); eprintln(out); exit(2) }
    println(out)
    println("")
    println("wrote " + output)
    exit(0)
}

main()
