// ω-stdlib-2 large-file O(1) probe
fn main() {
    let p = "/Users/ghost/core/.filter-repo-backup-current-20260409-014517/nexus.tar.gz"
    let t0 = timestamp()
    let sz = file_size(p)
    let t1 = timestamp()
    let ex = file_exists(p)
    let t2 = timestamp()
    println("size=" + to_string(sz))
    println("exists=" + to_string(ex))
    println("file_size_ms=" + to_string(t1 - t0))
    println("file_exists_ms=" + to_string(t2 - t1))
}
