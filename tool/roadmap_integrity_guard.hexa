// tool/roadmap_integrity_guard.hexa — OS-level live 실수 방지 8-check guard
//
// PURPOSE
//   이번 세션에서 12+ 건 발생한 .roadmap / paths.json / SSOT drift
//   실수 패턴을 8 개 체크로 자동 감지한다. report-only (auto-fix 는
//   tool/roadmap_mistake_auto_fix.hexa 로 분리).
//
// CHECKS
//   #1 lint         — hexa /hexa-lang/tool/roadmap_lint.hexa → violations==0
//   #2 uchg         — ls -lO .roadmap → "uchg" 포함 required
//   #3 paths_drift  — paths.json path-like string 후행 설명 / line-range flag
//   #4 file_drift   — 선언 path vs repo 실체 비교 + 유사 이름 제안
//   #5 ssot_stale   — state/*_audit.json validator_status stale flag
//   #6 lock         — /tmp/hexa_stage0.lock.d long-hold PID 기록
//   #7 coverage     — .roadmap vs paths.json vs tool/*.hexa symmetric diff
//   #8 closure_debt — closure_debt_scanner SSOT debt_hits/score readback (WARN)
//
// USAGE
//   hexa tool/roadmap_integrity_guard.hexa              full run, exit 1 on ERROR
//   hexa tool/roadmap_integrity_guard.hexa --json       emit SSOT only, silent
//   hexa tool/roadmap_integrity_guard.hexa --check N    run single check (1..8)
//   hexa tool/roadmap_integrity_guard.hexa --config P   override config path
//   hexa tool/roadmap_integrity_guard.hexa --help
//
// EXIT CODES
//   0  all checks pass (ERROR severity all green)
//   1  any ERROR-severity check fails
//   2  config / setup problem
//
// RULES
//   raw#9  hexa-only     raw#11 snake_case    raw#15 no-hardcode (config JSON)
//   raw#1  does NOT alter chflags state (read-only probe); auto-fix tool 별도
//   raw#10 writes state/integrity_drift_<ts>.json + summary SSOT
//
// AIRGENOME LONG-LENS CHAIN (rig_trend)
//   program 시작 시 airgenome hook 기반으로 "rig_trend" 라는 단일 장기 lens
//   chain 을 보장한다 (is-active 가드, 없으면 activate). 8 체크 완료 후
//   1 회 touch 로 snapshot payload 를 findings.jsonl 에 append 한다. release
//   하지 않는다 (장기 lens 유지). airgenome 바이너리 부재 또는 hook CLI
//   미구현 환경에서는 graceful skip 하여 integrity_guard 본 실행은 영향받지
//   않는다.

let DEFAULT_CONFIG = "/Users/ghost/core/anima/config/roadmap_integrity_config.json"

// ─── airgenome hook long-lens chain (rig_trend) ─────────────────────
//
// CLI-only 경로. MCP / hexa wrapper 가 제공되지 않아도 동일 state root
// (AIRGENOME_HOOK_ROOT > CLAUDE_PROJECT_DIR > pwd) 에 기록된다. 모든
// 호출은 graceful — 실패 시 false 반환 후 호출부에서 silently skip.

let RIG_TREND_CHAIN   = "rig_trend"
let RIG_TREND_SEED    = "roadmap integrity trend"
let RIG_TREND_COMMAND = "roadmap"

fn _airgenome_bin() -> string {
    let candidates = [
        "/Users/ghost/Dev/airgenome/bin/airgenome",
        "/Users/ghost/.hx/bin/airgenome"
    ]
    for c in candidates {
        let p = to_string(c)
        if _file_exists(p) { return p }
    }
    return ""
}

fn _airgenome_hook_is_active(bin: string, chain: string) -> int {
    // exit 0 + stdout "1" → active; exit 0 + stdout "0" → inactive;
    // any error (missing shim, non-zero exit) → -1 (unknown, skip).
    let cmd = _sh_quote(bin) + " hook is-active " + _sh_quote(chain) + " 2>/dev/null"
    let r = exec_with_status(cmd)
    if r[1] != 0 { return -1 }
    let out = to_string(r[0]).trim()
    if out == "1" { return 1 }
    if out == "0" { return 0 }
    return -1
}

fn _airgenome_hook_activate(bin: string, chain: string, seed: string, command: string) -> bool {
    let cmd = _sh_quote(bin) + " hook activate " +
              _sh_quote(chain) + " " + _sh_quote(seed) + " " + _sh_quote(command) +
              " >/dev/null 2>&1"
    return _exec_code(cmd) == 0
}

fn _airgenome_hook_touch(bin: string, chain: string, kind: string, payload: string) -> bool {
    let cmd = _sh_quote(bin) + " hook touch " +
              _sh_quote(chain) + " " + _sh_quote(kind) + " " + _sh_quote(payload) +
              " >/dev/null 2>&1"
    return _exec_code(cmd) == 0
}

// Ensure rig_trend chain is active. Returns:
//   "active"   — already active OR successfully activated (proceed with touch)
//   "skip"     — airgenome missing / hook CLI unavailable / activate failed
fn _rig_trend_ensure() -> string {
    let bin = _airgenome_bin()
    if bin == "" { return "skip" }
    let st = _airgenome_hook_is_active(bin, RIG_TREND_CHAIN)
    if st == 1 { return "active" }
    if st < 0  { return "skip" }
    // st == 0 → activate
    if _airgenome_hook_activate(bin, RIG_TREND_CHAIN, RIG_TREND_SEED, RIG_TREND_COMMAND) {
        return "active"
    }
    return "skip"
}

fn _rig_trend_snapshot_payload(results: array) -> string {
    // Build deterministic JSON payload with per-check verdict + drift counts.
    let mut check_pairs = []
    let mut i = 0
    while i < len(results) {
        let r = results[i]
        let name = to_string(r[0])
        let verdict = to_string(r[1])
        // name := "check_<N>_<slug>" → reduce to "check_<N>"
        let mut short = name
        let us1 = short.index_of("_")
        if us1 >= 0 {
            let rest = short.substring(us1 + 1, len(short))
            let us2 = rest.index_of("_")
            if us2 >= 0 {
                short = short.substring(0, us1 + 1 + us2)
            }
        }
        check_pairs.push("\"" + _json_escape(short) + "\":\"" + _json_escape(verdict) + "\"")
        i = i + 1
    }

    // drift counters
    let mut closure_debt = 0
    let mut non_blocking_warn = 0
    let mut total_drift = 0
    let mut k = 0
    while k < len(results) {
        let r = results[k]
        let name = to_string(r[0])
        let verdict = to_string(r[1])
        if verdict == "FAIL" || verdict == "WARN" { total_drift = total_drift + 1 }
        if verdict == "WARN" { non_blocking_warn = non_blocking_warn + 1 }
        if name == "check_8_closure_debt" && (verdict == "WARN" || verdict == "FAIL") {
            closure_debt = 1
        }
        k = k + 1
    }

    let mut parts = []
    parts.push("{\"ts\":\"" + _ts_iso() + "\"")
    let mut j = 0
    while j < len(check_pairs) {
        parts.push("," + to_string(check_pairs[j]))
        j = j + 1
    }
    parts.push(",\"closure_debt\":" + to_string(closure_debt))
    parts.push(",\"non_blocking_warn\":" + to_string(non_blocking_warn))
    parts.push(",\"total_drift\":" + to_string(total_drift))
    parts.push("}")
    return parts.join("")
}

// Emit single snapshot touch on rig_trend. No release (long-lens).
// Caller passes the ensure-state string so we do not re-invoke
// is-active. Returns true if touch was attempted + succeeded.
fn _rig_trend_emit_snapshot(state: string, results: array) -> bool {
    if state != "active" { return false }
    let bin = _airgenome_bin()
    if bin == "" { return false }
    let payload = _rig_trend_snapshot_payload(results)
    return _airgenome_hook_touch(bin, RIG_TREND_CHAIN, "snapshot", payload)
}

// ─── sys helpers ─────────────────────────────────────────────────────

// INLINE_DEPRECATED[H42]: see shared/util/sh_quote.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _sh_quote(s: string) -> string {
    let mut out = "'"
    out = out + s.replace("'", "'\\''")
    out = out + "'"
    return out
}

fn _exec_out(cmd: string) -> string {
    let r = exec_with_status(cmd)
    return to_string(r[0])
}

fn _exec_code(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

// INLINE_DEPRECATED[H42]: see shared/util/file_exists.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _file_exists(path: string) -> bool {
    let r = exec_with_status("test -e " + _sh_quote(path))
    return r[1] == 0
}

fn _dir_exists(path: string) -> bool {
    let r = exec_with_status("test -d " + _sh_quote(path))
    return r[1] == 0
}

fn _ts_epoch() -> string {
    return _exec_out("date -u +%s").trim()
}

// INLINE_DEPRECATED[H42]: see shared/util/ts_iso.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _ts_iso() -> string {
    return _exec_out("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _mkdir_p(dir: string) -> bool {
    return _exec_code("mkdir -p " + _sh_quote(dir)) == 0
}

// ─── argv ────────────────────────────────────────────────────────────

fn _argv() -> array {
    let a = args()
    let mut out = []
    let mut i = 2
    while i < len(a) {
        out.push(a[i])
        i = i + 1
    }
    return out
}

fn _flag(av: array, k: string) -> bool {
    for x in av {
        if to_string(x) == k { return true }
    }
    return false
}

fn _opt(av: array, k: string, d: string) -> string {
    let mut i = 0
    while i < len(av) {
        if to_string(av[i]) == k && i + 1 < len(av) {
            return to_string(av[i + 1])
        }
        i = i + 1
    }
    return d
}

// ─── config load ─────────────────────────────────────────────────────

fn _load_config(path: string) {
    if !_file_exists(path) {
        eprintln("integrity_guard: SETUP_ERROR — config missing: " + path)
        exit(2)
    }
    let raw = read_file(path)
    let cfg = json_parse(raw)
    return cfg
}

fn _cfg_str(cfg, key: string, dflt: string) -> string {
    if cfg.contains_key(key) { return to_string(cfg[key]) }
    return dflt
}

// ─── check #1: roadmap_lint ─────────────────────────────────────────
//
// Invokes the canonical hexa-lang roadmap_lint tool with the .roadmap
// working directory. Captures exit code + stdout for drift preview.
fn check_1_lint(cfg) -> array {
    let lint_tool = _cfg_str(cfg, "lint_tool", "/Users/ghost/core/hexa-lang/tool/roadmap_lint.hexa")
    let hexa_bin  = _cfg_str(cfg, "hexa_bin",  "/Users/ghost/.hx/bin/hexa")
    let repo_root = _cfg_str(cfg, "repo_root", "/Users/ghost/core/anima")

    if !_file_exists(lint_tool) {
        return ["check_1_lint", "ERROR", "lint tool missing: " + lint_tool, []]
    }
    let cmd = "cd " + _sh_quote(repo_root) + " && " +
              _sh_quote(hexa_bin) + " " + _sh_quote(lint_tool) + " 2>&1"
    let r = exec_with_status(cmd)
    let out = to_string(r[0])
    let code = r[1]
    if code == 0 {
        return ["check_1_lint", "PASS", "lint clean", []]
    }
    // preview first 400 chars
    let mut preview = out
    if len(preview) > 400 { preview = preview.substring(0, 400) }
    return ["check_1_lint", "FAIL", "lint exit=" + to_string(code), [preview]]
}

// ─── check #2: chflags uchg presence ────────────────────────────────
fn check_2_uchg(cfg) -> array {
    let roadmap_path = _cfg_str(cfg, "roadmap_path", "/Users/ghost/core/anima/.roadmap")
    if !_file_exists(roadmap_path) {
        return ["check_2_uchg", "FAIL", "roadmap missing: " + roadmap_path, []]
    }
    let cmd = "ls -lO " + _sh_quote(roadmap_path) + " 2>/dev/null"
    let out = _exec_out(cmd)
    let ok = out.index_of("uchg") >= 0
    if ok {
        return ["check_2_uchg", "PASS", "chflags uchg present", []]
    }
    return ["check_2_uchg", "FAIL", "chflags uchg missing — auto_fix via roadmap_mistake_auto_fix", [out.trim()]]
}

// ─── check #3: paths.json description / line-range drift ────────────
//
// Scan every string value in paths.json. If a string starts with a
// known path-prefix (tool/, edu/, …) but contains a description
// separator (" — ", " 작성", ":NUM-NUM", …), flag WARN.
fn _has_prefix(s: string, prefixes: array) -> bool {
    for p in prefixes {
        let ps = to_string(p)
        if len(s) >= len(ps) && s.substring(0, len(ps)) == ps { return true }
    }
    return false
}

fn _contains_any(s: string, seps: array) -> bool {
    for sep in seps {
        let ss = to_string(sep)
        if s.index_of(ss) >= 0 { return true }
    }
    return false
}

fn _has_line_range(s: string) -> bool {
    // match trailing :N+-N+  (hexa lacks regex — manual scan)
    // find last ':' then check pattern digit+ "-" digit+ to end
    let idx = s.index_of(":")
    if idx < 0 { return false }
    // iterate all colons
    let n = len(s)
    let mut i = 0
    while i < n {
        if s.substring(i, i + 1) == ":" {
            // after colon: digit sequence
            let mut j = i + 1
            let mut d1 = 0
            while j < n {
                let c = s.substring(j, j + 1)
                if c >= "0" && c <= "9" { d1 = d1 + 1; j = j + 1 }
                else { break }
            }
            if d1 > 0 && j < n && s.substring(j, j + 1) == "-" {
                let mut k = j + 1
                let mut d2 = 0
                while k < n {
                    let c2 = s.substring(k, k + 1)
                    if c2 >= "0" && c2 <= "9" { d2 = d2 + 1; k = k + 1 }
                    else { break }
                }
                if d2 > 0 { return true }
            }
        }
        i = i + 1
    }
    return false
}

// Extract all JSON string literals from raw source (naive — handles
// escape sequences only as transparent pass-through). Returns array of
// [value, line_number].
fn _extract_json_strings(raw: string) -> array {
    let n = len(raw)
    let mut out = []
    let mut i = 0
    let mut line = 1
    while i < n {
        let c = raw.substring(i, i + 1)
        if c == "\n" { line = line + 1; i = i + 1; continue }
        if c == "\"" {
            let mut j = i + 1
            let mut buf = ""
            while j < n {
                let cc = raw.substring(j, j + 1)
                if cc == "\\" && j + 1 < n {
                    let nx = raw.substring(j + 1, j + 2)
                    // unescape \" and \\ for content; drop others literally
                    if nx == "\"" { buf = buf + "\""; j = j + 2; continue }
                    if nx == "\\" { buf = buf + "\\"; j = j + 2; continue }
                    if nx == "n"  { buf = buf + "\n"; j = j + 2; continue }
                    buf = buf + cc + nx
                    j = j + 2
                    continue
                }
                if cc == "\"" { break }
                buf = buf + cc
                j = j + 1
            }
            out.push([buf, to_string(line)])
            if j < n { i = j + 1 } else { i = j }
            continue
        }
        i = i + 1
    }
    return out
}

fn check_3_paths_drift(cfg) -> array {
    let repo_root = _cfg_str(cfg, "repo_root", "/Users/ghost/core/anima")
    let sources = cfg["paths_json_sources"]
    let check_cfg = cfg["checks"]["check_3_paths_drift"]
    let prefixes = check_cfg["path_prefixes"]
    let seps = check_cfg["description_separators"]

    let mut warnings = []
    let mut i = 0
    while i < len(sources) {
        let rel = to_string(sources[i])
        let full = repo_root + "/" + rel
        if !_file_exists(full) {
            warnings.push(rel + ": source missing")
            i = i + 1
            continue
        }
        let src = read_file(full)
        let strs = _extract_json_strings(src)
        let mut k = 0
        while k < len(strs) {
            let v  = to_string(strs[k][0])
            let ln = to_string(strs[k][1])
            if _has_prefix(v, prefixes) {
                let has_sep = _contains_any(v, seps)
                let has_rng = _has_line_range(v)
                if has_sep || has_rng {
                    let tag = if has_rng { "line_range" } else { "desc_suffix" }
                    warnings.push(rel + ":L" + ln + " [" + tag + "] " + v)
                }
            }
            k = k + 1
        }
        i = i + 1
    }
    if len(warnings) == 0 {
        return ["check_3_paths_drift", "PASS", "no description-suffix or line-range in path strings", []]
    }
    return ["check_3_paths_drift", "WARN", to_string(len(warnings)) + " path strings carry description / range suffix", warnings]
}

// ─── check #4: declared path vs actual file existence ───────────────
//
// Every JSON string with a recognized path prefix is tested for
// existence (after stripping the same suffixes check_3 catches).
// Missing → attempt similar-name suggestion via find + basename match.
fn _strip_suffixes(s: string, seps: array) -> string {
    let mut out = s
    for sep in seps {
        let ss = to_string(sep)
        let k = out.index_of(ss)
        if k >= 0 { out = out.substring(0, k) }
    }
    // also strip trailing :N-N range
    let n = len(out)
    let mut i = n - 1
    let mut saw_digit = false
    let mut saw_dash = false
    // scan back: digits — digits — colon
    let mut end = n
    let mut j = end - 1
    let mut d_right = 0
    while j >= 0 {
        let c = out.substring(j, j + 1)
        if c >= "0" && c <= "9" { d_right = d_right + 1; j = j - 1 } else { break }
    }
    if d_right > 0 && j >= 0 && out.substring(j, j + 1) == "-" {
        let mut k = j - 1
        let mut d_left = 0
        while k >= 0 {
            let c2 = out.substring(k, k + 1)
            if c2 >= "0" && c2 <= "9" { d_left = d_left + 1; k = k - 1 } else { break }
        }
        if d_left > 0 && k >= 0 && out.substring(k, k + 1) == ":" {
            out = out.substring(0, k)
        }
    }
    return out.trim()
}

fn _basename(p: string) -> string {
    let n = len(p)
    let mut i = n - 1
    while i >= 0 {
        if p.substring(i, i + 1) == "/" { return p.substring(i + 1, n) }
        i = i - 1
    }
    return p
}

fn _find_similar(repo_root: string, bn: string) -> string {
    // Use find to locate any matching basename. Limit depth 6 for sanity.
    let cmd = "find " + _sh_quote(repo_root) + " -maxdepth 6 -name " + _sh_quote(bn) + " 2>/dev/null | head -1"
    let out = _exec_out(cmd).trim()
    return out
}

fn check_4_file_drift(cfg) -> array {
    let repo_root = _cfg_str(cfg, "repo_root", "/Users/ghost/core/anima")
    let sources = cfg["paths_json_sources"]
    let check_cfg = cfg["checks"]["check_4_file_drift"]
    let pcfg3 = cfg["checks"]["check_3_paths_drift"]
    let prefixes = pcfg3["path_prefixes"]
    let seps = pcfg3["description_separators"]
    let fix_map = check_cfg["drift_fix_map"]

    let mut drifts = []
    let mut seen = []

    let mut i = 0
    while i < len(sources) {
        let rel = to_string(sources[i])
        let full = repo_root + "/" + rel
        if !_file_exists(full) { i = i + 1; continue }
        let src = read_file(full)
        let strs = _extract_json_strings(src)
        let mut k = 0
        while k < len(strs) {
            let v = _strip_suffixes(to_string(strs[k][0]), seps)
            let ln = to_string(strs[k][1])
            if _has_prefix(v, prefixes) {
                // dedupe
                let mut dup = false
                for s in seen {
                    if to_string(s) == v { dup = true }
                }
                if !dup {
                    seen.push(v)
                    let abs = repo_root + "/" + v
                    if !_file_exists(abs) {
                        let mut hint = ""
                        if fix_map.contains_key(v) {
                            hint = " → map:" + to_string(fix_map[v])
                        } else {
                            let sim = _find_similar(repo_root, _basename(v))
                            if sim != "" { hint = " → similar:" + sim }
                        }
                        drifts.push(rel + ":L" + ln + " missing " + v + hint)
                    }
                }
            }
            k = k + 1
        }
        i = i + 1
    }

    if len(drifts) == 0 {
        return ["check_4_file_drift", "PASS", "all declared paths exist", []]
    }
    return ["check_4_file_drift", "WARN", to_string(len(drifts)) + " declared paths missing", drifts]
}

// ─── check #5: SSOT validator_status stale ──────────────────────────
//
// Iterate state/*_audit.json, look for validator_status /
// gate_status / strict_status fields matching "NOT_EXECUTED" or
// "PENDING". Emits SSOT_STALE warning per file.
fn _list_dir(dir: string, pattern: string) -> array {
    let cmd = "ls " + _sh_quote(dir) + "/" + pattern + " 2>/dev/null"
    let out = _exec_out(cmd)
    let lines = split(out, "\n")
    let mut acc = []
    for l in lines {
        let t = to_string(l).trim()
        if len(t) > 0 { acc.push(t) }
    }
    return acc
}

fn _json_field_str(raw: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = raw.index_of(needle)
    if k < 0 { return "" }
    let rest = raw.substring(k + len(needle), len(raw))
    // skip ws + ':' + ws + '"'
    let mut j = 0
    while j < len(rest) {
        let c = rest.substring(j, j + 1)
        if c == " " || c == "\t" || c == ":" { j = j + 1 } else { break }
    }
    if j >= len(rest) { return "" }
    if rest.substring(j, j + 1) != "\"" { return "" }
    j = j + 1
    let mut buf = ""
    while j < len(rest) {
        let c = rest.substring(j, j + 1)
        if c == "\"" { break }
        buf = buf + c
        j = j + 1
    }
    return buf
}

fn check_5_ssot_stale(cfg) -> array {
    let repo_root = _cfg_str(cfg, "repo_root", "/Users/ghost/core/anima")
    let dirs = cfg["audit_json_glob_dirs"]
    let ccfg = cfg["checks"]["check_5_ssot_stale"]
    let stale_values = ccfg["stale_values"]
    let keys = ccfg["validator_keys"]

    let mut stale = []
    let mut i = 0
    while i < len(dirs) {
        let d_rel = to_string(dirs[i])
        let d_full = repo_root + "/" + d_rel
        if !_dir_exists(d_full) { i = i + 1; continue }
        let files = _list_dir(d_full, "*_audit.json")
        for f in files {
            let raw = read_file(to_string(f))
            let mut hit_key = ""
            let mut hit_val = ""
            for k in keys {
                let kk = to_string(k)
                let v = _json_field_str(raw, kk)
                if v == "" { continue }
                for sv in stale_values {
                    if v == to_string(sv) {
                        hit_key = kk
                        hit_val = v
                    }
                }
            }
            if hit_key != "" {
                stale.push(to_string(f) + " " + hit_key + "=" + hit_val)
            }
        }
        i = i + 1
    }
    if len(stale) == 0 {
        return ["check_5_ssot_stale", "PASS", "no stale audit SSOT", []]
    }
    return ["check_5_ssot_stale", "WARN", to_string(len(stale)) + " audit SSOT stale (needs revalidation)", stale]
}

// ─── check #6: concurrent long-held lock ────────────────────────────
fn check_6_lock(cfg) -> array {
    let ccfg = cfg["checks"]["check_6_lock"]
    let lock_dir = to_string(ccfg["lock_dir"])
    let threshold = to_int(to_string(ccfg["long_hold_seconds"]))

    if !_dir_exists(lock_dir) {
        return ["check_6_lock", "PASS", "no active hexa_stage0 lock dir", []]
    }
    let pid_file = lock_dir + "/pid"
    if !_file_exists(pid_file) {
        return ["check_6_lock", "PASS", "lock dir empty (no holder)", []]
    }
    // lock age: stat mtime
    let age_cmd = "echo $(( $(date -u +%s) - $(stat -f %m " + _sh_quote(pid_file) + " 2>/dev/null || echo 0) ))"
    let age_s = _exec_out(age_cmd).trim()
    let age = to_int(age_s)
    let pid = read_file(pid_file).trim()
    if age < threshold {
        return ["check_6_lock", "PASS", "lock held " + to_string(age) + "s pid=" + pid + " (under threshold)", []]
    }
    let ps_cmd = "ps -p " + _sh_quote(pid) + " -o pid,state,etime,command 2>/dev/null | tail -n +2"
    let ps_out = _exec_out(ps_cmd).trim()
    return ["check_6_lock", "WARN", "LONG_LOCK pid=" + pid + " age=" + to_string(age) + "s threshold=" + to_string(threshold) + "s", [ps_out]]
}

// ─── check #7: coverage cross-check ─────────────────────────────────
//
// Compute symmetric differences between three sets:
//   A = .roadmap track/phase category labels (collected from `track` keys)
//   B = paths.json `paths` / `prerequisites_confirmed` keys
//   C = tool/*.hexa file basenames
fn _read_roadmap_tracks(path: string) -> array {
    if !_file_exists(path) { return [] }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    let mut tracks = []
    for l in lines {
        let t = to_string(l).trim()
        if t.index_of("track ") == 0 || t.index_of("track\t") == 0 {
            // key value — "track foo"
            let sp = t.index_of(" ")
            if sp > 0 {
                let v = t.substring(sp + 1, len(t)).trim()
                if len(v) > 0 {
                    let mut dup = false
                    for x in tracks { if to_string(x) == v { dup = true } }
                    if !dup { tracks.push(v) }
                }
            }
        }
    }
    return tracks
}

fn _json_top_keys(raw: string, container_key: string) -> array {
    // Find container "container_key": { … } then return top-level keys at
    // that nesting depth. Rudimentary parser — adequate for paths.json.
    let nk = "\"" + container_key + "\""
    let start = raw.index_of(nk)
    if start < 0 { return [] }
    let rest = raw.substring(start + len(nk), len(raw))
    // find first '{'
    let bo = rest.index_of("{")
    if bo < 0 { return [] }
    let mut i = bo + 1
    let mut depth = 1
    let n = len(rest)
    let mut keys = []
    while i < n && depth > 0 {
        let c = rest.substring(i, i + 1)
        if c == "{" { depth = depth + 1; i = i + 1; continue }
        if c == "}" { depth = depth - 1; i = i + 1; continue }
        if c == "\"" && depth == 1 {
            // possible key — read until closing quote
            let mut j = i + 1
            let mut buf = ""
            while j < n {
                let cc = rest.substring(j, j + 1)
                if cc == "\\" && j + 1 < n { buf = buf + rest.substring(j, j + 2); j = j + 2; continue }
                if cc == "\"" { break }
                buf = buf + cc
                j = j + 1
            }
            // confirm this is a key (next non-ws char is ':')
            let mut k = j + 1
            while k < n {
                let cw = rest.substring(k, k + 1)
                if cw == " " || cw == "\t" || cw == "\n" || cw == "\r" { k = k + 1 } else { break }
            }
            if k < n && rest.substring(k, k + 1) == ":" {
                keys.push(buf)
            }
            i = j + 1
            continue
        }
        i = i + 1
    }
    return keys
}

fn _list_tool_hexa(dir: string) -> array {
    let cmd = "ls " + _sh_quote(dir) + "/*.hexa 2>/dev/null"
    let out = _exec_out(cmd)
    let lines = split(out, "\n")
    let mut acc = []
    for l in lines {
        let p = to_string(l).trim()
        if len(p) == 0 { continue }
        acc.push(_basename(p))
    }
    return acc
}

fn check_7_coverage(cfg) -> array {
    let repo_root = _cfg_str(cfg, "repo_root", "/Users/ghost/core/anima")
    let roadmap_path = _cfg_str(cfg, "roadmap_path", repo_root + "/.roadmap")
    let sources = cfg["paths_json_sources"]
    let tool_dirs = cfg["tool_dirs"]

    let roadmap_tracks = _read_roadmap_tracks(roadmap_path)

    // paths.json top-level keys under "paths" + "prerequisites_confirmed"
    let mut paths_keys = []
    let mut i = 0
    while i < len(sources) {
        let full = repo_root + "/" + to_string(sources[i])
        if _file_exists(full) {
            let raw = read_file(full)
            let ks1 = _json_top_keys(raw, "paths")
            let ks2 = _json_top_keys(raw, "prerequisites_confirmed")
            for k in ks1 { paths_keys.push(to_string(k)) }
            for k in ks2 { paths_keys.push(to_string(k)) }
        }
        i = i + 1
    }

    // tool files
    let mut tool_files = []
    let mut j = 0
    while j < len(tool_dirs) {
        let full = repo_root + "/" + to_string(tool_dirs[j])
        let lst = _list_tool_hexa(full)
        for f in lst { tool_files.push(to_string(f)) }
        j = j + 1
    }

    let summary = "roadmap_tracks=" + to_string(len(roadmap_tracks)) +
                  " paths_keys=" + to_string(len(paths_keys)) +
                  " tool_files=" + to_string(len(tool_files))

    let mut detail = []
    detail.push("roadmap_tracks: " + to_string(len(roadmap_tracks)))
    for t in roadmap_tracks { detail.push("  T: " + to_string(t)) }
    detail.push("paths_keys: " + to_string(len(paths_keys)))
    for k in paths_keys { detail.push("  P: " + to_string(k)) }
    detail.push("tool_files_count: " + to_string(len(tool_files)))

    return ["check_7_coverage", "INFO", summary, detail]
}

// ─── check #8: closure_debt pattern detection ──────────────────────
//
// Reads the closure_debt_scanner SSOT (state/closure_debt_result.json)
// if present and reports debt_hits / closure_debt_score. If SSOT missing
// suggests the scanner invocation. Does NOT re-invoke the scanner here
// (stage0 is serialized; embedded invocation would deadlock).
fn _json_field_num(raw: string, key: string) -> int {
    // "key": <digits> — parse integer after colon.
    let needle = "\"" + key + "\""
    let k = raw.index_of(needle)
    if k < 0 { return 0 }
    let rest = raw.substring(k + len(needle), len(raw))
    let mut j = 0
    while j < len(rest) {
        let c = rest.substring(j, j + 1)
        if c == " " || c == "\t" || c == ":" { j = j + 1 } else { break }
    }
    if j >= len(rest) { return 0 }
    // optional leading minus
    let mut sign = 1
    if rest.substring(j, j + 1) == "-" { sign = -1; j = j + 1 }
    let mut v = 0
    let mut saw = false
    while j < len(rest) {
        let c = rest.substring(j, j + 1)
        if c == "0" { v = v * 10 + 0; saw = true; j = j + 1 }
        else if c == "1" { v = v * 10 + 1; saw = true; j = j + 1 }
        else if c == "2" { v = v * 10 + 2; saw = true; j = j + 1 }
        else if c == "3" { v = v * 10 + 3; saw = true; j = j + 1 }
        else if c == "4" { v = v * 10 + 4; saw = true; j = j + 1 }
        else if c == "5" { v = v * 10 + 5; saw = true; j = j + 1 }
        else if c == "6" { v = v * 10 + 6; saw = true; j = j + 1 }
        else if c == "7" { v = v * 10 + 7; saw = true; j = j + 1 }
        else if c == "8" { v = v * 10 + 8; saw = true; j = j + 1 }
        else if c == "9" { v = v * 10 + 9; saw = true; j = j + 1 }
        else { break }
    }
    if !saw { return 0 }
    return v * sign
}

fn check_8_closure_debt(cfg) -> array {
    let ccfg = cfg["checks"]["check_8_closure_debt"]
    let ssot_path = to_string(ccfg["closure_debt_result"])
    let scanner_path = to_string(ccfg["closure_debt_scanner"])
    if !_file_exists(ssot_path) {
        let hint = "run: hexa " + scanner_path + " --all --auto-dispatch"
        return ["check_8_closure_debt", "INFO", "closure_debt SSOT 부재 (raw#12 추측 exempt) — " + hint, []]
    }
    let raw = read_file(ssot_path)
    let score = _json_field_num(raw, "closure_debt_score")
    let debt  = _json_field_num(raw, "debt_hits")
    let ex    = _json_field_num(raw, "exempt_hits")
    let ts_s  = _json_field_str(raw, "ts")
    if debt == 0 {
        return ["check_8_closure_debt", "PASS", "debt_hits=0 exempt=" + to_string(ex) + " ts=" + ts_s, []]
    }
    let items = ["ssot: " + ssot_path,
                 "debt_hits=" + to_string(debt) + " exempt=" + to_string(ex) + " score=" + to_string(score),
                 "run: hexa " + scanner_path + " --all --auto-dispatch"]
    return ["check_8_closure_debt", "WARN", "closure_debt detected score=" + to_string(score), items]
}

// ─── dispatcher ─────────────────────────────────────────────────────

fn run_check(cfg, n: int) -> array {
    if n == 1 { return check_1_lint(cfg) }
    if n == 2 { return check_2_uchg(cfg) }
    if n == 3 { return check_3_paths_drift(cfg) }
    if n == 4 { return check_4_file_drift(cfg) }
    if n == 5 { return check_5_ssot_stale(cfg) }
    if n == 6 { return check_6_lock(cfg) }
    if n == 7 { return check_7_coverage(cfg) }
    if n == 8 { return check_8_closure_debt(cfg) }
    return ["check_unknown_" + to_string(n), "FAIL", "unknown check number", []]
}

fn _severity_of(cfg, check_name: string) -> string {
    let ccfg = cfg["checks"]
    if ccfg.contains_key(check_name) {
        let sub = ccfg[check_name]
        if sub.contains_key("severity") { return to_string(sub["severity"]) }
    }
    return "INFO"
}

fn _verdict_symbol(v: string) -> string {
    if v == "PASS" { return "✓" }
    if v == "WARN" { return "⚠" }
    if v == "FAIL" { return "✗" }
    if v == "INFO" { return "·" }
    return "?"
}

// INLINE_DEPRECATED[H42]: see shared/util/json_escape.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
}

fn emit_summary_ssot(cfg, results: array, exit_code: int) -> string {
    let output = cfg["output"]
    let summary_path = to_string(output["summary_ssot"])
    let drift_dir = to_string(output["drift_log_dir"])
    let prefix = to_string(output["drift_log_prefix"])

    let mut parts = []
    parts.push("{\n  \"schema\": \"anima.roadmap_integrity.result.v1\",\n")
    parts.push("  \"ts\": \"" + _ts_iso() + "\",\n")
    parts.push("  \"tool\": \"tool/roadmap_integrity_guard.hexa\",\n")
    parts.push("  \"exit_code\": " + to_string(exit_code) + ",\n")
    parts.push("  \"checks\": [\n")
    let mut i = 0
    while i < len(results) {
        let r = results[i]
        let name = to_string(r[0])
        let verdict = to_string(r[1])
        let detail = to_string(r[2])
        let sev = _severity_of(cfg, name)
        let comma = if i + 1 < len(results) { "," } else { "" }
        parts.push("    { \"check\": \"" + _json_escape(name) + "\"")
        parts.push(", \"verdict\": \"" + verdict + "\"")
        parts.push(", \"severity\": \"" + sev + "\"")
        parts.push(", \"detail\": \"" + _json_escape(detail) + "\"")
        parts.push(", \"items\": [")
        let items = r[3]
        let mut j = 0
        while j < len(items) {
            let it = to_string(items[j])
            let c2 = if j + 1 < len(items) { ", " } else { "" }
            parts.push("\"" + _json_escape(it) + "\"" + c2)
            j = j + 1
        }
        parts.push("] }" + comma + "\n")
        i = i + 1
    }
    parts.push("  ]\n}\n")

    let body = parts.join("")
    let _ = _mkdir_p(drift_dir)
    let _ = write_file(summary_path, body)

    // per-drift log if any non-PASS/INFO result
    let mut has_drift = false
    for r in results {
        let v = to_string(r[1])
        if v == "FAIL" || v == "WARN" { has_drift = true }
    }
    if has_drift {
        let drift_path = drift_dir + "/" + prefix + _ts_epoch() + ".json"
        let _ = write_file(drift_path, body)
        return drift_path
    }
    return ""
}

fn print_human(results: array, cfg) {
    println("── roadmap_integrity_guard ──")
    for r in results {
        let name = to_string(r[0])
        let verdict = to_string(r[1])
        let detail = to_string(r[2])
        let sev = _severity_of(cfg, name)
        let sym = _verdict_symbol(verdict)
        println("  " + sym + " [" + sev + "] " + name + "  " + verdict + "  " + detail)
        let items = r[3]
        if len(items) > 0 {
            let cap = if len(items) < 8 { len(items) } else { 8 }
            let mut i = 0
            while i < cap {
                println("      · " + to_string(items[i]))
                i = i + 1
            }
            if len(items) > cap {
                println("      · (+" + to_string(len(items) - cap) + " more suppressed)")
            }
        }
    }
}

fn main() -> int {
    let av = _argv()

    if _flag(av, "--help") || _flag(av, "-h") {
        println("usage: hexa tool/roadmap_integrity_guard.hexa [opts]")
        println("  --json                emit SSOT only, suppress human output")
        println("  --check N             run single check (1..8)")
        println("  --config <path>       override config path")
        println("  --help")
        return 0
    }

    let cfg_path = _opt(av, "--config", DEFAULT_CONFIG)
    let cfg = _load_config(cfg_path)
    let json_mode = _flag(av, "--json")
    let single = _opt(av, "--check", "")

    // airgenome rig_trend long-lens: ensure active before running checks.
    // is-active guard prevents duplicate activation; missing airgenome or
    // hook CLI returns "skip" and downstream touch is suppressed.
    let rig_state = _rig_trend_ensure()

    let mut results = []
    if single != "" {
        let n = to_int(single)
        if n < 1 || n > 8 {
            eprintln("integrity_guard: --check must be 1..8")
            return 2
        }
        results.push(run_check(cfg, n))
    } else {
        let mut n = 1
        while n <= 8 {
            results.push(run_check(cfg, n))
            n = n + 1
        }
    }

    // exit policy: ERROR severity + non-PASS → exit 1
    let mut exit_code = 0
    for r in results {
        let name = to_string(r[0])
        let verdict = to_string(r[1])
        let sev = _severity_of(cfg, name)
        if sev == "ERROR" && verdict != "PASS" { exit_code = 1 }
    }

    if !json_mode { print_human(results, cfg) }
    let drift_log = emit_summary_ssot(cfg, results, exit_code)

    // rig_trend snapshot touch — full run only (single-check mode skips).
    // No release: long-lens chain remains active across invocations.
    let mut rig_touched = false
    if single == "" {
        rig_touched = _rig_trend_emit_snapshot(rig_state, results)
    }

    if !json_mode {
        println("")
        if drift_log != "" { println("drift_log: " + drift_log) }
        println("summary_ssot: " + to_string(cfg["output"]["summary_ssot"]))
        let mut rig_msg = "skip (airgenome unavailable)"
        if rig_state == "active" { rig_msg = "active (touch skipped)" }
        if rig_touched { rig_msg = "active (snapshot appended)" }
        println("rig_trend: " + rig_msg)
        println("exit_code=" + to_string(exit_code))
    }
    return exit_code
}
