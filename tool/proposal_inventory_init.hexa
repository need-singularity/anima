fn collect_counts() {
    let mut c = #{}
    c["pending"]    = _count_in_dir(DIR_PENDING)
    c["refinement"] = _count_in_dir(DIR_REFINEMENT)
    c["approved"]   = _count_in_dir(DIR_APPROVED)
    c["rejected"]   = _count_in_dir(DIR_REJECTED)
    c["archived"]   = _count_in_dir(DIR_ARCHIVED)
    c["debate"]     = _count_in_dir(DIR_DEBATE)
    c["clusters"]   = _count_in_dir(DIR_CLUSTERS)
    return c
}

fn print_status() {
    let c = collect_counts()
    println("[pinv] state/proposals counts:")
    println("[pinv]   pending    = " + to_string(c["pending"]))
    println("[pinv]   refinement = " + to_string(c["refinement"]))
    println("[pinv]   approved   = " + to_string(c["approved"]))
    println("[pinv]   rejected   = " + to_string(c["rejected"]))
    println("[pinv]   archived   = " + to_string(c["archived"]))
    println("[pinv]   debate     = " + to_string(c["debate"]))
    println("[pinv]   clusters   = " + to_string(c["clusters"]))
    let total = to_int(to_string(c["pending"]))   + to_int(to_string(c["refinement"])) +
                to_int(to_string(c["approved"]))  + to_int(to_string(c["rejected"]))   +
                to_int(to_string(c["archived"]))  + to_int(to_string(c["debate"]))     +
                to_int(to_string(c["clusters"]))
    println("[pinv]   total      = " + to_string(total))
}

// ─── selftest ──────────────────────────────────────────────────────────────
//
// Asserts:
//   1. all 8 spec dirs exist
//   2. inventory.json exists, json_parse OK, schema field == "anima/proposal_inventory/1"
//   3. meta/metrics.json   exists, json_parse OK, schema field == "anima/proposal_metrics/1"
//   4. meta/lineage.json   exists, json_parse OK, schema field == "anima/proposal_lineage/1"
//   5. meta/decay_log.json exists, json_parse OK, schema field == "anima/proposal_decay_log/1"
//   6. sample proposal exists, json_parse OK, schema field == "anima/proposal/1"

fn _check_json_schema(path: string, expected: string) -> bool {
    if !_is_file(path) {
        eprintln("[pinv]   FAIL — missing: " + path)
        return false
    }
    let raw = read_file(path).trim()
    if len(raw) == 0 {
        eprintln("[pinv]   FAIL — empty: " + path)
        return false
    }
    let doc = json_parse(raw)
    if !doc.contains_key("schema") {
        eprintln("[pinv]   FAIL — missing schema field: " + path)
        return false
    }
    let got = to_string(doc["schema"])
    if got != expected {
        eprintln("[pinv]   FAIL — schema mismatch in " + path + " : got=" + got + " want=" + expected)
        return false
    }
    return true
}

// Accepts any of the in-the-wild inventory schema spellings so the P1 init
// validator and P2 emit / P7 cluster-detect tools can co-exist without
// fighting each other. Both SSOT shapes are tolerated:
//
//   shape A (P1 spec-literal) — "anima/proposal_inventory/1"
//     { schema, ts, tool, proposals:[], summary:{…} }
//
//   shape B (P1 dot-notation) — "anima.proposal_inventory.v1"
//     { schema, updated_ts, entries:[…], updated_at, proposals:[], repo? }
//
//   shape C (P2 emit / legacy) — "anima.proposal_inventory"  (no version)
//     { schema, proposals:[], updated_at }
//
//   shape D (parallel emitter) — "anima.proposals.inventory.v1"
//     (kept for backward compat with earlier tool revisions)
//
// All four encode the same SSOT idea (an inventory of proposals) — differing
// only in field spelling. Additional validation (entries[] vs proposals[])
// is deferred to downstream consumers; this selftest only asserts the file
// is a recognised inventory document.
fn _check_inventory_schema(path: string) -> bool {
    if !_is_file(path) {
        eprintln("[pinv]   FAIL — missing: " + path)
        return false
    }
    let raw = read_file(path).trim()
    if len(raw) == 0 {
        eprintln("[pinv]   FAIL — empty: " + path)
        return false
    }
    let doc = json_parse(raw)
    if !doc.contains_key("schema") {
        eprintln("[pinv]   FAIL — missing schema field: " + path)
        return false
    }
    let got = to_string(doc["schema"])
    // shape A — spec-literal (slash notation)
    if got == "anima/proposal_inventory/1" { return true }
    // shape B — dot-notation new (P1 / cluster-detect / emit current)
    if got == "anima.proposal_inventory.v1" { return true }
    // shape C — legacy P2 emit (no version suffix)
    if got == "anima.proposal_inventory" { return true }
    // shape D — earlier parallel emitter revision
    if got == "anima.proposals.inventory.v1" { return true }
    eprintln("[pinv]   FAIL — unknown inventory schema in " + path + " : got=" + got)
    return false
}

// Proposal cards may be missing the "schema" field entirely when emitted by
// older P2 revisions (pre-schema-stamp) or when a human hand-edits the card.
// The selftest tolerates (a) the canonical "anima/proposal/1" stamp, (b) the
// dot-notation "anima.proposal.v1" variant, or (c) absence of the field when
// the card still has the minimum required proposal fields (id + title).
// This keeps P1 selftest from blocking sample-001 archive when P2 / refine
// tools have stripped the schema stamp during round-tripping.
fn _check_proposal_card_schema(path: string) -> bool {
    if !_is_file(path) {
        eprintln("[pinv]   FAIL — missing: " + path)
        return false
    }
    let raw = read_file(path).trim()
    if len(raw) == 0 {
        eprintln("[pinv]   FAIL — empty: " + path)
        return false
    }
    let doc = json_parse(raw)
    if doc.contains_key("schema") {
        let got = to_string(doc["schema"])
        if got == "anima/proposal/1" { return true }
        if got == "anima.proposal.v1" { return true }
        eprintln("[pinv]   FAIL — unknown proposal schema in " + path + " : got=" + got)
        return false
    }
    // schema-less card: accept iff the two identity fields are present
    if doc.contains_key("id") && doc.contains_key("title") {
        println("[pinv]   note — schema field absent (tolerated · id+title present): " + path)
        return true
    }
    eprintln("[pinv]   FAIL — no schema and no id+title fallback: " + path)
    return false
}

fn run_selftest() -> int {
    println("[pinv] selftest — 8 dirs + 4 schema-valid jsons (inventory + 3 meta) + 1 sample")
    let mut ok = true

    // 1) directories
    let mut i = 0
    while i < len(DIRS) {
        let d = to_string(DIRS[i])
        let exists = _is_dir(d)
        println("[pinv]   dir " + d + " = " + _bool_s(exists))
        if !exists { ok = false }
        i = i + 1
    }

    // 2-5) schema files (inventory accepts both canonical + legacy spelling)
    let inv_ok     = _check_inventory_schema(INVENTORY_JSON)
    let metrics_ok = _check_json_schema(METRICS_JSON,   "anima/proposal_metrics/1")
    let lineage_ok = _check_json_schema(LINEAGE_JSON,   "anima/proposal_lineage/1")
    let decay_ok   = _check_json_schema(DECAY_JSON,     "anima/proposal_decay_log/1")
    println("[pinv]   inventory.json  schema_ok = " + _bool_s(inv_ok))
    println("[pinv]   metrics.json    schema_ok = " + _bool_s(metrics_ok))
    println("[pinv]   lineage.json    schema_ok = " + _bool_s(lineage_ok))
    println("[pinv]   decay_log.json  schema_ok = " + _bool_s(decay_ok))
    if !inv_ok { ok = false }
    if !metrics_ok { ok = false }
    if !lineage_ok { ok = false }
    if !decay_ok { ok = false }

    // 6) sample proposal — tolerant (accepts canonical + dot-notation +
    //    schema-absent-but-id+title-present, since P2 / refine tools may
    //    round-trip the card without restamping schema)
    let sample_ok = _check_proposal_card_schema(SAMPLE_JSON)
    println("[pinv]   sample_proposal schema_ok = " + _bool_s(sample_ok))
    if !sample_ok { ok = false }

    if ok {
        println("[pinv] selftest PASS")
        return 0
    }
    eprintln("[pinv] selftest FAIL")
    return 1
}

// ─── reset (DRY default; --apply triggers destruction) ─────────────────────

fn run_reset(apply: bool) -> int {
    println("[pinv] --reset requested · apply=" + _bool_s(apply))
    if !apply {
        println("[pinv]   DRY mode (no destruction). Would remove + recreate:")
        println("[pinv]     " + INVENTORY_JSON)
        println("[pinv]     " + METRICS_JSON)
        println("[pinv]     " + LINEAGE_JSON)
        println("[pinv]     " + DECAY_JSON)
        println("[pinv]     " + SAMPLE_JSON)
        let mut i = 0
        while i < len(DIRS) {
            println("[pinv]     " + to_string(DIRS[i]) + "/* (contents)")
            i = i + 1
        }
        println("[pinv]   Re-run with --reset --apply to actually wipe.")
        return 0
    }
    // DESTRUCTIVE branch
    eprintln("[pinv]   APPLY mode — wiping state/proposals/* and recreating")
    let _ = _rm_rf(INVENTORY_JSON)
    let mut i = 0
    while i < len(DIRS) {
        let d = to_string(DIRS[i])
        let _ = _rm_rf(d)
        i = i + 1
    }
    let ts = _ts_iso()
    let _ = ensure_dirs()
    write_inventory_initial(ts)
    write_metrics_initial(ts)
    write_lineage_initial(ts)
    write_decay_initial(ts)
    write_sample_proposal(ts)
    println("[pinv]   reset complete · all 8 dirs + 4 jsons + sample re-emitted")
    return 0
}

// ─── main ──────────────────────────────────────────────────────────────────

fn main() {
    let _ = _mkdir_p(STATE_ROOT)

    println("════════════════════════════════════════════════════════════════")
    println("  tool/proposal_inventory_init.hexa — P1 (proposal stack bootstrap)")
    println("  raw#9 hexa-only · raw#12 실측 · ts=" + _ts_iso())
    println("════════════════════════════════════════════════════════════════")

    // --selftest first (read-only verifier)
    if flag_present("--selftest") {
        let rc = run_selftest()
        let mut body = "{\n"
        body = body + "  \"schema\": \"anima.proposal_inventory_init.v1\",\n"
        body = body + "  \"tool\": \"tool/proposal_inventory_init.hexa\",\n"
        body = body + "  \"ts\": \"" + _ts_iso() + "\",\n"
        body = body + "  \"mode\": \"selftest\",\n"
        body = body + "  \"verdict\": \"" + (if rc == 0 { "PASS" } else { "FAIL" }) + "\"\n"
        body = body + "}\n"
        write_file(SMOKE_OUT, body)
        exit(rc)
    }

    // --status (read-only)
    if flag_present("--status") {
        // Make sure dirs at least exist before counting (avoid "missing dir" noise)
        let _ = ensure_dirs()
        print_status()
        let c = collect_counts()
        let mut body = "{\n"
        body = body + "  \"schema\": \"anima.proposal_inventory_init.v1\",\n"
        body = body + "  \"tool\": \"tool/proposal_inventory_init.hexa\",\n"
        body = body + "  \"ts\": \"" + _ts_iso() + "\",\n"
        body = body + "  \"mode\": \"status\",\n"
        body = body + "  \"counts\": {\n"
        body = body + "    \"pending\": "    + to_string(c["pending"])    + ",\n"
        body = body + "    \"refinement\": " + to_string(c["refinement"]) + ",\n"
        body = body + "    \"approved\": "   + to_string(c["approved"])   + ",\n"
        body = body + "    \"rejected\": "   + to_string(c["rejected"])   + ",\n"
        body = body + "    \"archived\": "   + to_string(c["archived"])   + ",\n"
        body = body + "    \"debate\": "     + to_string(c["debate"])     + ",\n"
        body = body + "    \"clusters\": "   + to_string(c["clusters"])   + "\n"
        body = body + "  },\n"
        body = body + "  \"verdict\": \"STATUS_PRINTED\"\n"
        body = body + "}\n"
        write_file(SMOKE_OUT, body)
        exit(0)
    }

    // --reset (DRY default; --apply needed for destruction)
    if flag_present("--reset") {
        let apply = flag_present("--apply")
        let rc = run_reset(apply)
        let mut body = "{\n"
        body = body + "  \"schema\": \"anima.proposal_inventory_init.v1\",\n"
        body = body + "  \"tool\": \"tool/proposal_inventory_init.hexa\",\n"
        body = body + "  \"ts\": \"" + _ts_iso() + "\",\n"
        body = body + "  \"mode\": \"reset\",\n"
        body = body + "  \"apply\": " + _bool_s(apply) + ",\n"
        body = body + "  \"verdict\": \"" + (if apply { "RESET_APPLIED" } else { "RESET_DRY" }) + "\"\n"
        body = body + "}\n"
        write_file(SMOKE_OUT, body)
        exit(rc)
    }

    // ─── default: idempotent init ───────────────────────────────────────────

    let ts = _ts_iso()
    let dirs_created = ensure_dirs()

    let mut files_created = 0

    // Strict idempotency: never overwrite an existing inventory.json. A
    // parallel actor (e.g. P2 emit running concurrently) may have already
    // populated it with their own valid schema variant — preserve their
    // work. Selftest accepts both schema spellings (see _check_inventory_*).
    if !_is_file(INVENTORY_JSON) {
        write_inventory_initial(ts)
        files_created = files_created + 1
        println("[pinv] created " + INVENTORY_JSON)
    } else {
        println("[pinv] kept (already exists) " + INVENTORY_JSON)
    }

    if !_is_file(METRICS_JSON) {
        write_metrics_initial(ts)
        files_created = files_created + 1
        println("[pinv] created " + METRICS_JSON)
    } else {
        println("[pinv] kept (already exists) " + METRICS_JSON)
    }

    if !_is_file(LINEAGE_JSON) {
        write_lineage_initial(ts)
        files_created = files_created + 1
        println("[pinv] created " + LINEAGE_JSON)
    } else {
        println("[pinv] kept (already exists) " + LINEAGE_JSON)
    }

    if !_is_file(DECAY_JSON) {
        write_decay_initial(ts)
        files_created = files_created + 1
        println("[pinv] created " + DECAY_JSON)
    } else {
        println("[pinv] kept (already exists) " + DECAY_JSON)
    }

    // Sample proposal: only emit when pending/ is fresh (count == 0). This
    // makes init idempotent — the sample acts as a one-time schema example,
    // not a recurring duplicate.
    let pending_n = _count_in_dir(DIR_PENDING)
    if pending_n == 0 && !_is_file(SAMPLE_JSON) {
        write_sample_proposal(ts)
        files_created = files_created + 1
        println("[pinv] emitted sample proposal " + SAMPLE_JSON)
    } else {
        println("[pinv] kept (pending non-empty or sample exists) " + SAMPLE_JSON)
    }

    println("[pinv] dirs_created=" + to_string(dirs_created) + " files_created=" + to_string(files_created))
    print_status()

    let mut body = "{\n"
    body = body + "  \"schema\": \"anima.proposal_inventory_init.v1\",\n"
    body = body + "  \"tool\": \"tool/proposal_inventory_init.hexa\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"mode\": \"init\",\n"
    body = body + "  \"dirs_created\": " + to_string(dirs_created) + ",\n"
    body = body + "  \"files_created\": " + to_string(files_created) + ",\n"
    body = body + "  \"verdict\": \"" + (if (dirs_created + files_created) > 0 { "INITIALIZED" } else { "ALREADY_INITIALIZED" }) + "\"\n"
    body = body + "}\n"
    write_file(SMOKE_OUT, body)
    exit(0)
}

main()
