// ─── shell helpers (INLINE_DEPRECATED[H42]: see shared/util/*) ──────────────

fn _sh_quote(s: string) -> string {
    let mut out = "'"
    out = out + s.replace("'", "'\\''")
    out = out + "'"
    return out
}

fn _exec_out(cmd: string) -> string {
    let r = exec_with_status(cmd)
    return to_string(r[0])
}

fn _exec_code(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

// INLINE_DEPRECATED[H42]: see shared/util/ts_iso.hexa
fn _ts_iso() -> string {
    return _exec_out("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _bool_s(b: bool) -> string {
    if b { return "true" } else { return "false" }
}

// INLINE_DEPRECATED[H42]: see shared/util/file_exists.hexa
fn _file_exists(path: string) -> bool {
    let r = exec_with_status("test -e " + _sh_quote(path))
    return r[1] == 0
}

fn _is_dir(path: string) -> bool {
    let r = exec_with_status("test -d " + _sh_quote(path))
    return r[1] == 0
}

fn _is_file(path: string) -> bool {
    let r = exec_with_status("test -f " + _sh_quote(path))
    return r[1] == 0
}

fn _mkdir_p(d: string) -> bool {
    let r = exec_with_status("mkdir -p " + _sh_quote(d))
    return r[1] == 0
}

fn _rm_rf(p: string) -> bool {
    // Used ONLY by --reset --apply; guarded above.
    let r = exec_with_status("rm -rf " + _sh_quote(p))
    return r[1] == 0
}

fn _count_in_dir(d: string) -> int {
    if !_is_dir(d) { return 0 }
    // Count entries (files OR subdirs) at depth 1, excluding dotfiles.
    let cmd = "ls -1 " + _sh_quote(d) + " 2>/dev/null | wc -l | tr -d ' '"
    let raw = _exec_out(cmd).trim()
    if len(raw) == 0 { return 0 }
    return to_int(raw)
}

// INLINE_DEPRECATED[H42]: see shared/util/json_escape.hexa
fn _json_escape(s: string) -> string {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
}

fn flag_present(name: string) -> bool {
    let argv = args()
    let mut i = 0
    while i < len(argv) {
        if to_string(argv[i]) == name { return true }
        i = i + 1
    }
    return false
}

// ─── directory bootstrap ───────────────────────────────────────────────────

let DIRS = [
    "/Users/ghost/core/anima/state/proposals/pending",
    "/Users/ghost/core/anima/state/proposals/refinement",
    "/Users/ghost/core/anima/state/proposals/approved",
    "/Users/ghost/core/anima/state/proposals/rejected",
    "/Users/ghost/core/anima/state/proposals/archived",
    "/Users/ghost/core/anima/state/proposals/debate",
    "/Users/ghost/core/anima/state/proposals/clusters",
    "/Users/ghost/core/anima/state/proposals/meta"
]

fn ensure_dirs() -> int {
    let mut created = 0
    let _ = _mkdir_p(STATE_ROOT)
    let _ = _mkdir_p(PROP_ROOT)
    let mut i = 0
    while i < len(DIRS) {
        let d = to_string(DIRS[i])
        if !_is_dir(d) {
            let ok = _mkdir_p(d)
            if ok {
                created = created + 1
                println("[pinv] created dir: " + d)
            } else {
                eprintln("[pinv] FAILED mkdir: " + d)
            }
        }
        i = i + 1
    }
    return created
}

// ─── meta json bootstrap ───────────────────────────────────────────────────

// NOTE (schema coexistence — option C, 2026-04-22):
//   inventory.json carries TWO parallel arrays that serve different roles:
//     • "proposals": []  — per-card dedup+seq index used by P2 emit / P4
//                          approve / reject / implement / archive.
//     • "entries":   []  — cluster & super-proposal meta index used by
//                          P7 cluster_detect / P6 lineage_graph / P3 review.
//   Both keys are canonical. Every tool that rewrites this file MUST
//   preserve the opposite key (see append_to_inventory in cluster_detect
//   and _load_inventory in emit for the merge logic).
fn write_inventory_initial(ts: string) {
    let mut body = "{\n"
    body = body + "  \"schema\": \"anima/proposal_inventory/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"tool\": \"tool/proposal_inventory_init.hexa\",\n"
    body = body + "  \"version\": \"" + TOOL_VERSION + "\",\n"
    body = body + "  \"proposals\": [],\n"
    body = body + "  \"entries\": [],\n"
    body = body + "  \"summary\": {\n"
    body = body + "    \"pending\": 0,\n"
    body = body + "    \"refinement\": 0,\n"
    body = body + "    \"approved\": 0,\n"
    body = body + "    \"rejected\": 0,\n"
    body = body + "    \"archived\": 0,\n"
    body = body + "    \"debate\": 0,\n"
    body = body + "    \"clusters\": 0,\n"
    body = body + "    \"total\": 0\n"
    body = body + "  },\n"
    body = body + "  \"raw_strict\": \"raw#9 raw#10 raw#11 raw#12 raw#15\"\n"
    body = body + "}\n"
    write_file(INVENTORY_JSON, body)
}

