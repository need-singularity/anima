// tool/an11_b_eeg_ingest.hexa — Raw EEG (BDF/EDF/FIF) → standardized JSON state (raw#9 hexa-only).
//
// PURPOSE
//   Ingest 16ch EEG hardware recording → normalized JSON for downstream verifiers
//   (V_phen_LZ_complexity, V_phen_GWT_attention_entropy). Helper Python /tmp emit
//   prefers MNE-Python (raw#37); fallback note when MNE absent.
//
// MODES
//   --mode raw           — raw arrays + metadata only (no filtering)
//   --mode preprocessed  — bandpass 1-45Hz, optional ICA / ASR (flag-gated)
//   --selftest           — synthetic 16ch × 1s × 250Hz signal generation + ingest
//
// OUTPUT JSON (schema: anima/eeg_recording/1)
//   channels:        16 names (10-20 system or custom)
//   channel_positions: list[(x,y,z)] or null
//   sample_rate:     float Hz
//   raw_arrays:      list[list[float]] shape (channels, samples) — float32 by default
//   metadata: {
//     recording_duration_s, reference, filtering_applied,
//     filter_band_hz, ica_applied, asr_applied, timestamp,
//     source_format, source_path, mne_version (if used)
//   }
//
// raw#10 honest scope
//   - Hardware 도착 후 actual recording. 본 cycle은 prototype only.
//   - helper Python에서 `mne` import 실패 시 ABORT_NO_MNE + install instruction
//     ("pip install mne") emit. fallback: scipy + manual EDF reader 가능 시 안내.
//   - bfloat16 raw_arrays compaction은 future opt — 본 cycle은 float32 list.
//
// USAGE
//   hexa run tool/an11_b_eeg_ingest.hexa --input <path.{bdf|edf|fif}> --output state/eeg_recording_<id>.json --mode raw
//   hexa run tool/an11_b_eeg_ingest.hexa --input <path.fif> --output state/eeg_recording_<id>.json --mode preprocessed --ica --asr
//   hexa run tool/an11_b_eeg_ingest.hexa --selftest

let HELPER_PATH = "/tmp/an11_b_eeg_ingest_helper.hexa_tmp"
let SCHEMA      = "anima/eeg_recording/1"
let SPEC_DOC    = "docs/eeg_cross_substrate_validation_plan_20260425.md §1, §6.3"

fn _sh_quote(s: string) -> string {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn _kv_lookup(body: string, key: string) -> string {
    let prefix = key + "="
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i].trim()
        if ln.starts_with(prefix) {
            return ln.substring(prefix.len(), ln.len())
        }
        i = i + 1
    }
    return ""
}

fn _write_helper() {
    let src = "#!/usr/bin/env python3\n" +
        "# auto-generated by tool/an11_b_eeg_ingest.hexa (raw#37: not git-tracked)\n" +
        "import json, sys, os, datetime\n" +
        "import numpy as np\n" +
        "\n" +
        "HAVE_MNE = False\n" +
        "MNE_VERSION = None\n" +
        "try:\n" +
        "    import mne  # type: ignore\n" +
        "    HAVE_MNE = True\n" +
        "    MNE_VERSION = mne.__version__\n" +
        "except Exception:\n" +
        "    pass\n" +
        "\n" +
        "HAVE_SCIPY = False\n" +
        "try:\n" +
        "    from scipy.signal import butter, filtfilt  # type: ignore\n" +
        "    HAVE_SCIPY = True\n" +
        "except Exception:\n" +
        "    pass\n" +
        "\n" +
        "DEFAULT_10_20_16 = ['Fp1','Fp2','F3','F4','C3','C4','P3','P4',\n" +
        "                   'O1','O2','F7','F8','T3','T4','T5','T6']\n" +
        "\n" +
        "def now_iso():\n" +
        "    return datetime.datetime.now(datetime.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')\n" +
        "\n" +
        "def bandpass_scipy(arr, fs, lo=1.0, hi=45.0, order=4):\n" +
        "    if not HAVE_SCIPY: return arr, False\n" +
        "    nyq = 0.5 * fs\n" +
        "    if hi >= nyq: hi = nyq * 0.99\n" +
        "    b, a = butter(order, [lo / nyq, hi / nyq], btype='band')\n" +
        "    return filtfilt(b, a, arr, axis=-1), True\n" +
        "\n" +
        "def load_mne(path):\n" +
        "    p = path.lower()\n" +
        "    if p.endswith('.bdf'):\n" +
        "        raw = mne.io.read_raw_bdf(path, preload=True, verbose='error')\n" +
        "        fmt = 'bdf'\n" +
        "    elif p.endswith('.edf'):\n" +
        "        raw = mne.io.read_raw_edf(path, preload=True, verbose='error')\n" +
        "        fmt = 'edf'\n" +
        "    elif p.endswith('.fif') or p.endswith('.fif.gz'):\n" +
        "        raw = mne.io.read_raw_fif(path, preload=True, verbose='error')\n" +
        "        fmt = 'fif'\n" +
        "    else:\n" +
        "        raise ValueError(f'unsupported extension; expected bdf/edf/fif, got: {path}')\n" +
        "    return raw, fmt\n" +
        "\n" +
        "def ingest_with_mne(input_path, mode, channel_count, sample_rate_arg, do_ica, do_asr):\n" +
        "    raw, fmt = load_mne(input_path)\n" +
        "    if sample_rate_arg not in (None, '', 'auto'):\n" +
        "        try: target_fs = float(sample_rate_arg)\n" +
        "        except Exception: target_fs = None\n" +
        "        if target_fs is not None and abs(target_fs - raw.info['sfreq']) > 0.5:\n" +
        "            raw.resample(target_fs, npad='auto', verbose='error')\n" +
        "    fs = float(raw.info['sfreq'])\n" +
        "    ch_names = list(raw.info['ch_names'])\n" +
        "    if channel_count and len(ch_names) > channel_count:\n" +
        "        keep = ch_names[:channel_count]; raw.pick_channels(keep)\n" +
        "        ch_names = keep\n" +
        "    filter_band = None; filt_applied = False\n" +
        "    ica_applied = False; asr_applied = False\n" +
        "    if mode == 'preprocessed':\n" +
        "        raw.filter(l_freq=1.0, h_freq=45.0, verbose='error')\n" +
        "        filter_band = [1.0, 45.0]; filt_applied = True\n" +
        "        if do_ica:\n" +
        "            try:\n" +
        "                ica = mne.preprocessing.ICA(n_components=min(15, len(ch_names)), random_state=20260425, max_iter='auto')\n" +
        "                ica.fit(raw, verbose='error')\n" +
        "                ica.apply(raw, verbose='error')\n" +
        "                ica_applied = True\n" +
        "            except Exception as e:\n" +
        "                print(f'WARN: ICA failed: {e}', file=sys.stderr)\n" +
        "        if do_asr:\n" +
        "            print('NOTE: ASR not bundled with MNE; flag noted, no-op (raw#10 honest)', file=sys.stderr)\n" +
        "            asr_applied = False\n" +
        "    data = raw.get_data().astype(np.float32)  # (channels, samples)\n" +
        "    pos = None\n" +
        "    try:\n" +
        "        montage = raw.get_montage()\n" +
        "        if montage is not None:\n" +
        "            d = montage.get_positions()\n" +
        "            ch_pos = d.get('ch_pos', {}) if isinstance(d, dict) else {}\n" +
        "            pos = []\n" +
        "            for nm in ch_names:\n" +
        "                p = ch_pos.get(nm)\n" +
        "                pos.append([float(p[0]), float(p[1]), float(p[2])] if p is not None else None)\n" +
        "    except Exception:\n" +
        "        pos = None\n" +
        "    ref = raw.info.get('custom_ref_applied', False)\n" +
        "    duration_s = float(data.shape[1]) / fs if fs > 0 else 0.0\n" +
        "    return {\n" +
        "        'channels': ch_names,\n" +
        "        'channel_positions': pos,\n" +
        "        'sample_rate': fs,\n" +
        "        'raw_arrays': data.tolist(),\n" +
        "        'metadata': {\n" +
        "            'recording_duration_s': duration_s,\n" +
        "            'reference': 'custom_ref_applied' if ref else 'unknown',\n" +
        "            'filtering_applied': filt_applied,\n" +
        "            'filter_band_hz': filter_band,\n" +
        "            'ica_applied': ica_applied,\n" +
        "            'asr_applied': asr_applied,\n" +
        "            'timestamp': now_iso(),\n" +
        "            'source_format': fmt,\n" +
        "            'source_path': input_path,\n" +
        "            'mne_version': MNE_VERSION,\n" +
        "            'channel_count': len(ch_names),\n" +
        "            'sample_count': int(data.shape[1])\n" +
        "        }\n" +
        "    }\n" +
        "\n" +
        "def ingest_no_mne_abort(input_path):\n" +
        "    msg = ('ABORT_NO_MNE: helper requires mne (and optionally scipy).\\n' +\n" +
        "           '  install: pip install mne scipy\\n' +\n" +
        "           f'  input: {input_path}\\n' +\n" +
        "           '  fallback: synthetic selftest (--selftest) does not need mne.')\n" +
        "    print(msg, file=sys.stderr); sys.exit(3)\n" +
        "\n" +
        "def cmd_run(input_path, output_path, mode, channel_count_str, sample_rate_arg, do_ica_str, do_asr_str, schema, spec_doc):\n" +
        "    if not os.path.exists(input_path):\n" +
        "        print(f'ERR: missing input {input_path}', file=sys.stderr); sys.exit(2)\n" +
        "    try: channel_count = int(channel_count_str) if channel_count_str else 16\n" +
        "    except Exception: channel_count = 16\n" +
        "    do_ica = (do_ica_str == '1' or do_ica_str.lower() == 'true')\n" +
        "    do_asr = (do_asr_str == '1' or do_asr_str.lower() == 'true')\n" +
        "    if not HAVE_MNE: ingest_no_mne_abort(input_path)\n" +
        "    out = ingest_with_mne(input_path, mode, channel_count, sample_rate_arg, do_ica, do_asr)\n" +
        "    out['schema'] = schema\n" +
        "    out['spec_doc'] = spec_doc\n" +
        "    out['mode'] = mode\n" +
        "    out['raw10_honest'] = 'prototype ingest; phenomenal correlate measurement only; Hard Problem 우회 X'\n" +
        "    with open(output_path, 'w') as f: json.dump(out, f, indent=2)\n" +
        "    print(f'output_path={output_path}')\n" +
        "    print(f'channels={out[\"metadata\"][\"channel_count\"]}')\n" +
        "    print(f'sample_rate={out[\"sample_rate\"]}')\n" +
        "    print(f'samples={out[\"metadata\"][\"sample_count\"]}')\n" +
        "    print(f'duration_s={out[\"metadata\"][\"recording_duration_s\"]:.3f}')\n" +
        "    print(f'mode={mode}')\n" +
        "    print(f'mne_version={MNE_VERSION}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def cmd_selftest():\n" +
        "    # Synthetic 16ch × 1s × 250Hz signal generation + ingest (no MNE required).\n" +
        "    rng = np.random.default_rng(20260425)\n" +
        "    fs = 250.0; n = int(fs * 1.0)\n" +
        "    t = np.arange(n) / fs\n" +
        "    eeg = np.zeros((16, n), dtype=np.float32)\n" +
        "    for ch in range(16):\n" +
        "        eeg[ch] = (0.6 * np.sin(2 * np.pi * (8 + ch * 0.5) * t) +\n" +
        "                   0.4 * rng.standard_normal(n)).astype(np.float32)\n" +
        "    if HAVE_SCIPY:\n" +
        "        eeg_filt, applied = bandpass_scipy(eeg.astype(np.float64), fs)\n" +
        "        eeg_filt = eeg_filt.astype(np.float32)\n" +
        "    else:\n" +
        "        eeg_filt = eeg; applied = False\n" +
        "    out = {\n" +
        "        'schema': 'anima/eeg_recording/1',\n" +
        "        'spec_doc': 'tool/an11_b_eeg_ingest.hexa selftest',\n" +
        "        'mode': 'selftest_synthetic',\n" +
        "        'channels': DEFAULT_10_20_16,\n" +
        "        'channel_positions': None,\n" +
        "        'sample_rate': fs,\n" +
        "        'raw_arrays': eeg_filt.tolist(),\n" +
        "        'metadata': {\n" +
        "            'recording_duration_s': float(n)/fs,\n" +
        "            'reference': 'synthetic_none',\n" +
        "            'filtering_applied': bool(applied),\n" +
        "            'filter_band_hz': [1.0, 45.0] if applied else None,\n" +
        "            'ica_applied': False,\n" +
        "            'asr_applied': False,\n" +
        "            'timestamp': now_iso(),\n" +
        "            'source_format': 'synthetic',\n" +
        "            'source_path': '<synthetic>',\n" +
        "            'mne_version': MNE_VERSION,\n" +
        "            'channel_count': 16,\n" +
        "            'sample_count': n\n" +
        "        },\n" +
        "        'raw10_honest': 'synthetic selftest; not phenomenal data'\n" +
        "    }\n" +
        "    # validation invariants\n" +
        "    assert len(out['raw_arrays']) == 16, 'channel count mismatch'\n" +
        "    assert len(out['raw_arrays'][0]) == n, 'sample count mismatch'\n" +
        "    assert out['sample_rate'] == 250.0\n" +
        "    s = json.dumps(out)\n" +
        "    assert len(s) > 0\n" +
        "    print(f'selftest=ok')\n" +
        "    print(f'channels={len(out[\"channels\"])}')\n" +
        "    print(f'sample_rate={out[\"sample_rate\"]}')\n" +
        "    print(f'samples={n}')\n" +
        "    print(f'mne_available={HAVE_MNE}')\n" +
        "    print(f'mne_version={MNE_VERSION}')\n" +
        "    print(f'scipy_available={HAVE_SCIPY}')\n" +
        "    print(f'filtering_applied={applied}')\n" +
        "    print(f'json_payload_bytes={len(s)}')\n" +
        "    print('DONE')\n" +
        "\n" +
        "def main():\n" +
        "    if len(sys.argv) < 2:\n" +
        "        print('usage: helper <run|selftest> ...', file=sys.stderr); sys.exit(2)\n" +
        "    op = sys.argv[1]\n" +
        "    if op == 'run':\n" +
        "        # input output mode channel_count sample_rate ica asr schema spec_doc\n" +
        "        cmd_run(sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6], sys.argv[7], sys.argv[8], sys.argv[9], sys.argv[10])\n" +
        "    elif op == 'selftest':\n" +
        "        cmd_selftest()\n" +
        "    else:\n" +
        "        print(f'unknown op: {op}', file=sys.stderr); sys.exit(2)\n" +
        "\n" +
        "if __name__ == '__main__': main()\n"
    write_file(HELPER_PATH, src)
}

fn _run_helper(args: string) -> list {
    let cmd = "python3 " + HELPER_PATH + " " + args
    let r = exec_with_status(cmd)
    return [to_string(r[0]).trim(), to_int(r[1])]
}

fn main() {
    let av = argv()
    let mut input = ""
    let mut output = ""
    let mut mode = "raw"
    let mut channel_count = "16"
    let mut sample_rate = "auto"
    let mut do_ica = "0"
    let mut do_asr = "0"
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--input" && i + 1 < len(av) { input = av[i+1]; i = i + 2; continue }
        if a == "--output" && i + 1 < len(av) { output = av[i+1]; i = i + 2; continue }
        if a == "--mode" && i + 1 < len(av) { mode = av[i+1]; i = i + 2; continue }
        if a == "--channel-count" && i + 1 < len(av) { channel_count = av[i+1]; i = i + 2; continue }
        if a == "--sample-rate" && i + 1 < len(av) { sample_rate = av[i+1]; i = i + 2; continue }
        if a == "--ica" { do_ica = "1"; i = i + 1; continue }
        if a == "--asr" { do_asr = "1"; i = i + 1; continue }
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }

    _write_helper()

    if selftest {
        println("── an11_b_eeg_ingest selftest ──")
        let r = _run_helper("selftest")
        println(r[0])
        if r[1] != 0 { eprintln("selftest FAILED (exit " + to_string(r[1]) + ")"); exit(1) }
        if _kv_lookup(r[0], "selftest") != "ok" { eprintln("selftest marker missing"); exit(1) }
        println("selftest: OK")
        exit(0)
    }

    if input == "" || output == "" {
        eprintln("ABORT: --input <path.{bdf|edf|fif}> --output <path> required (or --selftest).")
        exit(2)
    }
    if !file_exists(input) {
        eprintln("ABORT: missing input " + input)
        exit(2)
    }
    if mode != "raw" && mode != "preprocessed" {
        eprintln("ABORT: --mode must be raw|preprocessed (got " + mode + ").")
        exit(2)
    }

    println("── an11_b_eeg_ingest ──")
    println("input:  " + input)
    println("output: " + output)
    println("mode:   " + mode)

    let args = "run " +
        _sh_quote(input) + " " +
        _sh_quote(output) + " " +
        _sh_quote(mode) + " " +
        _sh_quote(channel_count) + " " +
        _sh_quote(sample_rate) + " " +
        _sh_quote(do_ica) + " " +
        _sh_quote(do_asr) + " " +
        _sh_quote(SCHEMA) + " " +
        _sh_quote(SPEC_DOC)
    let r = _run_helper(args)
    let out = r[0]
    let st  = r[1]
    if st == 3 {
        eprintln(out)
        eprintln("HINT: pip install mne scipy")
        exit(3)
    }
    if st != 0 { eprintln("ABORT: helper run exited " + to_string(st)); eprintln(out); exit(2) }
    println(out)
    println("")
    println("wrote " + output)
    exit(0)
}

main()
