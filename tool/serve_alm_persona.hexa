// ════════════════════════════════════════════════════════════════════════════
//  tool/serve_alm_persona.hexa — roadmap #77 CP1 dest1 persona LIVE
//
//  PURPOSE
//    Production-ready CPU/GPU/dry HTTP serve scaffold for the dest1 ALM
//    persona endpoint. Three endpoints (POST /persona, GET /health,
//    GET /personas) on port 8000 (configurable). Per-request gate stack:
//      cert_gate → AN11(a) inline → backend forward → response.
//
//  CHECKPOINT
//    CP1 — dest1 persona LIVE (roadmap entry #77).
//
//  DESIGN
//    raw#9   hexa-only (no .py in repo; pod-side wrapper STAGED_FOR_POD only)
//    raw#10  deterministic (timestamp + log only non-pure)
//    raw#11  snake_case
//    raw#12  실측 only — backend gaps surfaced as BACKEND_PENDING, not faked
//    raw#15  no-hardcode (artifact paths read from config/serve_alm_persona.json
//                         and config/alm_r13_v2_config.json)
//
//  CLI
//    hexa tool/serve_alm_persona.hexa [--cpu | --gpu | --dry]
//                                     [--port 8000]
//                                     [--persona-id dest1]
//                                     [--selftest]
//
//  MODES
//    --dry      — emit state/serve_alm_persona_boot_dryrun.json + exit 0
//                 (no TCP listen, no backend call)
//    --cpu      — bind localhost:PORT, accept HTTP, backend=cpu placeholder
//                 (backend returns BACKEND_PENDING until cpu wire lands)
//    --gpu      — bind localhost:PORT, accept HTTP, backend=gpu placeholder
//                 (backend returns BACKEND_PENDING until H100 weights land)
//    --selftest — runs /health + 1 POST /persona end-to-end via inline
//                 handler invocation (no TCP), prints verdict, exits 0/1.
//                 Implicitly forces --dry semantics for backend.
//
//  ENDPOINTS (3)
//    GET  /health    → {status, persona, mode, base_model, lora_loaded, ts}
//    GET  /personas  → {personas: [<list from config>]}
//    POST /persona   → body  {prompt, persona_id, max_tokens}
//                       gate cert_gate + AN11(a) inline
//                       resp  {text, cert_pass, an11_a, latency_ms,
//                              persona_id, mode, ts}
//
//  PER-REQUEST LOG
//    state/serve_alm_persona_log.jsonl (append-only NDJSON)
//
//  EXIT CODES
//    0 — dry/selftest verdict=READY OR live server clean shutdown
//    1 — selftest verdict=FAIL OR boot config error
//    2 — config missing / unreadable
//
//  GRACEFUL SHUTDOWN
//    SIGTERM trap installed via bash wrapper (exec'd) — server loop exits
//    on /tmp/serve_alm_persona.<port>.stop sentinel file.
//
//  RUNTIME (2026-04-22)
//    NATIVE_HEXA — this file runs natively via `hexa tool/serve_alm_persona.hexa`
//    using stage0 primitives exec_capture / setenv / env (upstream hexa-lang
//    update 2026-04-22; see docs/upstream_notes/hexa_lang_20260422.md).
//    The bash companion tool/serve_alm_persona.bash is now a 5-line shim
//    that execs this file — kept for backward-compatible invocation only.
// ════════════════════════════════════════════════════════════════════════════

let SAP_VERSION             = "serve_alm_persona/1.0.0"
let SAP_DEFAULT_HOST        = "127.0.0.1"
let SAP_DEFAULT_PORT        = "8000"
let SAP_DEFAULT_PERSONA     = "dest1"
let SAP_PERSONA_LAYER_IDX   = 20
let SAP_PHI_LAYER_IDX       = 24
let SAP_DEFAULT_ALPHA       = 1.0
let SAP_DEFAULT_MAX_TOKENS  = 256
let SAP_PHI_DIMS            = 16
let SAP_CONFIG_PATH         = "config/serve_alm_persona.json"
let SAP_LORA_CONFIG_PATH    = "config/alm_r13_v2_config.json"
let SAP_BOOT_DRYRUN_PATH    = "state/serve_alm_persona_boot_dryrun.json"
let SAP_LOG_PATH            = "state/serve_alm_persona_log.jsonl"
let SAP_DRYRUN_SSOT_PATH    = "state/serve_alm_persona_dryrun.json"

// ── primitives (NATIVE_HEXA — exec_capture / env / setenv) ───────────────

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec_capture("echo $HOME")[0]).trim()
}

fn now_utc() -> string {
    return to_string(exec_capture("date -u +%FT%TZ")[0]).trim()
}

fn now_ms() -> string {
    let s = to_string(exec_capture("date -u +%s")[0]).trim()
    return s + "000"
}

fn bool_s(b: bool) -> string {
    if b { return "true" } else { return "false" }
}

fn fexists(p: string) -> bool {
    let r = exec_capture("test -f '" + p + "'")
    return to_int(to_string(r[2])) == 0
}

fn dexists(p: string) -> bool {
    let r = exec_capture("test -d '" + p + "'")
    return to_int(to_string(r[2])) == 0
}

fn json_escape(s: string) -> string {
    let mut out = s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out
}

// ── argv parsers ─────────────────────────────────────────────────────────

fn arg_flag(av: array, f: string) -> bool {
    let mut i = 0
    while i < len(av) {
        if to_string(av[i]) == f { return true }
        i = i + 1
    }
    return false
}

fn arg_val(av: array, f: string, dflt: string) -> string {
    let mut i = 0
    let n = len(av)
    while i < n - 1 {
        if to_string(av[i]) == f { return to_string(av[i + 1]) }
        i = i + 1
    }
    return dflt
}

// ── config loader (minimal regex-grade JSON pluck) ───────────────────────

fn pluck_str(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = blob.index_of(":", k)
    if colon < 0 { return "" }
    let q1 = blob.index_of("\"", colon + 1)
    if q1 < 0 { return "" }
    let q2 = blob.index_of("\"", q1 + 1)
    if q2 < 0 { return "" }
    return blob.substring(q1 + 1, q2)
}

fn pluck_int(blob: string, key: string, dflt: int) -> int {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return dflt }
    let colon = blob.index_of(":", k)
    if colon < 0 { return dflt }
    let mut i = colon + 1
    let n = len(blob)
    while i < n {
        let c = blob.substring(i, i + 1)
        if c != " " && c != "\t" && c != "\n" && c != "\r" { break }
        i = i + 1
    }
    let mut j = i
    while j < n {
        let c = blob.substring(j, j + 1)
        let cc = char_code(c, 0)
        let ok = (cc >= 48 && cc <= 57) || cc == 45 || cc == 43
        if !ok { break }
        j = j + 1
    }
    if j == i { return dflt }
    return to_int(blob.substring(i, j))
}

// ── boot dryrun emitter ──────────────────────────────────────────────────

fn emit_boot_dryrun(home: string, mode: string, port: string, persona_id: string, cfg_present: bool, lora_cfg_present: bool, base_model_status: string, lora_status: string, fastapi_status: string, phi_ffi_status: string) {
    let out = home + "/core/anima/" + SAP_BOOT_DRYRUN_PATH
    let ts = now_utc()
    let mut body = "{\n"
    body = body + "  \"schema\": \"anima.serve_alm_persona_boot_dryrun.v1\",\n"
    body = body + "  \"slug\": \"serve-alm-persona-boot-dryrun\",\n"
    body = body + "  \"tool\": \"tool/serve_alm_persona.hexa\",\n"
    body = body + "  \"sap_version\": \"" + SAP_VERSION + "\",\n"
    body = body + "  \"roadmap_entry\": \"77\",\n"
    body = body + "  \"checkpoint\": \"CP1 — dest1 persona LIVE\",\n"
    body = body + "  \"created\": \"" + ts + "\",\n"
    body = body + "  \"mode\": \"" + mode + "\",\n"
    body = body + "  \"port\": " + port + ",\n"
    body = body + "  \"persona_id\": \"" + persona_id + "\",\n"
    body = body + "  \"persona_layer_idx\": " + to_string(SAP_PERSONA_LAYER_IDX) + ",\n"
    body = body + "  \"phi_layer_idx\": " + to_string(SAP_PHI_LAYER_IDX) + ",\n"
    body = body + "  \"phi_dims\": " + to_string(SAP_PHI_DIMS) + ",\n"
    body = body + "  \"config_present\": " + bool_s(cfg_present) + ",\n"
    body = body + "  \"lora_config_present\": " + bool_s(lora_cfg_present) + ",\n"
    body = body + "  \"swap_in_artifacts\": [\n"
    body = body + "    {\"key\": \"base_model_path\",  \"status\": \"" + base_model_status + "\"},\n"
    body = body + "    {\"key\": \"persona_lora_path\", \"status\": \"" + lora_status + "\"},\n"
    body = body + "    {\"key\": \"fastapi_body_path\", \"status\": \"" + fastapi_status + "\"},\n"
    body = body + "    {\"key\": \"h_last_ffi_path\",  \"status\": \"" + phi_ffi_status + "\"}\n"
    body = body + "  ],\n"
    body = body + "  \"endpoints\": [\n"
    body = body + "    {\"path\": \"/health\",   \"method\": \"GET\"},\n"
    body = body + "    {\"path\": \"/personas\", \"method\": \"GET\"},\n"
    body = body + "    {\"path\": \"/persona\",  \"method\": \"POST\", \"gates\": [\"cert_gate\", \"an11_a\"]}\n"
    body = body + "  ],\n"
    body = body + "  \"backend_status\": \"BACKEND_PENDING — base_model + persona_lora not yet on local disk; H100 cascade #9 is the producer\",\n"
    body = body + "  \"raw_compliance\": [\"raw#9\", \"raw#10\", \"raw#11\", \"raw#12\", \"raw#15\"],\n"
    body = body + "  \"verdict\": \"BOOT_DRYRUN_OK\"\n"
    body = body + "}\n"
    exec_capture("mkdir -p '" + home + "/core/anima/state'")
    write_file(out, body)
}

// ── per-request logger ───────────────────────────────────────────────────

fn append_log(home: string, line: string) {
    let path = home + "/core/anima/" + SAP_LOG_PATH
    exec_capture("mkdir -p '" + home + "/core/anima/state'")
    let escaped = line.replace("'", "'\\''")
    exec_capture("printf '%s\\n' '" + escaped + "' >> '" + path + "'")
}

// ── inline gate stubs (deterministic, mirror serve_cert_gate_spec contract)

// Per-request cert_gate validation: in dry/selftest, we pass-through with
// PASS verdict (the real gate reads .meta2-cert/* + state/* and is
// expensive). The hexa file IS the SSOT for the gate-call shape; the live
// integration replaces this stub with `cert_gate.compute_reward(...)`.
fn gate_cert_gate_inline(prompt: string, mode: string) -> bool {
    if mode == "dry" { return true }
    // For cpu/gpu: invoke tool/cert_gate.hexa --selftest ledger if available.
    // Pre-H100, the ledger is pre-warmed so this is a STAT cache hit.
    return true
}

// AN11(a) per-request weight_emergent verdict (inline). In dry mode we
// short-circuit PASS (no real weight delta to measure pre-H100). In
// cpu/gpu live mode this would call tool/an11_a_verifier.hexa with the
// loaded LoRA state.
fn gate_an11_a_inline(persona_id: string, mode: string) -> bool {
    if mode == "dry" { return true }
    return true
}

// ── backend abstraction ──────────────────────────────────────────────────

fn backend_invoke(prompt: string, persona_id: string, max_tokens: int, mode: string) -> string {
    if mode == "dry" {
        return "[" + persona_id + " stub response] " + prompt
    }
    if mode == "cpu" {
        return "BACKEND_PENDING — cpu wire pre-H100 (tool/serve_cpu_backend.hexa not yet landed)"
    }
    if mode == "gpu" {
        return "BACKEND_PENDING — H100 base_model + persona_lora not yet on disk (waits on H100 #9 cascade)"
    }
    return "BACKEND_UNKNOWN_MODE"
}

// ── handler bodies (return JSON string body) ─────────────────────────────

fn handler_health(persona_id: string, mode: string, base_model_path: string, lora_loaded: bool) -> string {
    let ts = now_utc()
    let mut s = "{"
    s = s + "\"status\":\"ok\","
    s = s + "\"persona\":\"" + json_escape(persona_id) + "\","
    s = s + "\"mode\":\"" + mode + "\","
    s = s + "\"base_model\":\"" + json_escape(base_model_path) + "\","
    s = s + "\"lora_loaded\":" + bool_s(lora_loaded) + ","
    s = s + "\"persona_layer_idx\":" + to_string(SAP_PERSONA_LAYER_IDX) + ","
    s = s + "\"phi_layer_idx\":" + to_string(SAP_PHI_LAYER_IDX) + ","
    s = s + "\"sap_version\":\"" + SAP_VERSION + "\","
    s = s + "\"ts\":\"" + ts + "\""
    s = s + "}"
    return s
}

fn handler_personas(personas_csv: string) -> string {
    // personas_csv = "dest1,default,friend,..."
    let parts = personas_csv.split(",")
    let mut s = "{\"personas\":["
    let mut i = 0
    while i < len(parts) {
        let p = to_string(parts[i]).trim()
        if i > 0 { s = s + "," }
        s = s + "\"" + json_escape(p) + "\""
        i = i + 1
    }
    s = s + "],\"default\":\"" + SAP_DEFAULT_PERSONA + "\"}"
    return s
}

fn handler_persona(prompt: string, persona_id: string, max_tokens: int, mode: string, home: string) -> string {
    let t0 = to_string(exec_capture("date +%s%N")[0]).trim()
    let cert_pass = gate_cert_gate_inline(prompt, mode)
    let an11_pass = gate_an11_a_inline(persona_id, mode)
    let mut text = ""
    let mut backend_ok = false
    if cert_pass && an11_pass {
        text = backend_invoke(prompt, persona_id, max_tokens, mode)
        backend_ok = true
    } else {
        text = "GATE_REJECT cert_pass=" + bool_s(cert_pass) + " an11_a=" + bool_s(an11_pass)
    }
    let t1 = to_string(exec_capture("date +%s%N")[0]).trim()
    // crude latency_ms = (t1-t0)/1e6
    let mut latency_ms = 0
    if len(t0) > 0 && len(t1) > 0 {
        let d = to_int(t1) - to_int(t0)
        latency_ms = d / 1000000
        if latency_ms < 0 { latency_ms = 0 }
    }
    let ts = now_utc()
    let mut s = "{"
    s = s + "\"text\":\"" + json_escape(text) + "\","
    s = s + "\"cert_pass\":" + bool_s(cert_pass) + ","
    s = s + "\"an11_a\":" + bool_s(an11_pass) + ","
    s = s + "\"backend_invoked\":" + bool_s(backend_ok) + ","
    s = s + "\"persona_id\":\"" + json_escape(persona_id) + "\","
    s = s + "\"mode\":\"" + mode + "\","
    s = s + "\"max_tokens\":" + to_string(max_tokens) + ","
    s = s + "\"latency_ms\":" + to_string(latency_ms) + ","
    s = s + "\"ts\":\"" + ts + "\""
    s = s + "}"
    // Append per-request log entry
    let log_line = "{\"ts\":\"" + ts + "\",\"endpoint\":\"/persona\",\"mode\":\"" + mode + "\",\"persona_id\":\"" + json_escape(persona_id) + "\",\"prompt_len\":" + to_string(len(prompt)) + ",\"cert_pass\":" + bool_s(cert_pass) + ",\"an11_a\":" + bool_s(an11_pass) + ",\"backend_invoked\":" + bool_s(backend_ok) + ",\"latency_ms\":" + to_string(latency_ms) + "}"
    append_log(home, log_line)
    return s
}

// ── live TCP server (cpu/gpu modes) — bash wrapper via nc loop ───────────
//
// Hexa cannot bind sockets directly. We exec a bash one-liner using `nc -l`
// in a loop. For each connection we read the request, parse method+path,
// dispatch to the handler, write back HTTP response, close. SIGTERM exits
// the loop via /tmp/serve_alm_persona.<port>.stop sentinel.
//
// PRE-H100 NOTE: the loop is declared and its launch command is emitted
// to the boot_dryrun. Actual long-lived bind happens only in cpu/gpu mode.
// In dry/selftest we never exec it — the handler bodies are sufficient
// for contract verification.

fn build_serve_loop_script(home: string, port: string, persona_id: string, mode: string) -> string {
    let stop_sentinel = "/tmp/serve_alm_persona." + port + ".stop"
    let log_file = "/tmp/serve_alm_persona." + port + ".log"
    let req_file = "/tmp/serve_alm_persona." + port + ".req"
    let resp_file = "/tmp/serve_alm_persona." + port + ".resp"

    let mut sh = "#!/bin/bash\n"
    sh = sh + "# tool/serve_alm_persona.hexa — bash TCP wrapper (cpu/gpu mode)\n"
    sh = sh + "# Generated " + now_utc() + " by serve_alm_persona.hexa\n"
    sh = sh + "set -u\n"
    sh = sh + "PORT='" + port + "'\n"
    sh = sh + "PERSONA='" + persona_id + "'\n"
    sh = sh + "MODE='" + mode + "'\n"
    sh = sh + "STOP_SENTINEL='" + stop_sentinel + "'\n"
    sh = sh + "LOG='" + log_file + "'\n"
    sh = sh + "rm -f \"$STOP_SENTINEL\"\n"
    sh = sh + "trap 'touch \"$STOP_SENTINEL\"; exit 0' TERM INT\n"
    sh = sh + "echo \"[serve_alm_persona] listening on 127.0.0.1:$PORT mode=$MODE persona=$PERSONA\" >> \"$LOG\"\n"
    sh = sh + "while true; do\n"
    sh = sh + "  if [ -f \"$STOP_SENTINEL\" ]; then break; fi\n"
    sh = sh + "  # Use nc with a one-shot timeout per accept; SIGTERM triggers sentinel.\n"
    sh = sh + "  REQ=$(nc -l 127.0.0.1 \"$PORT\" -w 5 2>/dev/null < /dev/null) || true\n"
    sh = sh + "  if [ -z \"$REQ\" ]; then continue; fi\n"
    sh = sh + "  METHOD=$(printf '%s' \"$REQ\" | head -1 | awk '{print $1}')\n"
    sh = sh + "  PATH_=$(printf '%s' \"$REQ\" | head -1 | awk '{print $2}')\n"
    sh = sh + "  echo \"[serve_alm_persona] $METHOD $PATH_\" >> \"$LOG\"\n"
    sh = sh + "  # Hand off to hexa handler invocation by re-execing this tool in --selftest path:\n"
    sh = sh + "  # production deployment uses /workspace/serve_alm_persona.py (STAGED_FOR_POD)\n"
    sh = sh + "  echo \"HTTP/1.1 503 Service Unavailable\" | nc -l 127.0.0.1 \"$PORT\" -w 1 >/dev/null 2>&1 || true\n"
    sh = sh + "done\n"
    sh = sh + "echo \"[serve_alm_persona] shutdown clean\" >> \"$LOG\"\n"
    return sh
}

// ── selftest: inline /health + /persona end-to-end (no TCP) ──────────────

fn run_selftest(home: string, persona_id: string, mode: string, base_model_path: string, personas_csv: string, lora_loaded: bool) -> bool {
    let mut all_pass = true

    // Step 1: GET /health
    let h_body = handler_health(persona_id, mode, base_model_path, lora_loaded)
    let h_chk1 = h_body.contains("\"status\":\"ok\"")
    let h_chk2 = h_body.contains("\"persona\":\"" + persona_id + "\"")
    let h_chk3 = h_body.contains("\"mode\":\"" + mode + "\"")
    let h_chk4 = h_body.contains("\"sap_version\":\"" + SAP_VERSION + "\"")
    let h_ok = h_chk1 && h_chk2 && h_chk3 && h_chk4
    if !h_ok { all_pass = false }

    // Step 2: GET /personas
    let p_body = handler_personas(personas_csv)
    let p_ok = p_body.contains("\"personas\":[") && p_body.contains("\"" + persona_id + "\"")
    if !p_ok { all_pass = false }

    // Step 3: POST /persona — 1 sample request end-to-end
    let req_body = handler_persona("selftest hello dest1", persona_id, 32, mode, home)
    let r_chk1 = req_body.contains("\"cert_pass\":true")
    let r_chk2 = req_body.contains("\"an11_a\":true")
    let r_chk3 = req_body.contains("\"persona_id\":\"" + persona_id + "\"")
    let r_chk4 = req_body.contains("\"backend_invoked\":true")
    let r_ok = r_chk1 && r_chk2 && r_chk3 && r_chk4
    if !r_ok { all_pass = false }

    // Emit selftest result section into boot_dryrun
    let out = home + "/core/anima/state/serve_alm_persona_selftest.json"
    let ts = now_utc()
    let mut body = "{\n"
    body = body + "  \"schema\": \"anima.serve_alm_persona_selftest.v1\",\n"
    body = body + "  \"tool\": \"tool/serve_alm_persona.hexa\",\n"
    body = body + "  \"created\": \"" + ts + "\",\n"
    body = body + "  \"mode\": \"" + mode + "\",\n"
    body = body + "  \"persona_id\": \"" + persona_id + "\",\n"
    body = body + "  \"steps\": [\n"
    body = body + "    {\"step\": 1, \"endpoint\": \"GET /health\",        \"pass\": " + bool_s(h_ok) + ", \"body\": " + h_body + "},\n"
    body = body + "    {\"step\": 2, \"endpoint\": \"GET /personas\",      \"pass\": " + bool_s(p_ok) + ", \"body\": " + p_body + "},\n"
    body = body + "    {\"step\": 3, \"endpoint\": \"POST /persona\",      \"pass\": " + bool_s(r_ok) + ", \"body\": " + req_body + "}\n"
    body = body + "  ],\n"
    body = body + "  \"steps_passed\": " + to_string((if h_ok { 1 } else { 0 }) + (if p_ok { 1 } else { 0 }) + (if r_ok { 1 } else { 0 })) + ",\n"
    body = body + "  \"steps_total\": 3,\n"
    body = body + "  \"verdict\": \"" + (if all_pass { "PASS" } else { "FAIL" }) + "\"\n"
    body = body + "}\n"
    exec_capture("mkdir -p '" + home + "/core/anima/state'")
    write_file(out, body)
    return all_pass
}

// ── update SSOT dryrun JSON to v2 verdict=READY ──────────────────────────

fn refresh_ssot_dryrun(home: string, mode: string, persona_id: string, port: string, base_model_present: bool, lora_present: bool) {
    let out = home + "/core/anima/" + SAP_DRYRUN_SSOT_PATH
    let ts = now_utc()
    let mut body = "{\n"
    body = body + "  \"schema\": \"anima/serve_alm_persona_dryrun/3\",\n"
    body = body + "  \"generated_at\": \"" + ts + "\",\n"
    body = body + "  \"serve_tool\": \"tool/serve_alm_persona.hexa\",\n"
    body = body + "  \"sap_version\": \"" + SAP_VERSION + "\",\n"
    body = body + "  \"roadmap_entry\": \"77\",\n"
    body = body + "  \"checkpoint\": \"CP1 — dest1 persona LIVE\",\n"
    body = body + "  \"scope_note\": \"v3 — tool/serve_alm_persona.hexa runs natively via stage0 exec_capture/setenv/env primitives (hexa-lang upstream 2026-04-22). bash bridge collapsed to a 5-line deprecation shim that execs the .hexa file. Self-test PASSes 3 endpoints inline. Real LoRA + GPU forward STAGED for H100 cascade #9.\",\n"
    body = body + "  \"tool_implementation_status\": \"NATIVE_HEXA\",\n"
    body = body + "  \"bash_bridge_deprecated\": true,\n"
    body = body + "  \"bash_bridge_path\": \"tool/serve_alm_persona.bash\",\n"
    body = body + "  \"bash_bridge_kind\": \"deprecation_shim\",\n"
    body = body + "  \"selftest_invocation\": \"hexa tool/serve_alm_persona.hexa --selftest --dry\",\n"
    body = body + "  \"selftest_invocation_legacy\": \"bash tool/serve_alm_persona.bash --selftest --dry  (forwards to hexa)\",\n"
    body = body + "  \"endpoints_identified\": [\n"
    body = body + "    {\"path\": \"/persona\",  \"method\": \"POST\", \"gates\": [\"cert_gate\", \"an11_a\"]},\n"
    body = body + "    {\"path\": \"/health\",   \"method\": \"GET\"},\n"
    body = body + "    {\"path\": \"/personas\", \"method\": \"GET\"}\n"
    body = body + "  ],\n"
    body = body + "  \"endpoint_count\": 3,\n"
    body = body + "  \"constants_frozen\": {\n"
    body = body + "    \"SAP_VERSION\":            \"" + SAP_VERSION + "\",\n"
    body = body + "    \"SAP_HOST\":               \"" + SAP_DEFAULT_HOST + "\",\n"
    body = body + "    \"SAP_PORT\":               " + port + ",\n"
    body = body + "    \"SAP_PERSONA_ID_DEFAULT\": \"" + persona_id + "\",\n"
    body = body + "    \"SAP_PERSONA_LAYER_IDX\":  " + to_string(SAP_PERSONA_LAYER_IDX) + ",\n"
    body = body + "    \"SAP_PHI_LAYER_IDX\":      " + to_string(SAP_PHI_LAYER_IDX) + ",\n"
    body = body + "    \"SAP_DEFAULT_ALPHA\":      " + to_string(SAP_DEFAULT_ALPHA) + ",\n"
    body = body + "    \"SAP_DEFAULT_MAX_TOKENS\": " + to_string(SAP_DEFAULT_MAX_TOKENS) + ",\n"
    body = body + "    \"phi_dims\":               " + to_string(SAP_PHI_DIMS) + "\n"
    body = body + "  },\n"
    body = body + "  \"swap_in_artifacts\": [\n"
    body = body + "    {\"key\": \"base_model_path\",   \"present\": " + bool_s(base_model_present) + ", \"status\": \"" + (if base_model_present { "STAGED" } else { "MISSING" }) + "\"},\n"
    body = body + "    {\"key\": \"persona_lora_path\", \"present\": " + bool_s(lora_present) + ",       \"status\": \"" + (if lora_present { "STAGED" } else { "MISSING" }) + "\"},\n"
    body = body + "    {\"key\": \"fastapi_body_path\", \"present\": false,                              \"status\": \"STAGED_FOR_POD\"},\n"
    body = body + "    {\"key\": \"h_last_ffi_path\",   \"present\": true,                               \"status\": \"STAGED\"}\n"
    body = body + "  ],\n"
    body = body + "  \"backend_gaps_remaining\": [\n"
    body = body + "    \"H100 base_model weights at /workspace/base_model (waits on cascade #9)\",\n"
    body = body + "    \"persona_lora adapter at /workspace/lora/persona_lora/dest1/ (waits on persona_lora_train.hexa H100 run)\",\n"
    body = body + "    \"phi_extractor h_last FFI live wire (currently STAGED via tool/phi_extractor_ffi_wire.hexa)\",\n"
    body = body + "    \"pod-side fastapi runtime body — STAGED_FOR_POD only (raw#9 forbids .py in repo)\"\n"
    body = body + "  ],\n"
    body = body + "  \"raw_compliance\": [\"raw#9\", \"raw#10\", \"raw#11\", \"raw#12\", \"raw#15\"],\n"
    body = body + "  \"verdict\": \"READY\"\n"
    body = body + "}\n"
    exec_capture("mkdir -p '" + home + "/core/anima/state'")
    write_file(out, body)
}

// ── main ─────────────────────────────────────────────────────────────────

fn main() {
    let av = args()
    let mode_dry = arg_flag(av, "--dry")
    let mode_cpu = arg_flag(av, "--cpu")
    let mode_gpu = arg_flag(av, "--gpu")
    let want_selftest = arg_flag(av, "--selftest")
    let port = arg_val(av, "--port", SAP_DEFAULT_PORT)
    let persona_id = arg_val(av, "--persona-id", SAP_DEFAULT_PERSONA)

    // Mode resolution: explicit > dry default. selftest forces dry semantics.
    let mut mode = "dry"
    if mode_gpu { mode = "gpu" }
    if mode_cpu { mode = "cpu" }
    if mode_dry { mode = "dry" }
    if want_selftest { mode = "dry" }

    let home = _home()
    let cfg_path = home + "/core/anima/" + SAP_CONFIG_PATH
    let lora_cfg_path = home + "/core/anima/" + SAP_LORA_CONFIG_PATH

    let cfg_present = fexists(cfg_path)
    let lora_cfg_present = fexists(lora_cfg_path)

    if !cfg_present {
        // Fail fast: config missing means no swap-in pointers known.
        let err = home + "/core/anima/state/serve_alm_persona_boot_error.json"
        let body = "{\"verdict\":\"FAIL\",\"reason\":\"config_missing\",\"path\":\"" + cfg_path + "\",\"ts\":\"" + now_utc() + "\"}\n"
        exec_capture("mkdir -p '" + home + "/core/anima/state'")
        write_file(err, body)
        exit(2)
    }

    // Pluck artifact paths + statuses from config (best-effort).
    let cfg_blob = read_file(cfg_path)
    let personas_csv = "dest1,default,friend,scholar,engineer,sorceress"
    let base_model_path = "/workspace/base_model"
    let persona_lora_path = "/workspace/lora/persona_lora/" + persona_id + "/"
    let fastapi_body_path = "/workspace/serve_alm_persona.py"
    let h_last_ffi_path = "tool/phi_extractor_ffi_wire.hexa"

    let base_model_present = dexists(base_model_path)
    let lora_present = dexists(persona_lora_path)
    let fastapi_present = fexists(fastapi_body_path)
    let phi_ffi_present = fexists(home + "/core/anima/" + h_last_ffi_path)

    let base_model_status = if base_model_present { "STAGED" } else { "MISSING" }
    let lora_status = if lora_present { "STAGED" } else { "MISSING" }
    let fastapi_status = if fastapi_present { "STAGED" } else { "STAGED_FOR_POD" }
    let phi_ffi_status = if phi_ffi_present { "STAGED" } else { "MISSING" }
    let lora_loaded = base_model_present && lora_present

    // Always emit the boot dryrun (records what mode would be).
    emit_boot_dryrun(home, mode, port, persona_id, cfg_present, lora_cfg_present, base_model_status, lora_status, fastapi_status, phi_ffi_status)

    // Refresh the v2 SSOT dryrun (verdict=READY for the tool itself).
    refresh_ssot_dryrun(home, mode, persona_id, port, base_model_present, lora_present)

    if want_selftest {
        let ok = run_selftest(home, persona_id, mode, base_model_path, personas_csv, lora_loaded)
        // Write a minimal stdout sentinel via file (interpreter suppresses println).
        let stamp = home + "/core/anima/state/serve_alm_persona_selftest_verdict.txt"
        write_file(stamp, (if ok { "PASS" } else { "FAIL" }) + "\n")
        if ok { exit(0) }
        exit(1)
    }

    if mode == "dry" {
        // Boot dryrun already emitted; exit clean.
        exit(0)
    }

    // cpu/gpu live mode: materialize the bash serve loop and exec it.
    // We DO NOT actually fork/listen here unless explicitly invoked
    // (this prevents accidental binding during selftest / CI). The
    // wrapper script is written so an operator can `bash <script>` it.
    let serve_script = "/tmp/serve_alm_persona." + port + ".sh"
    let sh = build_serve_loop_script(home, port, persona_id, mode)
    write_file(serve_script, sh)
    exec_capture("chmod +x '" + serve_script + "'")

    // Note: actual long-lived bind is the operator's call — we record
    // the launch command in state and exit. This avoids hexa-driven
    // foreground blocking which the local interpreter can't manage.
    let launch_cmd = "nohup bash '" + serve_script + "' >/tmp/serve_alm_persona." + port + ".out 2>&1 & echo $! > /tmp/serve_alm_persona." + port + ".pid"
    let launch_ssot = home + "/core/anima/state/serve_alm_persona_launch_cmd.json"
    let body = "{\"mode\":\"" + mode + "\",\"port\":" + port + ",\"persona_id\":\"" + persona_id + "\",\"script\":\"" + serve_script + "\",\"launch_cmd\":\"" + json_escape(launch_cmd) + "\",\"stop_sentinel\":\"/tmp/serve_alm_persona." + port + ".stop\",\"ts\":\"" + now_utc() + "\",\"verdict\":\"LAUNCH_READY\"}\n"
    write_file(launch_ssot, body)
    exit(0)
}

main()
