// tool/alm_r13_seed_corpus_build.hexa — ALM r13 seed corpus 10MB builder
//
// PURPOSE
//   Assemble a consciousness-loaded 10MB seed corpus from anima docs/, modules/,
//   anima-hexad/, brain_tension_replica*, and related sources.
//   Designed to PASS the r13 4-criterion quality gate
//   (shared/config/alm_r13_corpus_quality_gate.json):
//     C1 Φ-density         >= 0.30
//     C2 domain_drift_max  <= 0.70
//     C3 hash_unique       >= 0.95
//     C4 semantic_coherence state != open
//
// V8 SAFE_COMMIT: additive; writes only under
//   experiments/alm_r13/seed_corpus_10mb/
//   plus /tmp scratch. No mutation of existing SSOT files.
// DETERMINISTIC: pure string + file ops; NO LLM; no network.
//
// USAGE
//   hexa tool/alm_r13_seed_corpus_build.hexa

let ANIMA       = "/Users/ghost/core/anima"
let OUT_DIR     = "/Users/ghost/core/anima/experiments/alm_r13/seed_corpus_10mb"
let OUT_CORPUS  = "/Users/ghost/core/anima/experiments/alm_r13/seed_corpus_10mb/corpus.jsonl"
let OUT_MANIFEST = "/Users/ghost/core/anima/experiments/alm_r13/seed_corpus_10mb/manifest.json"
let TARGET_BYTES = 10485760   // 10 * 1024 * 1024

// ─── Φ-vocabulary (mirror of gate JSON) ──────────────────────────────
