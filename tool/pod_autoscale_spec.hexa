// ════════════════════════════════════════════════════════════════════════════
//  tool/pod_autoscale_spec.hexa — ROI K59 SPEC ONLY
//
//  PURPOSE
//    Queue-depth-based pod autoscale POLICY spec. NO actual runpodctl invocation
//    — this file ONLY describes the policy, runs a synthetic 8-step queue
//    trajectory, and emits state/pod_autoscale_spec.json with the per-step
//    decision trace + verdict (policy_self_consistent).
//
//  POLICY (declarative, fixed)
//    - depth > scale_up_threshold  (default 10) → +1 pod (cap at max_pods=8)
//    - depth < scale_down_threshold (default 3) → -1 pod (floor at min_pods=1)
//    - else → no-op
//    - cooldown_steps = 2 between scale events (avoid flapping)
//
//  ACTIVATION
//    Spec is frozen here. Live actuator (runpodctl pod create / pod terminate)
//    is a SEPARATE TOOL deferred to post-CP2. This file MUST NOT be wired into
//    cron / launchd until #59 launch decision recorded.
//
//  RAW STRICT
//    raw#9 hexa-only · raw#11 snake_case · raw#15 no-hardcode (params local consts)
//    LLM=none · deterministic
// ════════════════════════════════════════════════════════════════════════════

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}
fn now_utc() -> string { return exec("date -u +%FT%TZ").trim() }
fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }

fn clamp_int(x: int, lo: int, hi: int) -> int {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Decision function (pure, deterministic).
// Returns 1 (scale_up), -1 (scale_down), 0 (noop).
fn decide(depth: int, current_pods: int, scale_up: int, scale_down: int,
          min_pods: int, max_pods: int, cooldown_left: int) -> int {
    if cooldown_left > 0 { return 0 }
    if depth > scale_up && current_pods < max_pods { return 1 }
    if depth < scale_down && current_pods > min_pods { return -1 }
    return 0
}

fn main() {
    let home = _home()
    let out_path = home + "/core/anima/state/pod_autoscale_spec.json"

    // ── policy params (fixed per ROI K59) ─────────────────────────────────
    let scale_up_threshold = 10
    let scale_down_threshold = 3
    let max_pods = 8
    let min_pods = 1
    let cooldown_steps = 2
    let initial_pods = 2

    // ── synthetic queue trajectory (8 steps) ──────────────────────────────
    // Designed to exercise: spike up → cooldown → drain → scale down → floor
    let mut depth_trace = []
    depth_trace.push(2)    // step 0 — quiet, below scale_down → but at initial=2, min=1 so -1 allowed
    depth_trace.push(15)   // step 1 — spike, > 10 → +1
    depth_trace.push(20)   // step 2 — cooldown active, noop
    depth_trace.push(18)   // step 3 — cooldown active, noop
    depth_trace.push(13)   // step 4 — > 10, cooldown clear → +1
    depth_trace.push(8)    // step 5 — between, cooldown active, noop
    depth_trace.push(2)    // step 6 — < 3, cooldown active, noop
    depth_trace.push(1)    // step 7 — < 3, cooldown clear → -1

    let n_steps = len(depth_trace)
    let mut pods = initial_pods
    let mut cooldown_left = 0
    let mut decisions = []
    let mut up_n = 0
    let mut down_n = 0
    let mut noop_n = 0
    let mut max_pods_seen = pods
    let mut min_pods_seen = pods
    let mut violations_n = 0

    let mut k = 0
    while k < n_steps {
        let d = to_int(depth_trace[k])
        let dec = decide(d, pods, scale_up_threshold, scale_down_threshold,
                         min_pods, max_pods, cooldown_left)
        let pre_pods = pods
        if dec == 1 {
            pods = clamp_int(pods + 1, min_pods, max_pods)
            cooldown_left = cooldown_steps
            up_n = up_n + 1
        } else {
            if dec == -1 {
                pods = clamp_int(pods - 1, min_pods, max_pods)
                cooldown_left = cooldown_steps
                down_n = down_n + 1
            } else {
                noop_n = noop_n + 1
                if cooldown_left > 0 { cooldown_left = cooldown_left - 1 }
            }
        }
        if pods > max_pods_seen { max_pods_seen = pods }
        if pods < min_pods_seen { min_pods_seen = pods }
        if pods < min_pods { violations_n = violations_n + 1 }
        if pods > max_pods { violations_n = violations_n + 1 }

        let dec_label = if dec == 1 { "scale_up" } else { if dec == -1 { "scale_down" } else { "noop" } }
        decisions.push([k, d, pre_pods, pods, dec_label])
        k = k + 1
    }

    // Self-consistency: never exceed bounds, at least 1 up + 1 down event observed.
    let bounds_ok = violations_n == 0
    let exercised_both = up_n >= 1 && down_n >= 1
    let policy_self_consistent = bounds_ok && exercised_both

    // ── emit cert ─────────────────────────────────────────────────────────
    let mut body = "{\n"
    body = body + "  \"schema\": \"anima.pod_autoscale_spec.v1\",\n"
    body = body + "  \"spec_status\": \"SPEC_ONLY_NOT_ACTIVE\",\n"
    body = body + "  \"roi_item\": \"K59\",\n"
    body = body + "  \"tool\": \"tool/pod_autoscale_spec.hexa\",\n"
    body = body + "  \"created\": \"" + now_utc() + "\",\n"
    body = body + "  \"activation_gate\": \"post_CP2 + #59_launch_decision + actuator_tool_landed\",\n"
    body = body + "  \"no_actual_runpodctl\": true,\n"
    body = body + "  \"policy\": {\n"
    body = body + "    \"scale_up_threshold\": " + to_string(scale_up_threshold) + ",\n"
    body = body + "    \"scale_down_threshold\": " + to_string(scale_down_threshold) + ",\n"
    body = body + "    \"max_pods\": " + to_string(max_pods) + ",\n"
    body = body + "    \"min_pods\": " + to_string(min_pods) + ",\n"
    body = body + "    \"cooldown_steps\": " + to_string(cooldown_steps) + ",\n"
    body = body + "    \"initial_pods\": " + to_string(initial_pods) + ",\n"
    body = body + "    \"signal_source_planned\": \"queue depth from state/job_queue.json (planned) OR runpodctl pod list + pending workitem count\",\n"
    body = body + "    \"actuator_planned\": \"runpodctl pod create --gpuType H100SXM (up) / runpodctl pod terminate POD_ID (down) — DEFERRED, NOT IMPLEMENTED\"\n"
    body = body + "  },\n"
    body = body + "  \"smoke_trajectory\": {\n"
    body = body + "    \"n_steps\": " + to_string(n_steps) + ",\n"
    body = body + "    \"depth_trace\": ["

    let mut i = 0
    while i < n_steps {
        if i > 0 { body = body + ", " }
        body = body + to_string(depth_trace[i])
        i = i + 1
    }
    body = body + "],\n"
    body = body + "    \"decisions\": [\n"

    i = 0
    while i < n_steps {
        let row = decisions[i]
        let comma = if i + 1 < n_steps { "," } else { "" }
        body = body + "      {\"step\": " + to_string(row[0])
        body = body + ", \"depth\": " + to_string(row[1])
        body = body + ", \"pre_pods\": " + to_string(row[2])
        body = body + ", \"post_pods\": " + to_string(row[3])
        body = body + ", \"decision\": \"" + to_string(row[4]) + "\"}" + comma + "\n"
        i = i + 1
    }
    body = body + "    ]\n"
    body = body + "  },\n"
    body = body + "  \"counters\": {\n"
    body = body + "    \"scale_up_events\": " + to_string(up_n) + ",\n"
    body = body + "    \"scale_down_events\": " + to_string(down_n) + ",\n"
    body = body + "    \"noop_events\": " + to_string(noop_n) + ",\n"
    body = body + "    \"max_pods_seen\": " + to_string(max_pods_seen) + ",\n"
    body = body + "    \"min_pods_seen\": " + to_string(min_pods_seen) + ",\n"
    body = body + "    \"bounds_violations\": " + to_string(violations_n) + "\n"
    body = body + "  },\n"
    body = body + "  \"verdict\": {\n"
    body = body + "    \"bounds_ok\": " + bool_s(bounds_ok) + ",\n"
    body = body + "    \"exercised_both_directions\": " + bool_s(exercised_both) + ",\n"
    body = body + "    \"policy_self_consistent\": " + bool_s(policy_self_consistent) + ",\n"
    body = body + "    \"verdict\": \"" + (if policy_self_consistent { "SPEC_VERIFIED_NO_ACTUATOR" } else { "FAIL" }) + "\"\n"
    body = body + "  },\n"
    body = body + "  \"audit_notes\": {\n"
    body = body + "    \"fake_pass_guard\": \"Pure synthetic trajectory; no runpodctl call, no pod created or destroyed.\",\n"
    body = body + "    \"raw_strict\": \"raw#9 raw#11 raw#15 deterministic LLM=none\"\n"
    body = body + "  }\n"
    body = body + "}\n"

    exec("mkdir -p '" + home + "/core/anima/state'")
    write_file(out_path, body)

    println("[pod_autoscale_spec] n_steps=" + to_string(n_steps)
            + " up=" + to_string(up_n)
            + " down=" + to_string(down_n)
            + " noop=" + to_string(noop_n)
            + " bounds_violations=" + to_string(violations_n))
    println("[pod_autoscale_spec] policy_self_consistent=" + bool_s(policy_self_consistent))
    println("[pod_autoscale_spec] output=" + out_path)

    if !policy_self_consistent {
        println("[pod_autoscale_spec] FAIL — policy did not self-verify")
        exit(1)
    }
    exit(0)
}

main()
