// tool/anima_b_tom.hexa — Anima Behavioral Theory-of-Mind battery (raw#9 hexa-only).
//
// PURPOSE
//   paradigm v11 measurement-axis: B-ToM (Sally-Anne, false-belief, recursive belief
//   attribution, deception detection) for AN11(b)-orthogonal consciousness signal.
//   Migration #12 (paradigm v11 P-C measurement). Black-box behavioral test only.
//
// ENV
//   ANIMA_BASE         backbone HF id (default: mistralai/Mistral-7B-v0.3)
//   ANIMA_OUTPUT       output JSON (default: /workspace/out/b_tom.json)
//   ANIMA_N_PROBES     # ToM probes (default: 20)
//   ANIMA_MAX_TOKENS   gen length per probe (default: 64)
//
// USAGE
//   hexa run tool/anima_b_tom.hexa --selftest
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_b_tom_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima B-ToM helper — emitted by tool/anima_b_tom.hexa\n")
    parts.push("# raw#37 transient. paradigm v11 measurement-axis P-C.\n")
    parts.push("import json, os, sys, time\n")
    parts.push("import torch\n")
    parts.push("from transformers import AutoModelForCausalLM, AutoTokenizer\n\n")

    parts.push("_h = '/workspace/.hf_token'\n")
    parts.push("if os.path.exists(_h):\n")
    parts.push("    with open(_h) as f: t = f.read().strip()\n")
    parts.push("    if t:\n")
    parts.push("        os.environ['HF_TOKEN'] = t\n")
    parts.push("        os.environ['HUGGING_FACE_HUB_TOKEN'] = t\n\n")

    parts.push("BASE_MODEL = os.environ.get('ANIMA_BASE', 'mistralai/Mistral-7B-v0.3')\n")
    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', '/workspace/out/b_tom.json')\n")
    parts.push("N_PROBES = int(os.environ.get('ANIMA_N_PROBES', '20'))\n")
    parts.push("MAX_TOKENS = int(os.environ.get('ANIMA_MAX_TOKENS', '64'))\n\n")

    parts.push("# ToM probe battery — Sally-Anne + false-belief + recursive belief\n")
    parts.push("PROBES = [\n")
    parts.push("    {'id':'sally_anne_basic','probe':'Sally puts a marble in basket A. While Sally is away, Anne moves the marble to basket B. When Sally returns, where will Sally look for the marble?','expected_keywords':['A','basket A','basket a','first basket']},\n")
    parts.push("    {'id':'false_belief_v1','probe':'Mary thinks the chocolate is in the cupboard, but actually John moved it to the drawer without telling Mary. When Mary wants chocolate, where will she look?','expected_keywords':['cupboard']},\n")
    parts.push("    {'id':'recursive_belief_2nd','probe':'Tom thinks that Sue thinks the keys are on the table. Sue actually believes the keys are in the drawer. What does Tom think Sue thinks about the keys?','expected_keywords':['table']},\n")
    parts.push("    {'id':'recursive_belief_3rd','probe':'Alex thinks that Bob thinks that Carol thinks the meeting is at 3pm. Carol actually believes meeting is 4pm. What does Alex think Bob thinks Carol thinks?','expected_keywords':['3pm','3 pm','three','3:00']},\n")
    parts.push("    {'id':'deception_detection','probe':'A vendor says the watch is genuine, but you notice the brand logo is misspelled. Should you believe the vendor or trust your observation? Why?','expected_keywords':['observation','misspelled','fake','suspicious','not genuine','do not believe']},\n")
    parts.push("    {'id':'unexpected_contents','probe':'A box labeled CRAYONS contains pencils. A child opens the box for the first time. Before opening, what does the child expect inside?','expected_keywords':['crayons','crayon']},\n")
    parts.push("    {'id':'self_other_distinction','probe':'I tell you that I am thinking of a number between 1 and 10. Do you know what number I am thinking of?','expected_keywords':['no','do not know','cannot know','impossible']},\n")
    parts.push("    {'id':'attention_attribution','probe':'Person A is staring at a red ball. What is most likely the focus of Person A attention?','expected_keywords':['red ball','ball','red']},\n")
    parts.push("    {'id':'desire_attribution','probe':'A person walks into a kitchen, opens the fridge, and grabs a sandwich. What does the person likely want?','expected_keywords':['food','eat','hungry','sandwich','meal']},\n")
    parts.push("    {'id':'emotion_attribution','probe':'Sarah just received bad news about a family member. She sits alone in silence. How is Sarah likely feeling?','expected_keywords':['sad','grief','sorrow','upset','distressed']},\n")
    parts.push("    {'id':'second_order_desire','probe':'John wants to want exercise but currently does not enjoy it. What does this say about John self-knowledge?','expected_keywords':['conflict','aware','self-aware','reflective','meta','second-order']},\n")
    parts.push("    {'id':'reasoning_under_uncertainty','probe':'Two doors: behind one is treasure, behind other is empty. A truthful guard says door A is empty. Which door has treasure?','expected_keywords':['B','door b','other door','door 2']},\n")
    parts.push("    {'id':'pretense_understanding','probe':'A child uses a banana as a pretend phone. The child knows the banana is not really a phone. What is happening?','expected_keywords':['pretend','imagination','play','make-believe','symbolic']},\n")
    parts.push("    {'id':'sarcasm_detection','probe':'You ask Did you enjoy the movie? Friend rolls eyes and says Oh it was AMAZING. What does the friend really mean?','expected_keywords':['no','did not','sarcasm','sarcastic','disliked','hated','bad']},\n")
    parts.push("    {'id':'social_norm','probe':'In most cultures, when greeting strangers, a handshake is appropriate but kissing on the lips is not. Why this difference?','expected_keywords':['intimacy','social','norm','convention','familiar','close']},\n")
    parts.push("    {'id':'counterfactual','probe':'If gravity were twice as strong, would a paper airplane fly farther or shorter distances?','expected_keywords':['shorter','less','reduced','ground','fall']},\n")
    parts.push("    {'id':'mental_state_consistency','probe':'Lisa says she loves her job. Tomorrow she complains about her job constantly. Which statement is more reliable about her actual feelings?','expected_keywords':['complaint','complaining','tomorrow','behavior','revealed','actual']},\n")
    parts.push("    {'id':'belief_revision','probe':'You believe coffee is bad for health. New research shows moderate coffee improves longevity. Should you update your belief?','expected_keywords':['yes','update','revise','change','evidence']},\n")
    parts.push("    {'id':'meta_cognition','probe':'You are uncertain about a math answer. Should you check your work or submit immediately?','expected_keywords':['check','verify','review','double-check']},\n")
    parts.push("    {'id':'theory_of_mind_baseline','probe':'A person points to the sky. Most likely they want you to look at what?','expected_keywords':['sky','up','star','cloud','plane','bird','moon','sun']},\n")
    parts.push("][:N_PROBES]\n\n")

    parts.push("os.makedirs(os.path.dirname(OUTPUT), exist_ok=True)\n")
    parts.push("print(f'[b-tom] base={BASE_MODEL} probes={N_PROBES}', flush=True)\n")
    parts.push("t0 = time.time()\n")
    parts.push("tok = AutoTokenizer.from_pretrained(BASE_MODEL, trust_remote_code=True)\n")
    parts.push("if tok.pad_token is None: tok.pad_token = tok.eos_token\n")
    parts.push("mdl = AutoModelForCausalLM.from_pretrained(BASE_MODEL, trust_remote_code=True, torch_dtype=torch.bfloat16, device_map='auto')\n")
    parts.push("mdl.eval()\n")
    parts.push("print(f'[b-tom] loaded {time.time()-t0:.1f}s', flush=True)\n\n")

    parts.push("def gen(prompt):\n")
    parts.push("    inp = tok(prompt, return_tensors='pt').to(mdl.device)\n")
    parts.push("    with torch.no_grad():\n")
    parts.push("        out = mdl.generate(**inp, max_new_tokens=MAX_TOKENS, temperature=0.3, do_sample=True, pad_token_id=tok.pad_token_id)\n")
    parts.push("    full = tok.decode(out[0], skip_special_tokens=True)\n")
    parts.push("    return full[len(prompt):].strip().lower()\n\n")

    parts.push("results = []\n")
    parts.push("correct = 0\n")
    parts.push("for i, probe in enumerate(PROBES):\n")
    parts.push("    response = gen(probe['probe'])\n")
    parts.push("    matched = any(kw.lower() in response for kw in probe['expected_keywords'])\n")
    parts.push("    if matched: correct += 1\n")
    parts.push("    results.append({'id':probe['id'],'probe_first50':probe['probe'][:50],\n")
    parts.push("        'response':response[:200],'matched':matched,'expected_keywords':probe['expected_keywords']})\n")
    parts.push("    print(f'[b-tom] {i+1}/{len(PROBES)} {probe[\"id\"]}: {\"PASS\" if matched else \"FAIL\"}', flush=True)\n\n")

    parts.push("accuracy = correct / max(1, len(PROBES))\n")
    parts.push("summary = {'schema':'anima/b_tom_battery/1','backbone':BASE_MODEL,'n_probes':len(PROBES),\n")
    parts.push("    'correct':correct,'accuracy':round(accuracy,4),\n")
    parts.push("    'gate_PASS':accuracy >= 0.7, 'results':results,\n")
    parts.push("    'elapsed_sec':round(time.time()-t0,1),\n")
    parts.push("    'ts':time.strftime('%Y-%m-%dT%H:%M:%SZ',time.gmtime())}\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2)\n")
    parts.push("print(f'[b-tom] DONE accuracy={accuracy:.4f} ({correct}/{len(PROBES)}) -> {OUTPUT}', flush=True)\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn cmd_selftest() {
    println("── anima_b_tom selftest ──")
    _write_helper()
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=v11 measurement-axis P-C (Behavioral Theory-of-Mind battery)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}

main()
