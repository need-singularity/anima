// tool/anima_v11_main.hexa — paradigm v11 stack subcommand entry point (raw#9 hexa-only).
//
// PURPOSE
//   Single CLI router for the paradigm v11 15-helper consciousness measurement stack.
//   Provides discoverability + standard subcommand interface over the layered
//   helpers (measurement / analysis / orchestration / decision / longitudinal /
//   integration-test). Each subcommand thin-wraps a hexa source + delegates ENV.
//   Mac-local utility, no GPU. Migration #27 (paradigm v11 META-LAYER 1st helper).
//
// SUBCOMMANDS (12 routed via /tmp router + 13th first-class in-hexa)
//   v11_main list                            list all stack helpers + layer
//   v11_main run <name> [args...]            run a helper by short name
//   v11_main battery [hf_id]                 launch battery (default: Mistral)
//   v11_main benchmark                       emit + run v10 4-backbone fan-out plan
//   v11_main gate <backbone_dir>             g_gate evaluate one backbone
//   v11_main matrix [bench_dir]              v10_gate_matrix aggregate
//   v11_main integrate <bb_dir>              v11_integrate composition
//   v11_main ortho <dir1:dir2:...>           axis_orthogonality cross
//   v11_main rank <inc1:inc2:..> <cand1:..>  ensemble_rank
//   v11_main history [hist_dir]              signature_history drift
//   v11_main smoke                           full pipeline integration test
//   v11_main help                            help text (default)
//   v11_main --register-axis <NAME> --evidence <state-json-path>   (13th — D-day chain)
//
// USAGE
//   hexa run tool/anima_v11_main.hexa --selftest
//   hexa run tool/anima_v11_main.hexa list
//   hexa run tool/anima_v11_main.hexa smoke
//   hexa run tool/anima_v11_main.hexa --register-axis EEG-CORR --evidence state/anima_eeg_corr_v1.json
//
// raw#9 hexa-only / raw#15 SSOT this file (no Python emit — pure shell delegator)
// raw#65 idempotent registration (re-register same axis/evidence → no-op + "already registered")
// raw#66 negative-on-failure trailer

let PLAN_SH = "/tmp/anima_v11_main_router.sh"
let AXES_REGISTRY_PATH = "state/anima_v11_axes_registry.json"

fn _build_router() {
    let sh = []
    sh.push("#!/usr/bin/env bash\n")
    sh.push("# anima v11 main router — emitted by tool/anima_v11_main.hexa\n")
    sh.push("# raw#9 strict: subcommand dispatcher for paradigm v11 stack.\n")
    sh.push("set -euo pipefail\n")
    sh.push("REPO=\"${ANIMA_REPO:-/Users/ghost/core/anima}\"\n")
    sh.push("HEXA_RUN=\"HEXA_RESOLVER_NO_REROUTE=1 hexa run\"\n")
    sh.push("CMD=\"${1:-help}\"\n")
    sh.push("shift || true\n")
    sh.push("\n")
    sh.push("emit_only() {\n")
    sh.push("  local NAME=\"$1\"; local SRC=\"$REPO/tool/anima_${NAME}.hexa\"\n")
    sh.push("  test -f \"$SRC\" || { echo \"[v11_main] no source: $SRC\" >&2; exit 2; }\n")
    sh.push("  HEXA_RESOLVER_NO_REROUTE=1 hexa run \"$SRC\" --selftest >/dev/null 2>&1 || true\n")
    sh.push("}\n")
    sh.push("\n")
    sh.push("case \"$CMD\" in\n")
    sh.push("  list)\n")
    sh.push("    cat <<'EOF'\n")
    sh.push("paradigm v11 stack — 15 helpers across 6 layers (raw#9 strict .hexa)\n")
    sh.push("\n")
    sh.push("MEASUREMENT (6):\n")
    sh.push("  b_tom              behavioral theory-of-mind battery (20 probes)\n")
    sh.push("  mcca               meta-cognitive calibration (Brier + ECE)\n")
    sh.push("  phi_star           IIT Φ-star covariance partition (K=8)\n")
    sh.push("  cmt                causal mediation tomography (zero-ablation)\n")
    sh.push("  cds                cognitive dynamics signature (token trajectory)\n")
    sh.push("  sae_steer_bypass   SAE-steer transformer_lens-free (sparse features)\n")
    sh.push("\n")
    sh.push("ANALYSIS (3):\n")
    sh.push("  v11_integrate      5-axis composition (gmean weakest-link)\n")
    sh.push("  axis_orthogonality 7-axis cross-Pearson + greedy basis\n")
    sh.push("  ensemble_rank      Mk.XI v10 4-slot fit ranking + lift-vs-incumbent\n")
    sh.push("\n")
    sh.push("ORCHESTRATION (2):\n")
    sh.push("  v11_battery        single-load 6-axis battery (~50% wallclock save)\n")
    sh.push("  v10_benchmark      4-backbone parallel fan-out via runpod_orchestrator\n")
    sh.push("\n")
    sh.push("DECISION (3):\n")
    sh.push("  g_gate                    canonical G0..G7 composite PASS/FAIL evaluator\n")
    sh.push("  v10_gate_matrix           4-backbone × G0..G7 aggregate matrix + auto-gate\n")
    sh.push("  backbone_aware_composite  per-backbone axis-weighted gmean (within-backbone Pearson)\n")
    sh.push("\n")
    sh.push("LONGITUDINAL (1):\n")
    sh.push("  signature_history  per-backbone time-series Δ + regression flags\n")
    sh.push("\n")
    sh.push("INTEGRATION-TEST (1):\n")
    sh.push("  v11_pipeline_smoke 14-helper end-to-end synthetic chain (no GPU)\n")
    sh.push("EOF\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  run)\n")
    sh.push("    NAME=\"${1:-}\"; shift || true\n")
    sh.push("    test -n \"$NAME\" || { echo 'usage: v11_main run <name> [args...]' >&2; exit 2; }\n")
    sh.push("    SRC=\"$REPO/tool/anima_${NAME}.hexa\"\n")
    sh.push("    test -f \"$SRC\" || { echo \"no source: $SRC\" >&2; exit 2; }\n")
    sh.push("    exec env HEXA_RESOLVER_NO_REROUTE=1 hexa run \"$SRC\" \"$@\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  battery)\n")
    sh.push("    HFID=\"${1:-mistralai/Mistral-7B-v0.3}\"\n")
    sh.push("    emit_only v11_battery\n")
    sh.push("    H=/tmp/anima_v11_battery_helper.hexa_tmp\n")
    sh.push("    test -f \"$H\" || { echo 'helper not emitted' >&2; exit 1; }\n")
    sh.push("    echo \"[v11_main] battery → $HFID (helper at $H)\"\n")
    sh.push("    ANIMA_BASE=\"$HFID\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  benchmark)\n")
    sh.push("    emit_only v10_benchmark\n")
    sh.push("    PLAN=/tmp/anima_v10_benchmark_plan.sh\n")
    sh.push("    test -f \"$PLAN\" || { echo 'plan not emitted' >&2; exit 1; }\n")
    sh.push("    echo \"[v11_main] benchmark plan ready: $PLAN\"\n")
    sh.push("    echo \"[v11_main] dispatch: bash $PLAN\"\n")
    sh.push("    cat \"$PLAN\" | head -20\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  gate)\n")
    sh.push("    BB_DIR=\"${1:-}\"\n")
    sh.push("    test -d \"$BB_DIR\" || { echo 'usage: v11_main gate <backbone_dir>' >&2; exit 2; }\n")
    sh.push("    emit_only g_gate\n")
    sh.push("    H=/tmp/anima_g_gate_helper.hexa_tmp\n")
    sh.push("    ANIMA_BACKBONE_DIR=\"$BB_DIR\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  matrix)\n")
    sh.push("    BENCH=\"${1:-state/v10_benchmark}\"\n")
    sh.push("    emit_only v10_gate_matrix\n")
    sh.push("    H=/tmp/anima_v10_gate_matrix_helper.hexa_tmp\n")
    sh.push("    ANIMA_BENCHMARK_DIR=\"$BENCH\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  integrate)\n")
    sh.push("    BB_DIR=\"${1:-}\"\n")
    sh.push("    test -d \"$BB_DIR\" || { echo 'usage: v11_main integrate <bb_dir>' >&2; exit 2; }\n")
    sh.push("    emit_only v11_integrate\n")
    sh.push("    H=/tmp/anima_v11_integrate_helper.hexa_tmp\n")
    sh.push("    ANIMA_V11_DIR=\"$BB_DIR\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  ortho)\n")
    sh.push("    DIRS=\"${1:-}\"\n")
    sh.push("    test -n \"$DIRS\" || { echo 'usage: v11_main ortho <dir1:dir2:...>' >&2; exit 2; }\n")
    sh.push("    emit_only axis_orthogonality\n")
    sh.push("    H=/tmp/anima_axis_orthogonality_helper.hexa_tmp\n")
    sh.push("    ANIMA_BACKBONE_DIRS=\"$DIRS\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  rank)\n")
    sh.push("    INC=\"${1:-}\"; CAND=\"${2:-}\"\n")
    sh.push("    test -n \"$INC\" -a -n \"$CAND\" || { echo 'usage: v11_main rank <inc1:inc2:..> <cand1:..>' >&2; exit 2; }\n")
    sh.push("    emit_only ensemble_rank\n")
    sh.push("    H=/tmp/anima_ensemble_rank_helper.hexa_tmp\n")
    sh.push("    ANIMA_INCUMBENT_DIRS=\"$INC\" ANIMA_CANDIDATE_DIRS=\"$CAND\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  history)\n")
    sh.push("    HIST=\"${1:-state/v11_history}\"\n")
    sh.push("    emit_only signature_history\n")
    sh.push("    H=/tmp/anima_signature_history_helper.hexa_tmp\n")
    sh.push("    ANIMA_HISTORY_DIR=\"$HIST\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  bba)\n")
    sh.push("    DIRS=\"${1:-}\"\n")
    sh.push("    test -n \"$DIRS\" || { echo 'usage: v11_main bba <dir1:dir2:...>' >&2; exit 2; }\n")
    sh.push("    emit_only backbone_aware_composite\n")
    sh.push("    H=/tmp/anima_backbone_aware_composite_helper.hexa_tmp\n")
    sh.push("    ANIMA_BACKBONE_DIRS=\"$DIRS\" python3 \"$H\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  smoke)\n")
    sh.push("    emit_only v11_pipeline_smoke\n")
    sh.push("    PLAN=/tmp/anima_v11_pipeline_smoke_plan.sh\n")
    sh.push("    test -f \"$PLAN\" || { echo 'smoke plan not emitted' >&2; exit 1; }\n")
    sh.push("    bash \"$PLAN\"\n")
    sh.push("    ;;\n")
    sh.push("\n")
    sh.push("  help|*)\n")
    sh.push("    cat <<'EOF'\n")
    sh.push("anima v11_main — paradigm v11 stack CLI (raw#9 strict)\n")
    sh.push("\n")
    sh.push("Subcommands:\n")
    sh.push("  list                          show all 15 stack helpers per layer\n")
    sh.push("  run <name> [args...]          delegate to anima_<name>.hexa\n")
    sh.push("  battery [hf_id]               run 6-axis single-load battery (GPU)\n")
    sh.push("  benchmark                     show v10 4-backbone fan-out plan\n")
    sh.push("  gate <bb_dir>                 evaluate G0..G7 for one backbone\n")
    sh.push("  matrix [bench_dir]            4-backbone × G0..G7 aggregate matrix\n")
    sh.push("  integrate <bb_dir>            v11_signature composition\n")
    sh.push("  ortho <dir1:dir2:...>         axis_orthogonality cross-Pearson\n")
    sh.push("  rank <inc:..> <cand:..>       ensemble candidate ranking\n")
    sh.push("  history [hist_dir]            signature drift over time\n")
    sh.push("  bba <dir1:dir2:...>           backbone-aware composite (per-bb axis weighting)\n")
    sh.push("  smoke                         end-to-end pipeline integration test\n")
    sh.push("  help                          this message\n")
    sh.push("\n")
    sh.push("ENV:\n")
    sh.push("  ANIMA_REPO                    repo root (default: /Users/ghost/core/anima)\n")
    sh.push("EOF\n")
    sh.push("    ;;\n")
    sh.push("esac\n")

    write_file(PLAN_SH, sh.join(""))
}

fn cmd_selftest() {
    println("── anima_v11_main selftest ──")
    _build_router()
    println("selftest=ok")
    println("router_emitted=" + PLAN_SH)
    println("subcommands=12_routed + 1_first_class (--register-axis) = 13 total")
    println("DONE")
}

// ═══════════════════════════════════════════════════════════════════════
//  13TH SUBCOMMAND: --register-axis <NAME> --evidence <path>
//  D-day chain landing helper. Validates evidence JSON, ensures axis_index
//  matches expected, idempotently appends to state/anima_v11_axes_registry.json.
// ═══════════════════════════════════════════════════════════════════════

fn _str(v) -> string { return str(v) }

fn _fexists(p: string) -> bool {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn _ensure_dir(p: string) {
    exec("mkdir -p " + p)
}

fn _now_utc() -> string {
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn _expected_axis_index(name: string) -> int {
    if name == "EEG-CORR" { return 7 }
    return 0 - 1
}

fn cmd_register_axis(axis_name: string, evidence_path: string) {
    println("── anima_v11_main --register-axis ──")
    println("axis: " + axis_name)
    println("evidence: " + evidence_path)
    if axis_name == "" {
        eprintln("[raw#66] ABORT: --register-axis NAME empty")
        exit(2)
    }
    if evidence_path == "" {
        eprintln("[raw#66] ABORT: --evidence PATH empty")
        exit(2)
    }
    if !_fexists(evidence_path) {
        eprintln("[raw#66] ABORT: evidence path not found: " + evidence_path)
        exit(2)
    }
    let blob = read_file(evidence_path)
    let ev = json_parse(blob)
    let ev_axis = ev["paradigm_v11_axis"]
    let ev_axis_str = _str(ev_axis)
    if ev_axis_str != axis_name {
        eprintln("[raw#66] ABORT: evidence paradigm_v11_axis=" + ev_axis_str + " does not match registration NAME=" + axis_name)
        exit(2)
    }
    let ev_idx = ev["axis_index"]
    let want_idx = _expected_axis_index(axis_name)
    if want_idx >= 0 && ev_idx != want_idx {
        eprintln("[raw#66] ABORT: evidence axis_index=" + _str(ev_idx) + " does not match expected " + _str(want_idx) + " for axis " + axis_name)
        exit(2)
    }
    let ev_tool = _str(ev["tool"])
    let ev_classification = _str(ev["classification"])
    let ev_verdict = _str(ev["verdict"])
    let ev_pass = ev["pass_count"]

    // Ensure registry parent dir.
    let mut slash_idx = 0 - 1
    let mut __i = 0
    while __i < len(AXES_REGISTRY_PATH) {
        if AXES_REGISTRY_PATH.substring(__i, __i + 1) == "/" { slash_idx = __i }
        __i = __i + 1
    }
    if slash_idx > 0 {
        _ensure_dir(AXES_REGISTRY_PATH.substring(0, slash_idx))
    }

    let mut existing = []
    let mut already = false
    if _fexists(AXES_REGISTRY_PATH) {
        let raw = read_file(AXES_REGISTRY_PATH)
        let reg = json_parse(raw)
        let axes = reg["axes"]
        let s = _str(axes)
        if s != "null" && s != "" {
            let mut i = 0
            while i < len(axes) {
                let entry = axes[i]
                let nm = _str(entry["axis"])
                let ev_p = _str(entry["evidence"])
                if nm == axis_name && ev_p == evidence_path {
                    already = true
                }
                existing.push(entry)
                i = i + 1
            }
        }
    }

    if already {
        println("[raw#65] axis " + axis_name + " already registered with evidence " + evidence_path + " — no-op")
        println("registry: " + AXES_REGISTRY_PATH)
        println("DONE")
        exit(0)
    }

    // Append new entry. Build JSON manually to keep deterministic ordering.
    let parts = []
    parts.push("{\n  \"schema\": \"anima/v11_axes_registry/1\",\n  \"axes\": [")
    let mut k = 0
    while k < len(existing) {
        let e = existing[k]
        if k > 0 { parts.push(",") }
        parts.push("\n    {")
        parts.push("\"axis\": \"")
        parts.push(_str(e["axis"]))
        parts.push("\", \"axis_index\": ")
        parts.push(_str(e["axis_index"]))
        parts.push(", \"evidence\": \"")
        parts.push(_str(e["evidence"]))
        parts.push("\", \"tool\": \"")
        parts.push(_str(e["tool"]))
        parts.push("\", \"verdict\": \"")
        parts.push(_str(e["verdict"]))
        parts.push("\", \"classification\": \"")
        parts.push(_str(e["classification"]))
        parts.push("\", \"pass_count\": ")
        parts.push(_str(e["pass_count"]))
        parts.push(", \"registered_utc\": \"")
        parts.push(_str(e["registered_utc"]))
        parts.push("\"}")
        k = k + 1
    }
    if len(existing) > 0 { parts.push(",") }
    parts.push("\n    {")
    parts.push("\"axis\": \"")
    parts.push(axis_name)
    parts.push("\", \"axis_index\": ")
    parts.push(_str(ev_idx))
    parts.push(", \"evidence\": \"")
    parts.push(evidence_path)
    parts.push("\", \"tool\": \"")
    parts.push(ev_tool)
    parts.push("\", \"verdict\": \"")
    parts.push(ev_verdict)
    parts.push("\", \"classification\": \"")
    parts.push(ev_classification)
    parts.push("\", \"pass_count\": ")
    parts.push(_str(ev_pass))
    parts.push(", \"registered_utc\": \"")
    parts.push(_now_utc())
    parts.push("\"}")
    parts.push("\n  ]\n}\n")

    write_file(AXES_REGISTRY_PATH, parts.join(""))
    println("axis " + axis_name + " registered")
    println("registry: " + AXES_REGISTRY_PATH)
    println("axes_total: " + _str(len(existing) + 1))
    println("DONE")
    exit(0)
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut register_axis_name = ""
    let mut evidence_path = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        if a == "--register-axis" && i + 1 < len(av) {
            register_axis_name = av[i+1]; i = i + 2; continue
        }
        if a == "--evidence" && i + 1 < len(av) {
            evidence_path = av[i+1]; i = i + 2; continue
        }
        i = i + 1
    }
    if register_axis_name != "" {
        cmd_register_axis(register_axis_name, evidence_path)
        exit(0)
    }
    _build_router()
    if selftest { cmd_selftest(); exit(0) }
    println("emitted=" + PLAN_SH)
    println("dispatch via: bash " + PLAN_SH + " <subcommand> [args...]")
    println("DONE")
}

main()
