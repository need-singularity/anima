// tool/anima_memory_h100_pending_freshness_audit.hexa — cycle 64 memory staleness audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   handoff §5 next-priority 항목 중 "memory project_h100_launch_pending.md
//   업데이트 (5 days stale)" 처리. cycle 64 = mac-local audit + memory 갱신
//   (memory 파일 자체는 anima repo 외부, 직접 edit; 이 helper는 staleness
//   evidence를 state JSON으로 기록).
//
// FINDING (cycle 64, 2026-04-27)
//   memory file        : ~/.claude-claude11/.../memory/project_h100_launch_pending.md
//   prior date         : 2026-04-22 (5 days stale)
//   prior claim        : "Burn rate $0" / "weight pre-cache OK, pod create blocked"
//   reality (cycle 52+): 2 H100 pods active since 2026-04-26 ($5.98/hr, $122.96 spent)
//   contradiction      : prior memory 표면적으로 burn $0 주장 vs cycle 52-63 evidence
//
//   별도 사실: #83 unified kickoff(`tool/h100_stage2_unified_launch.bash`) 자체는
//   여전히 미실행. 즉 memory의 "still pending" 부분은 정확하나 "burn $0" 부분은 거짓.
//   부분-정확 → 분리해서 갱신 (split fact).
//
// OUTPUT
//   state/memory_h100_pending_freshness_audit.json
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - 이 helper 자체는 memory 파일을 read 안 함 (auto-memory system이 conversation
//     context로 이미 노출). prior 상태 + 갱신 후 상태를 documented summary로 기록.
//   - memory 파일 갱신은 helper 외부에서 Write tool로 직접 수행됨 (NON_MUTATION
//     guarantee = memory dir 외부 상태에 한정).
//   - cycle 63 발견 (probe-exec gap)을 cross-link.

let HELPER_PATH = "/tmp/anima_memory_h100_pending_freshness_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima memory h100_pending freshness audit — emitted by tool/anima_memory_h100_pending_freshness_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION (anima repo state 외부 변경 없음).\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/memory_h100_pending_freshness_audit.json')\n\n")

    parts.push("prior_memory = {\n")
    parts.push("    'name': 'H100 launch still pending (2026-04-22)',\n")
    parts.push("    'date': '2026-04-22',\n")
    parts.push("    'days_stale_at_audit': 5,\n")
    parts.push("    'claim_split': {\n")
    parts.push("        '83_kickoff_pending': {'value': True, 'still_correct': True, 'note': 'unified launch helper 미실행 그대로 유지'},\n")
    parts.push("        'burn_rate_zero': {'value': True, 'still_correct': False, 'note': 'cycle 52 발견: 2 H100 pods 2026-04-26부터 burn'},\n")
    parts.push("        'pod_create_blocked': {'value': True, 'still_correct': False, 'note': '#83은 미실행이나 별개 2 pods 생성됨 (anima-sae-steer-pilot + anima-gwt-deepseek-c2-long)'},\n")
    parts.push("    },\n")
    parts.push("}\n\n")

    parts.push("reality_2026_04_27 = {\n")
    parts.push("    '83_unified_kickoff': 'NOT_TRIGGERED (feedback_h100_gate.md 그대로 유효)',\n")
    parts.push("    'unrelated_active_pods': 2,\n")
    parts.push("    'pods': [\n")
    parts.push("        {'pod_id':'bnabak3i4r38bg','name':'anima-sae-steer-pilot','status':'IDLE_CONFIRMED_CYCLE_56','ssh':'103.207.149.52:19147','cost_per_hr':2.99},\n")
    parts.push("        {'pod_id':'1an0fdtr2mrif1','name':'anima-gwt-deepseek-c2-long','status':'TRANSITIONAL_SSH_PORTS_NOT_POPULATED','ssh':'unavailable','cost_per_hr':2.99},\n")
    parts.push("    ],\n")
    parts.push("    'cumulative_spent_usd': 122.96,\n")
    parts.push("    'balance_usd': 347.0,\n")
    parts.push("    'burn_per_hr_usd': 5.98,\n")
    parts.push("    'days_until_zero_balance': 2.4,\n")
    parts.push("}\n\n")

    parts.push("update_action = {\n")
    parts.push("    'memory_file': '~/.claude-claude11/projects/-Users-ghost-core-anima/memory/project_h100_launch_pending.md',\n")
    parts.push("    'action': 'OVERWRITTEN_2026_04_27',\n")
    parts.push("    'split_fact_preserved': True,\n")
    parts.push("    'prior_correct_part': '#83 kickoff still pending (preserved verbatim)',\n")
    parts.push("    'prior_incorrect_part': 'burn $0 (replaced with cycle 52-63 evidence)',\n")
    parts.push("    'cross_link': 'cycle 63 probe-exec gap discovery (state/h100_auto_kill_probe_gap_discovery.json)',\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm': 'cycle 64 — memory project_h100_launch_pending freshness audit + split-fact update',\n")
    parts.push("    'cycle': 64,\n")
    parts.push("    'prior_memory': prior_memory,\n")
    parts.push("    'reality_2026_04_27': reality_2026_04_27,\n")
    parts.push("    'update_action': update_action,\n")
    parts.push("    'non_mutation_guarantee': 'helper does NOT modify anima repo state; memory file (외부) is updated by Write tool separately',\n")
    parts.push("    'cross_link_cycles': ['cycle 36 workspace 19-repo discovery (memory drift class)', 'cycle 52 active pods discovery', 'cycle 59 capstone playbook', 'cycle 63 probe-exec gap'],\n")
    parts.push("    'pattern': 'governance audit chain layer 43 (memory staleness; split-fact handling)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[memory_freshness] cycle=64 split_fact=True burn=$5.98/hr file_action=OVERWRITTEN_2026_04_27 -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_REPO_STATE")
    println("inv:memory_split_fact_handled=true")
    println("inv:cycle=64")
    println("inv:cross_link_cycles=36,52,59,63")
    println("inv:burn_finding_preserved=$5.98/hr")
    return true
}

fn cmd_selftest() {
    println("── anima_memory_h100_pending_freshness_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 64 — memory staleness split-fact update; NON_MUTATION on anima repo; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
