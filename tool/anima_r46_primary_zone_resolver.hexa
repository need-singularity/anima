// tool/anima_r46_primary_zone_resolver.hexa — R46 PRIMARY zone (|BASE phi*|<3) base+instruct pair resolver (raw#9 hexa-only).
//
// PURPOSE
//   R46_CANDIDATE 4-family BIMODAL hypothesis: |BASE phi*| < ~3 → corpus PRIMARY (instruct flips sign),
//   |BASE phi*| > ~10 → MODIFIER (instruct preserves sign). Axis 90+94+104 11-bb evidence:
//     PRIMARY zone NEG measured: Qwen3-8B-Base -3.45 / gemma-2-9b -0.79 / Pythia-1B -1.32 (axis 104).
//     Instruct-pair flip 측정 완료: Qwen3-it / gemma-it (2/2 confirm flip).
//     PENDING direct flip test: Pythia-1B P1 (Pythia 가족 native Instruct variant 부재) + 다른 <2B candidates.
//
//   본 helper = mac-local resolver: <2B parameter "primary zone" backbone들의 curated
//   base+instruct pair registry. R46 verdict CONFIRMED upgrade를 위한 다음 GPU pilot trigger
//   candidate list 산출. Pythia-1B는 native instruct 부재 → ALT_REGISTRY 제시.
//
// INPUT
//   ANIMA_PARAM_MAX_B   primary zone upper bound (default: 2.0, in billions)
//   ANIMA_OUTPUT        output JSON (default: state/r46_primary_zone_candidates.json)
//
// OUTPUT
//   - registry: list of {base_id, instruct_id, params_b, family, instruct_method, status}
//   - pythia_alt_strategy: native Pythia instruct 부재 보충 후보 (TinyLlama-1.1B-Chat 등)
//   - gpu_pilot_recommended_order: |BASE phi*| zone 충실도 + cost 균형
//   - selftest verifies: ≥4 candidates, schema invariants, HF naming convention
//
// USAGE
//   hexa run tool/anima_r46_primary_zone_resolver.hexa --selftest
//   ANIMA_OUTPUT=state/r46_primary_zone_candidates.json hexa run tool/anima_r46_primary_zone_resolver.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_r46_primary_zone_resolver_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima R46 primary-zone resolver helper — emitted by tool/anima_r46_primary_zone_resolver.hexa\n")
    parts.push("# raw#37 transient. R46_CANDIDATE 4-family BIMODAL primary-zone Instruct pair registry.\n")
    parts.push("import json, os, sys, re\n\n")

    parts.push("PARAM_MAX_B = float(os.environ.get('ANIMA_PARAM_MAX_B', '2.0'))\n")
    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/r46_primary_zone_candidates.json')\n\n")

    parts.push("# Curated registry: PRIMARY zone (|BASE phi*| typically < ~3 by R46 hypothesis correlation with size).\n")
    parts.push("# Each entry: base_id, instruct_id, params_b, family, instruct_method, axis90_94_104_phi_star_baseline (if measured).\n")
    parts.push("REGISTRY = [\n")
    parts.push("    {'base_id':'Qwen/Qwen2-1.5B','instruct_id':'Qwen/Qwen2-1.5B-Instruct','params_b':1.54,'family':'Qwen2','instruct_method':'SFT+DPO','phi_star_base':None,'measured_axis':None,'status':'CANDIDATE_NOT_MEASURED'},\n")
    parts.push("    {'base_id':'Qwen/Qwen2.5-1.5B','instruct_id':'Qwen/Qwen2.5-1.5B-Instruct','params_b':1.54,'family':'Qwen2.5','instruct_method':'SFT+DPO','phi_star_base':None,'measured_axis':None,'status':'CANDIDATE_NOT_MEASURED'},\n")
    parts.push("    {'base_id':'HuggingFaceTB/SmolLM-1.7B','instruct_id':'HuggingFaceTB/SmolLM-1.7B-Instruct','params_b':1.71,'family':'SmolLM','instruct_method':'SFT','phi_star_base':None,'measured_axis':None,'status':'CANDIDATE_NOT_MEASURED'},\n")
    parts.push("    {'base_id':'TinyLlama/TinyLlama-1.1B-intermediate-step-1431k-3T','instruct_id':'TinyLlama/TinyLlama-1.1B-Chat-v1.0','params_b':1.10,'family':'TinyLlama','instruct_method':'SFT+DPO','phi_star_base':None,'measured_axis':None,'status':'CANDIDATE_NOT_MEASURED'},\n")
    parts.push("    {'base_id':'EleutherAI/pythia-1b','instruct_id':None,'params_b':1.01,'family':'Pythia','instruct_method':'NONE_NATIVE','phi_star_base':-1.32,'measured_axis':'axis_104','status':'BASE_MEASURED_INSTRUCT_NOT_AVAILABLE'},\n")
    parts.push("    {'base_id':'EleutherAI/pythia-1.4b','instruct_id':None,'params_b':1.41,'family':'Pythia','instruct_method':'NONE_NATIVE','phi_star_base':None,'measured_axis':None,'status':'BASE_NOT_MEASURED_INSTRUCT_NOT_AVAILABLE'},\n")
    parts.push("    {'base_id':'microsoft/phi-1_5','instruct_id':None,'params_b':1.30,'family':'Phi','instruct_method':'NONE_NATIVE','phi_star_base':None,'measured_axis':None,'status':'BASE_NOT_MEASURED_INSTRUCT_NOT_AVAILABLE'},\n")
    parts.push("    {'base_id':'google/gemma-2b','instruct_id':'google/gemma-2b-it','params_b':2.51,'family':'Gemma','instruct_method':'SFT+RLHF','phi_star_base':None,'measured_axis':None,'status':'CANDIDATE_EDGE_OF_ZONE'},\n")
    parts.push("]\n\n")

    parts.push("# Pythia native Instruct 부재 보충: 1B 사이즈 zone 다른 family Instruct pair로 R46 PRIMARY zone 검증 가능.\n")
    parts.push("PYTHIA_ALT_STRATEGY = {\n")
    parts.push("    'native_pythia_1b_instruct_exists': False,\n")
    parts.push("    'reason': 'EleutherAI Pythia 1B 가족에 native production Instruct/Chat variant 부재. dolly-v2-3b 는 Pythia-2.8B 기반, Pythia-Chat-Base-7B 는 7B size — both outside primary zone.',\n")
    parts.push("    'alternative_strategy': 'TinyLlama-1.1B-Chat / Qwen2-1.5B-Instruct / SmolLM-1.7B-Instruct 같은 다른 family <2B Instruct pair 측정으로 R46 primary-zone-flip 검증 보충',\n")
    parts.push("    'recommended_pythia_proxy': 'TinyLlama/TinyLlama-1.1B-Chat-v1.0 — 1.10B (closest to Pythia-1B 1.01B size matched), native Instruct via SFT+DPO, base+chat pair both publicly available',\n")
    parts.push("}\n\n")

    parts.push("# Filter to candidates with both base AND instruct AND within primary zone\n")
    parts.push("def is_primary_zone_pair(e):\n")
    parts.push("    return e['instruct_id'] is not None and e['params_b'] <= PARAM_MAX_B + 0.51  # +0.51 tolerance for gemma-2b 2.51\n\n")

    parts.push("primary_pairs = [e for e in REGISTRY if is_primary_zone_pair(e)]\n")
    parts.push("base_only_no_instruct = [e for e in REGISTRY if e['instruct_id'] is None]\n\n")

    parts.push("# GPU pilot recommended order: prioritize\n")
    parts.push("#   (1) BASE-measured + Instruct-available (direct zone proximity confirmed)\n")
    parts.push("#   (2) family diversity (≠ already-tested Mistral/Llama/Qwen3/gemma 8-9B)\n")
    parts.push("#   (3) smaller params_b (cheaper GPU)\n")
    parts.push("def pilot_priority(e):\n")
    parts.push("    has_base_measured = e.get('phi_star_base') is not None\n")
    parts.push("    bonus = -10 if has_base_measured else 0\n")
    parts.push("    return (bonus + e['params_b'], e['family'])\n\n")

    parts.push("pilot_order = sorted(primary_pairs, key=pilot_priority)\n")
    parts.push("pilot_recommendation = []\n")
    parts.push("for i, e in enumerate(pilot_order, start=1):\n")
    parts.push("    pilot_recommendation.append({'order':i,'base_id':e['base_id'],'instruct_id':e['instruct_id'],'params_b':e['params_b'],'family':e['family'],'rationale':f\"primary zone width-fill ({e['family']} family), {e['params_b']}B param, instruct method {e['instruct_method']}\"})\n\n")

    parts.push("# HF naming convention sanity: org/model_name format\n")
    parts.push("HF_RE = re.compile(r'^[A-Za-z0-9][A-Za-z0-9._-]*/[A-Za-z0-9][A-Za-z0-9._-]*$')\n")
    parts.push("naming_violations = []\n")
    parts.push("for e in REGISTRY:\n")
    parts.push("    if e['base_id'] and not HF_RE.match(e['base_id']):\n")
    parts.push("        naming_violations.append({'id':e['base_id'],'role':'base'})\n")
    parts.push("    if e['instruct_id'] and not HF_RE.match(e['instruct_id']):\n")
    parts.push("        naming_violations.append({'id':e['instruct_id'],'role':'instruct'})\n\n")

    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("summary = {\n")
    parts.push("    'schema':'anima/r46_primary_zone_candidates/1',\n")
    parts.push("    'param_max_b':PARAM_MAX_B,\n")
    parts.push("    'r46_hypothesis':'|BASE phi*| < ~3 → corpus PRIMARY (instruct flips sign); |BASE phi*| > ~10 → MODIFIER (instruct preserves sign)',\n")
    parts.push("    'evidence_so_far':{'primary_flip_confirmed':['Qwen3-8B-Base→Qwen3-8B-Instruct','gemma-2-9b→gemma-2-9b-it'],'primary_base_only_pending':['EleutherAI/pythia-1b (axis 104, -1.32)']},\n")
    parts.push("    'registry':REGISTRY,\n")
    parts.push("    'primary_pairs_actionable':primary_pairs,\n")
    parts.push("    'base_only_no_instruct_native':base_only_no_instruct,\n")
    parts.push("    'pythia_alt_strategy':PYTHIA_ALT_STRATEGY,\n")
    parts.push("    'gpu_pilot_recommended_order':pilot_recommendation,\n")
    parts.push("    'naming_violations':naming_violations,\n")
    parts.push("    'n_registry':len(REGISTRY),'n_primary_pairs':len(primary_pairs),'n_base_only_no_instruct':len(base_only_no_instruct),\n")
    parts.push("}\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[r46_resolver] registry={len(REGISTRY)} primary_pairs={len(primary_pairs)} base_only={len(base_only_no_instruct)} pilot_order_top={pilot_recommendation[0][\"base_id\"] if pilot_recommendation else None} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    // emit + spot-check via re-parse: candidate registry has ≥4 actionable primary-pairs
    // and pythia is recorded as base-only no-native-instruct.
    let registry_min_count = 8
    let primary_pairs_min = 4
    let pythia_status_expected = "BASE_MEASURED_INSTRUCT_NOT_AVAILABLE"
    println("inv:registry_min_count=" + to_string(registry_min_count))
    println("inv:primary_pairs_min=" + to_string(primary_pairs_min))
    println("inv:pythia_status_expected=" + pythia_status_expected)
    return true
}

fn cmd_selftest() {
    println("── anima_r46_primary_zone_resolver selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=R46 BIMODAL (|BASE phi*|<3 PRIMARY zone Instruct pair candidate registry, mac-local)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}

main()
