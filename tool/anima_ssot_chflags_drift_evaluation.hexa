// tool/anima_ssot_chflags_drift_evaluation.hexa — cycle 75 SSOT chflags drift 정밀 평가 (raw#9 hexa-only).
//
// PURPOSE
//   cycle 21 SSOT chflags audit 발견 3/7 unlocked. cycle 75에서 drift vs
//   active-edit-window 분리 + memory 패턴 갱신. 실 chflags mutation 보류
//   (parallel session race 위험).
//
// FINDINGS (cycle 75 직접 검증, 2026-04-27)
//
//   3 SSOT 모두 currently unlocked (cycle 21 finding 재확인):
//     .roadmap                                                     unlocked
//     state/atlas_convergence_witness.jsonl                        unlocked
//     state/v10_anima_physics_cloud_facade/integration_ledger/witness_ledger_v2.json.meta  unlocked
//
//   recent git log (2 days):
//     .roadmap edit commits 다수 (#230 ledger / #239 dry run / #237 phase 3a 등)
//     atlas_convergence_witness.jsonl edit 26cdc612 "witness(atlas):"
//     witness_ledger_v2.json.meta mtime Apr 27 07:42:58 (방금 전 — active edit 중)
//
//   해석: 3 SSOT 모두 active-edit window 안. cycle 21 audit는 그 순간 캡처.
//         drift가 아니라 정상 unlock-edit 중간 상태일 가능성 매우 높음.
//
// ACTION TAKEN
//   1) memory project_uchg_ssot.md 에 active-edit window observation 추가
//      (drift vs active-window 구분 명시; relock은 quiescent 시점에)
//   2) chflags mutation 보류 (parallel session race 위험)
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - cycle 21 audit가 catch한 unlock 상태가 drift인지 active-edit인지 audit 자체로
//     판별 불가 (chflags state는 시점 캡처). cycle 75 git log 분석으로 active-edit
//     해석이 더 plausible.
//   - 그래도 진짜 drift 가능성 0은 아니므로 향후 quiescent 시점에 재audit + relock 권장.
//   - 본 helper는 chflags mutation 안 함; memory edit는 main session Edit으로.

let HELPER_PATH = "/tmp/anima_ssot_chflags_drift_evaluation_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima SSOT chflags drift evaluation — emitted by tool/anima_ssot_chflags_drift_evaluation.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION (chflags / git state untouched).\n")
    parts.push("import json, os, subprocess\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/ssot_chflags_drift_evaluation.json')\n\n")

    parts.push("ssot_paths = [\n")
    parts.push("    '.roadmap',\n")
    parts.push("    'state/atlas_convergence_witness.jsonl',\n")
    parts.push("    'state/v10_anima_physics_cloud_facade/integration_ledger/witness_ledger_v2.json.meta',\n")
    parts.push("]\n\n")

    parts.push("def _chflags(p):\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['stat','-f','%Sf',p], capture_output=True, text=True)\n")
    parts.push("        return r.stdout.strip()\n")
    parts.push("    except Exception: return 'STAT_FAIL'\n\n")

    parts.push("def _last_commit(p):\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['git','log','-1','--pretty=format:%h %ai %s','--',p], capture_output=True, text=True)\n")
    parts.push("        return r.stdout.strip()[:200]\n")
    parts.push("    except Exception: return 'GIT_FAIL'\n\n")

    parts.push("def _mtime(p):\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['stat','-f','%Sm',p], capture_output=True, text=True)\n")
    parts.push("        return r.stdout.strip()\n")
    parts.push("    except Exception: return 'STAT_FAIL'\n\n")

    parts.push("ssot_state = []\n")
    parts.push("for p in ssot_paths:\n")
    parts.push("    ssot_state.append({\n")
    parts.push("        'path': p,\n")
    parts.push("        'chflags': _chflags(p),\n")
    parts.push("        'mtime': _mtime(p),\n")
    parts.push("        'last_commit': _last_commit(p),\n")
    parts.push("    })\n\n")

    parts.push("classification = {\n")
    parts.push("    'cycle_21_finding':'3/7 SSOT unlocked',\n")
    parts.push("    'cycle_75_interpretation':'active_edit_window (parallel session 중 unlock-edit-relock)',\n")
    parts.push("    'evidence':[\n")
    parts.push("        '.roadmap: 다수 #230/#237/#239 commits 최근 2일',\n")
    parts.push("        'atlas: 26cdc612 witness(atlas) commit',\n")
    parts.push("        'witness_ledger_v2 meta: mtime 방금 전 (active edit)',\n")
    parts.push("    ],\n")
    parts.push("    'drift_vs_active_window':'active_window 가능성 우세 — but audit-time-point limitation',\n")
    parts.push("    'recommended_relock_timing':'quiescent moment (활성 commit 흐름 멎은 후); race 회피',\n")
    parts.push("}\n\n")

    parts.push("memory_action = {\n")
    parts.push("    'memory_file':'~/.claude-claude11/projects/-Users-ghost-core-anima/memory/project_uchg_ssot.md',\n")
    parts.push("    'edit':'active-edit window observation (cycle 75, 2026-04-27) 추가',\n")
    parts.push("    'rationale':'drift vs active-window 구분 명시; relock 보류 정당화',\n")
    parts.push("}\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'quiescent 시점에 cycle 21 helper 재실행 + relock 시도', 'priority':'low', 'cost':'mac $0', 'requires':'parallel session 활동 멎음 확인'},\n")
    parts.push("    {'action':'cycle 21 helper에 active-edit-window 인식 추가', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 75 — SSOT chflags drift vs active-edit-window 정밀 평가',\n")
    parts.push("    'cycle': 75,\n")
    parts.push("    'ssot_state_now': ssot_state,\n")
    parts.push("    'classification': classification,\n")
    parts.push("    'memory_action': memory_action,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'non_mutation_guarantee':'chflags 변경 0; git state 변경 0; memory edit는 main session Edit으로 직접',\n")
    parts.push("    'cross_link_cycles':['cycle 21 chflags audit (initial)', 'cycles 64+66+69+70+74 memory rewrites (parallel pattern)'],\n")
    parts.push("    'pattern':'governance audit chain layer 54 (cycle 21 finding 정밀화 — drift 거짓 양성 가능성 증명)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[ssot_chflags_drift] cycle=75 cycle_21_unlocked=3 interpretation=active_edit_window relock_deferred -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_EVIDENCE")
    println("inv:cycle=75")
    println("inv:cycle_21_unlocked_count=3")
    println("inv:interpretation=active_edit_window")
    println("inv:relock_action=DEFERRED")
    println("inv:cross_link_cycles=21,64,66,69,70,74")
    return true
}

fn cmd_selftest() {
    println("── anima_ssot_chflags_drift_evaluation selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 75 — SSOT chflags drift vs active-window 정밀화; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
