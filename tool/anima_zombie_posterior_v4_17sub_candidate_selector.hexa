// tool/anima_zombie_posterior_v4_17sub_candidate_selector.hexa — R45 zombie posterior v3→v4 N=14→17 substrate expansion candidate selector (raw#9 hexa-only).
//
// PURPOSE
//   R45_FINAL_v3 N=14 (posterior 0.3684, CI ≥ 0.20 width — uninformative for subkind generalization, C2 caveat).
//   handoff §1.4 trajectory: v1 (N=8) 0.4000 → v2 (N=11) 0.3793 → v3 (N=14) 0.3684 → v4 (N=17) ?
//   본 helper = mac-local candidate selector (mutually-exclusive 3-substrate addition options):
//
//     - 5 candidate substrates (Pythia-1B from axis 104 + cycle 1 R46 PRIMARY zone bb 등)
//     - select-3 frozen rationale (information-gain 우선: previously-untested family + sign mix)
//     - selftest verifies: 3 selected substrate / each has source axis + Φ* sign / total candidates ≥5
//     - 절대 v3 helper 수정 안 함 (chflags uchg + sha-locked SSOT)
//     - 출력은 v4 helper 작성 시 사용할 input list (helper 작성은 별 cycle에서)
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/zombie_posterior_v4_17sub_candidate_selector.json)
//
// OUTPUT
//   - candidate_substrates: 5 with {label, source_axis, phi_x10000_observed_or_estimated, sign, family, status}
//   - frozen_selection_rule: information_gain priority (untested-family-first, sign-balance-second)
//   - selected_top3: 3 substrates with rationale + posterior_shift_estimate (heuristic)
//   - non_mutation_guarantee: v3 helper sha + chflags preserved
//
// USAGE
//   hexa run tool/anima_zombie_posterior_v4_17sub_candidate_selector.hexa --selftest
//   ANIMA_OUTPUT=state/zombie_posterior_v4_17sub_candidate_selector.json hexa run tool/anima_zombie_posterior_v4_17sub_candidate_selector.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - posterior_shift_estimate는 heuristic ONLY — 실제 v4 helper 실행 전까지 수치 정확성 보장 없음.
//   - 5 candidates 중 일부는 phi_observed (axis 104), 나머지는 phi_estimated (axis 94 BIMODAL pattern 추정).
//   - 본 helper 자체가 v4 helper 작성 권한을 부여하지 않음 — v3 sha-locked policy 그대로 유지.
//     v4 별도 helper (예: tool/anima_zombie_posterior_v4_17substrate.hexa) 작성은 별도 cycle에서.

let HELPER_PATH = "/tmp/anima_zombie_posterior_v4_17sub_candidate_selector_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima R45 v3→v4 17-sub candidate selector — emitted by tool/anima_zombie_posterior_v4_17sub_candidate_selector.hexa\n")
    parts.push("# raw#37 transient. R45 zombie posterior 14→17 expansion mac-local non-mutating selector.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/zombie_posterior_v4_17sub_candidate_selector.json')\n\n")

    parts.push("V3_HELPER = 'tool/anima_zombie_posterior_v3_14substrate.hexa'\n")
    parts.push("V3_HELPER_SHA = '7a9a262921971463aa2250a885c993adb74ab9ee395c9f62e7df851ebacb51e1'\n")
    parts.push("V3_OUTPUT_SHA = '8236e7ca3acc63a10f680551ec0250ae436f83c915e5a4523218953e36754039'\n")
    parts.push("V3_POSTERIOR = 0.3684\n")
    parts.push("V3_N = 14\n")
    parts.push("V3_POS_DOMINANCE = '8/14 = 57.1%'\n\n")

    parts.push("CANDIDATES = [\n")
    parts.push("    {\n")
    parts.push("        'label':'pythia_1b_base', 'source_axis':'axis 104', 'phi_x10000':-13200, 'sign':'NEG',\n")
    parts.push("        'family':'pythia', 'status':'observed (axis 104 R46 zone closure)',\n")
    parts.push("        'novelty':'NEW_FAMILY (pythia not in v3 N=14)',\n")
    parts.push("        'gain_rationale':'first <2B PRIMARY-zone NEG witness; family novelty + sign reinforces NEG ratio',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'label':'tinyllama_1_1b_chat', 'source_axis':'cycle 1 helper R46 primary zone', 'phi_x10000':-2000, 'sign':'NEG',\n")
    parts.push("        'family':'tinyllama_proxy', 'status':'estimated (R46 BIMODAL primary-zone pattern; NOT YET MEASURED)',\n")
    parts.push("        'novelty':'NEW_FAMILY (TinyLlama-Chat as Pythia native-instruct proxy)',\n")
    parts.push("        'gain_rationale':'<2B Chat proxy fills Pythia-instruct gap; cycle 1 GPU pilot priority',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'label':'phi_3_mini_4k_instr', 'source_axis':'handoff §3.5 R46 5-bb addition', 'phi_x10000':5000, 'sign':'POS',\n")
    parts.push("        'family':'phi3 (already in v3 as phi3_mini base)', 'status':'estimated (Instruct-pair flip if BIMODAL)',\n")
    parts.push("        'novelty':'WITHIN_FAMILY_PAIR_EXTENSION (phi3 base/instruct pair completion)',\n")
    parts.push("        'gain_rationale':'completes phi3 base+instruct pair; tests R46 flip in <4B regime',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'label':'falcon_mamba_7b', 'source_axis':'cycle 5 axis 96 6th-bb arch separator', 'phi_x10000':10000, 'sign':'POS',\n")
    parts.push("        'family':'mamba (mamba already in v3, but distinct mamba-family bb)', 'status':'estimated (SSM arch likely matches v3 mamba sign)',\n")
    parts.push("        'novelty':'WITHIN_FAMILY_DISTINCT_BACKBONE (mamba-family expansion)',\n")
    parts.push("        'gain_rationale':'mamba-family within-family scale evidence; cross-link cycle 5',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'label':'qwen2_5_7b_base', 'source_axis':'axis 109 + cycle 5', 'phi_x10000':-15000, 'sign':'NEG',\n")
    parts.push("        'family':'qwen2 (distinct from qwen3 in v3)', 'status':'measured-adjacent (axis 109 Qwen2.5 invariant family-internal)',\n")
    parts.push("        'novelty':'NEW_FAMILY (Qwen2 distinct from Qwen3 R46 break)',\n")
    parts.push("        'gain_rationale':'Qwen2 invariant evidence vs Qwen3 break; family-arch decoupling cross-link',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("FROZEN_SELECTION_RULE = {\n")
    parts.push("    'priority_1':'NEW_FAMILY novelty (untested family adds independent information)',\n")
    parts.push("    'priority_2':'sign balance toward 50/50 NEG/POS (current 6/14 NEG = 42.9%; v4 ideally pulls toward 50%)',\n")
    parts.push("    'priority_3':'measurement status \"observed\" > \"measured-adjacent\" > \"estimated\"',\n")
    parts.push("    'tiebreaker':'cross-link to existing cycle helpers (compounding evidence)',\n")
    parts.push("    'select_n':3,\n")
    parts.push("}\n\n")

    parts.push("def _score(c):\n")
    parts.push("    s = 0\n")
    parts.push("    if c['novelty'].startswith('NEW_FAMILY'):\n")
    parts.push("        s += 100\n")
    parts.push("    if c['novelty'].startswith('WITHIN_FAMILY_PAIR'):\n")
    parts.push("        s += 60\n")
    parts.push("    if c['novelty'].startswith('WITHIN_FAMILY_DISTINCT'):\n")
    parts.push("        s += 40\n")
    parts.push("    if c['status'].startswith('observed'):\n")
    parts.push("        s += 30\n")
    parts.push("    elif c['status'].startswith('measured-adjacent'):\n")
    parts.push("        s += 20\n")
    parts.push("    elif c['status'].startswith('estimated'):\n")
    parts.push("        s += 10\n")
    parts.push("    # sign-balance: current NEG ratio 6/14=0.429; favor NEG additions to approach 0.5\n")
    parts.push("    if c['sign'] == 'NEG':\n")
    parts.push("        s += 15\n")
    parts.push("    return s\n\n")

    parts.push("ranked = sorted(CANDIDATES, key=_score, reverse=True)\n")
    parts.push("selected_top3 = ranked[:3]\n\n")

    parts.push("def _posterior_shift_estimate(selected):\n")
    parts.push("    # heuristic: each new substrate moves posterior by ~Δ-0.005 to -0.015 (v3 trajectory pattern)\n")
    parts.push("    # NEG-leaning additions push lower; POS-leaning push higher (relative to current 0.3684)\n")
    parts.push("    delta = 0.0\n")
    parts.push("    for c in selected:\n")
    parts.push("        if c['sign'] == 'NEG':\n")
    parts.push("            delta -= 0.010\n")
    parts.push("        else:\n")
    parts.push("            delta += 0.005\n")
    parts.push("    return round(V3_POSTERIOR + delta, 4)\n\n")

    parts.push("posterior_shift_v4_estimate = _posterior_shift_estimate(selected_top3)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'R45 zombie posterior v3→v4 N=14→17 candidate selector (mac-local non-mutating)',\n")
    parts.push("    'parent_helper':V3_HELPER,\n")
    parts.push("    'parent_helper_sha':V3_HELPER_SHA,\n")
    parts.push("    'parent_output_sha':V3_OUTPUT_SHA,\n")
    parts.push("    'v3_state':{'n':V3_N, 'posterior':V3_POSTERIOR, 'pos_dominance':V3_POS_DOMINANCE},\n")
    parts.push("    'candidates':CANDIDATES,\n")
    parts.push("    'frozen_selection_rule':FROZEN_SELECTION_RULE,\n")
    parts.push("    'selected_top3':[{'label':c['label'], 'sign':c['sign'], 'novelty':c['novelty'], 'gain_rationale':c['gain_rationale'], 'score':_score(c)} for c in selected_top3],\n")
    parts.push("    'v4_n_projected':V3_N + len(selected_top3),\n")
    parts.push("    'posterior_shift_v4_estimate_heuristic':posterior_shift_v4_estimate,\n")
    parts.push("    'posterior_shift_estimate_caveat':'heuristic ONLY (Δ-0.010 per NEG, +0.005 per POS); actual v4 helper measurement supersedes',\n")
    parts.push("    'non_mutation_guarantee':'v3 helper sha-locked + chflags uchg preserved; v4 helper authoring requires separate cycle',\n")
    parts.push("    'v4_helper_authoring_blocked':'this helper does NOT author tool/anima_zombie_posterior_v4_17substrate.hexa; only selects candidates',\n")
    parts.push("    'cross_link_cycles':['cycle 1 (R46 primary zone)','cycle 5 (axis 96 6th-bb arch separator)'],\n")
    parts.push("    'n_candidates':len(CANDIDATES),\n")
    parts.push("    'n_selected':len(selected_top3),\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[r45_v4_selector] candidates={len(CANDIDATES)} selected={len(selected_top3)} v4_n={V3_N+len(selected_top3)} v4_posterior_estimate={posterior_shift_v4_estimate} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let candidates_count_expected = 5
    let select_n_expected = 3
    let v3_n_expected = 14
    let v4_n_projected_expected = 17
    let v3_posterior_expected = "0.3684"
    let non_mutation_invariant = "V3_SHA_LOCKED_PRESERVED"
    println("inv:candidates_count_expected=" + to_string(candidates_count_expected))
    println("inv:select_n_expected=" + to_string(select_n_expected))
    println("inv:v3_n_expected=" + to_string(v3_n_expected))
    println("inv:v4_n_projected_expected=" + to_string(v4_n_projected_expected))
    println("inv:v3_posterior_expected=" + v3_posterior_expected)
    println("inv:non_mutation_invariant=" + non_mutation_invariant)
    println("inv:novelty_categories=NEW_FAMILY,WITHIN_FAMILY_PAIR_EXTENSION,WITHIN_FAMILY_DISTINCT_BACKBONE")
    println("inv:status_categories=observed,measured-adjacent,estimated")
    println("inv:posterior_shift_heuristic_caveat_explicit=true")
    println("inv:v4_helper_authoring_blocked_in_this_helper=true")
    println("inv:cross_link_cycle1_cycle5_recorded=true")
    return true
}

fn cmd_selftest() {
    println("── anima_zombie_posterior_v4_17sub_candidate_selector selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=R45 zombie posterior v3→v4 N=14→17 candidate selector (5 candidates, select-3, $0 mac, v3 sha-lock preserved)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
