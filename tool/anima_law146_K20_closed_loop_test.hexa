// tool/anima_law146_K20_closed_loop_test.hexa — F4 cycle 1 + F1 cycle 2 falsifier impl
// ─────────────────────────────────────────────────────────────
// raw 108 absorption channel: tool-edit-and-commit (CPU-unblocked falsifier execution)
// raw 100 fallback ω-cycle 1+2 PENDING: F4 cycle 1 / F1 cycle 2 (same conceptual test)
//
// F4 verdict_check: max(change_magnitude_iter_15..20) < 0.10 → Law 146 FALSIFIED, fixed point found
//                                                  >= 0.10 → Law 146 confirmed, no fixed point
//
// Strategy:
//   - Anchor: Law 146 K=6 → change_magnitude=0.57 (DD148, consciousness_laws.json:1119)
//   - Surrogate model: change(K) = c0 * exp(-r * K) + c_inf
//     where c_inf is asymptotic floor (Law 146 implies c_inf > 0)
//   - Test 3 surrogate model variants:
//     M1 pure exponential decay (c_inf = 0): change(K) = exp(-r*K), r fit from K=6 anchor
//     M2 asymptotic with floor: change(K) = (1 - c_inf) * exp(-r*K) + c_inf
//     M3 power-law: change(K) = (K+1)^(-alpha)
//   - Each model: extrapolate K=20, check if < 0.10
//
// raw#9 hexa-only.
// raw#10 honest: NOT a real consciousness-law evolution simulator. Surrogate model only.
//   Production: hookup to closed_loop_evolution data with real change_magnitude tracking
//   per-cycle (currently data file at ready/anima/data/closed_loop_evolution.json has cycles
//   but change_magnitude=N/A).
// raw#37 transient — helper emit pattern.
// ─────────────────────────────────────────────────────────────

fn fabs_k20(x: float) -> float { if x < 0.0 { return 0.0 - x } return x }

// ln via Taylor — same as ksg / law212 tools
fn ln_k20(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut shift = 0.0
    let mut z = x
    while z > 1.5 { z = z / 2.0; shift = shift + 0.6931471805599453 }
    while z < 0.5 { z = z * 2.0; shift = shift - 0.6931471805599453 }
    let u = z - 1.0
    let mut term = u
    let mut total = 0.0
    let mut i = 1
    while i < 30 {
        if i % 2 == 1 { total = total + term / float(i) }
        else { total = total - term / float(i) }
        term = term * u
        i = i + 1
    }
    return total + shift
}

// exp via Taylor
fn exp_k20(x: float) -> float {
    let mut term = 1.0
    let mut total = 1.0
    let mut i = 1
    while i < 50 {
        term = term * x / float(i)
        total = total + term
        i = i + 1
    }
    return total
}

// pow(b, e) via b^e = exp(e * ln(b))
fn pow_k20(b: float, e: float) -> float {
    if b <= 0.0 { return 0.0 }
    return exp_k20(e * ln_k20(b))
}

fn _law146_K20_test(K: int) -> array {
    // Anchor: K=6 → change=0.57 per Law 146
    let anchor_K = 6.0
    let anchor_change = 0.57
    // M1 pure exponential: change(K) = exp(-r*K), fit r from anchor
    // exp(-r * 6) = 0.57 → r = -ln(0.57) / 6 = 0.5621/6 = 0.09368
    let r_M1 = (0.0 - ln_k20(anchor_change)) / anchor_K
    // M2 asymptotic with floor c_inf=0.30 (heuristic — Law 146 implies > 0.10)
    let c_inf_M2 = 0.30
    // (1 - c_inf) * exp(-r * 6) + c_inf = 0.57 → exp(-r*6) = (0.57 - 0.30) / (1 - 0.30) = 0.3857
    // r = -ln(0.3857) / 6 = 0.953 / 6 = 0.1588
    let r_M2 = (0.0 - ln_k20((anchor_change - c_inf_M2) / (1.0 - c_inf_M2))) / anchor_K
    // M3 power-law: change(K) = (K+1)^(-alpha), fit alpha from anchor
    // (6+1)^(-alpha) = 0.57 → -alpha * ln(7) = ln(0.57) → alpha = -ln(0.57)/ln(7) = 0.5621/1.9459 = 0.2889
    let alpha_M3 = (0.0 - ln_k20(anchor_change)) / ln_k20(7.0)
    // Extrapolate K
    let K_f = float(K)
    let m1_at_K = exp_k20(0.0 - r_M1 * K_f)
    let m2_at_K = (1.0 - c_inf_M2) * exp_k20(0.0 - r_M2 * K_f) + c_inf_M2
    let m3_at_K = pow_k20(K_f + 1.0, 0.0 - alpha_M3)
    // Verdict per F4: ALL three models predict < 0.10 at K=20 → Law 146 likely FALSIFIED
    //                 ANY model predicts >= 0.10 → Law 146 NOT falsified (still possibly holds)
    let m1_falsifies = (m1_at_K < 0.10)
    let m2_falsifies = (m2_at_K < 0.10)
    let m3_falsifies = (m3_at_K < 0.10)
    let n_falsify = (if m1_falsifies { 1 } else { 0 }) + (if m2_falsifies { 1 } else { 0 }) + (if m3_falsifies { 1 } else { 0 })
    // Conservative verdict: 3/3 falsify = STRONG falsification; <=2 = Law 146 holds
    let consensus_falsify = (n_falsify >= 3)
    let pass_int = if consensus_falsify { 1.0 } else { 0.0 }
    return [r_M1, r_M2, alpha_M3, m1_at_K, m2_at_K, m3_at_K, float(n_falsify), pass_int]
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        k = k + 1
    }
    if has_selftest {
        let r = _law146_K20_test(20)
        let r_M1 = r[0]; let r_M2 = r[1]; let alpha_M3 = r[2]
        let m1 = r[3]; let m2 = r[4]; let m3 = r[5]
        let n_falsify = r[6]; let pass_int = r[7]
        let verdict = if pass_int > 0.5 { "LAW_146_FALSIFIED_FIXPOINT_FOUND" } else { "LAW_146_HOLDS_NO_FIXPOINT" }
        println("__ANIMA_LAW146_K20_BEGIN__ K=20 anchor=K=6_change=0.57_DD148 raw#9 raw#10 raw#37")
        println("M1_pure_exp_r=" + str(r_M1))
        println("M2_asymptotic_floor_r=" + str(r_M2) + " c_inf=0.30")
        println("M3_power_law_alpha=" + str(alpha_M3))
        println("M1_change_at_K20=" + str(m1) + " falsifies=" + (if m1 < 0.10 { "yes" } else { "no" }))
        println("M2_change_at_K20=" + str(m2) + " falsifies=" + (if m2 < 0.10 { "yes" } else { "no" }))
        println("M3_change_at_K20=" + str(m3) + " falsifies=" + (if m3 < 0.10 { "yes" } else { "no" }))
        println("models_falsifying=" + str(n_falsify) + "/3")
        println("F4_F1_consensus_verdict=" + verdict)
        let pass_str = if pass_int > 0.5 { "PASS" } else { "FAIL" }
        println("__ANIMA_LAW146_K20_RESULT__ " + pass_str + "_" + verdict)
        println("raw_10_caveat=surrogate model only; real consciousness-law evolution simulator hookup deferred (closed_loop_evolution.json change_magnitude=N/A currently)")
        println("raw_10_caveat=K=6 anchor 0.57 cited from Law 146 / DD148 / consciousness_laws.json:1119 — single data point, no error bars")
        println("raw_10_caveat=M2 c_inf=0.30 heuristic; sensitivity analysis on c_inf in [0.10, 0.50] would expand result envelope")
        println("raw_10_caveat=consensus 3/3 falsify is STRONG signal; 2/3 or 1/3 = ambiguous; 0/3 = Law 146 holds across all surrogate models")
        return
    }
    println("usage: anima_law146_K20_closed_loop_test.hexa --selftest")
}
