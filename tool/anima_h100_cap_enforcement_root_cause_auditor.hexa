// tool/anima_h100_cap_enforcement_root_cause_auditor.hexa — H100 cap enforcement root cause audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 54 finding: COST_CAP/RUNTIME_CAP escaped 61.5×.
//   cycle 57 root cause: cap env vars are SET in launch helpers, but
//   ENFORCEMENT runtime (h100_auto_kill or runpod_watchdog) NOT auto-attached.
//
//   Anima codebase already has guards:
//     - tool/h100_auto_kill.hexa (roadmap #34 "H100 auto-kill idle ($143/2d 낭비 방지)")
//     - training/runpod_watchdog.hexa (on-pod watchdog with IDLE_TEARDOWN)
//
//   But neither is running for current 2 active pods → caps escape.
//
//   본 helper = mac-local NON_MUTATION:
//     - launch helpers inventory (mk_xi_launch_pod, runpod_orchestrator)
//     - guard helpers existence check (h100_auto_kill, runpod_watchdog)
//     - cap enforcement gap quantification
//     - remediation script proposed (NON_MUTATION; user manual launch)
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/h100_cap_enforcement_root_cause_auditor.json)
//
// OUTPUT
//   - launch_helpers
//   - guard_helpers + running_status
//   - root_cause_finding
//   - remediation_proposal
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_h100_cap_enforcement_root_cause_auditor.hexa --selftest
//   ANIMA_OUTPUT=state/h100_cap_enforcement_root_cause_auditor.json hexa run tool/anima_h100_cap_enforcement_root_cause_auditor.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - 전제: actual launch script (sae-steer, gwt-deepseek) 위치는 unknown — env COST_CAP=$1
//     세팅했지만 mk_xi_launch_pod (COST_CAP=20)와 다름. 별도 launch script 의심.
//   - guard helpers는 manual 실행 필요 (--apply daemon 형태로).

let HELPER_PATH = "/tmp/anima_h100_cap_enforcement_root_cause_auditor_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima H100 cap enforcement root cause auditor — emitted by tool/anima_h100_cap_enforcement_root_cause_auditor.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION root cause record.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/h100_cap_enforcement_root_cause_auditor.json')\n\n")

    parts.push("LAUNCH_HELPERS = [\n")
    parts.push("    {'path':'tool/mk_xi_launch_pod.hexa', 'sets_cost_cap':True, 'sets_runtime_cap':True, 'cap_default':'COST_CAP=20, RUNTIME_CAP_MIN=120', 'auto_attach_kill':False, 'note':'sets caps in env; instructs user to manually launch h100_auto_kill (step 5)'},\n")
    parts.push("    {'path':'tool/anima_runpod_orchestrator.hexa', 'sets_cost_cap':True, 'sets_runtime_cap':True, 'cap_default':'args.max_cost / args.max_runtime_min', 'auto_attach_kill':False, 'note':'env-only; no enforcement runtime'},\n")
    parts.push("    {'path':'training/launch_alm_*.hexa', 'sets_cost_cap':'unknown', 'sets_runtime_cap':'unknown', 'auto_attach_kill':'unknown', 'note':'multiple launch_alm_* helpers; need per-helper review'},\n")
    parts.push("]\n\n")

    parts.push("GUARD_HELPERS = [\n")
    parts.push("    {\n")
    parts.push("        'path':'tool/h100_auto_kill.hexa',\n")
    parts.push("        'present':os.path.exists('tool/h100_auto_kill.hexa'),\n")
    parts.push("        'role':'idle pod auto-kill guard',\n")
    parts.push("        'roadmap_motivation':'cluster #34 improvement (23) — H100 auto-kill idle ($143/2d 낭비 방지)',\n")
    parts.push("        'usage':'hexa run tool/h100_auto_kill.hexa --apply (default dry-run)',\n")
    parts.push("        'config':'config/h100_auto_kill_config.json',\n")
    parts.push("        'pods':'config/h100_pods.json',\n")
    parts.push("        'currently_running':False,  # if running, current 2 IDLE pods would be killed\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'path':'training/runpod_watchdog.hexa',\n")
    parts.push("        'present':os.path.exists('training/runpod_watchdog.hexa'),\n")
    parts.push("        'role':'on-pod watchdog (crash + idle teardown)',\n")
    parts.push("        'roadmap_motivation':'9+ hour idle H100 burn on r9 incident (alm14b_r10 status file went stale)',\n")
    parts.push("        'usage':'on-pod: hexa training/runpod_watchdog.hexa <run_id> <train_pid>',\n")
    parts.push("        'status_values':'INIT|TRAINING|SENTINEL|SAVING|UPLOADING|DONE|CRASHED|DEAD|IDLE_TEARDOWN',\n")
    parts.push("        'currently_running_per_pod':False,  # would teardown idle\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("ROOT_CAUSE_FINDING = {\n")
    parts.push("    'observation':'cycle 54: actual COST_CAP=$1, RUNTIME_CAP_MIN=12-15 in pod env; actual runtime 28-30h (61.5× cap escape)',\n")
    parts.push("    'investigation':[\n")
    parts.push("        '1. tool/mk_xi_launch_pod.hexa default COST_CAP=20 — different from actual $1 pods',\n")
    parts.push("        '2. → 2 active pods launched by DIFFERENT helper (sae-steer / gwt-deepseek; sets COST_CAP=$1)',\n")
    parts.push("        '3. tool/h100_auto_kill.hexa EXISTS but NOT running daemon → idle pods unattended',\n")
    parts.push("        '4. training/runpod_watchdog.hexa EXISTS but per-pod must be invoked → not auto-deployed',\n")
    parts.push("    ],\n")
    parts.push("    'root_cause':'launch helpers SET caps as env vars but do NOT auto-attach guard runtime. Caps become decorative; enforcement requires manual h100_auto_kill --apply or per-pod runpod_watchdog.',\n")
    parts.push("    'severity':'CRITICAL — already $122.96 wasted; recurring incident pattern',\n")
    parts.push("}\n\n")

    parts.push("REMEDIATION_PROPOSAL = [\n")
    parts.push("    {\n")
    parts.push("        'priority':'IMMEDIATE',\n")
    parts.push("        'action':'verify config/h100_pods.json includes current 2 active pod IDs',\n")
    parts.push("        'commands':['cat config/h100_pods.json'],\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'priority':'IMMEDIATE',\n")
    parts.push("        'action':'run h100_auto_kill --apply (one-shot now to terminate idle)',\n")
    parts.push("        'commands':['hexa run tool/h100_auto_kill.hexa --apply'],\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'priority':'PREVENTION',\n")
    parts.push("        'action':'schedule h100_auto_kill cron (hourly) to prevent recurrence',\n")
    parts.push("        'commands':['# add cron entry: 0 * * * * hexa run tool/h100_auto_kill.hexa --apply'],\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'priority':'PREVENTION',\n")
    parts.push("        'action':'patch launch helpers to auto-attach watchdog post-create',\n")
    parts.push("        'commands':['# edit mk_xi_launch_pod.hexa step 5 to invoke runpod_watchdog automatically'],\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'H100 cap enforcement root cause audit (cycle 54-56 chain root finding)',\n")
    parts.push("    'launch_helpers':LAUNCH_HELPERS,\n")
    parts.push("    'guard_helpers':GUARD_HELPERS,\n")
    parts.push("    'root_cause_finding':ROOT_CAUSE_FINDING,\n")
    parts.push("    'remediation_proposal':REMEDIATION_PROPOSAL,\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify launch helpers or guard helpers; user manual remediation required',\n")
    parts.push("    'cross_link_cycles':['cycle 54 runaway cost incident','cycle 56 ssh activity','cycle 13 H100 P1 precheck'],\n")
    parts.push("    'pattern':'governance audit chain layer 36 (cycles 21-56 + this) — root cause analysis closure',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[cap_enforcement] launch_helpers={len(LAUNCH_HELPERS)} guards_present={sum(1 for g in GUARD_HELPERS if g[\"present\"])}/{len(GUARD_HELPERS)} root_cause=set_env_only_no_runtime_attach remediation_steps={len(REMEDIATION_PROPOSAL)} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let launch_helpers_min = 2
    let guard_helpers_min = 2
    let remediation_steps = 4
    let non_mutation = "READ_ONLY"
    println("inv:launch_helpers_min=" + to_string(launch_helpers_min))
    println("inv:guard_helpers_min=" + to_string(guard_helpers_min))
    println("inv:remediation_steps=" + to_string(remediation_steps))
    println("inv:non_mutation=" + non_mutation)
    println("inv:cross_link_cycle54_cycle56_cycle13=true")
    return true
}

fn cmd_selftest() {
    println("── anima_h100_cap_enforcement_root_cause_auditor selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=H100 cap enforcement root cause audit (env set but no runtime attach; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
