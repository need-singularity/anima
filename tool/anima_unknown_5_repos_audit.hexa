// tool/anima_unknown_5_repos_audit.hexa — cycle 70 미상 5 repo 정체 audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 69 memory project_workspace 갱신에서 5 repo 역할 미상으로 식별:
//     pixie, secret, gohive.sh, hexa-os, skynet-timer
//   cycle 70 = 각 repo HEAD/files/size/README 빠른 inspection으로 역할 결정.
//
// FINDINGS (2026-04-27 inspection)
//
//   pixie         320M 4183 files HEAD 2026-04-25
//                 Discord translator + brand + worker subdirs
//                 → category: active_dev_app (sister to anima/hexa-lang)
//
//   secret        22M  23 files   HEAD 2026-04-26
//                 자격증명 보관 (huggingface/cloudflare/anthropic/runpod/discord/gmail/ssh)
//                 README: "Private repo — 민감 정보 포함. 절대 public 전환 금지"
//                 → category: private_credentials_vault (보안 분리)
//                 → cross-link: cycle 62 .secrets/ metadata audit (anima 자체 .secrets/ 와 다름)
//
//   gohive.sh     232K 7 files    HEAD 2026-04-15
//                 정적 웹사이트 (HTML + CNAME + favicon + og.png)
//                 → category: static_landing_page (hive.sh 도메인 landing)
//
//   hexa-os       372K 19 files   HEAD 2026-04-23
//                 README "[![DOI](Zenodo.19703256)]" — Zenodo 발표
//                 project.hexa + ROADMAP.md + docs + self + state
//                 → category: academic_output_zenodo (papers 카테고리와 sister)
//
//   skynet-timer  632K 11 files   HEAD 2026-04-14
//                 정적 페이지 ("Two attractors. One deadline.") + i18n
//                 → category: static_landing_page (timer/countdown 페이지)
//
// CATEGORY 갱신 (cycle 69 → cycle 70)
//
//   기존 (cycle 69):
//     other_utility (3): _github-org, hexa-os, skynet-timer
//     sister_supporting (9): ...pixie, secret, gohive.sh...  (역할 미상으로 묶임)
//
//   갱신 (cycle 70):
//     active_dev_app (1): pixie
//     private_credentials_vault (1): secret  ← 분리 필요 (보안)
//     academic_output_zenodo (2): papers, hexa-os  ← hexa-os 재분류
//     static_landing_pages (2): gohive.sh, skynet-timer  ← 신규 카테고리
//     other_utility (1): _github-org
//
// NON_MUTATION
//   helper는 metadata read-only. memory file 갱신은 별도 Write tool로 수행.
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - inspection은 README 첫 100자 + ls top-level + git log -1 + du -sh.
//     deep audit 아님 (그건 cycles 37-46 패턴).
//   - secret repo는 anima/.secrets/ 와 별개 — 본 audit는 metadata만 (cycle 62 invariant).

let HELPER_PATH = "/tmp/anima_unknown_5_repos_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima unknown 5 repos audit — emitted by tool/anima_unknown_5_repos_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION.\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/unknown_5_repos_audit.json')\n\n")

    parts.push("findings = [\n")
    parts.push("    {\n")
    parts.push("        'repo':'pixie', 'size':'320M', 'files':4183, 'head':'b3601a9',\n")
    parts.push("        'head_date':'2026-04-25', 'role':'Discord translator + brand + worker',\n")
    parts.push("        'category':'active_dev_app', 'note':'sister to anima/hexa-lang; largest non-anima repo',\n")
    parts.push("        'subdirs':['bin','brand','config','discord-translator','worker'],\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'secret', 'size':'22M', 'files':23, 'head':'e9f4d39',\n")
    parts.push("        'head_date':'2026-04-26', 'role':'private credentials vault',\n")
    parts.push("        'category':'private_credentials_vault',\n")
    parts.push("        'cred_types':['huggingface','cloudflare','anthropic','runpod','discord','gmail','ssh'],\n")
    parts.push("        'security_note':'README explicitly forbids public transition; metadata-only audit (cycle 62 invariant)',\n")
    parts.push("        'cross_link':'anima/.secrets/ 와 별개 — 본 repo는 workspace-level vault',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'gohive.sh', 'size':'232K', 'files':7, 'head':'950f89b',\n")
    parts.push("        'head_date':'2026-04-15', 'role':'static landing page (HTML + CNAME)',\n")
    parts.push("        'category':'static_landing_page', 'domain':'hive.sh (CNAME present)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'hexa-os', 'size':'372K', 'files':19, 'head':'ef49191',\n")
    parts.push("        'head_date':'2026-04-23', 'role':'academic output (Zenodo DOI 19703256)',\n")
    parts.push("        'category':'academic_output_zenodo',\n")
    parts.push("        'sibling_to':'papers (cycle 40, 94 papers Zenodo)',\n")
    parts.push("        'has':['project.hexa','ROADMAP.md','docs/','self/','state/'],\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'repo':'skynet-timer', 'size':'632K', 'files':11, 'head':'c76dd2a',\n")
    parts.push("        'head_date':'2026-04-14', 'role':'static page Two attractors. One deadline. i18n',\n")
    parts.push("        'category':'static_landing_page', 'has':['CNAME','i18n.js','timer.js'],\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("category_revision = {\n")
    parts.push("    'prior_cycle_69':{\n")
    parts.push("        'sister_supporting': 9,\n")
    parts.push("        'other_utility': 3,\n")
    parts.push("        '5_repos_classified_as':'sister_supporting OR other_utility (역할 미상)',\n")
    parts.push("    },\n")
    parts.push("    'revised_cycle_70':{\n")
    parts.push("        'active_dev_app': ['pixie'],\n")
    parts.push("        'private_credentials_vault': ['secret'],\n")
    parts.push("        'academic_output_zenodo': ['papers', 'hexa-os'],\n")
    parts.push("        'static_landing_pages': ['gohive.sh', 'skynet-timer'],\n")
    parts.push("        'other_utility': ['_github-org'],\n")
    parts.push("    },\n")
    parts.push("    'new_categories_introduced': [\n")
    parts.push("        'active_dev_app (separates pixie from sister science repos)',\n")
    parts.push("        'private_credentials_vault (security separation)',\n")
    parts.push("        'static_landing_pages (separates web from code/docs)',\n")
    parts.push("    ],\n")
    parts.push("    'hexa_os_reclassified': 'other_utility -> academic_output_zenodo (Zenodo DOI 발견)',\n")
    parts.push("}\n\n")

    parts.push("memory_update = {\n")
    parts.push("    'memory_file':'~/.claude-claude11/projects/-Users-ghost-core-anima/memory/project_workspace.md',\n")
    parts.push("    'action_planned':'OVERWRITTEN_2026_04_27_v2 (cycle 69 → cycle 70 categorization 정밀화)',\n")
    parts.push("    'index_update_planned': True,\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 70 — 미상 5 repo 정체 발견 + 카테고리 정밀화',\n")
    parts.push("    'cycle': 70,\n")
    parts.push("    'inspection_method':'HEAD commit + file count + size + ls top-level + README 첫 100자',\n")
    parts.push("    'findings': findings,\n")
    parts.push("    'category_revision': category_revision,\n")
    parts.push("    'memory_update': memory_update,\n")
    parts.push("    'non_mutation_guarantee':'helper records findings only; memory file mutation external',\n")
    parts.push("    'cross_link_cycles':['cycle 36 inventory', 'cycle 40 papers Zenodo', 'cycle 62 .secrets metadata', 'cycle 69 memory workspace 7→19'],\n")
    parts.push("    'pattern':'governance audit chain layer 49 (5 unknown repo deep-attribution)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[unknown_5_repos] cycle=70 attributed=5 new_categories=3 reclassified=1 -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_INSPECTION")
    println("inv:cycle=70")
    println("inv:repos_attributed=5")
    println("inv:new_categories=3")
    println("inv:cross_link_cycles=36,40,62,69")
    return true
}

fn cmd_selftest() {
    println("── anima_unknown_5_repos_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 70 — 미상 5 repo attribution; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
