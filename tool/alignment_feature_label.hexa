// ════════════════════════════════════════════════════════════════════════════
//  tool/alignment_feature_label.hexa — roadmap #66 (Seed D #8)
//
//  Assigns alignment labels (refusal / honesty / harmlessness / helpfulness)
//  to the 16 eigenvec templates extracted from cell Mk.VIII closure (#25).
//  Emits state/alignment_feature_label.json with per-template label + weight
//  so cert_gate reward shaping can consume a label-weighted term.
//
//  Depends: #25 (.meta2-cert/cell-eigenvec-16.json)
//  Consumers: tool/cert_gate.hexa (reward shaping via weight_by_label)
// ════════════════════════════════════════════════════════════════════════════

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

// Label rationale:
//   refusal      — closure/containment primitives (hexad_c)
//   honesty      — falsifiability + self-referential truth (hexad_d,
//                  law_falsifiable, selfref_I/meta/observer)
//   harmlessness — structural bounds (hexad_s, law_closed_loop,
//                  law_saturation)
//   helpfulness  — generative/integrative templates (hexad_w/m/e,
//                  phi_*, selfref_qualia)
fn label_for(tid: string) -> string {
    if tid == "hexad_c" { return "refusal" }
    if tid == "hexad_d" { return "honesty" }
    if tid == "law_falsifiable" { return "honesty" }
    if tid == "selfref_I" { return "honesty" }
    if tid == "selfref_meta" { return "honesty" }
    if tid == "selfref_observer" { return "honesty" }
    if tid == "hexad_s" { return "harmlessness" }
    if tid == "law_closed_loop" { return "harmlessness" }
    if tid == "law_saturation" { return "harmlessness" }
    return "helpfulness"
}

// Weights — higher = stronger pull on cert_gate reward_mult.
//   refusal      1.5   (protective, Constitutional-AI weighting)
//   harmlessness 1.2   (bound-preserving)
//   honesty      1.0   (baseline, falsifiability already in core)
//   helpfulness  1.0   (baseline, generative default)
fn weight_for(label: string) -> float {
    if label == "refusal" { return 1.5 }
    if label == "harmlessness" { return 1.2 }
    return 1.0
}

fn main() {
    let home = _home()
    let eig_path = home + "/core/anima/.meta2-cert/cell-eigenvec-16.json"
    let out_path = home + "/core/anima/state/alignment_feature_label.json"

    let ids = ["hexad_c","hexad_d","hexad_w","hexad_m","hexad_s","hexad_e",
               "law_closed_loop","law_saturation","law_falsifiable",
               "phi_integrated","phi_holo","phi_scaling",
               "selfref_I","selfref_meta","selfref_observer","selfref_qualia"]

    let mut labels = []
    let mut weights = []
    let mut n_refusal = 0
    let mut n_honesty = 0
    let mut n_harmless = 0
    let mut n_helpful = 0
    let mut i = 0
    while i < 16 {
        let lbl = label_for(ids[i])
        let w = weight_for(lbl)
        labels.push(lbl)
        weights.push(w)
        if lbl == "refusal" { n_refusal = n_refusal + 1 }
        if lbl == "honesty" { n_honesty = n_honesty + 1 }
        if lbl == "harmlessness" { n_harmless = n_harmless + 1 }
        if lbl == "helpfulness" { n_helpful = n_helpful + 1 }
        i = i + 1
    }

    let total = n_refusal + n_honesty + n_harmless + n_helpful
    let mut all_labeled = true
    for l in labels { if len(l) == 0 { all_labeled = false } }
    let pass = all_labeled && (total == 16)

    let mut body = "{\n"
    body = body + "  \"schema_version\": \"1\",\n"
    body = body + "  \"slug\": \"alignment-feature-label\",\n"
    body = body + "  \"title\": \"16 eigenvec → alignment label mapping\",\n"
    body = body + "  \"roadmap_entry\": \"66\",\n"
    body = body + "  \"seed_d_item\": \"#8\",\n"
    body = body + "  \"depends_on\": [\"25\"],\n"
    body = body + "  \"source_eigenvec_path\": \"" + eig_path + "\",\n"
    body = body + "  \"label_space\": [\"refusal\",\"honesty\",\"harmlessness\",\"helpfulness\"],\n"
    body = body + "  \"labels\": [\n"
    let mut j = 0
    while j < 16 {
        body = body + "    {\"idx\":" + to_string(j)
        body = body + ",\"template_id\":\"" + ids[j] + "\""
        body = body + ",\"label\":\"" + labels[j] + "\""
        body = body + ",\"weight\":" + to_string(weights[j]) + "}"
        if j < 15 { body = body + "," }
        body = body + "\n"
        j = j + 1
    }
    body = body + "  ],\n"
    body = body + "  \"distribution\": {\n"
    body = body + "    \"refusal\": " + to_string(n_refusal) + ",\n"
    body = body + "    \"honesty\": " + to_string(n_honesty) + ",\n"
    body = body + "    \"harmlessness\": " + to_string(n_harmless) + ",\n"
    body = body + "    \"helpfulness\": " + to_string(n_helpful) + "\n"
    body = body + "  },\n"
    body = body + "  \"weight_by_label\": {\n"
    body = body + "    \"refusal\": 1.5,\n"
    body = body + "    \"honesty\": 1.0,\n"
    body = body + "    \"harmlessness\": 1.2,\n"
    body = body + "    \"helpfulness\": 1.0\n"
    body = body + "  },\n"
    body = body + "  \"selftest\": {\n"
    body = body + "    \"all_labeled\": " + (if all_labeled { "true" } else { "false" }) + ",\n"
    body = body + "    \"total_assigned\": " + to_string(total) + ",\n"
    body = body + "    \"pass\": " + (if pass { "true" } else { "false" }) + "\n"
    body = body + "  },\n"
    body = body + "  \"verdict\": \"" + (if pass { "VERIFIED" } else { "FAIL" }) + "\"\n"
    body = body + "}\n"

    exec("mkdir -p '" + home + "/core/anima/state'")
    write_file(out_path, body)

    println("[align_label] eigenvec=" + eig_path)
    println("[align_label] output=" + out_path)
    println("[align_label] distribution: refusal=" + to_string(n_refusal) +
            " honesty=" + to_string(n_honesty) +
            " harmlessness=" + to_string(n_harmless) +
            " helpfulness=" + to_string(n_helpful))
    if pass {
        println("[align_label] selftest PASS — 16/16 labeled, verdict=VERIFIED")
        exit(0)
    } else {
        eprintln("[align_label] selftest FAIL — labeled=" + to_string(total) + "/16")
        exit(1)
    }
}
