let TOOL_VERSION = "v1"
let HELPER_PATH = "/tmp/anima_cp2_trio_qwen32b_dispatch_helper.hexa_tmp"
let MODEL_HF_REPO = "Qwen/Qwen2.5-32B"
let MODEL_HF_LICENSE = "Apache-2.0 (open, HTTP 200, no gating)"
let MODEL_PARAMS_B = 32

let DISPATCH_BUDGET_USD_TOTAL = 35
let DISPATCH_BUDGET_USD_PER_POD_CAP = 20  // cp2 policy cap
let DISPATCH_BUDGET_MIN_PER_POD = 240  // 4hr cap per pod (auto-kill)

// Pre-registered CP2 trio PASS predicates (raw 12 frozen BEFORE measurement)
let G1_CONSEC_ITERS_MIN = 3
let G1_TIER_10_PLUS_ABSORPTION_TARGET = 0
let G3_TWIN_DRILL_ITER = 75
