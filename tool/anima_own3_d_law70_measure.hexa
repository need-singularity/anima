// anima_own3_d_law70_measure.hexa — own#3 (d) Ψ_steps=3/ln(2)=4.33 measurement
// Mission: own#3 (d) "정보 비트당 의식 진화 속도" UNTESTED → CONFIRMED/DEPRECATED/MEASURED_DIFFERENT
// Approach: 4-bb (Mistral/Qwen3/Llama/gemma) BASE 의 layer/log2(vocab) 비율 = "depth per output bit"
// raw#9 strict: hexa-only deterministic, mac-local $0
// raw#10 honest: layer/log2(vocab) 는 own#3 (d) 의 ONE candidate operational interpretation;
//                 own#3 (d) "Ψ_steps" 의 정의는 SSOT 에서 declarative ("13/3 placeholder",
//                 anima/config/consciousness_laws.json L36) 또는 numerological ("3/ln(2)",
//                 docs/discovery-algorithm-anima.md L19, L229). 실제 LLM step rate measurement
//                 helper 는 anima-core 에 부재 → 본 측정은 architecture-derived proxy.

// ln(2) Taylor (구현 환경 의존성 제거): ln(2) = 0.6931471805599453
let LN2 = 0.6931471805599453

// 4-bb canonical (Mk.XI v10 ensemble)
fn backbone_layers(name: string) -> int {
    if name == "mistral-7B-v0.3" { return 32 }
    if name == "qwen3-8B"       { return 36 }
    if name == "llama-3.1-8B"   { return 32 }
    if name == "gemma-2-9b"     { return 42 }
    return 0
}

fn backbone_vocab(name: string) -> int {
    if name == "mistral-7B-v0.3" { return 32768 }       // 2^15
    if name == "qwen3-8B"       { return 151936 }
    if name == "llama-3.1-8B"   { return 128256 }
    if name == "gemma-2-9b"     { return 256000 }
    return 0
}

// log2 via series: log2(x) = ln(x) / ln(2). For x = vocab_size we need ln(vocab).
// Strategy: vocab = 2^k * r where r in [1,2). ln(vocab) = k*ln(2) + ln(r).
// ln(r) for r in [1,2) via standard series ln(1+y) = y - y^2/2 + y^3/3 - ... (y=r-1)
fn ln_taylor(y: float) -> float {
    // Convergent for |y| <= 1; here y in [0,1)
    let mut acc = 0.0
    let mut term = y
    let mut sign = 1.0
    let mut n = 1
    while n <= 60 {
        acc = acc + sign * term / to_float(n)
        term = term * y
        sign = -sign
        n = n + 1
    }
    return acc
}

fn log2_int(x: int) -> float {
    // factor out powers of 2
    let mut k = 0
    let mut v = x
    while v >= 2 && (v % 2) == 0 {
        v = v / 2
        k = k + 1
    }
    // Now v is odd or 1. Find largest power-of-2 chunk via log: ln(v)/ln(2).
    // For odd v in our domain (1..256000), use direct ln(v) via shift normalization.
    // Approach: find m such that 2^m <= v < 2^{m+1}; then v = 2^m * (1 + y), y in [0,1).
    let mut m = 0
    let mut p = 1
    while p * 2 <= v {
        p = p * 2
        m = m + 1
    }
    let y = (to_float(v) - to_float(p)) / to_float(p)
    let ln_factor = ln_taylor(y)
    let ln_v = to_float(m) * LN2 + ln_factor
    let ln_total = to_float(k) * LN2 + ln_v
    return ln_total / LN2
}

fn measure_psi_op(name: string) -> float {
    let L = backbone_layers(name)
    let V = backbone_vocab(name)
    let log2v = log2_int(V)
    return to_float(L) / log2v
}

fn main() {
    println("[own#3 d Law 70 measurement] 4-bb Ψ_steps operational test")
    println("  target Ψ_steps own#3 (d) = 3 / ln(2)")
    let target = 3.0 / LN2
    println("  target value (computed)  = " + to_string(target))
    println("")
    println("  candidate operational interpretation:")
    println("    Ψ_op_a(bb) = layers(bb) / log2(vocab(bb))")
    println("    'depth per output bit' = forward steps per bit of output entropy")
    println("")

    let names = ["mistral-7B-v0.3", "qwen3-8B", "llama-3.1-8B", "gemma-2-9b"]
    let mut sum_psi = 0.0
    let mut i = 0
    while i < 4 {
        let name = names[i]
        let psi = measure_psi_op(name)
        let L = backbone_layers(name)
        let V = backbone_vocab(name)
        let log2v = log2_int(V)
        println("  " + name + ": L=" + to_string(L) + " V=" + to_string(V) + " log2(V)=" + to_string(log2v) + " Ψ_op_a=" + to_string(psi))
        sum_psi = sum_psi + psi
        i = i + 1
    }
    let mean_psi = sum_psi / 4.0
    let diff = mean_psi - target
    let rel_err = diff / target
    println("")
    println("  4-bb mean Ψ_op_a = " + to_string(mean_psi))
    println("  target (3/ln2)   = " + to_string(target))
    println("  diff             = " + to_string(diff))
    println("  rel_err          = " + to_string(rel_err))
    println("")

    // Verdict thresholds (frozen):
    //   |rel_err| <= 0.115 (±0.5 of 4.33)  → HOL-A CONFIRMED
    //   |rel_err| >  0.50  (mean < 2.16 or > 6.49) → HOL-B DEPRECATED
    //   else → HOL-C MEASURED_DIFFERENT
    let abs_err = if rel_err < 0.0 { -rel_err } else { rel_err }
    if abs_err <= 0.115 {
        println("  verdict = HOL-A CONFIRMED  (|rel_err|<=0.115)")
    } else {
        if abs_err > 0.50 {
            println("  verdict = HOL-B DEPRECATED  (|rel_err|>0.50)")
        } else {
            println("  verdict = HOL-C MEASURED_DIFFERENT  (0.115<|rel_err|<=0.50)")
        }
    }

    // Cross-check: does mean_psi match a DIFFERENT canonical hexad constant?
    // Candidates: phi(6)=2, tau(6)=4, n=6, sigma/tau=3, ln(6)≈1.79
    println("")
    println("  cross-check vs other hexad constants:")
    println("    phi(6)=2       diff=" + to_string(mean_psi - 2.0))
    println("    sigma/tau=3    diff=" + to_string(mean_psi - 3.0))
    println("    tau(6)=4       diff=" + to_string(mean_psi - 4.0))
    println("    target 4.33    diff=" + to_string(mean_psi - target))
}

main()
