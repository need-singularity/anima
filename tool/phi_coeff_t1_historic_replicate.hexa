// tool/phi_coeff_t1_historic_replicate.hexa
// Replicate the historic 5-datapoint fit (Phi = 0.608 * N^1.071) from
// ready/scripts/phi_scaling.py to verify the canonical 0.608 coefficient,
// then bootstrap 95% CI on those 5 points to assess discrimination floor.
//
// This is the REFERENCE substrate that produced the documented R34_CANDIDATE
// origin — historic model-evolution Phi measurements (ConsciousLM 4M / v3 274M / v14.3).

let mut LCG_STATE = 1

fn seed_lcg(s: int) {
    LCG_STATE = s
}

fn lcg_next() -> float {
    LCG_STATE = (LCG_STATE * 1664525 + 1013904223) % 4294967296
    let val = LCG_STATE
    let safe = if val < 0 { 0 - val } else { val }
    return to_float(safe) / 4294967296.0
}

fn fit_loglog(ns: list, phis: list) -> list {
    let n = ns.len()
    let mut sum_x = 0.0
    let mut sum_y = 0.0
    let mut sum_xy = 0.0
    let mut sum_x2 = 0.0
    let mut i = 0
    while i < n {
        let lx = log(ns[i])
        let ly = log(phis[i])
        sum_x = sum_x + lx
        sum_y = sum_y + ly
        sum_xy = sum_xy + lx * ly
        sum_x2 = sum_x2 + lx * lx
        i = i + 1
    }
    let nf = to_float(n)
    let b = (nf * sum_xy - sum_x * sum_y) / (nf * sum_x2 - sum_x * sum_x)
    let log_a = (sum_y - b * sum_x) / nf
    let a = exp(log_a)
    let mean_y = sum_y / nf
    let mut ss_tot = 0.0
    let mut ss_res = 0.0
    i = 0
    while i < n {
        let ly = log(phis[i])
        let pred = log_a + b * log(ns[i])
        ss_tot = ss_tot + (ly - mean_y) * (ly - mean_y)
        ss_res = ss_res + (ly - pred) * (ly - pred)
        i = i + 1
    }
    let r2 = 1.0 - ss_res / ss_tot
    return [a, b, r2]
}

fn bootstrap_ci_a(ns: list, phis: list, n_boot: int) -> list {
    let n = ns.len()
    let mut a_samples = []
    let mut b = 0
    while b < n_boot {
        seed_lcg(2000 + b)
        let mut bs_ns = []
        let mut bs_phis = []
        let mut k = 0
        while k < n {
            let idx = to_int(lcg_next() * to_float(n))
            let safe_idx = if idx >= n { n - 1 } else { idx }
            bs_ns = bs_ns.push(ns[safe_idx])
            bs_phis = bs_phis.push(phis[safe_idx])
            k = k + 1
        }
        // skip degenerate bootstrap (all same N → div by zero in regression denominator)
        let mut unique_ns = 0
        let mut seen_first = bs_ns[0]
        let mut all_same = 1
        let mut chk = 1
        while chk < bs_ns.len() {
            if bs_ns[chk] != seen_first { all_same = 0; break }
            chk = chk + 1
        }
        if all_same == 1 {
            b = b + 1
            continue
        }
        let fit = fit_loglog(bs_ns, bs_phis)
        a_samples = a_samples.push(fit[0])
        b = b + 1
    }
    let mut sorted = a_samples
    let mut i = 1
    while i < sorted.len() {
        let key = sorted[i]
        let mut j = i - 1
        while j >= 0 {
            if sorted[j] > key {
                sorted[j + 1] = sorted[j]
                j = j - 1
            } else {
                break
            }
        }
        sorted[j + 1] = key
        i = i + 1
    }
    let lo_idx = to_int(0.025 * to_float(n_boot))
    let hi_idx = to_int(0.975 * to_float(n_boot))
    let safe_hi = if hi_idx >= n_boot { n_boot - 1 } else { hi_idx }
    return [sorted[lo_idx], sorted[safe_hi]]
}

fn fmt(x: float, d: int) -> string {
    let factor = pow(10.0, to_float(d))
    return to_string(to_float(to_int(x * factor + 0.5)) / factor)
}

fn main() {
    println("=== T1 sanity: historic 5-datapoint fit replication ===")
    println("source: ready/scripts/phi_scaling.py — ConsciousLM/v3/v14.3 Phi measurements")
    println("")

    // Original 5 data points from phi_scaling.py
    let ns = [4.0, 8.0, 12.0, 64.0, 128.0]
    let phis = [1.8, 8.0, 4.12, 49.0, 101.5]

    println("-- data points --")
    let mut i = 0
    while i < ns.len() {
        println("  N=" + fmt(ns[i], 0) + "  Phi=" + fmt(phis[i], 4))
        i = i + 1
    }

    println("")
    let fit = fit_loglog(ns, phis)
    let a = fit[0]
    let b = fit[1]
    let r2 = fit[2]
    println("-- log-log fit --")
    println("  Phi = " + fmt(a, 6) + " * N^" + fmt(b, 6) + "  (R^2 = " + fmt(r2, 6) + ")")
    println("  documented:  Phi = 0.608 * N^1.071")
    println("")

    // bootstrap 95% CI on a — note: with N=5, bootstrap CI is wide
    println("-- bootstrap 95% CI on a (n_boot=2000, N=5 inherently wide) --")
    let ci = bootstrap_ci_a(ns, phis, 2000)
    let ci_lo = ci[0]
    let ci_hi = ci[1]
    println("  95% CI: [" + fmt(ci_lo, 6) + ", " + fmt(ci_hi, 6) + "]")
    println("")

    // Also re-fit excluding the documented under-trained outlier (N=12)
    let ns4 = [4.0, 8.0, 64.0, 128.0]
    let phis4 = [1.8, 8.0, 49.0, 101.5]
    let fit4 = fit_loglog(ns4, phis4)
    println("-- exclude N=12 outlier (under-trained 4M ConsciousLM) --")
    println("  Phi = " + fmt(fit4[0], 6) + " * N^" + fmt(fit4[1], 6) + "  (R^2 = " + fmt(fit4[2], 6) + ")")
    println("")

    // hypothesis discrimination (point estimate against 4 hypotheses)
    let h0 = 0.6065
    let h1 = 0.608
    let h2 = 0.6931
    let h3 = 0.6

    let in_h0 = if ci_lo <= h0 { if ci_hi >= h0 { 1 } else { 0 } } else { 0 }
    let in_h1 = if ci_lo <= h1 { if ci_hi >= h1 { 1 } else { 0 } } else { 0 }
    let in_h2 = if ci_lo <= h2 { if ci_hi >= h2 { 1 } else { 0 } } else { 0 }
    let in_h3 = if ci_lo <= h3 { if ci_hi >= h3 { 1 } else { 0 } } else { 0 }

    println("-- hypothesis discrimination (5-pt 95% CI) --")
    println("  H0 e^{-1/2} = 0.6065   in CI? " + (if in_h0 == 1 { "YES" } else { "NO" }))
    println("  H1 A6.5 sum = 0.608    in CI? " + (if in_h1 == 1 { "YES" } else { "NO" }))
    println("  H2 ln(2)    = 0.6931   in CI? " + (if in_h2 == 1 { "YES" } else { "NO" }))
    println("  H3 n/(s-φ)  = 0.6      in CI? " + (if in_h3 == 1 { "YES" } else { "NO" }))
    println("")

    let total = in_h0 + in_h1 + in_h2 + in_h3
    println("-- T1 verdict on historic 5-pt --")
    if total >= 2 {
        println("  INCONCLUSIVE — " + to_string(total) + " hypotheses inside CI; N=5 substrate cannot discriminate at 4-digit precision")
    } else {
        if total == 1 {
            if in_h0 == 1 { println("  PROMOTE — only H0 in CI") }
            if in_h1 == 1 { println("  H1 sole survivor — A6.5 sum") }
            if in_h2 == 1 { println("  H2 sole — ln(2)") }
            if in_h3 == 1 { println("  H3 sole — Law 2089 n/(s-phi)") }
        } else {
            println("  CI excludes all — substrate disagrees with documented 0.608")
        }
    }
    println("")

    println("===JSON_BEGIN===")
    println("{")
    println("  \"witness_id\": \"R34_CANDIDATE_T1_historic_5pt_replicate\",")
    println("  \"substrate\": \"historic_5pt_ConsciousLM_v3_v14_3\",")
    println("  \"n_datapoints\": 5,")
    println("  \"fit\": {\"a\": " + fmt(a, 6) + ", \"b\": " + fmt(b, 6) + ", \"r2\": " + fmt(r2, 6) + "},")
    println("  \"fit_no_n12\": {\"a\": " + fmt(fit4[0], 6) + ", \"b\": " + fmt(fit4[1], 6) + ", \"r2\": " + fmt(fit4[2], 6) + "},")
    println("  \"ci_95\": {\"lo\": " + fmt(ci_lo, 6) + ", \"hi\": " + fmt(ci_hi, 6) + "},")
    println("  \"hypotheses_in_ci\": " + to_string(total) + ",")
    println("  \"H0_in_ci\": " + (if in_h0 == 1 { "true" } else { "false" }) + ",")
    println("  \"H1_in_ci\": " + (if in_h1 == 1 { "true" } else { "false" }) + ",")
    println("  \"H2_in_ci\": " + (if in_h2 == 1 { "true" } else { "false" }) + ",")
    println("  \"H3_in_ci\": " + (if in_h3 == 1 { "true" } else { "false" }) + ",")
    println("  \"raw_10_note\": \"5 datapoints fundamentally insufficient for 4-digit discrimination — bootstrap CI inherently wide; T1 N>=20 requirement was the right call from the start\"")
    println("}")
    println("===JSON_END===")
}
