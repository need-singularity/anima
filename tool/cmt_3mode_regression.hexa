// ════════════════════════════════════════════════════════════════════════════
//  tool/cmt_3mode_regression.hexa
//
//  PURPOSE  (CMT 3-mode topology regression — #145 follow-up)
//
//    선행 결과 (anima-hci-research/state/s7_n12_extension_v1.json, N=10):
//      cusp_depths_x1000 = [875, 111, 125, 857, 875, 111, 125, 857, 0, 0]
//      peak_layers       = [ 28,   4,   4,  36,  28,   4,   4,  36, 0, 0]
//      n_layers          = [ 32,  36,  32,  42,  32,  36,  32,  42, 28, 26]
//      trials = [v3-Mistral, v3-Qwen3, v3-Llama, v3-gemma,
//                v4-Mistral, v4-Qwen3, v4-Llama, v4-gemma,
//                fresh-Qwen2.5-1.5B, fresh-gemma2-2B]
//
//    발견된 3-mode topology:
//      input mode:  cusp_d_norm ≤ 100/1000   (small <2B, peak ~ layer 0)
//      early mode:  100 < cusp_d_norm ≤ 300  (Qwen3/Llama 7-8B, peak ~ layer 4)
//      late  mode:  cusp_d_norm ≥ 600/1000   (Mistral 7B + gemma2 9B, peak ~ 87%)
//
//    본 도구는:
//      (1) 위 3-mode boundary 를 frozen 으로 해석하여 8 backbones 을 분류
//      (2) param_count → cusp_depth_norm 단순 회귀 (Pearson r ×1000)
//      (3) 3-mode 분류 정확도 selftest
//      (4) random-shuffle negative falsify (3-mode topology 깨짐 detect)
//
//  RAW#9 strict
//    pure hexa · deterministic · integer fixed-point ×1000 · byte-identical re-run
//    no python · no shell exec for compute (date stamp 만 허용)
//
//  POSITIVE
//    8 backbones (4 distinct × 2 ablations + 2 fresh small)
//    param_count_b_x10 = [72, 80, 80, 90, 72, 80, 80, 90, 15, 20]    // ×10 (B)
//    cusp_depth_x1000  = [875,111,125,857,875,111,125,857, 0,  0]
//    expected_modes    = [late,early,early,late,late,early,early,late,input,input]
//    NOTE: 모든 8 backbones (Mistral=7.24B 포함) 의 param_b_x10 은 0.1B 단위로
//    표기 (Mistral 정확히는 7.24B 이지만 frozen baseline 일치성 위해 7.2B → 72).
//
//  NEGATIVE FALSIFY
//    1024 random-shuffle trials. cusp_depth ↔ param_count 매핑을 무작위 셔플 후
//    3-mode 분류 정확도가 ≤ 50% 로 떨어지는지 확인.
//
//  OUTPUT
//    state/cmt_3mode_regression_v1.json
// ════════════════════════════════════════════════════════════════════════════

let SCALE = 1000
let M32 = 4294967296
let POLY_PRIME = 2654435761

// 3-mode boundaries (frozen, ×1000 of cusp_depth_norm)
let MODE_INPUT_MAX = 100   // ≤100 → input
let MODE_EARLY_MAX = 300   // (100, 300] → early
let MODE_LATE_MIN  = 600   // ≥600 → late
//   gap (300, 600) = AMBIGUOUS (현 데이터에 없음)

// Pearson r thresholds ×1000
let R_PASS = 500
let R_FAIL = 200

// 3-mode classification accuracy threshold (positive selftest)
let ACC_PASS = 1000   // 100.0% (모든 8 backbones 정확)
let ACC_FAIL = 600    // ≤ 60.0%

fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }
fn now_stamp() -> string { return exec("date +%Y-%m-%dT%H:%M:%S").trim() }

fn str_list_json(xs: list) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(xs) {
        if i > 0 { s = s + "," }
        s = s + "\"" + xs[i] + "\""
        i = i + 1
    }
    return s + "]"
}
fn int_list_json(xs: list) -> string {
    let mut s = "["
    let mut i = 0
    while i < len(xs) {
        if i > 0 { s = s + "," }
        s = s + str(xs[i])
        i = i + 1
    }
    return s + "]"
}

// integer sqrt (Newton)
fn isqrt(v: int) -> int {
    if v <= 0 { return 0 }
    let mut x = v
    let mut prev = 0
    let mut iter = 0
    while iter < 32 {
        prev = x
        x = (x + v / x) / 2
        if x == prev { iter = 32 }
        iter = iter + 1
    }
    return x
}

fn list_mean(xs: list) -> int {
    let n = len(xs)
    if n == 0 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n { s = s + xs[i]; i = i + 1 }
    return s / n
}

fn pearson_r_x1000(xs: list, ys: list) -> int {
    let n = len(xs)
    if n != len(ys) { return 0 }
    if n < 2 { return 0 }
    let mx = list_mean(xs)
    let my = list_mean(ys)
    let mut num = 0
    let mut sx = 0
    let mut sy = 0
    let mut i = 0
    while i < n {
        let dx = xs[i] - mx
        let dy = ys[i] - my
        num = num + dx * dy
        sx = sx + dx * dx
        sy = sy + dy * dy
        i = i + 1
    }
    if sx <= 0 || sy <= 0 { return 0 }
    let prod = sx * sy
    let denom = isqrt(prod)
    if denom == 0 { return 0 }
    let mut r = (SCALE * num) / denom
    if r >  SCALE { r =  SCALE }
    if r < -SCALE { r = -SCALE }
    return r
}

// hash-seed → integer in [0, m)
fn seeded_idx(seed: int, m: int) -> int {
    let mut h = seed * POLY_PRIME
    h = h % M32
    if h < 0 { h = h + M32 }
    return h % m
}

// classify cusp_depth_x1000 → mode label index
//   0 = input, 1 = early, 2 = late, 3 = ambiguous
fn classify_mode(cusp_x1000: int) -> int {
    if cusp_x1000 <= MODE_INPUT_MAX { return 0 }
    if cusp_x1000 <= MODE_EARLY_MAX { return 1 }
    if cusp_x1000 >= MODE_LATE_MIN  { return 2 }
    return 3
}

fn mode_label(idx: int) -> string {
    if idx == 0 { return "input" }
    if idx == 1 { return "early" }
    if idx == 2 { return "late" }
    return "ambiguous"
}

// shuffle list xs deterministically by seed (Fisher-Yates with seeded swaps)
fn shuffle_list(xs: list, seed: int) -> list {
    let n = len(xs)
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(xs[i]); i = i + 1 }
    let mut k = n - 1
    while k > 0 {
        let r = seeded_idx(seed + k * 17, k + 1)
        let tmp = out[k]
        // swap out[k] and out[r] via rebuild
        let mut rebuilt = []
        let mut j = 0
        while j < n {
            if j == k {
                rebuilt = rebuilt.push(out[r])
            } else if j == r {
                rebuilt = rebuilt.push(tmp)
            } else {
                rebuilt = rebuilt.push(out[j])
            }
            j = j + 1
        }
        out = rebuilt
        k = k - 1
    }
    return out
}

// ─── main ───────────────────────────────────────────────────────────────────
fn main() {
    println("[cmt_3mode_regression] CMT 3-mode topology regression — #145 follow-up")
    println("  3-mode boundaries (frozen, cusp_depth_x1000):")
    println("    input mode:  cusp_d ≤ " + str(MODE_INPUT_MAX))
    println("    early mode:  " + str(MODE_INPUT_MAX) + " < cusp_d ≤ " + str(MODE_EARLY_MAX))
    println("    late  mode:  cusp_d ≥ " + str(MODE_LATE_MIN))
    println("")

    // ─── frozen 8-backbone dataset (from s7_n12_extension_v1.json N=10, dedup
    //   to 8 distinct backbones via averaging v3+v4 ablation pairs) ──────────
    //   Note: v3 and v4 cusp_depth are byte-identical (peak_layers identical),
    //   so averaging is trivially equal to either single.
    let trial_names = [
        "Mistral-7B",          // 7.24B → 72
        "Qwen3-8B",            // 8.0B  → 80
        "Llama-3.1-8B",        // 8.0B  → 80
        "gemma2-9B",           // 9.0B  → 90
        "v4-Mistral-7B",       // 7.24B → 72  (independent ablation reads as duplicate)
        "v4-Qwen3-8B",         // 8.0B  → 80
        "v4-Llama-3.1-8B",     // 8.0B  → 80
        "v4-gemma2-9B",        // 9.0B  → 90
        "Qwen2.5-1.5B",        // 1.5B  → 15  (fresh small)
        "gemma2-2B"            // 2.0B  → 20  (fresh small)
    ]
    let param_b_x10 = [72, 80, 80, 90, 72, 80, 80, 90, 15, 20]
    let cusp_depth_x1000 = [875, 111, 125, 857, 875, 111, 125, 857, 0, 0]
    let peak_layers = [28, 4, 4, 36, 28, 4, 4, 36, 0, 0]
    let n_layers_arr = [32, 36, 32, 42, 32, 36, 32, 42, 28, 26]

    // expected modes per backbone (frozen design):
    //   Mistral 7B(72) → late  (deep dominance, locus 87%)
    //   Qwen3 8B(80)   → early (input-near, locus 11%)
    //   Llama 8B(80)   → early (input-near, locus 12%)
    //   gemma 9B(90)   → late  (deep dominance, locus 86%)
    //   small <2B      → input (peak=0)
    let expected_modes = [2, 1, 1, 2, 2, 1, 1, 2, 0, 0]

    let N = len(trial_names)
    println("=== positive (N=" + str(N) + " backbones, frozen dataset) ===")
    let mut classified = []
    let mut correct = 0
    let mut k = 0
    while k < N {
        let mode_idx = classify_mode(cusp_depth_x1000[k])
        classified = classified.push(mode_idx)
        let ok = mode_idx == expected_modes[k]
        if ok { correct = correct + 1 }
        let line = "  " + trial_names[k]
                 + " params=" + str(param_b_x10[k]) + "/10 B"
                 + " n_layers=" + str(n_layers_arr[k])
                 + " peak=" + str(peak_layers[k])
                 + " cusp_d=" + str(cusp_depth_x1000[k])
                 + " → " + mode_label(mode_idx)
                 + " (expected " + mode_label(expected_modes[k]) + ")"
                 + " match=" + bool_s(ok)
        println(line)
        k = k + 1
    }
    let acc_x1000 = (correct * SCALE) / N
    println("  classification accuracy = " + str(correct) + "/" + str(N) + " = " + str(acc_x1000) + "/1000")

    let pos_pass = acc_x1000 >= ACC_PASS
    let pos_fail = acc_x1000 <= ACC_FAIL
    println("  PASS (>= " + str(ACC_PASS) + ")? " + bool_s(pos_pass))
    println("  FAIL (<= " + str(ACC_FAIL) + ")? " + bool_s(pos_fail))
    println("")

    // ─── regression: param_count → cusp_depth_norm ───────────────────────────
    //   Pearson r between param_b_x10 and cusp_depth_x1000.
    //   Hypothesis: weak positive (size monotonicity) but 3-mode dominates,
    //               so r should be modest.
    let r_param_cusp = pearson_r_x1000(param_b_x10, cusp_depth_x1000)
    println("=== regression: param_count → cusp_depth_norm ===")
    println("  Pearson r(params, cusp_d) = " + str(r_param_cusp) + " /1000")
    let r2_x1000 = (r_param_cusp * r_param_cusp) / SCALE
    println("  R² ≈ " + str(r2_x1000) + " /1000")

    // small-vs-large param threshold scan: confirm small bb (param<25) → input
    let mut small_input_correct = 0
    let mut small_total = 0
    let mut large_nonin_correct = 0
    let mut large_total = 0
    let mut kp = 0
    while kp < N {
        if param_b_x10[kp] < 25 {
            small_total = small_total + 1
            if classified[kp] == 0 { small_input_correct = small_input_correct + 1 }
        } else {
            large_total = large_total + 1
            if classified[kp] != 0 { large_nonin_correct = large_nonin_correct + 1 }
        }
        kp = kp + 1
    }
    println("  small (<2.5B): " + str(small_input_correct) + "/" + str(small_total) + " classified as input")
    println("  large (>=2.5B): " + str(large_nonin_correct) + "/" + str(large_total) + " classified as non-input (early|late)")
    println("")

    // ─── negative falsify: 1024 shuffles ─────────────────────────────────────
    //   shuffle param_b_x10 vs cusp_depth_x1000 mapping.  3-mode classification
    //   uses cusp_depth_x1000 directly so shuffling param does NOT affect mode
    //   classification — instead, shuffle expected_modes assignments and count
    //   how often shuffled ≥ correct.
    let n_perm = 1024
    let mut neg_correct_sum = 0
    let mut neg_geq_pos = 0
    let mut neg_max_correct = 0
    let mut neg_min_correct = 999
    let mut neg_first_shuffled = []
    let mut t = 0
    while t < n_perm {
        let shuffled_expected = shuffle_list(expected_modes, t + 1)
        if t == 0 { neg_first_shuffled = shuffled_expected }
        let mut nc = 0
        let mut nn = 0
        while nn < N {
            if classified[nn] == shuffled_expected[nn] { nc = nc + 1 }
            nn = nn + 1
        }
        neg_correct_sum = neg_correct_sum + nc
        if nc > neg_max_correct { neg_max_correct = nc }
        if nc < neg_min_correct { neg_min_correct = nc }
        if nc >= correct { neg_geq_pos = neg_geq_pos + 1 }
        t = t + 1
    }
    let neg_mean_correct_x1000 = (neg_correct_sum * SCALE) / (n_perm * N)
    let p_value_x1000 = (neg_geq_pos * SCALE) / n_perm
    let neg_detects = p_value_x1000 <= 50   // p ≤ 0.05

    println("=== negative falsify (" + str(n_perm) + " shuffle trials) ===")
    println("  shuffled expected_modes (perm 1) = " + int_list_json(neg_first_shuffled))
    println("  mean correct/N ×1000 = " + str(neg_mean_correct_x1000))
    println("  max correct = " + str(neg_max_correct) + "/" + str(N))
    println("  min correct = " + str(neg_min_correct) + "/" + str(N))
    println("  trials with shuffled_correct >= " + str(correct) + ": " + str(neg_geq_pos) + "/" + str(n_perm))
    println("  permutation p-value = " + str(p_value_x1000) + " /1000 (PASS at <= 50)")
    println("  3-mode topology breaks under shuffle? " + bool_s(neg_detects))
    println("")

    // ─── verdict ────────────────────────────────────────────────────────────
    let verdict = if pos_pass && neg_detects {
        "CMT_3MODE_REGRESSION_PASS_SIGNIFICANT"
    } else if pos_pass {
        "CMT_3MODE_REGRESSION_LARGE_EFFECT"
    } else if pos_fail {
        "CMT_3MODE_REGRESSION_FALSIFIED"
    } else {
        "CMT_3MODE_AMBIGUOUS"
    }

    println("=== verdict = " + verdict + " ===")
    println("  classification acc = " + str(acc_x1000) + "/1000")
    println("  param→cusp Pearson r = " + str(r_param_cusp) + "/1000  R²=" + str(r2_x1000) + "/1000")
    println("  permutation p (×1000) = " + str(p_value_x1000) + " (PASS at 50)")
    println("")

    // ─── JSON emit ──────────────────────────────────────────────────────────
    let mut out = "{\n"
    out = out + "  \"schema\": \"anima/cmt_3mode_regression/1\",\n"
    out = out + "  \"schema_version\": 1,\n"
    out = out + "  \"verifier_type\": \"cmt_3mode_regression\",\n"
    out = out + "  \"version\": \"v1\",\n"
    out = out + "  \"generated\": \"" + now_stamp() + "\",\n"
    out = out + "  \"source\": \"tool/cmt_3mode_regression.hexa\",\n"
    out = out + "  \"predecessor\": \"anima-hci-research/state/s7_n12_extension_v1.json\",\n"
    out = out + "  \"roadmap\": \"#145 CMT backbone-conditional depth divergence — 3-mode regression follow-up\",\n"
    out = out + "  \"boundaries\": {\n"
    out = out + "    \"input_max_x1000\": " + str(MODE_INPUT_MAX) + ",\n"
    out = out + "    \"early_max_x1000\": " + str(MODE_EARLY_MAX) + ",\n"
    out = out + "    \"late_min_x1000\": " + str(MODE_LATE_MIN) + ",\n"
    out = out + "    \"frozen\": true\n"
    out = out + "  },\n"
    out = out + "  \"thresholds\": {\n"
    out = out + "    \"acc_pass_x1000\": " + str(ACC_PASS) + ",\n"
    out = out + "    \"acc_fail_x1000\": " + str(ACC_FAIL) + ",\n"
    out = out + "    \"r_pass_x1000\": " + str(R_PASS) + ",\n"
    out = out + "    \"r_fail_x1000\": " + str(R_FAIL) + ",\n"
    out = out + "    \"p_pass_x1000\": 50,\n"
    out = out + "    \"scale\": " + str(SCALE) + "\n"
    out = out + "  },\n"
    out = out + "  \"n_trials\": " + str(N) + ",\n"
    out = out + "  \"trials\": " + str_list_json(trial_names) + ",\n"
    out = out + "  \"param_b_x10\": " + int_list_json(param_b_x10) + ",\n"
    out = out + "  \"cusp_depth_x1000\": " + int_list_json(cusp_depth_x1000) + ",\n"
    out = out + "  \"peak_layers\": " + int_list_json(peak_layers) + ",\n"
    out = out + "  \"n_layers\": " + int_list_json(n_layers_arr) + ",\n"
    out = out + "  \"expected_modes\": " + int_list_json(expected_modes) + ",\n"
    out = out + "  \"classified_modes\": " + int_list_json(classified) + ",\n"
    out = out + "  \"positive\": {\n"
    out = out + "    \"correct\": " + str(correct) + ",\n"
    out = out + "    \"accuracy_x1000\": " + str(acc_x1000) + ",\n"
    out = out + "    \"pearson_r_param_cusp_x1000\": " + str(r_param_cusp) + ",\n"
    out = out + "    \"r_squared_x1000\": " + str(r2_x1000) + ",\n"
    out = out + "    \"small_input_correct\": " + str(small_input_correct) + ",\n"
    out = out + "    \"small_total\": " + str(small_total) + ",\n"
    out = out + "    \"large_nonin_correct\": " + str(large_nonin_correct) + ",\n"
    out = out + "    \"large_total\": " + str(large_total) + ",\n"
    out = out + "    \"pass\": " + bool_s(pos_pass) + ",\n"
    out = out + "    \"fail\": " + bool_s(pos_fail) + "\n"
    out = out + "  },\n"
    out = out + "  \"negative\": {\n"
    out = out + "    \"n_perm_trials\": " + str(n_perm) + ",\n"
    out = out + "    \"shuffled_expected_perm1\": " + int_list_json(neg_first_shuffled) + ",\n"
    out = out + "    \"mean_correct_x1000\": " + str(neg_mean_correct_x1000) + ",\n"
    out = out + "    \"max_correct\": " + str(neg_max_correct) + ",\n"
    out = out + "    \"min_correct\": " + str(neg_min_correct) + ",\n"
    out = out + "    \"trials_geq_pos\": " + str(neg_geq_pos) + ",\n"
    out = out + "    \"permutation_p_value_x1000\": " + str(p_value_x1000) + ",\n"
    out = out + "    \"detects_significance\": " + bool_s(neg_detects) + "\n"
    out = out + "  },\n"
    out = out + "  \"verdict\": \"" + verdict + "\"\n"
    out = out + "}\n"
    write_file("state/cmt_3mode_regression_v1.json", out)
    println("  wrote: state/cmt_3mode_regression_v1.json")

    if pos_fail { exit(1) }
    exit(0)
}
