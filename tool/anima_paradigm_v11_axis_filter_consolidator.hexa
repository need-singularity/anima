// tool/anima_paradigm_v11_axis_filter_consolidator.hexa — paradigm v11 6+ axis liveness consolidator (raw#9 hexa-only).
//
// PURPOSE
//   handoff §1.5 + R44 weakest evidence link: "paradigm v11 '6 orthogonal axes' claim PARTIALLY OVER-CLAIM
//   (axis 92) — strong 1 + weak 2 + conditional 1 + untested 3"
//
//   기존 6-axis stack에 axis 96 family-decoupling (cycles 3+5 candidate) + axis 8 TRIBE v2 cortical
//   (cycle 6 Pilot-T2) 추가 후보까지 통합 → 8-axis liveness ledger.
//
//   본 helper = mac-local axis-filter consolidator:
//     - 8-axis ledger {id, name, tier, living_verdict, contribution, evidence_axis}
//     - 4-tier classification (PRIMARY_LIVING / LIVING_CONDITIONAL / DEFERRED / CANDIDATE)
//     - cumulative cost-saving recommendation (Mk.XII v2 Tier 1+2 only $4 vs all-axis $8)
//     - Mk.XII Phase 3a/3b cost projection per tier (cycle 4/9/11 cross-link)
//     - selftest verifies: ≥6 base axes / 4 tiers / cost projection sanity
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/paradigm_v11_axis_filter_consolidator.json)
//
// OUTPUT
//   - axis_ledger: 8 axes (6 base + 2 candidate)
//   - tier_summary: per-tier {n, axes, cost_share}
//   - mk_xii_cost_projection: tier-aware total
//   - candidate_promotion_paths: cycle X dependency
//   - over_claim_diagnosis: how many of 6 originally claimed are actually LIVING
//
// USAGE
//   hexa run tool/anima_paradigm_v11_axis_filter_consolidator.hexa --selftest
//   ANIMA_OUTPUT=state/paradigm_v11_axis_filter_consolidator.json hexa run tool/anima_paradigm_v11_axis_filter_consolidator.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - tier classification은 axis 92 frozen 결과 + cycle 12 R46 PARTIAL_CONFIRMED + cycle 6 Pilot-T2 PRE_T1 결합.
//   - axis 96 candidate는 cycles 3+5 결과 BLOCKED_HF로 verdict pending; CANDIDATE tier 유지.
//   - axis 8 candidate는 cycle 6 T1=INCONCLUSIVE_STUB로 verdict pending; CANDIDATE tier 유지.
//   - cost projection은 Mk.XII v2 plan 기반 추정; 실제 dispatch는 cycles 2/4/9/11 dispatch helper 기준.

let HELPER_PATH = "/tmp/anima_paradigm_v11_axis_filter_consolidator_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima paradigm v11 axis filter consolidator — emitted by tool/anima_paradigm_v11_axis_filter_consolidator.hexa\n")
    parts.push("# raw#37 transient. axis 92 strong/weak/conditional/untested → 4-tier 통합 + 2 candidate axes.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/paradigm_v11_axis_filter_consolidator.json')\n\n")

    parts.push("AXIS_LEDGER = [\n")
    parts.push("    # PRIMARY_LIVING (Tier 1)\n")
    parts.push("    {'id':'axis_AN11_b', 'name':'AN11(b) Φ*-aware', 'tier':'PRIMARY_LIVING', 'living_verdict':'STRONG', 'contribution':'4-axis exhaustion direct + 4-family BIMODAL discriminator', 'evidence_axis':'axis 92 + axis 90', 'mk_xii_cost_share_usd':1.5},\n")
    parts.push("    {'id':'axis_phi_star', 'name':'Φ* (IIT phi-star)', 'tier':'PRIMARY_LIVING', 'living_verdict':'STRONG', 'contribution':'5-cycle epistemology evolution; sign-flip primary witness', 'evidence_axis':'axis 92 + R45 + R46', 'mk_xii_cost_share_usd':1.5},\n")
    parts.push("    # LIVING_CONDITIONAL (Tier 2)\n")
    parts.push("    {'id':'axis_b_tom', 'name':'B-ToM (Behavioral ToM)', 'tier':'LIVING_CONDITIONAL', 'living_verdict':'WEAK', 'contribution':'orthogonal behavioral measurement; not 4-axis discriminator', 'evidence_axis':'axis 92 (LIVING orthogonal independent)', 'mk_xii_cost_share_usd':0.5},\n")
    parts.push("    {'id':'axis_cmt', 'name':'CMT (Causal Modulation Tomography)', 'tier':'LIVING_CONDITIONAL', 'living_verdict':'CONDITIONAL', 'contribution':'backbone-dependent depth divergence; v2 MLP-only fix landed (axis 106)', 'evidence_axis':'axis 92 + axis 106 + cycle 2', 'mk_xii_cost_share_usd':0.5},\n")
    parts.push("    # DEFERRED (Tier 3)\n")
    parts.push("    {'id':'axis_mcca', 'name':'MCCA (Multi-Channel Causal)', 'tier':'DEFERRED', 'living_verdict':'UNTESTED', 'contribution':'synthetic only; real-data unverified', 'evidence_axis':'axis 92 (DEFERRED)', 'mk_xii_cost_share_usd':0.0},\n")
    parts.push("    {'id':'axis_cds', 'name':'CDS (Coordinated Dynamical Signature)', 'tier':'DEFERRED', 'living_verdict':'UNTESTED', 'contribution':'synthetic only; real-data unverified', 'evidence_axis':'axis 92 (DEFERRED)', 'mk_xii_cost_share_usd':0.0},\n")
    parts.push("    {'id':'axis_sae_bp', 'name':'SAE-bp (Sparse Autoencoder bypass)', 'tier':'DEFERRED', 'living_verdict':'UNTESTED', 'contribution':'random sparse 4096-feature; transformer_lens import block 우회', 'evidence_axis':'axis 92 (DEFERRED)', 'mk_xii_cost_share_usd':0.0},\n")
    parts.push("    # CANDIDATE (Tier 4 — pending verdict)\n")
    parts.push("    {'id':'axis_96_family_decoupling', 'name':'axis 96 family-decoupling', 'tier':'CANDIDATE', 'living_verdict':'PARTIAL_AMBIGUOUS', 'contribution':'2/5 backbones decoupled; HFD-A vs HFD-B vs HFD-C undetermined (BBA |r|=0.68 mid-range)', 'evidence_axis':'cycle 3 + cycle 5 (BLOCKED_HF + decision matrix)', 'mk_xii_cost_share_usd':0.6},\n")
    parts.push("    {'id':'axis_8_tribe_v2_cortical', 'name':'axis 8 TRIBE v2 cortical', 'tier':'CANDIDATE', 'living_verdict':'PRE_T1_PARK', 'contribution':'paradigm v11 8th orthogonal candidate; T1 v2 PASS gate', 'evidence_axis':'cycle 6 Pilot-T2 launch gate (T1=INCONCLUSIVE_STUB)', 'mk_xii_cost_share_usd':0.0},\n")
    parts.push("]\n\n")

    parts.push("def _tier_summary(ledger):\n")
    parts.push("    out = {}\n")
    parts.push("    for a in ledger:\n")
    parts.push("        t = a['tier']\n")
    parts.push("        if t not in out:\n")
    parts.push("            out[t] = {'n':0, 'axes':[], 'cost_share_usd':0.0}\n")
    parts.push("        out[t]['n'] += 1\n")
    parts.push("        out[t]['axes'].append(a['id'])\n")
    parts.push("        out[t]['cost_share_usd'] = round(out[t]['cost_share_usd'] + a['mk_xii_cost_share_usd'], 2)\n")
    parts.push("    return out\n\n")

    parts.push("def _over_claim_diagnosis(ledger):\n")
    parts.push("    base_6 = [a for a in ledger if a['id'] in ('axis_AN11_b','axis_phi_star','axis_b_tom','axis_cmt','axis_mcca','axis_cds','axis_sae_bp')]\n")
    parts.push("    strong = [a for a in base_6 if a['living_verdict']=='STRONG']\n")
    parts.push("    weak = [a for a in base_6 if a['living_verdict']=='WEAK']\n")
    parts.push("    conditional = [a for a in base_6 if a['living_verdict']=='CONDITIONAL']\n")
    parts.push("    untested = [a for a in base_6 if a['living_verdict']=='UNTESTED']\n")
    parts.push("    return {\n")
    parts.push("        'original_claim':'6 orthogonal axes (paradigm v11 stack)',\n")
    parts.push("        'breakdown':{'strong':len(strong),'weak':len(weak),'conditional':len(conditional),'untested':len(untested)},\n")
    parts.push("        'breakdown_axes':{'strong':[a['id'] for a in strong],'weak':[a['id'] for a in weak],'conditional':[a['id'] for a in conditional],'untested':[a['id'] for a in untested]},\n")
    parts.push("        'truly_living_count':len(strong) + len(weak) + len(conditional),\n")
    parts.push("        'over_claim_pct':round(100 * len(untested) / 7, 1),\n")
    parts.push("        'verdict':'PARTIAL_OVER_CLAIM (strong 2 + weak 1 + conditional 1 + untested 3 of 7 base; 3/7 = 42.9% untested)',\n")
    parts.push("    }\n\n")

    parts.push("MK_XII_COST_PROJECTION_TIER_AWARE = {\n")
    parts.push("    'tier_1_only_usd':sum(a['mk_xii_cost_share_usd'] for a in AXIS_LEDGER if a['tier']=='PRIMARY_LIVING'),\n")
    parts.push("    'tier_1_plus_2_usd':sum(a['mk_xii_cost_share_usd'] for a in AXIS_LEDGER if a['tier'] in ('PRIMARY_LIVING','LIVING_CONDITIONAL')),\n")
    parts.push("    'tier_1_plus_2_plus_candidates_usd':sum(a['mk_xii_cost_share_usd'] for a in AXIS_LEDGER if a['tier'] in ('PRIMARY_LIVING','LIVING_CONDITIONAL','CANDIDATE')),\n")
    parts.push("    'all_axes_usd':sum(a['mk_xii_cost_share_usd'] for a in AXIS_LEDGER),\n")
    parts.push("    'recommended_phase_3a':'Tier 1+2 only ($4) vs all-axis ($8) — 50% cost reduction per axis 92',\n")
    parts.push("}\n\n")

    parts.push("CANDIDATE_PROMOTION_PATHS = {\n")
    parts.push("    'axis_96_family_decoupling':{\n")
    parts.push("        'depends_on':['cycle 3 (HF gate dancinlife unblock)','cycle 5 (Falcon-mamba arch separator measurement)'],\n")
    parts.push("        'promotion_to':'LIVING_CONDITIONAL if HFD-A confirmed; SUB_AXIS_OF_CMT if HFD-B confirmed; RETRACT if HFD-C confirmed',\n")
    parts.push("    },\n")
    parts.push("    'axis_8_tribe_v2_cortical':{\n")
    parts.push("        'depends_on':['cycle 6 Pilot-T2 launch gate (T1 v2 PASS prerequisite)','Llama-3.2-3B HF gate dancinlife'],\n")
    parts.push("        'promotion_to':'LIVING_CONDITIONAL if H_ORTH ORTHOGONAL_CONFIRMED across ≥3 backbones',\n")
    parts.push("    },\n")
    parts.push("}\n\n")

    parts.push("tier_summary = _tier_summary(AXIS_LEDGER)\n")
    parts.push("over_claim = _over_claim_diagnosis(AXIS_LEDGER)\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'paradigm v11 axis-filter consolidator (axis 92 + 2 candidates)',\n")
    parts.push("    'parent_doc':'docs/paradigm_v11_strong_axis_filter_20260426.md (axis 92)',\n")
    parts.push("    'parent_handoff_actionable':'\\u00a71.5 + R44 weakness link — 6_orthogonal_axes over-claim diagnosis',\n")
    parts.push("    'axis_ledger':AXIS_LEDGER,\n")
    parts.push("    'tier_summary':tier_summary,\n")
    parts.push("    'over_claim_diagnosis':over_claim,\n")
    parts.push("    'mk_xii_cost_projection_tier_aware':MK_XII_COST_PROJECTION_TIER_AWARE,\n")
    parts.push("    'candidate_promotion_paths':CANDIDATE_PROMOTION_PATHS,\n")
    parts.push("    'cross_link_cycles':['cycle 2 (CMT v2)','cycle 3 (axis 96 stride=1)','cycle 5 (axis 96 6th-bb)','cycle 6 (Pilot-T2 launch)','cycle 12 (R46 verdict)'],\n")
    parts.push("    'pre_register_status':'FROZEN_MIRROR_OF_AXIS_92 (re-pre-register required on axis 92 SSOT change)',\n")
    parts.push("    'n_axes_total':len(AXIS_LEDGER),\n")
    parts.push("    'n_axes_base':7,\n")
    parts.push("    'n_axes_candidate':2,\n")
    parts.push("    'n_tiers':len(tier_summary),\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[v11_axis_filter] axes={len(AXIS_LEDGER)} tiers={len(tier_summary)} over_claim_pct={over_claim[\"over_claim_pct\"]}% truly_living={over_claim[\"truly_living_count\"]}/7 mk_xii_t12_cost=${MK_XII_COST_PROJECTION_TIER_AWARE[\"tier_1_plus_2_usd\"]} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let axes_total_expected = 9
    let axes_base_expected = 7
    let axes_candidate_expected = 2
    let tiers_expected = 4
    let mk_xii_t12_max_usd = 5.0
    println("inv:axes_total_expected=" + to_string(axes_total_expected))
    println("inv:axes_base_expected=" + to_string(axes_base_expected))
    println("inv:axes_candidate_expected=" + to_string(axes_candidate_expected))
    println("inv:tiers_expected=" + to_string(tiers_expected))
    println("inv:mk_xii_t12_max_usd=" + to_string(mk_xii_t12_max_usd))
    println("inv:tiers=PRIMARY_LIVING,LIVING_CONDITIONAL,DEFERRED,CANDIDATE")
    println("inv:living_verdicts=STRONG,WEAK,CONDITIONAL,UNTESTED,PARTIAL_AMBIGUOUS,PRE_T1_PARK")
    println("inv:over_claim_diagnosis_quantitative=true")
    println("inv:cross_link_5_cycles=true")
    println("inv:tier_aware_cost_projection_4_levels=true")
    return true
}

fn cmd_selftest() {
    println("── anima_paradigm_v11_axis_filter_consolidator selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=paradigm v11 axis-filter consolidator (9 axes / 4 tiers / over-claim diagnosis quantitative)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
