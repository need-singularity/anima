// tool/ps_9_l0_lock.hexa — cl-rotate Step 9: chflags uchg (raw#1 L0 lock)
//
// Applies chflags uchg to the issue SSOT itself (so the resolved record
// is immutable) and to any files listed in issue.locked_files. On non-
// darwin hosts this is a noop (always returns success).

let DEFAULT_CONFIG = "/Users/ghost/core/anima/config/problem_solving_protocol_config.json"
let WITH_UNLOCK_TOOL = "/Users/ghost/core/hexa-lang/tool/roadmap_with_unlock.hexa"

// INLINE_DEPRECATED[H42]: see shared/util/sh_quote.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _sh_quote(s: string) -> string { let mut o = "'"; o = o + s.replace("'", "'\\''"); o = o + "'"; return o }
// INLINE_DEPRECATED[H42]: see shared/util/file_exists.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _file_exists(p: string) -> bool { return exec_with_status("test -e " + _sh_quote(p))[1] == 0 }
// INLINE_DEPRECATED[H42]: see shared/util/ts_iso.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _ts_iso() -> string { return to_string(exec_with_status("date -u +%Y-%m-%dT%H:%M:%SZ")[0]).trim() }
// INLINE_DEPRECATED[H42]: see shared/util/json_escape.hexa for canonical impl — kept inline (hexa stage0 loader)
fn _json_escape(s: string) -> string { return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n") }
fn _is_darwin() -> bool {
    let r = exec_with_status("uname -s")
    return to_string(r[0]).trim() == "Darwin"
}
fn _chflag_apply(path: string, flag: string) -> bool {
    if !_is_darwin() { return true }
    return exec_with_status("chflags " + flag + " " + _sh_quote(path))[1] == 0
}
fn _chflag_remove(path: string, flag: string) -> bool {
    if !_is_darwin() { return true }
    return exec_with_status("chflags no" + flag + " " + _sh_quote(path))[1] == 0
}

fn _load_config(p: string) { if !_file_exists(p) { eprintln("ps_9: config missing"); exit(2) }; return json_parse(read_file(p)) }
fn _cfg_str(cfg, k, d) -> string { if cfg.contains_key(k) { return to_string(cfg[k]) }; return d }
fn _cfg_bool(cfg, k, d: bool) -> bool { if cfg.contains_key(k) { return to_bool(cfg[k]) }; return d }
fn _argv() -> array { let a = args(); let mut o = []; let mut i = 2; while i < len(a) { o.push(a[i]); i = i + 1 }; return o }
fn _flag(av, k) -> bool { for x in av { if to_string(x) == k { return true } }; return false }
fn _opt(av, k, d) -> string { let mut i = 0; while i < len(av) { if to_string(av[i]) == k && i + 1 < len(av) { return to_string(av[i + 1]) }; i = i + 1 }; return d }
fn _issue_path(cfg, id) -> string { return _cfg_str(cfg, "issue_state_dir", "/Users/ghost/core/anima/state/issues") + "/" + id + ".json" }

fn _replace_field_int(body, key, v) -> string {
    let needle = "\"" + key + "\": "
    let i = body.index_of(needle)
    if i < 0 { return body }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let mut k = 0
    while k < len(rest) { let ch = rest.substring(k, k + 1); if ch == "," || ch == "\n" || ch == "}" { break }; k = k + 1 }
    return body.substring(0, j) + to_string(v) + rest.substring(k, len(rest))
}
fn _replace_field_str(body, key, v) -> string {
    let needle = "\"" + key + "\": \""
    let i = body.index_of(needle)
    if i < 0 { return body }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let e = rest.index_of("\"")
    if e < 0 { return body }
    return body.substring(0, j) + _json_escape(v) + rest.substring(e, len(rest))
}
fn _replace_array_inline(body, key, inline) -> string {
    let needle = "\"" + key + "\": ["
    let i = body.index_of(needle)
    if i < 0 { return body }
    let j = i + len(needle)
    let rest = body.substring(j, len(body))
    let e = rest.index_of("]")
    if e < 0 { return body }
    return body.substring(0, j) + inline + rest.substring(e, len(rest))
}

// Migration 20260422: write-then-lock via roadmap_with_unlock.hexa (PR #25).
// Issue SSOTs are typically NOT pre-locked at step 9 (lock applied here as
// part of the step transition), so the helper runs through its
// "was_locked=false → bare exec" path; the lock is then applied separately
// via _chflag_apply. If a previous run did leave the file uchg, the helper
// transparently unlocks → mv → relocks under a trap, preserving safety.
fn _stage_via_helper(target: string, body: string) -> bool {
    let mut tmp_parts = []
    tmp_parts.push(target)
    tmp_parts.push(".tmp.with_unlock.")
    tmp_parts.push(_ts_iso().replace(":", "").replace("-", ""))
    let tmp = tmp_parts.join("")
    write_file(tmp, body)
    if !_file_exists(WITH_UNLOCK_TOOL) {
        // Fallback: caller already removed uchg. Direct mv.
        let mvr = exec_with_status("mv " + _sh_quote(tmp) + " " + _sh_quote(target))
        return mvr[1] == 0
    }
    let mut cmd = []
    cmd.push("hexa ")
    cmd.push(WITH_UNLOCK_TOOL)
    cmd.push(" --file ")
    cmd.push(_sh_quote(target))
    cmd.push(" -- mv ")
    cmd.push(_sh_quote(tmp))
    cmd.push(" ")
    cmd.push(_sh_quote(target))
    let r = exec_with_status(cmd.join(""))
    if r[1] != 0 { exec_with_status("rm -f " + _sh_quote(tmp)) }
    return r[1] == 0
}

fn l0_lock(cfg, id: string) -> int {
    let path = _issue_path(cfg, id)
    if !_file_exists(path) { eprintln("ps_9: missing " + id); return 2 }
    let required = _cfg_bool(cfg, "l0_lock_required", true)
    // write step first (before locking), then lock
    let body = read_file(path)
    let mut locked_list = []
    if required {
        let mut b2 = _replace_field_str(body, "updated", _ts_iso())
        b2 = _replace_field_int(b2, "current_step", 10)
        let inline = "\"" + _json_escape(path) + "\""
        b2 = _replace_array_inline(b2, "locked_files", inline)
        let _ws = _stage_via_helper(path, b2)
        let ok = _chflag_apply(path, "uchg")
        if ok { locked_list.push(path) }
    } else {
        let mut b2 = _replace_field_str(body, "updated", _ts_iso())
        b2 = _replace_field_int(b2, "current_step", 10)
        let _ws = _stage_via_helper(path, b2)
    }
    println("ps_9_l0_lock: issue=" + id + " darwin=" + to_string(_is_darwin()) +
            " required=" + to_string(required) + " locked=" + to_string(len(locked_list)) + " → step 10")
    return 0
}

fn self_test(cfg) -> int {
    println("── ps_9_l0_lock self-test ──")
    let tid = "SELFTEST-PS9"
    let p = _cfg_str(cfg, "issue_state_dir", "/Users/ghost/core/anima/state/issues") + "/" + tid + ".json"
    let _rmn = _chflag_remove(p, "uchg")
    let _r = exec_with_status("rm -f " + _sh_quote(p))
    write_file(p, "{\n  \"issue_id\": \"" + tid + "\",\n  \"locked_files\": [],\n  \"current_step\": 9,\n  \"updated\": \"\"\n}\n")
    let rc = l0_lock(cfg, tid)
    if rc != 0 { return 1 }
    if !_file_exists(p) { eprintln("  FAIL missing after lock"); return 1 }
    let b2 = read_file(p)
    if b2.index_of("\"current_step\": 10") < 0 { eprintln("  FAIL step != 10"); return 1 }
    // cleanup: remove uchg then delete
    let _rm2 = _chflag_remove(p, "uchg")
    let _c = exec_with_status("rm -f " + _sh_quote(p))
    println("  PASS: step=10, lock applied (darwin=" + to_string(_is_darwin()) + ")")
    return 0
}

fn main() -> int {
    let av = _argv()
    if _flag(av, "--help") { println("usage: hexa tool/ps_9_l0_lock.hexa --issue <id>"); return 0 }
    let cfg = _load_config(_opt(av, "--config", DEFAULT_CONFIG))
    if _flag(av, "self-test") || _flag(av, "--self-test") { return self_test(cfg) }
    let id = _opt(av, "--issue", "")
    if id == "" { eprintln("--issue required"); return 2 }
    return l0_lock(cfg, id)
}
