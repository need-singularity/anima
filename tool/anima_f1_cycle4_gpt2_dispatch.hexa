// tool/anima_f1_cycle4_gpt2_dispatch.hexa — F1 cycle 4 real Transformer (GPT-2 small) baseline dispatch
// ─────────────────────────────────────────────────────────────────────────────
// Per Agent 3 cycle-4 prospective design (sub-agent kick 2026-04-28T07:25Z):
//   Replace order-1 Markov surrogate with real Transformer. GPT-2 small (124M)
//   fine-tuned on cycle 4 8-task corpus (200 train + 200 test per task).
//
// HF gating: gpt2 = OPEN (HTTP 200, no gating). vast.ai T4 ~$0.20/hr × ~2hr = ~$0.40-1
//
// PIPELINE (single T4 16GB pod ~2hr ~$1):
//   1. R1 download GPT-2 base (~500MB) + corpus prep — 5 min
//   2. R2 fine-tune GPT-2 across 8 tasks × 200 train ex (10 min/task = 80 min)
//   3. Eval forward 1600 × 10 steps (next-state predict) — 30 min
//   4. CA(5) baseline (rule-induction) re-run for paired comparison — 5 min
//   5. Per-task accuracy + Stouffer's z exact p-value mode (bootstrap 1000)
//   6. Buffer/teardown — 10 min
//
// PASS PREDICATE (raw 12 frozen BEFORE measurement):
//   - Per-task: bootstrap 1000 resamples (CA_acc - GPT2_acc), one-sided p<0.05
//   - Stouffer: z_combined > 1.645 for α=0.05 PASS at "any-advantage" threshold
//   - 81% claim PASS: each task advantage > 0.81 (very strict)
//
// raw 9 hexa-only · raw 12 frozen pre-registration · raw 86 cost · raw 100 fallback
// ─────────────────────────────────────────────────────────────────────────────

let TOOL_VERSION = "v1"
let HELPER_PATH = "/tmp/anima_f1_cycle4_gpt2_dispatch_helper.hexa_tmp"
let MODEL_HF_REPO = "gpt2"
let MODEL_HF_LICENSE = "MIT (open, HTTP 200)"
let MODEL_PARAMS_M = 124
let DISPATCH_BUDGET_USD = 2
let DISPATCH_BUDGET_MIN = 180  // 3hr cap

// Pre-registered cycle 4 PASS predicates (raw 12 frozen BEFORE measurement)
let STOUFFER_Z_ALPHA_05 = 1645  // 1.645 * 1000
let CYCLE4_81PCT_CLAIM_PER_THOUSAND = 810

fn _detect_python3() -> str {
    let candidates = [
        "/opt/homebrew/bin/python3",
        "/usr/local/bin/python3",
        "/usr/bin/python3"
    ]
    let mut i = 0
    while i < candidates.len() {
        let p = candidates[i]
        if file_exists(p) { return p }
        i = i + 1
    }
    return "python3"
}

fn _emit_helper() -> str {
    let lines = [
        "#!/usr/bin/env python3",
        "# anima_f1_cycle4_gpt2_dispatch_helper.py — raw#37 transient",
        "import os, sys, json, subprocess, datetime",
        "",
        "REPO = '/Users/ghost/core/anima'",
        "VASTAI_CLI = '/Users/ghost/.local/bin/vastai'",
        "SECRET_CLI = '/Users/ghost/core/secret/bin/secret'",
        "MODEL_HF_REPO = 'gpt2'",
        "DISPATCH_LABEL = 'anima-f1-cycle4-gpt2-dispatch'",
        "BUDGET_USD = 2",
        "BUDGET_MIN = 180",
        "",
        "def get_secret(key):",
        "    try:",
        "        return subprocess.check_output([SECRET_CLI, 'get', key], text=True).strip()",
        "    except Exception: return None",
        "",
        "def search_offers(gpu='RTX_3090', max_price=0.50, min_disk=50, min_reliability=0.95):",
        "    # T4 alternative: RTX_3090 (cheaper, sufficient for 124M GPT-2 fine-tune)",
        "    query = f'gpu_name={gpu} rentable=true reliability>{min_reliability} disk_space>={min_disk}'",
        "    try:",
        "        out = subprocess.check_output([VASTAI_CLI, 'search', 'offers', query, '--order', 'dph_total', '--limit', '5', '--raw'], text=True)",
        "        offers = json.loads(out) if out else []",
        "        affordable = [o for o in offers if o.get('dph_total', 999) <= max_price]",
        "        return affordable",
        "    except Exception as e:",
        "        return [{'error': str(e)}]",
        "",
        "def emit_dispatch_plan():",
        "    api_key = get_secret('vast.api_key')",
        "    if not api_key: return {'error': 'vast.api_key missing in secret store'}",
        "    ssh_key_path = os.path.expanduser('~/.vast/ssh/vast-key')",
        "    ssh_present = os.path.exists(ssh_key_path)",
        "    if not ssh_present:",
        "        return {'error': 'vast SSH key missing at ' + ssh_key_path}",
        "    offers = search_offers()",
        "    plan = {",
        "        'tool': 'anima_f1_cycle4_gpt2_dispatch',",
        "        'version': 'v1',",
        "        'ts': datetime.datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ'),",
        "        'model_hf_repo': MODEL_HF_REPO,",
        "        'model_license': 'MIT (open, HTTP 200)',",
        "        'model_params_m': 124,",
        "        'corpus': 'cycle 4 prospective 8-task (Wolfram 30/90/110/184 + Conway + integer-seq + boolean + random-walk)',",
        "        'samples_per_task_train': 200,",
        "        'samples_per_task_test': 200,",
        "        'preflight_checks': {",
        "            'gpt2_open_no_gating': True,  # HTTP 200 verified prior",
        "            'cycle_4_8_task_baseline_complete': True,  # commit feedc677 + e024fa41 + c4bd8d7d",
        "            'stouffer_aggregator_ready': True,  # commit 008e0a9d",
        "            'vast_api_key_present': True,",
        "            'vast_ssh_key_file_present': ssh_present,",
        "        },",
        "        'stages': [",
        "            {'stage': 'R1_download_gpt2_base_500MB', 'duration_min': 5, 'cost_usd': '0.05'},",
        "            {'stage': 'R2_finetune_8_tasks_200_train_each', 'duration_min': 80, 'cost_usd': '0.40'},",
        "            {'stage': 'eval_forward_1600_x_10_steps', 'duration_min': 30, 'cost_usd': '0.15'},",
        "            {'stage': 'ca_baseline_rerun_paired_comparison', 'duration_min': 5, 'cost_usd': '0.025'},",
        "            {'stage': 'stouffer_z_exact_pvalue_bootstrap_1000', 'duration_min': 10, 'cost_usd': '0.05'},",
        "            {'stage': 'buffer_teardown', 'duration_min': 10, 'cost_usd': 'overhead'},",
        "        ],",
        "        'total_estimated': {'duration_min': 140, 'cost_usd': 0.7, 'budget_cap_usd': BUDGET_USD, 'budget_cap_min': BUDGET_MIN},",
        "        'pre_registered_pass_predicates': {",
        "            'per_task_one_sided_alpha': 0.05,",
        "            'bootstrap_resamples': 1000,",
        "            'stouffer_z_alpha_05': 1.645,",
        "            'cycle4_81pct_claim_per_task_threshold': 0.81,",
        "        },",
        "        'cost_attribution_raw_86': {",
        "            'cost_center': 'anima-f1-cycle4-gpt2-real-transformer-baseline',",
        "            'task_id': 'f1c4_gpt2_dispatch_' + datetime.datetime.utcnow().strftime('%Y%m%dT%H%M%SZ'),",
        "            'cost_estimate_usd': 0.7,",
        "            'vendor': 'vast.ai',",
        "            'gpu_class': 'RTX_3090',",
        "        },",
        "        'expected_outcome_priors': {",
        "            'gpt2_should_match_or_beat_markov_on_T7_int_seq': 'GPT-2 has integer-pattern prior, Markov beat CA -15.3% in cycle 4 — GPT-2 expected to beat both',",
        "            'gpt2_likely_match_ca_on_T1_T5_wolfram_rules': 'Cycle 4 found CA=Markov=100% — GPT-2 likely also 100% (degenerate)',",
        "            'gpt2_may_beat_markov_on_T8b_glider': 'Glider period-4 Markov got 84% — GPT-2 with positional encoding may match CA 100%',",
        "        },",
        "        'offers_top5_filtered': offers[:5],",
        "        'dispatch_status': 'DESIGN_READY_AWAITING_USER_FIRE',",
        "    }",
        "    return plan",
        "",
        "def main():",
        "    plan = emit_dispatch_plan()",
        "    print(json.dumps(plan, indent=2))",
        "",
        "if __name__ == '__main__': main()",
    ]
    let mut text = ""
    let mut i = 0
    while i < lines.len() {
        text = text + lines[i] + "\n"
        i = i + 1
    }
    write_file(HELPER_PATH, text)
    return HELPER_PATH
}

fn _selftest() {
    println("__F1_CYCLE4_GPT2_DISPATCH_BEGIN__ selftest")
    let _path = _emit_helper()
    println("helper_emitted=" + HELPER_PATH)
    println("model_hf_repo=" + MODEL_HF_REPO)
    println("model_license=" + MODEL_HF_LICENSE)
    println("model_params_m=" + str(MODEL_PARAMS_M))
    println("dispatch_budget_usd=" + str(DISPATCH_BUDGET_USD) + " budget_min=" + str(DISPATCH_BUDGET_MIN))
    println("invariant_check_stouffer_z_alpha_05=" + str(STOUFFER_Z_ALPHA_05))
    println("invariant_check_81pct_claim_threshold=" + str(CYCLE4_81PCT_CLAIM_PER_THOUSAND))
    println("__F1_CYCLE4_GPT2_DISPATCH_RESULT__ PASS_SELFTEST")
    println("raw_10_caveat=GPT-2 small (124M) is small but addresses Markov surrogate caveat — real Transformer with positional encoding")
    println("raw_10_caveat=Pre-registered PASS predicates frozen BEFORE GPU dispatch (raw 12)")
    println("raw_10_caveat=Bootstrap 1000 resamples per task = exact p-value Stouffer mode (vs autonomous-loop iter 4 advantage-heuristic mode)")
    println("raw_10_caveat=RTX_3090 default (cheaper than T4 surprisingly per Agent 3 design); change to T4 if 3090 unavailable")
}

fn _plan() {
    println("__F1_CYCLE4_GPT2_DISPATCH_BEGIN__ plan")
    let _path = _emit_helper()
    let py = _detect_python3()
    println("helper_emitted=" + HELPER_PATH)
    println("python3_detected=" + py)
    println("__F1_CYCLE4_GPT2_DISPATCH_RESULT__ HELPER_READY")
    println("fix: 1) " + py + " " + HELPER_PATH + "  2) interpret JSON dispatch plan + offers  3) review + decide fire")
    println("raw_10_caveat=NO ACTUAL DISPATCH — plan emit only. user-fire required for vastai create instance.")
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_plan = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--plan" { has_plan = true }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_plan { _plan() }
    else {
        println("usage: hexa run tool/anima_f1_cycle4_gpt2_dispatch.hexa --selftest | --plan")
        println("F1 cycle 4 real Transformer (GPT-2 small) baseline vast.ai dispatch — addresses Markov surrogate caveat")
    }
    return 0
}
