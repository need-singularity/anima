// ════════════════════════════════════════════════════════════════════════════
//  tool/docs_toc_generator.hexa — auto TOC generator for anima docs/
//
//  PURPOSE
//    Scan a docs directory for *.md files, extract H1 / H2 headings, and
//    emit a single TOC.md with GitHub-style anchor links.
//    Stable ordering (sort by file path) guarantees byte-for-byte determinism.
//
//  USAGE
//    hexa run tool/docs_toc_generator.hexa                        # default path
//    hexa run tool/docs_toc_generator.hexa --docs <dir>           # override
//    hexa run tool/docs_toc_generator.hexa --out  <file>          # override
//    hexa run tool/docs_toc_generator.hexa --selftest             # S1/S2/S3
//    hexa run tool/docs_toc_generator.hexa --help
//
//  OUTPUT FORMAT
//    # Documentation TOC
//
//    _Auto-generated by tool/docs_toc_generator.hexa — do not hand-edit._
//
//    ## <relative-file-path>
//    - [<H1-text>](<relative-file-path>#<slug>)
//      - [<H2-text>](<relative-file-path>#<slug>)
//      - [<H2-text>](<relative-file-path>#<slug>)
//    ...
//
//    When docs dir is empty, only the header + placeholder survive.
//
//  RULES
//    raw#9  hexa-only    raw#11 snake_case    raw#15 no-hardcode
//    Existing TOC.md at --out target is preserved as TOC.md.bak.<ts> (never
//    silently overwritten).  Stable sort + deterministic slug = S3 passes.
//
//  GITHUB-STYLE SLUG (subset matching GitHub's rules)
//    · lowercase
//    · drop characters that are not [a-z0-9 -_]
//    · spaces -> hyphens
//    · consecutive hyphens collapse to one   (we keep them — GH also does)
//
//  EXIT CODES
//    0  success (generation or selftest PASS)
//    1  selftest FAIL
//    2  setup error (missing docs dir when required)
// ════════════════════════════════════════════════════════════════════════════

let DEFAULT_DOCS_DIR = "/Users/ghost/core/anima/docs"
let DEFAULT_OUT_PATH = "/Users/ghost/core/anima/docs/TOC.md"

let TOC_HEADER      = "# Documentation TOC"
let TOC_BANNER      = "_Auto-generated by tool/docs_toc_generator.hexa — do not hand-edit._"
let TOC_EMPTY_NOTE  = "_No markdown files found in docs/._"

// ─── sys helpers ──────────────────────────────────────────────────────────

fn _sh_quote(s: string) -> string {
    let mut out = "'"
    out = out + s.replace("'", "'\\''")
    out = out + "'"
    return out
}

fn _exec_out(cmd: string) -> string {
    let r = exec_with_status(cmd)
    return to_string(r[0])
}

fn _exec_code(cmd: string) -> int {
    let r = exec_with_status(cmd)
    return r[1]
}

fn _file_exists(path: string) -> bool {
    return _exec_code("test -e " + _sh_quote(path)) == 0
}

fn _dir_exists(path: string) -> bool {
    return _exec_code("test -d " + _sh_quote(path)) == 0
}

fn _mkdir_p(dir: string) -> bool {
    return _exec_code("mkdir -p " + _sh_quote(dir)) == 0
}

fn _rm_rf(path: string) -> bool {
    return _exec_code("rm -rf " + _sh_quote(path)) == 0
}

fn _ts_compact() -> string {
    return _exec_out("date -u +%Y%m%d%H%M%S").trim()
}

// List *.md files (non-recursive) inside dir, sorted by path (LC_ALL=C).
fn _list_md_files(dir: string) -> array {
    if !_dir_exists(dir) { return [] }
    // `-name '*.md'` filters; `-maxdepth 1` = non-recursive; sort stable.
    let cmd = "find " + _sh_quote(dir) + " -maxdepth 1 -type f -name '*.md' 2>/dev/null | LC_ALL=C sort"
    let out = _exec_out(cmd)
    let lines = out.split("\n")
    let mut acc = []
    for l in lines {
        let t = to_string(l).trim()
        if t.len() > 0 { acc.push(t) }
    }
    return acc
}

// Relative path = basename (docs_dir is the single root we scan).
fn _basename(path: string) -> string {
    let parts = path.split("/")
    if len(parts) == 0 { return path }
    return to_string(parts[len(parts) - 1])
}

// ─── argv ────────────────────────────────────────────────────────────────

fn _argv() -> array {
    let a = args()
    let mut out = []
    let mut i = 2
    while i < len(a) {
        out.push(a[i])
        i = i + 1
    }
    return out
}

fn _flag(av: array, k: string) -> bool {
    for x in av {
        if to_string(x) == k { return true }
    }
    return false
}

fn _opt(av: array, k: string, d: string) -> string {
    let mut i = 0
    while i < len(av) {
        if to_string(av[i]) == k && i + 1 < len(av) {
            return to_string(av[i + 1])
        }
        i = i + 1
    }
    return d
}

// ─── GitHub-style slug ────────────────────────────────────────────────────

// Use char_code ranges — string relational ops aren't reliable across
// the hexa toolchain for single-char strings.
fn _is_alpha_code(cc: int) -> bool {
    if cc >= 97 && cc <= 122 { return true }   // a..z
    if cc >= 65 && cc <= 90  { return true }   // A..Z
    return false
}

fn _is_digit_code(cc: int) -> bool {
    return cc >= 48 && cc <= 57                // 0..9
}

// GH slug: lowercase; keep a-z 0-9 _; spaces -> '-'; drop everything else.
// Consecutive hyphens preserved (matches GitHub).
fn slugify(s: string) -> string {
    let lower = s.to_lower()
    let n = lower.len()
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = lower.substring(i, i + 1)
        let cc = char_code(c, 0)
        if _is_alpha_code(cc) || _is_digit_code(cc) {
            out = out + c
        } else if cc == 32 {
            out = out + "-"
        } else if cc == 45 {        // '-'
            out = out + "-"
        } else if cc == 95 {        // '_'
            out = out + "_"
        }
        // everything else: drop
        i = i + 1
    }
    return out
}

// ─── heading extraction ───────────────────────────────────────────────────
//
// Extract H1 / H2 only.  ATX-style headings:  ^#  <text>   or  ^##  <text>.
// We ignore setext headings (underline) and code-fence blocks.
//
// Returns array of heading maps: [{"level": 1|2, "text": "...", "slug": "..."}]
//
fn extract_headings(body: string) -> array {
    let mut out = []
    let lines = body.split("\n")
    let mut in_fence = false
    let mut fence_mark = ""
    let mut i = 0
    let n = len(lines)
    while i < n {
        let raw = to_string(lines[i])
        let trimmed_left = raw   // preserve left-side for fence detection
        let t = raw.trim()
        // Code fence tracking (```  or  ~~~).  A fence opens on "```..." line
        // and closes on next "```" at any indent.  We accept raw match at start.
        if !in_fence {
            if t.starts_with("```") {
                in_fence = true
                fence_mark = "```"
                i = i + 1
                continue
            }
            if t.starts_with("~~~") {
                in_fence = true
                fence_mark = "~~~"
                i = i + 1
                continue
            }
        } else {
            if t.starts_with(fence_mark) {
                in_fence = false
                fence_mark = ""
            }
            i = i + 1
            continue
        }

        // Heading must start at column 0 (ATX) — ignore indented "pseudo" heads.
        if raw.starts_with("# ") {
            let txt = raw.substring(2, raw.len()).trim()
            // strip trailing '#' sequence (GH allows closing '#' run)
            let clean = _strip_trailing_hashes(txt)
            let mut h = #{}
            h["level"] = 1
            h["text"] = clean
            h["slug"] = slugify(clean)
            out.push(h)
        } else if raw.starts_with("## ") {
            let txt = raw.substring(3, raw.len()).trim()
            let clean = _strip_trailing_hashes(txt)
            let mut h = #{}
            h["level"] = 2
            h["text"] = clean
            h["slug"] = slugify(clean)
            out.push(h)
        }
        // H3+ ignored per spec
        i = i + 1
    }
    return out
}

fn _strip_trailing_hashes(s: string) -> string {
    // Remove trailing run of '#' chars (optionally preceded by space).
    let mut t = s
    while t.len() > 0 && t.substring(t.len() - 1, t.len()) == "#" {
        t = t.substring(0, t.len() - 1)
    }
    return t.trim()
}

// ─── TOC render ───────────────────────────────────────────────────────────

// Render a single file block.
//   ## <rel>
//   - [H1](rel#slug)
//     - [H2](rel#slug)
fn _render_file_block(rel: string, headings: array) -> string {
    let mut s = ""
    s = s + "## " + rel + "\n"
    if len(headings) == 0 {
        s = s + "_(no H1/H2 headings)_\n"
        return s
    }
    let mut i = 0
    let n = len(headings)
    while i < n {
        let h = headings[i]
        let lvl = to_int(to_string(h["level"]))
        let txt = to_string(h["text"])
        let slug = to_string(h["slug"])
        let link = "[" + _md_escape(txt) + "](" + rel + "#" + slug + ")"
        if lvl == 1 {
            s = s + "- " + link + "\n"
        } else {
            s = s + "  - " + link + "\n"
        }
        i = i + 1
    }
    return s
}

// Escape `]` and `[` in heading text for markdown link anchors.
fn _md_escape(s: string) -> string {
    let a = s.replace("\\", "\\\\")
    let b = a.replace("]", "\\]")
    let c = b.replace("[", "\\[")
    return c
}

// Build complete TOC body.  Empty dir -> header + empty note.
fn render_toc(docs_dir: string, self_out_path: string) -> string {
    let files = _list_md_files(docs_dir)
    let mut body = ""
    body = body + TOC_HEADER + "\n\n"
    body = body + TOC_BANNER + "\n\n"

    // Filter: skip the output TOC itself, if it lives inside docs_dir.
    let self_base = _basename(self_out_path)
    let mut rendered = 0
    let mut i = 0
    let n = len(files)
    while i < n {
        let full = to_string(files[i])
        let rel = _basename(full)
        if rel == self_base {
            i = i + 1
            continue
        }
        let raw = read_file(full)
        let hs = extract_headings(raw)
        body = body + _render_file_block(rel, hs) + "\n"
        rendered = rendered + 1
        i = i + 1
    }

    if rendered == 0 {
        body = body + TOC_EMPTY_NOTE + "\n"
    }
    return body
}

// ─── atomic write + backup ───────────────────────────────────────────────

fn _backup_if_present(path: string) -> string {
    if !_file_exists(path) { return "" }
    let ts = _ts_compact()
    let bak = path + ".bak." + ts
    let rc = _exec_code("cp -p " + _sh_quote(path) + " " + _sh_quote(bak))
    if rc != 0 { return "" }
    return bak
}

fn _atomic_write(path: string, body: string) {
    let tmp = path + ".tmp." + _ts_compact()
    write_file(tmp, body)
    let _ = _exec_code("mv -f " + _sh_quote(tmp) + " " + _sh_quote(path))
}

// ─── real-run ─────────────────────────────────────────────────────────────

fn generate_toc(docs_dir: string, out_path: string) -> int {
    if !_dir_exists(docs_dir) {
        eprintln("docs_toc_generator: SETUP_ERROR — docs dir missing: " + docs_dir)
        return 2
    }
    let out_dir = _parent_of(out_path)
    let _ = _mkdir_p(out_dir)
    let bak = _backup_if_present(out_path)
    let body = render_toc(docs_dir, out_path)
    _atomic_write(out_path, body)

    // Stats for the human log.
    let files = _list_md_files(docs_dir)
    let self_base = _basename(out_path)
    let mut file_count = 0
    let mut heading_count = 0
    let mut i = 0
    while i < len(files) {
        let full = to_string(files[i])
        if _basename(full) == self_base { i = i + 1; continue }
        let raw = read_file(full)
        let hs = extract_headings(raw)
        heading_count = heading_count + len(hs)
        file_count = file_count + 1
        i = i + 1
    }

    println("docs_toc_generator: wrote " + out_path)
    println("  docs_dir      = " + docs_dir)
    println("  files         = " + to_string(file_count))
    println("  headings      = " + to_string(heading_count) + "  (H1+H2)")
    if bak != "" {
        println("  prior_backup  = " + bak)
    }
    return 0
}

fn _parent_of(path: string) -> string {
    let parts = path.split("/")
    if len(parts) <= 1 { return "." }
    let mut out = ""
    let mut i = 0
    let cap = len(parts) - 1
    while i < cap {
        if i > 0 { out = out + "/" }
        out = out + to_string(parts[i])
        i = i + 1
    }
    if out == "" { return "/" }
    return out
}

// ─── selftest ─────────────────────────────────────────────────────────────
//
// S1 — synthetic 3 md files with known headings → TOC.md matches expected
//      byte-for-byte.
// S2 — empty dir → TOC.md only the header + placeholder.
// S3 — run twice back-to-back → identical output (determinism).
//

fn _mktempdir() -> string {
    let raw = _exec_out("mktemp -d -t docs_toc_selftest.XXXXXX 2>/dev/null").trim()
    return raw
}

fn _hash_file(path: string) -> string {
    if !_file_exists(path) { return "" }
    return _exec_out("shasum -a 256 " + _sh_quote(path) + " 2>/dev/null | awk '{print $1}'").trim()
}

fn _write_file(path: string, body: string) {
    write_file(path, body)
}

fn _expected_s1() -> string {
    // Must match render_toc's byte-for-byte output for the S1 fixture.
    let mut e = ""
    e = e + TOC_HEADER + "\n\n"
    e = e + TOC_BANNER + "\n\n"

    // alpha.md  (H1 "Alpha Doc"; H2 "Overview"; H2 "Details & More")
    e = e + "## alpha.md\n"
    e = e + "- [Alpha Doc](alpha.md#alpha-doc)\n"
    e = e + "  - [Overview](alpha.md#overview)\n"
    e = e + "  - [Details & More](alpha.md#details--more)\n"
    e = e + "\n"

    // bravo.md  (H1 "Bravo"; H2 "Setup"; fence around "## not-a-heading";
    //            H2 "Teardown")
    e = e + "## bravo.md\n"
    e = e + "- [Bravo](bravo.md#bravo)\n"
    e = e + "  - [Setup](bravo.md#setup)\n"
    e = e + "  - [Teardown](bravo.md#teardown)\n"
    e = e + "\n"

    // charlie.md  (no H1; H2 "Only Section")
    e = e + "## charlie.md\n"
    e = e + "  - [Only Section](charlie.md#only-section)\n"
    e = e + "\n"

    return e
}

fn _expected_s2() -> string {
    let mut e = ""
    e = e + TOC_HEADER + "\n\n"
    e = e + TOC_BANNER + "\n\n"
    e = e + TOC_EMPTY_NOTE + "\n"
    return e
}

fn _s1_write_fixtures(dir: string) {
    _write_file(dir + "/alpha.md",
        "# Alpha Doc\n" +
        "\n" +
        "some text\n" +
        "\n" +
        "## Overview\n" +
        "\n" +
        "body\n" +
        "\n" +
        "## Details & More\n" +
        "\n" +
        "tail\n")

    _write_file(dir + "/bravo.md",
        "# Bravo\n" +
        "\n" +
        "intro\n" +
        "\n" +
        "## Setup\n" +
        "\n" +
        "```\n" +
        "## not-a-heading\n" +
        "```\n" +
        "\n" +
        "## Teardown\n" +
        "\n" +
        "done\n")

    _write_file(dir + "/charlie.md",
        "no top heading\n" +
        "\n" +
        "## Only Section\n" +
        "\n" +
        "body\n")

    // Also write a stray non-md file to ensure we ignore it.
    _write_file(dir + "/ignore_me.txt", "not markdown\n")
}

fn run_selftest() -> int {
    let mut fails = 0
    println("docs_toc_generator: SELFTEST starting")

    // ── S1 ─────────────────────────────────────────────────────────────
    let d1 = _mktempdir()
    if d1 == "" {
        println("S1 FAIL: mktemp failed")
        return 1
    }
    _s1_write_fixtures(d1)
    let o1 = d1 + "/TOC.md"
    let rc1 = generate_toc(d1, o1)
    if rc1 != 0 {
        println("S1 FAIL: generate_toc returned " + to_string(rc1))
        fails = fails + 1
    } else {
        let got = read_file(o1)
        let want = _expected_s1()
        if got == want {
            println("S1 PASS: 3-file synthetic fixture byte-match")
        } else {
            fails = fails + 1
            println("S1 FAIL: byte mismatch")
            println("----- WANT -----")
            println(want)
            println("----- GOT  -----")
            println(got)
            println("----- END  -----")
        }
    }

    // ── S2 ─────────────────────────────────────────────────────────────
    let d2 = _mktempdir()
    if d2 == "" {
        println("S2 FAIL: mktemp failed")
        return 1
    }
    let o2 = d2 + "/TOC.md"
    let rc2 = generate_toc(d2, o2)
    if rc2 != 0 {
        println("S2 FAIL: generate_toc returned " + to_string(rc2))
        fails = fails + 1
    } else {
        let got2 = read_file(o2)
        let want2 = _expected_s2()
        if got2 == want2 {
            println("S2 PASS: empty-dir header + placeholder only")
        } else {
            fails = fails + 1
            println("S2 FAIL: byte mismatch")
            println("----- WANT -----")
            println(want2)
            println("----- GOT  -----")
            println(got2)
            println("----- END  -----")
        }
    }

    // ── S3 ─────────────────────────────────────────────────────────────
    // Reuse S1 tree; run twice, compare hashes.
    let o3 = d1 + "/TOC.md"
    let rc3a = generate_toc(d1, o3)
    let h_a = _hash_file(o3)
    let rc3b = generate_toc(d1, o3)
    let h_b = _hash_file(o3)
    if rc3a != 0 || rc3b != 0 {
        println("S3 FAIL: non-zero rc")
        fails = fails + 1
    } else if h_a != "" && h_a == h_b {
        println("S3 PASS: back-to-back runs deterministic (sha256=" + h_a.substring(0, 12) + "...)")
    } else {
        fails = fails + 1
        println("S3 FAIL: hash drift a=" + h_a + " b=" + h_b)
    }

    // Cleanup tmp dirs (best-effort).
    let _ = _rm_rf(d1)
    let _ = _rm_rf(d2)

    if fails == 0 {
        println("docs_toc_generator: SELFTEST PASS")
        return 0
    }
    println("docs_toc_generator: SELFTEST FAIL (" + to_string(fails) + " case(s))")
    return 1
}

// ─── main ────────────────────────────────────────────────────────────────

fn main() -> int {
    let av = _argv()
    if _flag(av, "--help") || _flag(av, "-h") {
        println("usage: hexa run tool/docs_toc_generator.hexa [opts]")
        println("  --docs <dir>     docs dir to scan (default: " + DEFAULT_DOCS_DIR + ")")
        println("  --out  <file>    output TOC file (default: " + DEFAULT_OUT_PATH + ")")
        println("  --selftest       run S1/S2/S3 and exit")
        println("  --help")
        return 0
    }
    if _flag(av, "--selftest") {
        return run_selftest()
    }
    let docs_dir = _opt(av, "--docs", DEFAULT_DOCS_DIR)
    let out_path = _opt(av, "--out",  DEFAULT_OUT_PATH)
    return generate_toc(docs_dir, out_path)
}

exit(main())
