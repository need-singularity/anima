// ════════════════════════════════════════════════════════════════════════════
//  tool/cert_gate.hexa — Path B Day 1 #22 soft reward shaping gate
//
//  PURPOSE
//    Deterministic reward-shaping primitive for ALM training. Loads the
//    full breakthrough certificate stack + state verdicts, computes
//    AN11 / Hexad / Mk.VIII satisfaction factors, and emits a single
//    reward multiplier reward_mult ∈ [0.0, 1.5] that downstream trainers
//    multiply into the gradient scale (no gradient X in this tool — it
//    only computes the scalar).
//
//  ROADMAP
//    airgenome-roadmap entry #22 (Path B Day 1)
//    exit_criteria: cert_gate.hexa landed + Mk.VIII cert self-test 100% PASS
//                   + ALM r12 dry-run (gradient X).
//
//  N6 TAGS
//    BT-C13 #8  consciousness-training (benzene π=6, τ(6)+2=6)
//               — n6 cluster entry #52 Mk.VI T0 매핑 (cert reward shaping).
//               mirror   : state/n6_ai_training_cost_status.json
//               selftest : tool/n6_consciousness_training_selftest.hexa
//               identity : J₂ = σ(6)·φ(6) = 12·2 = 24 (Trotter gate depth)
//
//  DESIGN — FACTOR → SOURCE MAPPING
//    --- AN11 factor (weight 1/3 of core) ---
//      state/learning_free_driver_result.json        stage_4_an11 triple
//      state/an11_a_verdict.json                     AN11(a) coverage note
//      state/an11_b_verdict.json                     AN11(b) coverage note
//      state/alm_r13_an11_b.json                     empirical AN11(b) gate
//      state/alm_r13_an11_c.json                     empirical AN11(c) JSD
//      state/alm_r0_an11_a.json                      r0 baseline (negative ref)
//      state/alm_r0_an11_c.json                      r0 baseline (negative ref)
//      .meta2-cert/lora-an11c-jsd1.json              cert (AN11(c) gap-close)
//
//    --- Hexad factor (weight 1/3 of core) ---
//      state/hexad_closure_verdict.json              6-cat closure axioms
//      state/hexad_n28_falsification_verdict.json    H★ EXP-1 n=28
//      .meta2-cert/cell-hexad-closure.json           natural-observed cert
//
//    --- Mk.VIII factor (weight 1/3 of core) ---
//      .meta2-cert/cell-mk8-stationary.json          KKT stationarity cert
//      .meta2-cert/mk8-7axis-skeleton.json           7-axis skeleton cert
//      .meta2-cert/cell-eigenvec-16.json             16 eigenvec orthogonality
//      state/cpgd_minimal_proof_result.json          10-step CPGD min proof
//
//    --- auxiliary state signal (bounded bonus ≤ +0.25) ---
//      state/true_closure_cert.json                  β main 8/8 aggregate
//      state/flops_landauer_bench_result.json        cell vs LoRA claim
//      state/learning_free_driver_result.json        overall_pass
//      state/anima_main_result.json                  anima_main heartbeat
//      state/cell_token_bridge_proto.json            bridge PoC
//      state/l_ix_integrator_verdict.json            L_IX
//      state/l_ix_5term_stress_verdict.json          L_IX 5-term stress
//      state/landauer_tracker_verdict.json           landauer
//      state/efficiency_verdict.json                 efficiency
//      state/v_rg_verdict.json                       v_rg
//      state/v_sync_kuramoto_verdict.json            v_sync
//      state/phase_progression_cert.json             phase progression
//      state/an_lix_01_smoke_result.json             L_IX smoke
//      state/edu_cell_l_ix_integrator.json           edu cell integrator
//      state/closure_debt_result.json                closure debt
//      state/roadmap_integrity_result.json           roadmap integrity
//      state/an11_weight_emergent_verdict.json       AN11 weight note
//      state/problem_solving_protocol_result.json    PSP
//      state/unified_eval_result.json                unified eval
//      state/meta2_hashchain_verify.json             meta^2 hashchain
//
//    --- bonus certs (contribute to aux signal, never core) ---
//      .meta2-cert/lora-phase-jump-k4.json           PHASE_JUMP @K=4
//      .meta2-cert/lora-l12-cpu-real.json            3 CPU-real adapters
//      .meta2-cert/universal-constant-4.json         K_c=4 (PARTIAL)
//      .meta2-cert/lora-mk6-held.json                Mk.VI HELD
//
//  REWARD FORMULA
//    core_sat      = mean(an11_sat, hexad_sat, mk8_sat)   ∈ [0,1]
//    aux_bonus     = 0.25 · aux_mean                      ∈ [0, 0.25]
//    base_reward   = 1.0 when all three core ≥ 0.999     (else scaled)
//      linear_sat  = 1.0 + 0.25 · (2·core_sat − 1)        ∈ [0.75, 1.25]
//    reward_mult   = clamp(linear_sat + aux_bonus, 0.0, 1.5)
//    HARD ZERO     = reward_mult := 0.0 when core_sat < 0.5
//                    (below-threshold → no reward flows; SGD frozen)
//
//  SELF-TEST (--selftest)
//    1. Load Mk.VIII cert triplet (cell-mk8-stationary, mk8-7axis-skeleton,
//       cell-hexad-closure) — all must have verdict=VERIFIED.
//    2. Load 20+ state verdicts and 10 .meta2-cert entries — count must
//       meet the roadmap contract.
//    3. Recompute reward_mult twice on the same frozen state → must be
//       bit-identical (byte_identical flag).
//    4. PASS iff mk8 triplet all VERIFIED AND count_state>=20 AND
//       count_cert>=10 AND byte_identical AND reward_mult >= 1.0.
//
//  DRY-RUN (--dry-run --target alm_r12)
//    Simulate ALM r12 reward application for the current training step.
//    No gradient update is performed — only reward_mult is emitted with
//    the target ckpt tag (for downstream ALM orchestrator to read).
//
//  USAGE
//    hexa tool/cert_gate.hexa --help
//    hexa tool/cert_gate.hexa --selftest
//    hexa tool/cert_gate.hexa --dry-run --target alm_r12
//    hexa tool/cert_gate.hexa --selftest --output <alt_path>
//
//  OUTPUT (raw#10 proof-carrying)
//    state/cert_gate_result.json
//
//  CONSTRAINTS
//    raw#9  hexa-only (no .py, no LLM judge)
//    raw#10 proof-carrying (verdict + all sat factors recorded)
//    raw#11 snake_case
//    raw#12 empirical (실측 only — reads real files, no synthetic)
//    raw#15 no-hardcode business logic (factor mapping documented above;
//                                       file paths are the only constants)
// ════════════════════════════════════════════════════════════════════════════

let CERT_DIR     = ".meta2-cert"
let STATE_DIR    = "state"
