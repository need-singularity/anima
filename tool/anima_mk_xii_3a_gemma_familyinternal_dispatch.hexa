// tool/anima_mk_xii_3a_gemma_familyinternal_dispatch.hexa — Mk.XII Phase 3a gemma family-internal scale pre-register (raw#9 hexa-only).
//
// PURPOSE
//   Mk.XII v2 Phase 3b 70B 진입 justification PARTIAL (1/3 clean: Mistral only).
//   axis 109 Qwen family-internal: Qwen2.5 invariant / Qwen3 BREAK → HQS-C MIXED_BACKBONE_CONDITIONAL.
//   handoff §3.6 actionable: "Mk.XII Phase 3a additional family-internal (gemma-2-9b → 27b within-family)".
//
//   본 helper = mac-local pre-register + dispatch ledger:
//     - gemma family within-family scale: gemma-2-2b → gemma-2-9b → gemma-2-27b (3-point scale curve)
//     - HMK-A (SCALE_INVARIANT) / HMK-B (SCALE_BREAK) decision criteria w/ explicit thresholds
//     - HQS-C MIXED hypothesis falsification path: gemma family must be either invariant OR break,
//       not both (else MIXED designation rooted in family heterogeneity, not architecture)
//     - dispatch order: 9b (already partial) → 2b (cheapest cross-anchor) → 27b (most expensive, decisive)
//     - selftest verifies: 3 bb scale curve / 3 frozen hypotheses / total budget ≤ $1.50
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/mk_xii_3a_gemma_familyinternal_pre_register.json)
//   ANIMA_INCLUDE_27B include gemma-2-27b ("true" default | "false" budget cap)
//
// OUTPUT
//   - bb_registry: 3-point gemma scale curve (2b / 9b / 27b)
//   - frozen_hypotheses: HMK-A SCALE_INVARIANT_GEMMA / HMK-B SCALE_BREAK_GEMMA / HQS-C_FALSIF
//   - dispatch_order: cheapest cross-anchor first, decisive 27b last
//   - cumulative_evidence_after_dispatch: how this changes Phase 3b 70B justification (1/3 → 2/3 if clean)
//
// USAGE
//   hexa run tool/anima_mk_xii_3a_gemma_familyinternal_dispatch.hexa --selftest
//   ANIMA_OUTPUT=state/mk_xii_3a_gemma_familyinternal_pre_register.json hexa run tool/anima_mk_xii_3a_gemma_familyinternal_dispatch.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - gemma-2-9b는 axis 99 Phase 3a에서 degenerate measured. v2 (axis 106 fix) 적용 후
//     재측정 필수 — HMK-A/B 평가 전 CMT v2 in_vivo retest 결과 dependency.
//   - 27b 포함 시 비용 증가 (~$0.95). dispatch_order에서 마지막 → 9b/2b 결과 보고 abort 가능.
//   - HQS-C MIXED 가설은 Qwen3 BREAK + Mistral CLEAN의 family-쌍 측정에서 등장 — gemma family-internal
//     이 invariant 또는 break 둘 중 하나로 결정나야 MIXED 가설이 architecture vs family에 attributable.

let HELPER_PATH = "/tmp/anima_mk_xii_3a_gemma_familyinternal_dispatch_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima Mk.XII Phase 3a gemma family-internal dispatch helper — emitted by tool/anima_mk_xii_3a_gemma_familyinternal_dispatch.hexa\n")
    parts.push("# raw#37 transient. Phase 3b 70B justification (1/3 → ≥2/3 clean) escalation harness.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/mk_xii_3a_gemma_familyinternal_pre_register.json')\n")
    parts.push("INCLUDE_27B = os.environ.get('ANIMA_INCLUDE_27B', 'true').lower() == 'true'\n\n")

    parts.push("BB_REGISTRY_FULL = [\n")
    parts.push("    {\n")
    parts.push("        'model_id':'google/gemma-2-2b', 'params_b':2.6, 'role':'CROSS_ANCHOR_LOW',\n")
    parts.push("        'cost_usd_est':0.10, 'hf_gated':False,\n")
    parts.push("        'measurement_status':'NOT_PREVIOUSLY_MEASURED_in_axis_99_or_109',\n")
    parts.push("        'precondition':'CMT v2 fix applied (axis 106 tool/anima_cmt_v2.hexa MLP-only)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'model_id':'google/gemma-2-9b', 'params_b':9.2, 'role':'PARTIAL_BASELINE',\n")
    parts.push("        'cost_usd_est':0.20, 'hf_gated':False,\n")
    parts.push("        'measurement_status':'DEGENERATE_v1_in_axis_99_PHASE_3a (axis 106 v2 retest pending: tool/anima_cmt_v2_5bb_retest_dispatch.hexa)',\n")
    parts.push("        'precondition':'CMT v2 5-bb retest (cycle 2 helper) result available',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'model_id':'google/gemma-2-27b', 'params_b':27.2, 'role':'DECISIVE_HIGH',\n")
    parts.push("        'cost_usd_est':0.65, 'hf_gated':False,\n")
    parts.push("        'measurement_status':'NOT_PREVIOUSLY_MEASURED (Phase 3a additional)',\n")
    parts.push("        'precondition':'CMT v2 fix applied; 9b retest result available (avoid duplicate degenerate measurement)',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("BB_REGISTRY = BB_REGISTRY_FULL if INCLUDE_27B else BB_REGISTRY_FULL[:2]\n\n")

    parts.push("FROZEN_HYPOTHESES = [\n")
    parts.push("    {\n")
    parts.push("        'id':'HMK-A_GEMMA', 'name':'SCALE_INVARIANT_GEMMA',\n")
    parts.push("        'statement':'gemma family within-family scale (2b/9b/27b) yields invariant CMT signature (Mistral-pattern)',\n")
    parts.push("        'decision_threshold':'CONFIRMED if all 3 bb v2 rel patterns yield BBA pairwise |r| > 0.7 across (2b,9b),(9b,27b),(2b,27b)',\n")
    parts.push("        'consequence_if_confirmed':'Phase 3b 70B justification advances 1/3 → 2/3 clean (Mistral + gemma)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'HMK-B_GEMMA', 'name':'SCALE_BREAK_GEMMA',\n")
    parts.push("        'statement':'gemma family BREAK at some scale boundary (Qwen3-pattern)',\n")
    parts.push("        'decision_threshold':'CONFIRMED if any pairwise BBA |r| < 0.3 in (2b,9b),(9b,27b),(2b,27b)',\n")
    parts.push("        'consequence_if_confirmed':'HQS-C MIXED elevated to STRONG (≥2 family BREAK confirms architecture-conditional, not noise)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'HQS-C_FALSIFICATION', 'name':'MIXED_BACKBONE_CONDITIONAL_test',\n")
    parts.push("        'statement':'HQS-C MIXED requires gemma family resolves to either CLEAN or BREAK — ambiguous (mid-range r) leaves HQS-C undetermined',\n")
    parts.push("        'decision_threshold':'AMBIGUOUS if all pairwise |r| in (0.3, 0.7) → HQS-C cannot be promoted; one more family (Llama 8b/70b) required',\n")
    parts.push("        'consequence_if_ambiguous':'Phase 3b 70B justification REMAINS PARTIAL — Llama family-internal escalation (HF gate dependency) becomes blocker',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("def _dispatch_order(bbs):\n")
    parts.push("    # cheapest cross-anchor first (de-risk pipeline) → decisive last\n")
    parts.push("    cross = sorted([b for b in bbs if b['role']=='CROSS_ANCHOR_LOW'], key=lambda b: b['cost_usd_est'])\n")
    parts.push("    partial = sorted([b for b in bbs if b['role']=='PARTIAL_BASELINE'], key=lambda b: b['cost_usd_est'])\n")
    parts.push("    decisive = sorted([b for b in bbs if b['role']=='DECISIVE_HIGH'], key=lambda b: b['cost_usd_est'])\n")
    parts.push("    return cross + partial + decisive\n\n")

    parts.push("order = _dispatch_order(BB_REGISTRY)\n")
    parts.push("total_budget = round(sum(b['cost_usd_est'] for b in BB_REGISTRY), 2)\n\n")

    parts.push("cumulative_evidence_paths = {\n")
    parts.push("    'HMK-A_CONFIRMED':{'phase_3b_clean_count':'1/3 → 2/3', 'verdict':'70B justification ADVANCES (Mistral+gemma 2 clean families)'},\n")
    parts.push("    'HMK-B_CONFIRMED':{'phase_3b_clean_count':'1/3 (unchanged)', 'verdict':'HQS-C MIXED elevated; 70B justification REQUIRES Llama family-internal next'},\n")
    parts.push("    'HQS-C_AMBIGUOUS':{'phase_3b_clean_count':'1/3 (unchanged)', 'verdict':'70B justification BLOCKED; Llama family-internal becomes critical-path blocker'},\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'Mk.XII Phase 3a gemma family-internal scale (2b/9b/27b) pre-register',\n")
    parts.push("    'parent_axis':'axis 109 (Qwen family-internal HQS-C MIXED) + axis 99 (Phase 3a 1/3 clean)',\n")
    parts.push("    'parent_handoff_actionable':'§3.6 Mk.XII Phase 3a additional family-internal (gemma-2-9b → 27b within-family)',\n")
    parts.push("    'bb_registry':BB_REGISTRY,\n")
    parts.push("    'frozen_hypotheses':FROZEN_HYPOTHESES,\n")
    parts.push("    'dispatch_order':[b['model_id'] for b in order],\n")
    parts.push("    'dispatch_order_with_cost':[{'model_id':b['model_id'],'cost_usd_est':b['cost_usd_est']} for b in order],\n")
    parts.push("    'total_budget_est_usd':total_budget,\n")
    parts.push("    'include_27b':INCLUDE_27B,\n")
    parts.push("    'precondition_chain':'axis 106 CMT v2 (#237 fix) → cycle 2 helper 5-bb retest → THIS HELPER',\n")
    parts.push("    'cumulative_evidence_paths':cumulative_evidence_paths,\n")
    parts.push("    'pre_register_status':'FROZEN_PRE_MEASUREMENT (raw#10 honest: post-hoc threshold revision = re-pre-register required)',\n")
    parts.push("    'n_bb':len(BB_REGISTRY),\n")
    parts.push("    'n_hypotheses':len(FROZEN_HYPOTHESES),\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[mk_xii_3a_gemma] n_bb={len(BB_REGISTRY)} budget=${total_budget} include_27b={INCLUDE_27B} dispatch_first={order[0][\"model_id\"]} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let bb_count_full_expected = 3
    let bb_count_min_expected = 2
    let hypotheses_count_expected = 3
    let total_budget_max_usd = 1.00
    let scale_points_expected = "2b/9b/27b"
    println("inv:bb_count_full_expected=" + to_string(bb_count_full_expected))
    println("inv:bb_count_min_expected=" + to_string(bb_count_min_expected))
    println("inv:hypotheses_count_expected=" + to_string(hypotheses_count_expected))
    println("inv:total_budget_max_usd=" + to_string(total_budget_max_usd))
    println("inv:scale_points_expected=" + scale_points_expected)
    println("inv:hypotheses_ids=HMK-A_GEMMA,HMK-B_GEMMA,HQS-C_FALSIFICATION")
    println("inv:every_hypothesis_has_explicit_threshold=true")
    println("inv:every_hypothesis_has_consequence_path=true")
    println("inv:precondition_chain_axis106_cycle2_THIS=true")
    println("inv:dispatch_order_cheapest_first_decisive_last=true")
    return true
}

fn cmd_selftest() {
    println("── anima_mk_xii_3a_gemma_familyinternal_dispatch selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=Mk.XII Phase 3a gemma family-internal scale (2b/9b/27b) pre-register, GPU $≤0.95)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
