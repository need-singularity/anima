// tool/anima_workspace_sibling_repos_auditor.hexa — $WS sibling repos cross-audit (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   memory project_workspace.md: $WS=/Users/ghost/core, anima + hexa-lang + airgenome 3 repos.
//   memory project_roadmap_engine.md: roadmap_engine reads 3 repos' .roadmap directly.
//   cycle 31 ready/ raw#9 divergence 발견 → sibling repos에서도 유사한 policy divergence 가능.
//
//   본 helper = mac-local NON_MUTATION:
//     - 3 sibling repos (anima/hexa-lang/airgenome) 각각 metadata
//     - .gitignore raw#9 strict (`**/*.py`) 적용 여부 비교
//     - .roadmap presence + size + age
//     - HEAD commit + branch
//     - selftest verifies: 3 repos / .roadmap presence / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/workspace_sibling_repos_auditor.json)
//   ANIMA_WS          workspace root (default: /Users/ghost/core)
//
// OUTPUT
//   - sibling_repos: list of {name, path, has_gitignore, has_roadmap, raw9_py_blanket, head_commit, branch, roadmap_size_kb}
//   - policy_divergence_findings (cycle 31 pattern)
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_workspace_sibling_repos_auditor.hexa --selftest
//   ANIMA_OUTPUT=state/workspace_sibling_repos_auditor.json hexa run tool/anima_workspace_sibling_repos_auditor.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - sibling list는 memory frozen (anima/hexa-lang/airgenome) — 추가 repos 시 list 갱신 필요.
//   - HEAD/branch는 subprocess git; failure 시 None.
//   - raw#9 .py blanket은 text match (cycle 31 같은 heuristic).

let HELPER_PATH = "/tmp/anima_workspace_sibling_repos_auditor_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima workspace sibling repos auditor — emitted by tool/anima_workspace_sibling_repos_auditor.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION sibling repos audit.\n")
    parts.push("import json, os, sys, subprocess\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/workspace_sibling_repos_auditor.json')\n")
    parts.push("WS = os.environ.get('ANIMA_WS', '/Users/ghost/core')\n\n")

    parts.push("SIBLINGS = [\n")
    parts.push("    {'name':'anima', 'path':os.path.join(WS, 'anima'), 'role':'consciousness implementation (main)'},\n")
    parts.push("    {'name':'hexa-lang', 'path':os.path.join(WS, 'hexa-lang'), 'role':'perfect number programming language + roadmap_engine binary'},\n")
    parts.push("    {'name':'airgenome', 'path':os.path.join(WS, 'airgenome'), 'role':'autonomous OS genome scanner'},\n")
    parts.push("]\n\n")

    parts.push("def _read_lines(path):\n")
    parts.push("    if not os.path.exists(path): return []\n")
    parts.push("    try:\n")
    parts.push("        with open(path, encoding='utf-8') as f: return f.read().splitlines()\n")
    parts.push("    except Exception: return []\n\n")

    parts.push("def _has_py_blanket(lines):\n")
    parts.push("    return any(l.strip() in ('**/*.py', '*.py') for l in lines)\n\n")

    parts.push("def _git_head(path):\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['git', 'rev-parse', 'HEAD'], cwd=path, capture_output=True, text=True, timeout=5)\n")
    parts.push("        if r.returncode == 0: return r.stdout.strip()[:12]\n")
    parts.push("    except Exception: pass\n")
    parts.push("    return None\n\n")

    parts.push("def _git_branch(path):\n")
    parts.push("    try:\n")
    parts.push("        r = subprocess.run(['git', 'branch', '--show-current'], cwd=path, capture_output=True, text=True, timeout=5)\n")
    parts.push("        if r.returncode == 0: return r.stdout.strip()\n")
    parts.push("    except Exception: pass\n")
    parts.push("    return None\n\n")

    parts.push("audit = []\n")
    parts.push("for s in SIBLINGS:\n")
    parts.push("    p = s['path']\n")
    parts.push("    if not os.path.isdir(p):\n")
    parts.push("        audit.append({**s, 'present':False})\n")
    parts.push("        continue\n")
    parts.push("    gi_path = os.path.join(p, '.gitignore')\n")
    parts.push("    rm_path = os.path.join(p, '.roadmap')\n")
    parts.push("    gi_lines = _read_lines(gi_path)\n")
    parts.push("    rm_size = os.path.getsize(rm_path) if os.path.exists(rm_path) else 0\n")
    parts.push("    audit.append({\n")
    parts.push("        **s,\n")
    parts.push("        'present':True,\n")
    parts.push("        'has_gitignore':os.path.exists(gi_path),\n")
    parts.push("        'gitignore_lines':len(gi_lines),\n")
    parts.push("        'has_roadmap':os.path.exists(rm_path),\n")
    parts.push("        'roadmap_size_kb':round(rm_size / 1024, 1),\n")
    parts.push("        'raw9_py_blanket':_has_py_blanket(gi_lines),\n")
    parts.push("        'head_commit':_git_head(p),\n")
    parts.push("        'branch':_git_branch(p),\n")
    parts.push("    })\n\n")

    parts.push("# policy divergence (cycle 31 pattern)\n")
    parts.push("findings = []\n")
    parts.push("for a in audit:\n")
    parts.push("    if not a.get('present'): continue\n")
    parts.push("    if not a.get('raw9_py_blanket'):\n")
    parts.push("        findings.append({\n")
    parts.push("            'repo':a['name'],\n")
    parts.push("            'kind':'NO_RAW9_PY_BLANKET',\n")
    parts.push("            'severity':'medium' if a['name'] != 'anima' else 'high',\n")
    parts.push("            'detail':f'{a[\"name\"]} .gitignore does NOT enforce **/*.py ban',\n")
    parts.push("            'consequence':'Python files allowed in this sibling repo',\n")
    parts.push("        })\n")
    parts.push("    if not a.get('has_roadmap'):\n")
    parts.push("        findings.append({\n")
    parts.push("            'repo':a['name'],\n")
    parts.push("            'kind':'NO_ROADMAP',\n")
    parts.push("            'severity':'high',\n")
    parts.push("            'detail':f'{a[\"name\"]} missing .roadmap (memory says roadmap_engine reads 3 repos)',\n")
    parts.push("        })\n\n")

    parts.push("# Aggregate\n")
    parts.push("present_count = sum(1 for a in audit if a.get('present'))\n")
    parts.push("with_roadmap = sum(1 for a in audit if a.get('has_roadmap'))\n")
    parts.push("with_py_blanket = sum(1 for a in audit if a.get('raw9_py_blanket'))\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'$WS sibling repos cross-audit (cycle 31 pattern generalization)',\n")
    parts.push("    'workspace':WS,\n")
    parts.push("    'sibling_repos':audit,\n")
    parts.push("    'sibling_count':len(SIBLINGS),\n")
    parts.push("    'present_count':present_count,\n")
    parts.push("    'with_roadmap':with_roadmap,\n")
    parts.push("    'with_raw9_py_blanket':with_py_blanket,\n")
    parts.push("    'policy_divergence_findings':findings,\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify sibling repos; read-only audit',\n")
    parts.push("    'cross_link_cycles':['cycle 21 SSOT chflags (.roadmap unlocked anima)','cycle 26 .gitignore audit (anima raw#9 verified)','cycle 27 nexus roadmaps','cycle 31 ready/ divergence pattern'],\n")
    parts.push("    'pattern':'governance audit chain layer 12 (cycles 21-31 + this)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[ws_siblings] siblings={present_count}/{len(SIBLINGS)} with_roadmap={with_roadmap} with_py_blanket={with_py_blanket} findings={len(findings)} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let siblings_count = 3
    let expected_repos = "anima,hexa-lang,airgenome"
    let non_mutation = "READ_ONLY"
    let divergence_kinds = "NO_RAW9_PY_BLANKET,NO_ROADMAP"
    println("inv:siblings_count=" + to_string(siblings_count))
    println("inv:expected_repos=" + expected_repos)
    println("inv:non_mutation=" + non_mutation)
    println("inv:divergence_kinds=" + divergence_kinds)
    println("inv:py_blanket_text_match=true")
    println("inv:cross_link_cycle21_cycle26_cycle27_cycle31=true")
    println("inv:subprocess_timeout_5s=true")
    return true
}

fn cmd_selftest() {
    println("── anima_workspace_sibling_repos_auditor selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=$WS sibling repos cross-audit (anima+hexa-lang+airgenome / raw#9 + roadmap consistency; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
