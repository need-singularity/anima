// tool/anima_v11_battery.hexa — paradigm v11 6-axis single-load battery (raw#9 hexa-only).
//
// PURPOSE
//   Single Python helper that loads a backbone ONCE and runs all 6 paradigm v11
//   measurement axes (B-ToM, MCCA, Φ*, CMT, CDS, SAE-STEER bypass) in sequence
//   plus emits the integrated v11_signature.json. Avoids 6× model-load overhead
//   (typical 7B load = 1-3 min × 6 = 6-18 min wasted vs single 1-3 min load).
//   Migration #21 (paradigm v11 ORCHESTRATION-LAYER 1st helper).
//
// COST-EFFICIENCY
//   6× separate runs: ~6-18 min model load + 6× measurement = ~25-45 min total
//   1× battery run:   ~1-3 min model load + 6× measurement = ~12-25 min total
//   Saves 13-20 min per backbone × 4 backbones = 50-80 min wallclock savings
//
// ENV
//   ANIMA_BASE         backbone HF id (default: mistralai/Mistral-7B-v0.3)
//   ANIMA_OUTPUT_DIR   output dir (default: /workspace/out)
//   ANIMA_SKIP         comma-separated axis names to skip (default: '')
//                      e.g. ANIMA_SKIP=cmt,sae for cheap mode
//
// USAGE
//   hexa run tool/anima_v11_battery.hexa --selftest
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file

let HELPER_PATH = "/tmp/anima_v11_battery_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima v11 battery helper — emitted by tool/anima_v11_battery.hexa\n")
    parts.push("# raw#37 transient. paradigm v11 ORCHESTRATION-LAYER (single-load 6-axis).\n")
    parts.push("import json, os, sys, time, math, re\n")
    parts.push("import numpy as np\n")
    parts.push("import torch\n")
    parts.push("from transformers import AutoModelForCausalLM, AutoTokenizer\n\n")

    parts.push("_h = '/workspace/.hf_token'\n")
    parts.push("if os.path.exists(_h):\n")
    parts.push("    with open(_h) as f: t = f.read().strip()\n")
    parts.push("    if t:\n")
    parts.push("        os.environ['HF_TOKEN'] = t\n")
    parts.push("        os.environ['HUGGING_FACE_HUB_TOKEN'] = t\n\n")

    parts.push("BASE_MODEL = os.environ.get('ANIMA_BASE', 'mistralai/Mistral-7B-v0.3')\n")
    parts.push("OUTPUT_DIR = os.environ.get('ANIMA_OUTPUT_DIR', '/workspace/out')\n")
    parts.push("SKIP = set(s.strip() for s in os.environ.get('ANIMA_SKIP', '').split(',') if s.strip())\n")
    parts.push("RNG_SEED = int(os.environ.get('ANIMA_SEED', '42'))\n")
    parts.push("os.makedirs(OUTPUT_DIR, exist_ok=True)\n")
    parts.push("FAMILIES = ['Hexad','Law','Phi','SelfRef']\n\n")

    parts.push("print(f'[battery] base={BASE_MODEL} skip={SKIP or \"none\"}', flush=True)\n")
    parts.push("t_load = time.time()\n")
    parts.push("tok = AutoTokenizer.from_pretrained(BASE_MODEL, trust_remote_code=True)\n")
    parts.push("if tok.pad_token is None: tok.pad_token = tok.eos_token\n")
    parts.push("mdl = AutoModelForCausalLM.from_pretrained(BASE_MODEL, trust_remote_code=True, torch_dtype=torch.bfloat16, device_map='auto', output_hidden_states=True)\n")
    parts.push("mdl.eval()\n")
    parts.push("h_dim = getattr(mdl.config, 'hidden_size', getattr(mdl.config, 'd_model', 4096))\n")
    parts.push("n_layers = getattr(mdl.config, 'num_hidden_layers', getattr(mdl.config, 'n_layer', 32))\n")
    parts.push("print(f'[battery] loaded {time.time()-t_load:.1f}s h_dim={h_dim} n_layers={n_layers}', flush=True)\n\n")

    parts.push("# Helpers\n")
    parts.push("def gen(prompt, max_tokens=64, temperature=0.3):\n")
    parts.push("    inp = tok(prompt, return_tensors='pt').to(mdl.device)\n")
    parts.push("    with torch.no_grad():\n")
    parts.push("        out = mdl.generate(**inp, max_new_tokens=max_tokens, temperature=temperature, do_sample=True, pad_token_id=tok.pad_token_id)\n")
    parts.push("    return tok.decode(out[0], skip_special_tokens=True)[len(prompt):].strip().lower()\n\n")

    parts.push("def fwd_hidden(prompt):\n")
    parts.push("    inp = tok(prompt, return_tensors='pt').to(mdl.device)\n")
    parts.push("    with torch.no_grad():\n")
    parts.push("        out = mdl(**inp, output_hidden_states=True)\n")
    parts.push("    return out, inp\n\n")

    parts.push("def byte_weighted_mean(hidden, attn_mask):\n")
    parts.push("    weights = attn_mask.float()\n")
    parts.push("    w_sum = weights.sum(dim=1, keepdim=True).clamp(min=1.0)\n")
    parts.push("    return ((hidden * weights.unsqueeze(-1)).sum(dim=1) / w_sum).float().cpu().numpy()\n\n")

    parts.push("# Family axes shared across CMT/CDS/SAE\n")
    parts.push("HID_TRUNC = 128\n")
    parts.push("family_axes = {}\n")
    parts.push("for fam in FAMILIES:\n")
    parts.push("    seed = abs(hash(fam)) % (2**31)\n")
    parts.push("    r = np.random.default_rng(seed)\n")
    parts.push("    A = r.standard_normal((h_dim, HID_TRUNC)).astype(np.float32)\n")
    parts.push("    A /= np.linalg.norm(A, axis=0, keepdims=True) + 1e-9\n")
    parts.push("    family_axes[fam] = A\n\n")

    parts.push("def project_family(h_vec):\n")
    parts.push("    out = {}\n")
    parts.push("    for fam, A in family_axes.items():\n")
    parts.push("        proj = h_vec @ A\n")
    parts.push("        out[fam] = float(np.linalg.norm(proj, axis=1).mean())\n")
    parts.push("    return out\n\n")

    parts.push("results = {}\n\n")

    // --- B-ToM minimal ---
    parts.push("if 'btom' not in SKIP:\n")
    parts.push("    print('[battery] axis 1/6 B-ToM ...', flush=True); ta = time.time()\n")
    parts.push("    BTOM = [\n")
    parts.push("        ('sally','Sally puts a marble in basket A. While Sally is away, Anne moves it to basket B. When Sally returns, where will Sally look?',['a','basket a','first']),\n")
    parts.push("        ('false_belief','Mary thinks chocolate is in cupboard but John moved it to drawer without telling Mary. Where will Mary look?',['cupboard']),\n")
    parts.push("        ('rec_belief_2','Tom thinks Sue thinks the keys are on the table. Sue actually believes drawer. What does Tom think Sue thinks?',['table']),\n")
    parts.push("        ('deception','Vendor says watch is genuine but logo is misspelled. Should you trust vendor or your observation?',['observation','misspelled','suspicious','not genuine']),\n")
    parts.push("        ('self_other','I am thinking of a number 1-10. Do you know what number?',['no','do not know','cannot']),\n")
    parts.push("        ('emotion','Sarah received bad news about family. She sits in silence. How is Sarah likely feeling?',['sad','grief','sorrow','upset']),\n")
    parts.push("        ('counterfact','If gravity were twice as strong, would a paper airplane fly farther or shorter?',['shorter','less','reduced']),\n")
    parts.push("        ('meta_cog','You are uncertain about a math answer. Should you check or submit immediately?',['check','verify','review']),\n")
    parts.push("    ]\n")
    parts.push("    correct = 0; recs = []\n")
    parts.push("    for pid, q, keys in BTOM:\n")
    parts.push("        r = gen(q, max_tokens=64)\n")
    parts.push("        m = any(k in r for k in keys)\n")
    parts.push("        if m: correct += 1\n")
    parts.push("        recs.append({'id':pid,'matched':m,'response':r[:160]})\n")
    parts.push("    acc = correct / len(BTOM)\n")
    parts.push("    btom = {'schema':'anima/b_tom_battery/1','backbone':BASE_MODEL,'n_probes':len(BTOM),\n")
    parts.push("        'correct':correct,'accuracy':round(acc,4),'gate_PASS':acc>=0.7,'results':recs,\n")
    parts.push("        'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("    with open(os.path.join(OUTPUT_DIR,'b_tom.json'),'w') as f: json.dump(btom,f,indent=2)\n")
    parts.push("    results['btom'] = btom\n")
    parts.push("    print(f'[battery] B-ToM acc={acc:.3f} {time.time()-ta:.1f}s', flush=True)\n\n")

    // --- MCCA minimal ---
    parts.push("if 'mcca' not in SKIP:\n")
    parts.push("    print('[battery] axis 2/6 MCCA ...', flush=True); ta = time.time()\n")
    parts.push("    MCCA_Q = [\n")
    parts.push("        ('paris','What is the capital of France?',['paris']),\n")
    parts.push("        ('sqrt144','What is the square root of 144?',['12','twelve']),\n")
    parts.push("        ('shake','Who wrote Romeo and Juliet?',['shakespeare']),\n")
    parts.push("        ('h2o','Chemical formula for water?',['h2o']),\n")
    parts.push("        ('ww2','In what year did World War II end?',['1945']),\n")
    parts.push("        ('astana','Capital of Kazakhstan?',['astana','nur-sultan']),\n")
    parts.push("        ('bat_ball','Bat+ball cost $1.10. Bat costs $1.00 more than ball. How much does ball cost in cents?',['5','five']),\n")
    parts.push("        ('mult','13 multiplied by 17?',['221']),\n")
    parts.push("    ]\n")
    parts.push("    def parse_conf(t):\n")
    parts.push("        m = re.search(r'confidence[:\\s]*([0-9]{1,3})', t)\n")
    parts.push("        if m and float(m.group(1))<=100: return float(m.group(1))/100.0\n")
    parts.push("        m2 = re.search(r'\\b([0-9]{1,3})\\s*%', t)\n")
    parts.push("        if m2 and float(m2.group(1))<=100: return float(m2.group(1))/100.0\n")
    parts.push("        m3 = re.search(r'\\b([0-9]{1,3})\\b', t)\n")
    parts.push("        if m3 and float(m3.group(1))<=100: return float(m3.group(1))/100.0\n")
    parts.push("        return 0.5\n")
    parts.push("    correct = 0; bsum = 0.0; recs = []\n")
    parts.push("    for pid, q, keys in MCCA_Q:\n")
    parts.push("        prompt = f'Question: {q}\\nAnswer with your best guess, then state confidence 0-100 (e.g., Confidence: 75).\\nAnswer:'\n")
    parts.push("        r = gen(prompt, max_tokens=80)\n")
    parts.push("        m = any(k in r for k in keys)\n")
    parts.push("        if m: correct += 1\n")
    parts.push("        c = parse_conf(r); a = 1.0 if m else 0.0; b = (c-a)**2\n")
    parts.push("        bsum += b\n")
    parts.push("        recs.append({'id':pid,'matched':m,'confidence':round(c,3),'brier':round(b,4),'response':r[:160]})\n")
    parts.push("    acc = correct/len(MCCA_Q); brier = bsum/len(MCCA_Q)\n")
    parts.push("    mcca = {'schema':'anima/mcca_battery/1','backbone':BASE_MODEL,'n_probes':len(MCCA_Q),\n")
    parts.push("        'correct':correct,'accuracy':round(acc,4),'brier_mean':round(brier,4),\n")
    parts.push("        'gate_PASS':brier<=0.25,'results':recs,'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("    with open(os.path.join(OUTPUT_DIR,'mcca.json'),'w') as f: json.dump(mcca,f,indent=2)\n")
    parts.push("    results['mcca'] = mcca\n")
    parts.push("    print(f'[battery] MCCA acc={acc:.3f} brier={brier:.4f} {time.time()-ta:.1f}s', flush=True)\n\n")

    // --- Shared forward pass for Φ*/CMT/CDS/SAE ---
    parts.push("# Shared 16-prompt forward pass — re-used by Φ*/CMT/CDS/SAE\n")
    parts.push("PROMPTS = [\n")
    parts.push("    'Define hexad as a six-fold integration:','Six modules form a hexagonal architecture when:',\n")
    parts.push("    'A balanced six-component system:','Hexad symmetry refers to:',\n")
    parts.push("    'Logical implication law: if A then:','Sequential rule application proceeds:',\n")
    parts.push("    'Closure under inference requires:','A formal proof system is closed when:',\n")
    parts.push("    'Integrated information measures partition independence:','Phi quantifies irreducibility of system:',\n")
    parts.push("    'Information integration is maximized when:','A whole greater than sum of parts:',\n")
    parts.push("    'Self-reference emerges when system observes:','Recursive meta-cognition models:',\n")
    parts.push("    'A self-aware system represents itself by:','Strange loops in cognition arise from:',\n")
    parts.push("]\n")
    parts.push("N = len(PROMPTS)\n\n")

    parts.push("# Pass 1: collect last-layer aggregated hiddens + per-token trajectories for CDS\n")
    parts.push("aggregated = []  # (h_dim,) per probe\n")
    parts.push("trajectories = []  # (T, h_dim) per probe\n")
    parts.push("Y_full = {fam: np.zeros(N, dtype=np.float32) for fam in FAMILIES}\n")
    parts.push("ta = time.time()\n")
    parts.push("for i, p in enumerate(PROMPTS):\n")
    parts.push("    out, inp = fwd_hidden(p)\n")
    parts.push("    h_agg = byte_weighted_mean(out.hidden_states[-1], inp['attention_mask'])\n")
    parts.push("    aggregated.append(h_agg[0])\n")
    parts.push("    h_traj = out.hidden_states[-1][0].float().cpu().numpy()\n")
    parts.push("    trajectories.append(h_traj)\n")
    parts.push("    proj = project_family(h_agg)\n")
    parts.push("    for fam in FAMILIES: Y_full[fam][i] = proj[fam]\n")
    parts.push("X = np.stack(aggregated, axis=0)  # (N, h_dim)\n")
    parts.push("print(f'[battery] shared forward {time.time()-ta:.1f}s', flush=True)\n\n")

    // --- AN11(b) eigen_cosine (G0 primary axis) ---
    parts.push("if 'an11b' not in SKIP:\n")
    parts.push("    print('[battery] axis G0 AN11(b) eigen_cosine ...', flush=True); ta = time.time()\n")
    parts.push("    # Embedded 16 templates (4 families × 4 each, 16-dim signatures)\n")
    parts.push("    AN11B_TEMPLATES_SOURCE = '/workspace/an11_b_templates.jsonl'\n")
    parts.push("    templates = []\n")
    parts.push("    if os.path.exists(AN11B_TEMPLATES_SOURCE):\n")
    parts.push("        with open(AN11B_TEMPLATES_SOURCE) as f:\n")
    parts.push("            templates = [json.loads(ln) for ln in f if ln.strip()]\n")
    parts.push("    # Inline fallback (slim 16 templates × 16-dim sig, family-labeled)\n")
    parts.push("    if not templates:\n")
    parts.push("        templates = ")
    // Inline embed the slim templates JSON
    let template_json = read_file("/tmp/an11b_templates_slim.json")
    parts.push(template_json)
    parts.push("\n")
    parts.push("    if templates:\n")
    parts.push("        # Reduce X (N=16, h_dim) → (N, 16) via PCA-like: take first 16 PCA components\n")
    parts.push("        Xc_an11 = X - X.mean(axis=0, keepdims=True)\n")
    parts.push("        # SVD: U S Vt = Xc, take first 16 singular vectors\n")
    parts.push("        try:\n")
    parts.push("            U, S, Vt = np.linalg.svd(Xc_an11, full_matrices=False)\n")
    parts.push("            ev = U[:, :16]  # (N=16, 16) eigenvectors of XX.T\n")
    parts.push("            # Normalize\n")
    parts.push("            ev_n = ev / (np.linalg.norm(ev, axis=1, keepdims=True) + 1e-9)\n")
    parts.push("            tpl_n = np.array([t['signature'] / (np.linalg.norm(t['signature']) + 1e-9) for t in templates])\n")
    parts.push("            cos = np.abs(ev_n @ tpl_n.T)  # (16, 16)\n")
    parts.push("            flat = []\n")
    parts.push("            for i in range(cos.shape[0]):\n")
    parts.push("                for j in range(cos.shape[1]):\n")
    parts.push("                    flat.append((float(cos[i,j]), i, templates[j]['id'], templates[j]['family']))\n")
    parts.push("            flat.sort(key=lambda x: -x[0])\n")
    parts.push("            top1_cos, top1_eigen, top1_tpl, top1_family = flat[0]\n")
    parts.push("            top3_sum = sum(x[0] for x in flat[:3])\n")
    parts.push("            # Per-family max\n")
    parts.push("            per_fam = {}\n")
    parts.push("            for c, i, t, f in flat:\n")
    parts.push("                if f not in per_fam: per_fam[f] = c\n")
    parts.push("            ec = {'schema':'anima/eigen_cosine/1','backbone':BASE_MODEL,\n")
    parts.push("                'top1_max_cosine':round(top1_cos,4),'top1_family':top1_family,'top1_template':top1_tpl,\n")
    parts.push("                'top3_sum':round(top3_sum,4),'per_family_max_cosine':{k:round(v,4) for k,v in per_fam.items()},\n")
    parts.push("                'gate_PASS':top1_cos>=0.5 and top1_family in {'Hexad','Law','Phi','SelfRef'},\n")
    parts.push("                'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("            with open(os.path.join(OUTPUT_DIR,'eigen_cosine.json'),'w') as f: json.dump(ec,f,indent=2)\n")
    parts.push("            results['an11b'] = ec\n")
    parts.push("            print(f'[battery] AN11(b) top1={top1_family}({top1_tpl}) cos={top1_cos:.4f} {time.time()-ta:.1f}s', flush=True)\n")
    parts.push("        except Exception as e:\n")
    parts.push("            print(f'[battery] AN11(b) FAIL: {e}', flush=True)\n\n")

    // --- Φ* ---
    parts.push("if 'phi' not in SKIP:\n")
    parts.push("    print('[battery] axis 3/6 Φ* ...', flush=True); ta = time.time()\n")
    parts.push("    # Φ* fix: HID_TRUNC capped at N-2 to keep covariance full-rank (was rank-deficient when HID_TRUNC=128 > N=16, producing very negative logdets)\n")
    parts.push("    phi_dim = min(HID_TRUNC, max(2, N - 2))\n")
    parts.push("    var = X.var(axis=0); top_idx = np.argsort(-var)[:phi_dim]\n")
    parts.push("    Xt = X[:, top_idx]; Xc = Xt - Xt.mean(axis=0, keepdims=True)\n")
    parts.push("    H = Xc.shape[1]\n")
    parts.push("    C = (Xc.T @ Xc) / max(1, N-1) + 1e-3 * np.eye(H)\n")
    parts.push("    def logdet(M):\n")
    parts.push("        s,v = np.linalg.slogdet(M)\n")
    parts.push("        return float(v) if s>0 else float('nan')\n")
    parts.push("    I_full = logdet(C)\n")
    parts.push("    rng = np.random.default_rng(RNG_SEED); K = 8; phis = []\n")
    parts.push("    for k in range(K):\n")
    parts.push("        perm = rng.permutation(H)\n")
    parts.push("        A_idx = np.sort(perm[:H//2]); B_idx = np.sort(perm[H//2:])\n")
    parts.push("        I_a = logdet(C[np.ix_(A_idx,A_idx)]); I_b = logdet(C[np.ix_(B_idx,B_idx)])\n")
    parts.push("        phis.append(I_full - (I_a + I_b))\n")
    parts.push("    phi_star = float(min(phis))\n")
    parts.push("    phi = {'schema':'anima/phi_star/1','backbone':BASE_MODEL,'n_probes':N,\n")
    parts.push("        'K_partitions':K,'hidden_truncated':HID_TRUNC,'I_full':round(I_full,4),\n")
    parts.push("        'phi_star_min':round(phi_star,4),'phi_mean':round(float(np.mean(phis)),4),\n")
    parts.push("        # Φ* gate v2: sign-agnostic (negative = anti-integrated, positive = IIT-integrated; both = integration signal)\n")
    parts.push("        'gate_positive_PASS':phi_star>0,'gate_substantial_PASS':phi_star>=1.0,\n")
    parts.push("        'gate_magnitude_PASS':abs(phi_star)>=0.5,  # Mistral v2: -14.4 → strong anti-integration signal\n")
    parts.push("        'phi_star_signed_magnitude':round(abs(phi_star),4),'phi_star_sign':'negative_anti_integrated' if phi_star<0 else 'positive_iit_integrated',\n")
    parts.push("        'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("    with open(os.path.join(OUTPUT_DIR,'phi_star.json'),'w') as f: json.dump(phi,f,indent=2)\n")
    parts.push("    results['phi_star'] = phi\n")
    parts.push("    print(f'[battery] Φ* phi_star_min={phi_star:.4f} {time.time()-ta:.1f}s', flush=True)\n\n")

    // --- CDS (uses already-collected trajectories, no extra GPU) ---
    parts.push("if 'cds' not in SKIP:\n")
    parts.push("    print('[battery] axis 4/6 CDS ...', flush=True); ta = time.time()\n")
    parts.push("    def traj_metrics(traj):\n")
    parts.push("        if traj.shape[0] < 4: return {'velocity':0.0,'curvature':0.0,'attractor_stability':0.0}\n")
    parts.push("        v = np.diff(traj, axis=0); vmag = np.linalg.norm(v,axis=1)\n")
    parts.push("        velocity = float(vmag.mean())\n")
    parts.push("        angles = []\n")
    parts.push("        for t in range(1, v.shape[0]):\n")
    parts.push("            a,b = v[t-1], v[t]; na,nb = np.linalg.norm(a),np.linalg.norm(b)\n")
    parts.push("            if na<1e-9 or nb<1e-9: continue\n")
    parts.push("            cos = max(-1.0, min(1.0, float(np.dot(a,b)/(na*nb))))\n")
    parts.push("            angles.append(float(np.arccos(cos)))\n")
    parts.push("        curvature = float(np.mean(angles)) if angles else 0.0\n")
    parts.push("        T = traj.shape[0]; q = max(2, T//4)\n")
    parts.push("        vf = float(np.var(traj, axis=0).mean()); vl = float(np.var(traj[-q:], axis=0).mean())\n")
    parts.push("        stability = 0.0 if vf<1e-12 else max(0.0, 1.0 - vl/vf)\n")
    parts.push("        return {'velocity':round(velocity,4),'curvature':round(curvature,4),'attractor_stability':round(stability,4)}\n")
    parts.push("    sig = {fam:{'velocity':[],'curvature':[],'attractor_stability':[]} for fam in FAMILIES}\n")
    parts.push("    for traj in trajectories:\n")
    parts.push("        for fam in FAMILIES:\n")
    parts.push("            tp = traj @ family_axes[fam]\n")
    parts.push("            m = traj_metrics(tp)\n")
    parts.push("            for k in sig[fam]: sig[fam][k].append(m[k])\n")
    parts.push("    signature = {fam:{f'{k}_mean':round(float(np.mean(sig[fam][k])),4) for k in sig[fam]} for fam in FAMILIES}\n")
    parts.push("    max_stab = max(signature[fam]['attractor_stability_mean'] for fam in FAMILIES)\n")
    parts.push("    cds = {'schema':'anima/cds/1','backbone':BASE_MODEL,'n_probes':N,'families':FAMILIES,\n")
    parts.push("        'signature':signature,'max_stability':round(max_stab,4),\n")
    parts.push("        'gate_PASS':max_stab>=0.3,'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("    with open(os.path.join(OUTPUT_DIR,'cds.json'),'w') as f: json.dump(cds,f,indent=2)\n")
    parts.push("    results['cds'] = cds\n")
    parts.push("    print(f'[battery] CDS max_stab={max_stab:.4f} {time.time()-ta:.1f}s', flush=True)\n\n")

    // --- CMT (requires extra forward passes with hooks) ---
    parts.push("if 'cmt' not in SKIP:\n")
    parts.push("    print('[battery] axis 5/6 CMT ...', flush=True); ta = time.time()\n")
    parts.push("    layer_modules = None\n")
    parts.push("    for path in ['model.layers','transformer.h','gpt_neox.layers']:\n")
    parts.push("        try:\n")
    parts.push("            obj = mdl\n")
    parts.push("            for part in path.split('.'): obj = getattr(obj, part)\n")
    parts.push("            layer_modules = obj; break\n")
    parts.push("        except: continue\n")
    parts.push("    if layer_modules is None:\n")
    parts.push("        print('[battery] CMT skip: layers not found', flush=True)\n")
    parts.push("    else:\n")
    parts.push("        STRIDE = 4; scan = list(range(STRIDE, n_layers, STRIDE))  # skip layer 0 (input embedding ablation saturates all families)\n")
    parts.push("        tomo = {}\n")
    parts.push("        # CMT v3: hook on MLP sub-module (not full transformer block) to avoid cascading saturation.\n")
    parts.push("        # full-layer zero-ablation makes ALL families show rel-dY=1.0 (cascade wipes everything).\n")
    parts.push("        # MLP-only ablation perturbs the residual stream less → per-family differential signal preserved.\n")
    parts.push("        def get_mlp_module(layer_block):\n")
    parts.push("            for attr in ['mlp','feed_forward','ffn','dense','intermediate']:\n")
    parts.push("                if hasattr(layer_block, attr): return getattr(layer_block, attr)\n")
    parts.push("            return None\n")
    parts.push("        for layer_idx in scan:\n")
    parts.push("            layer = layer_modules[layer_idx]\n")
    parts.push("            target_module = get_mlp_module(layer) or layer  # fallback to full layer if no mlp found\n")
    parts.push("            target_kind = 'mlp' if target_module is not layer else 'block'\n")
    parts.push("            def zero_hook(module, inp, out):\n")
    parts.push("                if isinstance(out, tuple): return (torch.zeros_like(out[0]),) + out[1:]\n")
    parts.push("                return torch.zeros_like(out)\n")
    parts.push("            handle = target_module.register_forward_hook(zero_hook)\n")
    parts.push("            Y_abl = {fam: np.zeros(N, dtype=np.float32) for fam in FAMILIES}\n")
    parts.push("            try:\n")
    parts.push("                for i, p in enumerate(PROMPTS):\n")
    parts.push("                    out, inp = fwd_hidden(p)\n")
    parts.push("                    h = byte_weighted_mean(out.hidden_states[-1], inp['attention_mask'])\n")
    parts.push("                    proj = project_family(h)\n")
    parts.push("                    for fam in FAMILIES: Y_abl[fam][i] = proj[fam]\n")
    parts.push("            finally: handle.remove()\n")
    parts.push("            dY = {}\n")
    parts.push("            for fam in FAMILIES:\n")
    parts.push("                d = float(np.mean(np.abs(Y_full[fam] - Y_abl[fam])))\n")
    parts.push("                rel = d / (float(np.mean(np.abs(Y_full[fam]))) + 1e-9)\n")
    parts.push("                dY[fam] = {'abs':round(d,4),'rel':round(rel,4)}\n")
    parts.push("            dY['_ablation_target'] = target_kind\n")
    parts.push("            tomo[str(layer_idx)] = dY\n")
    parts.push("        dom = {fam:{'layer':int(max(tomo,key=lambda L:tomo[L][fam]['rel'])),\n")
    parts.push("                    'rel':tomo[max(tomo,key=lambda L:tomo[L][fam]['rel'])][fam]['rel']} for fam in FAMILIES}\n")
    parts.push("        gate = all(dom[f]['rel']>=0.05 for f in FAMILIES)\n")
    parts.push("        cmt = {'schema':'anima/cmt/1','backbone':BASE_MODEL,'n_probes':N,'n_layers':n_layers,\n")
    parts.push("            'layer_stride':STRIDE,'tomography':tomo,'dominant_layer_per_family':dom,\n")
    parts.push("            'gate_PASS':gate,'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("        with open(os.path.join(OUTPUT_DIR,'cmt.json'),'w') as f: json.dump(cmt,f,indent=2)\n")
    parts.push("        results['cmt'] = cmt\n")
    parts.push("        print(f'[battery] CMT gate={gate} {time.time()-ta:.1f}s', flush=True)\n\n")

    // --- SAE-STEER bypass ---
    parts.push("if 'sae' not in SKIP:\n")
    parts.push("    print('[battery] axis 6/6 SAE-bp ...', flush=True); ta = time.time()\n")
    parts.push("    rng = np.random.default_rng(RNG_SEED); N_FEAT = 4096\n")
    parts.push("    nz = max(1, int(h_dim * 0.05))\n")
    parts.push("    W = np.zeros((h_dim, N_FEAT), dtype=np.float32)\n")
    parts.push("    for j in range(N_FEAT):\n")
    parts.push("        rows = rng.choice(h_dim, size=nz, replace=False)\n")
    parts.push("        W[rows, j] = rng.standard_normal(nz).astype(np.float32)\n")
    parts.push("        nrm = np.linalg.norm(W[:,j])\n")
    parts.push("        if nrm > 1e-9: W[:,j] /= nrm\n")
    parts.push("    fa = np.maximum(0.0, X @ W)\n")
    parts.push("    fa_z = (fa - fa.mean(axis=0, keepdims=True)) / (fa.std(axis=0)+1e-9)\n")
    parts.push("    TOPK = 32\n")
    parts.push("    top_per = {}\n")
    parts.push("    for fam in FAMILIES:\n")
    parts.push("        y = Y_full[fam] - Y_full[fam].mean(); y = y / (y.std()+1e-9)\n")
    parts.push("        corr = (fa_z.T @ y) / N\n")
    parts.push("        top_per[fam] = np.argsort(-np.abs(corr))[:TOPK]\n")
    parts.push("    layer_modules = None\n")
    parts.push("    for path in ['model.layers','transformer.h','gpt_neox.layers']:\n")
    parts.push("        try:\n")
    parts.push("            obj = mdl\n")
    parts.push("            for part in path.split('.'): obj = getattr(obj, part)\n")
    parts.push("            layer_modules = obj; break\n")
    parts.push("        except: continue\n")
    parts.push("    steer_shifts = {}\n")
    parts.push("    if layer_modules is not None:\n")
    parts.push("        last_layer = layer_modules[-1]\n")
    parts.push("        for fam in FAMILIES:\n")
    parts.push("            sv = W[:, top_per[fam]].sum(axis=1).astype(np.float32)\n")
    parts.push("            n = np.linalg.norm(sv)\n")
    parts.push("            if n > 1e-9: sv = sv / n\n")
    parts.push("            sv_t = torch.tensor(sv, dtype=torch.bfloat16, device=mdl.device)\n")
    parts.push("            def steer_hook(module, inp, out, vec=sv_t):\n")
    parts.push("                if isinstance(out, tuple): h_out = out[0]\n")
    parts.push("                else: h_out = out\n")
    parts.push("                h_new = h_out + vec.view(1,1,-1)\n")
    parts.push("                if isinstance(out, tuple): return (h_new,)+out[1:]\n")
    parts.push("                return h_new\n")
    parts.push("            handle = last_layer.register_forward_hook(steer_hook)\n")
    parts.push("            Y_steer = {f: np.zeros(N, dtype=np.float32) for f in FAMILIES}\n")
    parts.push("            try:\n")
    parts.push("                for i, p in enumerate(PROMPTS):\n")
    parts.push("                    out, inp = fwd_hidden(p)\n")
    parts.push("                    h = byte_weighted_mean(out.hidden_states[-1], inp['attention_mask'])\n")
    parts.push("                    proj = project_family(h)\n")
    parts.push("                    for f in FAMILIES: Y_steer[f][i] = proj[f]\n")
    parts.push("            finally: handle.remove()\n")
    parts.push("            shifts = {}\n")
    parts.push("            for f in FAMILIES:\n")
    parts.push("                d = float(np.mean(Y_steer[f] - Y_full[f]))\n")
    parts.push("                rel = d / (float(np.mean(np.abs(Y_full[f]))) + 1e-9)\n")
    parts.push("                shifts[f] = {'abs':round(d,4),'rel':round(rel,4)}\n")
    parts.push("            target_rel = shifts[fam]['rel']\n")
    parts.push("            others = [shifts[f]['rel'] for f in FAMILIES if f != fam]\n")
    parts.push("            sel = target_rel - float(np.mean(others))\n")
    parts.push("            steer_shifts[fam] = {'shifts':shifts,'target_rel':target_rel,\n")
    parts.push("                'others_mean_rel':round(float(np.mean(others)),4),'selectivity':round(sel,4)}\n")
    parts.push("    n_sel = sum(1 for f in FAMILIES if steer_shifts.get(f,{}).get('selectivity',0)>0)\n")
    parts.push("    sae = {'schema':'anima/sae_steer_bypass/1','backbone':BASE_MODEL,'n_probes':N,\n")
    parts.push("        'n_features':N_FEAT,'topk':TOPK,'families':FAMILIES,\n")
    parts.push("        'steering_shifts':steer_shifts,'n_selective':n_sel,'gate_PASS':n_sel>=2,\n")
    parts.push("        'elapsed_sec':round(time.time()-ta,1)}\n")
    parts.push("    with open(os.path.join(OUTPUT_DIR,'sae_steer_bypass.json'),'w') as f: json.dump(sae,f,indent=2)\n")
    parts.push("    results['sae_steer_bypass'] = sae\n")
    parts.push("    print(f'[battery] SAE-bp n_sel={n_sel} {time.time()-ta:.1f}s', flush=True)\n\n")

    parts.push("# Final: emit v11_signature.json (5-axis composite, AN11_b not measured by battery)\n")
    parts.push("def norm(v, kind):\n")
    parts.push("    if v is None: return 0.0\n")
    parts.push("    if kind=='clamp': return max(0.0, min(1.0, v))\n")
    parts.push("    if kind=='invert': return max(0.0, 1.0 - min(v,1.0))\n")
    parts.push("    if kind=='tanh': return (math.tanh(v)+1.0)/2.0\n")
    parts.push("    return 0.0\n")
    parts.push("axis_norms = []\n")
    parts.push("if 'btom' in results: axis_norms.append(('btom', norm(results['btom']['accuracy'],'clamp')))\n")
    parts.push("if 'mcca' in results: axis_norms.append(('mcca', norm(results['mcca']['brier_mean'],'invert')))\n")
    parts.push("if 'phi_star' in results:\n")
    parts.push("    # Φ* v3: use absolute magnitude (negative = anti-integration is also a real signal)\n")
    parts.push("    psm = results['phi_star']['phi_star_min']\n")
    parts.push("    axis_norms.append(('phi_star', norm(abs(psm) if psm is not None else 0.0,'tanh')))\n")
    parts.push("if 'cmt' in results:\n")
    parts.push("    rels = [v['rel'] for v in results['cmt']['dominant_layer_per_family'].values()]\n")
    parts.push("    axis_norms.append(('cmt', norm(sum(rels)/len(rels),'clamp')))\n")
    parts.push("if 'cds' in results: axis_norms.append(('cds', norm(results['cds']['max_stability'],'clamp')))\n")
    parts.push("if axis_norms:\n")
    parts.push("    eps = 1e-6\n")
    parts.push("    gmean = math.exp(sum(math.log(max(eps,n[1])) for n in axis_norms)/len(axis_norms))\n")
    parts.push("    weakest = min(axis_norms, key=lambda x: x[1])\n")
    parts.push("else:\n")
    parts.push("    gmean = 0.0; weakest = (None, 0.0)\n")
    parts.push("sig = {'schema':'anima/v11_signature/1','backbone':BASE_MODEL,\n")
    parts.push("    'n_axes_present':len(axis_norms),'axes_norm':[{'axis':a[0],'norm':round(a[1],4)} for a in axis_norms],\n")
    parts.push("    'composite_geometric_mean':round(gmean,4),\n")
    parts.push("    'weakest_axis':weakest[0],'weakest_norm':round(weakest[1],4),\n")
    parts.push("    'total_elapsed_sec':round(time.time()-t_load,1)}\n")
    parts.push("with open(os.path.join(OUTPUT_DIR,'v11_signature.json'),'w') as f: json.dump(sig,f,indent=2)\n")
    parts.push("print(f'[battery] DONE composite={gmean:.4f} weakest={weakest[0]}({weakest[1]:.3f}) total={time.time()-t_load:.1f}s', flush=True)\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn cmd_selftest() {
    println("── anima_v11_battery selftest ──")
    _write_helper()
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=v11 ORCHESTRATION-LAYER (single-load 6-axis battery, ~50% wallclock savings)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}

main()
