// tool/drill_ext_resolve.hexa — raw#14 .ext SSOT resolver helper
//
// Purpose: drill canonical refs (criteria, seed_set) 을 .ext SSOT 에서 resolve.
//          raw#0 SSOT / raw#14 .ext-decl / raw#15 no-hardcode 엄수.
//
// Usage:
//   hexa tool/drill_ext_resolve.hexa <ref_name>
//
//   ref_name ∈ { drill_breakthrough_criteria, drill_seed_set }
//
// Behavior:
//   - shared/config/drill_ext_resolver.json 로드 (raw#15 — path 를 code 에 박지 않고 config 경유)
//   - canonical_path 에서 ~ → $HOME 확장
//   - 파일 존재 검증 (raw#14 proof)
//   - stdout 에 absolute path 출력
//
// Exit codes:
//   0 = OK (path printed)
//   1 = unknown ref
//   2 = resolver config missing/invalid
//   3 = canonical file missing on disk
//
// raw#9 hexa-only. stage0-portable (no dict literals, manual JSON parse).

let RESOLVER_CONFIG = "shared/config/drill_ext_resolver.json"

// ─── string helpers (stage0 portable) ───

fn str_index_of(hay, needle, from) {
    let hn = len(hay)
    let nn = len(needle)
    if nn == 0 { return from }
    let mut i = from
    while i + nn <= hn {
        if hay.substring(i, i + nn) == needle { return i }
        i = i + 1
    }
    return -1
}

fn str_contains(s, sub) { return str_index_of(s, sub, 0) >= 0 }

// Extract the first JSON string value following a "<key>" occurrence whose
// enclosing "<object_key>" block also appears. We just search forward from
// the object key for the target key, skipping nested braces.
fn extract_nested_string(text, outer_key, inner_key) {
    let onee = "\"" + outer_key + "\""
    let opos = str_index_of(text, onee, 0)
    if opos < 0 { return "" }
    let ine = "\"" + inner_key + "\""
    let ipos = str_index_of(text, ine, opos)
    if ipos < 0 { return "" }
    let after = ipos + len(ine)
    let colon = str_index_of(text, ":", after)
    if colon < 0 { return "" }
    let q_open = str_index_of(text, "\"", colon)
    if q_open < 0 { return "" }
    let q_close = str_index_of(text, "\"", q_open + 1)
    if q_close < 0 { return "" }
    return text.substring(q_open + 1, q_close)
}

// ~ → $HOME expansion (stage0 has env()).
fn expand_home(path) {
    if len(path) == 0 { return path }
    if path.substring(0, 1) == "~" {
        let home = env("HOME")
        if len(path) == 1 { return home }
        if path.substring(1, 2) == "/" {
            return home + path.substring(1, len(path))
        }
        return home + "/" + path.substring(1, len(path))
    }
    return path
}

fn resolve_ref(ref_name) {
    if !file_exists(RESOLVER_CONFIG) {
        println("ERROR: resolver config missing: " + RESOLVER_CONFIG)
        exit(2)
    }
    let body = read_file(RESOLVER_CONFIG)
    if len(body) == 0 {
        println("ERROR: resolver config empty: " + RESOLVER_CONFIG)
        exit(2)
    }
    let raw_path = extract_nested_string(body, ref_name, "canonical_path")
    if len(raw_path) == 0 {
        println("ERROR: unknown ref or missing canonical_path: " + ref_name)
        exit(1)
    }
    let abs_path = expand_home(raw_path)
    if !file_exists(abs_path) {
        println("ERROR: canonical file missing on disk: " + abs_path)
        exit(3)
    }
    return abs_path
}

fn main() {
    let argv = args()
    if argv.len() < 3 {
        println("usage: hexa tool/drill_ext_resolve.hexa <ref_name>")
        println("  ref_name ∈ { drill_breakthrough_criteria, drill_seed_set }")
        exit(1)
    }
    let ref_name = argv[2]
    let p = resolve_ref(ref_name)
    println(p)
    exit(0)
}
