// tool/anima_mk_xii_3a_llama_familyinternal_dispatch.hexa — Mk.XII Phase 3a Llama family-internal scale pre-register (raw#9 hexa-only).
//
// PURPOSE
//   cycle 4 (gemma family-internal) 패턴 mirror — Llama family within-family scale curve.
//   Phase 3a 5-family panel에서 llama_family는 BLOCKED_HF (handoff §3.10 dancinlife pending).
//   HF gate 해제 후 즉시 실행 가능한 frozen pre-register.
//
//   Llama family 3-point scale curve (3.2-3B / 3.1-8B / 3.1-70B):
//     - smallest reachable native instruct pair (Llama-3.2-3B-Instruct는 별도 gate, base만 사용)
//     - mid: Llama-3.1-8B (axis 96 cycle 3 stride=1 baseline 공유)
//     - high: Llama-3.1-70B (cycle 9 70B prep 핵심 후보)
//
//   본 helper = mac-local pre-register + dispatch ledger:
//     - Llama family 3-point scale curve
//     - HMK-A_LLAMA / HMK-B_LLAMA / HQS-E_LLAMA_INSTRUCT_FORK frozen hypotheses
//     - HF gate triple-blocker explicit (3개 모두 dancinlife approval 필요)
//     - cross-link cycle 3 (Llama stride=1) + cycle 9 (70B prep)
//     - selftest verifies: 3 bb / 3 hypotheses / triple HF gate / total budget ≤ $3.20
//
// INPUT
//   ANIMA_OUTPUT          output JSON (default: state/mk_xii_3a_llama_familyinternal_pre_register.json)
//   ANIMA_HF_GATES_OK     "true"|"false" (default "false")
//
// OUTPUT
//   - bb_registry: 3-point Llama scale curve (3B / 8B / 70B)
//   - frozen_hypotheses: HMK-A_LLAMA / HMK-B_LLAMA / HQS-E_LLAMA_INSTRUCT_FORK
//   - dispatch_order: 3B → 8B → 70B (cheapest first); all gated last regardless
//   - hf_gate_status (3 sub-gates)
//   - cumulative_evidence_paths: how this changes Phase 3a clean count + Phase 3b 70B justification
//
// USAGE
//   hexa run tool/anima_mk_xii_3a_llama_familyinternal_dispatch.hexa --selftest
//   ANIMA_OUTPUT=state/mk_xii_3a_llama_familyinternal_pre_register.json hexa run tool/anima_mk_xii_3a_llama_familyinternal_dispatch.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - Llama-3.1-8B + 3.1-70B + 3.2-3B 모두 HF gate (dancinlife). triple-gate dependency.
//   - 70B는 cycle 9 70B prep와 중복 후보 — 본 helper에서 family-internal scale 목적으로 재사용.
//   - 3.2-3B는 Pilot-T1 v2와도 dependency 공유 (cycle 6 launch gate matrix 참조).

let HELPER_PATH = "/tmp/anima_mk_xii_3a_llama_familyinternal_dispatch_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima Mk.XII Phase 3a Llama family-internal dispatch helper — emitted by tool/anima_mk_xii_3a_llama_familyinternal_dispatch.hexa\n")
    parts.push("# raw#37 transient. Phase 3a 5-family panel BLOCKED_HF llama unblock 후 즉시 실행 가능한 pre-register.\n")
    parts.push("import json, os, sys\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/mk_xii_3a_llama_familyinternal_pre_register.json')\n")
    parts.push("HF_GATES_OK = os.environ.get('ANIMA_HF_GATES_OK', 'false').lower() == 'true'\n\n")

    parts.push("BB_REGISTRY = [\n")
    parts.push("    {\n")
    parts.push("        'model_id':'meta-llama/Llama-3.2-3B', 'params_b':3.21, 'role':'CROSS_ANCHOR_LOW',\n")
    parts.push("        'cost_usd_est':0.12, 'hf_gated':True, 'gate_resource':'meta-llama/Llama-3.2-3B license accept',\n")
    parts.push("        'measurement_status':'NOT_PREVIOUSLY_MEASURED (Pilot-T1 v2 + Mk.XII Llama 모두 dependency)',\n")
    parts.push("        'cross_link':'cycle 6 Pilot-T2 launch gate matrix bb#4',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'model_id':'meta-llama/Meta-Llama-3.1-8B', 'params_b':8.03, 'role':'PARTIAL_BASELINE',\n")
    parts.push("        'cost_usd_est':0.18, 'hf_gated':True, 'gate_resource':'meta-llama/Meta-Llama-3.1-8B license accept',\n")
    parts.push("        'measurement_status':'NOT_PREVIOUSLY_MEASURED in family-internal context (cycle 3 axis 96 stride=1 dispatch도 동일 gate)',\n")
    parts.push("        'cross_link':'cycle 3 axis 96 Llama stride=1 dispatch + cycle 5 axis 96 6th-bb arch separator',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'model_id':'meta-llama/Llama-3.1-70B', 'params_b':70.55, 'role':'DECISIVE_HIGH',\n")
    parts.push("        'cost_usd_est':2.40, 'hf_gated':True, 'gate_resource':'meta-llama/Llama-3.1-70B license accept',\n")
    parts.push("        'measurement_status':'NOT_PREVIOUSLY_MEASURED (Phase 3b 70B 진입 후보; cycle 9 prep와 중복)',\n")
    parts.push("        'cross_link':'cycle 9 Mk.XII 70B prep dispatch bb#2',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("FROZEN_HYPOTHESES = [\n")
    parts.push("    {\n")
    parts.push("        'id':'HMK-A_LLAMA', 'name':'SCALE_INVARIANT_LLAMA',\n")
    parts.push("        'statement':'Llama family within-family scale (3B/8B/70B) yields invariant CMT signature',\n")
    parts.push("        'decision_threshold':'CONFIRMED if all 3 bb pairwise BBA |r| > 0.7 across (3B,8B),(8B,70B),(3B,70B)',\n")
    parts.push("        'consequence_if_confirmed':'Phase 3a clean 2/5 → 3/5 (Mistral+Qwen2.5+Llama); Phase 3b 70B justification ENTER_3B_READY',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'HMK-B_LLAMA', 'name':'SCALE_BREAK_LLAMA',\n")
    parts.push("        'statement':'Llama family BREAK at scale boundary (Qwen3-pattern recurrence)',\n")
    parts.push("        'decision_threshold':'CONFIRMED if any pairwise BBA |r| < 0.3',\n")
    parts.push("        'consequence_if_confirmed':'Phase 3a break 1/5 → 2/5 (Qwen3+Llama); HQS-C MIXED elevated to STRONG; 70B justification REQUIRES Mk.XIII redesign',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'HQS-E_LLAMA_INSTRUCT_FORK', 'name':'INSTRUCT_FORK_AT_SCALE',\n")
    parts.push("        'statement':'Llama base/instruct pair-divergence depends on scale (3B/8B/70B 각각 다른 instruct fork pattern)',\n")
    parts.push("        'decision_threshold':'CONFIRMED if instruct/base BBA |r| variance across 3 scales > 0.3 (i.e. fork pattern scale-dependent)',\n")
    parts.push("        'consequence_if_confirmed':'R46 BIMODAL hypothesis 4-family extension: Llama가 4번째 family로 PRIMARY/MODIFIER 양쪽 모두 표현 가능 — Mistral+Llama MODIFIER 가설 부분 falsified',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("def _dispatch_order(bbs):\n")
    parts.push("    # all gated; cheapest first within gated batch\n")
    parts.push("    return sorted(bbs, key=lambda b: b['cost_usd_est'])\n\n")

    parts.push("order = _dispatch_order(BB_REGISTRY)\n")
    parts.push("total_budget = round(sum(b['cost_usd_est'] for b in BB_REGISTRY), 2)\n")
    parts.push("n_gated = sum(1 for b in BB_REGISTRY if b['hf_gated'])\n")
    parts.push("dispatch_readiness = 'READY' if HF_GATES_OK else 'BLOCKED_HF_GATES_TRIPLE'\n\n")

    parts.push("HF_GATE_STATUS = [\n")
    parts.push("    {'gate_resource':'meta-llama/Llama-3.2-3B', 'status':'OK' if HF_GATES_OK else 'PENDING_DANCINLIFE'},\n")
    parts.push("    {'gate_resource':'meta-llama/Meta-Llama-3.1-8B', 'status':'OK' if HF_GATES_OK else 'PENDING_DANCINLIFE'},\n")
    parts.push("    {'gate_resource':'meta-llama/Llama-3.1-70B', 'status':'OK' if HF_GATES_OK else 'PENDING_DANCINLIFE'},\n")
    parts.push("]\n\n")

    parts.push("cumulative_evidence_paths = {\n")
    parts.push("    'HMK-A_LLAMA_CONFIRMED':{'phase_3a_clean_count':'2/5 → 3/5', 'phase_3b_readiness':'ENTER_3B_READY (≥2 CLEAN family threshold + Llama 3-point baseline)'},\n")
    parts.push("    'HMK-B_LLAMA_CONFIRMED':{'phase_3a_break_count':'1/5 → 2/5', 'phase_3b_readiness':'BLOCKED + Mk.XIII redesign required'},\n")
    parts.push("    'HQS-E_CONFIRMED':{'r46_hypothesis':'4-family BIMODAL → 5-family TRIMODAL with Llama spanning'},\n")
    parts.push("}\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'Mk.XII Phase 3a Llama family-internal scale (3B/8B/70B) pre-register',\n")
    parts.push("    'parent_handoff_actionable':'§3.7 + §3.9 Llama-3.2-3B HF gate unblock + Mk.XII Llama family',\n")
    parts.push("    'parent_helpers':[\n")
    parts.push("        'tool/anima_mk_xii_3a_gemma_familyinternal_dispatch.hexa (cycle 4 gemma mirror)',\n")
    parts.push("        'tool/anima_axis96_llama_stride1_dispatch.hexa (cycle 3 same HF gate)',\n")
    parts.push("        'tool/anima_pilot_t2_launch_gate_dispatch.hexa (cycle 6 bb#4 overlap)',\n")
    parts.push("        'tool/anima_mk_xii_3b_70b_prep_dispatch.hexa (cycle 9 70B prep overlap)',\n")
    parts.push("    ],\n")
    parts.push("    'bb_registry':BB_REGISTRY,\n")
    parts.push("    'frozen_hypotheses':FROZEN_HYPOTHESES,\n")
    parts.push("    'dispatch_order':[b['model_id'] for b in order],\n")
    parts.push("    'dispatch_order_with_cost':[{'model_id':b['model_id'],'cost_usd_est':b['cost_usd_est']} for b in order],\n")
    parts.push("    'total_budget_est_usd':total_budget,\n")
    parts.push("    'n_hf_gated':n_gated,\n")
    parts.push("    'hf_gate_status':HF_GATE_STATUS,\n")
    parts.push("    'dispatch_readiness':dispatch_readiness,\n")
    parts.push("    'cumulative_evidence_paths':cumulative_evidence_paths,\n")
    parts.push("    'pre_register_status':'FROZEN_PRE_MEASUREMENT (raw#10 honest re-pre-register on threshold change)',\n")
    parts.push("    'h100_stop_gate_invariant':'GPU pod creation requires user explicit approval (memory feedback_h100_gate.md)',\n")
    parts.push("    'n_bb':len(BB_REGISTRY),\n")
    parts.push("    'n_hypotheses':len(FROZEN_HYPOTHESES),\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[mk_xii_3a_llama] n_bb={len(BB_REGISTRY)} budget=${total_budget} gated={n_gated}/3 readiness={dispatch_readiness} dispatch_first={order[0][\"model_id\"]} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let bb_count_expected = 3
    let hypotheses_count_expected = 3
    let total_budget_max_usd = 3.20
    let scale_points_expected = "3B/8B/70B"
    let triple_hf_gate_expected = 3
    println("inv:bb_count_expected=" + to_string(bb_count_expected))
    println("inv:hypotheses_count_expected=" + to_string(hypotheses_count_expected))
    println("inv:total_budget_max_usd=" + to_string(total_budget_max_usd))
    println("inv:scale_points_expected=" + scale_points_expected)
    println("inv:triple_hf_gate_expected=" + to_string(triple_hf_gate_expected))
    println("inv:hypotheses_ids=HMK-A_LLAMA,HMK-B_LLAMA,HQS-E_LLAMA_INSTRUCT_FORK")
    println("inv:dancinlife_3_resources_required=true")
    println("inv:cross_link_cycle3_cycle4_cycle6_cycle9=true")
    println("inv:every_bb_marked_hf_gated=true")
    println("inv:dispatch_order_cheapest_first=true")
    return true
}

fn cmd_selftest() {
    println("── anima_mk_xii_3a_llama_familyinternal_dispatch selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=Mk.XII Phase 3a Llama family-internal scale (3B/8B/70B; triple HF gate; budget $2.70)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
