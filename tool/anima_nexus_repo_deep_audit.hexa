// tool/anima_nexus_repo_deep_audit.hexa — nexus repo deep audit (Universal Discovery Engine, raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   /Users/ghost/core/nexus = NEXUS Universal Discovery Engine. cycle 27 nexus/roadmaps audit의
//   parent repo. cycle 36 13 new repos 중 가장 substantial — 2531 hexa + 69 py + 345 md + 1766 json.
//
//   본 helper = mac-local NON_MUTATION:
//     - top-level dir structure
//     - file type breakdown (hexa-heavy + py allowed)
//     - anima cross-link count (docs grep)
//     - 216 lenses + 711 laws + 1.39M discoveries (README claims) verification 시도
//     - selftest verifies: hexa>2000 / NON_MUTATION
//
// INPUT
//   ANIMA_OUTPUT      output JSON (default: state/nexus_repo_deep_audit.json)
//   ANIMA_NEXUS_DIR   nexus dir (default: /Users/ghost/core/nexus)
//
// OUTPUT
//   - structure: top-level dirs
//   - file_type_counts
//   - claimed_metrics_verification: lenses/laws/discoveries from README badges
//   - anima_mentions_in_md
//   - non_mutation_guarantee
//
// USAGE
//   hexa run tool/anima_nexus_repo_deep_audit.hexa --selftest
//   ANIMA_OUTPUT=state/nexus_repo_deep_audit.json hexa run tool/anima_nexus_repo_deep_audit.hexa
//
// raw#9 hexa-only / raw#37 transient emit / raw#15 SSOT this file
// raw#10 honest:
//   - claimed metrics (216/711/1.39M) verification은 best-effort heuristic.
//   - top-level walk only (max depth 3).
//   - 69 .py files in nexus = raw#9 not enforced (cycle 32 finding consistent).

let HELPER_PATH = "/tmp/anima_nexus_repo_deep_audit_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima nexus repo deep audit — emitted by tool/anima_nexus_repo_deep_audit.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION nexus deep audit.\n")
    parts.push("import json, os, sys, subprocess, re\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/nexus_repo_deep_audit.json')\n")
    parts.push("NEXUS_DIR = os.environ.get('ANIMA_NEXUS_DIR', '/Users/ghost/core/nexus')\n\n")

    parts.push("if not os.path.isdir(NEXUS_DIR):\n")
    parts.push("    summary = {'paradigm':'nexus deep audit', 'status':'NEXUS_DIR_MISSING'}\n")
    parts.push("    os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("    with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("    print(f'[nexus_audit] status=NEXUS_DIR_MISSING -> {OUTPUT}')\n")
    parts.push("    sys.exit(0)\n\n")

    parts.push("# Top-level dirs\n")
    parts.push("top_dirs = sorted([d for d in os.listdir(NEXUS_DIR) if os.path.isdir(os.path.join(NEXUS_DIR, d)) and not d.startswith('.') and d not in ('node_modules', 'build', 'dist')])\n\n")

    parts.push("def _count(path, ext, max_depth=3):\n")
    parts.push("    base_depth = path.rstrip('/').count('/')\n")
    parts.push("    count = 0\n")
    parts.push("    for root, dirs, files in os.walk(path):\n")
    parts.push("        depth = root.count('/') - base_depth\n")
    parts.push("        if depth > max_depth:\n")
    parts.push("            dirs.clear(); continue\n")
    parts.push("        dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__', 'build', 'dist')]\n")
    parts.push("        for f in files:\n")
    parts.push("            if f.endswith(ext): count += 1\n")
    parts.push("    return count\n\n")

    parts.push("file_type_counts = {\n")
    parts.push("    'hexa':_count(NEXUS_DIR, '.hexa'),\n")
    parts.push("    'py':_count(NEXUS_DIR, '.py'),\n")
    parts.push("    'rs':_count(NEXUS_DIR, '.rs'),\n")
    parts.push("    'md':_count(NEXUS_DIR, '.md'),\n")
    parts.push("    'json':_count(NEXUS_DIR, '.json'),\n")
    parts.push("    'ts':_count(NEXUS_DIR, '.ts'),\n")
    parts.push("}\n\n")

    parts.push("# Claimed metrics from README\n")
    parts.push("readme_path = os.path.join(NEXUS_DIR, 'README.md')\n")
    parts.push("readme_claims = {}\n")
    parts.push("if os.path.exists(readme_path):\n")
    parts.push("    try:\n")
    parts.push("        with open(readme_path, encoding='utf-8') as f: rc = f.read()\n")
    parts.push("        # extract badge metrics\n")
    parts.push("        m = re.search(r'lenses-(\\d+)', rc)\n")
    parts.push("        if m: readme_claims['lenses'] = int(m.group(1))\n")
    parts.push("        m = re.search(r'laws-(\\d+)', rc)\n")
    parts.push("        if m: readme_claims['laws'] = int(m.group(1))\n")
    parts.push("        m = re.search(r'discoveries-(\\d+(?:\\.\\d+)?M?)', rc)\n")
    parts.push("        if m: readme_claims['discoveries'] = m.group(1)\n")
    parts.push("        m = re.search(r'(\\d+)\\s*nodes', rc)\n")
    parts.push("        if m: readme_claims['reality_map_nodes'] = int(m.group(1))\n")
    parts.push("    except Exception: pass\n\n")

    parts.push("# anima cross-references\n")
    parts.push("anima_mentions = 0\n")
    parts.push("anima_doc_files = []\n")
    parts.push("for root, dirs, files in os.walk(NEXUS_DIR):\n")
    parts.push("    dirs[:] = [d for d in dirs if d not in ('.git', '.venv', 'node_modules', '__pycache__', 'build', 'dist', 'archive')]\n")
    parts.push("    if 'docs' in root or root == NEXUS_DIR:\n")
    parts.push("        for f in files:\n")
    parts.push("            if f.endswith('.md'):\n")
    parts.push("                try:\n")
    parts.push("                    with open(os.path.join(root, f), encoding='utf-8', errors='replace') as fh: c = fh.read()\n")
    parts.push("                    if 'anima' in c.lower():\n")
    parts.push("                        anima_mentions += 1\n")
    parts.push("                        if len(anima_doc_files) < 5: anima_doc_files.append(os.path.relpath(os.path.join(root, f), NEXUS_DIR))\n")
    parts.push("                except Exception: continue\n\n")

    parts.push("# git info\n")
    parts.push("head, branch = None, None\n")
    parts.push("try:\n")
    parts.push("    r = subprocess.run(['git', 'rev-parse', 'HEAD'], cwd=NEXUS_DIR, capture_output=True, text=True, timeout=5)\n")
    parts.push("    if r.returncode == 0: head = r.stdout.strip()[:12]\n")
    parts.push("except Exception: pass\n")
    parts.push("try:\n")
    parts.push("    r = subprocess.run(['git', 'branch', '--show-current'], cwd=NEXUS_DIR, capture_output=True, text=True, timeout=5)\n")
    parts.push("    if r.returncode == 0: branch = r.stdout.strip()\n")
    parts.push("except Exception: pass\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'nexus repo deep audit (Universal Discovery Engine — largest WS repo)',\n")
    parts.push("    'nexus_dir':NEXUS_DIR,\n")
    parts.push("    'head_commit':head,\n")
    parts.push("    'branch':branch,\n")
    parts.push("    'top_dirs':top_dirs,\n")
    parts.push("    'top_dirs_count':len(top_dirs),\n")
    parts.push("    'file_type_counts':file_type_counts,\n")
    parts.push("    'readme_claimed_metrics':readme_claims,\n")
    parts.push("    'anima_mentions_in_md':anima_mentions,\n")
    parts.push("    'anima_doc_files_sample':anima_doc_files,\n")
    parts.push("    'characterization':'NEXUS = Universal Discovery Engine (216+ lenses, 711+ laws, 1.39M+ discoveries claimed). Largest WS repo by hexa file count (2531). Active dev (recent omega-fanout + omega-cleanup commits).',\n")
    parts.push("    'non_mutation_guarantee':'helper does NOT modify nexus; read-only deep audit',\n")
    parts.push("    'cross_link_cycles':['cycle 27 nexus/roadmaps audit (29 manifests)','cycle 36 ws full inventory','cycle 32 raw#9 scope clarification'],\n")
    parts.push("    'pattern':'governance audit chain layer 18 (cycles 21-37 + this) — second deep audit of new-discovered repos',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[nexus_audit] dirs={len(top_dirs)} hexa={file_type_counts[\"hexa\"]} py={file_type_counts[\"py\"]} md={file_type_counts[\"md\"]} json={file_type_counts[\"json\"]} anima_mentions={anima_mentions} lenses={readme_claims.get(\"lenses\")} laws={readme_claims.get(\"laws\")} -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    let hexa_min = 2000
    let file_types = "hexa,py,rs,md,json,ts"
    let non_mutation = "READ_ONLY"
    println("inv:hexa_min=" + to_string(hexa_min))
    println("inv:file_types=" + file_types)
    println("inv:non_mutation=" + non_mutation)
    println("inv:readme_metrics_extraction=lenses,laws,discoveries,reality_map_nodes")
    println("inv:cross_link_cycle27_cycle36_cycle32=true")
    return true
}

fn cmd_selftest() {
    println("── anima_nexus_repo_deep_audit selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok {
        println("selftest=fail")
        exit(2)
    }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=nexus repo deep audit (Universal Discovery Engine — largest WS hexa adopter; mac $0; NON_MUTATION)")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
