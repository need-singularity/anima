#compdef anima
# anima CLI zsh completion — matches bin/anima + tool/anima_cli/*.hexa
# install: put file in $fpath (e.g., ~/.zsh/completions/) + `compinit`

_anima_topics=(
  'compute:pod lifecycle (status|start|stop|watch|cost|recover|ingest|preflight)'
  'weight:weight precache (status|apply|strategy)'
  'proposal:proposal stack (review|approve|reject|implement|archive|dashboard|cluster|cycle)'
  'cert:breakthrough cert (verify|graph|dag)'
  'roadmap:roadmap engine (status|entries|blockers|roi)'
  'serve:serving layer (persona|api)'
  'paradigm:unified paradigm status'
  'inbox:proposal inbox (list|next|ack|done|drain)'
  'cost:session cost (status|session|per-pod|history|export)'
  'status:global dashboard (alias)'
)

_anima_compute_sub=(status start stop watch cost recover ingest preflight)
_anima_weight_sub=(status apply strategy)
_anima_proposal_sub=(review approve reject implement archive dashboard cluster cycle)
_anima_cert_sub=(verify graph dag)
_anima_roadmap_sub=(status entries blockers roi)
_anima_serve_sub=(persona api)
_anima_inbox_sub=(list next ack done drain)
_anima_cost_sub=(status session per-pod history export)

_anima() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '1: :->topic' \
    '2: :->subcmd' \
    '*::arg:->arg' \
    '(--help)--help[show help]' \
    '(--version)--version[show version]'

  case $state in
    topic)
      _describe -t topics 'anima topic' _anima_topics ;;
    subcmd)
      case $line[1] in
        compute) _describe 'subcmd' _anima_compute_sub ;;
        weight) _describe 'subcmd' _anima_weight_sub ;;
        proposal) _describe 'subcmd' _anima_proposal_sub ;;
        cert) _describe 'subcmd' _anima_cert_sub ;;
        roadmap) _describe 'subcmd' _anima_roadmap_sub ;;
        serve) _describe 'subcmd' _anima_serve_sub ;;
        inbox) _describe 'subcmd' _anima_inbox_sub ;;
        cost) _describe 'subcmd' _anima_cost_sub ;;
      esac ;;
  esac
}

_anima "$@"
