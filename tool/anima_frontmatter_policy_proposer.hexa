// tool/anima_frontmatter_policy_proposer.hexa — cycle 80 docs/ frontmatter compliance policy proposer (raw#9 hexa-only, NON_MUTATION).
//
// PURPOSE
//   cycle 24 docs_dir_md_integrity_auditor 발견 "frontmatter 0% compliance".
//   cycle 80 직접 검증 + 4 policy options 제시.
//
// CYCLE 24 RECHECK (2026-04-27)
//   docs total md count   : cycle 24 reported 410, cycle 80 actual 1012 (root-level
//                            only vs recursive 차이 추정)
//   frontmatter compliance : cycle 24 reported 0%, cycle 80 actual 12/1012 = 1.2%
//                            (TOC.md / preprint / cmt 등 일부 docs는 first line이
//                            #heading 형식; 12개 docs만 --- frontmatter)
//
//   cycle 24 finding 정밀화: 0% → 1.2% (false zero, but compliance 거의 nil 정직).
//
// 4 POLICY OPTIONS
//
//   OPT_A_BLANKET           : 1012 md 모두 frontmatter 자동 추가
//                             cost: very-high (helper automation 필요)
//                             template: name/description/type/originSessionId
//                             risk: 기존 첫 라인 # heading 위에 frontmatter 삽입
//                                    렌더링 깨짐 가능성; manual review 필수
//
//   OPT_B_NEW_ONLY          : 신규 md만 frontmatter enforce
//                             cost: low (CI lint hook 또는 git pre-commit)
//                             기존 1000 md는 immune
//                             gradual compliance 자연 증가
//
//   OPT_C_OPT_OUT           : docs/ frontmatter 정책 면제 (status quo)
//                             cost: zero
//                             rationale: anima docs는 markdown standard heading-start
//                                         형식이 일반적; frontmatter 강제는 over-engineering
//                             cycle 24 finding은 informational only
//
//   OPT_D_KEY_DOCS_ONLY     : 핵심 docs (TOC, preprint, ROADMAP, READMEs)에만 frontmatter
//                             cost: low (50개 미만)
//                             selection criteria: 외부 reference / project metadata
//                                                  / structured indexing 필요한 docs
//                             기존 12 docs 위에 ~30-50 추가
//
// HELPER RECOMMENDATION
//   anima docs 특성 (academic preprints + research notes + landing pages + handoffs)
//   이 markdown heading-start 패턴과 자연스럽게 정합. frontmatter blanket 강제는
//   ROI 낮음. **OPT_C (OPT_OUT)** 권장 — 대신 cycle 24 finding을 "INFORMATIONAL"
//   severity로 재분류. 또는 **OPT_D** (key docs only) — 50 docs frontmatter 추가
//   하면 cross-link/indexing 도움.
//
// NON_MUTATION
//   본 helper는 docs/ 파일 안 건드림. 정책 결정은 사용자 영역.
//
// raw#9 hexa-only / raw#10 honest meta / raw#15 SSOT this file
// raw#10 honest:
//   - cycle 24 reported "0% compliance"는 미세 부정확 (실제 1.2%) — false zero pattern.
//     cycle 24 helper의 frontmatter detection이 multi-pattern 처리 안 했을 수도.
//   - 1012 vs 410 file count 차이는 cycle 24가 docs/ root만 카운트했거나 다른
//     glob 패턴 사용한 결과 추정.

let HELPER_PATH = "/tmp/anima_frontmatter_policy_proposer_helper.hexa_tmp"

fn _write_helper() {
    let parts = []
    parts.push("#!/usr/bin/env python3\n")
    parts.push("# Anima frontmatter policy proposer — emitted by tool/anima_frontmatter_policy_proposer.hexa\n")
    parts.push("# raw#37 transient. mac-local NON_MUTATION (docs 안 만짐).\n")
    parts.push("import json, os\n\n")

    parts.push("OUTPUT = os.environ.get('ANIMA_OUTPUT', 'state/frontmatter_policy_proposer.json')\n\n")

    parts.push("cycle_24_recheck = {\n")
    parts.push("    'cycle_24_reported': {'total_md': 410, 'frontmatter_compliance_pct': 0.0},\n")
    parts.push("    'cycle_80_actual':   {'total_md': 1012, 'frontmatter_count': 12, 'compliance_pct': 1.2},\n")
    parts.push("    'classification':'cycle_24_minor_inaccuracy (0% reported vs 1.2% actual; 410 vs 1012)',\n")
    parts.push("    'pattern':'false_zero_class — cycle 25/39 false-positive 패턴과 같은 helper detection 정밀도 issue',\n")
    parts.push("}\n\n")

    parts.push("policy_options = [\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_A_BLANKET',\n")
    parts.push("        'description':'1012 md 모두 frontmatter 자동 추가',\n")
    parts.push("        'cost':'very-high (1012 file modify + helper automation)',\n")
    parts.push("        'risk':'기존 첫 라인 # heading 위 frontmatter 삽입 — 렌더링 깨짐 가능성',\n")
    parts.push("        'aligns':'low (anima docs는 markdown standard 자연스러움)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_B_NEW_ONLY',\n")
    parts.push("        'description':'신규 md만 enforce (CI lint 또는 pre-commit hook)',\n")
    parts.push("        'cost':'low ($0 mac, hook 작성)',\n")
    parts.push("        'risk':'gradual compliance — 즉시 효과 없음',\n")
    parts.push("        'aligns':'medium (compliance increase over time)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_C_OPT_OUT',\n")
    parts.push("        'description':'docs/ frontmatter 정책 면제 (status quo); cycle 24 finding을 INFORMATIONAL 재분류',\n")
    parts.push("        'cost':'zero',\n")
    parts.push("        'rationale':'anima docs는 academic preprints + research notes + landing pages — markdown standard heading-start 패턴 자연스러움. frontmatter 강제 over-engineering.',\n")
    parts.push("        'aligns':'high (현재 패턴 그대로)',\n")
    parts.push("    },\n")
    parts.push("    {\n")
    parts.push("        'id':'OPT_D_KEY_DOCS',\n")
    parts.push("        'description':'핵심 docs (TOC, preprint, ROADMAP, READMEs)에만 frontmatter — 50개 미만',\n")
    parts.push("        'cost':'low (~30-50 file modify)',\n")
    parts.push("        'selection_criteria':[\n")
    parts.push("            'docs/TOC.md (cross-link index)',\n")
    parts.push("            'docs/preprint_*.md (academic output)',\n")
    parts.push("            'docs/handoff_*.md, docs/new_session_prompt_*.md (session continuity)',\n")
    parts.push("            'docs/ROADMAP.md (외부 reference)',\n")
    parts.push("            '*_landing.md / *_dispatch.md (cycle output, structured indexing 도움)',\n")
    parts.push("        ],\n")
    parts.push("        'aligns':'high (핵심 docs metadata structured + 나머지 free-form)',\n")
    parts.push("    },\n")
    parts.push("]\n\n")

    parts.push("recommendation = {\n")
    parts.push("    'primary':'OPT_C (OPT_OUT) — cycle 24 finding INFORMATIONAL 재분류',\n")
    parts.push("    'secondary':'OPT_D (KEY_DOCS_ONLY) — 50 docs frontmatter 추가 (handoff/preprint/landing/dispatch class)',\n")
    parts.push("    'against':'OPT_A (very-high cost + 렌더링 risk)',\n")
    parts.push("    'rationale':'anima docs 특성 (academic + research + handoff)이 markdown heading-start와 자연 정합. cycle 24 \\\"0%\\\" 자체가 minor inaccuracy (실제 1.2%) — informational signal로 충분.',\n")
    parts.push("    'user_decision_required':True,\n")
    parts.push("}\n\n")

    parts.push("residual_actions = [\n")
    parts.push("    {'action':'cycle 24 helper의 frontmatter detection 정밀도 audit (false zero pattern)', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("    {'action':'사용자 OPT 선택 + apply (OPT_D 시 50 docs frontmatter 추가 helper)', 'priority':'low', 'cost':'mac $0'},\n")
    parts.push("]\n\n")

    parts.push("summary = {\n")
    parts.push("    'paradigm':'cycle 80 — frontmatter 0% compliance policy proposer (cycle 24 follow-up + 정밀화)',\n")
    parts.push("    'cycle': 80,\n")
    parts.push("    'cycle_24_recheck': cycle_24_recheck,\n")
    parts.push("    'policy_options': policy_options,\n")
    parts.push("    'recommendation': recommendation,\n")
    parts.push("    'residual_actions': residual_actions,\n")
    parts.push("    'non_mutation_guarantee':'docs/ 안 건드림; 정책 결정 사용자 영역',\n")
    parts.push("    'cross_link_cycles':['cycle 24 docs integrity audit','cycle 25 false positive (cycle 74)','cycle 39 false alarm (cycle 77)','cycle 79 false alarm sweep'],\n")
    parts.push("    'pattern':'governance audit chain layer 59 (cycle 24 frontmatter finding 정밀화 + 정책)',\n")
    parts.push("}\n")
    parts.push("os.makedirs(os.path.dirname(OUTPUT) or '.', exist_ok=True)\n")
    parts.push("with open(OUTPUT,'w') as f: json.dump(summary, f, indent=2, ensure_ascii=False)\n")
    parts.push("print(f'[frontmatter_policy] cycle=80 actual_compliance=1.2pct options=4 recommended=OPT_C_or_D -> {OUTPUT}')\n")

    write_file(HELPER_PATH, parts.join(""))
}

fn _selftest_invariants() -> bool {
    println("inv:non_mutation=READ_ONLY_PROPOSER")
    println("inv:cycle=80")
    println("inv:cycle_24_reported_compliance=0pct")
    println("inv:cycle_80_actual_compliance=1.2pct")
    println("inv:options_count=4")
    println("inv:recommendation=OPT_C_or_OPT_D")
    println("inv:cross_link_cycles=24,25,39,79")
    return true
}

fn cmd_selftest() {
    println("── anima_frontmatter_policy_proposer selftest ──")
    _write_helper()
    let ok = _selftest_invariants()
    if !ok { println("selftest=fail"); exit(2) }
    println("selftest=ok")
    println("helper_emitted=" + HELPER_PATH)
    println("paradigm=cycle 80 — frontmatter compliance policy 4 options; NON_MUTATION; mac $0")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest { cmd_selftest(); exit(0) }
    _write_helper()
    println("emitted=" + HELPER_PATH)
    println("DONE")
}
