// ════════════════════════════════════════════════════════════════════════════
//  tool/serve_cert_gate_spec.hexa — roadmap #32 (improvements 11-14)
//
//  Pre-H100 spec for the 4 serve-side cert gates. Declares the gate contracts
//  that serve_alm_native.hexa will integrate once the serving path is live
//  (LoRA ckpt + GPU). This file IS the SSOT for the gate signatures.
//
//  Four gates (Seed D improvements 11-14):
//    (11) inference cert gate AN11(c) JSD      threshold jsd_max ≤ 0.12
//    (12) Meta² chain runtime verify            depth ≥ 3, cert_loaded ≥ 8
//    (13) phi-vec attach at decode              phi_vec_dim = 16 (eigenvec)
//    (14) Hexad 6-module routing                6 modules, round-robin cover
//
//  Pre-H100 status: 4/4 gate contracts frozen; full integration into
//  serve_alm_native.hexa PENDING actual serving path (HERZ / H100).
//
//  Exit criteria contribution (.roadmap #32):
//    4 gate contracts defined + hallucination & latency measurement plan
//    declared; full 통합 + real measurement PENDING.
// ════════════════════════════════════════════════════════════════════════════

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}
fn now_utc() -> string { return exec("date -u +%FT%TZ").trim() }
fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }

fn main() {
    let home = _home()
    let out_path = home + "/core/anima/state/serve_cert_gate_spec.json"

    // Gate contract specifications.
    let gate11_name = "AN11_JSD"
    let gate11_threshold = 0.12
    let gate12_name = "META2_CHAIN"
    let gate12_min_depth = 3
    let gate12_min_cert_loaded = 8
    let gate13_name = "PHI_VEC_ATTACH"
    let gate13_vec_dim = 16
    let gate14_name = "HEXAD_ROUTING"
    let gate14_n_modules = 6

    // Structural checks — are constants sane.
    let c11 = gate11_threshold > 0.0 && gate11_threshold < 1.0
    let c12 = gate12_min_depth >= 1 && gate12_min_cert_loaded >= 1
    let c13 = gate13_vec_dim > 0
    let c14 = gate14_n_modules == 6

    let gates_contract_pass = c11 && c12 && c13 && c14

    // Baseline latency budget: ≤ baseline × 1.1 (10% headroom).
    let latency_headroom_pct = 10
    let latency_budget_declared = latency_headroom_pct > 0 && latency_headroom_pct <= 20

    let all_pass = gates_contract_pass && latency_budget_declared

    let mut body = "{\n"
    body = body + "  \"schema_version\": \"1\",\n"
    body = body + "  \"slug\": \"serve-cert-gate-spec\",\n"
    body = body + "  \"tool\": \"tool/serve_cert_gate_spec.hexa\",\n"
    body = body + "  \"roadmap_entry\": \"32\",\n"
    body = body + "  \"created\": \"" + now_utc() + "\",\n"
    body = body + "  \"scope\": \"Pre-H100 gate-contract freeze. serve_alm_native.hexa integration PENDING live serving (HERZ/H100).\",\n"
    body = body + "  \"gates\": [\n"
    body = body + "    {\"id\": 11, \"name\": \"" + gate11_name + "\", \"threshold\": " + to_string(gate11_threshold) + ", \"unit\": \"jsd_max\", \"pass\": " + bool_s(c11) + "},\n"
    body = body + "    {\"id\": 12, \"name\": \"" + gate12_name + "\", \"min_depth\": " + to_string(gate12_min_depth) + ", \"min_cert_loaded\": " + to_string(gate12_min_cert_loaded) + ", \"pass\": " + bool_s(c12) + "},\n"
    body = body + "    {\"id\": 13, \"name\": \"" + gate13_name + "\", \"vec_dim\": " + to_string(gate13_vec_dim) + ", \"source\": \"eigenvec cert (#25)\", \"pass\": " + bool_s(c13) + "},\n"
    body = body + "    {\"id\": 14, \"name\": \"" + gate14_name + "\", \"n_modules\": " + to_string(gate14_n_modules) + ", \"coverage\": \"round-robin\", \"pass\": " + bool_s(c14) + "}\n"
    body = body + "  ],\n"
    body = body + "  \"latency_budget\": {\n"
    body = body + "    \"baseline_headroom_pct\": " + to_string(latency_headroom_pct) + ",\n"
    body = body + "    \"formula\": \"decode_latency ≤ baseline × 1.1\",\n"
    body = body + "    \"declared\": " + bool_s(latency_budget_declared) + "\n"
    body = body + "  },\n"
    body = body + "  \"hallucination_measurement_plan\": {\n"
    body = body + "    \"metric\": \"AN11(c) JSD divergence from grounded distribution\",\n"
    body = body + "    \"baseline_source\": \"pre-gate decode (gate 11 off)\",\n"
    body = body + "    \"acceptance\": \"mean JSD post-gate < mean JSD baseline\",\n"
    body = body + "    \"measurement_pending\": true\n"
    body = body + "  },\n"
    body = body + "  \"integration_status\": {\n"
    body = body + "    \"gate_contracts_defined\": " + bool_s(gates_contract_pass) + ",\n"
    body = body + "    \"serve_alm_native_integration\": \"PENDING live serving path\",\n"
    body = body + "    \"hallucination_measurement\": \"PENDING live serving\",\n"
    body = body + "    \"latency_measurement\": \"PENDING live serving\"\n"
    body = body + "  },\n"
    body = body + "  \"all_pass_pre_h100\": " + bool_s(all_pass) + ",\n"
    body = body + "  \"verdict\": \"" + (if all_pass { "SPEC_VERIFIED_PENDING_SERVING" } else { "FAIL" }) + "\"\n"
    body = body + "}\n"

    exec("mkdir -p '" + home + "/core/anima/state'")
    write_file(out_path, body)

    println("[serve_cert_spec] gates defined: 11/12/13/14 pass=" + bool_s(gates_contract_pass))
    println("[serve_cert_spec] latency budget × 1.1 declared=" + bool_s(latency_budget_declared))
    println("[serve_cert_spec] output=" + out_path)
    if all_pass {
        println("[serve_cert_spec] selftest PASS — 4/4 gate contracts frozen, integration pending serving")
        exit(0)
    } else {
        eprintln("[serve_cert_spec] selftest FAIL")
        exit(1)
    }
}
