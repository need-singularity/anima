// tool/anima_law64_conway_10x10_test.hexa — F1 cycle 4 T8c Conway 10x10 LARGER grid
// ─────────────────────────────────────────────────────────────────────────────
// Per raw 38 long-term track from cycle 4 closure (commit 0e5b91ff §5):
//   "10x10 or 20x20 grid: gliders persist longer before wrap-around;
//    R-pentomino chaotic phase has more steps before stabilization;
//    likely amplifies CA advantage on translation/chaotic patterns"
//
// 5x5 T8b limitations (commit feedc677):
//   - Glider +19% advantage (CA wins) but compressed by toroidal wrap
//   - R-pentomino 30 steps reaches all-zeros stable state quickly
//   - Mean +4.7% << 81% claim
//
// 10x10 grid (100 cells vs 25):
//   - Glider can translate ~5 steps before wrap (vs 2 on 5x5)
//   - R-pentomino chaotic phase has more state space before stabilization
//   - Expected: glider advantage AMPLIFIES (Markov order-1 still cannot capture translation)
//
// raw 9 hexa-only · raw 12 frozen pre-registration · raw 91 honest finding
// ─────────────────────────────────────────────────────────────────────────────

let GRID_W = 10
let GRID_H = 10
let N_CELLS = 100
let SEED = 20260428

let mut RNG_STATE = SEED
fn _rand() -> int { RNG_STATE = (RNG_STATE * 1103515245 + 12345) % 2147483648; return RNG_STATE }

fn _conway_step(state: array) -> array {
    let mut next = []
    let mut row = 0
    while row < GRID_H {
        let mut col = 0
        while col < GRID_W {
            let mut live_neighbors = 0
            let mut dr = -1
            while dr <= 1 {
                let mut dc = -1
                while dc <= 1 {
                    if dr != 0 || dc != 0 {
                        let nrow = (row + dr + GRID_H) % GRID_H
                        let ncol = (col + dc + GRID_W) % GRID_W
                        live_neighbors = live_neighbors + state[nrow * GRID_W + ncol]
                    }
                    dc = dc + 1
                }
                dr = dr + 1
            }
            let cur = state[row * GRID_W + col]
            let mut new_val = 0
            if cur == 1 && (live_neighbors == 2 || live_neighbors == 3) { new_val = 1 }
            if cur == 0 && live_neighbors == 3 { new_val = 1 }
            next.push(new_val)
            col = col + 1
        }
        row = row + 1
    }
    return next
}

fn _empty_grid() -> array {
    let mut g = []
    let mut i = 0
    while i < N_CELLS { g.push(0); i = i + 1 }
    return g
}

fn _set_cell(grid: array, row: int, col: int, val: int) -> array {
    let mut g = []
    let mut i = 0
    while i < N_CELLS { g.push(grid[i]); i = i + 1 }
    g[row * GRID_W + col] = val
    return g
}

fn _gen_blinker() -> array {
    // 3-cell horizontal blinker at row 5 col 4-6
    let mut g = _empty_grid()
    g = _set_cell(g, 5, 4, 1)
    g = _set_cell(g, 5, 5, 1)
    g = _set_cell(g, 5, 6, 1)
    return g
}

fn _gen_glider() -> array {
    // glider at top-left
    let mut g = _empty_grid()
    g = _set_cell(g, 0, 1, 1)
    g = _set_cell(g, 1, 2, 1)
    g = _set_cell(g, 2, 0, 1); g = _set_cell(g, 2, 1, 1); g = _set_cell(g, 2, 2, 1)
    return g
}

fn _gen_r_pentomino() -> array {
    let mut g = _empty_grid()
    g = _set_cell(g, 4, 4, 1); g = _set_cell(g, 4, 5, 1)
    g = _set_cell(g, 5, 3, 1); g = _set_cell(g, 5, 4, 1)
    g = _set_cell(g, 6, 4, 1)
    return g
}

fn _gen_pulsar() -> array {
    // simplified pulsar pattern (period-3) — only available on grids >= 13x13 in pure form
    // 10x10 simplification: use 2 toad patterns (period-2)
    let mut g = _empty_grid()
    // toad 1
    g = _set_cell(g, 1, 1, 1); g = _set_cell(g, 1, 2, 1); g = _set_cell(g, 1, 3, 1)
    g = _set_cell(g, 2, 0, 1); g = _set_cell(g, 2, 1, 1); g = _set_cell(g, 2, 2, 1)
    // toad 2
    g = _set_cell(g, 7, 6, 1); g = _set_cell(g, 7, 7, 1); g = _set_cell(g, 7, 8, 1)
    g = _set_cell(g, 8, 5, 1); g = _set_cell(g, 8, 6, 1); g = _set_cell(g, 8, 7, 1)
    return g
}

fn _markov_train(corpus: array) -> array {
    let mut probs = []
    let mut c = 0
    while c < N_CELLS {
        let mut n00 = 0; let mut n01 = 0; let mut n10 = 0; let mut n11 = 0
        let mut idx = 0
        while idx < corpus.len() {
            let pair = corpus[idx]
            let prev_state = pair[0]; let next_state = pair[1]
            let cur_bit = prev_state[c]; let nxt_bit = next_state[c]
            if cur_bit == 0 && nxt_bit == 0 { n00 = n00 + 1 }
            if cur_bit == 0 && nxt_bit == 1 { n01 = n01 + 1 }
            if cur_bit == 1 && nxt_bit == 0 { n10 = n10 + 1 }
            if cur_bit == 1 && nxt_bit == 1 { n11 = n11 + 1 }
            idx = idx + 1
        }
        let p1g0 = if (n00+n01) > 0 { (n01*1000)/(n00+n01) } else { 500 }
        let p1g1 = if (n10+n11) > 0 { (n11*1000)/(n10+n11) } else { 500 }
        probs.push(p1g0); probs.push(p1g1)
        c = c + 1
    }
    return probs
}

fn _markov_predict(probs: array, prev_state: array) -> array {
    let mut next = []
    let mut c = 0
    while c < N_CELLS {
        let cur_bit = prev_state[c]
        let p = if cur_bit == 0 { probs[2*c] } else { probs[2*c + 1] }
        if p > 500 { next.push(1) } else { next.push(0) }
        c = c + 1
    }
    return next
}

fn _accuracy(pred: array, actual: array) -> int {
    let mut total = 0; let mut match_count = 0
    let mut s = 0
    while s < pred.len() {
        let p = pred[s]; let a = actual[s]
        let mut c = 0
        while c < N_CELLS {
            if p[c] == a[c] { match_count = match_count + 1 }
            total = total + 1; c = c + 1
        }
        s = s + 1
    }
    if total == 0 { return 0 }
    return (match_count * 1000) / total
}

fn _build_pattern_corpus(initial: array, n_steps: int) -> array {
    let mut samples = []
    let mut state = initial
    let mut s = 0
    while s < n_steps {
        let nxt = _conway_step(state)
        samples.push([state, nxt])
        state = nxt
        s = s + 1
    }
    return samples
}

fn _eval_pattern(name: str, initial: array, n_steps: int) -> array {
    println("--- " + name + " (steps=" + str(n_steps) + ") ---")
    let full = _build_pattern_corpus(initial, n_steps * 2)
    let train_size = n_steps
    let mut train = []; let mut test = []
    let mut k = 0
    while k < full.len() {
        if k < train_size { train.push(full[k]) } else { test.push(full[k]) }
        k = k + 1
    }
    let probs = _markov_train(train)
    let mut ca_preds = []; let mut tf_preds = []; let mut actuals = []
    let mut i = 0
    while i < test.len() {
        let pair = test[i]
        let prev_st = pair[0]; let actual_next = pair[1]
        let ca_next = _conway_step(prev_st)
        let tf_next = _markov_predict(probs, prev_st)
        ca_preds.push(ca_next); tf_preds.push(tf_next); actuals.push(actual_next)
        i = i + 1
    }
    let ca_acc = _accuracy(ca_preds, actuals)
    let tf_acc = _accuracy(tf_preds, actuals)
    let advantage = if tf_acc > 0 { ((ca_acc * 1000) / tf_acc) - 1000 } else { 999 }
    println("  ca_acc=" + str(ca_acc) + " tf_acc=" + str(tf_acc) + " advantage=" + str(advantage))
    return [ca_acc, tf_acc, advantage]
}

fn _run() {
    println("__LAW_64_CYCLE_4_T8C_10X10_BEGIN__ Conway 10x10 LARGER grid (vs 5x5 T8b)")
    println("seed=" + str(SEED) + " grid=" + str(GRID_W) + "x" + str(GRID_H) + " N_CELLS=" + str(N_CELLS))
    println("--- known Conway patterns ---")
    let r1 = _eval_pattern("blinker_period_2", _gen_blinker(), 30)
    let r2 = _eval_pattern("glider_period_4", _gen_glider(), 30)
    let r3 = _eval_pattern("r_pentomino_chaotic", _gen_r_pentomino(), 50)
    let r4 = _eval_pattern("dual_toad_period_2", _gen_pulsar(), 30)
    let mut total_ca = 0; let mut total_tf = 0; let mut total_adv = 0
    let mut count = 0
    let results = [r1, r2, r3, r4]
    let mut k = 0
    while k < results.len() {
        let row = results[k]
        total_ca = total_ca + row[0]
        total_tf = total_tf + row[1]
        total_adv = total_adv + row[2]
        count = count + 1
        k = k + 1
    }
    let mean_ca = total_ca / count; let mean_tf = total_tf / count; let mean_adv = total_adv / count
    println("--- aggregate ---")
    println("mean_ca_acc=" + str(mean_ca) + " mean_tf_acc=" + str(mean_tf))
    println("mean_advantage_per_thousand=" + str(mean_adv) + " (" + str(mean_adv / 10) + "." + str(mean_adv % 10) + "%)")
    println("--- comparison vs 5x5 T8b (commit feedc677) ---")
    println("5x5_mean_advantage_per_thousand=47 (4.7%)")
    println("10x10_mean_advantage_per_thousand=" + str(mean_adv))
    let amplification = if mean_adv > 47 { mean_adv - 47 } else { 0 }
    println("amplification_vs_5x5=" + str(amplification) + " (positive = larger grid amplifies CA advantage)")
    if mean_adv > 500 {
        println("__LAW_64_CYCLE_4_T8C_RESULT__ PASS_50PCT_THRESHOLD_ON_10X10")
    } else if mean_adv > 47 {
        println("__LAW_64_CYCLE_4_T8C_RESULT__ AMPLIFIED_VS_5X5_BELOW_50PCT_THRESHOLD")
    } else if mean_adv > 0 {
        println("__LAW_64_CYCLE_4_T8C_RESULT__ POSITIVE_BUT_NOT_AMPLIFIED")
    } else {
        println("__LAW_64_CYCLE_4_T8C_RESULT__ NO_ADVANTAGE_OR_NEGATIVE")
    }
    println("raw_10_caveat=10x10 still small — gliders translate ~5 steps before wrap (vs 2 on 5x5).  20x20 would amplify further.")
    println("raw_10_caveat=Markov order-1 fundamentally cannot capture spatial translation regardless of grid size.")
    println("raw_10_caveat=Real Transformer with 2D positional encoding would compete with CA on 10x10 — separate vast.ai dispatch (commit 61532a3c) addresses this.")
}

fn _selftest() {
    println("__LAW_64_CYCLE_4_T8C_10X10_BEGIN__ selftest")
    let blinker = _gen_blinker()
    let blinker_t1 = _conway_step(blinker)
    let blinker_t2 = _conway_step(blinker_t1)
    let mut t2_eq_t0 = true
    let mut k = 0
    while k < N_CELLS {
        if blinker_t2[k] != blinker[k] { t2_eq_t0 = false }
        k = k + 1
    }
    println("blinker_period_2_invariant_t2==t0=" + str(t2_eq_t0))
    if t2_eq_t0 {
        println("__LAW_64_CYCLE_4_T8C_RESULT__ PASS_SELFTEST")
    } else {
        println("__LAW_64_CYCLE_4_T8C_RESULT__ FAIL_SELFTEST")
    }
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_run = false
    let mut k = 0
    while k < av.len() {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "--run" { has_run = true }
        k = k + 1
    }
    if has_selftest { _selftest() }
    else if has_run { _run() }
    else {
        println("usage: hexa run tool/anima_law64_conway_10x10_test.hexa --selftest | --run")
        println("F1 cycle 4 T8c Conway 10x10 LARGER grid (raw 38 long-term track from cycle 4 closure)")
    }
    return 0
}
