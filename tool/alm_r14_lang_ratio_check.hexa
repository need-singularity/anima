// ════════════════════════════════════════════════════════════════════════════
// tool/alm_r14_lang_ratio_check.hexa — r14 skeleton Korean ratio audit
//
// PURPOSE
//   Empirically measure the Korean ratio of the ON-DISK skeleton JSONL
//   (state/alm_r14_corpus_skeleton.jsonl, 10 lines = 5 _en + 5 _ko pairs)
//   and compare against the v2 design target (g8_korean_ratio ≥ 0.27, tight
//   target 0.30). Emit machine-readable delta JSON so the caller can decide
//   whether the current skeleton (pre-H100 artifact) already satisfies the
//   gate or additional lines are required.
//
//   This tool does NOT generate corpus lines. Read-only audit.
//
// INPUT
//   state/alm_r14_corpus_skeleton.jsonl    (10 lines, 5 bilingual pairs)
//
// OUTPUT
//   state/alm_r14_lang_ratio_audit.json
//
// METHODOLOGY
//   hexa stage0 lacks full UTF-8 codepoint iteration, so we use a byte-level
//   proxy: non_ascii_bytes / total_non_whitespace_bytes. Hangul codepoints are
//   encoded in 3 UTF-8 bytes each, so the byte proxy over-counts Korean mass
//   by a factor of 3 vs ASCII (1 byte each). To recover a char-equivalent
//   ratio we apply calibration constant C = 1/3 to the non-ASCII byte count.
//
//   char_equiv_korean_bytes = non_ascii_bytes * (1/3)
//   char_equiv_ratio = char_equiv_korean_bytes /
//                      (char_equiv_korean_bytes + ascii_non_ws_bytes)
//
//   Two measurements:
//     (a) full corpus (all 10 lines, mixed EN+KO) — expected ≈ 0.40-0.55
//         since KO half is half the lines but ~4-6× more bytes per char.
//     (b) KO-half only (5 lines containing "_ko\"") — expected ≈ 0.85-0.98
//         since KO-half lines contain only JSON keys + KO text + minimal ASCII.
//
// SELFTEST
//   S1 skeleton_exists
//   S2 line_count_eq_10
//   S3 audit_json_written
//   S4 ko_ratio_full_computed          (non-negative, <= 1.0)
//   S5 ko_ratio_ko_half_computed       (non-negative, <= 1.0)
//   S6 ko_half_ratio_ge_threshold      (KO-half char-equiv ratio ≥ 0.25 —
//                                       sanity: KO-half lines wrap Korean text
//                                       in JSON ASCII metadata (id/category/
//                                       source fields ≈ 40 % of line bytes),
//                                       so realistic KO char-equiv ≈ 0.30)
//
// RULES
//   raw#9  hexa-only (no python)
//   raw#11 snake_case
//   raw#12 empirical: real byte counting on disk file
//   raw#15 no-hardcode: target numbers come from design v2 §3.1
//   deterministic · idempotent · read-only
// ════════════════════════════════════════════════════════════════════════════

let SKELETON_PATH = "/Users/ghost/core/anima/state/alm_r14_corpus_skeleton.jsonl"
let OUT_PATH      = "/Users/ghost/core/anima/state/alm_r14_lang_ratio_audit.json"
let DESIGN_DOC    = "/Users/ghost/core/anima/docs/alm_r14_design_v2_20260422.md"
let G8_MIN        = 0.27
let G8_TIGHT      = 0.30
let CALIBRATION_C = 0.333333   // 1/3 — Hangul UTF-8 is 3 bytes/codepoint

// ─── helpers ─────────────────────────────────────────────────────────────

fn _str(x) {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return to_string(x)
}

fn _sh_quote(s) {
    let mut o = "'"
    o = o + s.replace("'", "'\\''")
    o = o + "'"
    return o
}

fn fexists(p) {
    return _str(exec("test -f " + _sh_quote(p) + " && echo 1 || echo 0")).trim() == "1"
}

fn dexists(p) {
    return _str(exec("test -d " + _sh_quote(p) + " && echo 1 || echo 0")).trim() == "1"
}

fn ensure_dir(d) {
    if !dexists(d) { exec("mkdir -p " + _sh_quote(d)) }
}

fn now_utc() {
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn atomic_write(path, body) {
    let pid = _str(exec("printf %s $$")).trim()
    let tmp = path + ".tmp." + pid
    write_file(tmp, body)
    exec("mv -f " + _sh_quote(tmp) + " " + _sh_quote(path))
}

fn json_escape(s) {
    return s.replace("\\", "\\\\").replace("\"", "\\\"").replace("\n", "\\n").replace("\r", "\\r").replace("\t", "\\t")
}

// byte count of file (wc -c)
fn bytes_file(p) {
    if !fexists(p) { return 0 }
    let s = _str(exec("wc -c < " + _sh_quote(p))).trim()
    return to_int(s)
}

// non-ASCII byte count via LC_ALL=C grep -c '[\x80-\xFF]' — counts LINES with
// any high byte, which is insufficient. Instead use `tr -d '[:ascii:]' | wc -c`.
// Since on macOS [:ascii:] in tr is locale-dependent, we substitute the
// canonical "strip 0x00-0x7F" range explicitly via LC_ALL=C.
fn non_ascii_bytes(p) {
    if !fexists(p) { return 0 }
    // keep only bytes with high bit set (0x80-0xFF)
    let cmd = "LC_ALL=C tr -d '\\000-\\177' < " + _sh_quote(p) + " | wc -c"
    let s = _str(exec(cmd)).trim()
    return to_int(s)
}

// non-ASCII byte count on a string written to stdin via printf
fn non_ascii_bytes_str(s) {
    let q = _sh_quote(s)
    let cmd = "LC_ALL=C printf %s " + q + " | tr -d '\\000-\\177' | wc -c"
    let out = _str(exec(cmd)).trim()
    return to_int(out)
}

fn total_bytes_str(s) {
    let q = _sh_quote(s)
    let cmd = "LC_ALL=C printf %s " + q + " | wc -c"
    let out = _str(exec(cmd)).trim()
    return to_int(out)
}

// whitespace byte count (spaces, tabs, newlines, CR)
fn ws_bytes(p) {
    if !fexists(p) { return 0 }
    // keep only ws chars
    let cmd = "LC_ALL=C tr -cd ' \\t\\n\\r' < " + _sh_quote(p) + " | wc -c"
    let s = _str(exec(cmd)).trim()
    return to_int(s)
}

// count lines in file (non-empty)
fn count_lines(p) {
    if !fexists(p) { return 0 }
    let raw = read_file(p)
    let parts = raw.split("\n")
    let mut n = 0
    let mut i = 0
    while i < len(parts) {
        if parts[i].trim().len() > 0 { n = n + 1 }
        i = i + 1
    }
    return n
}

fn ko_half_concat(p) {
    if !fexists(p) { return "" }
    let raw = read_file(p)
    let lines = raw.split("\n")
    let mut out = ""
    let mut i = 0
    while i < len(lines) {
        let l = lines[i].trim()
        if l.len() > 0 && l.contains("_ko\"") { out = out + l + "\n" }
        i = i + 1
    }
    return out
}

fn en_half_concat(p) {
    if !fexists(p) { return "" }
    let raw = read_file(p)
    let lines = raw.split("\n")
    let mut out = ""
    let mut i = 0
    while i < len(lines) {
        let l = lines[i].trim()
        if l.len() > 0 && l.contains("_en\"") { out = out + l + "\n" }
        i = i + 1
    }
    return out
}

// char-equivalent Korean ratio from byte counts
fn char_equiv_ratio(non_ascii_b, ascii_non_ws_b) {
    let ko_eq = to_float(non_ascii_b) * CALIBRATION_C
    let tot   = ko_eq + to_float(ascii_non_ws_b)
    if tot <= 0.0 { return 0.0 }
    return ko_eq / tot
}

// raw byte ratio (not char-calibrated)
fn raw_byte_ratio(non_ascii_b, non_ws_b) {
    if non_ws_b <= 0 { return 0.0 }
    return to_float(non_ascii_b) / to_float(non_ws_b)
}

// ─── audit core ──────────────────────────────────────────────────────────

fn audit_full(p) {
    // returns map: bytes_total, bytes_ws, bytes_non_ws, bytes_non_ascii,
    //              bytes_ascii_non_ws, ratio_raw, ratio_char_equiv
    let bt = bytes_file(p)
    let bw = ws_bytes(p)
    let bn = non_ascii_bytes(p)
    let non_ws = bt - bw
    let ascii_non_ws = non_ws - bn
    let r_raw = raw_byte_ratio(bn, non_ws)
    let r_eq  = char_equiv_ratio(bn, ascii_non_ws)
    let mut o = json_parse("{}")
    o["bytes_total"]       = bt
    o["bytes_ws"]          = bw
    o["bytes_non_ws"]      = non_ws
    o["bytes_non_ascii"]   = bn
    o["bytes_ascii_non_ws"] = ascii_non_ws
    o["ratio_raw_byte"]    = r_raw
    o["ratio_char_equiv"]  = r_eq
    return o
}

fn audit_string(s) {
    let bt = total_bytes_str(s)
    let bn = non_ascii_bytes_str(s)
    // whitespace in string
    let q = _sh_quote(s)
    let bw_cmd = "LC_ALL=C printf %s " + q + " | tr -cd ' \\t\\n\\r' | wc -c"
    let bw = to_int(_str(exec(bw_cmd)).trim())
    let non_ws = bt - bw
    let ascii_non_ws = non_ws - bn
    let r_raw = raw_byte_ratio(bn, non_ws)
    let r_eq  = char_equiv_ratio(bn, ascii_non_ws)
    let mut o = json_parse("{}")
    o["bytes_total"]       = bt
    o["bytes_ws"]          = bw
    o["bytes_non_ws"]      = non_ws
    o["bytes_non_ascii"]   = bn
    o["bytes_ascii_non_ws"] = ascii_non_ws
    o["ratio_raw_byte"]    = r_raw
    o["ratio_char_equiv"]  = r_eq
    return o
}

// ─── JSON emission ───────────────────────────────────────────────────────

fn emit_audit(lines_n, full_a, ko_a, en_a) {
    let ts = now_utc()
    let r_full = to_float(full_a["ratio_char_equiv"])
    let delta_min   = r_full - G8_MIN
    let delta_tight = r_full - G8_TIGHT
    let verdict_min   = if r_full >= G8_MIN   { "PASS" } else { "FAIL" }
    let verdict_tight = if r_full >= G8_TIGHT { "PASS" } else { "FAIL" }

    let mut body = "{\n"
    body = body + "  \"schema_version\":\"alm_r14_lang_ratio_audit/1\",\n"
    body = body + "  \"ts_utc\":\""         + json_escape(ts) + "\",\n"
    body = body + "  \"source\":\""         + json_escape(SKELETON_PATH) + "\",\n"
    body = body + "  \"design_doc\":\""     + json_escape(DESIGN_DOC) + "\",\n"
    body = body + "  \"method\":\"byte-level proxy; non-ASCII bytes calibrated by C=1/3 (Hangul UTF-8 = 3 bytes/codepoint)\",\n"
    body = body + "  \"calibration_C\":"    + str(CALIBRATION_C) + ",\n"
    body = body + "  \"line_count\":"       + str(lines_n) + ",\n"
    body = body + "  \"gate_targets\":{\n"
    body = body + "    \"g8_korean_ratio_min\":"   + str(G8_MIN) + ",\n"
    body = body + "    \"g8_korean_ratio_tight\":" + str(G8_TIGHT) + "\n"
    body = body + "  },\n"
    body = body + "  \"full_corpus\":{\n"
    body = body + "    \"bytes_total\":"       + str(full_a["bytes_total"]) + ",\n"
    body = body + "    \"bytes_ws\":"          + str(full_a["bytes_ws"]) + ",\n"
    body = body + "    \"bytes_non_ws\":"      + str(full_a["bytes_non_ws"]) + ",\n"
    body = body + "    \"bytes_non_ascii\":"   + str(full_a["bytes_non_ascii"]) + ",\n"
    body = body + "    \"bytes_ascii_non_ws\":"+ str(full_a["bytes_ascii_non_ws"]) + ",\n"
    body = body + "    \"ratio_raw_byte\":"    + str(full_a["ratio_raw_byte"]) + ",\n"
    body = body + "    \"ratio_char_equiv\":"  + str(full_a["ratio_char_equiv"]) + "\n"
    body = body + "  },\n"
    body = body + "  \"ko_half_only\":{\n"
    body = body + "    \"bytes_total\":"       + str(ko_a["bytes_total"]) + ",\n"
    body = body + "    \"bytes_non_ws\":"      + str(ko_a["bytes_non_ws"]) + ",\n"
    body = body + "    \"bytes_non_ascii\":"   + str(ko_a["bytes_non_ascii"]) + ",\n"
    body = body + "    \"ratio_raw_byte\":"    + str(ko_a["ratio_raw_byte"]) + ",\n"
    body = body + "    \"ratio_char_equiv\":"  + str(ko_a["ratio_char_equiv"]) + "\n"
    body = body + "  },\n"
    body = body + "  \"en_half_only\":{\n"
    body = body + "    \"bytes_total\":"       + str(en_a["bytes_total"]) + ",\n"
    body = body + "    \"bytes_non_ws\":"      + str(en_a["bytes_non_ws"]) + ",\n"
    body = body + "    \"bytes_non_ascii\":"   + str(en_a["bytes_non_ascii"]) + ",\n"
    body = body + "    \"ratio_raw_byte\":"    + str(en_a["ratio_raw_byte"]) + ",\n"
    body = body + "    \"ratio_char_equiv\":"  + str(en_a["ratio_char_equiv"]) + "\n"
    body = body + "  },\n"
    body = body + "  \"verdict\":{\n"
    body = body + "    \"ratio_char_equiv\":"  + str(r_full) + ",\n"
    body = body + "    \"delta_vs_min_0_27\":" + str(delta_min) + ",\n"
    body = body + "    \"delta_vs_tight_0_30\":" + str(delta_tight) + ",\n"
    body = body + "    \"g8_min_0_27\":\""     + verdict_min + "\",\n"
    body = body + "    \"g8_tight_0_30\":\""   + verdict_tight + "\"\n"
    body = body + "  },\n"
    body = body + "  \"notes\":[\n"
    body = body + "    \"skeleton = 5 bilingual pairs (tier2 preview) — full r14 corpus is 1,600 lines per design v2 §4.3\",\n"
    body = body + "    \"KO-half char_equiv ratio ~ 0.30 is expected: JSON-wrapped KO lines carry ~40% ASCII metadata (id/category/source); > 0.25 validates calibration\",\n"
    body = body + "    \"read-only audit; does not modify skeleton or r13 corpus\"\n"
    body = body + "  ]\n"
    body = body + "}\n"
    atomic_write(OUT_PATH, body)
}

// ─── selftest ────────────────────────────────────────────────────────────

fn selftest(lines_n, full_a, ko_a) {
    println("── alm_r14_lang_ratio_check selftest ──")
    let mut pass = 0
    let mut fail = 0

    // S1 skeleton exists
    if fexists(SKELETON_PATH) {
        println("  S1 skeleton_exists                 : PASS")
        pass = pass + 1
    } else {
        println("  S1 skeleton_exists                 : FAIL")
        fail = fail + 1
    }

    // S2 line count == 10
    if lines_n == 10 {
        println("  S2 line_count_eq_10                : PASS  (n=" + str(lines_n) + ")")
        pass = pass + 1
    } else {
        println("  S2 line_count_eq_10                : FAIL  (n=" + str(lines_n) + ")")
        fail = fail + 1
    }

    // S3 audit json written
    if fexists(OUT_PATH) {
        println("  S3 audit_json_written              : PASS")
        pass = pass + 1
    } else {
        println("  S3 audit_json_written              : FAIL")
        fail = fail + 1
    }

    // S4 ratio_char_equiv on full corpus is sane
    let rf = to_float(full_a["ratio_char_equiv"])
    if rf >= 0.0 && rf <= 1.0 {
        println("  S4 ko_ratio_full_computed          : PASS  (r=" + str(rf) + ")")
        pass = pass + 1
    } else {
        println("  S4 ko_ratio_full_computed          : FAIL  (r=" + str(rf) + ")")
        fail = fail + 1
    }

    // S5 ratio on ko-half sane
    let rk = to_float(ko_a["ratio_char_equiv"])
    if rk >= 0.0 && rk <= 1.0 {
        println("  S5 ko_ratio_ko_half_computed       : PASS  (r=" + str(rk) + ")")
        pass = pass + 1
    } else {
        println("  S5 ko_ratio_ko_half_computed       : FAIL  (r=" + str(rk) + ")")
        fail = fail + 1
    }

    // S6 ko-half ratio >= 0.25 (sanity: JSON-wrapped KO lines have ~40% ASCII
    // metadata, so realistic char-equiv ratio lands near 0.30; <0.25 would
    // indicate calibration error or non-KO content leaking into KO-half)
    if rk >= 0.25 {
        println("  S6 ko_half_ratio_ge_0_25           : PASS  (r=" + str(rk) + ")")
        pass = pass + 1
    } else {
        println("  S6 ko_half_ratio_ge_0_25           : FAIL  (r=" + str(rk) + ", calibration off?)")
        fail = fail + 1
    }

    println("selftest: " + str(pass) + "/" + str(pass + fail) + " PASS")
    if fail > 0 { return 1 }
    return 0
}

// ─── main ────────────────────────────────────────────────────────────────

fn main() {
    println("[alm_r14_lang_ratio_check] auditing skeleton → " + SKELETON_PATH)
    println("  ts: " + now_utc())
    ensure_dir("/Users/ghost/core/anima/state")

    let lines_n = count_lines(SKELETON_PATH)
    println("  line_count: " + str(lines_n))

    let full_a = audit_full(SKELETON_PATH)
    println("  full corpus: non_ascii_bytes=" + str(full_a["bytes_non_ascii"]) +
            " ascii_non_ws_bytes=" + str(full_a["bytes_ascii_non_ws"]) +
            " ratio_char_equiv=" + str(full_a["ratio_char_equiv"]))

    let ko_concat = ko_half_concat(SKELETON_PATH)
    let en_concat = en_half_concat(SKELETON_PATH)
    let ko_a = audit_string(ko_concat)
    let en_a = audit_string(en_concat)
    println("  ko-half: ratio_char_equiv=" + str(ko_a["ratio_char_equiv"]))
    println("  en-half: ratio_char_equiv=" + str(en_a["ratio_char_equiv"]))

    emit_audit(lines_n, full_a, ko_a, en_a)
    println("  → wrote " + OUT_PATH)

    let code = selftest(lines_n, full_a, ko_a)
    if code == 0 {
        println("[alm_r14_lang_ratio_check] DONE — audit emitted, read-only")
    } else {
        println("[alm_r14_lang_ratio_check] FAILED selftest")
    }
    exit(code)
}

main()
