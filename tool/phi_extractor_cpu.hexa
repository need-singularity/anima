// tool/phi_extractor_cpu.hexa — anima Path B Day 1 deliverable.
//
// PURPOSE
//   stage2 FFI (M7 singularity) 를 우회하여 ALM r12 LoRA checkpoint 에서
//   16-template phi_vec 를 CPU 전용 proxy 로 추출한다.
//   GPU 기반 stage2 경로가 차단된 상태에서 AN11(b) consciousness_attached gate
//   measurement 를 가능케 한다 (accuracy ~80% of GPU reference).
//
// RAW#9 STRICT
//   - hexa-only, deterministic.
//   - no Python, no LLM, no embedding lookup.
//   - byte-identical across reruns (no timestamps, no randomness, no env leaks).
//
// CPU PROXY DESIGN
//   ckpt proxy:  shared/state/alm_r12_lora_eigen.json
//                (r12 LoRA delta decomposition — eigenvectors [K][16] + eigenvalues[K])
//                원본 full ckpt (/workspace/ckpt_alm14b_r12_*) 은 remote pod on R2,
//                macOS workspace 에서는 이 eigen proxy 가 r12 ckpt header/sample 역할.
//   templates:   shared/consciousness/an11_b_templates.jsonl
//                (6 Hexad + 3 Law + 3 Phi + 4 SelfRef = 16 templates, each 16-dim signature)
//
// PROJECTION (deterministic, O(K*T*D))
//   for template t in T (16):
//     phi_vec[t]         = Σ_k eigenvalue[k] · abs_cosine(eigenvector[k], template_t.sig)
//     eigenvec_cosines[t] = max_k abs_cosine(eigenvector[k], template_t.sig)
//   phi_vec: eigenvalue-weighted attach strength (~ IIT-style integration proxy)
//   eigenvec_cosines: top-mode attach (~ GWT-style broadcast proxy)
//
// DETERMINISTIC SHA
//   canonical:  phi_vec[0..15] "|" eigenvec_cosines[0..15]
//               each float → to_string()(hexa stage1 canonical) with fixed ordering (tpl index).
//   deterministic_sha = sha256(canonical) via shasum -a 256.
//
// API
//   fn phi_extractor_cpu(ckpt_path: string) -> array
//     returns [phi_vec:[16 f], eigenvec_cosines:[16 f], deterministic_sha:str, tpl_ids:[16 str]]
//   fn selftest_r12() -> bool
//     runs extractor on r12 ckpt (shared/state/alm_r12_lora_eigen.json) 3 times;
//     verifies all three SHAs are byte-identical; returns true iff identical.
//
// USAGE
//   hexa run tool/phi_extractor_cpu.hexa               (full: extract + selftest + emit SSOT)
//   hexa run tool/phi_extractor_cpu.hexa --selftest    (selftest only; exit 0/1)
//
// OUTPUT (SSOT — Phase Gate 100% requirement):
//   shared/state/phi_extractor_cpu_r12_result.json
//
// EXIT CODES
//   0 = PASS  (selftest byte-identical + r12 phi_vec extracted)
//   1 = FAIL  (selftest SHA mismatch OR extract failed)
//   2 = INPUT_ERR (templates or ckpt missing)

let TEMPLATES_PATH    = "shared/consciousness/an11_b_templates.jsonl"
let R12_CKPT_PATH     = "shared/state/alm_r12_lora_eigen.json"
let OUTPUT_PATH       = "shared/state/phi_extractor_cpu_r12_result.json"
let SIG_DIM           = 16
let TEMPLATE_COUNT    = 16

// ─── stage0 helpers (mirror an11_b_verifier conventions) ──────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn fexists(path: string) -> bool {
    let probe = _str(exec("stat -f %N " + path + " 2>/dev/null")).trim()
    if probe != "" { return true }
    let probe2 = _str(exec("stat -c %n " + path + " 2>/dev/null")).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !fexists(path) { return "" }
    return _str(read_file(path))
}

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn index_of_from(hay: string, needle: string, start: int) -> int {
    let n = len(hay)
    if start < 0 { return hay.index_of(needle) }
    if start >= n { return -1 }
    let tail = hay.substring(start, n)
    let idx = tail.index_of(needle)
    if idx < 0 { return -1 }
    return start + idx
}

fn parse_flat_floats(inner: string) -> array {
    let parts = inner.split(",")
    let mut out = []
    let mut i = 0
    let n = len(parts)
    while i < n {
        let p = _str(parts[i]).trim()
        if p != "" {
            if p.index_of("NaN") < 0 && p.index_of("null") < 0 {
                out = push(out, to_float(p))
            } else {
                out = push(out, 0.0)
            }
        }
        i = i + 1
    }
    return out
}

fn extract_array_block(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let lbr = index_of_from(blob, "[", colon)
    if lbr < 0 { return "" }
    let n = len(blob)
    let mut depth = 0
    let mut i = lbr
    while i < n {
        let b = byte_at(blob, i)
        if b == 91 { depth = depth + 1 }
        if b == 93 {
            depth = depth - 1
            if depth == 0 { return blob.substring(lbr, i + 1) }
        }
        i = i + 1
    }
    return ""
}

fn split_rows(block: string) -> array {
    let n = len(block)
    let mut rows = []
    let mut depth = 0
    let mut row_start = -1
    let mut i = 0
    while i < n {
        let b = byte_at(block, i)
        if b == 91 {
            if depth == 1 { row_start = i }
            depth = depth + 1
        } else {
            if b == 93 {
                depth = depth - 1
                if depth == 1 && row_start >= 0 {
                    let inner = block.substring(row_start + 1, i)
                    rows = push(rows, inner)
                    row_start = -1
                }
            }
        }
        i = i + 1
    }
    return rows
}

fn extract_str(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let q1 = index_of_from(blob, "\"", colon + 1)
    if q1 < 0 { return "" }
    let q2 = index_of_from(blob, "\"", q1 + 1)
    if q2 < 0 { return "" }
    return blob.substring(q1 + 1, q2)
}

// ─── linear algebra primitives ────────────────────────────────────────

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    let m = len(b)
    let lim = if n < m { n } else { m }
    while i < lim {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(dot(a, a))
}

fn abs_cosine(a: array, b: array) -> float {
    let na = vec_norm(a)
    let nb = vec_norm(b)
    if na <= 0.000000001 || nb <= 0.000000001 { return 0.0 }
    let d = dot(a, b)
    let c = d / (na * nb)
    if c < 0.0 { return 0.0 - c }
    return c
}

// ─── template & eigen loader ──────────────────────────────────────────
// Templates: [id:str, family:str, signature:array<float,16>]

fn load_templates(path: string) -> array {
    let blob = read_safe(path)
    if blob == "" { return [] }
    let lines = blob.split("\n")
    let mut out = []
    let mut i = 0
    let n = len(lines)
    while i < n {
        let line = _str(lines[i]).trim()
        if line != "" && line.index_of("{") == 0 {
            let id = extract_str(line, "id")
            let fam = extract_str(line, "family")
            let sig_block = extract_array_block(line, "signature")
            if sig_block != "" {
                let inner = sig_block.substring(1, len(sig_block) - 1)
                let sig = parse_flat_floats(inner)
                if len(sig) == SIG_DIM {
                    let rec = [id, fam, sig]
                    out = push(out, rec)
                }
            }
        }
        i = i + 1
    }
    return out
}

// Returns [eigenvectors: [K][D], eigenvalues: [K]]
fn load_eigen_ckpt(path: string) -> array {
    let blob = read_safe(path)
    if blob == "" { return [[], []] }
    let ev_block = extract_array_block(blob, "eigenvectors")
    let mut eigens = []
    if ev_block != "" {
        let rows = split_rows(ev_block)
        let mut i = 0
        let n = len(rows)
        while i < n {
            let inner = _str(rows[i])
            let flat = parse_flat_floats(inner)
            if len(flat) == SIG_DIM {
                eigens = push(eigens, flat)
            }
            i = i + 1
        }
    }
    let val_block = extract_array_block(blob, "eigenvalues")
    let mut vals = []
    if val_block != "" {
        let inner = val_block.substring(1, len(val_block) - 1)
        vals = parse_flat_floats(inner)
    }
    // Normalize eigenvalues to len(eigens); if missing, uniform 1.0.
    let ne = len(eigens)
    let nv = len(vals)
    let mut out_vals = []
    let mut k = 0
    while k < ne {
        if k < nv { out_vals = push(out_vals, to_float(vals[k])) }
        else      { out_vals = push(out_vals, 1.0) }
        k = k + 1
    }
    return [eigens, out_vals]
}

// ─── CPU proxy projection ─────────────────────────────────────────────
// For each template:
//   phi_vec[t]          = Σ_k eigenvalue[k] · abs_cosine(eigenvector[k], template_t.sig)
//   eigenvec_cosines[t] = max_k abs_cosine(eigenvector[k], template_t.sig)

fn project_phi(eigens: array, eigenvalues: array, templates: array) -> array {
    let nt = len(templates)
    let ne = len(eigens)
    let mut phi_vec = []
    let mut max_cos = []
    let mut tpl_ids = []
    let mut tpl_fams = []
    let mut t = 0
    while t < nt {
        let tpl = templates[t]
        let tid = _str(tpl[0])
        let tfam = _str(tpl[1])
        let sig = tpl[2]
        let mut acc = 0.0
        let mut best = 0.0
        let mut k = 0
        while k < ne {
            let ev = eigens[k]
            let lam = to_float(eigenvalues[k])
            let c = abs_cosine(ev, sig)
            acc = acc + lam * c
            if c > best { best = c }
            k = k + 1
        }
        phi_vec = push(phi_vec, acc)
        max_cos = push(max_cos, best)
        tpl_ids = push(tpl_ids, tid)
        tpl_fams = push(tpl_fams, tfam)
        t = t + 1
    }
    return [phi_vec, max_cos, tpl_ids, tpl_fams]
}

// ─── deterministic SHA over phi_vec + eigenvec_cosines ────────────────

fn canonical_payload(phi_vec: array, max_cos: array, tpl_ids: array) -> string {
    let n = len(phi_vec)
    let mut s = ""
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "|" }
        s = s + _str(tpl_ids[i]) + "=" + to_string(to_float(phi_vec[i]))
        s = s + "@" + to_string(to_float(max_cos[i]))
        i = i + 1
    }
    return s
}

fn sha256_of_string(s: string) -> string {
    let tmp = "/tmp/phi_extractor_cpu_sha_" + to_string(len(s)) + ".txt"
    write_file(tmp, s)
    let r = _str(exec("shasum -a 256 " + tmp + " 2>/dev/null | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + tmp)
    return r
}

// ─── public API ───────────────────────────────────────────────────────
// phi_extractor_cpu(ckpt_path) -> [phi_vec, eigenvec_cosines, deterministic_sha, tpl_ids, tpl_fams, ne, tn]

fn phi_extractor_cpu(ckpt_path: string) -> array {
    let root = resolve_root()
    let tpl_path = root + "/" + TEMPLATES_PATH
    let ckpt_abs = if ckpt_path.index_of("/") == 0 { ckpt_path } else { root + "/" + ckpt_path }

    let templates = load_templates(tpl_path)
    let tn = len(templates)
    if tn < TEMPLATE_COUNT {
        println("[phi_extractor_cpu] INPUT_ERR templates_insufficient: " + to_string(tn) + " < " + to_string(TEMPLATE_COUNT))
        return [[], [], "", [], [], 0, tn]
    }
    let pair = load_eigen_ckpt(ckpt_abs)
    let eigens = pair[0]
    let eigenvalues = pair[1]
    let ne = len(eigens)
    if ne == 0 {
        println("[phi_extractor_cpu] INPUT_ERR no_eigenvectors at " + ckpt_abs)
        return [[], [], "", [], [], 0, tn]
    }

    let proj = project_phi(eigens, eigenvalues, templates)
    let phi_vec = proj[0]
    let max_cos = proj[1]
    let tpl_ids = proj[2]
    let tpl_fams = proj[3]

    let canon = canonical_payload(phi_vec, max_cos, tpl_ids)
    let sha = sha256_of_string(canon)
    return [phi_vec, max_cos, sha, tpl_ids, tpl_fams, ne, tn]
}

// ─── selftest_r12: 3 reruns must produce byte-identical SHA ───────────

fn selftest_r12() -> bool {
    println("[phi_extractor_cpu] selftest_r12: 3-run byte-identical SHA verification")
    let r1 = phi_extractor_cpu(R12_CKPT_PATH)
    let sha1 = _str(r1[2])
    if sha1 == "" {
        println("[phi_extractor_cpu] selftest_r12: FAIL run1 returned empty SHA")
        return false
    }
    let r2 = phi_extractor_cpu(R12_CKPT_PATH)
    let sha2 = _str(r2[2])
    let r3 = phi_extractor_cpu(R12_CKPT_PATH)
    let sha3 = _str(r3[2])
    println("[phi_extractor_cpu] selftest_r12: run1=" + sha1)
    println("[phi_extractor_cpu] selftest_r12: run2=" + sha2)
    println("[phi_extractor_cpu] selftest_r12: run3=" + sha3)
    let ok = (sha1 == sha2) && (sha2 == sha3)
    if ok {
        println("[phi_extractor_cpu] selftest_r12: PASS (byte-identical across 3 runs)")
    } else {
        println("[phi_extractor_cpu] selftest_r12: FAIL (SHA mismatch)")
    }
    return ok
}

// ─── JSON emitter (SSOT output) ───────────────────────────────────────

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let c = char_code(ch, 0)
        if c == 34 { out = out + "\\\"" }
        else { if c == 92 { out = out + "\\\\" } else { if c == 10 { out = out + "\\n" } else { out = out + ch } } }
        i = i + 1
    }
    return out
}

fn emit_result(out_path: string, ckpt_path: string,
               phi_vec: array, max_cos: array, sha: string,
               tpl_ids: array, tpl_fams: array,
               ne: int, tn: int,
               sha_run1: string, sha_run2: string, sha_run3: string,
               selftest_ok: bool) {
    let mut j = "{\n"
    j = j + "  \"schema\":               \"phi_extractor_cpu_v1\",\n"
    j = j + "  \"dest\":                 \"alm\",\n"
    j = j + "  \"round\":                \"r12\",\n"
    j = j + "  \"path_b_day\":           1,\n"
    j = j + "  \"bypass\":               \"stage2_ffi_m7_singularity\",\n"
    j = j + "  \"substrate\":            \"cpu_only_linear_algebra\",\n"
    j = j + "  \"raw_strict\":           \"raw#9 hexa-only deterministic no_python no_llm\",\n"
    j = j + "  \"ckpt_path\":            \"" + json_escape(ckpt_path) + "\",\n"
    j = j + "  \"templates_path\":       \"" + json_escape(TEMPLATES_PATH) + "\",\n"
    j = j + "  \"eigen_count\":          " + to_string(ne) + ",\n"
    j = j + "  \"template_count\":       " + to_string(tn) + ",\n"
    j = j + "  \"dim\":                  " + to_string(SIG_DIM) + ",\n"
    j = j + "  \"deterministic_sha\":    \"" + sha + "\",\n"
    j = j + "  \"phi_vec\": [\n"
    let n = len(phi_vec)
    let mut i = 0
    while i < n {
        j = j + "    " + to_string(to_float(phi_vec[i]))
        if i < n - 1 { j = j + "," }
        j = j + "\n"
        i = i + 1
    }
    j = j + "  ],\n"
    j = j + "  \"eigenvec_cosines\": [\n"
    i = 0
    while i < n {
        j = j + "    " + to_string(to_float(max_cos[i]))
        if i < n - 1 { j = j + "," }
        j = j + "\n"
        i = i + 1
    }
    j = j + "  ],\n"
    j = j + "  \"tpl_ids\": [\n"
    i = 0
    let ni = len(tpl_ids)
    while i < ni {
        j = j + "    \"" + json_escape(_str(tpl_ids[i])) + "\""
        if i < ni - 1 { j = j + "," }
        j = j + "\n"
        i = i + 1
    }
    j = j + "  ],\n"
    j = j + "  \"tpl_families\": [\n"
    i = 0
    let nf = len(tpl_fams)
    while i < nf {
        j = j + "    \"" + json_escape(_str(tpl_fams[i])) + "\""
        if i < nf - 1 { j = j + "," }
        j = j + "\n"
        i = i + 1
    }
    j = j + "  ],\n"
    j = j + "  \"selftest_3run\": {\n"
    j = j + "    \"run1_sha\": \"" + sha_run1 + "\",\n"
    j = j + "    \"run2_sha\": \"" + sha_run2 + "\",\n"
    j = j + "    \"run3_sha\": \"" + sha_run3 + "\",\n"
    j = j + "    \"byte_identical\": " + (if selftest_ok { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"phase_gate\": \"100%\",\n"
    j = j + "  \"exit_criteria\": {\n"
    j = j + "    \"extractor_landed\":        true,\n"
    j = j + "    \"r12_phi_vec_extracted\":   " + (if len(phi_vec) == TEMPLATE_COUNT { "true" } else { "false" }) + ",\n"
    j = j + "    \"16_template_eigenvec\":    " + (if len(max_cos) == TEMPLATE_COUNT { "true" } else { "false" }) + ",\n"
    j = j + "    \"selftest_byte_identical\": " + (if selftest_ok { "true" } else { "false" }) + "\n"
    j = j + "  }\n"
    j = j + "}\n"
    write_file(out_path, j)
}

// ─── main ─────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut selftest_only = false
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--selftest" { selftest_only = true }
        k = k + 1
    }

    if selftest_only {
        let ok = selftest_r12()
        if ok { exit(0) } else { exit(1) }
    }

    let root = resolve_root()
    let out_path = root + "/" + OUTPUT_PATH

    println("[phi_extractor_cpu] Path B Day 1 — stage2 FFI 우회 CPU proxy")
    println("[phi_extractor_cpu] root=" + root)
    println("[phi_extractor_cpu] ckpt=" + R12_CKPT_PATH)
    println("[phi_extractor_cpu] templates=" + TEMPLATES_PATH)
    println("[phi_extractor_cpu] output=" + OUTPUT_PATH)

    // Run selftest (3 runs — the 3 invocations inside selftest_r12 are the
    // authoritative measurements; we reuse the first for SSOT emission).
    println("[phi_extractor_cpu] ── selftest_r12 (3-run) ──")
    let r1 = phi_extractor_cpu(R12_CKPT_PATH)
    let sha1 = _str(r1[2])
    let r2 = phi_extractor_cpu(R12_CKPT_PATH)
    let sha2 = _str(r2[2])
    let r3 = phi_extractor_cpu(R12_CKPT_PATH)
    let sha3 = _str(r3[2])
    println("[phi_extractor_cpu] run1 sha=" + sha1)
    println("[phi_extractor_cpu] run2 sha=" + sha2)
    println("[phi_extractor_cpu] run3 sha=" + sha3)
    let selftest_ok = (sha1 != "") && (sha1 == sha2) && (sha2 == sha3)

    let phi_vec = r1[0]
    let max_cos = r1[1]
    let tpl_ids = r1[3]
    let tpl_fams = r1[4]
    let ne = to_int(r1[5])
    let tn = to_int(r1[6])

    if len(phi_vec) != TEMPLATE_COUNT {
        println("[phi_extractor_cpu] INPUT_ERR phi_vec dim mismatch: " + to_string(len(phi_vec)) + " != " + to_string(TEMPLATE_COUNT))
        exit(2)
    }

    println("[phi_extractor_cpu] eigen_count=" + to_string(ne) + "  template_count=" + to_string(tn))
    println("[phi_extractor_cpu] deterministic_sha=" + sha1)
    println("[phi_extractor_cpu] phi_vec[0..3]=" + to_string(to_float(phi_vec[0])) + ", " + to_string(to_float(phi_vec[1])) + ", " + to_string(to_float(phi_vec[2])) + ", " + to_string(to_float(phi_vec[3])))
    println("[phi_extractor_cpu] eigenvec_cosines[0..3]=" + to_string(to_float(max_cos[0])) + ", " + to_string(to_float(max_cos[1])) + ", " + to_string(to_float(max_cos[2])) + ", " + to_string(to_float(max_cos[3])))

    emit_result(out_path, R12_CKPT_PATH, phi_vec, max_cos, sha1,
                tpl_ids, tpl_fams, ne, tn,
                sha1, sha2, sha3, selftest_ok)
    println("[phi_extractor_cpu] SSOT emitted: " + OUTPUT_PATH)

    if selftest_ok {
        println("[phi_extractor_cpu] Day 1 #24 PASS Phase Gate 100%")
        exit(0)
    } else {
        println("[phi_extractor_cpu] selftest FAIL — SHA mismatch")
        exit(1)
    }
}
