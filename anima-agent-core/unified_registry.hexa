}

fn discover_plugins(reg: &mut UnifiedRegistry) {
    // TODO[python-sdk]: plugin_loader.discover_plugins or manual scan
}

fn register_entry(reg: &mut UnifiedRegistry, entry: HandlerEntry) {
    let base = last(split(entry.name, ":"))
    if !has_key(reg.entries, base) || entry.priority > reg.entries[base].priority {
        reg.entries[base] = entry
    }
}

fn route(reg: &UnifiedRegistry, intent: string) -> HandlerEntry {
    let mut best_entry = HandlerEntry { name: "", source: "", keywords: [], description: "", priority: 0 }
    let mut best_score = 0.0

    for name, entry in reg.entries {
        let score = score_intent(intent, entry.keywords) + to_float(entry.priority) * 0.01
        if score > best_score {
            best_score = score
            best_entry = entry
        }
    }
    best_entry
}

fn route_top_k(reg: &UnifiedRegistry, intent: string, k: int) -> array {
    let mut scored = []
    for name, entry in reg.entries {
        let score = score_intent(intent, entry.keywords) + to_float(entry.priority) * 0.01
        if score > 0.0 {
            append(scored, {"entry": entry, "score": score})
        }
    }
    sort_by(scored, "score", "desc")
    slice(scored, 0, min(k, len(scored)))
}

fn registry_act(reg: &UnifiedRegistry, intent: string) -> map {
    let entry = route(reg, intent)
    if entry.name == "" {
        return {"success": false, "error": "No handler matched: " + intent}
    }
    // TODO[python-sdk]: entry.handler(intent)
    {"success": true, "handler": entry.name, "source": entry.source}
}

fn registry_list_all(reg: &UnifiedRegistry) -> array {
    let mut entries = values(reg.entries)
    sort_by(entries, "priority", "desc")
    entries
}

fn registry_stats(reg: &UnifiedRegistry) -> map {
    let mut counts = {"hub": 0, "tool": 0, "plugin": 0, "total": 0}
    for name, e in reg.entries {
        counts[e.source] = counts[e.source] + 1
        counts["total"] = counts["total"] + 1
    }
    counts
}

fn main() {
    println("=== UnifiedRegistry ===")
    let reg = new_unified_registry(true)
    let s = registry_stats(&reg)
    println("hub=" + to_string(s["hub"]) + " tool=" + to_string(s["tool"]) +
            " plugin=" + to_string(s["plugin"]) + " total=" + to_string(s["total"]))
}
