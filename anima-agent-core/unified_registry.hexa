// unified_registry.hexa -- Merged registry: hub modules + agent tools + plugins
// Port of unified_registry.py
// Single route(intent) resolves natural language to best handler

comptime const LN2 = 0.693147
comptime const PSI_F_CRITICAL = 0.10

struct HandlerEntry {
    name: string,
    source: string,       // "plugin" | "tool" | "hub"
    keywords: array,
    description: string,
    priority: int,        // plugin=2, tool=1, hub=0
}

fn score_intent(text: string, keywords: array) -> float {
    let text_lower = lowercase(text)
    let tokens = split(text_lower, " ")
    let mut score = 0.0
    for kw in keywords {
        let kw_lower = lowercase(kw)
        if contains(text_lower, kw_lower) {
            score = score + 1.0
        } else {
            let kw_tokens = split(kw_lower, " ")
            let mut overlap = 0
            for t in kw_tokens {
                if contains_item(tokens, t) {
                    overlap = overlap + 1
                }
            }
            if overlap > 0 {
                score = score + 0.5 * (to_float(overlap) / to_float(len(kw_tokens)))
            }
        }
    }
    score
}

struct UnifiedRegistry {
    entries: map,
}

comptime const PRIORITY_MAP = {"plugin": 2, "tool": 1, "hub": 0}

fn new_unified_registry(auto_discover: bool) -> UnifiedRegistry {
    let mut reg = UnifiedRegistry { entries: {} }
    if auto_discover {
        discover_hub(&mut reg)
        discover_tools(&mut reg)
        discover_plugins(&mut reg)
    }
    reg
}

