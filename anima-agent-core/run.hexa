// run.hexa -- Argparse dispatcher for all agent modes
// Port of run.py

comptime const ANIMA_ROOT = "."

struct RunArgs {
    cli: bool,
    telegram: bool,
    discord: bool,
    all: bool,
    enable_tools: bool,
    enable_learning: bool,
    provider: string,
    verbose: bool,
    quiet: bool,
}

fn parse_args() -> RunArgs {
    // TODO[python-sdk]: argparse argument parsing
    RunArgs {
        cli: true,
        telegram: false,
        discord: false,
        all: false,
        enable_tools: true,
        enable_learning: false,
        provider: "",
        verbose: false,
        quiet: false,
    }
}

struct GracefulShutdown {
    shutdown_requested: bool,
    tasks: array,
}

fn new_shutdown() -> GracefulShutdown {
    GracefulShutdown { shutdown_requested: false, tasks: [] }
}

fn request_shutdown(gs: &mut GracefulShutdown) {
    gs.shutdown_requested = true
}

async fn cancel_all(gs: &mut GracefulShutdown) {
    for task in gs.tasks {
        // TODO[python-sdk]: task.cancel()
    }
    gs.tasks = []
}

async fn async_main(args: RunArgs) {
