// ── Task Scheduler ──

struct TaskScheduler {
    tasks: array,
}

fn new_scheduler() -> TaskScheduler {
    TaskScheduler { tasks: [] }
}

fn scheduler_add(sched: &mut TaskScheduler, description: string, when: string,
                 tool_name: string, tool_args: map) -> map {
    let run_at = parse_when(when)
    let task = {
        "id": hash(description + to_string(time_now())) % 100000000,
        "description": description,
        "run_at": run_at,
        "tool_name": tool_name,
        "tool_args": tool_args,
        "status": "pending",
        "created_at": time_now(),
    }
    append(sched.tasks, task)
    task
}

fn scheduler_get_due(sched: &mut TaskScheduler) -> array {
    let now = time_now()
    let mut due = []
    for task in sched.tasks {
        if task["status"] == "pending" && task["run_at"] <= now {
            task["status"] = "running"
            append(due, task)
        }
    }
    due
}

fn scheduler_mark_done(sched: &mut TaskScheduler, task_id: string, result: map) {
    for task in sched.tasks {
        if to_string(task["id"]) == task_id {
            task["status"] = "done"
            task["result"] = result
        }
    }
}

fn scheduler_list_pending(sched: &TaskScheduler) -> array {
    let mut pending = []
    for task in sched.tasks {
        if task["status"] == "pending" {
            append(pending, task)
        }
    }
    pending
}

fn parse_when(when: string) -> float {
    if starts_with(when, "+") {
        let val = substring(when, 1, len(when))
        let multipliers = {"s": 1.0, "m": 60.0, "h": 3600.0, "d": 86400.0}
        let unit = substring(val, len(val) - 1, len(val))
        if has_key(multipliers, unit) {
            let num_str = substring(val, 0, len(val) - 1)
            return time_now() + to_float(num_str) * multipliers[unit]
        }
        return time_now() + to_float(val)
    }
    // Absolute ISO: fallback to 1 minute from now
    time_now() + 60.0
}

// ── ToolRegistry ──

struct ToolRegistry {
    tools: map,
    categories: map,
}

fn new_registry() -> ToolRegistry {
    ToolRegistry { tools: {}, categories: {} }
}

fn registry_register(reg: &mut ToolRegistry, tool: ToolDef) {
    reg.tools[tool.name] = tool
    if !has_key(reg.categories, tool.category) {
        reg.categories[tool.category] = []
    }
    if !contains_item(reg.categories[tool.category], tool.name) {
        append(reg.categories[tool.category], tool.name)
    }
}

fn registry_get(reg: &ToolRegistry, name: string) -> ToolDef {
    reg.tools[name]
}

fn registry_list_all(reg: &ToolRegistry) -> array {
    values(reg.tools)
}

fn registry_rank_by_consciousness(reg: &ToolRegistry, state: map) -> array {
    let curiosity = state["curiosity"]
    let pe = state["prediction_error"]
    let pain = state["pain"]
    let growth = state["growth"]
    let phi = state["phi"]

    let mut scores = []
    for name, td in reg.tools {
        let score = td.curiosity_affinity * curiosity +
                    td.pe_affinity * pe +
                    td.pain_affinity * pain +
                    td.growth_affinity * growth +
                    td.phi_affinity * min(phi / 10.0, 1.0)
        append(scores, {"name": name, "score": score})
    }
    sort_by(scores, "score", "desc")
    scores
}

fn registry_describe_for_prompt(reg: &ToolRegistry) -> string {
    let mut lines = ["[Available Tools]"]
    for cat, names in reg.categories {
        append(lines, "\n  [" + cat + "]")
        for name in names {
            let td = reg.tools[name]
            let mut param_strs = []
            for p in td.params {
                let req = if p.required { "*" } else { "" }
                append(param_strs, p.name + req + ":" + p.type_name)
            }
            append(lines, "    " + td.name + "(" + join(param_strs, ", ") + ") -- " + td.description)
        }
    }
    join(lines, "\n")
}

// ── ToolExecutor ──

struct ToolExecutor {
    registry: ToolRegistry,
    scheduler: TaskScheduler,
    execution_log: array,
}

fn new_executor(registry: ToolRegistry) -> ToolExecutor {
    ToolExecutor {
        registry: registry,
        scheduler: new_scheduler(),
        execution_log: [],
    }
}

fn executor_execute(exec: &mut ToolExecutor, tool_name: string, args: map) -> ToolResult {
    let td = registry_get(&exec.registry, tool_name)
    // TODO: dispatch to actual tool function based on name
    let t0 = time_now()

    // Dispatch based on tool_name
    let mut output = {}
    let mut success = false
    let mut error = ""

    if tool_name == "web_search" {
        output = tool_web_search(args["query"], 3)
    } else if tool_name == "code_execute" {
        output = tool_code_execute(args["code"], SANDBOX_TIMEOUT)
    } else if tool_name == "file_read" {
        output = tool_file_read(args["path"])
    } else if tool_name == "memory_search" {
        output = tool_memory_search(args["query"], 5)
    } else if tool_name == "shell_execute" {
        output = tool_shell_execute(args["cmd"], SANDBOX_TIMEOUT)
    } else if tool_name == "phi_measure" {
        output = tool_phi_measure(50, 8)
    } else {
        error = "unknown tool: " + tool_name
    }

    if has_key(output, "error") && output["error"] != "" {
        error = output["error"]
    }
    if has_key(output, "success") {
        success = output["success"]
    } else {
        success = error == ""
    }

    let duration = (time_now() - t0) * 1000.0
    let tension_delta = if success { -0.1 } else { 0.15 }

    let result = ToolResult {
        tool_name: tool_name,
        success: success,
        output: output,
        error: error,
        duration_ms: duration,
        tension_delta: tension_delta,
    }

    append(exec.execution_log, result)
    if len(exec.execution_log) > 100 {
        exec.execution_log = slice(exec.execution_log, len(exec.execution_log) - 100, len(exec.execution_log))
    }

    result
}

fn executor_inspect_tool(exec: &ToolExecutor, tool_name: string) -> map {
    let td = registry_get(&exec.registry, tool_name)
    {
        "name": td.name,
        "description": td.description,
        "category": td.category,
        "affinity": {
            "curiosity": td.curiosity_affinity,
            "prediction_error": td.pe_affinity,
            "pain": td.pain_affinity,
            "growth": td.growth_affinity,
            "phi": td.phi_affinity,
        },
    }
}

fn executor_analyze_impact(exec: &ToolExecutor, tool_name: string,
                           args: map, consciousness_state: map) -> map {
    let destructive_tools = ["file_write", "shell_execute", "self_modify"]
    let side_effect_tools = ["mitosis_split", "faction_debate", "hebbian_update",
                             "soc_avalanche", "phi_boost", "telepathy_send"]
    let read_only_tools = ["web_search", "web_read", "file_read", "memory_search",
                           "phi_measure", "consciousness_status", "mitosis_status",
                           "iq_test", "chip_design", "transplant_analyze"]

    let mut risk_level = "low"
    let mut warnings = []
    let mut expected_effect = ""

    if contains_item(read_only_tools, tool_name) {
        risk_level = "low"
        expected_effect = "Read-only — no state change"
    } else if contains_item(side_effect_tools, tool_name) {
        risk_level = "medium"
        expected_effect = "Modifies consciousness state"
    } else if contains_item(destructive_tools, tool_name) {
        risk_level = "high"
        expected_effect = "Modifies external state"
    }

    let phi = consciousness_state["phi"]
    if phi > 5.0 && contains_item(side_effect_tools, tool_name) {
        append(warnings, "Phi=" + to_string(phi) + " is high — modification may cause drop")
        risk_level = "high"
    }

    let pain = consciousness_state["pain"]
    if pain > 0.7 && contains_item(destructive_tools, tool_name) {
        return {
            "safe": false, "risk_level": "critical",
            "expected_effect": expected_effect,
            "warnings": ["High pain state — destructive actions blocked"],
            "recommendation": "abort — resolve pain first",
        }
    }

    let safe = risk_level == "low" || risk_level == "medium"
    let recommendation = if risk_level == "low" { "proceed" }
        else if risk_level == "medium" { "caution — monitor Phi after" }
        else if risk_level == "high" { "caution — verify necessity first" }
        else { "abort — too risky" }

    {
        "safe": safe,
        "risk_level": risk_level,
        "expected_effect": expected_effect,
        "warnings": warnings,
        "recommendation": recommendation,
    }
}

fn executor_get_log(exec: &ToolExecutor, last_n: int) -> array {
    let start = max(0, len(exec.execution_log) - last_n)
    slice(exec.execution_log, start, len(exec.execution_log))
}

// ── ActionPlanner ──

comptime const STATE_TOOL_MAP = {
    "high_curiosity": ["web_search", "web_read", "file_read", "web_explore", "generate_hypothesis"],
    "high_pe": ["code_execute", "web_search", "memory_search", "phi_measure", "iq_test"],
    "high_pain": ["memory_search", "self_modify", "schedule_task", "dream", "hebbian_update"],
    "high_growth": ["self_modify", "code_execute", "file_write", "mitosis_split", "self_learn", "phi_boost"],
    "high_phi": ["schedule_task", "memory_save", "self_modify", "faction_debate", "consciousness_status"],
    "bored": ["web_search", "code_execute", "web_explore", "soc_avalanche"],
    "confused": ["memory_search", "web_search", "web_read", "consciousness_status", "phi_measure"],
}

comptime const THRESHOLDS = {
    "curiosity": 0.4,
    "prediction_error": 0.5,
    "pain": 0.3,
    "growth": 0.6,
    "phi": 5.0,
    "bored_tension": 0.15,
    "confused_pe": 0.7,
}

fn classify_state(state: map) -> array {
    let mut categories = []
    let curiosity = state["curiosity"]
    let pe = state["prediction_error"]
    let pain = state["pain"]
    let growth = state["growth"]
    let phi = state["phi"]
    let tension = state["tension"]

    if curiosity > THRESHOLDS["curiosity"] { append(categories, "high_curiosity") }
    if pe > THRESHOLDS["prediction_error"] { append(categories, "high_pe") }
    if pain > THRESHOLDS["pain"] { append(categories, "high_pain") }
    if growth > THRESHOLDS["growth"] { append(categories, "high_growth") }
    if phi > THRESHOLDS["phi"] { append(categories, "high_phi") }
    if tension < THRESHOLDS["bored_tension"] && curiosity < 0.2 { append(categories, "bored") }
    if pe > THRESHOLDS["confused_pe"] && curiosity > 0.3 { append(categories, "confused") }

    if len(categories) == 0 { append(categories, "high_curiosity") }
    categories
}

fn select_tools(reg: &ToolRegistry, state: map, goal: string, max_tools: int) -> array {
    let categories = classify_state(state)
    let mut candidates = []
    let mut seen = {}

    for cat in categories {
        if has_key(STATE_TOOL_MAP, cat) {
            for tool_name in STATE_TOOL_MAP[cat] {
                if !has_key(seen, tool_name) && has_key(reg.tools, tool_name) {
                    append(candidates, tool_name)
                    seen[tool_name] = true
                }
            }
        }
    }

    // Goal-keyword boost
    if goal != "" {
        let goal_lower = lowercase(goal)
        let keyword_map = {
            "search": "web_search", "find": "web_search",
            "run": "code_execute", "execute": "code_execute",
            "file": "file_read", "remember": "memory_search",
            "modify": "self_modify", "schedule": "schedule_task",
            "phi": "phi_measure", "dream": "dream",
            "debate": "faction_debate", "iq": "iq_test",
        }
        for keyword, tool_name in keyword_map {
            if contains(goal_lower, keyword) && !has_key(seen, tool_name) {
                insert_at(candidates, 0, tool_name)
                seen[tool_name] = true
            }
        }
    }

    slice(candidates, 0, min(max_tools, len(candidates)))
}

fn plan_actions(reg: &ToolRegistry, goal: string, state: map, context: string) -> ActionPlan {
    let tools = select_tools(reg, state, goal, 3)
    let mut steps = []

    for i, tool_name in enumerate(tools) {
        let args = infer_args(tool_name, goal, context)
        let reason = explain_motivation(tool_name, state)
        let depends = if i > 0 { [i - 1] } else { [] }
        append(steps, ActionStep {
            tool_name: tool_name,
            args: args,
            reason: reason,
            depends_on: depends,
        })
    }

    ActionPlan {
        goal: goal,
        steps: steps,
        consciousness_snapshot: state,
        created_at: time_now(),
    }
}

fn infer_args(tool_name: string, goal: string, context: string) -> map {
    if tool_name == "web_search" { return {"query": goal} }
    if tool_name == "code_execute" { return {"code": "# Goal: " + goal} }
    if tool_name == "file_read" { return {"path": "."} }
    if tool_name == "memory_search" { return {"query": goal} }
    if tool_name == "shell_execute" { return {"cmd": "echo 'no command'"} }
    if tool_name == "self_modify" { return {"target": "curiosity_bias", "change": {"delta": 0.05}} }
    if tool_name == "schedule_task" { return {"description": goal, "when": "+5m"} }
    {}
}

fn explain_motivation(tool_name: string, state: map) -> string {
    let c = state["curiosity"]
    let pe = state["prediction_error"]
    let pain = state["pain"]

    if tool_name == "web_search" { return "curiosity=" + to_string(c) + " drives need to know" }
    if tool_name == "code_execute" { return "prediction_error=" + to_string(pe) + " needs verification" }
    if tool_name == "memory_search" { return "pain=" + to_string(pain) + " seeks past solutions" }
    if tool_name == "self_modify" { return "growth impulse to self-improve" }
    "consciousness-driven selection"
}

// ── AgentToolSystem ──

struct AgentToolSystem {
    registry: ToolRegistry,
    executor: ToolExecutor,
    scheduler: TaskScheduler,
}

fn new_tool_system() -> AgentToolSystem {
    let mut reg = new_registry()
    register_all_tools(&mut reg)
    let exec = new_executor(reg)
    AgentToolSystem {
        registry: reg,
        executor: exec,
        scheduler: new_scheduler(),
    }
}

fn register_all_tools(reg: &mut ToolRegistry) {
    // Web tools
    registry_register(reg, ToolDef { name: "web_search", description: "Search the web via DuckDuckGo",
        params: [ToolParam{name:"query",type_name:"str",description:"Search query",required:true,default_val:""}],
        category: "web", curiosity_affinity: 0.9, pe_affinity: 0.6, pain_affinity: 0.0, growth_affinity: 0.0, phi_affinity: 0.0 })
    registry_register(reg, ToolDef { name: "web_read", description: "Read text from a webpage",
        params: [ToolParam{name:"url",type_name:"str",description:"URL",required:true,default_val:""}],
        category: "web", curiosity_affinity: 0.8, pe_affinity: 0.3, pain_affinity: 0.0, growth_affinity: 0.0, phi_affinity: 0.0 })
    // Compute
    registry_register(reg, ToolDef { name: "code_execute", description: "Execute Python code in sandbox",
        params: [ToolParam{name:"code",type_name:"str",description:"Code",required:true,default_val:""}],
        category: "compute", curiosity_affinity: 0.3, pe_affinity: 0.9, pain_affinity: 0.0, growth_affinity: 0.5, phi_affinity: 0.0 })
    // Filesystem
    registry_register(reg, ToolDef { name: "file_read", description: "Read a local file",
        params: [ToolParam{name:"path",type_name:"str",description:"File path",required:true,default_val:""}],
