// ── Data structures ──

struct ToolParam {
    name: string,
    type_name: string,
    description: string,
    required: bool,
    default_val: string,
}

struct ToolDef {
    name: string,
    description: string,
    params: array,
    category: string,
    curiosity_affinity: float,
    pe_affinity: float,
    pain_affinity: float,
    growth_affinity: float,
    phi_affinity: float,
}

struct ToolResult {
    tool_name: string,
    success: bool,
    output: map,
    error: string,
    duration_ms: float,
    tension_delta: float,
}

struct ActionStep {
    tool_name: string,
    args: map,
    reason: string,
    depends_on: array,
}

struct ActionPlan {
    goal: string,
    steps: array,
    consciousness_snapshot: map,
    created_at: float,
}

