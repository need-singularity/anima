fn tool_system_act(sys: &mut AgentToolSystem, goal: string,
                   consciousness_state: map, context: string) -> array {
    let plan = plan_actions(&sys.registry, goal, consciousness_state, context)
    tool_system_execute_plan(sys, plan)
}

fn tool_system_execute_plan(sys: &mut AgentToolSystem, plan: ActionPlan) -> array {
    let mut results = []
    let mut step_outputs = {}

    for i, step in enumerate(plan.steps) {
        // Check dependencies
        let mut skip = false
        for dep_idx in step.depends_on {
            if dep_idx < len(results) && !results[dep_idx].success {
                append(results, ToolResult {
                    tool_name: step.tool_name, success: false, output: {},
                    error: "dependency step " + to_string(dep_idx) + " failed",
                    duration_ms: 0.0, tension_delta: 0.0,
                })
                skip = true
            }
        }
        if skip { continue }

        let result = executor_execute(&mut sys.executor, step.tool_name, step.args)
        append(results, result)
        step_outputs[i] = result.output
    }

    results
}

fn tool_system_get_descriptions(sys: &AgentToolSystem) -> string {
    registry_describe_for_prompt(&sys.registry)
}

fn parse_tool_calls_from_response(response_text: string) -> array {
    // Parse ```tool ... ``` JSON blocks and [tool:name key=value] inline patterns
    // TODO: regex matching for tool call extraction
    []
}

