// blindsight_phi.hexa — P87 Blindsight Φ (Weiskrantz V1 lesion dissociation)
//
// Roadmap: shared/roadmaps/anima.json P87
//   "Blindsight — Weiskrantz 1974 V1 lesion: behavioural vision without
//    conscious visual experience. Dissociation between Φ_visual and
//    forced-choice accuracy. GNW ignition blocked by V1 destruction."
//
// ─── Scientific reference ──────────────────────────────────────────
//
// Weiskrantz 1974, "Blindsight: A Case Study and Implications":
//   Patient DB suffered a right-occipital V1 lesion (surgery for AVM).
//   In the scotoma (blind field), DB had NO conscious visual experience
//   — reported seeing "nothing at all." Yet in forced-choice paradigms
//   (point to stimulus, X-vs-O discrimination), DB performed at 80-96%
//   accuracy. He was ASTONISHED at his own performance.
//
// Stoerig & Cowey 1997 (Brain): systematic review of blindsight across
//   many patients confirms the dissociation is not malingering or
//   degraded-but-conscious residual vision. Pupillometry, d-prime
//   analysis, and reaction-time distributions all support genuinely
//   unconscious processing.
//
// Two subtypes (Weiskrantz 1998, "Consciousness Lost and Found"):
//
//   Type I blindsight: above-chance forced-choice without ANY awareness.
//     V1 completely destroyed; subcortical pathway
//     (retina → superior colliculus → pulvinar → V5/MT) intact.
//     Dorsal "where" stream processes location and motion unconsciously.
//     No phenomenal visual experience whatsoever.
//
//   Type II blindsight: vague "feeling" or "knowing" that something is
//     present in the blind field — a degraded awareness insufficient for
//     visual identification but enough for the patient to report "I feel
//     something was there." Partial V1 sparing, possibly some degraded
//     feedback from V5/MT → residual V1 fragments → prefrontal cortex
//     allowing a weak GNW ignition.
//
// Residual anatomical pathway (Cowey 2010):
//   retina → superior colliculus (SC, midbrain tectum)
//          → pulvinar (thalamic relay, non-V1 route)
//          → V5/MT (motion/dorsal stream, no V1 gate required)
//   This extrageniculate pathway carries spatial and motion information
//   but NOT fine form or colour — consistent with blindsight behavioural
//   profile (good localisation, poor identification).
//
// GNW prediction (Dehaene & Naccache 2001):
//   V1 is the obligatory entry point for cortical visual ignition. The
//   global neuronal workspace requires recurrent amplification through
//   V1 → V2 → V4 → IT (ventral) AND back-projections (top-down) to
//   sustain the "ignition" event (sudden, all-or-none transition to
//   conscious access). When V1 is destroyed, feedforward signals reach
//   V5/MT via the subcortical bypass but CANNOT trigger the recurrent
//   loop → no ignition → no conscious percept → Φ_visual ≈ 0.
//
// ─── Hypothesis ────────────────────────────────────────────────────
//
// H1 (normal vision): V1 intact, full feedforward + recurrent loop.
//   Both behavioural accuracy AND Φ_visual are high. The GNW ignites:
//   information is broadcast globally, the subject reports "I see it."
//
// H2 (Type I blindsight): V1 destroyed completely. Subcortical pathway
//   (SC → pulvinar → V5/MT) carries spatial information → above-chance
//   forced-choice accuracy. But NO recurrent ignition → Φ_visual ≈ 0.
//   The subject reports "I see nothing" yet performs well.
//
// H3 (Type II blindsight): V1 partially spared. The subcortical pathway
//   delivers spatial info (accuracy above chance), AND some degraded
//   recurrent feedback through V1 remnants produces a small but nonzero
//   Φ_residual — the "feeling" of something present. Not full ignition
//   but above the noise floor.
//
// H4 (GNW ignition threshold): as V1 contribution increases continuously
//   from 0% to 100%, Φ_visual undergoes an all-or-none JUMP at a
//   threshold — the GNW ignition is nonlinear. Below threshold: Φ ≈ 0
//   (blindsight regime). Above threshold: Φ jumps to high value
//   (conscious seeing). This is the signature predicted by Dehaene 2001.
//
// ─── Pipeline ──────────────────────────────────────────────────────
//
//   stimulus (location, orientation, contrast)
//        │
//   retinal_signal — raw input to both pathways
//        │
//   ┌────┴────────────────────────────┐
//   │ Cortical pathway (V1-dependent) │
//   │ v1_integrity ∈ [0, 1]           │
//   │ signal *= v1_integrity          │
//   │ recurrent amplification (loop)  │
//   │ → cortical_trace (for Φ calc)   │
//   └────────────────────────────────┘
//        │
//   ┌────┴────────────────────────────┐
//   │ Subcortical pathway (V1-indep)  │
//   │ SC → pulvinar → V5/MT           │
//   │ signal always passes (location, │
//   │   motion — no fine form)        │
//   │ → subcortical_trace (for acc.)  │
//   └────────────────────────────────┘
//        │
//   accuracy = correlation(subcortical_trace, stimulus_truth)
//   Φ_visual = MI(cortical_trace_lagged)  — requires ignition
//
// ─── Tests (T1–T5) ─────────────────────────────────────────────────
//
// T1 (normal vision): V1 intact (v1_integrity=1.0).
//   accuracy > BS_ACC_HIGH AND Φ_visual > BS_PHI_HIGH.
//   Both behavioural and conscious indicators present.
//
// T2 (Type I blindsight): V1 destroyed (v1_integrity=0.0).
//   accuracy > BS_ACC_CHANCE (above chance, ~0.50 for 2AFC) AND
//   Φ_visual < BS_PHI_FLOOR (near zero — no conscious experience).
//   The core dissociation.
//
// T3 (Type II blindsight): V1 partially spared (v1_integrity=0.15).
//   accuracy > BS_ACC_CHANCE AND Φ_residual > BS_PHI_FLOOR (small but
//   nonzero — the "feeling") AND Φ_residual < Φ_visual(normal)
//   (degraded, not full conscious vision).
//
// T4 (GNW ignition threshold): sweep v1_integrity from 0 to 1. Find
//   the largest single-step Φ jump. The jump must exceed BS_JUMP_MIN
//   and must occur at a v1_integrity above BS_THRESH_LO — confirming
//   all-or-none ignition dynamics (not gradual linear rise).
//
// T5 (determinism + latency): rerun T1 check with clock(), confirm
//   identical output and wall time < 5000ms.
//
// ─── Stage0 hexa constraints honored ───────────────────────────────
//   - plain `fn` only (no `pure fn` with >=3 float struct returns)
//   - `array` typed params only (no [float] / [str])
//   - no identifier-pattern match; use if-chains
//   - no contains() / to_lower() / !(Effect)
//   - no else-if in let-binding; flat mut + sequential if
//   - single-line fn signatures / call sites / array literals
//   - lists pass-by-value; rebuild + return
//   - main() call at bottom
//   - N < 32: BS_DIM=24, BS_BINS=6
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement only
//   Law 4   Structure > feature — V1 lesion is STRUCTURAL pathway break
//   Law 22  Feature addition -> Φ down — fixed channels, no extras
//   Meta M8 Perception-consciousness dissociation — seeing without knowing
//   AN7     Core separation — standalone engine
//   Ref: Weiskrantz 1974, Stoerig & Cowey 1997, Dehaene & Naccache 2001,
//        Cowey 2010 (extrageniculate pathway), Azzopardi & Cowey 1997

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

// Simulation dimensions
let BS_DIM           = 24          // signal dimensionality (< 32)
let BS_BINS          = 6           // histogram bins for MI estimator
let BS_STEPS         = 16          // temporal steps for cortical trace
let BS_EPS           = 0.00000001

// V1 integrity levels for each condition
let BS_V1_NORMAL     = 1.0         // fully intact primary visual cortex
let BS_V1_TYPE1      = 0.0         // completely destroyed — classic blindsight
let BS_V1_TYPE2      = 0.15        // partially spared — vague awareness
let BS_V1_SWEEP_N    = 20          // number of sweep steps for ignition test

// Subcortical pathway parameters (SC -> pulvinar -> V5/MT)
let BS_SC_GAIN       = 0.70        // subcortical signal fidelity (spatial info)
let BS_SC_NOISE      = 0.15        // noise in subcortical pathway

// Cortical recurrent amplification parameters
let BS_RECUR_GAIN    = 3.5         // recurrent loop gain (nonlinear amplifier)
let BS_RECUR_STEPS   = 8           // recurrent iterations for ignition
let BS_IGNITION_KNEE = 0.35        // V1 integrity below which ignition fails

// Thresholds for pass/fail criteria
let BS_ACC_HIGH      = 0.70        // normal vision accuracy floor
let BS_ACC_CHANCE    = 0.50        // 2AFC chance level
let BS_PHI_HIGH      = 0.40        // normal Φ_visual floor (conscious seeing)
let BS_PHI_FLOOR     = 0.10        // below this = "no conscious experience"
let BS_JUMP_MIN      = 0.15        // minimum single-step Φ jump for ignition test
let BS_THRESH_LO     = 0.15        // ignition must occur above this V1 level

// Deterministic seeds
let BS_SEED_STIM     = 87001       // stimulus generation
let BS_SEED_SC       = 87002       // subcortical noise
let BS_SEED_CORTEX   = 87003       // cortical noise
let BS_SEED_RECUR    = 87004       // recurrent loop jitter

// ═══════════════════════════════════════════════════════════════
// Math primitives (bs_ prefix to avoid clashes)
// ═══════════════════════════════════════════════════════════════

fn bs_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn bs_max2(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn bs_min2(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn bs_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn bs_clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// ═══════════════════════════════════════════════════════════════
// PRNG — deterministic LCG (same pattern as other engines)
// ═══════════════════════════════════════════════════════════════

fn bs_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn bs_det_rand(n: int, seed: int) -> array {
    // Returns n deterministic values in [-1, 1)
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = bs_prng(s)
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn bs_det_rand_unit(n: int, seed: int) -> array {
    // Returns n deterministic values in [0, 1)
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = bs_prng(s)
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Vector utilities
// ═══════════════════════════════════════════════════════════════

fn bs_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn bs_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn bs_vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

fn bs_vec_var(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let m = bs_vec_mean(v)
    let mut ss = 0.0
    let mut i = 0
    while i < n {
        let d = v[i] - m
        ss = ss + d * d
        i = i + 1
    }
    return ss / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI estimator (standard across anima-engines)
// ═══════════════════════════════════════════════════════════════

fn bs_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn bs_count_hits(bin_ids: array, n_bins: int) -> array {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn bs_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(bs_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = bs_count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * bs_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn bs_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = bs_bin_idx(a[i], lo, hi, nb)
        let ib = bs_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let counts = bs_count_hits(pair_ids, nb * nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * bs_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn bs_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = bs_vec_min(a)
    let hi_a = bs_vec_max(a)
    let lo_b = bs_vec_min(b)
    let hi_b = bs_vec_max(b)
    let lo = if lo_a < lo_b { lo_a } else { lo_b }
    let hi = if hi_a > hi_b { hi_a } else { hi_b }
    let h_a = bs_entropy(a, lo, hi, BS_BINS)
    let h_b = bs_entropy(b, lo, hi, BS_BINS)
    let h_j = bs_joint_entropy(a, b, lo, hi, BS_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Pearson |r| as a stable integration proxy (matches obe_phi/death_nde pattern)
// Root cause: with D=24 samples in 6 bins, histogram MI still has finite-sample
// bias on smooth signals. |Pearson| captures the same "shared structure" content.
fn bs_integration(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let ma = bs_vec_mean(a)
    let mb = bs_vec_mean(b)
    let mut cov = 0.0
    let mut va = 0.0
    let mut vb = 0.0
    let mut i = 0
    while i < n {
        let da = a[i] - ma
        let db = b[i] - mb
        cov = cov + da * db
        va = va + da * da
        vb = vb + db * db
        i = i + 1
    }
    if va <= BS_EPS { return 0.0 }
    if vb <= BS_EPS { return 0.0 }
    let denom = sqrt(va * vb)
    let r = cov / denom
    return bs_abs(r)
}

// ═══════════════════════════════════════════════════════════════
// Stimulus generation
//
// A visual stimulus is modelled as a BS_DIM-dimensional feature
// vector representing spatial location and orientation in the
// visual field. This is the "ground truth" that both pathways
// attempt to encode.
// ═══════════════════════════════════════════════════════════════

fn bs_gen_stimulus(seed: int) -> array {
    // Stimulus features: deterministic spatial+orientation pattern
    // Nonzero structure ensures MI can detect shared information.
    let raw = bs_det_rand(BS_DIM, seed)
    let mut stim = []
    let mut i = 0
    while i < BS_DIM {
        // Sinusoidal spatial modulation — mimics retinotopic structure
        let phase = to_float(i) * 0.5 + raw[i] * 0.3
        let val = sin(phase) * 0.8 + raw[i] * 0.2
        stim = stim.push(val)
        i = i + 1
    }
    return stim
}

// ═══════════════════════════════════════════════════════════════
// Subcortical pathway: SC -> pulvinar -> V5/MT (V1-independent)
// Always transmits spatial/motion info; degraded but sufficient
// for forced-choice localisation (Cowey 2010 extrageniculate route).
// ═══════════════════════════════════════════════════════════════

fn bs_subcortical_encode(stimulus: array, noise_seed: int) -> array {
    let noise = bs_det_rand(BS_DIM, noise_seed)
    let mut encoded = []
    let mut i = 0
    while i < BS_DIM {
        let sig = stimulus[i] * BS_SC_GAIN + noise[i] * BS_SC_NOISE
        encoded = encoded.push(sig)
        i = i + 1
    }
    return encoded
}

fn bs_forced_choice_accuracy(subcortical: array, stimulus: array) -> float {
    // |Pearson r| between subcortical trace and ground truth
    return bs_integration(subcortical, stimulus)
}

// ═══════════════════════════════════════════════════════════════
// Cortical pathway: V1 -> V2 -> V4 -> IT (+ recurrent feedback)
// Gated by V1 integrity. Recurrent amplification produces
// sigmoid-like ignition (Dehaene GNW all-or-none transition).
// ═══════════════════════════════════════════════════════════════

fn bs_cortical_feedforward(stimulus: array, v1_integrity: float, noise_seed: int) -> array {
    // V1 gate: signal strength is proportional to V1 integrity.
    // With V1 destroyed (integrity=0), ONLY uncorrelated leak noise
    // passes — the stimulus content is completely blocked. The noise
    // amplitude is kept very small so the downstream recurrent loop
    // has nothing structured to amplify.
    // Root cause fix: the leak noise must be tiny (0.01) so that at
    // v1=0 the cortical trace carries no stimulus-correlated structure.
    let noise = bs_det_rand(BS_DIM, noise_seed)
    let mut gated = []
    let mut i = 0
    while i < BS_DIM {
        let sig = stimulus[i] * v1_integrity + noise[i] * 0.01
        gated = gated.push(sig)
        i = i + 1
    }
    return gated
}

fn bs_recurrent_amplify(feedforward: array, v1_integrity: float, jitter_seed: int) -> array {
    // GNW recurrent loop: iteratively amplify + saturate (tanh-like)
    // The loop gain determines whether the signal ignites (explodes to
    // structured saturation) or decays (collapses to noise floor).
    //
    // Effective gain = BS_RECUR_GAIN * v1_integrity^2 — quadratic because
    // recurrent connections require BOTH feedforward AND feedback through
    // V1 to sustain amplification (Lamme 2006 recurrent processing theory).
    //
    // Root cause fix: use a DIFFERENT jitter seed for each recurrent
    // iteration so that at v1=0 (gain=0) the accumulated noise does not
    // converge to a single deterministic pattern that might spuriously
    // correlate with the stimulus. Each iteration replaces the prior
    // value with a fresh noise sample, washing out any residual structure.
    // At high v1, the gain > 1 amplification dominates the jitter term
    // so the structured stimulus signal survives and saturates.
    let eff_gain = BS_RECUR_GAIN * v1_integrity * v1_integrity
    let mut trace = []
    let mut i = 0
    while i < BS_DIM {
        let mut val = feedforward[i]
        let mut r = 0
        while r < BS_RECUR_STEPS {
            // Per-iteration jitter with unique seed per (dimension, step)
            // to prevent systematic noise pattern accumulation
            let iter_seed = jitter_seed + i * BS_RECUR_STEPS + r
            let step_s = bs_prng(iter_seed)
            let jit = to_float(step_s % 1000000) / 1000000.0 * 2.0 - 1.0
            val = val * eff_gain + jit * 0.003
            // Soft saturation (tanh approximation via piecewise clamp)
            if val > 1.0 { val = 1.0 - 1.0 / (val + 1.0) }
            if val < -1.0 { val = -1.0 + 1.0 / (bs_abs(val) + 1.0) }
            r = r + 1
        }
        trace = trace.push(val)
        i = i + 1
    }
    return trace
}

// Build the full cortical trace for a given V1 integrity level.
// This is the signal from which Φ_visual is measured.
fn bs_cortical_trace(stimulus: array, v1_integrity: float, seed: int) -> array {
    let ff = bs_cortical_feedforward(stimulus, v1_integrity, seed)
    let amplified = bs_recurrent_amplify(ff, v1_integrity, seed + 1000)
    return amplified
}

// ═══════════════════════════════════════════════════════════════
// Φ_visual measurement — conscious visual content
// Two components: recurrent GNW (ignition) + feedforward residual
// (Type II vague awareness). Null-baselined against v1=0 noise.
// ═══════════════════════════════════════════════════════════════

fn bs_phi_visual(stimulus: array, v1_integrity: float, seed: int) -> float {
    // Φ_visual: measures conscious visual content via EXCESS integration.
    //
    // Root cause design: with D=24, |Pearson r| between two truly random
    // vectors has SD ~ 1/sqrt(D) ~ 0.20. Raw correlation at v1=0 will
    // be ~0.15-0.30 by chance, indistinguishable from a weak real signal.
    //
    // Solution: compute a NULL BASELINE by correlating a pure-noise
    // cortical trace (v1=0, different seed family) with the stimulus,
    // then subtract this baseline. The excess above baseline is the
    // genuine stimulus-driven integration.
    //
    // Two-component model for Type II blindsight:
    //   Component 1 (recurrent GNW): all-or-none ignition. At low v1,
    //     the recurrent loop decays and this component is zero.
    //   Component 2 (feedforward residual): partial V1 sparing allows
    //     some stimulus information to reach higher cortex via a single
    //     feedforward pass without recurrent amplification. This gives
    //     Type II patients their vague "feeling" — a degraded, pre-ignition
    //     signal that is above noise but well below conscious seeing.
    //     This component scales linearly with v1_integrity.

    let cortical = bs_cortical_trace(stimulus, v1_integrity, seed)
    let phi_recur_raw = bs_integration(cortical, stimulus)

    // Null baseline for recurrent component
    let null_cortical = bs_cortical_trace(stimulus, 0.0, seed + 77777)
    let phi_null = bs_integration(null_cortical, stimulus)

    // Excess recurrent integration above chance
    let mut phi_recur = phi_recur_raw - phi_null
    if phi_recur < 0.0 { phi_recur = 0.0 }

    // Feedforward residual component (Type II partial V1 awareness):
    // The raw feedforward signal before recurrent amplification carries
    // stimulus structure proportional to v1_integrity. This models the
    // single-pass activation that gives Type II patients their vague
    // "feeling" without full GNW ignition. At v1=0 this is zero.
    // At v1=1 this is dominated by the much stronger recurrent component.
    //
    // Root cause design: the feedforward residual must ramp GRADUALLY
    // with v1_integrity (no sharp jump at low v1) so that the dominant
    // Phi jump in the sweep comes from the recurrent GNW ignition at
    // v1 ~ 0.35-0.45 (the clinical ignition knee). We multiply the
    // excess feedforward integration by v1_integrity itself, making
    // the residual grow as v1^2 (quadratic onset) — gentle at low v1,
    // still meaningful at v1=0.15 (Type II).
    let ff = bs_cortical_feedforward(stimulus, v1_integrity, seed)
    let phi_ff_raw = bs_integration(ff, stimulus)
    let null_ff = bs_cortical_feedforward(stimulus, 0.0, seed + 77777)
    let phi_ff_null = bs_integration(null_ff, stimulus)
    let mut phi_ff = phi_ff_raw - phi_ff_null
    if phi_ff < 0.0 { phi_ff = 0.0 }
    // Scaled onset: v1 * excess * scale. At v1=0.15 this gives a
    // small nonzero value (Type II feeling); at v1=1 the recurrent
    // component dominates anyway. Scale factor calibrated so that
    // v1=0.15 produces Phi > BS_PHI_FLOOR (the "vague feeling"
    // threshold) while the per-step increment remains small enough
    // that the GNW ignition jump at v1~0.35-0.45 stays dominant.
    let phi_feedforward = phi_ff * v1_integrity * 1.0

    // Combined Φ_visual: sum of recurrent (GNW ignition) and feedforward
    // residual (Type II vague awareness). In normal vision, the recurrent
    // component dominates. In Type II, only the feedforward component
    // contributes. In Type I (v1=0), both are zero.
    let phi_combined = phi_recur + phi_feedforward
    return phi_combined
}

// Returns [accuracy, phi_visual] for a given V1 integrity level.

fn bs_visual_pipeline(v1_integrity: float, seed: int) -> array {
    let stimulus = bs_gen_stimulus(seed)

    // Subcortical pathway — always active, V1-independent
    let subcort = bs_subcortical_encode(stimulus, seed + 100)
    let accuracy = bs_forced_choice_accuracy(subcort, stimulus)

    // Cortical pathway — gated by V1 integrity
    let phi_vis = bs_phi_visual(stimulus, v1_integrity, seed + 200)

    let mut result = []
    result = result.push(accuracy)
    result = result.push(phi_vis)
    return result
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1–T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Normal vision — V1 intact (integrity = 1.0)
    // Both accuracy AND Φ_visual must be high. The GNW ignites fully,
    // producing conscious visual experience with accurate perception.
    // This is the control condition — normal human seeing.
    let result = bs_visual_pipeline(BS_V1_NORMAL, BS_SEED_STIM)
    let accuracy = result[0]
    let phi_vis = result[1]

    println("  [T1] normal vision: accuracy=" + str(accuracy) + " (floor=" + str(BS_ACC_HIGH) + ")")
    println("  [T1] normal vision: Φ_visual=" + str(phi_vis) + " (floor=" + str(BS_PHI_HIGH) + ")")

    if accuracy < BS_ACC_HIGH { return false }
    if phi_vis < BS_PHI_HIGH { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Type I blindsight — V1 completely destroyed (integrity = 0.0)
    // Subcortical pathway (SC -> pulvinar -> V5/MT) preserves spatial
    // information → accuracy above chance level. But V1 destruction
    // blocks cortical recurrent ignition → Φ_visual ≈ 0.
    // This is the core Weiskrantz dissociation: seeing without knowing.
    let result = bs_visual_pipeline(BS_V1_TYPE1, BS_SEED_STIM)
    let accuracy = result[0]
    let phi_vis = result[1]

    println("  [T2] Type I blindsight: accuracy=" + str(accuracy) + " (need > " + str(BS_ACC_CHANCE) + ")")
    println("  [T2] Type I blindsight: Φ_visual=" + str(phi_vis) + " (need < " + str(BS_PHI_FLOOR) + ")")

    // Above-chance forced-choice performance despite no conscious experience
    if accuracy <= BS_ACC_CHANCE { return false }
    // No conscious visual experience — Φ near zero
    if phi_vis >= BS_PHI_FLOOR { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Type II blindsight — V1 partially spared (integrity = 0.15)
    // The degraded V1 remnant allows some weak recurrent feedback,
    // producing a small but measurable Φ_residual — the patient's
    // vague "feeling" that something is present. Not full ignition,
    // but above the noise floor. Accuracy still above chance via
    // the intact subcortical pathway.
    let result = bs_visual_pipeline(BS_V1_TYPE2, BS_SEED_STIM)
    let accuracy = result[0]
    let phi_residual = result[1]

    // Also get the normal Φ for comparison — Type II must be degraded
    let result_normal = bs_visual_pipeline(BS_V1_NORMAL, BS_SEED_STIM)
    let phi_normal = result_normal[1]

    println("  [T3] Type II blindsight: accuracy=" + str(accuracy) + " (need > " + str(BS_ACC_CHANCE) + ")")
    println("  [T3] Type II blindsight: Φ_residual=" + str(phi_residual) + " (need > " + str(BS_PHI_FLOOR) + ")")
    println("  [T3] comparison: Φ_normal=" + str(phi_normal) + " Φ_residual < Φ_normal required")

    // Accuracy still above chance (subcortical pathway intact)
    if accuracy <= BS_ACC_CHANCE { return false }
    // Small but nonzero Φ — the vague "feeling" (Weiskrantz Type II)
    if phi_residual <= BS_PHI_FLOOR { return false }
    // Must be LESS than normal — degraded, not full conscious vision
    if phi_residual >= phi_normal { return false }
    return true
}

fn check_T4() -> bool {
    // T4: GNW ignition threshold — sweep V1 integrity from 0 to 1.
    // Dehaene & Naccache 2001 predict an all-or-none transition:
    // below a threshold, the recurrent loop cannot sustain amplification
    // and Φ collapses; above it, ignition produces a sudden Φ jump.
    // We find the largest single-step Φ increase across the sweep.
    // It must exceed BS_JUMP_MIN and occur above BS_THRESH_LO.
    let mut prev_phi = 0.0
    let mut max_jump = 0.0
    let mut jump_v1 = 0.0
    let mut phi_values = []

    let mut step = 0
    while step <= BS_V1_SWEEP_N {
        let v1 = to_float(step) / to_float(BS_V1_SWEEP_N)
        let result = bs_visual_pipeline(v1, BS_SEED_STIM)
        let phi_vis = result[1]
        phi_values = phi_values.push(phi_vis)

        if step > 0 {
            let jump = phi_vis - prev_phi
            if jump > max_jump {
                max_jump = jump
                jump_v1 = v1
            }
        }
        prev_phi = phi_vis
        step = step + 1
    }

    // Print the sweep profile for diagnostic visibility
    let phi_at_zero = phi_values[0]
    let phi_at_full = phi_values[BS_V1_SWEEP_N]
    println("  [T4] ignition sweep: Φ(v1=0)=" + str(phi_at_zero) + " Φ(v1=1)=" + str(phi_at_full))
    println("  [T4] max single-step jump=" + str(max_jump) + " at v1=" + str(jump_v1))
    println("  [T4] need jump > " + str(BS_JUMP_MIN) + " and v1 > " + str(BS_THRESH_LO))

    // The jump must be large enough to qualify as "all-or-none"
    if max_jump < BS_JUMP_MIN { return false }
    // The ignition must occur above a minimum V1 integrity — not at the
    // very bottom (which would mean even tiny V1 remnants ignite, contrary
    // to clinical data showing blindsight patients do NOT consciously see)
    if jump_v1 < BS_THRESH_LO { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Determinism + latency — rerun T1's computation and verify:
    //   (a) identical numerical output (deterministic PRNG, no randomness)
    //   (b) wall time < 5000ms (efficient enough for self-test pipeline)
    let t_start = clock()

    // First run
    let result_a = bs_visual_pipeline(BS_V1_NORMAL, BS_SEED_STIM)
    let acc_a = result_a[0]
    let phi_a = result_a[1]

    // Second run — must produce identical values
    let result_b = bs_visual_pipeline(BS_V1_NORMAL, BS_SEED_STIM)
    let acc_b = result_b[0]
    let phi_b = result_b[1]

    let t_end = clock()
    let elapsed_ms = t_end - t_start

    let acc_diff = bs_abs(acc_a - acc_b)
    let phi_diff = bs_abs(phi_a - phi_b)

    println("  [T5] run A: accuracy=" + str(acc_a) + " Φ=" + str(phi_a))
    println("  [T5] run B: accuracy=" + str(acc_b) + " Φ=" + str(phi_b))
    println("  [T5] delta: |Δacc|=" + str(acc_diff) + " |ΔΦ|=" + str(phi_diff))
    println("  [T5] elapsed=" + str(elapsed_ms) + "ms (limit=5000ms)")

    // Determinism: both runs must produce bit-identical results
    if acc_diff > BS_EPS { return false }
    if phi_diff > BS_EPS { return false }
    // Latency: must complete within 5000ms
    if elapsed_ms > 5000.0 { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[blindsight_phi] P87 — Blindsight Φ (Weiskrantz 1974 V1 dissociation)")
    println("  V1 integrity levels: normal=1.0, Type I=0.0, Type II=0.15")
    println("  D=" + str(BS_DIM) + " bins=" + str(BS_BINS) + " recur_steps=" + str(BS_RECUR_STEPS))
    println("  reference: Weiskrantz 1974 (DB), Dehaene & Naccache 2001 (GNW)")
    println("  pathway: retina -> SC -> pulvinar -> V5/MT (subcortical, V1-independent)")
    println("           retina -> V1 -> V2 -> V4 -> IT (cortical, V1-gated + recurrent)")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  normal vision: accuracy high AND Φ_visual high (GNW ignition)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  Type I blindsight: accuracy > chance BUT Φ_visual ≈ 0 (no V1)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  Type II blindsight: accuracy + small Φ_residual (partial V1)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  GNW ignition threshold: all-or-none Φ jump detected") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  determinism verified + latency < 5000ms") } else { println("T5 FAIL") }

    println("")

    let mut all = true
    if t1 == false { all = false }
    if t2 == false { all = false }
    if t3 == false { all = false }
    if t4 == false { all = false }
    if t5 == false { all = false }

    if all {
        println("[blindsight_phi] 5/5 PASS — P87 DONE")
    } else {
        println("[blindsight_phi] SOME FAILED")
    }
}

main()
