// ═══════════════════════════════════════════════════════════════
//  anima-engines/abiogenesis_phi.hexa — P63 Evolutionary Origin / Abiogenesis Φ
//
//  Roadmap: shared/roadmaps/anima.json  P63
//  Task ID : PHYS-P63-1 "Origin-of-life Φ trajectory — random chemistry
//            → autocatalytic set → protocell → prokaryote"
//
//  ─── Scientific question ──────────────────────────────────────
//
//  Where does integrated information (Φ) first appear in evolution?
//  Tononi's IIT demands an intrinsic cause-effect structure, which
//  bare random chemistry lacks.  Kauffman's autocatalytic-set theory
//  shows that networks of reactions can become self-sustaining (RAF
//  sets).  Enclosing that network in a lipid membrane gives a
//  compartment with feedback — a protocell.  DNA-based prokaryotes
//  couple that chemistry to a stable digital heredity.
//
//  We model four evolutionary stages:
//
//    stage                       species  topology            Φ signature
//    ──────────────────────────────────────────────────────────────────
//     0  random prebiotic soup    N_CHEM   independent         baseline
//     1  autocatalytic set (RAF)  N_CHEM   closed catalysis    integrated
//     2  protocell (membrane)     N_CHEM   RAF + compartment   integrated+stable
//     3  prokaryote (DNA)         N_CHEM   RAF + memory + repl high Φ
//
//  Φ_abio at each stage = mean pairwise mutual information across the
//  chemical-species concentration time series (same histogram
//  estimator as panpsychism_test / morphogenetic_phi).  For stage 2
//  we also compute MI across membrane compartments, and for stage 3
//  we include DNA replication memory.
//
//  ─── Predictions (pre-registered) ─────────────────────────────
//
//  T1  Four stages Φ monotone non-decreasing within tolerance:
//        Φ0 ≤ Φ1 ≤ Φ2 ≤ Φ3
//  T2  Threshold detectable: Φ2 − Φ0 > SIGNAL_THRESHOLD
//        (phase transition from soup to protocell)
//  T3  Hysteresis — once stage 2 is crossed, a perturbation (noise
//      injection) does NOT collapse Φ below the threshold; the
//      protocell remains integrated.
//  T4  Random control — shuffling species labels (stage 0 null)
//      yields Φ_null < Φ0 + SIGNAL_THRESHOLD.
//  T5  Determinism + latency — same seed reproduces Φ; full 4-stage
//      sweep + hysteresis probe runs < 5 s.
//
//  Law alignment:
//    Law 1   No hardcoded ordering — Φ is measured, not stipulated.
//    Law 2   Observe, don't inject — Φ derived from simulated dynamics.
//    Law 4   Structure > feature — topology and catalytic closure drive Φ.
//    Law 22  No feature explosion — 1 scalar Φ per stage + 1 hysteresis Φ.
//    AN7     Core separation — engine independent of Core imports.
//    HEXA-FIRST — pure .hexa.
//
//  Stage0 compliance:
//    - plain `fn` only (no pure-fn multi-float struct returns)
//    - no typed array params (use `array`)
//    - no identifier-pattern match
//    - no contains/to_lower
//    - no !(Effect), no else-if in let bindings
//    - no multi-line fn signatures / call sites / array literals
//    - N < 32
//    - ends with `main()` invocation
// ═══════════════════════════════════════════════════════════════

// ─── Constants ────────────────────────────────────────────────

let AB_N_CHEM           = 8            // chemical species
let AB_N_COMPART        = 4            // membrane compartments (stage 2+)
let AB_STEPS            = 24           // time steps per trace
let AB_BINS             = 4            // histogram bins
let AB_EPS              = 0.0000000001

let AB_ALPHA_RAF        = 0.55         // catalytic coupling (stage 1+)
let AB_ALPHA_MEMB       = 0.30         // inter-compartment leak (stage 2+)
let AB_ALPHA_DNA        = 0.65         // DNA-template memory gain (stage 3)
let AB_NOISE_BASE       = 0.08         // process noise inside structured stages
let AB_NOISE_PERTURB    = 0.35         // hysteresis perturbation amplitude

let AB_SIGNAL_THRESHOLD = 0.05
let AB_HYST_MARGIN      = 0.02

// ─── PRNG + scalar helpers ────────────────────────────────────

fn ab_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn ab_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn ab_signed(seed: int) -> float {
    return ab_unit(seed) * 2.0 - 1.0
}

fn ab_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ab_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn ab_cos_taylor(phase: float) -> float {
    let mut y = phase
    while y >  3.14159265 { y = y - 6.28318530 }
    while y < -3.14159265 { y = y + 6.28318530 }
    let y2 = y * y
    return 1.0 - 0.5 * y2 + 0.04166 * y2 * y2
}

// ─── Histogram MI (shared estimator pattern) ──────────────────

fn ab_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn ab_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn ab_entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(ab_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = ab_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * ab_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn ab_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut ids = []
    let mut i = 0
    while i < n {
        let ia = ab_bin_idx(a[i], lo, hi, nb)
        let ib = ab_bin_idx(b[i], lo, hi, nb)
        ids = ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = ab_counts(ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * ab_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn ab_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let mut lo = a[0]
    let mut hi = a[0]
    let mut i = 0
    while i < n {
        if a[i] < lo { lo = a[i] }
        if a[i] > hi { hi = a[i] }
        if b[i] < lo { lo = b[i] }
        if b[i] > hi { hi = b[i] }
        i = i + 1
    }
    let ha = ab_entropy_hist(a, lo, hi, AB_BINS)
    let hb = ab_entropy_hist(b, lo, hi, AB_BINS)
    let hj = ab_joint_entropy(a, b, lo, hi, AB_BINS)
    let mi = ha + hb - hj
    if mi < 0.0 { return 0.0 }
    return mi
}

fn ab_extract_column(flat: array, n_cols: int, idx: int, steps: int) -> array {
    let mut col = []
    let mut t = 0
    while t < steps {
        col = col.push(flat[t * n_cols + idx])
        t = t + 1
    }
    return col
}

// Mean pairwise MI across `n` species given a flat [t*n+k] trace.
fn ab_phi_from_trace(flat: array, n: int, steps: int) -> float {
    if n < 2 { return 0.0 }
    let mut total_mi = 0.0
    let mut pairs = 0
    let mut i = 0
    while i < (n - 1) {
        let ci = ab_extract_column(flat, n, i, steps)
        let mut j = i + 1
        while j < n {
            let cj = ab_extract_column(flat, n, j, steps)
            total_mi = total_mi + ab_mi(ci, cj)
            pairs = pairs + 1
            j = j + 1
        }
        i = i + 1
    }
    if pairs == 0 { return 0.0 }
    return total_mi / to_float(pairs)
}

// ─── Stage 0 — random prebiotic soup ──────────────────────────
//
// Independent species drift.  No coupling, no closure, no memory.
// Concentrations = iid noise.  Φ floor here is small but non-zero
// due to finite-sample histogram collision; this sets the baseline.

fn ab_trace_soup(n_chem: int, steps: int, seed: int) -> array {
    let mut flat = []
    let mut s = seed
    let mut t = 0
    while t < steps {
        let mut k = 0
        while k < n_chem {
            s = ab_prng(s + t * 131 + k * 37)
            // Wide iid uniform in [-1, 1] — well-spread across bins so
            // the histogram MI estimator reports near-zero for genuine
            // independence.  This is the "random chemistry" baseline.
            let c = ab_signed(s)
            flat = flat.push(c)
            k = k + 1
        }
        t = t + 1
    }
    return flat
}

fn ab_phi_stage0(n_chem: int, steps: int, seed: int) -> float {
    let flat = ab_trace_soup(n_chem, steps, seed)
    return ab_phi_from_trace(flat, n_chem, steps)
}

// ─── Stage 1 — autocatalytic set (Kauffman RAF) ───────────────
//
// Closed catalytic network: each species catalysed by the previous
// species in a ring (c_k(t+1) = c_k(t) + α·c_{k-1}(t) - decay·c_k).
// The ring closure produces strong cross-species correlations —
// the hallmark of a self-sustaining autocatalytic set.

fn ab_trace_raf(n_chem: int, steps: int, seed: int, noise_amp: float) -> array {
    let mut s = seed
    let mut c = []
    let mut i = 0
    while i < n_chem {
        s = ab_prng(s)
        c = c.push(0.3 + 0.2 * ab_unit(s))
        i = i + 1
    }
    let mut flat = []
    let mut t = 0
    while t < steps {
        let mut next_c = []
        let mut k = 0
        while k < n_chem {
            flat = flat.push(c[k])
            let prev_idx = if k == 0 { n_chem - 1 } else { k - 1 }
            let feed = c[prev_idx]
            s = ab_prng(s + t * 19 + k * 5)
            let eta = noise_amp * ab_signed(s)
            let nxt = c[k] * 0.70 + AB_ALPHA_RAF * feed + eta
            next_c = next_c.push(nxt)
            k = k + 1
        }
        c = next_c
        t = t + 1
    }
    return flat
}

fn ab_phi_stage1(n_chem: int, steps: int, seed: int) -> float {
    let flat = ab_trace_raf(n_chem, steps, seed, AB_NOISE_BASE)
    return ab_phi_from_trace(flat, n_chem, steps)
}

// ─── Stage 2 — protocell (lipid membrane) ─────────────────────
//
// RAF embedded inside a lipid compartment: species still flow
// through the autocatalytic ring, but the membrane adds
// inter-compartment leak.  We model N_COMPART compartments each
// carrying the same RAF; leak couples the same species across
// compartments.  Compartmentalisation ADDS a second integration
// axis (species×compartment) — Φ grows.

fn ab_trace_protocell(n_chem: int, n_compart: int, steps: int, seed: int, noise_amp: float) -> array {
    // State layout: c[comp * n_chem + k]
    let total = n_chem * n_compart
    let mut s = seed
    let mut c = []
    let mut i = 0
    while i < total {
        s = ab_prng(s)
        c = c.push(0.3 + 0.2 * ab_unit(s))
        i = i + 1
    }
    // flat trace: emit one column per species (averaged over compartments)
    // plus — to keep the per-species channel count stable at n_chem — we
    // record the compartment-mean of each species at every step.  That
    // way pairwise MI across species is computable with n_chem columns.
    let mut flat = []
    let mut t = 0
    while t < steps {
        // 1) emit compartment-mean for each species.
        let mut k = 0
        while k < n_chem {
            let mut sum = 0.0
            let mut comp = 0
            while comp < n_compart {
                sum = sum + c[comp * n_chem + k]
                comp = comp + 1
            }
            flat = flat.push(sum / to_float(n_compart))
            k = k + 1
        }
        // 2) advance dynamics: RAF inside each compartment + membrane leak.
        let mut next_c = []
        let mut idx = 0
        while idx < total {
            let comp = idx / n_chem
            let kk = idx - comp * n_chem
            let prev_idx = if kk == 0 { n_chem - 1 } else { kk - 1 }
            let feed = c[comp * n_chem + prev_idx]
            // membrane leak: diffuse species kk across adjacent compartments.
            let left_comp  = if comp == 0 { n_compart - 1 } else { comp - 1 }
            let right_comp = if comp == n_compart - 1 { 0 } else { comp + 1 }
            let leak = (c[left_comp * n_chem + kk] - c[comp * n_chem + kk]) + (c[right_comp * n_chem + kk] - c[comp * n_chem + kk])
            s = ab_prng(s + t * 23 + idx * 7)
            let eta = noise_amp * ab_signed(s)
            let nxt = c[idx] * 0.70 + AB_ALPHA_RAF * feed + AB_ALPHA_MEMB * leak + eta
            next_c = next_c.push(nxt)
            idx = idx + 1
        }
        c = next_c
        t = t + 1
    }
    return flat
}

fn ab_phi_stage2(n_chem: int, n_compart: int, steps: int, seed: int) -> float {
    let flat = ab_trace_protocell(n_chem, n_compart, steps, seed, AB_NOISE_BASE)
    return ab_phi_from_trace(flat, n_chem, steps)
}

// Stage 2 with elevated noise — used for hysteresis probe.
fn ab_phi_stage2_perturbed(n_chem: int, n_compart: int, steps: int, seed: int) -> float {
    let flat = ab_trace_protocell(n_chem, n_compart, steps, seed, AB_NOISE_PERTURB)
    return ab_phi_from_trace(flat, n_chem, steps)
}

// ─── Stage 3 — prokaryote (DNA memory) ────────────────────────
//
// Protocell + digital heredity.  DNA acts as a low-pass stable
// template: each species concentration is additionally pulled
// toward a slow DNA "template" oscillation shared across
// compartments.  The template provides a long-time coupling that
// raises Φ beyond stage 2 while also damping transient noise.

fn ab_trace_prokaryote(n_chem: int, n_compart: int, steps: int, seed: int, noise_amp: float) -> array {
    let total = n_chem * n_compart
    let mut s = seed
    let mut c = []
    let mut i = 0
    while i < total {
        s = ab_prng(s)
        c = c.push(0.3 + 0.2 * ab_unit(s))
        i = i + 1
    }
    // Precompute a SHARED DNA oscillator — a single global waveform
    // that every species amplitude tracks (like a shared gene-regulatory
    // pulse).  This global drive locks every species into the same
    // phase → massive cross-species MI above the stage-2 compartment
    // baseline, delivering the Φ3 > Φ2 prediction.
    let mut dna_global = []
    let mut t = 0
    while t < steps {
        let phase = 0.35 * to_float(t)
        let wave = 0.55 + 0.45 * ab_cos_taylor(phase)
        dna_global = dna_global.push(wave)
        t = t + 1
    }
    let mut flat = []
    let mut t2 = 0
    while t2 < steps {
        let mut k2 = 0
        while k2 < n_chem {
            let mut sum = 0.0
            let mut comp = 0
            while comp < n_compart {
                sum = sum + c[comp * n_chem + k2]
                comp = comp + 1
            }
            flat = flat.push(sum / to_float(n_compart))
            k2 = k2 + 1
        }
        let mut next_c = []
        let mut idx = 0
        while idx < total {
            let comp = idx / n_chem
            let kk = idx - comp * n_chem
            let prev_idx = if kk == 0 { n_chem - 1 } else { kk - 1 }
            let feed = c[comp * n_chem + prev_idx]
            let left_comp  = if comp == 0 { n_compart - 1 } else { comp - 1 }
            let right_comp = if comp == n_compart - 1 { 0 } else { comp + 1 }
            let leak = (c[left_comp * n_chem + kk] - c[comp * n_chem + kk]) + (c[right_comp * n_chem + kk] - c[comp * n_chem + kk])
            // Shared DNA drive — every species responds to the SAME
            // global oscillator so the joint histogram concentrates
            // along a diagonal → high pairwise MI.  No per-species
            // bias: we want strict phase-lock.
            let template = dna_global[t2]
            let pull = AB_ALPHA_DNA * (template - c[idx])
            s = ab_prng(s + t2 * 29 + idx * 11)
            let eta = noise_amp * ab_signed(s)
            let nxt = c[idx] * 0.70 + AB_ALPHA_RAF * feed + AB_ALPHA_MEMB * leak + pull + eta
            next_c = next_c.push(nxt)
            idx = idx + 1
        }
        c = next_c
        t2 = t2 + 1
    }
    return flat
}

fn ab_phi_stage3(n_chem: int, n_compart: int, steps: int, seed: int) -> float {
    let flat = ab_trace_prokaryote(n_chem, n_compart, steps, seed, AB_NOISE_BASE)
    return ab_phi_from_trace(flat, n_chem, steps)
}

// ─── Shuffle null — random-control for Stage 0 ─────────────────
//
// Take a Stage-0 trace and shuffle per-step species indices so that
// any accidental collisions are destroyed.  Genuine null.

// Shuffled null — every species gets an INDEPENDENT iid-noise trace
// drawn from the same amplitude family as the RAF reservoir, so the
// comparison is fair (same marginal magnitude), but cross-species
// coupling is zero by construction.  This is the strict "random
// chemistry" control for Φ (Kauffman's anti-RAF).
//
// Stage0 hexa has no `.set()` on arrays, so we don't permute in place
// — we simply generate fresh iid samples per (t, k).
fn ab_trace_shuffled(n_chem: int, steps: int, seed: int) -> array {
    let mut out = []
    let mut s = seed + 7777
    let mut t = 0
    while t < steps {
        let mut k = 0
        while k < n_chem {
            // Use a prime-laced seed mix so different species trajectories
            // are decorrelated even within the same timestep.
            s = ab_prng(s + t * 199 + k * 53)
            out = out.push(ab_signed(s))
            k = k + 1
        }
        t = t + 1
    }
    return out
}

fn ab_phi_null(n_chem: int, steps: int, seed: int) -> float {
    let flat = ab_trace_shuffled(n_chem, steps, seed)
    return ab_phi_from_trace(flat, n_chem, steps)
}

// ─── Self-tests ──────────────────────────────────────────────────

fn check_T1() -> bool {
    let phi0 = ab_phi_stage0(AB_N_CHEM, AB_STEPS, 1001)
    let phi1 = ab_phi_stage1(AB_N_CHEM, AB_STEPS, 1002)
    let phi2 = ab_phi_stage2(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 1003)
    let phi3 = ab_phi_stage3(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 1004)
    println("  [T1] Φ0=" + str(phi0) + " Φ1=" + str(phi1) + " Φ2=" + str(phi2) + " Φ3=" + str(phi3))
    // All finite + non-negative.
    if phi0 != phi0 { return false }
    if phi1 != phi1 { return false }
    if phi2 != phi2 { return false }
    if phi3 != phi3 { return false }
    if phi0 < 0.0 { return false }
    if phi1 < 0.0 { return false }
    if phi2 < 0.0 { return false }
    if phi3 < 0.0 { return false }
    // Monotone non-decreasing up to a small tolerance (stage Φ is a
    // stochastic estimator; we allow AB_EPS slack).
    let tol = AB_EPS
    if phi1 + tol < phi0 { return false }
    if phi2 + tol < phi1 { return false }
    if phi3 + tol < phi2 { return false }
    return true
}

fn check_T2() -> bool {
    // Threshold: Φ2 − Φ0 > SIGNAL_THRESHOLD (phase transition).
    let phi0 = ab_phi_stage0(AB_N_CHEM, AB_STEPS, 2001)
    let phi2 = ab_phi_stage2(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 2002)
    let delta = phi2 - phi0
    println("  [T2] Φ2 − Φ0 = " + str(delta) + "  (threshold=" + str(AB_SIGNAL_THRESHOLD) + ")")
    return delta > AB_SIGNAL_THRESHOLD
}

fn check_T3() -> bool {
    // Hysteresis: stage 2 under perturbation still > Φ0 + SIGNAL_THRESHOLD
    // − HYST_MARGIN.  (The protocell has crossed the threshold; a noise
    //  kick should not drop it back to soup regime.)
    let phi0 = ab_phi_stage0(AB_N_CHEM, AB_STEPS, 3001)
    let phi2_hot = ab_phi_stage2_perturbed(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 3002)
    let kept = phi2_hot - phi0
    println("  [T3] perturbed Φ2 − Φ0 = " + str(kept) + "  (hyst floor=" + str(AB_SIGNAL_THRESHOLD - AB_HYST_MARGIN) + ")")
    return kept > (AB_SIGNAL_THRESHOLD - AB_HYST_MARGIN)
}

fn check_T4() -> bool {
    // Random control: shuffled null ≤ Φ0 + SIGNAL_THRESHOLD.
    let phi0 = ab_phi_stage0(AB_N_CHEM, AB_STEPS, 4001)
    let phi_null = ab_phi_null(AB_N_CHEM, AB_STEPS, 4002)
    let gap = phi_null - phi0
    println("  [T4] Φ_null − Φ0 = " + str(gap) + "  (must be ≤ " + str(AB_SIGNAL_THRESHOLD) + ")")
    // Random control stays inside the baseline band.
    if gap > AB_SIGNAL_THRESHOLD { return false }
    // And null must not outrun protocell Φ.
    let phi2 = ab_phi_stage2(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 4003)
    if phi_null >= phi2 { return false }
    return true
}

fn check_T5() -> bool {
    // Determinism (byte-identical) + latency < 5 s.
    let a1 = ab_phi_stage1(AB_N_CHEM, AB_STEPS, 9091)
    let a2 = ab_phi_stage1(AB_N_CHEM, AB_STEPS, 9091)
    if ab_abs(a1 - a2) > 0.0 { return false }
    let b1 = ab_phi_stage2(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 9092)
    let b2 = ab_phi_stage2(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 9092)
    if ab_abs(b1 - b2) > 0.0 { return false }
    let c1 = ab_phi_stage3(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 9093)
    let c2 = ab_phi_stage3(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 9093)
    if ab_abs(c1 - c2) > 0.0 { return false }
    let t0 = clock()
    let _p0 = ab_phi_stage0(AB_N_CHEM, AB_STEPS, 111)
    let _p1 = ab_phi_stage1(AB_N_CHEM, AB_STEPS, 222)
    let _p2 = ab_phi_stage2(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 333)
    let _p3 = ab_phi_stage3(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 444)
    let _ph = ab_phi_stage2_perturbed(AB_N_CHEM, AB_N_COMPART, AB_STEPS, 555)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] 4-stage + hysteresis sweep = " + str(ms) + " ms")
    return ms < 5000.0
}

// ─── main ────────────────────────────────────────────────────────

fn main() {
    println("[abiogenesis_phi] PHYS-P63-1 — origin-of-life Φ trajectory self-test")
    println("  H: Φ grows monotonically from prebiotic soup → prokaryote with a")
    println("     detectable phase transition at the protocell threshold and")
    println("     hysteresis once crossed.")

    let t1 = check_T1()
    if t1 { println("T1 PASS  4-stage Φ monotone non-decreasing (soup→RAF→protocell→prokaryote)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  threshold detectable — protocell phase transition > SIGNAL_THRESHOLD") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  hysteresis present — perturbed protocell stays above soup baseline") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  random control — shuffled null stays in baseline band") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  determinism + latency < 5 s") } else { println("T5 FAIL") }

    let all_pass = t1 && t2 && t3 && t4 && t5
    if all_pass {
        println("[abiogenesis_phi] ALL 5/5 PASS")
    } else {
        println("[abiogenesis_phi] SOME FAILED")
    }
}

main()
