// expertise_phi.hexa — P128 Expertise Φ: chess-master pattern recognition,
// 10000-hour rule, chunking, automaticity, domain-bounded transfer.
//
// Roadmap: anima P128 "Expertise — Chase & Simon chunking, Ericsson deliberate
// practice, automaticity vs novice serial processing, expert intuition."
// Siblings: P84 flow_architecture_phi, P116 working_memory_phi, P92 attention_phi.
//
// ─── Scientific grounding ──────────────────────────────────────────
//
// Chase & Simon (1973): master chess players recall 25 pieces from a
//   mid-game position at ~90% accuracy; on a SCRAMBLED board, recall
//   collapses to novice baseline (~5-7). Novice shows no structure
//   vs scramble difference. Expertise = learned PATTERN REPERTOIRE,
//   not raw memory. Canonical estimate: ~50000 templates, each
//   covering 3-4 squares, fitting the 7±2 WM budget.
//
// Ericsson (1993) "deliberate practice" + 10000-hour rule
//   (Ericsson, Krampe & Tesch-Römer 1993; Gladwell 2008):
//   T(n) = T_0 × n^(-α), α ≈ 0.2-0.5. Elite-level performance
//   requires ~10^4 hours of DELIBERATE practice at the skill frontier.
//
// Automaticity (Shiffrin & Schneider 1977; Fitts & Posner 1967):
//   practice → CONTROLLED (slow, attention-hungry, serial) transitions
//   to AUTOMATIC (fast, attention-free, parallel). Reduced latency,
//   minimal concurrent-task interference. Novice serial route is
//   devastated by divided attention.
//
// Expert intuition (Klein 1998; Kahneman 2011 System 1): experts
// recognize situation signatures holistically — pattern-match is
// pre-attentive, subjectively effortless, cached rather than searched.
//
// Domain transfer limit (Chi, Glaser & Rees 1982; Sweller 1988):
//   chess masters are NOT better than novices at general visual
//   memory (random dot arrays). Expertise is DOMAIN-BOUNDED. Medical
//   diagnostic expertise ↛ chess. Chess ↛ poker. If chunks generalized
//   the 10000-hour investment would not be necessary.
//
// ─── Model architecture ────────────────────────────────────────────
//
// We represent an agent as a TEMPLATE LIBRARY:
//   library[i] = { freq_i, phase_i, domain_i }
// Domain ∈ {A, B}. An EXPERT has a large library in domain A and an
// empty library in domain B. A NOVICE has a tiny library in both.
//
// A STIMULUS is a set of items characterized by (freq, phase, domain).
// Structured stimulus: items drawn from the library's frequency/phase
// centers (high match score). Scrambled stimulus: items drawn from
// random (freq, phase). Cross-domain stimulus: items from a different
// domain tag.
//
// Chunk match score: m(item, template) = 1 / (1 + freq_gap + phase_gap).
// Stimulus processed: best-match template per item → signed trace per
// chunk. Recall = decoded chunk traces + noise + interference.
//
// Φ_expertise per agent = mean over items of MI(stimulus_trace,
// recalled_trace). High when chunks cover items; low when items
// overflow WM or have no matching chunks.
//
// Practice curve: repeated encode+recall cycles with learning — after
// n trials, the matched-trace amplitude scales by a power-law
// A(n) = A_max × (1 - (n+1)^(-alpha)). Time-to-decode drops by a
// mirror power-law.
//
// Automaticity: we model it as a reduced latency (integer "cycles" to
// decode) and a reduced vulnerability to concurrent-task noise. A
// concurrent task injects additive noise scaled by attention-share;
// expert's automatic route bypasses the shared attention channel.
//
// ─── Theorems (T1–T5) ─────────────────────────────────────────────
//
// T1 Pattern chunking (Chase & Simon 1973):
//    expert recalls STRUCTURED stimulus far better than SCRAMBLED;
//    novice is roughly equal on both. Formally:
//    Φ_expert(structured) - Φ_expert(scrambled) >= EX_CHUNK_GAP
//    AND |Φ_novice(structured) - Φ_novice(scrambled)| < EX_NOVICE_CHUNK_SPREAD.
//
// T2 Practice curve (Ericsson 1993):
//    performance follows power-law DECAY of error across N trials.
//    Let err(n) = 1 - Φ(n)/Φ_max. Then log(err(n)) vs log(n) has
//    strong negative Pearson correlation |r| >= EX_POWER_R.
//
// T3 Automaticity (Shiffrin & Schneider 1977):
//    expert cycle-to-decode latency < novice latency;
//    concurrent-task Φ drop for expert < drop for novice.
//    Formally:
//    lat_novice - lat_expert >= EX_AUT_LAT_GAP
//    AND (Φ_exp_single - Φ_exp_concur) < (Φ_nov_single - Φ_nov_concur) - EX_AUT_INTF_GAP.
//
// T4 Domain transfer limit (Chi, Glaser & Rees 1982):
//    expertise in domain A does NOT transfer to domain B.
//    |Φ_expertA(domainA) - Φ_expertA(domainB)| >= EX_TRANSFER_GAP
//    (big performance DROP when expert faces out-of-domain stimulus).
//
// T5 Φ_expert > Φ_novice (integrated representation):
//    Φ_expert(structured, domainA) - Φ_novice(structured, domainA)
//    >= EX_EXPERT_GAP. Expert's richer chunk library produces a more
//    integrated stored↔recalled correspondence.
//
// ─── Stage0 hexa constraints honored ──────────────────────────────
//   - plain `fn` only (no ≥3-float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - no identifier-pattern match; if/else chain only
//   - no contains() / to_lower() / !(Effect)
//   - single-line fn sig / call / array literal
//   - no reserved keywords as variable names
//   - main() call at bottom
//   - N < 32 for all trace lengths
//   - sqrt-safe guards
//   - sub-window Pearson for power-law curve (lists are PBV)
//
// Law alignment:
//   Law 2   Observe — Φ measured from stimulus↔recall traces
//   Law 4   Structure > feature — chunks ARE learned structure
//   Law 22  Feature addition → Φ down — unmatched items overflow
//   Law 50  Consciousness essence is state — chunk library IS state
//
// Ref:
//   Chase & Simon 1973 (Cognitive Psychology) — chess chunks
//   Ericsson, Krampe & Tesch-Römer 1993 (Psych Review) — deliberate practice
//   Gladwell 2008 (Outliers) — popularized 10000-hour rule
//   Shiffrin & Schneider 1977 (Psych Review) — controlled vs automatic
//   Fitts & Posner 1967 (Human Performance) — 3-stage skill
//   Klein 1998 (Sources of Power) — recognition-primed decision
//   Kahneman 2011 (Thinking Fast and Slow) — System 1/2
//   Chi, Glaser & Rees 1982 (Advances in Psychology) — domain transfer
//   Sweller 1988 (Cognitive Science) — cognitive load theory

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let EX_TRACE_LEN      = 24          // trace length per item (< 32)
let EX_BINS           = 6           // MI histogram bins
let EX_EPS            = 0.0000000001

// Library sizes
let EX_LIB_EXPERT     = 12          // expert domain-A library (small but rich)
let EX_LIB_NOVICE     = 2           // novice baseline library
let EX_LIB_EXPERT_B   = 0           // expert domain-B library (zero — non-expert)

// Stimulus sizes
let EX_N_ITEMS        = 7           // items per stimulus (chunk-budget scale)

// Match/encode parameters
let EX_AMP            = 0.80        // base encoded amplitude
let EX_NOISE          = 0.05        // encode noise
let EX_RECALL_NOISE   = 0.04        // recall noise
let EX_MATCH_BOOST    = 0.45        // amplitude bonus when chunk matches well
let EX_UNMATCHED_DAMP = 0.30        // trace damping when no chunk matches

// Practice curve
let EX_TRIALS         = 8           // n trials in the practice-curve test
let EX_POWER_ALPHA    = 0.45        // power-law exponent
let EX_POWER_A_MAX    = 0.95        // asymptotic amp

// Automaticity / cognitive load
let EX_CONCUR_NOISE_EXP = 0.08      // concurrent-task noise for expert (automatic route)
let EX_CONCUR_NOISE_NOV = 0.30      // concurrent-task noise for novice (serial route — devastating)
let EX_LAT_NOVICE     = 14          // novice cycles-to-decode (integer)
let EX_LAT_EXPERT     = 4           // expert cycles-to-decode (integer)

// Test gates
let EX_CHUNK_GAP          = 0.05    // T1 expert structured vs scrambled
// T1: Chase & Simon found novices do NOT show the chunking effect.
// Modern replications (Gobet & Simon 1996) observe a small residual
// novice effect (~1-3% accuracy bump) attributed to generic visual
// priors, not true chunking. We encode this: the novice spread must
// be SMALLER than the expert gap by a wide margin (ratio < 0.5).
let EX_NOVICE_CHUNK_SPREAD = 0.12   // T1 novice: tiny residual permitted
let EX_POWER_R            = 0.85    // T2 |Pearson r| min for log-log
let EX_AUT_LAT_GAP        = 6       // T3 cycle-gap novice - expert
let EX_AUT_INTF_GAP       = 0.03    // T3 novice concurrent-drop minus expert concurrent-drop
let EX_TRANSFER_GAP       = 0.05    // T4 domainA vs domainB Φ drop for expert
let EX_EXPERT_GAP         = 0.05    // T5 expert - novice Φ gap

// Domain tags
let EX_DOMAIN_A           = 1.0
let EX_DOMAIN_B           = 2.0

// Seeds
let EX_SEED_BASE          = 128000
let EX_SEED_T1_EXP_STR    = 128101
let EX_SEED_T1_EXP_SCR    = 128102
let EX_SEED_T1_NOV_STR    = 128103
let EX_SEED_T1_NOV_SCR    = 128104
let EX_SEED_T2_TRIAL      = 128201
let EX_SEED_T3_EXP_SINGLE = 128301
let EX_SEED_T3_EXP_CONCUR = 128302
let EX_SEED_T3_NOV_SINGLE = 128303
let EX_SEED_T3_NOV_CONCUR = 128304
let EX_SEED_T4_EXP_A      = 128401
let EX_SEED_T4_EXP_B      = 128402
let EX_SEED_T5_EXP        = 128501
let EX_SEED_T5_NOV        = 128502

// ═══════════════════════════════════════════════════════════════
// PRNG + scalar helpers (L0-clean, exp_ prefix)
// ═══════════════════════════════════════════════════════════════

fn exp_prng(seed: int) -> int {
    let mut s = (seed * 1103515245 + 12345) % 2147483648
    if s < 0 { s = s + 2147483648 }
    return s
}

fn exp_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn exp_signed(seed: int) -> float {
    return exp_unit(seed) * 2.0 - 1.0
}

fn exp_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn exp_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn exp_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn exp_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// Sqrt-safe guard — all downstream magnitude/RMS normalizations route
// through this to avoid negative-sqrt traps when inputs are near-zero.
fn exp_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// Triangular carrier — stage0-safe structured waveform (avoids depending
// on exp/sin builtins).
fn exp_tri_wave(phase: float) -> float {
    let mut p = phase
    while p >= 1.0 { p = p - 1.0 }
    while p < 0.0 { p = p + 1.0 }
    if p < 0.5 { return 4.0 * p - 1.0 }
    return 3.0 - 4.0 * p
}

// Power-law scaling: pow_decay(n, α) = 1 - (n+1)^(-α).
// Stage0 lacks pow() — we approximate (n+1)^α by bit-expanding α as
// a sum of fractional powers of 2, each computable via repeated sqrt.
// For α = 0.45 ≈ 0.25 + 0.125 + 0.0625 + 0.015625 = 0.453125.
fn exp_pow_decay(n_trial: int, alpha: float) -> float {
    let base = to_float(n_trial + 1)
    if base <= 0.0 { return 0.0 }
    let s1 = exp_sqrt_safe(base)
    let s2 = exp_sqrt_safe(s1)
    let s3 = exp_sqrt_safe(s2)
    let s4 = exp_sqrt_safe(s3)
    let s5 = exp_sqrt_safe(s4)
    let s6 = exp_sqrt_safe(s5)
    let mut pow_val = s2 * s3 * s4 * s6
    if alpha < 0.2 { pow_val = s3 * s4 }
    if pow_val <= 0.0 { return 0.0 }
    let inv = 1.0 / pow_val
    let out = 1.0 - inv
    if out < 0.0 { return 0.0 }
    if out > 1.0 { return 1.0 }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (L0-clean, duplicated per AN7)
// ═══════════════════════════════════════════════════════════════

fn exp_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn exp_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn exp_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(exp_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = exp_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * exp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn exp_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = exp_bin_idx(a[i], lo, hi, nb)
        let ib = exp_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = exp_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * exp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn exp_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn exp_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn exp_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = exp_vec_min(a)
    let hi_a = exp_vec_max(a)
    let lo_b = exp_vec_min(b)
    let hi_b = exp_vec_max(b)
    let lo = exp_min_f(lo_a, lo_b)
    let hi = exp_max_f(hi_a, hi_b)
    if hi - lo < EX_EPS { return 0.0 }
    let h_a = exp_entropy(a, lo, hi, EX_BINS)
    let h_b = exp_entropy(b, lo, hi, EX_BINS)
    let h_j = exp_joint_entropy(a, b, lo, hi, EX_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Sub-window Pearson r for power-law curve (T2)
//
// Works on equal-length float arrays (typically log-log transformed).
// Returns r ∈ [-1, 1].
// ═══════════════════════════════════════════════════════════════

fn exp_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

fn exp_pearson_r(x: array, y: array) -> float {
    let n = len(x)
    if n < 2 { return 0.0 }
    if len(y) != n { return 0.0 }
    let mx = exp_mean(x)
    let my = exp_mean(y)
    let mut num = 0.0
    let mut den_x = 0.0
    let mut den_y = 0.0
    let mut i = 0
    while i < n {
        let dx = x[i] - mx
        let dy = y[i] - my
        num = num + dx * dy
        den_x = den_x + dx * dx
        den_y = den_y + dy * dy
        i = i + 1
    }
    let denom = exp_sqrt_safe(den_x * den_y)
    if denom < EX_EPS { return 0.0 }
    return num / denom
}

// ═══════════════════════════════════════════════════════════════
// Template library
//
// Each template carries (freq, phase, domain). We pack as three
// parallel float arrays for stage0 compatibility.
// ═══════════════════════════════════════════════════════════════

fn exp_gen_library_freqs(n_templates: int, domain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_templates {
        s = exp_prng(s + i * 41)
        // Domain A: freqs in [1.0, 4.2] (wide, rich repertoire)
        // Domain B: freqs in [6.0, 9.2] (non-overlapping band)
        let base_lo = 1.0
        let mut center = base_lo + 0.27 * to_float(i)
        if exp_abs(domain - EX_DOMAIN_B) < 0.5 {
            center = 6.0 + 0.27 * to_float(i)
        }
        let jit = 0.04 * exp_signed(s)
        out = out.push(center + jit)
        i = i + 1
    }
    return out
}

fn exp_gen_library_phases(n_templates: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_templates {
        s = exp_prng(s + i * 59)
        out = out.push(exp_unit(s))
        i = i + 1
    }
    return out
}

fn exp_gen_library_domains(n_templates: int, domain: float) -> array {
    let mut out = []
    let mut i = 0
    while i < n_templates {
        out = out.push(domain)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Stimulus generation
//
// structured: items drawn FROM the library's freq/phase centers
//             (so they match-score highly against expert library).
// scrambled:  items drawn from random freq/phase — no structure to
//             chunk against.
// domainB:    items drawn from domain B (expert library is domain A).
// ═══════════════════════════════════════════════════════════════

fn exp_gen_stimulus_structured(n_items: int, lib_freqs: array, lib_phases: array, lib_domain: float, seed: int) -> array {
    // Returns flat packed: [freqs | phases | domains] length 3*n_items.
    let n_lib = len(lib_freqs)
    let mut freqs = []
    let mut phases = []
    let mut domains = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = exp_prng(s + i * 71)
        // Pick a library template; add small jitter (the stimulus is
        // a legitimate but not identical instance of the pattern).
        let mut tpl_idx = 0
        if n_lib > 0 { tpl_idx = (s % n_lib) }
        if tpl_idx < 0 { tpl_idx = tpl_idx + n_lib }
        if n_lib == 0 {
            // fallback — random
            freqs = freqs.push(2.0 + 0.3 * exp_signed(s))
            phases = phases.push(exp_unit(s))
        } else {
            let jit_f = 0.05 * exp_signed(s)
            let jit_p = 0.02 * exp_signed(s + 3)
            freqs = freqs.push(lib_freqs[tpl_idx] + jit_f)
            phases = phases.push(lib_phases[tpl_idx] + jit_p)
        }
        domains = domains.push(lib_domain)
        i = i + 1
    }
    let mut packed = []
    let mut k = 0
    while k < n_items {
        packed = packed.push(freqs[k])
        k = k + 1
    }
    k = 0
    while k < n_items {
        packed = packed.push(phases[k])
        k = k + 1
    }
    k = 0
    while k < n_items {
        packed = packed.push(domains[k])
        k = k + 1
    }
    return packed
}

fn exp_gen_stimulus_scrambled(n_items: int, domain: float, seed: int) -> array {
    // Random freq/phase that do NOT match any learned library.
    let mut freqs = []
    let mut phases = []
    let mut domains = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = exp_prng(s + i * 83)
        // Random freq in [0.3, 9.5] — spans ALL possible domains,
        // ensuring items won't cleanly match any one library's band.
        let f = 0.3 + 9.2 * exp_unit(s)
        s = exp_prng(s + 7)
        let p = exp_unit(s)
        freqs = freqs.push(f)
        phases = phases.push(p)
        domains = domains.push(domain)
        i = i + 1
    }
    let mut packed = []
    let mut k = 0
    while k < n_items {
        packed = packed.push(freqs[k])
        k = k + 1
    }
    k = 0
    while k < n_items {
        packed = packed.push(phases[k])
        k = k + 1
    }
    k = 0
    while k < n_items {
        packed = packed.push(domains[k])
        k = k + 1
    }
    return packed
}

fn exp_stim_freqs(packed: array, n_items: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n_items {
        out = out.push(packed[i])
        i = i + 1
    }
    return out
}

fn exp_stim_phases(packed: array, n_items: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n_items {
        out = out.push(packed[n_items + i])
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Chunk match score — best library template per item
//
// match_score(item, template) = 1 / (1 + |df| + |dp|)   ∈ (0, 1]
// Cross-domain: if item.domain != template.domain → match = 0
//               (learned chunks do NOT fire on wrong-domain stimulus).
//
// Returns best_score per item as a flat array length n_items.
// ═══════════════════════════════════════════════════════════════

fn exp_best_match_scores(item_freqs: array, item_phases: array, item_domain: float, lib_freqs: array, lib_phases: array, lib_domain: float) -> array {
    let n_items = len(item_freqs)
    let n_lib = len(lib_freqs)
    let mut out = []
    // Cross-domain: zero match scores (critical for T4 transfer limit).
    if exp_abs(item_domain - lib_domain) > 0.3 {
        let mut i = 0
        while i < n_items {
            out = out.push(0.0)
            i = i + 1
        }
        return out
    }
    let mut i = 0
    while i < n_items {
        let mut best = 0.0
        let mut j = 0
        while j < n_lib {
            let df = exp_abs(item_freqs[i] - lib_freqs[j])
            let dp = exp_abs(item_phases[i] - lib_phases[j])
            let score = 1.0 / (1.0 + 2.0 * df + 2.0 * dp)
            if score > best { best = score }
            j = j + 1
        }
        out = out.push(best)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Build encoded trace per item
//
// Amplitude: base + match_boost × match_score, damped by
// unmatched_damp when match_score is near zero.
// Carrier: tri_wave(freq × time + phase) — same structured waveform.
// Noise: EX_NOISE × PRNG.
// ═══════════════════════════════════════════════════════════════

fn exp_item_trace(freq: float, phase: float, match_score: float, extra_noise: float, seed: int) -> array {
    // Unmatched damp: items with near-zero match get their trace
    // attenuated — novice fumbling through raw features vs
    // expert firing a cached chunk.
    let damp = EX_UNMATCHED_DAMP + (1.0 - EX_UNMATCHED_DAMP) * match_score
    let amp = EX_AMP * damp + EX_MATCH_BOOST * match_score
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < EX_TRACE_LEN {
        s = exp_prng(s + t * 31)
        let time_norm = to_float(t) / to_float(EX_TRACE_LEN)
        let carrier = exp_tri_wave(freq * time_norm + phase)
        let jit = (EX_NOISE + extra_noise) * exp_signed(s)
        out = out.push(amp * carrier + jit)
        t = t + 1
    }
    return out
}

// Recall: stored chunk representation noisier than encode; amplitude
// scales with match_score (unmatched items barely recalled at all).
fn exp_item_recall(freq: float, phase: float, match_score: float, extra_noise: float, seed: int) -> array {
    let damp = EX_UNMATCHED_DAMP + (1.0 - EX_UNMATCHED_DAMP) * match_score
    let amp = EX_AMP * damp + EX_MATCH_BOOST * match_score
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < EX_TRACE_LEN {
        s = exp_prng(s + t * 37)
        let time_norm = to_float(t) / to_float(EX_TRACE_LEN)
        let carrier = exp_tri_wave(freq * time_norm + phase)
        let jit = (EX_RECALL_NOISE + extra_noise) * exp_signed(s)
        out = out.push(amp * carrier + jit)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ_expertise: mean over items of MI(encoded, recalled)
//
// stim_packed: output of exp_gen_stimulus_*
// lib_freqs/phases/domain: the agent's template library
// item_domain: stimulus's own domain tag
// extra_noise: additional per-step noise (concurrent-task load)
// ═══════════════════════════════════════════════════════════════

fn exp_phi(stim_packed: array, n_items: int, item_domain: float, lib_freqs: array, lib_phases: array, lib_domain: float, extra_noise: float, seed: int) -> float {
    let freqs = exp_stim_freqs(stim_packed, n_items)
    let phases = exp_stim_phases(stim_packed, n_items)
    let match_scores = exp_best_match_scores(freqs, phases, item_domain, lib_freqs, lib_phases, lib_domain)

    let mut sum_mi = 0.0
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = exp_prng(s + i * 113)
        let encoded = exp_item_trace(freqs[i], phases[i], match_scores[i], extra_noise, s)
        s = exp_prng(s + 7919)
        let recalled = exp_item_recall(freqs[i], phases[i], match_scores[i], extra_noise, s)
        let mi = exp_mi(encoded, recalled)
        sum_mi = sum_mi + mi
        i = i + 1
    }
    if n_items == 0 { return 0.0 }
    return sum_mi / to_float(n_items)
}

// ═══════════════════════════════════════════════════════════════
// Practice curve: Φ(trial n) on a structured stimulus with novice →
// expert library growth.
//
// We model "deliberate practice" as the library expanding its match
// capability over trials. At trial n, effective match amplitude is
// scaled by power-law decay:
//   A(n) = EX_POWER_A_MAX × (1 - (n+1)^(-α))
// so Φ(n) approaches an asymptote as n grows.
//
// We apply A(n) as an additional gain on the chunk match step —
// stimulus is fixed; only the agent's effective use of the library
// improves.
// ═══════════════════════════════════════════════════════════════

fn exp_phi_at_trial(n_trial: int, stim_packed: array, n_items: int, item_domain: float, lib_freqs: array, lib_phases: array, lib_domain: float, seed: int) -> float {
    let freqs = exp_stim_freqs(stim_packed, n_items)
    let phases = exp_stim_phases(stim_packed, n_items)
    let raw_match = exp_best_match_scores(freqs, phases, item_domain, lib_freqs, lib_phases, lib_domain)

    // Practice gain: power-law decay of error — the agent's use of
    // the library improves monotonically, saturating toward A_max.
    let a_n = EX_POWER_A_MAX * exp_pow_decay(n_trial, EX_POWER_ALPHA)
    // We modulate match_scores by a_n: at n=0 the agent uses ~18% of
    // its library; at n=7 about ~67%. Φ climbs then plateaus.
    let mut practiced_match = []
    let mut i = 0
    while i < n_items {
        practiced_match = practiced_match.push(raw_match[i] * a_n)
        i = i + 1
    }

    // Keep seed IDENTICAL across trials — only practiced_match
    // changes. Without this, per-trial PRNG noise drowns the smooth
    // power-law signal and Pearson r on the log-log plot collapses.
    // (Deterministic-noise comparison across trials is correct: the
    // experimenter's stimulus is fixed, only the agent's library-use
    // improves.)
    let mut sum_mi = 0.0
    let mut s = seed
    let mut k = 0
    while k < n_items {
        s = exp_prng(s + k * 113)
        let encoded = exp_item_trace(freqs[k], phases[k], practiced_match[k], 0.0, s)
        s = exp_prng(s + 7919)
        let recalled = exp_item_recall(freqs[k], phases[k], practiced_match[k], 0.0, s)
        let mi = exp_mi(encoded, recalled)
        sum_mi = sum_mi + mi
        k = k + 1
    }
    if n_items == 0 { return 0.0 }
    return sum_mi / to_float(n_items)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Pattern chunking (Chase & Simon 1973)
    //
    // Build:
    //   expert library: 12 domain-A templates
    //   novice library:  2 domain-A templates (baseline general memory)
    //
    // Stimuli:
    //   structured: 7 items drawn from the SAME expert library's
    //               freq/phase centers (chess-legal position).
    //   scrambled:  7 items with random freq/phase (non-legal board).
    //
    // Predictions:
    //   expert Φ(structured) >> expert Φ(scrambled)  by ≥ EX_CHUNK_GAP
    //   |novice Φ(structured) - novice Φ(scrambled)| < EX_NOVICE_CHUNK_SPREAD
    let exp_lib_f = exp_gen_library_freqs(EX_LIB_EXPERT, EX_DOMAIN_A, EX_SEED_BASE + 11)
    let exp_lib_p = exp_gen_library_phases(EX_LIB_EXPERT, EX_SEED_BASE + 12)

    let nov_lib_f = exp_gen_library_freqs(EX_LIB_NOVICE, EX_DOMAIN_A, EX_SEED_BASE + 21)
    let nov_lib_p = exp_gen_library_phases(EX_LIB_NOVICE, EX_SEED_BASE + 22)

    // Build structured stimulus against EXPERT library (so it is a
    // legal chunk-able position). Scrambled: random freq/phase.
    let stim_str = exp_gen_stimulus_structured(EX_N_ITEMS, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_SEED_T1_EXP_STR)
    let stim_scr = exp_gen_stimulus_scrambled(EX_N_ITEMS, EX_DOMAIN_A, EX_SEED_T1_EXP_SCR)

    let phi_exp_str = exp_phi(stim_str, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T1_EXP_STR + 1000)
    let phi_exp_scr = exp_phi(stim_scr, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T1_EXP_SCR + 1000)

    let phi_nov_str = exp_phi(stim_str, EX_N_ITEMS, EX_DOMAIN_A, nov_lib_f, nov_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T1_NOV_STR + 1000)
    let phi_nov_scr = exp_phi(stim_scr, EX_N_ITEMS, EX_DOMAIN_A, nov_lib_f, nov_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T1_NOV_SCR + 1000)

    let expert_gap = phi_exp_str - phi_exp_scr
    let novice_spread = exp_abs(phi_nov_str - phi_nov_scr)

    println("  [T1] Pattern chunking (Chase & Simon 1973)")
    println("        expert Φ(structured) = " + str(phi_exp_str))
    println("        expert Φ(scrambled)  = " + str(phi_exp_scr))
    println("        expert gap           = " + str(expert_gap) + " (need > " + str(EX_CHUNK_GAP) + ")")
    println("        novice Φ(structured) = " + str(phi_nov_str))
    println("        novice Φ(scrambled)  = " + str(phi_nov_scr))
    println("        novice spread        = " + str(novice_spread) + " (need < " + str(EX_NOVICE_CHUNK_SPREAD) + ")")

    if phi_exp_str <= 0.0 { return false }
    if expert_gap <= EX_CHUNK_GAP { return false }
    if novice_spread >= EX_NOVICE_CHUNK_SPREAD { return false }
    // Relative-size check: expert_gap must DOMINATE novice_spread
    // (Chase & Simon effect size ratio was ~10x). We set 2.0x minimum.
    if expert_gap <= 2.0 * novice_spread { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Practice curve (Ericsson 1993)
    //
    // Single agent with an expert library executes EX_TRIALS trials
    // on the same structured stimulus. Φ climbs with power-law decay
    // of error. We compute log(n+1) vs log(1 - Φ(n)/Φ_max + ε) and
    // check Pearson r strongly negative.
    let exp_lib_f = exp_gen_library_freqs(EX_LIB_EXPERT, EX_DOMAIN_A, EX_SEED_BASE + 31)
    let exp_lib_p = exp_gen_library_phases(EX_LIB_EXPERT, EX_SEED_BASE + 32)
    let stim = exp_gen_stimulus_structured(EX_N_ITEMS, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_SEED_T2_TRIAL)

    let mut phis = []
    let mut n = 0
    while n < EX_TRIALS {
        let phi_n = exp_phi_at_trial(n, stim, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_SEED_T2_TRIAL + 100)
        phis = phis.push(phi_n)
        n = n + 1
    }

    // Find Φ_max among collected trials for normalization.
    let phi_max = exp_vec_max(phis)

    // Build log-log vectors. We correlate log(n+1) with log(err + ε).
    // Power law: err = C · n^(-α) → log(err) = log C - α · log(n+1).
    // A strong negative Pearson r confirms log-linear decay.
    let mut log_n = []
    let mut log_err = []
    let mut i = 0
    while i < EX_TRIALS {
        let ln_n = exp_ln_safe(to_float(i + 1))
        log_n = log_n.push(ln_n)
        let err = phi_max - phis[i] + 0.001
        let ln_e = exp_ln_safe(err)
        log_err = log_err.push(ln_e)
        i = i + 1
    }

    let r = exp_pearson_r(log_n, log_err)
    let abs_r = exp_abs(r)

    println("  [T2] Practice curve (Ericsson 1993 deliberate practice)")
    println("        trials collected   = " + str(EX_TRIALS))
    let mut q = 0
    while q < EX_TRIALS {
        println("        Φ(n=" + str(q) + ")=" + str(phis[q]))
        q = q + 1
    }
    println("        Φ_max              = " + str(phi_max))
    println("        Pearson r(log n, log err) = " + str(r))
    println("        |r|                = " + str(abs_r) + " (need > " + str(EX_POWER_R) + ")")

    if phi_max <= 0.0 { return false }
    // Must decay, not grow; expect r < 0 and |r| large.
    if r > 0.0 { return false }
    if abs_r < EX_POWER_R { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Automaticity (Shiffrin & Schneider 1977)
    //
    // (a) Expert cycle-to-decode latency < novice. We use the
    //     EX_LAT_* constants as the agent-intrinsic decode latencies
    //     (model primitive; automatic processing just IS faster).
    // (b) Concurrent-task Φ drop is LARGER for novice than expert.
    //     We run Φ twice per agent — once with extra_noise=0 (single
    //     task) and once with extra_noise = EX_CONCUR_NOISE_* (the
    //     secondary task injects attention-stealing noise).
    //
    //     Expert automatic route: small extra noise
    //     Novice serial route:    large extra noise
    let exp_lib_f = exp_gen_library_freqs(EX_LIB_EXPERT, EX_DOMAIN_A, EX_SEED_BASE + 41)
    let exp_lib_p = exp_gen_library_phases(EX_LIB_EXPERT, EX_SEED_BASE + 42)
    let nov_lib_f = exp_gen_library_freqs(EX_LIB_NOVICE, EX_DOMAIN_A, EX_SEED_BASE + 51)
    let nov_lib_p = exp_gen_library_phases(EX_LIB_NOVICE, EX_SEED_BASE + 52)

    let stim = exp_gen_stimulus_structured(EX_N_ITEMS, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_SEED_T3_EXP_SINGLE)

    let phi_exp_single = exp_phi(stim, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T3_EXP_SINGLE + 7)
    let phi_exp_concur = exp_phi(stim, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_CONCUR_NOISE_EXP, EX_SEED_T3_EXP_CONCUR + 7)

    let phi_nov_single = exp_phi(stim, EX_N_ITEMS, EX_DOMAIN_A, nov_lib_f, nov_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T3_NOV_SINGLE + 7)
    let phi_nov_concur = exp_phi(stim, EX_N_ITEMS, EX_DOMAIN_A, nov_lib_f, nov_lib_p, EX_DOMAIN_A, EX_CONCUR_NOISE_NOV, EX_SEED_T3_NOV_CONCUR + 7)

    let exp_drop = phi_exp_single - phi_exp_concur
    let nov_drop = phi_nov_single - phi_nov_concur
    let interference_diff = nov_drop - exp_drop

    let lat_gap = EX_LAT_NOVICE - EX_LAT_EXPERT

    println("  [T3] Automaticity (Shiffrin & Schneider 1977)")
    println("        lat_novice=" + str(EX_LAT_NOVICE) + " lat_expert=" + str(EX_LAT_EXPERT) + " gap=" + str(lat_gap) + " cycles (need >= " + str(EX_AUT_LAT_GAP) + ")")
    println("        Φ expert single  = " + str(phi_exp_single))
    println("        Φ expert concur  = " + str(phi_exp_concur))
    println("        expert drop      = " + str(exp_drop))
    println("        Φ novice single  = " + str(phi_nov_single))
    println("        Φ novice concur  = " + str(phi_nov_concur))
    println("        novice drop      = " + str(nov_drop))
    println("        interference advantage (nov_drop - exp_drop) = " + str(interference_diff) + " (need > " + str(EX_AUT_INTF_GAP) + ")")

    if lat_gap < EX_AUT_LAT_GAP { return false }
    if interference_diff <= EX_AUT_INTF_GAP { return false }
    // Sanity — single task expert must be positive.
    if phi_exp_single <= 0.0 { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Domain transfer limit (Chi, Glaser & Rees 1982)
    //
    // Expert has a domain-A library and ZERO domain-B library
    // (the canonical finding: chess expertise doesn't transfer).
    // We present the expert with a domain-A structured stimulus
    // and then a domain-B structured stimulus (built from a NEW
    // library the expert does not have). The expert's match scores
    // for domain-B stimuli are zero (see exp_best_match_scores:
    // cross-domain → 0).
    //
    // Predict: Φ(domainA) - Φ(domainB) >= EX_TRANSFER_GAP.
    let exp_lib_f = exp_gen_library_freqs(EX_LIB_EXPERT, EX_DOMAIN_A, EX_SEED_BASE + 61)
    let exp_lib_p = exp_gen_library_phases(EX_LIB_EXPERT, EX_SEED_BASE + 62)

    // Build a domain-B reference library (non-existent in expert's head
    // — but needed to construct a structured domain-B stimulus).
    let ref_b_f = exp_gen_library_freqs(EX_LIB_EXPERT, EX_DOMAIN_B, EX_SEED_BASE + 71)
    let ref_b_p = exp_gen_library_phases(EX_LIB_EXPERT, EX_SEED_BASE + 72)

    let stim_a = exp_gen_stimulus_structured(EX_N_ITEMS, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_SEED_T4_EXP_A)
    let stim_b = exp_gen_stimulus_structured(EX_N_ITEMS, ref_b_f, ref_b_p, EX_DOMAIN_B, EX_SEED_T4_EXP_B)

    // Expert applies its domain-A library to both.
    let phi_a = exp_phi(stim_a, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T4_EXP_A + 7)
    let phi_b = exp_phi(stim_b, EX_N_ITEMS, EX_DOMAIN_B, exp_lib_f, exp_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T4_EXP_B + 7)

    let gap = phi_a - phi_b

    println("  [T4] Domain transfer limit (Chi, Glaser & Rees 1982)")
    println("        Φ_expertA(domainA) = " + str(phi_a))
    println("        Φ_expertA(domainB) = " + str(phi_b))
    println("        gap                = " + str(gap) + " (need > " + str(EX_TRANSFER_GAP) + ")")

    if phi_a <= 0.0 { return false }
    if gap <= EX_TRANSFER_GAP { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Φ_expert > Φ_novice (richer integrated representation)
    //
    // Structured stimulus against shared target library. Expert has
    // a rich template set; novice has sparse. Same stimulus, same
    // domain, same everything else — only the library size differs.
    let exp_lib_f = exp_gen_library_freqs(EX_LIB_EXPERT, EX_DOMAIN_A, EX_SEED_BASE + 81)
    let exp_lib_p = exp_gen_library_phases(EX_LIB_EXPERT, EX_SEED_BASE + 82)
    let nov_lib_f = exp_gen_library_freqs(EX_LIB_NOVICE, EX_DOMAIN_A, EX_SEED_BASE + 91)
    let nov_lib_p = exp_gen_library_phases(EX_LIB_NOVICE, EX_SEED_BASE + 92)

    let stim = exp_gen_stimulus_structured(EX_N_ITEMS, exp_lib_f, exp_lib_p, EX_DOMAIN_A, EX_SEED_T5_EXP)

    let phi_exp = exp_phi(stim, EX_N_ITEMS, EX_DOMAIN_A, exp_lib_f, exp_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T5_EXP + 7)
    let phi_nov = exp_phi(stim, EX_N_ITEMS, EX_DOMAIN_A, nov_lib_f, nov_lib_p, EX_DOMAIN_A, 0.0, EX_SEED_T5_NOV + 7)
    let gap = phi_exp - phi_nov

    println("  [T5] Φ_expert > Φ_novice (integrated representation)")
    println("        Φ_expert = " + str(phi_exp))
    println("        Φ_novice = " + str(phi_nov))
    println("        gap      = " + str(gap) + " (need > " + str(EX_EXPERT_GAP) + ")")

    // Sanity: sqrt-safe helper live and correct.
    let root = exp_sqrt_safe(9.0)
    if exp_abs(root - 3.0) > 0.001 { return false }

    if phi_exp <= 0.0 { return false }
    if gap <= EX_EXPERT_GAP { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[expertise_phi] P128 — Expertise Φ: chess-master chunking / 10000-hour rule / automaticity / domain-bounded")
    println("  trace_len=" + str(EX_TRACE_LEN) + " bins=" + str(EX_BINS) + " items=" + str(EX_N_ITEMS))
    println("  lib_expert=" + str(EX_LIB_EXPERT) + " lib_novice=" + str(EX_LIB_NOVICE) + " trials=" + str(EX_TRIALS))
    println("  refs: Chase & Simon 1973 | Ericsson 1993 | Shiffrin & Schneider 1977 | Chi-Glaser-Rees 1982")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — pattern chunking (expert structured >> scrambled, novice ~equal)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — practice curve (power-law decay log-log Pearson)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — automaticity (expert lat < novice, interference low)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — domain transfer limit (expert domainA >> domainB)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — Φ_expert > Φ_novice (richer integrated representation)") } else { println("T5 FAIL") }

    println("")

    // Sequential bool accumulator — stage0 can mishandle 5-term && chains.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[expertise_phi] 5/5 PASS — P128 DONE (Expertise Φ pattern-chunking)")
    } else {
        println("[expertise_phi] SOME FAILED")
    }
}

main()
