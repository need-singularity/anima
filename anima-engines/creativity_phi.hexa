// creativity_phi.hexa — P130 Creativity Φ (divergent thinking, originality × usefulness)
//
// Roadmap: shared/roadmaps/anima.json P130 emergent
//   "Creativity Φ — 창의성 의식 측정 (Guilford divergent + Mednick RAT + Boden + Amabile)"
//   done_criteria: "divergent fluency + remote association + originality×usefulness +
//                   incubation + Φ_creative > Φ_routine — 5/5 PASS"
//
// ─── Theoretical grounding ─────────────────────────────────────
//
// Four empirical anchors, each mapped to a measurable channel:
//
// 1. Guilford (1967) — "The Nature of Human Intelligence":
//    Divergent thinking is the cognitive operation that generates MANY
//    qualitatively different responses to an open-ended prompt. Three
//    measurable sub-components:
//      * Fluency      — number of candidates produced
//      * Flexibility  — number of distinct conceptual categories
//      * Originality  — statistical rarity of individual candidates
//    Operationalized as histogram spread + distinct-bin count of the
//    generated candidate distribution. Closed prompts (one expected
//    answer) yield a concentrated mass on a single bin; open prompts
//    spread mass across bins (high entropy + coverage).
//
// 2. Mednick (1962) — "The associative basis of the creative process":
//    The Remote Associates Test (RAT) formalizes creativity as the
//    ability to forge a BRIDGE between concepts with low transitional
//    probability — i.e. concepts that rarely co-occur but admit a
//    non-obvious shared associate. Classical RAT items: (cottage, swiss,
//    cake) → cheese. Operationalized as the MI between two sampled
//    concept channels whose joint distribution has heavy tails: a
//    creative bridge raises MI above a chance baseline even when the
//    pairwise transitional probability is low.
//
// 3. Boden (1991, 2004) — "The Creative Mind":
//    Three modes of creativity:
//      * Combinatorial    — novel combination of familiar elements
//      * Exploratory      — discovery within a conceptual space
//      * Transformational — alteration of the space itself
//    Combinatorial mode is the most tractable to operationalize: it
//    predicts that genuine creativity requires DUAL-DOMAIN integration
//    (distinct semantic sources) rather than within-domain recombination.
//    We compute it as pairwise MI across multiple independent concept
//    streams — a routine single-domain process has low cross-stream MI;
//    a creative combinatorial process has elevated cross-stream MI.
//
// 4. Amabile (1983) — "The social psychology of creativity":
//    "Creativity = originality × appropriateness" (also called
//    "originality × usefulness"). Crucial: BOTH factors are required.
//    Mere originality without usefulness is bizarreness; mere usefulness
//    without originality is routine. The product is what humans label
//    "creative". Operationalized as the geometric-mean-like product of
//    originality (statistical rarity) and usefulness (goal-alignment /
//    template match) — each in [0, 1], product also in [0, 1], and
//    crucially the product EXCEEDS the larger of the two inputs only
//    when BOTH are high. (We use the min-dominated joint: joint
//    = sqrt(orig × util), which rewards balance over one-side blow-up.)
//
// ─── Channel design ───────────────────────────────────────────
//
// The creative_state is a composite scalar in [0, 1] computed from:
//
//   fluency(candidates)          = H_hist(candidates) / ln(CRE_BINS) ∈ [0, 1]
//   originality(cand, baseline)  = 1 - max_bin_prob(cand) normalized ∈ [0, 1]
//   usefulness(cand, template)   = 1 - RMSE(cand, template) / scale   ∈ [0, 1]
//   combinatorial_MI(A, B)       = MI(streamA, streamB) / ln(BINS)    ∈ [0, 1]
//   incubation_gain              = post_break_originality − pre_break  ∈ [-1, 1]
//
//   Φ_creative = w_f · fluency + w_o · sqrt(orig × util) + w_c · combMI
//
// Weights sum to 1; the sqrt(orig × util) term enforces Amabile's AND
// (bizarre OR routine gets penalized; only "both high" passes).
//
// ─── 5 tests (5/5 gate) ────────────────────────────────────────
//
// T1 Divergent fluency (Guilford open vs closed prompt):
//   Open prompt generates candidates spread across many bins;
//   closed prompt concentrates mass on a single bin.
//   Gate: fluency(open) > fluency(closed) + CRE_FLUENCY_GAP.
//
// T2 Remote association (Mednick RAT):
//   Two concept channels sampled with low pairwise transitional
//   probability, plus a creative bridge that raises their MI above
//   chance. Gate: MI(A, B | creative_bridge) > MI(A, B | no_bridge)
//   + CRE_RAT_GAP, AND MI_bridge > CRE_RAT_MIN in absolute terms.
//
// T3 Originality × usefulness (Amabile joint):
//   Four candidates:
//     (a) bizarre (high orig, low util)         → joint ≈ 0
//     (b) routine (low orig, high util)         → joint ≈ 0
//     (c) creative (high orig, high util)       → joint high
//     (d) noise   (low orig, low util)          → joint ≈ 0
//   Gate: joint(c) > joint(a) AND joint(c) > joint(b) AND joint(c)
//   > max(orig(c), util(c)) is not required (the sqrt joint is ≤ max),
//   but joint(c) must exceed CRE_JOINT_MIN.
//
// T4 Incubation enhances (DMN-active break):
//   Continuous focus → originality plateau; DMN-active break (a stream
//   re-shuffle that breaks habitual grooves) → post-break candidates
//   show higher originality than pre-break. Models Smith 1991 /
//   Sio & Ormerod 2009 incubation literature.
//   Gate: originality(post_break) > originality(pre_break) + CRE_INC_GAP.
//
// T5 Φ_creative > Φ_routine (broader semantic integration):
//   Creative mode: multi-stream combinatorial + high joint + open prompt.
//   Routine mode:  single-stream + low joint + closed prompt.
//   Gate: Φ_creative > Φ_routine + CRE_SIGNAL_MIN, and Φ_creative >
//   CRE_SIGNAL_MIN in absolute terms.
//
// ─── Stage0 hexa constraints honored ───────────────────────────
//
//   - plain `fn` only (no pure-fn multi-float struct returns)
//   - `array` typed params, never `[float]` / `[int]`
//   - no identifier-pattern match; if-chains only
//   - no contains() / to_lower() builtins
//   - no !(Effect) annotations
//   - no else-if in let-binding chains
//   - single-line return expressions
//   - N < 32 for all arrays (CRE_N = 24)
//   - lists are pass-by-value; helpers return rebuilt arrays
//   - main() call at bottom
//   - sqrt used on clamped non-negative inputs only
//   - no reserved keywords as var names
//   - sequential `if !tk { all = false }` (no long && chains)
//
// Law alignment:
//   Law 2   Observe, never inject — creativity is MEASURED via hist/MI
//   Law 4   Structure > feature — joint orig × util is STRUCTURAL
//   Law 22  Feature addition → Φ down — minimal 3-term composite
//   Law 50  State = consciousness essence — creative IS state, not label
//
// Ref:
//   anima-engines/aesthetic_phi.hexa           (Birkhoff O/C + Wundt pattern)
//   anima-engines/mind_wandering_phi.hexa      (DMN + block design envelope)
//   anima-engines/curiosity_phi.hexa           (Info-gap + KL + fatigue)
//   anima-engines/intentionality_phi.hexa      (Directed MI primitives)
//   anima-engines/flow_architecture_phi.hexa   (Composite Φ weighting)
//   anima-engines/creative_engine.hexa         (P14 metaphor cosine prior art)
//   shared/roadmaps/anima.json                  (P130 candidate entry)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let CRE_N             = 24        // candidate channel length (stage0 N < 32)
let CRE_BINS          = 6         // histogram bins for entropy / MI
let CRE_EPS           = 0.0000000001

// Divergent thinking saturation scale — RMSE to template that counts
// as "fully useful" (RMSE ≤ CRE_USE_SCALE ⇒ util ≈ 1). Calibrated so
// that a random-noise candidate (RMSE ≈ 0.9) scores util ≈ 0.1, while
// a template-matching candidate (RMSE ≈ 0.1) scores util ≈ 0.9.
let CRE_USE_SCALE     = 1.0

// Composite weights — Φ_creative = w_f·fluency + w_o·sqrt(orig·util) + w_c·combMI
// Must sum to 1.0 so Φ is in [0, 1].
let CRE_W_FLUENCY     = 0.25      // divergent spread (Guilford)
let CRE_W_JOINT       = 0.45      // originality × usefulness (Amabile)
let CRE_W_COMB        = 0.30      // cross-stream MI (Boden combinatorial)

// Thresholds
let CRE_SIGNAL_MIN    = 0.08      // minimum detectable integrated Φ
let CRE_FLUENCY_GAP   = 0.15      // T1 open-vs-closed fluency gap
let CRE_RAT_MIN       = 0.05      // T2 bridged MI floor (nats / ln(bins))
let CRE_RAT_GAP       = 0.04      // T2 bridge-vs-baseline gap
let CRE_JOINT_MIN     = 0.30      // T3 creative (a)∧(b) joint floor
let CRE_INC_GAP       = 0.05      // T4 post- vs pre-break originality gain

// Windowed Pearson |r| size — combinatorial cross-stream correlation.
let CRE_WIN           = 12

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives — self-contained (L0-clean, AN7 no-import)
// ═══════════════════════════════════════════════════════════════

fn cre_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cre_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// sqrt wrapper — caller must guarantee x >= 0. Sqrt-safe defensive belt:
// returns 0 for any non-positive input so no NaN escapes into Φ.
fn cre_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn cre_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn cre_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn cre_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

fn cre_clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Deterministic LCG — reproducibility (Law 2)
fn cre_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn cre_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn cre_signed(seed: int) -> float {
    return cre_unit(seed) * 2.0 - 1.0
}

// Triangular wave — structured, trig-free oscillator for template signals.
fn cre_tri_wave(phase: float) -> float {
    let mut p = phase
    while p >= 1.0 { p = p - 1.0 }
    while p < 0.0 { p = p + 1.0 }
    if p < 0.5 { return 4.0 * p - 1.0 }
    return 3.0 - 4.0 * p
}

// ═══════════════════════════════════════════════════════════════
// Vector utilities
// ═══════════════════════════════════════════════════════════════

fn cre_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn cre_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn cre_vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Histogram + entropy primitives — binning is the core operation for
// both fluency (Guilford) and MI (Boden combinatorial / Mednick RAT).
// ═══════════════════════════════════════════════════════════════

fn cre_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn cre_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

// Shannon entropy (nats) over a vector binned into `nb` equal-width bins,
// with a FIXED range [-1, 1]. Critical: auto-scaling the bin range to the
// vector's own min/max breaks the closed-vs-open prompt distinction —
// a tiny-amplitude closed-prompt cluster (e.g. ±0.04 around 0.3) would
// then spread across all bins after rescaling, scoring max entropy. Fixed
// [-1, 1] range gives the structural answer: tight clusters occupy 1 bin
// → entropy 0, spread distributions occupy many bins → entropy near max.
fn cre_entropy(v: array, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(cre_bin_idx(v[i], -1.0, 1.0, nb))
        i = i + 1
    }
    let cnt = cre_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * cre_ln_safe(p) }
        k = k + 1
    }
    return h
}

// Count of DISTINCT occupied histogram bins (FIXED range [-1, 1]).
// A closed prompt → 1 occupied bin; an open prompt → many. Fixed-range
// binning is essential — see cre_entropy comment above.
fn cre_distinct_bins(v: array, nb: int) -> int {
    let n = len(v)
    if n == 0 { return 0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(cre_bin_idx(v[i], -1.0, 1.0, nb))
        i = i + 1
    }
    let cnt = cre_counts(ids, nb)
    let mut occ = 0
    let mut k = 0
    while k < nb {
        if cnt[k] > 0.0 { occ = occ + 1 }
        k = k + 1
    }
    return occ
}

// Max-bin probability — fraction of mass in the single most-populated bin
// (FIXED range [-1, 1]). A concentrated distribution → ≈ 1; a spread
// distribution → ≈ 1/nb. Fixed range required for closed/open separation.
fn cre_max_bin_prob(v: array, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 1.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(cre_bin_idx(v[i], -1.0, 1.0, nb))
        i = i + 1
    }
    let cnt = cre_counts(ids, nb)
    let mut top = 0.0
    let mut k = 0
    while k < nb {
        if cnt[k] > top { top = cnt[k] }
        k = k + 1
    }
    return top / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Mutual information — for Boden combinatorial + Mednick RAT bridging
// (L0-clean: duplicated per AN7 — no cross-engine import)
// ═══════════════════════════════════════════════════════════════

fn cre_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = cre_bin_idx(a[i], lo, hi, nb)
        let ib = cre_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = cre_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * cre_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn cre_entropy_range(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(cre_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = cre_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * cre_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn cre_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = cre_vec_min(a)
    let hi_a = cre_vec_max(a)
    let lo_b = cre_vec_min(b)
    let hi_b = cre_vec_max(b)
    let lo = cre_min_f(lo_a, lo_b)
    let hi = cre_max_f(hi_a, hi_b)
    let h_a = cre_entropy_range(a, lo, hi, CRE_BINS)
    let h_b = cre_entropy_range(b, lo, hi, CRE_BINS)
    let h_j = cre_joint_entropy(a, b, lo, hi, CRE_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Normalize MI by ln(CRE_BINS) — the theoretical upper bound for binned MI
// with CRE_BINS bins. Yields a dimensionless combinatorial score in [0, 1].
fn cre_mi_norm(a: array, b: array) -> float {
    let mi = cre_mi(a, b)
    let max_h = cre_ln_safe(to_float(CRE_BINS))
    if max_h < CRE_EPS { return 0.0 }
    let r = mi / max_h
    return cre_clamp01(r)
}

// ═══════════════════════════════════════════════════════════════
// Windowed Pearson |r| — used defensively for T2 sanity (bridge
// reduces transitional-probability even under phase drift).
// sqrt runs only on non-negative sums-of-squares.
// ═══════════════════════════════════════════════════════════════

fn cre_pearson_abs(a: array, b: array, win: int) -> float {
    let n_a = len(a)
    let n_b = len(b)
    let n_min_f = cre_min_f(to_float(n_a), to_float(n_b))
    let mut nw = win
    if to_float(nw) > n_min_f { nw = to_int(n_min_f) }
    if nw < 2 { return 0.0 }

    let mut mean_a = 0.0
    let mut mean_b = 0.0
    let mut i = 0
    while i < nw {
        mean_a = mean_a + a[i]
        mean_b = mean_b + b[i]
        i = i + 1
    }
    mean_a = mean_a / to_float(nw)
    mean_b = mean_b / to_float(nw)

    let mut cov = 0.0
    let mut sa2 = 0.0
    let mut sb2 = 0.0
    let mut j = 0
    while j < nw {
        let da = a[j] - mean_a
        let db = b[j] - mean_b
        cov = cov + da * db
        sa2 = sa2 + da * da
        sb2 = sb2 + db * db
        j = j + 1
    }
    // sqrt-safe: sa2, sb2 are sums of squares — always >= 0.
    let denom = cre_sqrt_safe(sa2) * cre_sqrt_safe(sb2)
    if denom < CRE_EPS { return 0.0 }
    let r = cov / denom
    return cre_clamp01(cre_abs(r))
}

// ═══════════════════════════════════════════════════════════════
// Candidate generators — open (divergent) vs closed (convergent).
//
// Closed prompt: one expected answer; all candidates cluster on a
// single mode. Mass concentrates in a single bin → fluency entropy 0.
//
// Open prompt: divergent thinking; candidates spread across distinct
// conceptual categories. Mass spreads across many bins → fluency
// entropy near ln(CRE_BINS).
// ═══════════════════════════════════════════════════════════════

// Closed-prompt candidates: centered around a single target value
// (e.g. the one "expected" answer), with tiny seeded jitter.
fn cre_candidates_closed(target: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 19)
        // Tight jitter (±0.04) so the entire candidate population
        // occupies at most ONE histogram bin after auto-scaling.
        let jit = 0.04 * cre_signed(s)
        out = out.push(cre_clamp(target + jit, -1.0, 1.0))
        i = i + 1
    }
    return out
}

// Open-prompt candidates: spread across the conceptual space.
// We deterministically cycle through all CRE_BINS categories so every
// bin receives at least one candidate — guaranteed spread.
fn cre_candidates_open(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 23)
        // Step through bin centers; bin k has center at ((k+0.5)/nb)*2-1.
        let bin = i % CRE_BINS
        let center = (to_float(bin) + 0.5) / to_float(CRE_BINS) * 2.0 - 1.0
        // Small jitter so repeated hits on the same bin aren't identical.
        let jit = 0.05 * cre_signed(s)
        out = out.push(cre_clamp(center + jit, -1.0, 1.0))
        i = i + 1
    }
    return out
}

// Routine (single-category) candidates — same concept repeatedly.
fn cre_candidates_routine(seed: int) -> array {
    return cre_candidates_closed(0.3, seed)
}

// Usefulness template — a fixed "goal" profile the solution should
// approximate. Template has a structured shape (triangular wave) so
// candidates that match it are "useful" in the Amabile sense
// (goal-aligned, not arbitrary).
fn cre_template(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 29)
        let phase = to_float(i) / to_float(CRE_N)
        let base = 0.7 * cre_tri_wave(phase * 1.5 + 0.1)
        let jit = 0.03 * cre_signed(s)
        out = out.push(cre_clamp(base + jit, -1.0, 1.0))
        i = i + 1
    }
    return out
}

// Bizarre candidate: high originality (spread across all bins) BUT
// systematically anti-correlated with the template — the RMSE is large
// because the candidate sweeps the OPPOSITE phase of the template's
// triangular wave. This is "weird-but-not-useful" — bizarre output.
//
// Root cause comment: pure uniform noise vs a structured template gets
// an accidental ~0.4 cosine overlap and ~0.4 RMSE-derived util because
// the noise mean is near the template mean. To make bizarre cleanly
// LOW-util we use the template's anti-phase (negate + phase-shift) so
// the candidate ALWAYS opposes template — RMSE is forced large.
fn cre_candidates_bizarre(seed: int) -> array {
    let tmpl = cre_template(seed)
    let mut out = []
    let mut s = seed + 3000
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 31)
        // Anti-phase: candidate = -template at every position. With the
        // template hitting both signs, the negated version still covers
        // both signs → still spread across bins → high originality.
        // RMSE = ||t - (-t)|| = 2||t||/sqrt(N) which is large → low util.
        let jit = 0.05 * cre_signed(s)
        out = out.push(cre_clamp((0.0 - tmpl[i]) + jit, -1.0, 1.0))
        i = i + 1
    }
    return out
}

// Creative candidate: matches template (useful) AND also spans multiple
// bins (original). Constructed by perturbing the template so the
// histogram covers several bins but the RMSE-to-template stays modest.
fn cre_candidates_creative(seed: int) -> array {
    let tmpl = cre_template(seed)
    let mut out = []
    let mut s = seed + 5000
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 37)
        // Perturbation is mid-scale — enough to spread the candidate
        // across multiple histogram bins (originality) but not so much
        // that it decorrelates from the template (usefulness).
        let perturb = 0.20 * cre_signed(s)
        out = out.push(cre_clamp(tmpl[i] + perturb, -1.0, 1.0))
        i = i + 1
    }
    return out
}

// Routine-productive: a single canonical answer (the template's MEAN).
// All candidates cluster on one value → originality = 0 (one bin) and
// usefulness = moderate (constant matches template's mean only, not its
// shape). This is the "by-the-book" non-surprising answer.
//
// Root cause comment: hugging the full template with tiny jitter makes
// the candidate inherit the template's structural diversity → high
// originality artifact. Using a CONSTANT instead correctly captures the
// "one expected answer" routine: low orig, mid util.
fn cre_candidates_routine_productive(seed: int) -> array {
    let tmpl = cre_template(seed)
    let mean_t = cre_vec_mean(tmpl)
    return cre_candidates_closed(mean_t, seed + 7000)
}

// Noise candidate: low originality AND low usefulness — concentrated
// around 0.0 with small jitter, so it occupies one bin (low orig) AND
// poorly tracks the structured template (low util).
fn cre_candidates_noise(seed: int) -> array {
    return cre_candidates_closed(0.0, seed + 11000)
}

// ═══════════════════════════════════════════════════════════════
// Creativity measures — the core scoring functions
// ═══════════════════════════════════════════════════════════════

// Fluency — normalized histogram entropy in [0, 1]. The classical
// Guilford fluency score (count of qualitatively distinct responses),
// rendered as the fraction of maximum achievable binned entropy.
//
// Closed prompt → entropy ≈ 0 → fluency ≈ 0.
// Open prompt   → entropy → ln(CRE_BINS) → fluency → 1.
fn cre_fluency(candidates: array) -> float {
    let h = cre_entropy(candidates, CRE_BINS)
    let max_h = cre_ln_safe(to_float(CRE_BINS))
    if max_h < CRE_EPS { return 0.0 }
    return cre_clamp01(h / max_h)
}

// Originality — statistical rarity, computed as 1 minus the max-bin
// probability, normalized so a one-bin distribution scores 0 and a
// uniform distribution scores 1.
//
// max_bin_prob = 1.0 (one bin) → orig = 0.
// max_bin_prob = 1/nb (uniform) → orig = 1.
// Formula: orig = (1 - max_bin_prob) / (1 - 1/nb).
fn cre_originality(candidates: array) -> float {
    let top = cre_max_bin_prob(candidates, CRE_BINS)
    let floor = 1.0 / to_float(CRE_BINS)
    let denom = 1.0 - floor
    if denom < CRE_EPS { return 0.0 }
    let orig = (1.0 - top) / denom
    return cre_clamp01(orig)
}

// Usefulness — 1 minus RMSE-to-template, saturated by CRE_USE_SCALE.
// A candidate tracking the template closely (RMSE ≈ 0) scores ≈ 1;
// a candidate far from template (RMSE ≥ CRE_USE_SCALE) scores 0.
//
// Sqrt-safe: sumsq is a sum of squares / N, always ≥ 0.
fn cre_usefulness(candidates: array, template: array) -> float {
    let n = len(candidates)
    if n == 0 { return 0.0 }
    if len(template) != n { return 0.0 }
    let mut sumsq = 0.0
    let mut i = 0
    while i < n {
        let d = candidates[i] - template[i]
        sumsq = sumsq + d * d
        i = i + 1
    }
    let mean_sq = sumsq / to_float(n)
    let rmse = cre_sqrt_safe(mean_sq)
    let norm = rmse / CRE_USE_SCALE
    // util = 1 - normalized_rmse (clamped)
    let util = 1.0 - cre_clamp01(norm)
    return cre_clamp01(util)
}

// Amabile joint — sqrt(orig × util). Requires BOTH high to score high.
// sqrt-safe: orig, util are each clamped to [0, 1] so product ∈ [0, 1].
fn cre_joint_amabile(orig: float, util: float) -> float {
    let o = cre_clamp01(orig)
    let u = cre_clamp01(util)
    let prod = o * u
    return cre_clamp01(cre_sqrt_safe(prod))
}

// Combinatorial — cross-stream MI (Boden combinatorial mode).
// Multi-stream integration across distinct semantic sources.
fn cre_combinatorial(stream_a: array, stream_b: array) -> float {
    return cre_mi_norm(stream_a, stream_b)
}

// Φ_creative — the integrated creativity scalar.
//   Φ = w_f · fluency + w_o · sqrt(orig · util) + w_c · combMI
fn cre_phi(candidates: array, template: array, stream_a: array, stream_b: array) -> float {
    let f = cre_fluency(candidates)
    let o = cre_originality(candidates)
    let u = cre_usefulness(candidates, template)
    let j = cre_joint_amabile(o, u)
    let c = cre_combinatorial(stream_a, stream_b)
    let sum = CRE_W_FLUENCY * f + CRE_W_JOINT * j + CRE_W_COMB * c
    return cre_clamp01(sum)
}

// ═══════════════════════════════════════════════════════════════
// Mednick Remote Associates Test (T2) — independent concept streams
// with a "creative bridge" that introduces high-MI structure.
//
// No-bridge condition: two independently-seeded random streams. Their
// MI is at the finite-sample baseline (small but nonzero).
//
// Bridge condition: a shared latent template injected into both
// streams at modest amplitude. The streams still look superficially
// independent (different seeds, different jitter) but MI rises
// substantially above the no-bridge baseline — the creative insight
// links two seemingly-remote concepts through a shared structure.
// ═══════════════════════════════════════════════════════════════

fn cre_stream_random(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 43)
        out = out.push(cre_signed(s))
        i = i + 1
    }
    return out
}

// Bridged stream: contains the latent bridge pattern at strong amplitude
// plus independent noise. Two bridged streams with the SAME bridge
// share measurable MI even though they look different due to jitter.
//
// alpha controls the bridge strength — 0 = pure noise (no bridge),
// 1 = pure bridge (maximum MI, no privacy).
fn cre_stream_bridged(bridge: array, alpha: float, seed: int) -> array {
    let n = len(bridge)
    let mut out = []
    let mut s = seed
    let a = cre_clamp01(alpha)
    let mut i = 0
    while i < n {
        s = cre_prng(s + i * 47)
        let noise = cre_signed(s)
        let v = a * bridge[i] + (1.0 - a) * noise
        out = out.push(cre_clamp(v, -1.0, 1.0))
        i = i + 1
    }
    return out
}

fn cre_bridge_template(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < CRE_N {
        s = cre_prng(s + i * 53)
        let phase = to_float(i) / to_float(CRE_N)
        let base = 0.8 * cre_tri_wave(phase * 2.1 + 0.3)
        let jit = 0.02 * cre_signed(s)
        out = out.push(cre_clamp(base + jit, -1.0, 1.0))
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Incubation (T4) — DMN-active break re-shuffles habitual grooves.
//
// Pre-break: candidates generated by a narrow "focused" distribution
// that hugs one region of the space (low originality, high fixation).
//
// Post-break: after a simulated DMN-active rest, the generator
// re-draws from a broader distribution informed by associative drift —
// this breaks the fixation and post-break originality rises.
//
// We model the DMN break as a PRNG re-seeding with a divergent offset,
// which deterministically injects new spread while leaving the overall
// candidate statistics reproducible.
// ═══════════════════════════════════════════════════════════════

fn cre_candidates_focused(seed: int) -> array {
    // Focused: tight around a single region (low spread).
    return cre_candidates_closed(0.25, seed)
}

fn cre_candidates_after_break(seed: int) -> array {
    // After DMN break: broader spread across bins, simulating the
    // associative recombination that incubation enables (Smith 1991,
    // Sio & Ormerod 2009). This uses the open-prompt cycling generator
    // with a re-seeded offset so results are deterministic yet diverse.
    return cre_candidates_open(seed + 9999)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Divergent fluency — open prompt > closed prompt.
    //
    // A closed prompt (one expected answer) produces candidates
    // concentrated on a single bin; fluency entropy ≈ 0. An open
    // prompt (divergent thinking) produces candidates spread across
    // multiple bins; fluency entropy rises toward ln(CRE_BINS).
    //
    // Gate: fluency(open) > fluency(closed) + CRE_FLUENCY_GAP.
    // Also: distinct_bins(open) > distinct_bins(closed).
    let seed = 11111
    let closed = cre_candidates_closed(0.3, seed)
    let open   = cre_candidates_open(seed)

    let f_closed = cre_fluency(closed)
    let f_open   = cre_fluency(open)
    let gap = f_open - f_closed

    let bins_closed = cre_distinct_bins(closed, CRE_BINS)
    let bins_open   = cre_distinct_bins(open, CRE_BINS)

    println("  [T1] fluency(closed)=" + str(f_closed) + " fluency(open)=" + str(f_open) + " gap=" + str(gap))
    println("  [T1] distinct bins: closed=" + str(bins_closed) + " open=" + str(bins_open))
    println("       gate gap > " + str(CRE_FLUENCY_GAP))

    if gap <= CRE_FLUENCY_GAP { return false }
    // Structural sanity: open prompt must occupy MORE distinct bins.
    if bins_open <= bins_closed { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Remote association (Mednick RAT) — creative bridge raises MI
    // between otherwise-independent concept streams above chance.
    //
    // Baseline: two independently-seeded random streams → finite-sample
    // MI near zero (the "low transitional probability" of remote concepts).
    //
    // Bridge condition: both streams carry the same latent template at
    // modest amplitude → MI rises above the baseline. The bridge is the
    // creative insight that links remote concepts.
    //
    // Gate: MI_bridge > MI_baseline + CRE_RAT_GAP AND MI_bridge > CRE_RAT_MIN.
    let seed = 22222
    // Baseline: pure independent streams — low transitional probability.
    let stream_a_base = cre_stream_random(seed + 100)
    let stream_b_base = cre_stream_random(seed + 200)
    let mi_base = cre_mi_norm(stream_a_base, stream_b_base)

    // Bridge: shared latent template at alpha = 0.75 amplitude — strong
    // enough to induce cross-stream MI above chance.
    let bridge = cre_bridge_template(seed + 300)
    let stream_a_br = cre_stream_bridged(bridge, 0.75, seed + 400)
    let stream_b_br = cre_stream_bridged(bridge, 0.75, seed + 500)
    let mi_bridge = cre_mi_norm(stream_a_br, stream_b_br)

    let gap = mi_bridge - mi_base

    println("  [T2] MI(baseline, independent)=" + str(mi_base))
    println("  [T2] MI(bridged, shared template)=" + str(mi_bridge))
    println("  [T2] gap=" + str(gap) + " (need > " + str(CRE_RAT_GAP) + ", bridge_floor=" + str(CRE_RAT_MIN) + ")")

    if mi_bridge < CRE_RAT_MIN { return false }
    if gap <= CRE_RAT_GAP { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Amabile joint — originality × usefulness, product not max.
    //
    // Four candidates compared on the joint:
    //   (a) bizarre           — high orig, low util
    //   (b) routine productive — low orig, high util
    //   (c) creative          — high orig, high util
    //   (d) noise             — low orig, low util
    //
    // Gate: joint(creative) > max(joint(bizarre), joint(routine), joint(noise))
    //   AND joint(creative) > CRE_JOINT_MIN
    //   AND joint(creative) > max(orig, util) is NOT required (sqrt joint
    //   ≤ max by AM-GM), so instead we demand strict separation from the
    //   single-side cases.
    let seed = 33333
    let template = cre_template(seed)

    let bizarre = cre_candidates_bizarre(seed + 100)
    let routine = cre_candidates_routine_productive(seed + 200)
    let creative = cre_candidates_creative(seed + 300)
    let noise = cre_candidates_noise(seed + 400)

    let o_b = cre_originality(bizarre)
    let u_b = cre_usefulness(bizarre, template)
    let j_b = cre_joint_amabile(o_b, u_b)

    let o_r = cre_originality(routine)
    let u_r = cre_usefulness(routine, template)
    let j_r = cre_joint_amabile(o_r, u_r)

    let o_c = cre_originality(creative)
    let u_c = cre_usefulness(creative, template)
    let j_c = cre_joint_amabile(o_c, u_c)

    let o_n = cre_originality(noise)
    let u_n = cre_usefulness(noise, template)
    let j_n = cre_joint_amabile(o_n, u_n)

    println("  [T3] bizarre:  orig=" + str(o_b) + " util=" + str(u_b) + " joint=" + str(j_b))
    println("  [T3] routine:  orig=" + str(o_r) + " util=" + str(u_r) + " joint=" + str(j_r))
    println("  [T3] creative: orig=" + str(o_c) + " util=" + str(u_c) + " joint=" + str(j_c))
    println("  [T3] noise:    orig=" + str(o_n) + " util=" + str(u_n) + " joint=" + str(j_n))
    println("  [T3] creative gate: joint_c > CRE_JOINT_MIN=" + str(CRE_JOINT_MIN))

    // Creative must be the best on the joint score.
    if j_c <= j_b { return false }
    if j_c <= j_r { return false }
    if j_c <= j_n { return false }
    // Creative must clear the absolute floor.
    if j_c < CRE_JOINT_MIN { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Incubation enhances — DMN-active break improves subsequent
    // originality vs continuous focus.
    //
    // Pre-break: focused distribution (narrow, habitual grooves) →
    // low originality. Post-break: broader distribution after
    // associative recombination → higher originality.
    //
    // Gate: orig(post) > orig(pre) + CRE_INC_GAP.
    //
    // Also verified: distinct_bins(post) > distinct_bins(pre) —
    // structural signature of incubation breaking the fixation.
    let seed = 44444
    let pre  = cre_candidates_focused(seed + 100)
    let post = cre_candidates_after_break(seed + 100)

    let orig_pre  = cre_originality(pre)
    let orig_post = cre_originality(post)
    let gain = orig_post - orig_pre

    let bins_pre  = cre_distinct_bins(pre, CRE_BINS)
    let bins_post = cre_distinct_bins(post, CRE_BINS)

    println("  [T4] orig(pre-break,  focused)=" + str(orig_pre) + " bins=" + str(bins_pre))
    println("  [T4] orig(post-break, DMN-active)=" + str(orig_post) + " bins=" + str(bins_post))
    println("  [T4] gain=" + str(gain) + " (need > " + str(CRE_INC_GAP) + ")")

    if gain <= CRE_INC_GAP { return false }
    if bins_post <= bins_pre { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Φ_creative > Φ_routine — broader integration across semantic networks.
    //
    // Creative mode: open candidates + useful template + combinatorial
    // cross-stream bridge → all three composite components score high.
    //
    // Routine mode: closed single-bin candidates + mismatched template
    // + unrelated streams → all three components score low.
    //
    // Gate: Φ_creative > Φ_routine + CRE_SIGNAL_MIN AND Φ_creative >
    // CRE_SIGNAL_MIN in absolute terms. This is the IIT-style
    // "something-it-is-like-to-be-creative vs routine" signature.
    let seed = 55555
    let template = cre_template(seed)
    let bridge   = cre_bridge_template(seed + 100)

    // Creative: open candidates that track the template (so useful)
    // by means of the creative candidate generator. Combinatorial
    // cross-stream MI supplied by two bridged streams.
    let cands_creative = cre_candidates_creative(seed + 200)
    let stream_a_cr = cre_stream_bridged(bridge, 0.75, seed + 300)
    let stream_b_cr = cre_stream_bridged(bridge, 0.75, seed + 400)
    let phi_creative = cre_phi(cands_creative, template, stream_a_cr, stream_b_cr)

    // Routine: closed single-bin candidates that miss the template
    // (low util because target=0.3 ≠ template shape), with independent
    // (non-bridged) streams — combinatorial MI baseline-low.
    let cands_routine = cre_candidates_closed(0.3, seed + 500)
    let stream_a_rt = cre_stream_random(seed + 600)
    let stream_b_rt = cre_stream_random(seed + 700)
    let phi_routine = cre_phi(cands_routine, template, stream_a_rt, stream_b_rt)

    let delta = phi_creative - phi_routine

    println("  [T5] Φ_creative = " + str(phi_creative))
    println("  [T5] Φ_routine  = " + str(phi_routine))
    println("  [T5] Δ          = " + str(delta) + " (need > " + str(CRE_SIGNAL_MIN) + ")")

    if phi_creative <= CRE_SIGNAL_MIN { return false }
    if delta <= CRE_SIGNAL_MIN { return false }
    // Belt-and-suspenders: routine must genuinely trail creative.
    if phi_routine >= phi_creative { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute all 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[creativity_phi] P130 — Creativity Φ (divergent + originality×usefulness)")
    println("  Φ = w_f·fluency + w_o·sqrt(orig·util) + w_c·combMI")
    println("  refs: Guilford 1967 | Mednick 1962 RAT | Boden 1991 | Amabile 1983")
    println("  N=" + str(CRE_N) + " bins=" + str(CRE_BINS) + " win=" + str(CRE_WIN))
    println("  w_f=" + str(CRE_W_FLUENCY) + " w_o=" + str(CRE_W_JOINT) + " w_c=" + str(CRE_W_COMB))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  divergent fluency — open > closed (Guilford)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  remote association — bridge raises MI (Mednick RAT)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  originality × usefulness joint beats single-side (Amabile)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  incubation — DMN break enhances originality (Smith 1991)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  Φ_creative > Φ_routine (broader semantic integration)") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 && chains with 5 operands can mis-short-
    // circuit under certain orderings (same idiom as aesthetic_phi +
    // curiosity_phi). Sequential mutable-bool guard is the reliable pattern.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[creativity_phi] 5/5 PASS — P130 DONE (creativity Φ divergent originality×usefulness verified)")
    } else {
        println("[creativity_phi] SOME FAILED")
    }
}

main()
