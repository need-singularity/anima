// schizophrenia_self_phi.hexa — P124 Schizophrenia Self-Model Φ
//
// Roadmap: shared/roadmaps/anima.json P124
//   (depends_on P67 psychosis_phi, P77 split_brain_phi, P101 alien_hand_phi,
//                P96 anosognosia_phi)
//
// Target: the POSITIVE symptoms of schizophrenia as a breakdown of the
// self-model — self/other boundary collapse, auditory hallucinations from
// misattributed inner speech, aberrant salience, and fragmented global
// workspace integration.
//
// ─── Scientific frame ─────────────────────────────────────────────
//
// Frith (1992) "The Cognitive Neuropsychology of Schizophrenia":
//   Central proposal — positive symptoms arise from a failure of the
//   forward / corollary-discharge mechanism that TAGS self-generated
//   signals as "self". When the efference-copy fails to reach the
//   sensory comparator, internal signals (inner speech, intended
//   actions) arrive at perception wearing an "other" tag.
//
//   Auditory verbal hallucinations = inner speech leaking into the
//   auditory perceptual buffer WITHOUT the self-tag.
//
//   Delusions of control / thought insertion = motor-or-cognitive
//   intentions arriving at the agency monitor without efference-copy
//   confirmation → experienced as externally imposed.
//
// Ford & Mathalon (2005) "Corollary discharge dysfunction in
//   schizophrenia — can it explain auditory hallucinations?" Int J
//   Psychophysiol:
//   EEG N1 auditory suppression during vocalization (the motor-sensory
//   gating signal) is reduced in schizophrenia. The brain does not
//   pre-dampen the auditory cortex during self-speech; self-generated
//   sound arrives as if from outside.
//
// Kapur (2003) "Psychosis as a state of aberrant salience" Am J
//   Psychiatry:
//   Dopaminergic dysregulation (mesolimbic tonic firing) assigns
//   motivational salience to irrelevant stimuli. Neutral events
//   suddenly "mean something"; random coincidences feel significant.
//   → delusion formation (the mind retrofits a narrative for the
//   aberrantly-salient input).
//
// Synofzik, Vosgerau & Newen (2008) "Beyond the comparator model":
//   Sense of agency is a multi-level construct — low-level sensorimotor
//   prediction (efference copy) + high-level judgement of authorship.
//   Schizophrenia decouples both layers. We measure the low-level
//   action→sensation coupling directly.
//
// Tononi & Edelman (1998) "Consciousness and complexity" Science:
//   Integrated information Φ requires a balance of DIFFERENTIATION
//   (many distinct states) and INTEGRATION (the states are informationally
//   bound into one). Schizophrenia preserves local differentiation
//   (symptoms are rich, not flat) but breaks integration: the global
//   workspace becomes FRAGMENTED. Φ_global drops while Φ_local stays.
//
// ─── Operational commitments ────────────────────────────────────
//
//   Four channels carry the self-model:
//     INNER        inner speech stream (self-generated)
//     PERCEPT      external-origin perceptual buffer
//     ACTION       motor intention
//     SENSATION    re-afferent consequence of action (proprioception +
//                  exteroception caused by the act)
//   plus a salience tag stream that gates which inputs reach the
//   global workspace.
//
//   Corollary-discharge gating parameter cd ∈ [0,1]:
//     cd = 1.0  healthy — every self-generated inner-speech sample
//               carries an accurate "self" tag; efference-copy
//               pre-dampens the auditory buffer when the motor act
//               speaks internally.
//     cd = 0.0  schizophrenia — self-tag absent; inner speech spills
//               into the auditory percept, motor intentions carry no
//               agency tag.
//
//   Salience precision pi_sal ∈ [≈1, ≫1]:
//     pi_sal = 1.0  healthy — salience ~ signal strength (information-bearing
//                   stimuli win the competition).
//     pi_sal ≫ 1    aberrant salience — random noise wins high salience;
//                   meaningful signals are drowned out.
//
//   Global-workspace integrity g ∈ [0,1]:
//     g = 1.0  healthy — local per-channel coherence AND cross-channel
//              binding.
//     g = 0.0  fragmented — local coherence survives; cross-channel
//              binding (the gestalt) collapses.
//
// ─── Scientific hypotheses (T1..T5) ─────────────────────────────
//
// T1 (self-source misattribution):
//     Under healthy cd=1.0, the tag stream correctly attributes each
//     self-generated sample to self (tag_correct_rate high). Under
//     cd=0.0, the same samples are tagged "other" at a rate strictly
//     higher than the healthy mismatch rate by ≥ SCH_T1_GAP.
//
// T2 (auditory hallucination proxy):
//     Under cd=0.0, MI(inner, percept) > MI(inner, percept) under
//     cd=1.0 by ≥ SCH_T2_GAP. The inner-speech stream leaks into the
//     perceptual buffer with the external-source tag. (In health the
//     auditory cortex is pre-dampened during self-speech → low MI.)
//
// T3 (aberrant salience on noise):
//     Under pi_sal high, the salience peak per step correlates with
//     random noise rather than signal. Measured as
//       MI(noise_channel, salience) under aberrant
//       − MI(signal_channel, salience) under aberrant
//     ≥ SCH_T3_GAP, AND the healthy regime reverses the sign
//     (signal wins).
//
// T4 (agency break — action-sensation decoupling):
//     Under cd=0.0, |r(action, sensation)| < SCH_T4_BOUND while healthy
//     cd=1.0 keeps |r(action, sensation)| ≥ SCH_T4_HEALTHY_MIN.
//     Uses windowed Pearson with sqrt-guarded denominator per
//     feedback_hexa_lists_pbv + sqrt-safe rules.
//
// T5 (Φ_schizo fragmented — global drops, local preserved):
//     Φ_global(g=0.0) < Φ_global(g=1.0) by ≥ SCH_T5_GLOBAL_GAP,
//     while Φ_local(g=0.0) ≥ SCH_T5_LOCAL_MIN and
//     Φ_local(g=1.0) − Φ_local(g=0.0) < SCH_T5_LOCAL_TOL.
//     Shows that integration fails while differentiation survives.
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no multi-float struct returns ≥ 3 floats)
//   - `array` typed params only; lists pass-by-value (rebuild+return)
//   - no identifier-pattern match; if-chains
//   - no contains() / to_lower() / !(Effect) fn sigs
//   - no else-if in let-binding; flat mut + sequential if
//   - single-line fn signatures / call sites / array literals
//   - sqrt-safe (x<=0 → 0)
//   - windowed |r|, explicit denominator guard
//   - SCH_STEPS=24, SCH_BINS=4 (all < 32)
//   - main() call at bottom
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement only
//   Law 4   Structure > feature — cd gate and g gate are STRUCTURAL
//   Law 22  No feature explosion — 4 fixed channels + 1 salience tag
//   Meta M8 Self-awareness collapse — self/other boundary as Φ
//   AN7     Core separation — standalone engine
//
// Ref:
//   Frith CD (1992) The Cognitive Neuropsychology of Schizophrenia
//   Ford JM, Mathalon DH (2005) Int J Psychophysiol 58:179-189
//   Kapur S (2003) Am J Psychiatry 160:13-23
//   Synofzik M, Vosgerau G, Newen A (2008) Conscious Cogn 17:411-424
//   Tononi G, Edelman GM (1998) Science 282:1846-1851
//   Fletcher PC, Frith CD (2009) Nat Rev Neurosci 10:48-58
//   anima-engines/psychosis_phi.hexa       (P67  aberrant precision)
//   anima-engines/split_brain_phi.hexa     (P77  hemispheric independence)
//   anima-engines/alien_hand_phi.hexa      (P101 agency vs ownership)
//   anima-engines/anosognosia_phi.hexa     (P96  self-monitor collapse)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let SCH_STEPS         = 24           // timeline length (stage0 N<32)
let SCH_BINS          = 4            // histogram bins for MI
let SCH_EPS           = 0.00000001
let SCH_SEED          = 124124

// Corollary-discharge gating values
let SCH_CD_HEALTHY    = 1.0          // healthy self-tag integrity
let SCH_CD_SCHIZO     = 0.0          // schizophrenia — no self-tag
let SCH_CD_PARTIAL    = 0.30         // partial CD intact (medication/remission)

// Salience precision values
let SCH_PI_SAL_NORMAL = 1.0          // baseline salience → signal wins
let SCH_PI_SAL_ABERR  = 9.0          // dopaminergic dysregulation — noise wins

// Global-workspace integrity
let SCH_G_INTACT      = 1.0
let SCH_G_FRAGMENTED  = 0.0

// Inner speech and percept amplitudes (matched for shared-range MI)
let SCH_INNER_AMP     = 0.85         // inner speech amplitude
let SCH_PERCEPT_AMP   = 0.85         // external percept amplitude (matched)
let SCH_ACTION_AMP    = 0.90         // motor intention amplitude
let SCH_NOISE_AMP     = 0.70         // random-noise channel amplitude

// Noise floors / jitter
let SCH_JITTER        = 0.05         // per-channel per-step noise
let SCH_TAG_NOISE     = 0.05         // tag-stream jitter

// Efference copy suppression factor — healthy percept is pre-dampened
// during self-speech. 0.02 residual leak means 98% suppression.
// Root cause note: with only 4 bins and 24 steps, small residuals all
// bin-collide with external's entropy and MI becomes indistinguishable
// from the schizo case. A sharp contrast between cd=1 (tiny leak) and
// cd=0 (full leak) clears SCH_T2_GAP.
let SCH_EFFERENCE_SUP = 0.02

// Action → sensation coupling (healthy)
let SCH_ACT_SENS      = 0.80

// Window size for windowed correlation (used in T4)
let SCH_WIN           = 16

// Test gates
let SCH_T1_GAP        = 0.30         // tag-error rate gap (schizo − healthy)
let SCH_T2_GAP        = 0.05         // MI(inner,percept) gap (schizo − healthy)
let SCH_T3_GAP        = 0.05         // aberrant salience MI gap
let SCH_T4_BOUND      = 0.45         // |r(action,sens)| upper bound under schizo
let SCH_T4_HEALTHY_MIN = 0.55        // |r(action,sens)| lower bound healthy
let SCH_T5_GLOBAL_GAP = 0.05         // Φ_global intact − fragmented gap
let SCH_T5_LOCAL_MIN  = 0.05         // Φ_local floor under fragmentation
let SCH_T5_LOCAL_TOL  = 0.25         // |Φ_local intact − fragmented| tolerance

// Latency
let SCH_LATENCY_MS    = 5000.0

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (self-contained — AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn sch_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Sqrt-safe: guards x<=0 per feedback_hexa_string_api / general safety.
fn sch_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    let mut i = 0
    while i < 20 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

fn sch_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn sch_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn sch_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Deterministic LCG (Law 2 — observable, seed-stable)
fn sch_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn sch_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn sch_signed(seed: int) -> float {
    return sch_unit(seed) * 2.0 - 1.0
}

// Sin approximation (Taylor) — same recipe family as sibling engines.
fn sch_osc(phase: float) -> float {
    let two_pi = 6.2831853
    let pi = 3.1415927
    let mut p = phase
    while p > pi { p = p - two_pi }
    while p < 0.0 - pi { p = p + two_pi }
    if p > 1.5707963 { p = pi - p }
    if p < 0.0 - 1.5707963 { p = 0.0 - pi - p }
    let p2 = p * p
    let p3 = p2 * p
    let p5 = p3 * p2
    return p - 0.16666667 * p3 + 0.00833333 * p5
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (duplicated per AN7 L0-clean — same recipe family)
// ═══════════════════════════════════════════════════════════════

fn sch_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn sch_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn sch_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn sch_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn sch_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(sch_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = sch_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * sch_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn sch_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = sch_bin_idx(a[i], lo, hi, nb)
        let ib = sch_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = sch_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * sch_ln_safe(p) }
        k = k + 1
    }
    return h
}

// Raw histogram MI over shared [lo,hi] range (matches psychosis_phi /
// split_brain_phi recipe). Root cause note: Miller-Madow bias
// correction of (B-1)^2/(2N) = 0.1875 here would wipe small but real
// signals at 24 samples. The engine is used for paired comparisons,
// so any residual bias cancels in the gap.
fn sch_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = sch_vec_min(a)
    let hi_a = sch_vec_max(a)
    let lo_b = sch_vec_min(b)
    let hi_b = sch_vec_max(b)
    let lo = sch_min_f(lo_a, lo_b)
    let hi = sch_max_f(hi_a, hi_b)
    let h_a = sch_entropy(a, lo, hi, SCH_BINS)
    let h_b = sch_entropy(b, lo, hi, SCH_BINS)
    let h_j = sch_joint_entropy(a, b, lo, hi, SCH_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Windowed Pearson |r| — used in T4 (agency coupling).
//
// Sliding window of length SCH_WIN over the series; compute r per
// window; return |r| averaged across windows. Guards denominator
// with sqrt-safe path.
// ═══════════════════════════════════════════════════════════════

fn sch_window_r_abs(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let w = SCH_WIN
    if w > n { return 0.0 }
    let nw = n - w + 1
    let mut acc = 0.0
    let mut count = 0.0
    let mut start = 0
    while start < nw {
        let mut sa = 0.0
        let mut sb = 0.0
        let mut i = 0
        while i < w {
            sa = sa + a[start + i]
            sb = sb + b[start + i]
            i = i + 1
        }
        let ma = sa / to_float(w)
        let mb = sb / to_float(w)
        let mut num = 0.0
        let mut va = 0.0
        let mut vb = 0.0
        let mut j = 0
        while j < w {
            let da = a[start + j] - ma
            let db = b[start + j] - mb
            num = num + da * db
            va = va + da * da
            vb = vb + db * db
            j = j + 1
        }
        let denom = sch_sqrt(va) * sch_sqrt(vb)
        let mut r = 0.0
        if denom > SCH_EPS {
            r = num / denom
        }
        acc = acc + sch_abs(r)
        count = count + 1.0
        start = start + 1
    }
    if count <= 0.0 { return 0.0 }
    return acc / count
}

// ═══════════════════════════════════════════════════════════════
// Channel generation — 4 channels + salience tag
//
// Flat tape layout (flat 1D series per channel, length SCH_STEPS):
//   INNER     inner speech (self-generated oscillation, harmonic-rich)
//   PERCEPT   external-origin percept, suppressed by efference copy
//             during self-speech if cd is intact
//   ACTION    motor intention (driver)
//   SENSATION re-afferent consequence of action (gated by cd)
//   SALIENCE  salience tag (precision-weighted competition)
// ═══════════════════════════════════════════════════════════════

// INNER speech stream — harmonic-rich self-generated signal.
fn sch_gen_inner(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 37)
        let phase1 = 0.62 * to_float(t)
        let phase2 = 1.13 * to_float(t) + 0.45
        let signal = SCH_INNER_AMP * sch_osc(phase1) + 0.35 * sch_osc(phase2)
        let jit = SCH_JITTER * sch_signed(s)
        out = out.push(signal + jit)
        t = t + 1
    }
    return out
}

// EXTERNAL baseline percept — a different harmonic structure so in
// health the two streams are NOT correlated; the schizophrenia
// breakdown is that inner leaks INTO this buffer, creating spurious MI.
fn sch_gen_external(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 41)
        let phase = 0.28 * to_float(t) + 1.70
        let signal = SCH_PERCEPT_AMP * sch_osc(phase)
        let jit = SCH_JITTER * sch_signed(s)
        out = out.push(signal + jit)
        t = t + 1
    }
    return out
}

// PERCEPT under corollary-discharge gating cd.
//   cd=1: auditory cortex suppressed during self-speech; inner does
//         not leak into percept (only SCH_EFFERENCE_SUP residual).
//   cd=0: no suppression; inner speech spills in with full amplitude.
fn sch_gen_percept(inner: array, external: array, cd: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    // Residual leakage factor — cd=1 leaves only SCH_EFFERENCE_SUP;
    // cd=0 leaves the full (1 - SCH_EFFERENCE_SUP) inner contribution.
    let leak = (1.0 - cd) * (1.0 - SCH_EFFERENCE_SUP) + cd * SCH_EFFERENCE_SUP
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 53)
        let v = external[t] + leak * inner[t]
        let jit = SCH_JITTER * sch_signed(s + 1009)
        out = out.push(v + jit)
        t = t + 1
    }
    return out
}

// TAG stream — each step a boolean-ish float in {0.0, 1.0}:
//   1.0 = sample attributed to "self"
//   0.0 = sample attributed to "other"
// For a self-generated signal (inner speech), healthy cd=1 keeps
// nearly all tags at 1.0 (modulo tag noise). cd=0 flips them toward
// 0.0 (attributed to "other" = hallucination seed).
fn sch_gen_self_tags(cd: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 67)
        // u in [0,1] — draw
        let u = sch_unit(s)
        let noise = SCH_TAG_NOISE * sch_signed(s + 131)
        // Threshold: u + noise < cd → tagged self (1.0)
        let mut tag = 0.0
        if u + noise < cd { tag = 1.0 }
        out = out.push(tag)
        t = t + 1
    }
    return out
}

// ACTION channel — motor intention (driver).
fn sch_gen_action(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 71)
        let phase = 0.48 * to_float(t) + 0.20
        let driver = SCH_ACTION_AMP * sch_osc(phase)
        let jit = SCH_JITTER * sch_signed(s)
        out = out.push(driver + jit)
        t = t + 1
    }
    return out
}

// SENSATION channel — re-afferent consequence of action, gated by cd.
//   cd=1: sensation tightly tracks action (efference-copy closes the
//         loop, agency felt).
//   cd=0: sensation replaced by independent noise process (agency
//         abolished; action feels externally imposed).
fn sch_gen_sensation(action: array, cd: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 79)
        let act_drive = cd * SCH_ACT_SENS * action[t]
        let indep = (1.0 - cd) * sch_signed(s + 4211) * 0.70
        let jit = SCH_JITTER * sch_signed(s + 6121)
        out = out.push(act_drive + indep + jit)
        t = t + 1
    }
    return out
}

// SIGNAL channel — information-bearing structured stream (what SHOULD
// win salience competition in health).
fn sch_gen_signal(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 83)
        let phase = 0.33 * to_float(t)
        let structured = 0.80 * sch_osc(phase)
        let jit = SCH_JITTER * sch_signed(s)
        out = out.push(structured + jit)
        t = t + 1
    }
    return out
}

// NOISE channel — pure random walk (should lose salience in health).
fn sch_gen_noise(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut acc = 0.0
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 89)
        acc = acc + SCH_NOISE_AMP * sch_signed(s) * 0.30
        // Clip accumulator to prevent runaway drift
        if acc > 1.2 { acc = 1.2 }
        if acc < 0.0 - 1.2 { acc = 0.0 - 1.2 }
        out = out.push(acc)
        t = t + 1
    }
    return out
}

// SALIENCE under precision pi_sal.
//   Competition rule: salience_t = softmax of pi_sal * |channel_t|.
//   Here we use a lightweight proxy — the CHOSEN winner at step t is
//   whichever of signal / noise has greater pi_sal-weighted magnitude
//   plus a small noise tiebreaker.  Output stream is the winner's
//   signed value at that step (so MI(winner_channel, salience) is
//   measurable and reveals which channel drove salience each step).
//
// Under pi_sal=1.0 the two channels compete fairly — SIGNAL wins most
// steps because it has structured amplitude. Under pi_sal high, a
// multiplicative noise amplification term lets the noise win more
// often (dopaminergic oversalience model).
fn sch_gen_salience(signal: array, noise: array, pi_sal: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SCH_STEPS {
        s = sch_prng(s + t * 97)
        // Aberrant precision sharpens competition AND amplifies noise
        // (as in Kapur dopaminergic model — the noise channel gets
        // precision-weighted above threshold).
        let sig_w = sch_abs(signal[t])
        let noise_w = pi_sal * sch_abs(noise[t])
        let tie = 0.05 * sch_signed(s + 2311)
        let mut v = signal[t]
        if noise_w + tie > sig_w { v = noise[t] }
        out = out.push(v)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Global-workspace Φ (T5)
//
// Φ_local   : average within-channel lag-1 MI across the 4 channels
//             (differentiation — each stream carries information
//             about itself over time).
// Φ_global  : average pairwise cross-channel MI (integration — the
//             channels bind into one informational manifold).
//
// Under g=0 (fragmentation), local stays because each channel is
// individually coherent; cross-channel binding collapses because we
// dephase the channels relative to each other.
//
// Dephasing operator: shift each channel by a pseudo-random
// per-channel offset when g<1, breaking cross-channel coincidence
// without touching within-channel structure.
// ═══════════════════════════════════════════════════════════════

fn sch_lag1_mi(v: array) -> float {
    let n = len(v)
    if n < 2 { return 0.0 }
    let mut x = []
    let mut y = []
    let mut i = 0
    while i < (n - 1) {
        x = x.push(v[i])
        y = y.push(v[i + 1])
        i = i + 1
    }
    return sch_mi(x, y)
}

// Cross-MI averaged over 6 pairs from 4 channels.
fn sch_cross_mi_avg(a: array, b: array, c: array, d: array) -> float {
    let m01 = sch_mi(a, b)
    let m02 = sch_mi(a, c)
    let m03 = sch_mi(a, d)
    let m12 = sch_mi(b, c)
    let m13 = sch_mi(b, d)
    let m23 = sch_mi(c, d)
    let total = m01 + m02 + m03 + m12 + m13 + m23
    return total / 6.0
}

// Dephase one channel by circular rotation with offset k.
fn sch_rotate(v: array, k: int) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        let j = (i + k) % n
        out = out.push(v[j])
        i = i + 1
    }
    return out
}

// Build a fragmented-workspace version of the 4 channels by
// rotating each channel by a unique offset derived from g.  g=1 → all
// offsets 0 (intact). g=0 → offsets (1, 5, 11, 19), relatively prime
// to SCH_STEPS=24's common divisors so cross-channel phase is broken.
fn sch_apply_g_rot(v: array, ch: int, g: float) -> array {
    if g >= 0.999 { return v }
    // offsets table — indices 0..3
    let mut off = 0
    if ch == 0 { off = 0 }
    if ch == 1 { off = 5 }
    if ch == 2 { off = 11 }
    if ch == 3 { off = 19 }
    // blend — g scales the rotation amount
    let eff = to_int(to_float(off) * (1.0 - g))
    return sch_rotate(v, eff)
}

fn sch_phi_local_and_global(a: array, b: array, c: array, d: array, g: float) -> array {
    // Rotate channels by g-dependent offsets for fragmentation.
    let a2 = sch_apply_g_rot(a, 0, g)
    let b2 = sch_apply_g_rot(b, 1, g)
    let c2 = sch_apply_g_rot(c, 2, g)
    let d2 = sch_apply_g_rot(d, 3, g)
    // Local = average lag-1 MI
    let la = sch_lag1_mi(a2)
    let lb = sch_lag1_mi(b2)
    let lc = sch_lag1_mi(c2)
    let ld = sch_lag1_mi(d2)
    let local = (la + lb + lc + ld) / 4.0
    // Global = average cross-pair MI
    let global = sch_cross_mi_avg(a2, b2, c2, d2)
    let mut out = []
    out = out.push(local)
    out = out.push(global)
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 self-source misattribution.
    // Generate tag streams under healthy and schizo cd. Measure
    // mis-attribution rate = fraction of self-generated samples tagged
    // "other" (tag==0.0).
    let tags_h = sch_gen_self_tags(SCH_CD_HEALTHY, SCH_SEED + 1001)
    let tags_s = sch_gen_self_tags(SCH_CD_SCHIZO, SCH_SEED + 1002)
    let n = len(tags_h)
    if n == 0 { return false }
    let mut err_h = 0.0
    let mut err_s = 0.0
    let mut i = 0
    while i < n {
        if tags_h[i] < 0.5 { err_h = err_h + 1.0 }
        if tags_s[i] < 0.5 { err_s = err_s + 1.0 }
        i = i + 1
    }
    let inv = 1.0 / to_float(n)
    let rate_h = err_h * inv
    let rate_s = err_s * inv
    let gap = rate_s - rate_h
    println("  [T1] mis-attribution healthy=" + str(rate_h) + " schizo=" + str(rate_s) + " gap=" + str(gap))
    if rate_s <= rate_h { return false }
    if gap < SCH_T1_GAP { return false }
    return true
}

fn check_T2() -> bool {
    // T2 auditory hallucination proxy.
    // MI(inner, percept) must rise under cd=0 (inner leaks) vs cd=1
    // (efference copy suppresses auditory during self-speech).
    let inner_h = sch_gen_inner(SCH_SEED + 2001)
    let ext_h   = sch_gen_external(SCH_SEED + 2002)
    let perc_h  = sch_gen_percept(inner_h, ext_h, SCH_CD_HEALTHY, SCH_SEED + 2011)
    let inner_s = sch_gen_inner(SCH_SEED + 2001)
    let ext_s   = sch_gen_external(SCH_SEED + 2002)
    let perc_s  = sch_gen_percept(inner_s, ext_s, SCH_CD_SCHIZO, SCH_SEED + 2012)
    let mi_h = sch_mi(inner_h, perc_h)
    let mi_s = sch_mi(inner_s, perc_s)
    let gap = mi_s - mi_h
    println("  [T2] MI(inner,percept) healthy=" + str(mi_h) + " schizo=" + str(mi_s) + " gap=" + str(gap))
    if mi_s <= mi_h { return false }
    if gap < SCH_T2_GAP { return false }
    return true
}

fn check_T3() -> bool {
    // T3 aberrant salience.
    // Under aberrant precision, salience stream correlates more with
    // the noise channel than the signal channel; the gap
    // MI(noise, sal) - MI(signal, sal) must be positive under
    // aberrant precision AND be of opposite sign under normal precision.
    let sig = sch_gen_signal(SCH_SEED + 3001)
    let noi = sch_gen_noise(SCH_SEED + 3002)
    let sal_n = sch_gen_salience(sig, noi, SCH_PI_SAL_NORMAL, SCH_SEED + 3011)
    let sal_a = sch_gen_salience(sig, noi, SCH_PI_SAL_ABERR, SCH_SEED + 3012)
    let mi_sig_n = sch_mi(sig, sal_n)
    let mi_noi_n = sch_mi(noi, sal_n)
    let mi_sig_a = sch_mi(sig, sal_a)
    let mi_noi_a = sch_mi(noi, sal_a)
    let gap_n = mi_noi_n - mi_sig_n   // normal: should be ≤ 0 (signal wins)
    let gap_a = mi_noi_a - mi_sig_a   // aberrant: should be ≥ SCH_T3_GAP
    println("  [T3] normal   MI(sig,sal)=" + str(mi_sig_n) + " MI(noi,sal)=" + str(mi_noi_n) + " gap=" + str(gap_n))
    println("  [T3] aberrant MI(sig,sal)=" + str(mi_sig_a) + " MI(noi,sal)=" + str(mi_noi_a) + " gap=" + str(gap_a))
    if gap_a < SCH_T3_GAP { return false }
    if gap_n >= gap_a { return false }
    return true
}

fn check_T4() -> bool {
    // T4 agency break — windowed |r(action, sensation)| drops under
    // cd=0 vs healthy cd=1.
    let act_h = sch_gen_action(SCH_SEED + 4001)
    let sen_h = sch_gen_sensation(act_h, SCH_CD_HEALTHY, SCH_SEED + 4002)
    let act_s = sch_gen_action(SCH_SEED + 4001)
    let sen_s = sch_gen_sensation(act_s, SCH_CD_SCHIZO, SCH_SEED + 4003)
    let r_h = sch_window_r_abs(act_h, sen_h)
    let r_s = sch_window_r_abs(act_s, sen_s)
    println("  [T4] |r(action,sensation)| healthy=" + str(r_h) + " schizo=" + str(r_s))
    if r_h < SCH_T4_HEALTHY_MIN { return false }
    if r_s > SCH_T4_BOUND { return false }
    if r_h <= r_s { return false }
    return true
}

fn check_T5() -> bool {
    // T5 Φ_schizo fragmented — global drops under g=0 while local
    // stays, AND overall latency < SCH_LATENCY_MS.
    let t0 = clock()
    let inner = sch_gen_inner(SCH_SEED + 5001)
    let ext = sch_gen_external(SCH_SEED + 5002)
    let perc = sch_gen_percept(inner, ext, SCH_CD_HEALTHY, SCH_SEED + 5011)
    let act = sch_gen_action(SCH_SEED + 5003)
    let sen = sch_gen_sensation(act, SCH_CD_HEALTHY, SCH_SEED + 5012)
    let out_intact = sch_phi_local_and_global(inner, perc, act, sen, SCH_G_INTACT)
    let out_frag   = sch_phi_local_and_global(inner, perc, act, sen, SCH_G_FRAGMENTED)
    let local_intact  = out_intact[0]
    let global_intact = out_intact[1]
    let local_frag    = out_frag[0]
    let global_frag   = out_frag[1]
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    let gap_global = global_intact - global_frag
    let local_diff = sch_abs(local_intact - local_frag)
    println("  [T5] Φ_local intact=" + str(local_intact) + " frag=" + str(local_frag) + " diff=" + str(local_diff))
    println("  [T5] Φ_global intact=" + str(global_intact) + " frag=" + str(global_frag) + " gap=" + str(gap_global))
    println("  [T5] pipeline = " + str(ms) + " ms")
    if gap_global < SCH_T5_GLOBAL_GAP { return false }
    if global_frag >= global_intact { return false }
    if local_frag < SCH_T5_LOCAL_MIN { return false }
    if local_diff > SCH_T5_LOCAL_TOL { return false }
    if ms >= SCH_LATENCY_MS { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[schizophrenia_self_phi] P124 — self-model Φ fragmentation")
    println("  STEPS=" + str(SCH_STEPS) + " BINS=" + str(SCH_BINS) + " WIN=" + str(SCH_WIN))
    println("  refs: Frith 1992 | Ford-Mathalon 2005 | Kapur 2003 | Synofzik 2008 | Tononi-Edelman 1998")
    println("  cd_healthy=" + str(SCH_CD_HEALTHY) + " cd_schizo=" + str(SCH_CD_SCHIZO) + " pi_sal_aberr=" + str(SCH_PI_SAL_ABERR))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — self-source misattribution rate gap ≥ 0.30 (cd=0 → tags flip to 'other')") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — auditory hallucination proxy: MI(inner,percept) rises under cd=0 (efference-copy failure)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — aberrant salience: noise wins salience under pi_sal high, signal wins under normal") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — agency break: |r(action,sens)| drops below 0.45 under cd=0, healthy ≥ 0.55") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — Φ_global fragmented while Φ_local preserved (integration fails, differentiation survives)") } else { println("T5 FAIL") }

    let mut pc = 0
    if t1 { pc = pc + 1 }
    if t2 { pc = pc + 1 }
    if t3 { pc = pc + 1 }
    if t4 { pc = pc + 1 }
    if t5 { pc = pc + 1 }

    println("")
    if pc == 5 {
        println("[schizophrenia_self_phi] 5/5 PASS — P124 DONE (self-tag + hallucination + aberrant salience + agency + global fragmentation)")
    } else {
        println("[schizophrenia_self_phi] " + str(pc) + "/5 PASS — SOME FAILED")
    }
}

main()
