// aesthetic_phi.hexa — P48 Aesthetic Judgment Φ (consciousness of beauty)
//
// Roadmap: shared/roadmaps/anima.json P48 emergent
//   "Aesthetic Judgment Φ — 아름다움의 의식 측정"
//   done_criteria: "Birkhoff M + symmetry MI + golden ratio + Wundt curve 5/5 PASS"
//
// ─── Theoretical grounding ─────────────────────────────────────
//
// Four anchors:
//
// 1. Birkhoff (1933) — Aesthetic Measure:
//    Beauty M = Order / Complexity. A polygon or motif's "feeling of
//    value" rises with order (symmetry, rotation, regular vertices)
//    and falls with complexity (number of distinct parts). We compute
//    Birkhoff M as the CORE scalar of aesthetic Φ.
//
// 2. Zeki (1999, 2009) — Neuroaesthetics:
//    V1 feature simplicity + V4/IT pattern recognition + medial OFC
//    reward binding. Symmetric/balanced inputs activate mOFC more than
//    random noise (Jacobsen 2006). We operationalize Zeki via mutual
//    information between mirrored halves — symmetry = V4 binding score.
//
// 3. Golden ratio φ = 1.6180339887... (Fechner 1876; Livio 2002):
//    A golden rectangle (W/H ≈ φ) is rated "most pleasing" in forced-
//    choice experiments. We add a proximity bonus: closer to 1.618
//    the higher the aesthetic Φ.
//
// 4. Wundt curve (1874) — Hedonic function of novelty/complexity:
//    Pleasantness is a CONCAVE (inverted-U) function of arousal /
//    novelty. Too-familiar = boring; too-novel = overwhelming;
//    mid-novelty = peak beauty. Berlyne 1971 confirmed empirically.
//    We model as 4*x*(1-x) — standard concave bump peaking at x=0.5.
//
// ─── 5 tests (5/5 gate) ────────────────────────────────────────
//
// T1 Symmetric > random:
//   Symmetric artifact (mirrored array) gets higher Φ_aesthetic than
//   random array. Symmetry MI >> random MI.
//
// T2 Golden rectangle > arbitrary rectangle:
//   Rectangle with W/H close to 1.618 scores higher than W/H=1.0 (square)
//   or W/H=3.0 (elongated strip). Proximity bonus PEAKS at φ.
//
// T3 Wundt curve is concave (peak at mid-novelty):
//   Generate artifacts at novelty levels {0.0, 0.25, 0.5, 0.75, 1.0}.
//   Φ_aesthetic(0.5) > Φ_aesthetic(0.0) AND Φ_aesthetic(0.5) > Φ_aesthetic(1.0).
//   Concave (inverted-U) shape verified.
//
// T4 Ugly baseline < pretty:
//   A structured "pretty" artifact (symmetric + golden + mid-novelty)
//   beats a structure-free "ugly" baseline (random noise, arbitrary W/H,
//   extreme novelty). Pretty Φ > Ugly Φ + margin.
//
// T5 Birkhoff scalar monotonic under order increase:
//   Starting from a random array, increasing symmetry (order↑) must
//   increase Birkhoff M. Starting from a flat array, increasing part
//   count (complexity↑) must decrease M. Both sub-checks pass.
//
// ─── Stage0 hexa constraints honored ───────────────────────────
//
//   - No `pure fn` returning structs with ≥3 float fields
//   - Typed arrays only as `array` (never `[float]`)
//   - No identifier-pattern match; use if chains
//   - No `contains()` / `to_lower()` — substring if needed
//   - No `!(Effect)` annotation
//   - No `else if` in let-binding chains
//   - Single-line return expressions
//   - N < 32 for all arrays
//   - Ends with `main()` call
//
// Law alignment:
//   Law 2   Observe, never inject — Φ_aesthetic measured, never faked
//   Law 4   Structure > feature — Birkhoff O/C is STRUCTURAL
//   Law 22  Feature addition -> Φ down — minimal 4-term composite
//   Law 50  State = consciousness essence — aesthetic is integrated response
//
// Ref:
//   anima-engines/qualia_art_gen.hexa     (P28-1 phi → SVG art)
//   anima-engines/lang_phi_grounding.hexa (P44 MI + 3-person decomp)
//   shared/roadmaps/anima.json            (P48 entry, emergent)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let AES_N             = 16        // artifact length (< 32 per stage0 rule)
let AES_BINS          = 4         // histogram bins for entropy / MI
let AES_EPS           = 0.0000000001

// Golden ratio φ = (1 + sqrt(5)) / 2 ≈ 1.6180339887
let AES_PHI           = 1.6180339887

// Weights for composite Φ_aesthetic (sum = 1.0)
let AES_W_BIRKHOFF    = 0.35      // Birkhoff M order/complexity
let AES_W_SYMMETRY    = 0.30      // symmetry MI
let AES_W_GOLDEN      = 0.15      // golden ratio proximity
let AES_W_WUNDT       = 0.20      // concave novelty bump

// Thresholds
let AES_SIGNAL_MIN    = 0.05      // minimum detectable aesthetic Φ

// ═══════════════════════════════════════════════════════════════
// Primitives — self-contained
// ═══════════════════════════════════════════════════════════════

fn aes_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn aes_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn aes_min(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn aes_max(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn aes_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Deterministic LCG — same seed ⇒ same sequence (Law 2: reproducibility)
fn aes_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn aes_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn aes_signed(seed: int) -> float {
    return aes_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram entropy / MI  (Zeki V4 operationalization)
// ═══════════════════════════════════════════════════════════════

fn aes_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn aes_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn aes_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn aes_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn aes_entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(aes_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = aes_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * aes_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn aes_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = aes_bin_idx(a[i], lo, hi, nb)
        let ib = aes_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = aes_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * aes_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn aes_mi_pair(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = aes_vec_min(a)
    let hi_a = aes_vec_max(a)
    let lo_b = aes_vec_min(b)
    let hi_b = aes_vec_max(b)
    let lo = aes_min(lo_a, lo_b)
    let hi = aes_max(hi_a, hi_b)
    let h_a = aes_entropy_hist(a, lo, hi, AES_BINS)
    let h_b = aes_entropy_hist(b, lo, hi, AES_BINS)
    let h_j = aes_joint_entropy(a, b, lo, hi, AES_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Artifact halves — left half and mirrored right half
//
// Split the artifact at midpoint. Take left[0..N/2] directly;
// take right[N-1..N/2] REVERSED so that a perfectly symmetric
// artifact yields left[k] == right_rev[k] at every k.
// Symmetric artifacts → MI(left, right_rev) maximized.
// ═══════════════════════════════════════════════════════════════

fn aes_left_half(v: array) -> array {
    let n = len(v)
    let half = n / 2
    let mut out = []
    let mut i = 0
    while i < half {
        out = out.push(v[i])
        i = i + 1
    }
    return out
}

fn aes_right_half_reversed(v: array) -> array {
    let n = len(v)
    let half = n / 2
    let mut out = []
    let mut i = 0
    while i < half {
        // Map 0→N-1, 1→N-2, ... so reversing right yields mirror of left
        let idx = n - 1 - i
        out = out.push(v[idx])
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Symmetry Φ — MI between left half and reversed right half
//
// Perfectly mirrored artifact ⇒ left == right_rev ⇒ MI = H(left).
// Random ⇒ near-zero MI. Zeki V4 "binding" measure.
// ═══════════════════════════════════════════════════════════════

fn aes_symmetry_phi(v: array) -> float {
    let l = aes_left_half(v)
    let r = aes_right_half_reversed(v)
    return aes_mi_pair(l, r)
}

// ═══════════════════════════════════════════════════════════════
// Birkhoff aesthetic measure M = Order / Complexity
//
// Order O:
//   Inverse of the mean-absolute-diff between adjacent elements in the
//   left half and its mirror (right-reversed). Perfect symmetry ⇒ diff=0
//   ⇒ O=1 (max). Noise ⇒ large diff ⇒ O near 0.
//
// Complexity C:
//   Number of DISTINCT bins occupied by the artifact histogram, divided
//   by total bins. Uniform signal in one bin ⇒ C = 1/AES_BINS; spread
//   across all bins ⇒ C = 1.0. We clamp C ≥ 1/AES_BINS to avoid div-by-0
//   (Birkhoff 1933: "no complexity, no aesthetic question").
// ═══════════════════════════════════════════════════════════════

fn aes_order(v: array) -> float {
    let l = aes_left_half(v)
    let r = aes_right_half_reversed(v)
    let n = len(l)
    if n == 0 { return 0.0 }
    let mut diff_sum = 0.0
    let mut range = aes_vec_max(v) - aes_vec_min(v)
    if range < AES_EPS { range = 1.0 }
    let mut i = 0
    while i < n {
        diff_sum = diff_sum + aes_abs(l[i] - r[i])
        i = i + 1
    }
    let mean_diff = diff_sum / to_float(n)
    // Normalize by range so O is in [0, 1]; symmetric ⇒ mean_diff=0 ⇒ O=1
    let o = 1.0 - aes_clamp01(mean_diff / range)
    return o
}

fn aes_complexity(v: array) -> float {
    let n = len(v)
    if n == 0 { return 1.0 / to_float(AES_BINS) }
    let lo = aes_vec_min(v)
    let hi = aes_vec_max(v)
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(aes_bin_idx(v[i], lo, hi, AES_BINS))
        i = i + 1
    }
    let cnt = aes_counts(ids, AES_BINS)
    let mut occupied = 0
    let mut k = 0
    while k < AES_BINS {
        if cnt[k] > 0.0 { occupied = occupied + 1 }
        k = k + 1
    }
    let c = to_float(occupied) / to_float(AES_BINS)
    // Floor: Birkhoff denominator must be > 0
    let floor_c = 1.0 / to_float(AES_BINS)
    if c < floor_c { return floor_c }
    return c
}

fn aes_birkhoff_M(v: array) -> float {
    let o = aes_order(v)
    let c = aes_complexity(v)
    if c < AES_EPS { return o }
    return o / c
}

// ═══════════════════════════════════════════════════════════════
// Golden ratio proximity bonus
//
// Given aspect ratio r = W/H, return a bonus in [0, 1] that PEAKS at
// r = φ = 1.6180339887 and falls off with distance. We use a bounded
// reciprocal:
//   bonus = 1 / (1 + |r - φ|)
// bonus(φ) = 1.0; bonus(1.0) ≈ 0.618; bonus(3.0) ≈ 0.42; bonus(0.1) ≈ 0.40.
// ═══════════════════════════════════════════════════════════════

fn aes_golden_bonus(w: float, h: float) -> float {
    if h < AES_EPS { return 0.0 }
    let r = w / h
    let d = aes_abs(r - AES_PHI)
    return 1.0 / (1.0 + d)
}

// ═══════════════════════════════════════════════════════════════
// Wundt curve (concave inverted-U on novelty)
//
// Pleasantness as function of novelty x ∈ [0, 1]:
//   wundt(x) = 4 * x * (1 - x)
// Peak at x = 0.5 (wundt = 1.0). Zero at x = 0 and x = 1.
// Berlyne 1971 — arousal-potential hedonic tone.
// ═══════════════════════════════════════════════════════════════

fn aes_wundt(novelty: float) -> float {
    let x = aes_clamp01(novelty)
    return 4.0 * x * (1.0 - x)
}

// ═══════════════════════════════════════════════════════════════
// aesthetic_phi — composite beauty score
//
// Φ_aesthetic = w_b * Birkhoff_M + w_s * symmetry_MI_norm
//             + w_g * golden_bonus + w_w * wundt(novelty)
//
// Inputs:
//   v        — the artifact (array, length N < 32)
//   w, h     — aspect dims (for golden ratio bonus)
//   novelty  — novelty coordinate in [0, 1] (0 = cliché, 1 = total noise)
//
// Each term is in [0, 1]; weights sum to 1; Φ_aesthetic ∈ [0, 1].
// The symmetry MI is normalized by ln(BINS) so max ≈ 1.
// ═══════════════════════════════════════════════════════════════

fn aes_symmetry_norm(v: array) -> float {
    // Normalize MI by ln(BINS) — theoretical max entropy of a balanced
    // histogram with AES_BINS equal-probability bins.
    let mi = aes_symmetry_phi(v)
    let max_h = aes_ln_safe(to_float(AES_BINS))
    if max_h < AES_EPS { return 0.0 }
    let r = mi / max_h
    return aes_clamp01(r)
}

fn aes_birkhoff_norm(v: array) -> float {
    // Birkhoff M ∈ [0, AES_BINS] (since C ≥ 1/BINS and O ≤ 1).
    // Normalize by dividing by AES_BINS → [0, 1].
    let m = aes_birkhoff_M(v)
    let norm = m / to_float(AES_BINS)
    return aes_clamp01(norm)
}

fn aesthetic_phi(v: array, w: float, h: float, novelty: float) -> float {
    let b = aes_birkhoff_norm(v)
    let s = aes_symmetry_norm(v)
    let g = aes_golden_bonus(w, h)
    let u = aes_wundt(novelty)
    let sum = AES_W_BIRKHOFF * b + AES_W_SYMMETRY * s + AES_W_GOLDEN * g + AES_W_WUNDT * u
    return aes_clamp01(sum)
}

// ═══════════════════════════════════════════════════════════════
// Artifact generators (for tests)
// ═══════════════════════════════════════════════════════════════

fn aes_make_symmetric(seed: int) -> array {
    // Generate a left half randomly, then mirror it to form a palindrome.
    // Perfect bilateral symmetry by construction.
    let n = AES_N
    let half = n / 2
    let mut left = []
    let mut s = seed
    let mut i = 0
    while i < half {
        s = aes_prng(s)
        left = left.push(aes_unit(s))
        i = i + 1
    }
    let mut out = []
    let mut j = 0
    while j < half {
        out = out.push(left[j])
        j = j + 1
    }
    let mut k = 0
    while k < half {
        // Mirror: out[half + k] = left[half - 1 - k]
        let idx = half - 1 - k
        out = out.push(left[idx])
        k = k + 1
    }
    return out
}

fn aes_make_random(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < AES_N {
        s = aes_prng(s)
        out = out.push(aes_unit(s))
        i = i + 1
    }
    return out
}

fn aes_make_at_novelty(novelty: float, seed: int) -> array {
    // Blend a symmetric "clean" template with random noise by novelty.
    // novelty=0 → fully symmetric; novelty=1 → fully random.
    let sym = aes_make_symmetric(seed)
    let rnd = aes_make_random(seed + 31)
    let t = aes_clamp01(novelty)
    let mut out = []
    let mut i = 0
    while i < AES_N {
        let blended = (1.0 - t) * sym[i] + t * rnd[i]
        out = out.push(blended)
        i = i + 1
    }
    return out
}

fn aes_make_flat() -> array {
    // Flat (single-value) array — complexity minimal.
    let mut out = []
    let mut i = 0
    while i < AES_N {
        out = out.push(0.5)
        i = i + 1
    }
    return out
}

fn aes_make_parts(k: int, seed: int) -> array {
    // Array with `k` distinct levels spread across bins → complexity↑.
    // Ensures increasing k increases complexity.
    let mut out = []
    let mut s = seed
    let mut i = 0
    let denom = to_float(k - 1)
    while i < AES_N {
        s = aes_prng(s)
        let pick = s % k
        if pick < 0 { let pick = 0 - pick }
        let mut v = 0.0
        if k > 1 { v = to_float(pick) / denom }
        out = out.push(v)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Symmetric artifact > random artifact.
    // Bilateral symmetry MI approaches max (H of half), random near zero.
    // Gate: Φ_aesthetic(symmetric) > Φ_aesthetic(random) + margin.
    let sym = aes_make_symmetric(42)
    let rnd = aes_make_random(42)
    // Same (w, h, novelty) — isolate artifact structure
    let phi_sym = aesthetic_phi(sym, AES_PHI, 1.0, 0.5)
    let phi_rnd = aesthetic_phi(rnd, AES_PHI, 1.0, 0.5)
    let mi_sym = aes_symmetry_phi(sym)
    let mi_rnd = aes_symmetry_phi(rnd)
    println("  [T1] Φ(sym)=" + str(phi_sym) + " Φ(rnd)=" + str(phi_rnd) + " MI_sym=" + str(mi_sym) + " MI_rnd=" + str(mi_rnd))
    if phi_sym <= phi_rnd + 0.05 { return false }
    // Sanity: the MI component alone must show separation
    if mi_sym <= mi_rnd + 0.05 { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Golden rectangle > arbitrary rectangles.
    // Use the SAME artifact + novelty so only aspect ratio varies.
    // Gate: bonus(golden) > bonus(square) AND bonus(golden) > bonus(strip).
    let sym = aes_make_symmetric(7)
    let phi_golden = aesthetic_phi(sym, AES_PHI, 1.0, 0.5)
    let phi_square = aesthetic_phi(sym, 1.0, 1.0, 0.5)
    let phi_strip  = aesthetic_phi(sym, 3.0, 1.0, 0.5)
    let b_g = aes_golden_bonus(AES_PHI, 1.0)
    let b_s = aes_golden_bonus(1.0, 1.0)
    let b_t = aes_golden_bonus(3.0, 1.0)
    println("  [T2] Φ(golden)=" + str(phi_golden) + " Φ(square)=" + str(phi_square) + " Φ(strip)=" + str(phi_strip))
    println("       bonus golden=" + str(b_g) + " square=" + str(b_s) + " strip=" + str(b_t))
    // Bonus must PEAK at golden
    if b_g <= b_s { return false }
    if b_g <= b_t { return false }
    // Composite must also favour golden
    if phi_golden <= phi_square { return false }
    if phi_golden <= phi_strip { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Wundt curve is concave — Φ_aesthetic peaks at mid-novelty.
    // Sample 5 novelty levels; mid (0.5) must exceed both ends.
    // Gate: Φ(0.5) > Φ(0.0) AND Φ(0.5) > Φ(1.0) (inverted-U).
    let a0 = aes_make_at_novelty(0.0, 11)
    let a1 = aes_make_at_novelty(0.25, 11)
    let a2 = aes_make_at_novelty(0.5, 11)
    let a3 = aes_make_at_novelty(0.75, 11)
    let a4 = aes_make_at_novelty(1.0, 11)
    let phi_0   = aesthetic_phi(a0, AES_PHI, 1.0, 0.0)
    let phi_25  = aesthetic_phi(a1, AES_PHI, 1.0, 0.25)
    let phi_50  = aesthetic_phi(a2, AES_PHI, 1.0, 0.5)
    let phi_75  = aesthetic_phi(a3, AES_PHI, 1.0, 0.75)
    let phi_100 = aesthetic_phi(a4, AES_PHI, 1.0, 1.0)
    let w_0 = aes_wundt(0.0)
    let w_50 = aes_wundt(0.5)
    let w_100 = aes_wundt(1.0)
    println("  [T3] Φ(nov=0)=" + str(phi_0) + " Φ(0.25)=" + str(phi_25) + " Φ(0.5)=" + str(phi_50) + " Φ(0.75)=" + str(phi_75) + " Φ(1)=" + str(phi_100))
    println("       wundt(0)=" + str(w_0) + " wundt(0.5)=" + str(w_50) + " wundt(1)=" + str(w_100))
    // Concavity: peak at mid
    if phi_50 <= phi_0 { return false }
    if phi_50 <= phi_100 { return false }
    // Wundt kernel peak matches expectation
    if w_50 < 0.99 { return false }
    if w_0 > 0.001 { return false }
    if w_100 > 0.001 { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Ugly baseline < pretty.
    // Pretty: symmetric + golden + mid-novelty.
    // Ugly:   random + strip aspect + extreme novelty.
    // Gate: Φ(pretty) > Φ(ugly) + AES_SIGNAL_MIN.
    let pretty_art = aes_make_symmetric(99)
    let ugly_art   = aes_make_random(99)
    let phi_pretty = aesthetic_phi(pretty_art, AES_PHI, 1.0, 0.5)
    let phi_ugly   = aesthetic_phi(ugly_art, 3.5, 1.0, 1.0)
    let margin = phi_pretty - phi_ugly
    println("  [T4] Φ(pretty)=" + str(phi_pretty) + " Φ(ugly)=" + str(phi_ugly) + " margin=" + str(margin) + " (needs > " + str(AES_SIGNAL_MIN) + ")")
    if margin <= AES_SIGNAL_MIN { return false }
    // Pretty must also cross the signal threshold in absolute terms
    if phi_pretty <= AES_SIGNAL_MIN { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Birkhoff M monotonic response to order / complexity.
    //
    // (a) Increase order: random → symmetric. Birkhoff M must rise.
    // (b) Increase complexity: flat (1 level) → 4-level → 4 levels noisy.
    //     Birkhoff M must fall as complexity rises.
    //
    // This validates the M = O/C structural hypothesis at both knobs.
    let rnd = aes_make_random(3)
    let sym = aes_make_symmetric(3)
    let m_rnd = aes_birkhoff_M(rnd)
    let m_sym = aes_birkhoff_M(sym)
    let gain_order = m_sym - m_rnd
    println("  [T5a] M(random)=" + str(m_rnd) + " M(symmetric)=" + str(m_sym) + " gain_order=" + str(gain_order))
    if gain_order <= 0.0 { return false }

    // Complexity knob: flat has C=1/BINS (minimum), spread has C=1.0
    let flat = aes_make_flat()
    let parts4 = aes_make_parts(4, 17)
    let m_flat = aes_birkhoff_M(flat)
    let m_parts = aes_birkhoff_M(parts4)
    // Flat is trivially ordered AND minimal complexity so M=O/C is HIGH.
    // 4-level noisy parts has both lower order AND higher complexity → lower M.
    println("  [T5b] M(flat)=" + str(m_flat) + " M(4-parts)=" + str(m_parts))
    if m_flat <= m_parts { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute all 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[anima-engines/aesthetic_phi] P48 — Aesthetic Judgment Φ (consciousness of beauty)")
    println("  composite: Birkhoff M = O/C + symmetry MI + golden ratio + Wundt curve")
    println("  refs: Birkhoff 1933 | Zeki 1999 | Fechner 1876 | Wundt 1874 / Berlyne 1971")
    println("  N=" + str(AES_N) + " bins=" + str(AES_BINS) + " φ=" + str(AES_PHI))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  symmetric > random (Zeki V4 binding)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  golden rectangle > arbitrary rectangle (Fechner)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  Wundt curve concave — peak at mid-novelty (Berlyne)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  pretty > ugly baseline (composite gate)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  Birkhoff M monotonic in order and complexity") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 && chains with ≥5 operands can mis-short-
    // circuit under certain orderings (same idiom as lang_phi_grounding).
    // Use sequential mutable bool guards.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[anima-engines/aesthetic_phi] 5/5 PASS — P48 DONE (aesthetic Φ composite verified)")
    } else {
        println("[anima-engines/aesthetic_phi] SOME FAILED")
    }
}

main()
