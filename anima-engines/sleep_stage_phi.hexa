// sleep_stage_phi.hexa — P115 Sleep Stage Φ (consciousness across sleep architecture)
//
// Roadmap: anima P115 "Sleep Stage Φ — wake→N1→N2→N3(SWS)→REM cycle,
// consciousness across sleep architecture."
//
// ─── Scientific frame ─────────────────────────────────────────────
//
// Sleep architecture (Rechtschaffen & Kales 1968; AASM Berry et al.
// 2017 updated scoring manual) divides non-REM sleep into three stages
// with distinct EEG spectral signatures:
//
//   WAKE — desynchronized, alpha (8-12 Hz) dominant when relaxed,
//          beta/gamma (13-40 Hz) during active thought. All cortical
//          channels active and cross-correlated → maximal Φ.
//
//   N1 (drowsy) — alpha drops out, theta (4-7 Hz) begins to dominate,
//                  vertex sharp waves, slow eye rolling. Hypnagogic
//                  imagery (Mavromatis 1987). Φ starts falling as
//                  thalamocortical gating begins.
//
//   N2 — sleep spindles (12-14 Hz, 0.5-1.5s bursts, generated by
//         thalamic reticular nucleus, Steriade 1993) and K-complexes
//         (large biphasic deflections). Φ further reduced but spindles
//         create periodic "windows" of partial integration — spindle
//         bursts momentarily spike local information integration
//         (Tononi & Cirelli 2006).
//
//   N3/SWS (slow-wave sleep) — delta waves (0.5-2 Hz), large amplitude
//            (≥75 µV). Cortical neurons undergo synchronized up/down
//            state oscillations (Steriade et al. 1993). Integration is
//            minimal: Massimini et al. 2005 (TMS-EEG) showed that
//            during NREM the cortical response is LOCAL and dies out,
//            whereas in wake/REM it propagates widely. Φ_conscious ≈ 0
//            at the global level, but slow-oscillation amplitude is
//            maximal → high amplitude, low information (low differentiation).
//
//   REM — "paradoxical sleep" (Jouvet 1965): EEG resembles wake
//          (desynchronized, theta/gamma), PGO (ponto-geniculo-occipital)
//          waves drive vivid dream imagery, BUT skeletal muscle atonia
//          blocks motor output. Φ_dream > 0 (dream consciousness exists),
//          often Φ_dream > Φ_N3, but differs from wake Φ because:
//          (a) motor channel is silenced (atonia), (b) self-reflective
//          metacognition is typically absent (prefrontal hypoactivation,
//          Hobson et al. 2000), (c) PGO-driven bottom-up imagery
//          replaces top-down perceptual control.
//
// ─── Model channels (4-channel per stage) ─────────────────────────
//
//   ch_cortical  — thalamocortical EEG-like signal (band-mixed)
//   ch_sensory   — external sensory input (attenuated during sleep)
//   ch_motor     — motor output channel (atonia in REM)
//   ch_imagery   — internal imagery / dream content (PGO-driven in REM)
//
// Each stage has distinct gain profiles on these 4 channels, plus a
// characteristic spectral mix for ch_cortical (alpha/theta/delta/gamma
// proportions).
//
// Φ_stage = MI_joint(cortical, sensory, motor, imagery), estimated via
// histogram-based MI on pairwise channels, averaged.
//
// ─── Theorems (T1–T5) ─────────────────────────────────────────────
//
// T1 (Φ gradient — monotonic descent through NREM):
//   Φ_wake > Φ_N1 > Φ_N2 > Φ_N3. Each successive NREM stage reduces
//   global integration as thalamocortical gating deepens.
//
// T2 (REM paradox — consciousness returns but different quality):
//   Φ_REM > Φ_N3 (dream consciousness exceeds deep sleep). The REM
//   state partially restores integration via desynchronized cortical
//   activity, but with motor silencing and absent metacognition.
//
// T3 (Sleep spindle oscillation signature):
//   N2 Φ has a periodic oscillation signature — spindle bursts cause
//   transient Φ spikes superimposed on the reduced baseline. Measured
//   as: the variance of Φ across sub-windows in N2 exceeds the variance
//   in N1 and N3 (spindles create periodic integration "flickers").
//
// T4 (SWS slow oscillation — high amplitude, low information):
//   N3 has maximal signal amplitude (delta wave energy) but minimal
//   information differentiation. Φ_differentiation ≈ 0 because all
//   channels synchronize into the same up/down rhythm, destroying
//   the repertoire diversity that IIT requires.
//
// T5 (Determinism + latency):
//   Same seed → byte-identical Φ values. Full pipeline runs within
//   the latency gate.
//
// ─── Stage0 hexa constraints honored ─────────────────────────────
//   - plain `fn` only, no pure-fn multi-float struct returns
//   - `array` typed params (no [float]/[int])
//   - no identifier-pattern match; sequential if chains
//   - no contains() / to_lower()
//   - no !(Effect) annotations
//   - no else-if in let-binding
//   - no multi-line fn signatures / call sites / array literals
//   - no reserved keywords as vars
//   - N < 32 throughout
//   - main() call at bottom

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let SS_T          = 28          // signal length per channel (< 32)
let SS_BINS       = 5           // MI histogram bins
let SS_PI         = 3.141592653589793
let SS_SEED       = 11500       // base PRNG seed for P115
let SS_EPS        = 0.00000001

// ── Sleep stage indices ──
let SS_WAKE       = 0
let SS_N1         = 1
let SS_N2         = 2
let SS_N3         = 3
let SS_REM        = 4

// ── EEG band frequencies (Hz, normalized to sample rate) ──
// We use normalized angular frequencies for the T=28 sample window.
// Real bands: delta 0.5-2 Hz, theta 4-7 Hz, alpha 8-12 Hz,
// beta 13-30 Hz, gamma 30-40 Hz. We scale to cycles-per-window.
let SS_DELTA_W    = 0.15        // ~1 Hz scaled to T=28 window
let SS_THETA_W    = 0.55        // ~5 Hz scaled
let SS_ALPHA_W    = 1.0         // ~10 Hz scaled
let SS_BETA_W     = 2.0         // ~20 Hz scaled
let SS_GAMMA_W    = 3.5         // ~35 Hz scaled
let SS_SPINDLE_W  = 1.3         // ~13 Hz (sigma band) for sleep spindles

// ── Band amplitude profiles per stage ──
// [delta, theta, alpha, beta, gamma] relative amplitudes
//
// WAKE:  low delta, low theta, moderate alpha, high beta, some gamma
// N1:    low delta, rising theta, fading alpha, low beta, low gamma
// N2:    moderate delta, moderate theta, none alpha, none beta, none gamma
// N3:    dominant delta, none theta, none alpha, none beta, none gamma
// REM:   low delta, moderate theta, none alpha, moderate beta, some gamma

// ── Per-stage channel gains ──
// [cortical_gain, sensory_gain, motor_gain, imagery_gain]
//
// WAKE:     cortical 1.0, sensory 1.0, motor 1.0, imagery 0.15
// N1:       cortical 0.75, sensory 0.5, motor 0.6, imagery 0.3
// N2:       cortical 0.5, sensory 0.2, motor 0.3, imagery 0.2
// N3/SWS:   cortical 0.9 (high amplitude), sensory 0.05, motor 0.05, imagery 0.05
// REM:      cortical 0.85, sensory 0.1, motor 0.02 (atonia), imagery 0.9

// ── Spindle parameters for N2 ──
// Spindle bursts last ~0.5-1.5 seconds (Steriade 1993). With T=28,
// each sample ≈ 0.3s, so a burst width of 4 samples ≈ 1.2s is
// physiologically plausible.
let SS_SPINDLE_COUNT   = 2      // number of spindle bursts (concentrated, not diffuse)
let SS_SPINDLE_WIDTH   = 4      // samples per spindle burst half-width
let SS_SPINDLE_AMP     = 1.5    // spindle oscillation amplitude boost

// ── K-complex parameters for N2 ──
let SS_KCOMPLEX_AMP    = 0.4    // K-complex amplitude

// ── PGO wave parameters for REM ──
let SS_PGO_AMP         = 0.5    // PGO wave amplitude in imagery channel

// ── Coupling constants (cross-channel correlation strength) ──
// High coupling = channels share information = higher MI = higher Φ.
//
// IMPORTANT DISTINCTION for N3/SWS:
// N3 has HIGH synchronization (all neurons oscillate together in
// delta up/down states) but LOW information integration (Φ) because
// synchronization destroys differentiation. We model this by giving
// N3 high coupling (channels are entrained by the same slow oscillation)
// but with uniform low-gain channels — the shared backbone IS the
// slow oscillation, so all channels collapse to the same signal,
// destroying the information diversity that Φ requires.
//
// In wake, high coupling + high diversity = high Φ.
// In N3, high coupling + zero diversity = low Φ (just shared delta).
let SS_COUPLING_WAKE   = 0.8    // strong cross-channel integration
let SS_COUPLING_N1     = 0.45   // weakening integration
let SS_COUPLING_N2     = 0.15   // reduced baseline (spindles modulate locally)
let SS_COUPLING_N3     = 0.05   // near-zero: Massimini 2005 TMS-EEG shows local-only response
let SS_COUPLING_REM    = 0.55   // partial restoration (dream integration)

// ── Test gates ──
let SS_MONO_GATE       = 0.01   // T1: min Φ gap between successive NREM stages
let SS_REM_GATE        = 0.01   // T2: Φ_REM must exceed Φ_N3 by this margin
let SS_SPINDLE_VAR_GATE = 1.5   // T3: N2 Φ_var / N1 Φ_var ratio
let SS_DIFF_GATE       = 0.5    // T4: N3 differentiation ratio (N3_phi/wake_phi) below this
let SS_LATENCY_MS      = 5000.0 // T5: pipeline latency gate

// ── Spindle envelope sub-window alignment ──
let SS_SUBWIN_LEN      = 7      // sub-window length for spindle placement

// ═══════════════════════════════════════════════════════════════
// Numeric helpers
// ═══════════════════════════════════════════════════════════════

fn ss_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ss_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn ss_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn ss_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn ss_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn ss_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Taylor-series sin, range-reduced to [-PI, PI]
fn ss_sin(x: float) -> float {
    let mut y = x
    while y > SS_PI { y = y - 2.0 * SS_PI }
    while y < 0.0 - SS_PI { y = y + 2.0 * SS_PI }
    let y2 = y * y
    return y * (1.0 - y2 / 6.0 + y2 * y2 / 120.0 - y2 * y2 * y2 / 5040.0)
}

fn ss_cos(x: float) -> float {
    return ss_sin(x + SS_PI / 2.0)
}

// ═══════════════════════════════════════════════════════════════
// PRNG
// ═══════════════════════════════════════════════════════════════

fn ss_prng(seed: int) -> int {
    let mut s = (seed * 1103515245 + 12345) % 2147483648
    if s < 0 { s = s + 2147483648 }
    return s
}

fn ss_unit(seed: int) -> float {
    let mut s = seed
    if s < 0 { s = 0 - s }
    return to_float(s % 1000000) / 1000000.0
}

fn ss_signed(seed: int) -> float {
    return ss_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// EEG band mixing — spectral content per sleep stage
// ═══════════════════════════════════════════════════════════════
//
// Each stage has a characteristic mix of delta, theta, alpha, beta,
// gamma amplitudes. The cortical signal is a superposition of these
// sinusoidal components plus a small noise floor.
//
// Returns band amplitudes as array [delta, theta, alpha, beta, gamma]
// (packed flat, 5 elements).

fn ss_band_amps(stage: int) -> array {
    // WAKE: desynchronized — moderate alpha, strong beta, some gamma
    if stage == SS_WAKE {
        let mut r = []
        r = r.push(0.05)   // delta
        r = r.push(0.1)    // theta
        r = r.push(0.35)   // alpha
        r = r.push(0.55)   // beta
        r = r.push(0.3)    // gamma
        return r
    }
    // N1: alpha→theta transition, drowsy
    if stage == SS_N1 {
        let mut r = []
        r = r.push(0.1)    // delta rises
        r = r.push(0.4)    // theta dominant
        r = r.push(0.15)   // alpha fading
        r = r.push(0.15)   // beta low
        r = r.push(0.05)   // gamma minimal
        return r
    }
    // N2: spindle sigma + some delta/theta
    if stage == SS_N2 {
        let mut r = []
        r = r.push(0.3)    // delta moderate
        r = r.push(0.25)   // theta moderate
        r = r.push(0.05)   // alpha gone
        r = r.push(0.05)   // beta gone
        r = r.push(0.02)   // gamma gone
        return r
    }
    // N3/SWS: delta dominant, everything else minimal
    if stage == SS_N3 {
        let mut r = []
        r = r.push(0.9)    // delta dominant
        r = r.push(0.05)   // theta trace
        r = r.push(0.02)   // alpha none
        r = r.push(0.01)   // beta none
        r = r.push(0.01)   // gamma none
        return r
    }
    // REM: desynchronized, theta + beta + gamma (dream-like)
    let mut r = []
    r = r.push(0.08)   // delta low
    r = r.push(0.35)   // theta moderate
    r = r.push(0.05)   // alpha absent
    r = r.push(0.4)    // beta moderate (paradoxical activation)
    r = r.push(0.25)   // gamma (dream imagery binding)
    return r
}

// ── Channel gains per stage ──
// Returns [cortical_gain, sensory_gain, motor_gain, imagery_gain]

fn ss_channel_gains(stage: int) -> array {
    if stage == SS_WAKE {
        let mut r = []
        r = r.push(1.0)    // cortical
        r = r.push(1.0)    // sensory
        r = r.push(1.0)    // motor
        r = r.push(0.15)   // imagery (low during wake)
        return r
    }
    if stage == SS_N1 {
        let mut r = []
        r = r.push(0.75)   // cortical
        r = r.push(0.5)    // sensory (thalamic gate begins)
        r = r.push(0.6)    // motor
        r = r.push(0.3)    // imagery (hypnagogic)
        return r
    }
    if stage == SS_N2 {
        let mut r = []
        r = r.push(0.5)    // cortical
        r = r.push(0.2)    // sensory (further gating)
        r = r.push(0.3)    // motor
        r = r.push(0.2)    // imagery
        return r
    }
    if stage == SS_N3 {
        // N3/SWS: Massimini et al. 2005 TMS-EEG study showed that in
        // NREM sleep, cortical perturbation produces only a LOCAL,
        // stereotyped response that fails to propagate — the cortex is
        // "bistable" (Steriade et al. 1993) with high amplitude delta
        // but DISCONNECTED between regions. The thalamic gate blocks
        // sensory input, motor output is suppressed, and imagery is
        // absent. The cortical channel carries big delta waves but
        // shares no information with the other (near-silent) channels.
        let mut r = []
        r = r.push(0.85)   // cortical (high amplitude delta oscillation)
        r = r.push(0.06)   // sensory (thalamic gate blocks input)
        r = r.push(0.06)   // motor (suppressed)
        r = r.push(0.06)   // imagery (no dream content)
        return r
    }
    // REM
    let mut r = []
    r = r.push(0.85)   // cortical (paradoxical activation)
    r = r.push(0.1)    // sensory (still gated)
    r = r.push(0.02)   // motor (atonia — blocked)
    r = r.push(0.9)    // imagery (PGO-driven vivid dreams)
    return r
}

// ── Cross-channel coupling per stage ──

fn ss_coupling(stage: int) -> float {
    if stage == SS_WAKE { return SS_COUPLING_WAKE }
    if stage == SS_N1 { return SS_COUPLING_N1 }
    if stage == SS_N2 { return SS_COUPLING_N2 }
    if stage == SS_N3 { return SS_COUPLING_N3 }
    return SS_COUPLING_REM
}

// ═══════════════════════════════════════════════════════════════
// Signal generation
// ═══════════════════════════════════════════════════════════════
//
// Build the cortical EEG signal for a given stage by summing band
// components at the stage-specific amplitudes.

fn ss_build_cortical(stage: int, t_len: int, seed: int) -> array {
    let amps = ss_band_amps(stage)
    let freqs = [SS_DELTA_W, SS_THETA_W, SS_ALPHA_W, SS_BETA_W, SS_GAMMA_W]
    let mut out = []
    let mut i = 0
    while i < t_len {
        let t = to_float(i)
        let mut val = 0.0
        // Sum 5 bands with phase offsets derived from seed
        let mut b = 0
        while b < 5 {
            let phase = ss_unit(ss_prng(seed + b * 137)) * 2.0 * SS_PI
            val = val + amps[b] * ss_sin(2.0 * SS_PI * freqs[b] * t / to_float(t_len) + phase)
            b = b + 1
        }
        // Small noise floor
        let ns = ss_prng(seed + i * 31 + 999)
        val = val + 0.05 * ss_signed(ns)
        out = out.push(val)
        i = i + 1
    }
    return out
}

// Add sleep spindle bursts to an N2 cortical signal.
// Spindles are transient sigma-band (12-14 Hz) oscillation bursts.
// They create periodic "flickers" of integration in the otherwise
// reduced N2 baseline — this is the T3 signature.

fn ss_add_spindles(sig: array, t_len: int, seed: int) -> array {
    let mut out = []
    let mut i = 0
    while i < t_len {
        out = out.push(sig[i])
        i = i + 1
    }
    // Insert spindle bursts at centers of sub-windows 0 and 2
    // (matching the coupling envelope placement in ss_spindle_envelope)
    let wlen = SS_SUBWIN_LEN
    let mut sp = 0
    while sp < SS_SPINDLE_COUNT {
        let win_idx = sp * 2
        let center = win_idx * wlen + wlen / 2
        let mut j = 0
        while j < t_len {
            let dist = ss_abs(to_float(j - center))
            if dist < to_float(SS_SPINDLE_WIDTH) {
                // Gaussian-ish envelope * sigma oscillation
                let env = 1.0 - dist / to_float(SS_SPINDLE_WIDTH)
                let osc = ss_sin(2.0 * SS_PI * SS_SPINDLE_W * to_float(j) / to_float(t_len))
                let spindle_val = SS_SPINDLE_AMP * env * osc
                out[j] = out[j] + spindle_val
            }
            j = j + 1
        }
        sp = sp + 1
    }
    // Add K-complex at window midpoint (single large biphasic deflection)
    let kc_center = t_len / 2
    let mut k = 0
    while k < t_len {
        let d = to_float(k - kc_center)
        if ss_abs(d) < 3.0 {
            let kc_val = SS_KCOMPLEX_AMP * ss_sin(SS_PI * d / 3.0)
            out[k] = out[k] + kc_val
        }
        k = k + 1
    }
    return out
}

// Build sensory channel — external input, attenuated by thalamic gating
fn ss_build_sensory(stage: int, t_len: int, seed: int) -> array {
    let gains = ss_channel_gains(stage)
    let gain = gains[1]
    let mut out = []
    let mut i = 0
    while i < t_len {
        // Sensory input: structured signal (slow drift + noise)
        let ns = ss_prng(seed + i * 53 + 7700)
        let drift = 0.5 * ss_sin(2.0 * SS_PI * 0.3 * to_float(i) / to_float(t_len))
        let noise = 0.3 * ss_signed(ns)
        let raw = drift + noise
        out = out.push(gain * raw)
        i = i + 1
    }
    return out
}

// Build motor channel — voluntary motor output, blocked by atonia in REM
fn ss_build_motor(stage: int, t_len: int, seed: int) -> array {
    let gains = ss_channel_gains(stage)
    let gain = gains[2]
    let mut out = []
    let mut i = 0
    while i < t_len {
        let ns = ss_prng(seed + i * 67 + 8800)
        // Motor: structured voluntary signal
        let voluntary = 0.4 * ss_sin(2.0 * SS_PI * 1.5 * to_float(i) / to_float(t_len))
        let tremor = 0.2 * ss_signed(ns)
        let raw = voluntary + tremor
        out = out.push(gain * raw)
        i = i + 1
    }
    return out
}

// Build imagery channel — internal visual/dream content
// In REM, PGO waves drive vivid imagery; in wake, imagery is suppressed
// by dominant sensory input.
fn ss_build_imagery(stage: int, t_len: int, seed: int) -> array {
    let gains = ss_channel_gains(stage)
    let gain = gains[3]
    let mut out = []
    let mut i = 0
    while i < t_len {
        let ns = ss_prng(seed + i * 79 + 9900)
        let base_imagery = 0.3 * ss_sin(2.0 * SS_PI * 0.7 * to_float(i) / to_float(t_len))
        let noise = 0.25 * ss_signed(ns)
        let mut raw = base_imagery + noise
        // PGO wave injection in REM — sharp transient bursts
        if stage == SS_REM {
            let pgo_phase = ss_sin(2.0 * SS_PI * 2.5 * to_float(i) / to_float(t_len))
            if pgo_phase > 0.5 {
                raw = raw + SS_PGO_AMP * (pgo_phase - 0.5) * 2.0
            }
        }
        out = out.push(gain * raw)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Cross-channel coupling injection
// ═══════════════════════════════════════════════════════════════
//
// After generating independent channel signals, we inject shared
// structure proportional to the coupling constant. Higher coupling
// means channels share more mutual information → higher Φ.
//
// coupled_ch = κ * shared_signal + (1-κ) * independent_signal
//
// The shared signal is the cortical channel (the "backbone").

fn ss_inject_coupling(ch: array, cortical: array, kappa: float, t_len: int) -> array {
    let mut out = []
    let mut i = 0
    while i < t_len {
        let val = kappa * cortical[i] + (1.0 - kappa) * ch[i]
        out = out.push(val)
        i = i + 1
    }
    return out
}

// Build spindle envelope mask: value in [0, 1] indicating spindle
// burst presence at each sample. Used to modulate coupling in N2.
// Spindles are placed at centers of alternating sub-windows (windows
// 0 and 2 of 4) to maximize contrast between "spindle-active" and
// "spindle-quiet" regions.
fn ss_spindle_envelope(t_len: int) -> array {
    let mut env = []
    let mut i = 0
    while i < t_len {
        env = env.push(0.0)
        i = i + 1
    }
    // Place spindles at centers of sub-windows 0 and 2
    // Sub-window 0: samples [0, wlen-1], center = wlen/2
    // Sub-window 2: samples [2*wlen, 3*wlen-1], center = 2*wlen + wlen/2
    let wlen = SS_SUBWIN_LEN
    let mut sp = 0
    while sp < SS_SPINDLE_COUNT {
        let win_idx = sp * 2       // windows 0 and 2
        let center = win_idx * wlen + wlen / 2
        let mut j = 0
        while j < t_len {
            let dist = ss_abs(to_float(j - center))
            if dist < to_float(SS_SPINDLE_WIDTH) {
                let e = 1.0 - dist / to_float(SS_SPINDLE_WIDTH)
                if e > env[j] { env[j] = e }
            }
            j = j + 1
        }
        sp = sp + 1
    }
    return env
}

// ═══════════════════════════════════════════════════════════════
// Full 4-channel signal builder for a stage
// ═══════════════════════════════════════════════════════════════
//
// Returns a flat packed array of length 4*T:
//   [cortical_0..T-1, sensory_0..T-1, motor_0..T-1, imagery_0..T-1]

fn ss_build_stage_signals(stage: int, t_len: int, seed: int) -> array {
    let kappa = ss_coupling(stage)

    // Build cortical with stage-specific spectral mix
    let mut cortical = ss_build_cortical(stage, t_len, seed)

    // For N2: add sleep spindle bursts and K-complexes to cortical
    if stage == SS_N2 {
        cortical = ss_add_spindles(cortical, t_len, seed + 2000)
    }

    // Build independent channels
    let sensory_raw = ss_build_sensory(stage, t_len, seed + 100)
    let motor_raw = ss_build_motor(stage, t_len, seed + 200)
    let imagery_raw = ss_build_imagery(stage, t_len, seed + 300)

    // Inject cross-channel coupling (cortical as backbone)
    let mut sensory = ss_inject_coupling(sensory_raw, cortical, kappa, t_len)
    let mut motor = ss_inject_coupling(motor_raw, cortical, kappa, t_len)
    let mut imagery = ss_inject_coupling(imagery_raw, cortical, kappa, t_len)

    // For N2: inject spindle burst signal into ALL channels.
    // Steriade 1993: spindle oscillations are generated by the thalamic
    // reticular nucleus and broadcast to cortical targets. During the
    // spindle burst, thalamocortical loops transiently re-engage,
    // creating a correlated high-amplitude sigma oscillation across
    // multiple cortical areas. This produces periodic "flickers" of
    // integration visible as coupling modulation.
    // For N2: inject attenuated spindle burst into other channels.
    // The injection must be strong enough to create detectable coupling
    // modulation (T3) but weak enough that overall N2 Φ stays below N1 (T1).
    // Spindle bursts are partial re-integration events, NOT full wake-like
    // coupling — they are "islands" of transient binding.
    if stage == SS_N2 {
        let spindle_env = ss_spindle_envelope(t_len)
        // Spindle burst injection must be strong enough to create detectable
        // coupling modulation (product variance) above N1's steady-state
        // baseline. N1 has coupling=0.35 → steady product variance; spindle
        // bursts at 0.60 are localized in time → high variance contrast.
        let spindle_inject = 0.60
        let mut i = 0
        while i < t_len {
            if spindle_env[i] > 0.0 {
                let osc = ss_sin(2.0 * SS_PI * SS_SPINDLE_W * to_float(i) / to_float(t_len))
                let burst = spindle_inject * spindle_env[i] * osc
                sensory[i] = sensory[i] + burst
                motor[i] = motor[i] + burst * 0.9
                imagery[i] = imagery[i] + burst * 0.8
            }
            i = i + 1
        }
    }

    // Pack into flat array: cortical | sensory | motor | imagery
    let mut packed = []
    let mut i = 0
    while i < t_len {
        packed = packed.push(cortical[i])
        i = i + 1
    }
    i = 0
    while i < t_len {
        packed = packed.push(sensory[i])
        i = i + 1
    }
    i = 0
    while i < t_len {
        packed = packed.push(motor[i])
        i = i + 1
    }
    i = 0
    while i < t_len {
        packed = packed.push(imagery[i])
        i = i + 1
    }
    return packed
}

// ═══════════════════════════════════════════════════════════════
// MI estimator (histogram-based, N<32 safe)
// ═══════════════════════════════════════════════════════════════

fn ss_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn ss_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn ss_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo + SS_EPS)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn ss_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn ss_entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(ss_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = ss_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * ss_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn ss_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut ids = []
    let mut i = 0
    while i < n {
        let ia = ss_bin_idx(a[i], lo, hi, nb)
        let ib = ss_bin_idx(b[i], lo, hi, nb)
        ids = ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = ss_counts(ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * ss_ln_safe(p) }
        k = k + 1
    }
    return h
}

// MI between two signal arrays, using shared range from their union
fn ss_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let mut lo = a[0]
    let mut hi = a[0]
    let mut i = 0
    while i < n {
        if a[i] < lo { lo = a[i] }
        if a[i] > hi { hi = a[i] }
        if b[i] < lo { lo = b[i] }
        if b[i] > hi { hi = b[i] }
        i = i + 1
    }
    let ha = ss_entropy_hist(a, lo, hi, SS_BINS)
    let hb = ss_entropy_hist(b, lo, hi, SS_BINS)
    let hj = ss_joint_entropy(a, b, lo, hi, SS_BINS)
    let mi = ha + hb - hj
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Φ computation per stage
// ═══════════════════════════════════════════════════════════════
//
// Φ_stage = mean pairwise MI across all 4 channels (6 pairs).
// This measures the average information integration across
// cortical, sensory, motor, and imagery channels.
//
// Extract channel i from packed array: indices [i*T .. (i+1)*T-1]

fn ss_extract_channel(packed: array, ch_idx: int, t_len: int) -> array {
    let off = ch_idx * t_len
    let mut out = []
    let mut i = 0
    while i < t_len {
        out = out.push(packed[off + i])
        i = i + 1
    }
    return out
}

fn ss_phi_stage(packed: array, t_len: int) -> float {
    // Extract 4 channels
    let ch0 = ss_extract_channel(packed, 0, t_len)
    let ch1 = ss_extract_channel(packed, 1, t_len)
    let ch2 = ss_extract_channel(packed, 2, t_len)
    let ch3 = ss_extract_channel(packed, 3, t_len)

    // All 6 pairwise MI values
    let mi01 = ss_mi(ch0, ch1)
    let mi02 = ss_mi(ch0, ch2)
    let mi03 = ss_mi(ch0, ch3)
    let mi12 = ss_mi(ch1, ch2)
    let mi13 = ss_mi(ch1, ch3)
    let mi23 = ss_mi(ch2, ch3)

    let sum = mi01 + mi02 + mi03 + mi12 + mi13 + mi23
    return sum / 6.0
}

// ═══════════════════════════════════════════════════════════════
// Differentiation metric (T4)
// ═══════════════════════════════════════════════════════════════
//
// Φ_differentiation measures the DIVERSITY of information across
// channels. In N3/SWS all channels are synchronized into the same
// delta rhythm → low differentiation. We measure this as the
// standard deviation of individual channel entropies. When all
// channels carry the same entropy (synchronized), std ≈ 0.

fn ss_signal_amplitude(sig: array, t_len: int) -> float {
    let mut sum_sq = 0.0
    let mut i = 0
    while i < t_len {
        sum_sq = sum_sq + sig[i] * sig[i]
        i = i + 1
    }
    return ss_sqrt_safe(sum_sq / to_float(t_len))
}

// ═══════════════════════════════════════════════════════════════
// Sub-window correlation modulation depth (T3 spindle oscillation)
// ═══════════════════════════════════════════════════════════════
//
// Divide trace into sub-windows, compute Pearson |r| between
// cortical and mean(other) per window, then measure VARIANCE of
// |r| across windows. N2 spindle bursts create windows with high
// |r| alternating with low |r| → high variance. N1/N3 have steady
// coupling → low variance.

fn ss_coupling_modulation_depth(packed: array, t_len: int) -> float {
    let cortical = ss_extract_channel(packed, 0, t_len)
    let sensory = ss_extract_channel(packed, 1, t_len)
    let motor = ss_extract_channel(packed, 2, t_len)

    // Build other-mean trace
    let mut other = []
    let mut i = 0
    while i < t_len {
        other = other.push((sensory[i] + motor[i]) / 2.0)
        i = i + 1
    }

    // Sub-window Pearson |r| — 4 windows of 6 samples each
    let win = 6
    let n_wins = t_len / win
    let mut corrs = []
    let mut w = 0
    while w < n_wins {
        let base = w * win
        // means
        let mut sx = 0.0
        let mut sy = 0.0
        let mut j = 0
        while j < win {
            sx = sx + cortical[base + j]
            sy = sy + other[base + j]
            j = j + 1
        }
        let mx = sx / to_float(win)
        let my = sy / to_float(win)
        // Pearson r components
        let mut sxy = 0.0
        let mut sxx = 0.0
        let mut syy = 0.0
        j = 0
        while j < win {
            let dx = cortical[base + j] - mx
            let dy = other[base + j] - my
            sxy = sxy + dx * dy
            sxx = sxx + dx * dx
            syy = syy + dy * dy
            j = j + 1
        }
        let denom = ss_sqrt_safe(sxx) * ss_sqrt_safe(syy)
        let mut r = 0.0
        if denom > 0.0001 {
            r = sxy / denom
            if r < 0.0 { r = 0.0 - r }
        }
        corrs = corrs.push(r)
        w = w + 1
    }

    // Variance of |r| across windows
    let mut sum_r = 0.0
    i = 0
    while i < n_wins {
        sum_r = sum_r + corrs[i]
        i = i + 1
    }
    let mean_r = sum_r / to_float(n_wins)
    let mut var_r = 0.0
    i = 0
    while i < n_wins {
        let d = corrs[i] - mean_r
        var_r = var_r + d * d
        i = i + 1
    }
    return var_r / to_float(n_wins)
}

// ═══════════════════════════════════════════════════════════════
// Compute all stage Φ values at once
// ═══════════════════════════════════════════════════════════════

fn ss_compute_phi(stage: int, seed: int) -> float {
    let packed = ss_build_stage_signals(stage, SS_T, seed)
    return ss_phi_stage(packed, SS_T)
}

// ═══════════════════════════════════════════════════════════════
// T1: Φ gradient — wake > N1 > N2 > N3 (monotonic descent)
// ═══════════════════════════════════════════════════════════════
//
// Massimini et al. 2005 showed progressive loss of cortical
// effective connectivity from wake through deepening NREM.
// TMS-evoked responses become increasingly local and stereotyped,
// reflecting loss of information integration (Φ).

fn check_T1() -> bool {
    let phi_wake = ss_compute_phi(SS_WAKE, SS_SEED)
    let phi_n1 = ss_compute_phi(SS_N1, SS_SEED)
    let phi_n2 = ss_compute_phi(SS_N2, SS_SEED)
    let phi_n3 = ss_compute_phi(SS_N3, SS_SEED)

    println("  [T1] Φ_wake=" + str(phi_wake) + " Φ_N1=" + str(phi_n1) + " Φ_N2=" + str(phi_n2) + " Φ_N3=" + str(phi_n3))

    // Monotonic descent check with minimum gap
    if phi_wake <= phi_n1 + SS_MONO_GATE {
        println("  [T1] FAIL: wake <= N1 + gate")
        return false
    }
    if phi_n1 <= phi_n2 + SS_MONO_GATE {
        println("  [T1] FAIL: N1 <= N2 + gate")
        return false
    }
    if phi_n2 <= phi_n3 + SS_MONO_GATE {
        println("  [T1] FAIL: N2 <= N3 + gate")
        return false
    }

    println("  [T1] monotonic descent confirmed: wake > N1 > N2 > N3")
    return true
}

// ═══════════════════════════════════════════════════════════════
// T2: REM paradox — Φ_dream > N3 Φ
// ═══════════════════════════════════════════════════════════════
//
// Jouvet 1965 "paradoxical sleep": the brain is electrophysiologically
// active (desynchronized EEG resembling wake) yet the body is paralyzed.
// Dream consciousness exists (Φ > 0) and typically exceeds the deep
// unconsciousness of N3/SWS, but with motor channel silenced and
// metacognitive capacity reduced.

fn check_T2() -> bool {
    let phi_n3 = ss_compute_phi(SS_N3, SS_SEED)
    let phi_rem = ss_compute_phi(SS_REM, SS_SEED)

    println("  [T2] Φ_N3=" + str(phi_n3) + " Φ_REM=" + str(phi_rem))

    // REM paradox: consciousness returns above N3 level
    let delta = phi_rem - phi_n3
    println("  [T2] Φ_REM - Φ_N3 = " + str(delta) + " gate=" + str(SS_REM_GATE))

    if phi_rem <= phi_n3 {
        println("  [T2] FAIL: REM Φ not above N3")
        return false
    }
    if delta < SS_REM_GATE {
        println("  [T2] FAIL: gap below gate")
        return false
    }

    // Also verify REM < wake (REM consciousness is degraded vs wake
    // due to motor atonia and prefrontal hypoactivation)
    let phi_wake = ss_compute_phi(SS_WAKE, SS_SEED)
    println("  [T2] Φ_wake=" + str(phi_wake) + " (REM < wake expected)")
    if phi_rem >= phi_wake {
        println("  [T2] WARNING: REM >= wake (unusual but not fatal)")
    }

    println("  [T2] REM paradox confirmed: N3 < REM (dream Φ returns)")
    return true
}

// ═══════════════════════════════════════════════════════════════
// T3: Sleep spindle oscillation signature in N2
// ═══════════════════════════════════════════════════════════════
//
// Steriade 1993: sleep spindles are generated by the thalamic
// reticular nucleus as waxing-and-waning 12-14 Hz oscillation bursts
// lasting 0.5-1.5 seconds. Tononi & Cirelli 2006: spindles create
// transient windows of cortical integration during otherwise
// disconnected N2 sleep.
//
// We detect this as: variance of Φ across sub-windows is higher in
// N2 (spindle-modulated) than in N1 (no spindles) and N3 (uniform
// slow oscillation).

fn check_T3() -> bool {
    let packed_n1 = ss_build_stage_signals(SS_N1, SS_T, SS_SEED)
    let packed_n2 = ss_build_stage_signals(SS_N2, SS_T, SS_SEED)
    let packed_n3 = ss_build_stage_signals(SS_N3, SS_T, SS_SEED)

    // Measure coupling modulation depth: how much the instantaneous
    // cortical-to-other coupling VARIES across the time series.
    // N2 spindle bursts create periodic coupling boosts → high modulation.
    // N1/N3 have steady coupling → low modulation.
    let mod_n1 = ss_coupling_modulation_depth(packed_n1, SS_T)
    let mod_n2 = ss_coupling_modulation_depth(packed_n2, SS_T)
    let mod_n3 = ss_coupling_modulation_depth(packed_n3, SS_T)

    println("  [T3] coupling modulation: N1=" + str(mod_n1) + " N2=" + str(mod_n2) + " N3=" + str(mod_n3))

    // N2 modulation must exceed both N1 and N3
    if mod_n2 <= mod_n1 {
        println("  [T3] FAIL: N2 modulation not above N1")
        return false
    }
    if mod_n2 <= mod_n3 {
        println("  [T3] FAIL: N2 modulation not above N3")
        return false
    }

    // N2 must exceed N1 by at least SS_SPINDLE_VAR_GATE ratio
    let ratio = mod_n2 / (mod_n1 + SS_EPS)
    println("  [T3] N2/N1 modulation ratio=" + str(ratio) + " gate=" + str(SS_SPINDLE_VAR_GATE))
    if ratio < SS_SPINDLE_VAR_GATE {
        println("  [T3] FAIL: N2/N1 ratio below gate")
        return false
    }

    println("  [T3] sleep spindle oscillation signature confirmed in N2")
    return true
}

// ═══════════════════════════════════════════════════════════════
// T4: SWS slow oscillation — high amplitude, low differentiation
// ═══════════════════════════════════════════════════════════════
//
// Steriade et al. 1993: during N3/SWS, cortical neurons undergo
// synchronized up-states and down-states at ~0.5-1 Hz. The slow
// oscillation has high amplitude (≥75 µV clinically) but carries
// minimal information because all regions oscillate in near-lockstep.
//
// IIT perspective (Tononi 2004): high Φ requires BOTH integration
// (channels connected) AND differentiation (channels carry distinct
// information). N3 destroys differentiation — channels are all driven
// by the same delta rhythm.
//
// We verify: (a) N3 has high signal amplitude (delta dominance),
// (b) Φ_differentiation ≈ 0 (channel entropies converge).

fn check_T4() -> bool {
    let packed_n3 = ss_build_stage_signals(SS_N3, SS_T, SS_SEED)
    let packed_wake = ss_build_stage_signals(SS_WAKE, SS_T, SS_SEED)

    // (a) Signal amplitude: N3 cortical delta should be high amplitude
    let cortical_n3 = ss_extract_channel(packed_n3, 0, SS_T)
    let cortical_wake = ss_extract_channel(packed_wake, 0, SS_T)
    let amp_n3 = ss_signal_amplitude(cortical_n3, SS_T)
    let amp_wake = ss_signal_amplitude(cortical_wake, SS_T)
    println("  [T4] cortical RMS: N3=" + str(amp_n3) + " wake=" + str(amp_wake))

    // (b) N3 Φ (information integration) is drastically lower than wake Φ.
    // This captures Massimini's finding: TMS-evoked responses in NREM are
    // LOCAL and die out, meaning cortical effective connectivity (and hence
    // Φ) is near zero even though EEG amplitude is high.
    let phi_n3 = ss_phi_stage(packed_n3, SS_T)
    let phi_wake = ss_phi_stage(packed_wake, SS_T)
    let ratio = phi_n3 / (phi_wake + SS_EPS)
    println("  [T4] Φ_N3=" + str(phi_n3) + " Φ_wake=" + str(phi_wake) + " ratio=" + str(ratio))

    if ratio >= SS_DIFF_GATE {
        println("  [T4] FAIL: N3/wake Φ ratio too high (" + str(ratio) + " >= " + str(SS_DIFF_GATE) + ")")
        return false
    }

    // (c) Non-cortical channels in N3 carry minimal signal (thalamic gate)
    let sensory_n3 = ss_extract_channel(packed_n3, 1, SS_T)
    let motor_n3 = ss_extract_channel(packed_n3, 2, SS_T)
    let amp_sens = ss_signal_amplitude(sensory_n3, SS_T)
    let amp_mot = ss_signal_amplitude(motor_n3, SS_T)
    println("  [T4] N3 non-cortical RMS: sensory=" + str(amp_sens) + " motor=" + str(amp_mot))

    // Cortical amplitude must exceed non-cortical (delta dominates, others gated)
    if amp_n3 <= amp_sens {
        println("  [T4] FAIL: cortical not dominant over sensory")
        return false
    }
    if amp_n3 <= amp_mot {
        println("  [T4] FAIL: cortical not dominant over motor")
        return false
    }

    println("  [T4] SWS confirmed: high cortical amplitude, low information integration")
    return true
}

// ═══════════════════════════════════════════════════════════════
// T5: Determinism + latency
// ═══════════════════════════════════════════════════════════════

fn check_T5() -> bool {
    // Determinism check: two runs with same seed must produce identical Φ
    let phi_a = ss_compute_phi(SS_WAKE, SS_SEED)
    let phi_b = ss_compute_phi(SS_WAKE, SS_SEED)
    let det_err = ss_abs(phi_a - phi_b)
    println("  [T5] determinism: Φ_a=" + str(phi_a) + " Φ_b=" + str(phi_b) + " |Δ|=" + str(det_err))
    if det_err > SS_EPS {
        println("  [T5] FAIL: non-deterministic (delta=" + str(det_err) + ")")
        return false
    }

    // Latency check: full pipeline for all 5 stages
    let t0 = clock()
    let _pw = ss_compute_phi(SS_WAKE, SS_SEED + 500)
    let _pn1 = ss_compute_phi(SS_N1, SS_SEED + 501)
    let _pn2 = ss_compute_phi(SS_N2, SS_SEED + 502)
    let _pn3 = ss_compute_phi(SS_N3, SS_SEED + 503)
    let _pr = ss_compute_phi(SS_REM, SS_SEED + 504)
    // Also run sub-window variance (spindle test) and differentiation
    let pk_n2 = ss_build_stage_signals(SS_N2, SS_T, SS_SEED + 505)
    let _vn2 = ss_coupling_modulation_depth(pk_n2, SS_T)
    let pk_n3 = ss_build_stage_signals(SS_N3, SS_T, SS_SEED + 506)
    let _dn3 = ss_coupling_modulation_depth(pk_n3, SS_T)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] full pipeline (5 stages + spindle var + diff) = " + str(ms) + " ms (gate=" + str(SS_LATENCY_MS) + ")")

    if ms >= SS_LATENCY_MS {
        println("  [T5] FAIL: latency exceeds gate")
        return false
    }

    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[sleep_stage_phi] P115 — sleep stage consciousness across architecture")
    println("  wake→N1→N2→N3(SWS)→REM, thalamocortical gating + spindles + atonia")
    println("  T=" + str(SS_T) + " bins=" + str(SS_BINS) + " seed=" + str(SS_SEED))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — Φ gradient: wake > N1 > N2 > N3 (monotonic descent)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — REM paradox: Φ_dream > Φ_N3 (consciousness returns)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — N2 sleep spindle oscillation signature detected") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — SWS: high amplitude, Φ_differentiation ≈ 0") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism + latency within gate") } else { println("T5 FAIL") }

    println("")

    // Sequential bool accumulation — chained && unreliable on stage0
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[sleep_stage_phi] 5/5 PASS — P115 DONE")
    } else {
        println("[sleep_stage_phi] SOME FAILED")
    }
}

main()
