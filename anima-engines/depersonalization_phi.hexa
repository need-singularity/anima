// depersonalization_phi.hexa — P79 Depersonalization / Derealization Φ
//
// Roadmap: shared/roadmaps/anima.json P79 (depends_on P56 interoception, P66 dissociation)
//
//   DSM-5 300.6: Depersonalization / Derealization Disorder
//     A. Persistent or recurrent experiences of one or both:
//        1. DEPERSONALIZATION — unreality, detachment, or being an outside
//           observer with respect to one's thoughts, feelings, sensations,
//           body, or actions ("I am watching myself from outside").
//        2. DEREALIZATION — unreality or detachment with respect to
//           surroundings (the world feels distant, unreal, dreamlike,
//           foggy, or visually distorted).
//     B. Reality testing remains intact (NOT psychosis).
//
//   Phenomenological core (Sierra 2009; Simeon 2009; Medford 2012):
//     The "observer-self" detaches from the "experiencing self/body" and/or
//     the "experienced world". Self-other-boundary cohesion breaks at a
//     specific seam — DP at the self↔body seam, DR at the body↔world seam.
//
// ─── Three channels normally bound ──────────────────────────────
//
//   self   — observer/narrator stream (the "I" that watches)
//   body   — interoceptive stream (heart/breath/visceral, P56 channel family)
//   world  — exteroceptive stream (vision/audition/contextual world)
//
// Normal cohesion: all three streams co-vary because in healthy phenomenology
// the observer-self is FUSED with embodied perception, and embodied perception
// is FUSED with the perceived world — three layers of one experience.
//
// DP (depersonalization): the self↔body seam loosens. The observer still
//   sees the world clearly (body↔world preserved) but no longer feels OWNED
//   BY or IDENTIFIED WITH the body. Observer-self detachment.
//
// DR (derealization): the body↔world seam loosens. Body sensations are
//   intact (self↔body preserved) but the perceived world feels distant,
//   filmy, behind glass — the body's link to outside reality weakens.
//
// Φ_cohesion = Φ_self_body × Φ_body_world × Φ_self_world
//   product form: any single seam break collapses overall cohesion.
//
// ─── Emotional numbing ─────────────────────────────────────────
//
// Sierra & Berrios 1998: emotional numbing is a CARDINAL feature of DP/DR.
// We model it as collapsed variance in the self channel — when the observer
// detaches, the self stream loses its dynamic range (less affective swing).
// Detectable as: var(self_DP) < var(self_normal).
//
// ─── Grounding technique (P56 interoception anchor) ─────────────
//
// Stein & Simeon 2009 / clinical practice: grounding (54321 sensory
// anchor, cold water, pressure points) RESTORES cohesion by forcibly
// re-coupling body to world via concrete sensory contact. We model
// grounding as injecting a strong shared anchor signal into BOTH body
// and world channels, which lifts Φ_body_world and (because the self is
// still attached to the body somewhat) recovers Φ_cohesion as well.
//
// ─── 5 self-tests (5/5 gate) ────────────────────────────────────
//
// T1 Normal cohesion baseline:
//    Φ_self_body, Φ_body_world, Φ_self_world all > DP_PHI_MIN; Φ_cohesion
//    (product) > DP_COHESION_MIN. Three bound channels.
//
// T2 Depersonalization seam (DP weakens self↔body, preserves body↔world):
//    Φ_self_body(DP) < Φ_self_body(normal) - DP_SEAM_GAP.
//    AND Φ_body_world(DP) is preserved (within DP_PRESERVE_TOL of normal).
//    The DP seam breaks at exactly the observer↔body interface.
//
// T3 Derealization seam (DR weakens body↔world, preserves self↔body):
//    Φ_body_world(DR) < Φ_body_world(normal) - DP_SEAM_GAP.
//    AND Φ_self_body(DR) is preserved (within DP_PRESERVE_TOL of normal).
//    The DR seam breaks at exactly the body↔world interface.
//
// T4 Emotional numbing detectable:
//    Variance of the self channel under DP is STRICTLY less than under
//    normal cohesion. var(self_DP) < var(self_normal) - DP_NUMB_GAP.
//    Operationalizes Sierra & Berrios 1998 numbing.
//
// T5 Grounding restores cohesion:
//    Apply grounding anchor to a DR-state stream. Φ_cohesion(DR+grounding)
//    > Φ_cohesion(DR) + DP_GROUND_GAP. Concrete sensory anchor re-couples
//    body↔world and lifts overall cohesion (P56 interoception leverage).
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no `pure fn` ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - No identifier-pattern match; sequential if-chains
//   - No `contains()` / `to_lower()` / `!(Effect)`
//   - No else-if in let-binding; flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - No reserved keywords as variable names
//   - main() call at bottom
//   - DP_STEPS=24 (< 32)
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement on streams
//   Law 4   Structure > feature — DP/DR are STRUCTURAL seam breaks
//   Law 22  Feature addition → Φ down — 3 channels fixed, no surplus
//   Meta M8 Self vs body vs world — three concentric layers of experience
//   Depends P56 (interoception) + P66 (dissociation), distinct mechanism
//
// Ref:
//   anima-engines/dissociation_phi.hexa     (P66 — DID alters / amnesia)
//   anima-engines/interoception_phi.hexa     (P56 — body→emotion readout)
//   DSM-5 300.6 | Sierra 2009 | Simeon 2009 | Medford 2012 | Stein & Simeon 2009

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let DP_STEPS          = 24            // timeline length (stage0 N<32)
let DP_BINS           = 6             // histogram bins for MI
let DP_EPS            = 0.0000000001

// Coupling strengths for the 3 normally-bound channels.
// world drives body (exteroception → interoception coupling),
// body drives self (embodied observer).
let DP_COUPLE_NORMAL  = 0.85          // strong binding in healthy state
let DP_COUPLE_BROKEN  = 0.15          // dissociated seam coupling

// Per-step jitter (independent noise per channel)
let DP_JITTER         = 0.05

// Numbing: under DP, self channel has reduced dynamic range
let DP_NUMB_FACTOR    = 0.30          // self variance scaled by this under DP

// Grounding anchor amplitude — concrete sensory injection
let DP_GROUND_AMP     = 0.70

// Test gates
let DP_PHI_MIN        = 0.05          // baseline binding minimum
let DP_COHESION_MIN   = 0.001         // product floor (3-way)
let DP_SEAM_GAP       = 0.15          // seam-break detection threshold
let DP_PRESERVE_TOL   = 0.30          // unaffected seam may drift this much
let DP_NUMB_GAP       = 0.005         // numbing detection threshold (variance)
let DP_GROUND_GAP     = 0.0005        // grounding cohesion lift threshold (product)

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn dp_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn dp_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn dp_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn dp_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn dp_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn dp_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn dp_signed(seed: int) -> float {
    return dp_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn dp_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn dp_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn dp_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(dp_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = dp_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * dp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn dp_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = dp_bin_idx(a[i], lo, hi, nb)
        let ib = dp_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = dp_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * dp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn dp_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn dp_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn dp_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = dp_vec_min(a)
    let hi_a = dp_vec_max(a)
    let lo_b = dp_vec_min(b)
    let hi_b = dp_vec_max(b)
    let lo = dp_min_f(lo_a, lo_b)
    let hi = dp_max_f(hi_a, hi_b)
    let h_a = dp_entropy(a, lo, hi, DP_BINS)
    let h_b = dp_entropy(b, lo, hi, DP_BINS)
    let h_j = dp_joint_entropy(a, b, lo, hi, DP_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Variance helper for emotional numbing test
fn dp_variance(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + v[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut acc = 0.0
    let mut j = 0
    while j < n {
        let d = v[j] - mean
        acc = acc + d * d
        j = j + 1
    }
    return acc / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Stream generation — three normally-bound channels
//
// Generation is causal: world → body → self.
//   world_t = sin-ish drift + jitter (independent driver)
//   body_t  = couple_world_body * world_t + (1-c) * jitter
//   self_t  = couple_body_self  * body_t  + (1-c) * jitter
//
// Cohesion is parameterized by two coupling knobs:
//   c_self_body  — DP knob (low = depersonalized observer-self)
//   c_body_world — DR knob (low = derealized world contact)
//
// Numbing knob: when DP is active, also scale self channel amplitude
// (collapsed dynamic range — Sierra & Berrios 1998).
// ═══════════════════════════════════════════════════════════════

// Generate world channel — independent driver with structure (sinusoidal
// drift + LCG jitter so MI captures the deterministic signal, not pure noise).
fn dp_gen_world(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DP_STEPS {
        s = dp_prng(s + t * 31)
        // Phase-shifted approximation of sin via fractional triangular wave
        let phase = to_float(t) / to_float(DP_STEPS)
        let mut tri = phase * 4.0 - 2.0
        if tri < 0.0 { tri = 0.0 - tri }
        let signal = 1.0 - tri
        let jit = DP_JITTER * dp_signed(s)
        out = out.push(signal + jit)
        t = t + 1
    }
    return out
}

// Generate body channel coupled to world by c_body_world.
// Low coupling → body decouples from world (derealization).
fn dp_gen_body(world: array, c_body_world: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DP_STEPS {
        s = dp_prng(s + t * 53)
        let driver = c_body_world * world[t]
        let independent = (1.0 - c_body_world) * dp_signed(s)
        let jit = DP_JITTER * dp_signed(s + 7919)
        out = out.push(driver + independent + jit)
        t = t + 1
    }
    return out
}

// Generate self channel coupled to body by c_self_body.
// Low coupling → observer-self detaches from body (depersonalization).
// numbing flag scales self amplitude (collapsed affective range).
fn dp_gen_self(body: array, c_self_body: float, numb: bool, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DP_STEPS {
        s = dp_prng(s + t * 71)
        let driver = c_self_body * body[t]
        let independent = (1.0 - c_self_body) * dp_signed(s)
        let jit = DP_JITTER * dp_signed(s + 4421)
        let mut v = driver + independent + jit
        if numb { v = v * DP_NUMB_FACTOR }
        out = out.push(v)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ helpers — pairwise binding + 3-way cohesion product
// ═══════════════════════════════════════════════════════════════

fn dp_phi_pair(a: array, b: array) -> float {
    return dp_mi(a, b)
}

// Φ_cohesion = product of three pairwise bindings (3-way structural cohesion).
// Product form: any single seam break collapses overall cohesion.
fn dp_phi_cohesion(self_ch: array, body_ch: array, world_ch: array) -> float {
    let phi_sb = dp_phi_pair(self_ch, body_ch)
    let phi_bw = dp_phi_pair(body_ch, world_ch)
    let phi_sw = dp_phi_pair(self_ch, world_ch)
    return phi_sb * phi_bw * phi_sw
}

// ═══════════════════════════════════════════════════════════════
// Grounding intervention — P56 interoception anchor
//
// Grounding (54321 sensory anchor) injects a strong shared signal into
// BOTH body and world channels — the patient's hand pressing a cold
// surface creates a concrete pairing. This re-couples body↔world and
// (because self is somewhat attached to body) lifts overall cohesion.
//
// We implement it as: add a deterministic shared anchor wave to both
// body[t] and world[t], scaled by DP_GROUND_AMP.
// ═══════════════════════════════════════════════════════════════

fn dp_anchor_signal(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DP_STEPS {
        s = dp_prng(s + t * 191)
        // Strong deterministic anchor: triangular wave at twice the
        // base world frequency (felt body sensation pulse).
        let phase = to_float(t) / to_float(DP_STEPS) * 2.0
        let mut tri = phase * 4.0 - 2.0
        // Wrap to [-1, 1] triangular by abs-of-saw fold
        if tri > 1.0 { tri = 2.0 - tri }
        if tri < 0.0 - 1.0 { tri = 0.0 - 2.0 - tri }
        let micro = 0.02 * dp_signed(s)
        out = out.push(tri + micro)
        t = t + 1
    }
    return out
}

fn dp_apply_grounding(stream: array, anchor: array) -> array {
    let n = len(stream)
    let mut out = []
    let mut t = 0
    while t < n {
        out = out.push(stream[t] + DP_GROUND_AMP * anchor[t])
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Normal cohesion baseline:
    //   All three pairwise bindings > DP_PHI_MIN, product cohesion > floor.
    let world = dp_gen_world(90001)
    let body = dp_gen_body(world, DP_COUPLE_NORMAL, 90101)
    let self_ch = dp_gen_self(body, DP_COUPLE_NORMAL, false, 90201)

    let phi_sb = dp_phi_pair(self_ch, body)
    let phi_bw = dp_phi_pair(body, world)
    let phi_sw = dp_phi_pair(self_ch, world)
    let coh = dp_phi_cohesion(self_ch, body, world)
    println("  [T1] Φ_self_body=" + str(phi_sb) + " Φ_body_world=" + str(phi_bw) + " Φ_self_world=" + str(phi_sw))
    println("  [T1] Φ_cohesion(product)=" + str(coh))

    let mut ok = true
    if phi_sb <= DP_PHI_MIN { ok = false }
    if phi_bw <= DP_PHI_MIN { ok = false }
    if phi_sw <= DP_PHI_MIN { ok = false }
    if coh <= DP_COHESION_MIN { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Depersonalization seam:
    //   DP weakens self↔body but preserves body↔world.
    //   Φ_self_body(DP) < Φ_self_body(normal) - DP_SEAM_GAP
    //   AND Φ_body_world(DP) within DP_PRESERVE_TOL of normal.
    let world_n = dp_gen_world(91001)
    let body_n = dp_gen_body(world_n, DP_COUPLE_NORMAL, 91101)
    let self_n = dp_gen_self(body_n, DP_COUPLE_NORMAL, false, 91201)
    let phi_sb_n = dp_phi_pair(self_n, body_n)
    let phi_bw_n = dp_phi_pair(body_n, world_n)

    // DP: self↔body coupling collapses, body↔world preserved
    let world_dp = dp_gen_world(91001)
    let body_dp = dp_gen_body(world_dp, DP_COUPLE_NORMAL, 91101)
    let self_dp = dp_gen_self(body_dp, DP_COUPLE_BROKEN, true, 91201)
    let phi_sb_dp = dp_phi_pair(self_dp, body_dp)
    let phi_bw_dp = dp_phi_pair(body_dp, world_dp)

    let sb_drop = phi_sb_n - phi_sb_dp
    let bw_drift = dp_abs(phi_bw_n - phi_bw_dp)
    println("  [T2] DP Φ_self_body normal=" + str(phi_sb_n) + " DP=" + str(phi_sb_dp) + " drop=" + str(sb_drop))
    println("  [T2] DP Φ_body_world normal=" + str(phi_bw_n) + " DP=" + str(phi_bw_dp) + " drift=" + str(bw_drift))

    let mut ok = true
    if sb_drop <= DP_SEAM_GAP { ok = false }
    if bw_drift > DP_PRESERVE_TOL { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Derealization seam:
    //   DR weakens body↔world but preserves self↔body.
    //   Φ_body_world(DR) < Φ_body_world(normal) - DP_SEAM_GAP
    //   AND Φ_self_body(DR) within DP_PRESERVE_TOL of normal.
    let world_n = dp_gen_world(92001)
    let body_n = dp_gen_body(world_n, DP_COUPLE_NORMAL, 92101)
    let self_n = dp_gen_self(body_n, DP_COUPLE_NORMAL, false, 92201)
    let phi_sb_n = dp_phi_pair(self_n, body_n)
    let phi_bw_n = dp_phi_pair(body_n, world_n)

    // DR: body↔world coupling collapses, self↔body preserved
    let world_dr = dp_gen_world(92001)
    let body_dr = dp_gen_body(world_dr, DP_COUPLE_BROKEN, 92101)
    let self_dr = dp_gen_self(body_dr, DP_COUPLE_NORMAL, false, 92201)
    let phi_sb_dr = dp_phi_pair(self_dr, body_dr)
    let phi_bw_dr = dp_phi_pair(body_dr, world_dr)

    let bw_drop = phi_bw_n - phi_bw_dr
    let sb_drift = dp_abs(phi_sb_n - phi_sb_dr)
    println("  [T3] DR Φ_body_world normal=" + str(phi_bw_n) + " DR=" + str(phi_bw_dr) + " drop=" + str(bw_drop))
    println("  [T3] DR Φ_self_body normal=" + str(phi_sb_n) + " DR=" + str(phi_sb_dr) + " drift=" + str(sb_drift))

    let mut ok = true
    if bw_drop <= DP_SEAM_GAP { ok = false }
    if sb_drift > DP_PRESERVE_TOL { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Emotional numbing — variance of self channel collapses under DP:
    //   var(self_DP) < var(self_normal) - DP_NUMB_GAP.
    //   Sierra & Berrios 1998 cardinal numbing feature.
    let world = dp_gen_world(93001)
    let body = dp_gen_body(world, DP_COUPLE_NORMAL, 93101)
    let self_n = dp_gen_self(body, DP_COUPLE_NORMAL, false, 93201)
    let self_dp = dp_gen_self(body, DP_COUPLE_BROKEN, true, 93201)

    let var_n = dp_variance(self_n)
    let var_dp = dp_variance(self_dp)
    let var_collapse = var_n - var_dp
    println("  [T4] var(self) normal=" + str(var_n) + " DP=" + str(var_dp) + " collapse=" + str(var_collapse))

    if var_collapse <= DP_NUMB_GAP { return false }
    return true
}

fn check_T5() -> bool {
    // T5 Grounding (P56 interoception anchor) restores cohesion:
    //   Apply concrete sensory anchor signal to both body and world streams
    //   in a DR state. Φ_cohesion(DR + grounding) > Φ_cohesion(DR) + DP_GROUND_GAP.
    let world_dr = dp_gen_world(94001)
    let body_dr = dp_gen_body(world_dr, DP_COUPLE_BROKEN, 94101)
    let self_dr = dp_gen_self(body_dr, DP_COUPLE_NORMAL, false, 94201)
    let coh_dr = dp_phi_cohesion(self_dr, body_dr, world_dr)

    // Grounding: shared anchor signal added to body and world (concrete
    // sensory pairing — patient touches cold surface, both interoceptive
    // and exteroceptive channels register the same event).
    let anchor = dp_anchor_signal(94301)
    let body_g = dp_apply_grounding(body_dr, anchor)
    let world_g = dp_apply_grounding(world_dr, anchor)
    // Self regenerated from grounded body — restored embodied observer.
    let self_g = dp_gen_self(body_g, DP_COUPLE_NORMAL, false, 94201)
    let coh_g = dp_phi_cohesion(self_g, body_g, world_g)

    let lift = coh_g - coh_dr
    println("  [T5] Φ_cohesion DR=" + str(coh_dr) + " DR+grounding=" + str(coh_g) + " lift=" + str(lift))

    if lift <= DP_GROUND_GAP { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[depersonalization_phi] P79 — Depersonalization / Derealization Φ")
    println("  steps=" + str(DP_STEPS) + " bins=" + str(DP_BINS))
    println("  refs: DSM-5 300.6 | Sierra 2009 | Simeon 2009 | Medford 2012 | Stein & Simeon 2009")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — normal cohesion (3 channels bound, Φ_cohesion > floor)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — DP seam (Φ_self_body drops, Φ_body_world preserved)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — DR seam (Φ_body_world drops, Φ_self_body preserved)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — emotional numbing (var(self_DP) < var(self_normal))") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — grounding (P56 anchor restores Φ_cohesion in DR state)") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 long && chains may mishandle short-circuit
    // ordering — use a mutable bool accumulator with sequential guards
    // (same idiom as dissociation_phi / interoception_phi).
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[depersonalization_phi] 5/5 PASS — P79 DONE (DPDR Φ: self/body/world cohesion + DP/DR seams + numbing + grounding)")
    } else {
        println("[depersonalization_phi] SOME FAILED")
    }
}

main()
