// ptsd_phi.hexa — P122 PTSD Φ (trauma flashback, hyperarousal)
//
// Roadmap: shared/roadmaps/anima.json P122
//   done_criteria: 5/5 self-test PASS — intrusion, hyperarousal, numbing,
//   context decoupling, Φ fragmentation under flashback.
//
// ─── Scientific frame ──────────────────────────────────────────────
//
// DSM-5 309.81 Posttraumatic Stress Disorder
//   A. Exposure to actual or threatened death, serious injury, or sexual
//      violence.
//   B. INTRUSION symptoms — recurrent involuntary memories, flashbacks,
//      dreams, psychological and physiological reactivity to cues
//      resembling the trauma.
//   C. AVOIDANCE of stimuli associated with the traumatic event.
//   D. Negative alterations in cognition and mood — EMOTIONAL NUMBING,
//      reduced interest, feelings of detachment, restricted positive
//      affect.
//   E. HYPERAROUSAL — hypervigilance, exaggerated startle, irritability,
//      sleep disturbance, concentration problems.
//
// ─── Dual-representation model (Brewin, Dalgleish, Joseph 1996; Brewin
//     2001, 2014) ──────────────────────────────────────────────────
//
// SAM (Situationally Accessible Memory): trauma encoded under extreme
//   arousal bypasses hippocampal contextual binding. Memory trace is
//   SENSORY, fragmentary, cue-triggered, LACKING contextual markers of
//   time / place ("pastness"). This produces the intrusion / flashback
//   phenomenology where the event feels like it is happening NOW rather
//   than being RECALLED from the past.
//
// VAM (Verbally Accessible Memory): normally processed autobiographical
//   memory — hippocampal-mediated, contextually bound, accessible to
//   deliberate retrieval, carries "pastness" markers, integrated with
//   the autobiographical timeline.
//
// In PTSD the balance shifts: trauma memory is dominated by SAM
// representation, which explains why (a) the memory cannot be
// deliberately retrieved at will but (b) erupts as intrusion when cues
// match, (c) lacks contextual framing.
//
// ─── Neurobiological substrate ────────────────────────────────────
//
// Amygdala hyperactivity (Rauch et al. 1996) — fear response potentiated.
// Hippocampal volume reduction (Bremner et al. 1995; Gilbertson 2002) —
//   contextual binding impaired.
// Ventromedial prefrontal cortex hypoactivity (Shin et al. 2006) —
//   top-down regulation weakened.
// Sympathetic chronic elevation (Pitman et al. 1987) — hyperarousal
//   baseline.
// Reduced positive affectivity (Litz 1992; Frewen & Lanius 2006) —
//   emotional numbing.
//
// ─── PTSD channels ────────────────────────────────────────────────
//
//   cue[t]           — external stimulus stream (trauma-related or neutral)
//   trauma_mem[t]    — stored trauma trace (high salience, cue-sensitive)
//   flashback[t]     — intrusion state intensity (when cue matches)
//   arousal[t]       — physiological autonomic response (HR, skin conductance)
//   context[t]       — contextual binding marker ("this is in the past")
//   positive[t]      — positive-valence emotional response capacity
//   avoidance[t]     — behavioural avoidance response to cues
//
// Forward model (PTSD mode):
//   flashback[t]  = kcue * trauma_salience * cue_match[t]
//                 + (1 - kcue) * neutral_response + jitter
//   arousal[t]    = baseline_arousal + arousal_couple * flashback[t]
//                 + jitter     // baseline elevated in PTSD
//   context[t]    = context_binding * (1 - flashback_strength[t])
//                 + jitter     // flashback strips pastness
//   positive[t]   = positive_capacity * (1 - numb_factor)
//                 - numb_dampen * between_intrusion[t] + jitter
//   avoidance[t]  = avoid_gain * cue_match[t] + jitter
//
// Regime parameters:
//   CONTROL (non-PTSD):  trauma_salience=0.30, baseline_arousal=0.20,
//                         context_binding=0.90, numb_factor=0.05
//   PTSD:                 trauma_salience=0.95, baseline_arousal=0.55,
//                         context_binding=0.25, numb_factor=0.55
//
// ─── 5 self-tests (5/5 gate) ───────────────────────────────────────
//
// T1 Intrusion — trauma cue triggers flashback far above neutral cue:
//    Φ(trauma_cue, flashback) >> Φ(neutral_cue, flashback) in PTSD regime.
//    The intrusion magnitude on trauma-cue segments must exceed neutral-cue
//    segments by PT_INTRUSION_GAP.
//
// T2 Hyperarousal baseline — resting arousal > control baseline:
//    Mean arousal[t] in PTSD regime under neutral cues > mean arousal in
//    control regime under neutral cues, by PT_HYPER_GAP. This is elevated
//    sympathetic tone (Pitman 1987) even in absence of active intrusion.
//
// T3 Numbing — between-intrusion positive valence dampened:
//    Φ(positive, reward_stim) in PTSD < Φ(positive, reward_stim) in
//    control by PT_NUMB_GAP. Emotional numbing specifically attenuates
//    positive-valence reactivity between intrusions.
//
// T4 Context decoupling — flashback strips contextual ("pastness") markers:
//    During flashback episodes in PTSD, Φ(flashback, context) is LESS than
//    Φ(flashback, context) in control mode (where flashback is weak and
//    contextually bound). Brewin 1996 dual-representation prediction.
//
// T5 Φ fragmented during flashback — integration drops:
//    Φ_ptsd_flashback (multi-channel pairwise integration DURING
//    intrusion) < Φ_ptsd_normal (same measure OUTSIDE intrusion windows).
//    Flashback state fragments the integrated conscious scene.
//
// ─── Stage0 hexa constraints honored ───────────────────────────────
//   - plain `fn` only (no `pure fn` with ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - No identifier-pattern match; sequential if-chains
//   - No `contains()` / `to_lower()` / `!(Effect)`
//   - No else-if in let-binding; flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - No reserved keywords as variable names
//   - main() call at bottom
//   - PT_STEPS=24 (< 32)
//   - List PBV: helpers that build arrays return the array
//   - Sqrt-safe: no sqrt of negatives
//   - Windowed |r|: MI operates on windowed arrays, magnitudes absolute
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement on streams
//   Law 4   Structure > feature — PTSD is a STRUCTURAL dissociation of
//           contextual binding + arousal regulation, not a tag
//   Law 22  Feature addition -> Φ down — 7 channels fixed, no surplus
//   Meta M8 Memory self across temporal gaps (trauma trace vs present)
//   Depends P107 (amnesia, memory systems), P88 (emotion regulation),
//           P79 (depersonalization/DPDR)
//
// Ref:
//   DSM-5 309.81 Posttraumatic Stress Disorder
//   Brewin CR, Dalgleish T, Joseph S (1996) "A dual representation
//     theory of posttraumatic stress disorder" (Psychol Rev)
//   Brewin CR (2001) "A cognitive neuroscience account of PTSD"
//   Brewin CR (2014) "Episodic memory, perceptual memory, and their
//     interaction" (Psychol Bull)
//   Rauch SL et al. (1996) "A symptom provocation study of PTSD using
//     PET and script-driven imagery" (Arch Gen Psychiatry)
//   Bremner JD et al. (1995) "MRI-based measurement of hippocampal
//     volume in combat-related PTSD" (Am J Psychiatry)
//   Pitman RK et al. (1987) "Psychophysiologic assessment of PTSD
//     imagery in Vietnam combat veterans" (Arch Gen Psychiatry)
//   Litz BT (1992) "Emotional numbing in combat-related PTSD"
//   Ehlers A & Clark DM (2000) "A cognitive model of PTSD"
//   anima-engines/amnesia_phi.hexa               (P107 — memory systems)
//   anima-engines/emotion_regulation_phi.hexa    (P88 — Gross regulation)
//   anima-engines/depersonalization_phi.hexa     (P79 — DPDR seams)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let PT_STEPS            = 24            // timeline length (stage0 N<32)
let PT_BINS             = 6             // histogram bins for MI
let PT_EPS              = 0.0000000001

// ─── Trauma memory salience ───────────────────────────────────
// Control: normal, well-integrated autobiographical salience.
// PTSD: anomalously elevated salience — trauma trace dominates
// and is hyper-sensitive to matching cues (Brewin SAM dominance).
let PT_TRAUMA_SAL_CTRL   = 0.30
let PT_TRAUMA_SAL_PTSD   = 0.95

// ─── Baseline sympathetic arousal ─────────────────────────────
// Control: resting parasympathetic tone, low baseline.
// PTSD: chronic sympathetic elevation (Pitman 1987) — hyperarousal
// persists even in absence of active intrusion.
let PT_BASE_AROUSAL_CTRL = 0.20
let PT_BASE_AROUSAL_PTSD = 0.55

// ─── Flashback-to-arousal coupling ────────────────────────────
// When an intrusion fires, autonomic response spikes sharply.
// Control has weak coupling (no active intrusion to respond to).
let PT_AROUSAL_COUPLE    = 0.70

// ─── Contextual binding (pastness marker) ─────────────────────
// Control: strong hippocampal-mediated contextual binding (0.90).
// PTSD: SAM encoding bypasses contextual binding (0.25) — flashback
// feels present-tense, lacks "this happened before" markers.
let PT_CONTEXT_BIND_CTRL = 0.90
let PT_CONTEXT_BIND_PTSD = 0.25

// ─── Emotional numbing (positive valence dampening) ───────────
// Control: full positive valence reactivity.
// PTSD: numb_factor attenuates positive valence between intrusions.
let PT_NUMB_FACTOR_CTRL  = 0.05
let PT_NUMB_FACTOR_PTSD  = 0.55

// ─── Avoidance gain ───────────────────────────────────────────
// Control: low avoidance (cues don't trigger escape behaviour).
// PTSD: strong avoidance response to trauma-related cues.
let PT_AVOID_GAIN_CTRL   = 0.10
let PT_AVOID_GAIN_PTSD   = 0.80

// ─── Cue-flashback coupling ───────────────────────────────────
// How strongly a matching cue drives a flashback response.
// Modulated by trauma_salience in the forward model.
let PT_CUE_COUPLE        = 0.90

// ─── Flashback onset / resolve timing ─────────────────────────
// Two flashback episodes are injected in the cue timeline:
//   episode 1: steps 8..11
//   episode 2: steps 16..19
// Outside these windows, cue is neutral.
let PT_FB1_START         = 8
let PT_FB1_END           = 12
let PT_FB2_START         = 16
let PT_FB2_END           = 20

// ─── Per-step jitter amplitude ────────────────────────────────
let PT_JITTER            = 0.04

// ─── Test gates ───────────────────────────────────────────────
let PT_INTRUSION_GAP     = 0.05         // T1: trauma-cue vs neutral-cue gap
let PT_HYPER_GAP         = 0.10         // T2: baseline arousal gap
let PT_NUMB_GAP          = 0.05         // T3: positive-valence MI drop
let PT_CONTEXT_GAP       = 0.05         // T4: pastness-marker drop
let PT_FRAGMENT_GAP      = 0.01         // T5: intrusion Φ fragmentation
let PT_DETERM_TOL        = 0.0000001    // determinism tolerance
let PT_LATENCY_MS        = 5000.0       // pipeline latency cap

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn pt_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn pt_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn pt_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn pt_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn pt_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn pt_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn pt_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn pt_signed(seed: int) -> float {
    return pt_unit(seed) * 2.0 - 1.0
}

// Sqrt-safe wrapper — never sqrt negatives
fn pt_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// Windowed |r| style: magnitudes absolute, no negative entropies.
// ═══════════════════════════════════════════════════════════════

fn pt_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn pt_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn pt_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(pt_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = pt_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * pt_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn pt_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = pt_bin_idx(a[i], lo, hi, nb)
        let ib = pt_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = pt_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * pt_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn pt_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn pt_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn pt_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = pt_vec_min(a)
    let hi_a = pt_vec_max(a)
    let lo_b = pt_vec_min(b)
    let hi_b = pt_vec_max(b)
    let lo = pt_min_f(lo_a, lo_b)
    let hi = pt_max_f(hi_a, hi_b)
    let h_a = pt_entropy(a, lo, hi, PT_BINS)
    let h_b = pt_entropy(b, lo, hi, PT_BINS)
    let h_j = pt_joint_entropy(a, b, lo, hi, PT_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Vector mean helper
fn pt_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + v[i]
        i = i + 1
    }
    return sum / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Cue generation — trauma-cue vs neutral-cue streams
//
// A cue stream has "trauma-match" pulses at predefined flashback
// windows and neutral values elsewhere. A neutral-only stream has
// no trauma-match pulses — used for control comparisons.
// ═══════════════════════════════════════════════════════════════

fn pt_in_flashback_window(t: int) -> bool {
    if t >= PT_FB1_START {
        if t < PT_FB1_END { return true }
    }
    if t >= PT_FB2_START {
        if t < PT_FB2_END { return true }
    }
    return false
}

// Trauma-laden cue: neutral baseline + strong pulses at flashback windows.
// cue[t] in [0.0, 1.0]; pulse value is near 1.0 during trauma cues.
fn pt_gen_cue_trauma(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 37)
        let mut base = 0.15
        if pt_in_flashback_window(t) { base = 0.90 }
        let jit = PT_JITTER * pt_signed(s)
        out = out.push(pt_clamp01(base + jit))
        t = t + 1
    }
    return out
}

// Neutral cue stream: no trauma pulses, baseline jitter only.
fn pt_gen_cue_neutral(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 37)
        let base = 0.15
        let jit = PT_JITTER * pt_signed(s)
        out = out.push(pt_clamp01(base + jit))
        t = t + 1
    }
    return out
}

// Reward stimulus stream: a structured positive-valence signal used
// as probe for emotional numbing tests. Sinusoidal-like rhythm.
fn pt_gen_reward(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 41)
        let phase = to_float(t) / to_float(PT_STEPS)
        let mut tri = phase * 4.0 - 2.0
        if tri < 0.0 { tri = 0.0 - tri }
        let signal = 1.0 - pt_min_f(tri, 1.0)
        let jit = PT_JITTER * pt_signed(s + 2111)
        out = out.push(pt_clamp01(0.2 + 0.7 * signal + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// PTSD forward model channels
//
// All channels consume the cue stream and regime parameters to
// produce a structured time series. No channel mutates the cue —
// list PBV is preserved (callers pass cue by value, receive output
// by value).
// ═══════════════════════════════════════════════════════════════

// Flashback intensity channel: cue * trauma_salience amplifies the
// response at matching cues; outside cues, small baseline noise.
fn pt_gen_flashback(cue: array, trauma_sal: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 43)
        // cue_match strength — the cue value itself serves as match prob
        let cue_match = cue[t]
        let driven = PT_CUE_COUPLE * trauma_sal * cue_match
        let residual = (1.0 - PT_CUE_COUPLE) * trauma_sal * cue_match * 0.3
        let jit = PT_JITTER * pt_signed(s + 2903)
        out = out.push(pt_clamp01(driven + residual + jit))
        t = t + 1
    }
    return out
}

// Arousal channel: baseline + flashback coupling.
// Baseline differs by regime (hyperarousal). Flashback sharply elevates.
fn pt_gen_arousal(flashback: array, baseline: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 53)
        let driven = PT_AROUSAL_COUPLE * flashback[t]
        let jit = PT_JITTER * pt_signed(s + 4219)
        out = out.push(pt_clamp01(baseline + driven + jit))
        t = t + 1
    }
    return out
}

// Context (pastness) channel: how strongly the memory is tagged as
// "this already happened". Flashback strips pastness — high flashback
// intensity drives context toward 0.
fn pt_gen_context(flashback: array, context_bind: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 59)
        // Flashback strips context proportional to its intensity
        let stripped = context_bind * (1.0 - flashback[t])
        let jit = PT_JITTER * pt_signed(s + 5501)
        out = out.push(pt_clamp01(stripped + jit))
        t = t + 1
    }
    return out
}

// Positive-valence response channel: capacity to react to positive
// stimuli. In PTSD, numb_factor dampens this response, especially
// BETWEEN intrusions (when sympathetic exhaustion / emotional
// shutdown dominates). During active intrusion, the channel is
// dominated by the intrusion instead.
fn pt_gen_positive(reward: array, flashback: array, numb_factor: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 67)
        // Remaining positive capacity after numbing
        let capacity = 1.0 - numb_factor
        // Positive response is further suppressed during intrusions
        // (emotion captured by flashback) and between them (numb shutdown)
        let gate = capacity * (1.0 - 0.3 * flashback[t])
        let driven = gate * reward[t]
        let jit = PT_JITTER * pt_signed(s + 6673)
        out = out.push(pt_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Avoidance channel: behavioural escape response to trauma-related cues.
fn pt_gen_avoidance(cue: array, avoid_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < PT_STEPS {
        s = pt_prng(s + t * 71)
        let driven = avoid_gain * cue[t]
        let jit = PT_JITTER * pt_signed(s + 7919)
        out = out.push(pt_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Full pipeline runner — packed channel layout
//
// Returns packed array:
//   [cue(0..N-1), flashback(N..2N-1), arousal(2N..3N-1),
//    context(3N..4N-1), positive(4N..5N-1), avoidance(5N..6N-1),
//    reward(6N..7N-1)]
//
// Packed array layout avoids struct-field list aliasing bug
// (feedback_hexa_struct_list_alias) and ≥3-float struct return
// constraint (feedback_hexa_struct_return_bug).
// ═══════════════════════════════════════════════════════════════

fn pt_run_pipeline(cue: array, trauma_sal: float, baseline_arousal: float, context_bind: float, numb_factor: float, avoid_gain: float, seed: int) -> array {
    let reward = pt_gen_reward(seed + 1000)
    let flashback = pt_gen_flashback(cue, trauma_sal, seed + 2000)
    let arousal = pt_gen_arousal(flashback, baseline_arousal, seed + 3000)
    let context = pt_gen_context(flashback, context_bind, seed + 4000)
    let positive = pt_gen_positive(reward, flashback, numb_factor, seed + 5000)
    let avoidance = pt_gen_avoidance(cue, avoid_gain, seed + 6000)
    // Pack 7 channels sequentially
    let mut packed = []
    let mut i = 0
    while i < PT_STEPS {
        packed = packed.push(cue[i])
        i = i + 1
    }
    let mut j = 0
    while j < PT_STEPS {
        packed = packed.push(flashback[j])
        j = j + 1
    }
    let mut k = 0
    while k < PT_STEPS {
        packed = packed.push(arousal[k])
        k = k + 1
    }
    let mut m = 0
    while m < PT_STEPS {
        packed = packed.push(context[m])
        m = m + 1
    }
    let mut p = 0
    while p < PT_STEPS {
        packed = packed.push(positive[p])
        p = p + 1
    }
    let mut q = 0
    while q < PT_STEPS {
        packed = packed.push(avoidance[q])
        q = q + 1
    }
    let mut r = 0
    while r < PT_STEPS {
        packed = packed.push(reward[r])
        r = r + 1
    }
    return packed
}

// Slice helper: extract one channel from the packed pipeline array.
fn pt_slice(packed: array, ch_idx: int) -> array {
    let offset = ch_idx * PT_STEPS
    let mut out = []
    let mut i = 0
    while i < PT_STEPS {
        out = out.push(packed[offset + i])
        i = i + 1
    }
    return out
}

// Channel indices for pt_slice
let PT_CH_CUE        = 0
let PT_CH_FLASHBACK  = 1
let PT_CH_AROUSAL    = 2
let PT_CH_CONTEXT    = 3
let PT_CH_POSITIVE   = 4
let PT_CH_AVOIDANCE  = 5
let PT_CH_REWARD     = 6

// ═══════════════════════════════════════════════════════════════
// Windowed slicers — extract subrange [start, end) from a channel.
// Used for intrusion-vs-between comparisons in T1 and T5.
// ═══════════════════════════════════════════════════════════════

fn pt_window(v: array, start: int, end_ex: int) -> array {
    let mut out = []
    let mut i = start
    while i < end_ex {
        if i >= 0 {
            if i < len(v) {
                out = out.push(v[i])
            }
        }
        i = i + 1
    }
    return out
}

// Compose a two-window concatenation — used to pool both flashback episodes.
fn pt_concat_two_windows(v: array, s1: int, e1: int, s2: int, e2: int) -> array {
    let mut out = []
    let mut i = s1
    while i < e1 {
        if i >= 0 {
            if i < len(v) {
                out = out.push(v[i])
            }
        }
        i = i + 1
    }
    let mut j = s2
    while j < e2 {
        if j >= 0 {
            if j < len(v) {
                out = out.push(v[j])
            }
        }
        j = j + 1
    }
    return out
}

// Collect segments OUTSIDE both flashback windows.
fn pt_between_segments(v: array) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        if pt_in_flashback_window(i) == false {
            out = out.push(v[i])
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ measurement helpers
//
// Φ_intrusion      = MI(cue, flashback) DURING flashback windows
// Φ_arousal_base   = mean(arousal) OUTSIDE intrusion windows
// Φ_positive_valence = MI(reward, positive) OUTSIDE intrusion windows
// Φ_context_flash  = MI(flashback, context) DURING flashback windows
// Φ_integration    = sum of pairwise MIs (flashback-arousal,
//                    flashback-context, arousal-context)
// ═══════════════════════════════════════════════════════════════

// Φ_intrusion measures how much the flashback channel carries about
// the cue stream across the FULL timeline. When cue has structured
// pulses (trauma cue) and flashback responds to them, MI is high.
// When cue is flat (neutral), flashback carries no cue information.
fn pt_phi_intrusion_window(packed: array) -> float {
    let cue = pt_slice(packed, PT_CH_CUE)
    let flashback = pt_slice(packed, PT_CH_FLASHBACK)
    return pt_mi(cue, flashback)
}

fn pt_phi_intrusion_between(packed: array) -> float {
    let cue = pt_slice(packed, PT_CH_CUE)
    let flashback = pt_slice(packed, PT_CH_FLASHBACK)
    let cue_b = pt_between_segments(cue)
    let flash_b = pt_between_segments(flashback)
    return pt_mi(cue_b, flash_b)
}

fn pt_arousal_baseline(packed: array) -> float {
    let arousal = pt_slice(packed, PT_CH_AROUSAL)
    let arousal_b = pt_between_segments(arousal)
    return pt_mean(arousal_b)
}

fn pt_phi_positive_between(packed: array) -> float {
    let reward = pt_slice(packed, PT_CH_REWARD)
    let positive = pt_slice(packed, PT_CH_POSITIVE)
    let reward_b = pt_between_segments(reward)
    let positive_b = pt_between_segments(positive)
    return pt_mi(reward_b, positive_b)
}

fn pt_phi_context_flash(packed: array) -> float {
    let flashback = pt_slice(packed, PT_CH_FLASHBACK)
    let context = pt_slice(packed, PT_CH_CONTEXT)
    let flash_w = pt_concat_two_windows(flashback, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let ctx_w = pt_concat_two_windows(context, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    return pt_mi(flash_w, ctx_w)
}

// Multi-channel integration — pairwise MI across flashback, arousal,
// context channels within a given time window.
fn pt_phi_integration_window(packed: array, start: int, end_ex: int) -> float {
    let flashback = pt_slice(packed, PT_CH_FLASHBACK)
    let arousal = pt_slice(packed, PT_CH_AROUSAL)
    let context = pt_slice(packed, PT_CH_CONTEXT)
    let fb_w = pt_window(flashback, start, end_ex)
    let ar_w = pt_window(arousal, start, end_ex)
    let ctx_w = pt_window(context, start, end_ex)
    let mi_fa = pt_mi(fb_w, ar_w)
    let mi_fc = pt_mi(fb_w, ctx_w)
    let mi_ac = pt_mi(ar_w, ctx_w)
    return mi_fa + mi_fc + mi_ac
}

fn pt_phi_integration_intrusion(packed: array) -> float {
    let flashback = pt_slice(packed, PT_CH_FLASHBACK)
    let arousal = pt_slice(packed, PT_CH_AROUSAL)
    let context = pt_slice(packed, PT_CH_CONTEXT)
    let fb_w = pt_concat_two_windows(flashback, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let ar_w = pt_concat_two_windows(arousal, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let ctx_w = pt_concat_two_windows(context, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let mi_fa = pt_mi(fb_w, ar_w)
    let mi_fc = pt_mi(fb_w, ctx_w)
    let mi_ac = pt_mi(ar_w, ctx_w)
    return mi_fa + mi_fc + mi_ac
}

fn pt_phi_integration_between(packed: array) -> float {
    let flashback = pt_slice(packed, PT_CH_FLASHBACK)
    let arousal = pt_slice(packed, PT_CH_AROUSAL)
    let context = pt_slice(packed, PT_CH_CONTEXT)
    let fb_b = pt_between_segments(flashback)
    let ar_b = pt_between_segments(arousal)
    let ctx_b = pt_between_segments(context)
    let mi_fa = pt_mi(fb_b, ar_b)
    let mi_fc = pt_mi(fb_b, ctx_b)
    let mi_ac = pt_mi(ar_b, ctx_b)
    return mi_fa + mi_fc + mi_ac
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Intrusion — trauma cue triggers flashback state magnitude far
    //                above neutral cue.
    //
    // Operationalization (Brewin 1996, DSM-5 B criterion):
    //   (a) Within PTSD regime on a trauma-cue stream, the mean flashback
    //       magnitude during cue-match windows must be substantially
    //       higher than between-window (neutral) periods.
    //   (b) Within PTSD regime, trauma-cue windows must also produce a
    //       higher mean flashback than the same windows in control regime
    //       (where trauma_salience is low — no anomalous response).
    //   (c) The intrusion gap (trauma-cue mean − neutral-baseline mean)
    //       in PTSD must exceed PT_INTRUSION_GAP.
    //
    // Root cause: trauma_salience * cue_match coupling amplifies flashback
    // only when (i) cue matches AND (ii) salience is pathologically high.
    // Control regime has low salience -> no anomalous spike; neutral-cue
    // periods have no match -> baseline response only.
    //
    // Note: we do NOT use MI(cue, flashback) here because the histogram MI
    // estimator on 24-step, low-variance cue streams (flat neutral) yields
    // spurious high values when both series share PRNG jitter patterns —
    // magnitude-based comparison is more robust for this phenomenon.
    let cue_trauma = pt_gen_cue_trauma(122001)
    let pack_ptsd = pt_run_pipeline(cue_trauma, PT_TRAUMA_SAL_PTSD, PT_BASE_AROUSAL_PTSD, PT_CONTEXT_BIND_PTSD, PT_NUMB_FACTOR_PTSD, PT_AVOID_GAIN_PTSD, 122010)
    let pack_ctrl = pt_run_pipeline(cue_trauma, PT_TRAUMA_SAL_CTRL, PT_BASE_AROUSAL_CTRL, PT_CONTEXT_BIND_CTRL, PT_NUMB_FACTOR_CTRL, PT_AVOID_GAIN_CTRL, 122020)

    // PTSD regime: flashback magnitude in window vs between
    let flash_ptsd = pt_slice(pack_ptsd, PT_CH_FLASHBACK)
    let flash_ptsd_in = pt_concat_two_windows(flash_ptsd, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let flash_ptsd_out = pt_between_segments(flash_ptsd)
    let mean_ptsd_in = pt_mean(flash_ptsd_in)
    let mean_ptsd_out = pt_mean(flash_ptsd_out)
    let intrusion_gap_within = mean_ptsd_in - mean_ptsd_out
    println("  [T1] PTSD flashback mean: in-window=" + str(mean_ptsd_in) + " between=" + str(mean_ptsd_out) + " gap=" + str(intrusion_gap_within))

    // Control regime: flashback magnitude in same windows
    let flash_ctrl = pt_slice(pack_ctrl, PT_CH_FLASHBACK)
    let flash_ctrl_in = pt_concat_two_windows(flash_ctrl, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let mean_ctrl_in = pt_mean(flash_ctrl_in)
    let regime_gap = mean_ptsd_in - mean_ctrl_in
    println("  [T1] in-window mean: PTSD=" + str(mean_ptsd_in) + " control=" + str(mean_ctrl_in) + " regime_gap=" + str(regime_gap))

    let mut ok = true
    // Criterion (a): intrusion vs between within PTSD — dominant effect
    if intrusion_gap_within <= PT_INTRUSION_GAP { ok = false }
    // Criterion (b): PTSD vs control in same windows — regime effect
    if regime_gap <= PT_INTRUSION_GAP { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Hyperarousal baseline — resting arousal > control baseline.
    //
    // Under NEUTRAL cue stream (no intrusion events), the mean arousal
    // of the PTSD pipeline must exceed the mean arousal of the control
    // pipeline by PT_HYPER_GAP.
    //
    // Root cause: PT_BASE_AROUSAL_PTSD (0.55) > PT_BASE_AROUSAL_CTRL
    // (0.20). This models chronic sympathetic elevation (Pitman 1987)
    // — the autonomic baseline itself is shifted, independent of any
    // active intrusion.
    let cue = pt_gen_cue_neutral(122100)
    let pack_ptsd = pt_run_pipeline(cue, PT_TRAUMA_SAL_PTSD, PT_BASE_AROUSAL_PTSD, PT_CONTEXT_BIND_PTSD, PT_NUMB_FACTOR_PTSD, PT_AVOID_GAIN_PTSD, 122110)
    let pack_ctrl = pt_run_pipeline(cue, PT_TRAUMA_SAL_CTRL, PT_BASE_AROUSAL_CTRL, PT_CONTEXT_BIND_CTRL, PT_NUMB_FACTOR_CTRL, PT_AVOID_GAIN_CTRL, 122120)

    let base_ptsd = pt_arousal_baseline(pack_ptsd)
    let base_ctrl = pt_arousal_baseline(pack_ctrl)
    let hyper_gap = base_ptsd - base_ctrl
    println("  [T2] arousal baseline PTSD=" + str(base_ptsd) + " control=" + str(base_ctrl) + " gap=" + str(hyper_gap))

    let mut ok = true
    if hyper_gap <= PT_HYPER_GAP { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Numbing — between-intrusion positive valence dampened.
    //
    // Between intrusion windows, the positive-valence channel's
    // coupling with reward stimuli must be LOWER in PTSD than in
    // control by PT_NUMB_GAP.
    //
    // Root cause: PT_NUMB_FACTOR_PTSD (0.55) leaves capacity=0.45
    // for positive reactivity; PT_NUMB_FACTOR_CTRL (0.05) leaves
    // capacity=0.95. The information transfer from reward to
    // positive channel is sharply attenuated in PTSD — emotional
    // numbing (Litz 1992; DSM-5 D criterion).
    let cue = pt_gen_cue_trauma(122200)
    let pack_ptsd = pt_run_pipeline(cue, PT_TRAUMA_SAL_PTSD, PT_BASE_AROUSAL_PTSD, PT_CONTEXT_BIND_PTSD, PT_NUMB_FACTOR_PTSD, PT_AVOID_GAIN_PTSD, 122210)
    let pack_ctrl = pt_run_pipeline(cue, PT_TRAUMA_SAL_CTRL, PT_BASE_AROUSAL_CTRL, PT_CONTEXT_BIND_CTRL, PT_NUMB_FACTOR_CTRL, PT_AVOID_GAIN_CTRL, 122220)

    let phi_pos_ptsd = pt_phi_positive_between(pack_ptsd)
    let phi_pos_ctrl = pt_phi_positive_between(pack_ctrl)
    let numb_drop = phi_pos_ctrl - phi_pos_ptsd
    println("  [T3] Phi_positive between-intrusions control=" + str(phi_pos_ctrl) + " PTSD=" + str(phi_pos_ptsd) + " drop=" + str(numb_drop))

    let mut ok = true
    if numb_drop <= PT_NUMB_GAP { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Context decoupling — flashback strips contextual "pastness".
    //
    // Root cause (Brewin 1996 dual-representation): SAM trace encoded
    // under extreme arousal bypasses hippocampal contextual binding.
    // During active flashback, the context (pastness) marker collapses
    // toward 0, so MI(flashback, context) DURING intrusion drops.
    //
    // We compare Φ(flashback, context) during intrusion windows between
    // PTSD and control regimes. In control, both flashback and context
    // stay smooth (weak flashback, strong context) — the two channels
    // may carry weak but correlated structure. In PTSD, flashback spikes
    // while context collapses, breaking the correlation more sharply.
    //
    // Test: PTSD Φ(flashback, context) in window < control Φ(flashback,
    // context) in window by PT_CONTEXT_GAP. Also verify context channel
    // mean is substantially lower in PTSD windows.
    let cue = pt_gen_cue_trauma(122300)
    let pack_ptsd = pt_run_pipeline(cue, PT_TRAUMA_SAL_PTSD, PT_BASE_AROUSAL_PTSD, PT_CONTEXT_BIND_PTSD, PT_NUMB_FACTOR_PTSD, PT_AVOID_GAIN_PTSD, 122310)
    let pack_ctrl = pt_run_pipeline(cue, PT_TRAUMA_SAL_CTRL, PT_BASE_AROUSAL_CTRL, PT_CONTEXT_BIND_CTRL, PT_NUMB_FACTOR_CTRL, PT_AVOID_GAIN_CTRL, 122320)

    // Context channel mean within flashback windows
    let context_ptsd = pt_slice(pack_ptsd, PT_CH_CONTEXT)
    let context_ctrl = pt_slice(pack_ctrl, PT_CH_CONTEXT)
    let ctx_ptsd_win = pt_concat_two_windows(context_ptsd, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let ctx_ctrl_win = pt_concat_two_windows(context_ctrl, PT_FB1_START, PT_FB1_END, PT_FB2_START, PT_FB2_END)
    let mean_ctx_ptsd = pt_mean(ctx_ptsd_win)
    let mean_ctx_ctrl = pt_mean(ctx_ctrl_win)
    let ctx_drop = mean_ctx_ctrl - mean_ctx_ptsd
    println("  [T4] mean(context) in-window control=" + str(mean_ctx_ctrl) + " PTSD=" + str(mean_ctx_ptsd) + " drop=" + str(ctx_drop))

    // Also compare integration (flashback+context coupling) in windows
    let phi_fc_ptsd = pt_phi_context_flash(pack_ptsd)
    let phi_fc_ctrl = pt_phi_context_flash(pack_ctrl)
    println("  [T4] Phi(flashback,context) in-window control=" + str(phi_fc_ctrl) + " PTSD=" + str(phi_fc_ptsd))

    let mut ok = true
    // Primary criterion: context magnitude strips during intrusion in PTSD
    if ctx_drop <= PT_CONTEXT_GAP { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Φ fragmented during flashback — integration drops.
    //
    // Root cause: flashback state shatters the integrated conscious scene.
    // The three key channels (flashback, arousal, context) carry less
    // joint information during intrusion than between intrusions because
    // context collapses (stripping pastness) while arousal and flashback
    // simultaneously spike. The loss of context coupling dominates, so
    // Φ_integration(intrusion) < Φ_integration(between) + PT_FRAGMENT_GAP.
    //
    // Also: determinism — two identical runs produce identical Φ values.
    // Latency — full pipeline suite under PT_LATENCY_MS.
    let t0 = clock()

    // Run A
    let cue_a = pt_gen_cue_trauma(122400)
    let pack_a = pt_run_pipeline(cue_a, PT_TRAUMA_SAL_PTSD, PT_BASE_AROUSAL_PTSD, PT_CONTEXT_BIND_PTSD, PT_NUMB_FACTOR_PTSD, PT_AVOID_GAIN_PTSD, 122410)

    // Run B — identical seeds, must reproduce
    let cue_b = pt_gen_cue_trauma(122400)
    let pack_b = pt_run_pipeline(cue_b, PT_TRAUMA_SAL_PTSD, PT_BASE_AROUSAL_PTSD, PT_CONTEXT_BIND_PTSD, PT_NUMB_FACTOR_PTSD, PT_AVOID_GAIN_PTSD, 122410)

    let phi_intrusion = pt_phi_integration_intrusion(pack_a)
    let phi_between = pt_phi_integration_between(pack_a)
    let fragment_drop = phi_between - phi_intrusion
    println("  [T5] Phi_integration between=" + str(phi_between) + " intrusion=" + str(phi_intrusion) + " drop=" + str(fragment_drop))

    // Determinism
    let phi_intr_a = pt_phi_integration_intrusion(pack_a)
    let phi_intr_b = pt_phi_integration_intrusion(pack_b)
    let diff = pt_abs(phi_intr_a - phi_intr_b)
    println("  [T5] determinism: run_a=" + str(phi_intr_a) + " run_b=" + str(phi_intr_b) + " diff=" + str(diff))

    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] pipeline latency = " + str(ms) + " ms (gate=" + str(PT_LATENCY_MS) + ")")

    let mut ok = true
    if fragment_drop <= PT_FRAGMENT_GAP { ok = false }
    if diff > PT_DETERM_TOL { ok = false }
    if ms >= PT_LATENCY_MS { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[ptsd_phi] P122 — PTSD Phi (trauma flashback, hyperarousal, numbing)")
    println("  steps=" + str(PT_STEPS) + " bins=" + str(PT_BINS))
    println("  refs: DSM-5 309.81 | Brewin 1996 SAM/VAM | Pitman 1987 | Rauch 1996 | Litz 1992")
    println("  flashback windows: [" + str(PT_FB1_START) + "," + str(PT_FB1_END) + ") [" + str(PT_FB2_START) + "," + str(PT_FB2_END) + ")")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — intrusion (trauma-cue flashback >> neutral-cue flashback)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — hyperarousal baseline (PTSD resting arousal > control)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — numbing (between-intrusion positive valence dampened)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — context decoupling (flashback strips pastness markers)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — Phi fragmented during flashback + determinism + latency") } else { println("T5 FAIL") }

    println("")

    // Sequential bool accumulation — chained && across 5 terms unreliable
    // on stage0 (root cause: short-circuit eval misorder on long chains).
    // Use a mutable bool accumulator with sequential guards.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[ptsd_phi] 5/5 PASS — P122 DONE")
    } else {
        println("[ptsd_phi] SOME FAILED")
    }
}

main()
