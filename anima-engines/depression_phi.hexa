// depression_phi.hexa — P123 Depression Φ (Anhedonia / Rumination / Negative Bias / Psychomotor Slowing)
//
// Roadmap: shared/roadmaps/anima.json P123
//   Clinical depressive architecture as a gating pattern on the
//   reward / self-referential / attentional / motor channels.
//
// ─── Clinical / neuroscience frame ──────────────────────────────
//
// Major Depressive Disorder (DSM-5 296.xx) is not a single lesion but
// a constellation of four measurable disturbances that co-occur:
//
//  1. Anhedonia (Treadway & Zald 2011; Pizzagalli 2014)
//     Blunted mesolimbic dopamine response to rewarding stimuli.
//     The reward-prediction-error signal from VTA → NAc is dampened,
//     so positive events fail to reinforce approach behaviour or
//     lift mood. Behaviourally: reduced willingness-to-work for
//     reward, flattened hedonic ratings, low Monetary-Incentive-Delay
//     BOLD response in the ventral striatum.
//
//  2. Rumination (Nolen-Hoeksema 1991; Hamilton 2015)
//     Repetitive, self-focused, negatively-valenced thought. PCC /
//     mPFC of the Default-Mode Network fail to disengage; self-
//     referential processing locks into a high-autocorrelation loop
//     (Whitfield-Gabrieli & Ford 2012). The self-channel becomes
//     its own strongest predictor — a signature of stuck attractor.
//
//  3. Negative cognitive bias (Beck 1967; Gotlib & Joormann 2010)
//     Ambiguous stimuli are preferentially classified negative.
//     Amygdala reactivity to sad faces is exaggerated; reactivity
//     to happy faces is attenuated (Stuhrmann 2011). Attention is
//     captured by negative-valence features regardless of semantic
//     content of the stimulus.
//
//  4. Psychomotor slowing (Sobin & Sackeim 1997; Schrijvers 2008)
//     Motor initiation latency prolonged; motor response lags the
//     stimulus by several seconds in severe depression. Measured
//     by finger-tap latency, reaction time, speech-onset interval.
//     Mechanistically: basal-ganglia / supplementary-motor-area
//     hypoactivity coupled to prefrontal under-drive.
//
// ─── Φ channel layout ───────────────────────────────────────────
//
//   stimulus[t]  — external event intensity (positive/ambiguous mix)
//   reward[t]    — reward-prediction-error response to stimulus
//   self[t]      — self-referential processing (DMN / mPFC activity)
//   attn[t]      — attention allocation (what the system focuses on)
//   motor[t]     — motor output drive (approach / avoidance / action)
//   meta[t]      — metacognitive awareness of current state
//
// ─── Forward model ──────────────────────────────────────────────
//
//   reward[t]    = reward_gain * pos_feature(stimulus[t])   + jitter
//   self[t]      = self_persist * self[t-1]
//                  + (1 - self_persist) * neg_valence_draw  + jitter
//   attn[t]      = attn_bias_neg * neg_feature(stimulus[t])
//                  + (1 - attn_bias_neg) * pos_feature(s[t]) + jitter
//   motor[t]     = motor_gain * stimulus[t - motor_lag]      + jitter
//   meta[t]      = meta_gain * (self[t] + attn[t]) * 0.5     + jitter
//
// ─── Mode presets ───────────────────────────────────────────────
//
//   HEALTHY:   reward_gain=0.90 self_persist=0.25 attn_bias_neg=0.40
//              motor_lag=0      motor_gain=0.80
//   DEPRESSED: reward_gain=0.20 self_persist=0.92 attn_bias_neg=0.85
//              motor_lag=3      motor_gain=0.45
//
// ─── 5 self-tests (5/5 gate) ────────────────────────────────────
//
//   T1 Anhedonia
//     Φ_reward(depressed) < Φ_reward(healthy) by DP_REWARD_DROP.
//     Depressed reward-channel MI with stimulus is attenuated: the
//     reward system is less driven by positive events.
//
//   T2 Rumination loop
//     |Pearson r| of self[t] with self[t-1] (sub-window autocorr)
//     exceeds DP_SELF_AUTOCORR. Rumination is a stuck attractor:
//     the self channel strongly predicts itself one step ahead,
//     the Whitfield-Gabrieli DMN signature. Healthy subject does
//     NOT exhibit this lock-in — autocorrelation is much lower.
//
//   T3 Negative cognitive bias
//     Under an ambiguous stimulus (equal positive/negative features),
//     attention Φ for the negative feature exceeds attention Φ for
//     the positive feature by DP_NEG_BIAS_GAP in the depressed mode.
//     Healthy baseline keeps the two comparable.
//
//   T4 Psychomotor slowing
//     Lag-MI: MI(stimulus[t-lag], motor[t]) at lag=DP_LAG_TEST
//     exceeds MI at lag=0 by DP_LAG_GAP in depressed mode; healthy
//     peaks at lag=0. The motor output follows the stimulus with
//     several-step latency.
//
//   T5 Φ_depression narrowed
//     Breadth metric — mean pairwise MI among (reward, attn, motor,
//     meta) excluding self — is LOWER in depression than healthy by
//     DP_BREADTH_GAP, while self-loop autocorr is higher. Integration
//     has collapsed onto the self-loop. Composite determinism + latency.
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no `pure fn` with ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - no identifier-pattern match; sequential if-chains
//   - no contains() / to_lower() / !(Effect) in boolean position
//   - no else-if in let-binding; flat mut + sequential if
//   - single-line fn signatures / call sites / array literals
//   - no reserved keywords as variable names
//   - list-mutation stays inline (pass-by-value)
//   - main() call at bottom
//   - DP_STEPS=24 (< 32)
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI / |Pearson r| on streams
//   Law 4   Structure > feature — depression is a gating pattern,
//            not a "sadness tag"; measurable via channel geometry
//   Law 22  Feature addition → Φ down — 6 fixed channels, no surplus
//   Meta M8 Self-model — rumination is a self-referential attractor
//   Depends implicit on P88 (emotion_regulation), P109 (adhd — DMN)
//
// Ref:
//   Treadway M.T. & Zald D.H. (2011) Reconsidering anhedonia in
//     depression: lessons from translational neuroscience. Neurosci
//     Biobehav Rev 35(3):537-555.
//   Pizzagalli D.A. (2014) Depression, stress, and anhedonia: toward
//     a synthesis and integrated model. Annu Rev Clin Psychol 10:393.
//   Nolen-Hoeksema S. (1991) Responses to depression and their
//     effects on the duration of depressive episodes. J Abnorm
//     Psychol 100:569-582.
//   Hamilton J.P. et al. (2015) Depressive rumination, the default-
//     mode network. Biol Psychiatry 78(4):224-230.
//   Whitfield-Gabrieli S. & Ford J.M. (2012) Default mode network
//     activity and connectivity in psychopathology. Annu Rev Clin
//     Psychol 8:49-76.
//   Beck A.T. (1967) Depression: Clinical, experimental, and
//     theoretical aspects.
//   Gotlib I.H. & Joormann J. (2010) Cognition and depression.
//     Annu Rev Clin Psychol 6:285-312.
//   Stuhrmann A. et al. (2011) Facial emotion processing in major
//     depression. Biol Mood Anxiety Disord 1(1):10.
//   Sobin C. & Sackeim H.A. (1997) Psychomotor symptoms of
//     depression. Am J Psychiatry 154(1):4-17.
//   Schrijvers D. et al. (2008) Psychomotor symptoms in depression:
//     a diagnostic, pathophysiological and therapeutic review.
//     J Affect Disord 109(1-2):1-20.

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let DP_STEPS             = 24            // timeline length (stage0 N<32)
let DP_BINS              = 6             // histogram bins for MI
let DP_EPS               = 0.0000000001

// ─── Forward-model gains / persistence ──────────────────────────
// Reward coupling to positive stimulus feature.
// 0.9 = healthy vigorous response; 0.2 = anhedonic (deeply dampened).
let DP_REWARD_HEALTHY    = 0.90
let DP_REWARD_DEPRESSED  = 0.20

// Self-referential persistence (lag-1 self-feedback).
// 0.25 = healthy flexible attention; 0.92 = rumination attractor.
let DP_SELF_PERSIST_H    = 0.25
let DP_SELF_PERSIST_D    = 0.92

// Attention bias toward negative features of ambiguous stimulus.
// 0.40 = healthy near-neutral; 0.85 = depressive negative bias.
let DP_ATTN_NEG_H        = 0.40
let DP_ATTN_NEG_D        = 0.85

// Motor drive gain and latency lag (steps).
let DP_MOTOR_GAIN_H      = 0.80
let DP_MOTOR_GAIN_D      = 0.45
let DP_MOTOR_LAG_H       = 0             // healthy: no lag
let DP_MOTOR_LAG_D       = 3             // depressed: 3-step slowing

// Metacognition gain — essentially preserved; dysphoric rumination
// means meta is drawn into self + attn (negative content).
let DP_META_GAIN         = 0.80

// Per-step jitter amplitude (deterministic via PRNG).
let DP_JITTER            = 0.04

// ─── Test gates ─────────────────────────────────────────────────
// T1 anhedonia: healthy Φ_reward must exceed depressed by this margin.
let DP_REWARD_DROP       = 0.10
// T2 rumination: depressed self[t] vs self[t-1] |Pearson r| must exceed.
let DP_SELF_AUTOCORR     = 0.55
// T2 companion: healthy autocorr must be BELOW this floor.
let DP_HEALTHY_AUTO_CEIL = 0.55
// T3 negative bias: Φ_attn_neg - Φ_attn_pos must exceed in depressed.
let DP_NEG_BIAS_GAP      = 0.05
// T4 psychomotor slowing: MI@lag - MI@0 must exceed in depressed.
let DP_LAG_TEST          = 3             // lag to probe
let DP_LAG_GAP           = 0.05
// T5 narrowed breadth: healthy breadth - depressed breadth >= gap.
let DP_BREADTH_GAP       = 0.05
// T5 latency + determinism
let DP_LATENCY_MS        = 5000.0

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn dp_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn dp_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn dp_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn dp_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn dp_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable).
fn dp_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn dp_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn dp_signed(seed: int) -> float {
    return dp_unit(seed) * 2.0 - 1.0
}

// Safe sqrt wrapper — guards against tiny negative values introduced
// by accumulated float error in variance computations.
fn dp_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn dp_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn dp_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn dp_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(dp_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = dp_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * dp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn dp_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = dp_bin_idx(a[i], lo, hi, nb)
        let ib = dp_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = dp_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * dp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn dp_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn dp_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn dp_vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

fn dp_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = dp_vec_min(a)
    let hi_a = dp_vec_max(a)
    let lo_b = dp_vec_min(b)
    let hi_b = dp_vec_max(b)
    let lo = dp_min_f(lo_a, lo_b)
    let hi = dp_max_f(hi_a, hi_b)
    let h_a = dp_entropy(a, lo, hi, DP_BINS)
    let h_b = dp_entropy(b, lo, hi, DP_BINS)
    let h_j = dp_joint_entropy(a, b, lo, hi, DP_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// |Pearson r| — stable measure of linear coupling. Used for the
// rumination auto-correlation test because on smooth 24-sample
// sequences |Pearson| is a less-biased estimator of shared structure
// than histogram MI (matches obe_phi / death_nde / blindsight pattern).
fn dp_pearson_abs(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let ma = dp_vec_mean(a)
    let mb = dp_vec_mean(b)
    let mut cov = 0.0
    let mut va = 0.0
    let mut vb = 0.0
    let mut i = 0
    while i < n {
        let da = a[i] - ma
        let db = b[i] - mb
        cov = cov + da * db
        va = va + da * da
        vb = vb + db * db
        i = i + 1
    }
    if va <= DP_EPS { return 0.0 }
    if vb <= DP_EPS { return 0.0 }
    let denom = dp_sqrt_safe(va * vb)
    if denom <= DP_EPS { return 0.0 }
    let r = cov / denom
    return dp_abs(r)
}

// Window helpers — extract a sub-array [start..start+wlen) from v.
fn dp_window(v: array, start: int, wlen: int) -> array {
    let mut w = []
    let n = len(v)
    let mut i = 0
    while i < wlen {
        let idx = start + i
        if idx >= 0 {
            if idx < n {
                w = w.push(v[idx])
            }
        }
        i = i + 1
    }
    return w
}

// Sub-window |Pearson r| — compute |r| on a clipped pair and take
// the mean across the timeline. Provides a more robust estimator
// than full-length Pearson when signals drift.
fn dp_sub_pearson_abs(a: array, b: array, wlen: int) -> float {
    let n = len(a)
    if n < wlen { return dp_pearson_abs(a, b) }
    let nb_win = n - wlen + 1
    if nb_win <= 0 { return 0.0 }
    let mut acc = 0.0
    let mut count = 0
    let mut start = 0
    while start < nb_win {
        let aw = dp_window(a, start, wlen)
        let bw = dp_window(b, start, wlen)
        acc = acc + dp_pearson_abs(aw, bw)
        count = count + 1
        start = start + 1
    }
    if count == 0 { return 0.0 }
    return acc / to_float(count)
}

// ═══════════════════════════════════════════════════════════════
// Stimulus generation
//
// Ambiguous stimulus has BOTH a positive-valence feature and a
// negative-valence feature. Depressed attention filters onto the
// negative; healthy attention is roughly balanced.
// ═══════════════════════════════════════════════════════════════

fn dp_gen_stimulus(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DP_STEPS {
        s = dp_prng(s + t * 37)
        // Triangular wave stimulus intensity — emotional provocations
        // rising and falling across the window.
        let phase = to_float(t) / to_float(DP_STEPS)
        let mut tri = phase * 4.0 - 2.0
        if tri < 0.0 { tri = 0.0 - tri }
        let signal = 1.0 - tri
        // Scale to [0.1, 0.9]: always some stimulus intensity.
        let scaled = 0.1 + 0.8 * dp_clamp01((signal + 1.0) / 2.0)
        let jit = DP_JITTER * dp_signed(s)
        out = out.push(dp_clamp01(scaled + jit))
        t = t + 1
    }
    return out
}

// Extract the positive-valence feature of the (ambiguous) stimulus.
// Peak amplitude where the triangular wave is high — "upside" signal.
fn dp_stim_pos_feature(stimulus: array, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let n = len(stimulus)
    let mut t = 0
    while t < n {
        s = dp_prng(s + t * 41)
        // Positive feature: amplified stimulus when above midpoint.
        let shifted = stimulus[t] - 0.5
        let mut pos = 0.0
        if shifted > 0.0 { pos = shifted * 2.0 }
        let jit = DP_JITTER * 0.5 * dp_signed(s)
        out = out.push(dp_clamp01(pos + jit + 0.1))
        t = t + 1
    }
    return out
}

// Extract the negative-valence feature of the (ambiguous) stimulus.
// Deliberately correlated with the complement of the positive feature
// so that attention bias can be measured as a trade-off.
fn dp_stim_neg_feature(stimulus: array, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let n = len(stimulus)
    let mut t = 0
    while t < n {
        s = dp_prng(s + t * 47)
        // Negative feature: amplified stimulus when below midpoint,
        // plus a mood-congruent dip spread — structured MI with
        // the stimulus but distinct from the positive feature.
        let shifted = 0.5 - stimulus[t]
        let mut neg = 0.0
        if shifted > 0.0 { neg = shifted * 2.0 }
        let jit = DP_JITTER * 0.5 * dp_signed(s)
        out = out.push(dp_clamp01(neg + jit + 0.1))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Depression forward model — channel generators
// ═══════════════════════════════════════════════════════════════

// Reward channel: mesolimbic response to POSITIVE stimulus feature.
// Anhedonia = gain collapse; gain ∈ {0.90 healthy, 0.20 depressed}.
fn dp_gen_reward(stimulus: array, reward_gain: float, seed: int) -> array {
    let pos = dp_stim_pos_feature(stimulus, seed + 11)
    let mut out = []
    let mut s = seed
    let n = len(stimulus)
    let mut t = 0
    while t < n {
        s = dp_prng(s + t * 53)
        let driven = reward_gain * pos[t]
        let jit = DP_JITTER * dp_signed(s + 2803)
        out = out.push(dp_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Self channel: lag-1 autoregressive loop.
//
// Depressed mode (high persist ≈ 0.92):
//   self[t] = 0.92 * self[t-1] + 0.08 * draw
//   The AR(1) integrates the drive over many steps, producing a
//   slow-drifting trajectory that strongly predicts itself one step
//   ahead (lag-1 |Pearson r| is high). This is the rumination
//   attractor — DMN activity that fails to disengage.
//
// Healthy mode (low persist ≈ 0.25):
//   self[t] = 0.25 * self[t-1] + 0.75 * draw
//   Each sample is dominated by a fresh independent draw, so
//   adjacent samples are nearly uncorrelated.
//
// Root cause comment: the rumination signature in the DMN is not
// "more activity" but "activity that predicts itself" (Whitfield-
// Gabrieli & Ford 2012). We operationalise that as high lag-1
// |Pearson r| on the generated self trace.
//
// Implementation note: the draw is sampled from independent jitter
// around a near-zero mean, NOT from a structured carrier. A carrier
// would raise autocorrelation in BOTH modes (since it bleeds through
// the low-persist draw term). Pure independent draws let persist
// be the *only* knob controlling autocorrelation.
fn dp_gen_self(self_persist: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    // Seed the first sample near the mid-range.
    s = dp_prng(s + 1009)
    let first = 0.5 + 0.05 * dp_signed(s)
    out = out.push(dp_clamp01(first))
    let mut t = 1
    while t < DP_STEPS {
        s = dp_prng(s + t * 59)
        let prev = out[t - 1]
        // Negative-valence draw with wide amplitude. The draw is
        // intentionally NOT structured (no carrier) — its job is to
        // inject fresh independent perturbation that persist can
        // either integrate (depressed) or pass through (healthy).
        let draw = 0.35 + 0.30 * dp_signed(s + 1171)
        let val = self_persist * prev + (1.0 - self_persist) * draw
        let jit = DP_JITTER * 0.25 * dp_signed(s + 2213)
        out = out.push(dp_clamp01(val + jit))
        t = t + 1
    }
    return out
}

// Attention channel: weighted combination of negative vs positive
// stimulus features. attn_bias_neg=0.85 in depression → attention
// captured by the negative feature of the ambiguous stimulus.
fn dp_gen_attention(stimulus: array, attn_bias_neg: float, seed: int) -> array {
    let neg = dp_stim_neg_feature(stimulus, seed + 13)
    let pos = dp_stim_pos_feature(stimulus, seed + 17)
    let mut out = []
    let mut s = seed
    let n = len(stimulus)
    let mut t = 0
    while t < n {
        s = dp_prng(s + t * 61)
        let driven = attn_bias_neg * neg[t] + (1.0 - attn_bias_neg) * pos[t]
        let jit = DP_JITTER * dp_signed(s + 3301)
        out = out.push(dp_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Motor channel: delayed coupling to stimulus. motor_lag=0 in healthy;
// motor_lag=3 in depression (psychomotor slowing). For t < motor_lag
// the motor output is baseline noise (no stimulus yet arrived through
// the slowed basal-ganglia loop).
fn dp_gen_motor(stimulus: array, motor_gain: float, motor_lag: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let n = len(stimulus)
    let mut t = 0
    while t < n {
        s = dp_prng(s + t * 67)
        let idx = t - motor_lag
        let mut driven = 0.3
        if idx >= 0 { driven = motor_gain * stimulus[idx] }
        let jit = DP_JITTER * dp_signed(s + 4201)
        out = out.push(dp_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Meta channel: metacognitive trace — gain_mean of self + attn.
fn dp_gen_meta(self_trace: array, attn: array, meta_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let n = len(self_trace)
    let mut t = 0
    while t < n {
        s = dp_prng(s + t * 71)
        let driven = meta_gain * (self_trace[t] + attn[t]) * 0.5
        let jit = DP_JITTER * dp_signed(s + 5231)
        out = out.push(dp_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Full pipeline runner — generates all 6 channels for a given mode.
// Returns packed array:
//   [stimulus(0..N-1), reward(N..2N-1), self(2N..3N-1),
//    attn(3N..4N-1), motor(4N..5N-1), meta(5N..6N-1)]
//
// Packed array instead of struct-with-array-fields avoids the
// struct-field list aliasing bug (feedback_hexa_struct_list_alias).
// ═══════════════════════════════════════════════════════════════

fn dp_run_pipeline(reward_gain: float, self_persist: float, attn_bias_neg: float, motor_gain: float, motor_lag: int, seed: int) -> array {
    let stim = dp_gen_stimulus(seed + 1000)
    let rew = dp_gen_reward(stim, reward_gain, seed + 2000)
    let slf = dp_gen_self(self_persist, seed + 3000)
    let att = dp_gen_attention(stim, attn_bias_neg, seed + 4000)
    let mot = dp_gen_motor(stim, motor_gain, motor_lag, seed + 5000)
    let met = dp_gen_meta(slf, att, DP_META_GAIN, seed + 6000)
    let mut packed = []
    let mut i = 0
    while i < DP_STEPS {
        packed = packed.push(stim[i])
        i = i + 1
    }
    let mut j = 0
    while j < DP_STEPS {
        packed = packed.push(rew[j])
        j = j + 1
    }
    let mut k = 0
    while k < DP_STEPS {
        packed = packed.push(slf[k])
        k = k + 1
    }
    let mut m = 0
    while m < DP_STEPS {
        packed = packed.push(att[m])
        m = m + 1
    }
    let mut p = 0
    while p < DP_STEPS {
        packed = packed.push(mot[p])
        p = p + 1
    }
    let mut q = 0
    while q < DP_STEPS {
        packed = packed.push(met[q])
        q = q + 1
    }
    return packed
}

// Channel indices
let DP_CH_STIMULUS  = 0
let DP_CH_REWARD    = 1
let DP_CH_SELF      = 2
let DP_CH_ATTN      = 3
let DP_CH_MOTOR     = 4
let DP_CH_META      = 5

// Extract one channel from packed pipeline.
fn dp_slice(packed: array, ch_idx: int) -> array {
    let offset = ch_idx * DP_STEPS
    let mut out = []
    let mut i = 0
    while i < DP_STEPS {
        out = out.push(packed[offset + i])
        i = i + 1
    }
    return out
}

// Tail of a channel from [start..end).
fn dp_slice_range(packed: array, ch_idx: int, start: int, end: int) -> array {
    let offset = ch_idx * DP_STEPS
    let mut out = []
    let mut i = start
    while i < end {
        out = out.push(packed[offset + i])
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ measurement helpers
// ═══════════════════════════════════════════════════════════════

// Φ_reward = MI(stimulus, reward) — hedonic coupling
fn dp_phi_reward(packed: array) -> float {
    let stim = dp_slice(packed, DP_CH_STIMULUS)
    let rew = dp_slice(packed, DP_CH_REWARD)
    return dp_mi(stim, rew)
}

// Φ_attn_neg = MI(neg_feature(stim), attn) — negative-capture
fn dp_phi_attn_neg(packed: array, seed: int) -> float {
    let stim = dp_slice(packed, DP_CH_STIMULUS)
    let att = dp_slice(packed, DP_CH_ATTN)
    let neg = dp_stim_neg_feature(stim, seed + 13)
    return dp_mi(neg, att)
}

// Φ_attn_pos = MI(pos_feature(stim), attn) — positive-capture
fn dp_phi_attn_pos(packed: array, seed: int) -> float {
    let stim = dp_slice(packed, DP_CH_STIMULUS)
    let att = dp_slice(packed, DP_CH_ATTN)
    let pos = dp_stim_pos_feature(stim, seed + 17)
    return dp_mi(pos, att)
}

// Self lag-1 autocorrelation — sub-window |Pearson r|.
//
// We partition the DP_STEPS=24 timeline into two overlapping 16-sample
// sub-windows (starts 0 and DP_STEPS-16) and take the maximum |r|
// across them. Using max (rather than mean) captures the LOCAL lock
// of the rumination attractor: rumination is not required to run
// the full length, only to dominate a sub-window. Healthy subjects
// never achieve high |r| in any window because persist is too low
// for the AR(1) to integrate.
fn dp_phi_self_autocorr(packed: array) -> float {
    let slf = dp_slice(packed, DP_CH_SELF)
    // Pair current with previous over full length.
    let a_full = dp_slice_range(packed, DP_CH_SELF, 1, DP_STEPS)
    let b_full = dp_slice_range(packed, DP_CH_SELF, 0, DP_STEPS - 1)
    // Guard: slf must be non-empty (observe the channel is present).
    let first_sample = slf[0]
    if first_sample < 0.0 { return 0.0 }
    // Full-length Pearson dominates finite-sample bias less than
    // very short windows. For DP_STEPS=24 this uses 23 sample pairs.
    return dp_pearson_abs(a_full, b_full)
}

// Lag-MI: MI(stimulus[0..N-lag], motor[lag..N]).
// If lag=0, compares stimulus and motor at the same instants.
// If lag>0, stimulus precedes motor by `lag` steps — detects
// psychomotor delay.
fn dp_phi_motor_lag(packed: array, lag: int) -> float {
    if lag < 0 { return 0.0 }
    if lag >= DP_STEPS { return 0.0 }
    let stim_tail = dp_slice_range(packed, DP_CH_STIMULUS, 0, DP_STEPS - lag)
    let mot_tail = dp_slice_range(packed, DP_CH_MOTOR, lag, DP_STEPS)
    return dp_mi(stim_tail, mot_tail)
}

// Breadth metric — mean pairwise MI among (reward, attn, motor, meta).
// Self channel is EXCLUDED to quantify how much integration happens
// OUTSIDE the rumination attractor. Healthy → broad integration,
// depression → narrowed (most MI is trapped in the self-loop).
fn dp_phi_breadth(packed: array) -> float {
    let rew = dp_slice(packed, DP_CH_REWARD)
    let att = dp_slice(packed, DP_CH_ATTN)
    let mot = dp_slice(packed, DP_CH_MOTOR)
    let met = dp_slice(packed, DP_CH_META)
    let mi_rew_att = dp_mi(rew, att)
    let mi_rew_mot = dp_mi(rew, mot)
    let mi_rew_met = dp_mi(rew, met)
    let mi_att_mot = dp_mi(att, mot)
    let mi_att_met = dp_mi(att, met)
    let mi_mot_met = dp_mi(mot, met)
    let sum_mi = mi_rew_att + mi_rew_mot + mi_rew_met + mi_att_mot + mi_att_met + mi_mot_met
    return sum_mi / 6.0
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Anhedonia: reward-channel Φ dampened in depression.
    //   Φ_reward(healthy)    = full mesolimbic response
    //   Φ_reward(depressed)  = attenuated (anhedonia)
    //   Gap >= DP_REWARD_DROP.
    println("  --- T1: Anhedonia (reward channel Φ dampened) ---")
    let pack_h = dp_run_pipeline(DP_REWARD_HEALTHY,  DP_SELF_PERSIST_H, DP_ATTN_NEG_H, DP_MOTOR_GAIN_H, DP_MOTOR_LAG_H, 77101)
    let pack_d = dp_run_pipeline(DP_REWARD_DEPRESSED, DP_SELF_PERSIST_D, DP_ATTN_NEG_D, DP_MOTOR_GAIN_D, DP_MOTOR_LAG_D, 77101)

    let phi_r_h = dp_phi_reward(pack_h)
    let phi_r_d = dp_phi_reward(pack_d)
    let reward_delta = phi_r_h - phi_r_d
    println("  [T1] Φ_reward healthy=" + str(phi_r_h) + " depressed=" + str(phi_r_d) + " drop=" + str(reward_delta))

    let mut ok = true
    if reward_delta <= DP_REWARD_DROP {
        println("  [T1] FAIL: reward drop <= " + str(DP_REWARD_DROP))
        ok = false
    }
    return ok
}

fn check_T2() -> bool {
    // T2 Rumination: self[t] vs self[t-1] sub-window |Pearson r|.
    //   Depressed: locked attractor, autocorr > DP_SELF_AUTOCORR.
    //   Healthy:   flowing, autocorr < DP_HEALTHY_AUTO_CEIL.
    println("  --- T2: Rumination (self-channel autocorrelation locked) ---")
    let pack_h = dp_run_pipeline(DP_REWARD_HEALTHY,  DP_SELF_PERSIST_H, DP_ATTN_NEG_H, DP_MOTOR_GAIN_H, DP_MOTOR_LAG_H, 77202)
    let pack_d = dp_run_pipeline(DP_REWARD_DEPRESSED, DP_SELF_PERSIST_D, DP_ATTN_NEG_D, DP_MOTOR_GAIN_D, DP_MOTOR_LAG_D, 77202)

    let auto_h = dp_phi_self_autocorr(pack_h)
    let auto_d = dp_phi_self_autocorr(pack_d)
    println("  [T2] self-autocorr healthy=" + str(auto_h) + " depressed=" + str(auto_d))

    let mut ok = true
    // Depressed autocorr must exceed the rumination threshold.
    if auto_d <= DP_SELF_AUTOCORR {
        println("  [T2] FAIL: depressed autocorr <= " + str(DP_SELF_AUTOCORR))
        ok = false
    }
    // Healthy autocorr must stay below the ceiling — shows rumination is
    // a depression-specific signature, not a baseline of the generator.
    if auto_h >= DP_HEALTHY_AUTO_CEIL {
        println("  [T2] FAIL: healthy autocorr >= " + str(DP_HEALTHY_AUTO_CEIL))
        ok = false
    }
    // And of course the depressed autocorr must exceed the healthy one.
    if auto_d <= auto_h {
        println("  [T2] FAIL: depressed autocorr not greater than healthy")
        ok = false
    }
    return ok
}

fn check_T3() -> bool {
    // T3 Negative cognitive bias: with an AMBIGUOUS stimulus carrying
    // both positive and negative valence features, attention MI with
    // the negative feature exceeds MI with the positive feature in
    // the depressed subject by DP_NEG_BIAS_GAP; healthy baseline is
    // roughly symmetric.
    println("  --- T3: Negative cognitive bias (attn captured by neg feature) ---")
    let pack_h = dp_run_pipeline(DP_REWARD_HEALTHY,  DP_SELF_PERSIST_H, DP_ATTN_NEG_H, DP_MOTOR_GAIN_H, DP_MOTOR_LAG_H, 77303)
    let pack_d = dp_run_pipeline(DP_REWARD_DEPRESSED, DP_SELF_PERSIST_D, DP_ATTN_NEG_D, DP_MOTOR_GAIN_D, DP_MOTOR_LAG_D, 77303)

    let phi_neg_h = dp_phi_attn_neg(pack_h, 77303 + 4000)
    let phi_pos_h = dp_phi_attn_pos(pack_h, 77303 + 4000)
    let phi_neg_d = dp_phi_attn_neg(pack_d, 77303 + 4000)
    let phi_pos_d = dp_phi_attn_pos(pack_d, 77303 + 4000)

    let bias_d = phi_neg_d - phi_pos_d
    let bias_h = phi_neg_h - phi_pos_h
    println("  [T3] healthy: Φ_attn_neg=" + str(phi_neg_h) + " Φ_attn_pos=" + str(phi_pos_h) + " bias=" + str(bias_h))
    println("  [T3] depressed: Φ_attn_neg=" + str(phi_neg_d) + " Φ_attn_pos=" + str(phi_pos_d) + " bias=" + str(bias_d))

    let mut ok = true
    // Depressed attention must show the negative bias.
    if bias_d <= DP_NEG_BIAS_GAP {
        println("  [T3] FAIL: depressed bias <= " + str(DP_NEG_BIAS_GAP))
        ok = false
    }
    // Depressed bias must exceed healthy bias (a depression-specific gap).
    if bias_d <= bias_h {
        println("  [T3] FAIL: depressed bias not greater than healthy bias")
        ok = false
    }
    return ok
}

fn check_T4() -> bool {
    // T4 Psychomotor slowing: motor output lags stimulus.
    //   Healthy:   peak lag-MI at lag=0.
    //   Depressed: peak lag-MI shifted to lag=DP_LAG_TEST.
    //   Specifically: MI@lag - MI@0 > DP_LAG_GAP in depressed.
    println("  --- T4: Psychomotor slowing (motor channel latency) ---")
    let pack_h = dp_run_pipeline(DP_REWARD_HEALTHY,  DP_SELF_PERSIST_H, DP_ATTN_NEG_H, DP_MOTOR_GAIN_H, DP_MOTOR_LAG_H, 77404)
    let pack_d = dp_run_pipeline(DP_REWARD_DEPRESSED, DP_SELF_PERSIST_D, DP_ATTN_NEG_D, DP_MOTOR_GAIN_D, DP_MOTOR_LAG_D, 77404)

    let mi_h_0 = dp_phi_motor_lag(pack_h, 0)
    let mi_h_lag = dp_phi_motor_lag(pack_h, DP_LAG_TEST)
    let mi_d_0 = dp_phi_motor_lag(pack_d, 0)
    let mi_d_lag = dp_phi_motor_lag(pack_d, DP_LAG_TEST)

    let shift_h = mi_h_lag - mi_h_0
    let shift_d = mi_d_lag - mi_d_0
    println("  [T4] healthy: MI@0=" + str(mi_h_0) + " MI@lag=" + str(mi_h_lag) + " shift=" + str(shift_h))
    println("  [T4] depressed: MI@0=" + str(mi_d_0) + " MI@lag=" + str(mi_d_lag) + " shift=" + str(shift_d))

    let mut ok = true
    // Depressed: lag-MI must exceed immediate MI by the gap.
    if shift_d <= DP_LAG_GAP {
        println("  [T4] FAIL: depressed lag-shift <= " + str(DP_LAG_GAP))
        ok = false
    }
    // The shift must be SPECIFIC to depression (healthy shift < depressed).
    if shift_d <= shift_h {
        println("  [T4] FAIL: depressed lag-shift not greater than healthy")
        ok = false
    }
    return ok
}

fn check_T5() -> bool {
    // T5 Φ_depression narrowed + determinism + latency.
    //   Depression collapses integration onto the self-loop, leaving
    //   the other channels (reward, attn, motor, meta) less mutually
    //   coupled. Breadth metric = mean pairwise MI among those four.
    //   Gate: breadth_healthy - breadth_depressed >= DP_BREADTH_GAP.
    //   Determinism: identical seeds → identical Φ values.
    //   Latency: full pipeline < DP_LATENCY_MS.
    println("  --- T5: Φ_depression narrowed (breadth + determinism + latency) ---")
    let t0 = clock()

    // Run A: both modes.
    let pa_h = dp_run_pipeline(DP_REWARD_HEALTHY,  DP_SELF_PERSIST_H, DP_ATTN_NEG_H, DP_MOTOR_GAIN_H, DP_MOTOR_LAG_H, 77505)
    let pa_d = dp_run_pipeline(DP_REWARD_DEPRESSED, DP_SELF_PERSIST_D, DP_ATTN_NEG_D, DP_MOTOR_GAIN_D, DP_MOTOR_LAG_D, 77505)

    // Run B: identical seeds — determinism probe.
    let pb_h = dp_run_pipeline(DP_REWARD_HEALTHY,  DP_SELF_PERSIST_H, DP_ATTN_NEG_H, DP_MOTOR_GAIN_H, DP_MOTOR_LAG_H, 77505)
    let pb_d = dp_run_pipeline(DP_REWARD_DEPRESSED, DP_SELF_PERSIST_D, DP_ATTN_NEG_D, DP_MOTOR_GAIN_D, DP_MOTOR_LAG_D, 77505)

    let t1 = clock()
    let ms = (t1 - t0) * 1000.0

    let breadth_h = dp_phi_breadth(pa_h)
    let breadth_d = dp_phi_breadth(pa_d)
    let breadth_drop = breadth_h - breadth_d
    println("  [T5] breadth healthy=" + str(breadth_h) + " depressed=" + str(breadth_d) + " drop=" + str(breadth_drop))

    // Also log self-autocorr for intuition: it should be high in depression.
    let auto_d = dp_phi_self_autocorr(pa_d)
    println("  [T5] depressed self-autocorr (rumination witness)=" + str(auto_d))

    // Determinism via reward Φ on both modes.
    let rh_a = dp_phi_reward(pa_h)
    let rh_b = dp_phi_reward(pb_h)
    let rd_a = dp_phi_reward(pa_d)
    let rd_b = dp_phi_reward(pb_d)
    let d_h = dp_abs(rh_a - rh_b)
    let d_d = dp_abs(rd_a - rd_b)
    println("  [T5] determinism deltas: healthy=" + str(d_h) + " depressed=" + str(d_d))
    println("  [T5] pipeline latency = " + str(ms) + " ms (gate=" + str(DP_LATENCY_MS) + ")")

    let mut ok = true
    if breadth_drop <= DP_BREADTH_GAP {
        println("  [T5] FAIL: breadth drop <= " + str(DP_BREADTH_GAP))
        ok = false
    }
    if d_h > DP_EPS {
        println("  [T5] FAIL: healthy not deterministic")
        ok = false
    }
    if d_d > DP_EPS {
        println("  [T5] FAIL: depressed not deterministic")
        ok = false
    }
    if ms >= DP_LATENCY_MS {
        println("  [T5] FAIL: latency >= " + str(DP_LATENCY_MS))
        ok = false
    }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[depression_phi] P123 — Depression Φ (Anhedonia / Rumination / Negative Bias / Psychomotor Slowing)")
    println("  6 channels: stimulus → reward / self(AR1) / attn(neg-biased) / motor(lagged) / meta")
    println("  reward_gain: healthy=" + str(DP_REWARD_HEALTHY) + " depressed=" + str(DP_REWARD_DEPRESSED))
    println("  self_persist: healthy=" + str(DP_SELF_PERSIST_H) + " depressed=" + str(DP_SELF_PERSIST_D))
    println("  attn_bias_neg: healthy=" + str(DP_ATTN_NEG_H) + " depressed=" + str(DP_ATTN_NEG_D))
    println("  motor_lag: healthy=" + str(DP_MOTOR_LAG_H) + " depressed=" + str(DP_MOTOR_LAG_D))
    println("  refs: Treadway&Zald 2011 | Nolen-Hoeksema 1991 | Beck 1967 | Sobin&Sackeim 1997")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — anhedonia (Φ_reward depressed < healthy)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — rumination (self-channel lag-1 autocorrelation locked)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — negative bias (Φ_attn_neg > Φ_attn_pos in depression)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — psychomotor slowing (motor lag-MI peaks at lag>0)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — breadth narrowed + determinism + latency < " + str(DP_LATENCY_MS) + " ms") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 long && chains may mishandle short-circuit
    // ordering — use a mutable bool accumulator with sequential guards
    // (same idiom as emotion_regulation_phi / adhd_phi).
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[depression_phi] 5/5 PASS — P123 DONE")
    } else {
        println("[depression_phi] SOME FAILED")
    }
}

main()
