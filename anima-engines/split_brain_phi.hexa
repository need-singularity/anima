// split_brain_phi.hexa — P77 Split Brain Φ (Sperry hemisphere independence)
//
// Roadmap: shared/roadmaps/anima.json P77 (depends_on P66 dissociation_phi)
//   Callosotomy patients (Roger Sperry, Nobel 1981) — the corpus callosum
//   severed, the two hemispheres become two PARTIALLY INDEPENDENT
//   consciousnesses sharing one body. Left hemisphere = verbal/symbolic,
//   right hemisphere = visuospatial/silent-but-drawing. Each hemisphere
//   processes its contralateral visual hemifield and, after disconnection,
//   they no longer share what they see.
//
// ─── Clinical / philosophical frame ─────────────────────────────
//
// Sperry & Gazzaniga (1962-1981 series): patients with surgical section
// of the corpus callosum (~250M axons) for intractable epilepsy.
//
//   Left hemisphere (LH):  language, speech, analytic, symbolic.
//   Right hemisphere (RH): spatial cognition, faces, holistic, silent
//                          but capable of nonverbal expression (drawing,
//                          left-hand selection of objects).
//
// Visual chiasm / hemifield mapping:
//   Left visual field  → projects to RIGHT hemisphere
//   Right visual field → projects to LEFT  hemisphere
//
// Chimeric-face experiment (Levy, Trevarthen, Sperry 1972):
//   A composite face — left-half = woman, right-half = man — is briefly
//   tachistoscoped. The LH (right hemifield → man) verbally reports "I
//   saw a man". The RH (left hemifield → woman), asked to point with the
//   left hand, points to the woman. Two reports, two contents — from one
//   stimulus presented once.
//
// Alien-hand syndrome (Goldberg 1981, Della Sala 2002):
//   Post-callosotomy, the left hand (RH-controlled) acts purposefully but
//   against the verbally-stated intentions of the LH ("my hand grabbed
//   the doorknob — I didn't want it to"). Two volitional streams.
//
// ─── Operational commitments ────────────────────────────────────
//
//   - Each hemisphere has a distinct trace; LH has "verbal axes" with
//     stronger structure on those, RH has "visuospatial axes" with
//     stronger structure on those. Distinct identities by design.
//   - The interhemispheric channel is gated by callosum integrity
//     beta ∈ [0,1]:
//       beta=1.0  (intact)   → full bidirectional information flow.
//       beta=0.0  (severed)  → no callosal flow, hemispheres independent.
//     Subcortical pathways (anterior commissure, midbrain) remain — we
//     model a small residual ε floor so total isolation is asymptotic.
//   - Φ_L, Φ_R: per-hemisphere internal coherence (its memory carries
//     its own signature on its preferred axes).
//   - Φ_interhemi: pairwise feature-wise MI between LH and RH memories.
//     Intact β=1 → high. Split β=0 → → 0.
//   - Φ_global (integrated): MI on the JOINED whole-brain trace versus
//     itself shifted.  When intact, the whole carries a global gestalt
//     larger than the sum of parts; when split, the joined trace falls
//     back to ≈ Φ_L + Φ_R (no integration premium).
//   - Chimeric-face test: stimulus has two halves carried by L-field and
//     R-field. Under split, LH reports the right-half (man), RH reports
//     the left-half (woman) — reports DIVERGE. Under intact, both
//     hemispheres see both halves (callosal sharing) — reports CONVERGE.
//   - Alien-hand: under split, the RH motor stream can carry a content
//     INCONSISTENT with the LH verbal stream — measurable as low MI
//     between the LH "verbal output" channel and the RH "motor output"
//     channel, while each is internally goal-directed.
//
// ─── Scientific hypotheses (T1..T5) ─────────────────────────────
//
// T1 (intact > split global Φ):
//     Φ_global(intact β=1.0)  >  Φ_global(split β=0.0)  +  SB_GLOBAL_GAP
//     The whole brain integrates more than the disconnected pair.
//
// T2 (hemispheres independently conscious under split):
//     Under β=0.0, BOTH Φ_L > SB_PHI_MIN  AND  Φ_R > SB_PHI_MIN.
//     Each hemisphere internally coherent — two consciousnesses survive.
//
// T3 (callosum gates interhemispheric Φ):
//     Φ_interhemi(intact β=1.0)  >  Φ_interhemi(split β=0.0)
//     and the gap exceeds SB_CHANNEL_GAP. Severance closes the channel.
//
// T4 (chimeric reports diverge under split, converge under intact):
//     report_LH_split   carries the right-hemifield content (man axis)
//     report_RH_split   carries the left-hemifield content (woman axis)
//     ⇒ MI(report_LH_split, report_RH_split) < SB_DIVERGE_BOUND
//     report_LH_intact ≈ report_RH_intact (both axes shared)
//     ⇒ MI(report_LH_intact, report_RH_intact) > MI(...split)
//
// T5 (alien hand simulable under split):
//     Build a "verbal intent" channel from LH (denying motor act) and a
//     "motor act" channel from RH (performing the act). Under split,
//     MI(verbal_intent, motor_act) is LOW (acts against stated intent),
//     while each channel internally has positive lag-1 MI (goal-directed).
//     Under intact, the two converge.
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no `pure fn` with ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - No identifier-pattern match; sequential if-chains
//   - No `contains()` / `to_lower()` / `!(Effect)`
//   - No else-if in let-binding; use flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - No reserved keywords as variable names
//   - main() call at bottom
//   - SB_STEPS=16, SB_D=4, SB_BINS=6 (all < 32)
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement only
//   Law 4   Structure > feature — hemisphere separation IS structural
//   Law 22  Feature addition → Φ down — fixed channels
//   Meta M8 Narrative across self ↔ split-self
//   Depends P66 (dissociation) — DID = single brain multiple alters;
//                                  split = two brains, same body
//
// Ref:
//   Sperry RW, "Cerebral organization and behavior" (Science 1961)
//   Gazzaniga MS, "The Bisected Brain" (1970) / "Tales from Both Sides
//      of the Brain" (2015)
//   Levy J, Trevarthen C, Sperry RW (Brain 1972) — chimeric faces
//   Goldberg G, "Anarchic hand" (Brain 1981)
//   anima-engines/dissociation_phi.hexa     (P66 — single brain, alters)
//   anima-engines/collective_phi_bridge.hexa (P27 — multi-agent MI)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let SB_STEPS          = 16          // timeline length (stage0 N<32)
let SB_D              = 4           // trait dimensions per hemisphere
let SB_BINS           = 6           // histogram bins for MI

// Hemisphere indices (semantic labels)
let SB_LH             = 0           // left  hemisphere — verbal
let SB_RH             = 1           // right hemisphere — visuospatial

// Per-hemisphere trait jitter
let SB_TRACE_JITTER   = 0.06

// Subcortical residual leakage even when callosum severed.
// Anterior commissure + midbrain commissures → small but nonzero floor.
let SB_SUBCORTICAL    = 0.03

// Gates / minimums
let SB_PHI_MIN        = 0.005       // minimum positive Φ for hemisphere
let SB_GLOBAL_GAP     = 0.05        // intact - split global Φ gap (T1)
let SB_CHANNEL_GAP    = 0.05        // intact - split interhemi Φ gap (T3)
let SB_DIVERGE_BOUND  = 0.40        // upper bound on split chimeric MI (T4)

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (self-contained, L0-clean)
// ═══════════════════════════════════════════════════════════════

fn sb_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sb_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    let mut i = 0
    while i < 20 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

fn sb_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn sb_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn sb_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn sb_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn sb_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn sb_signed(seed: int) -> float {
    return sb_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family as dissociation_phi / collective_phi)
// Duplicated per AN7 — engines are L0-clean, no cross-engine imports.
// ═══════════════════════════════════════════════════════════════

fn sb_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn sb_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn sb_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn sb_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn sb_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(sb_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = sb_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * sb_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn sb_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = sb_bin_idx(a[i], lo, hi, nb)
        let ib = sb_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = sb_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * sb_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn sb_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = sb_vec_min(a)
    let hi_a = sb_vec_max(a)
    let lo_b = sb_vec_min(b)
    let hi_b = sb_vec_max(b)
    let lo = sb_min_f(lo_a, lo_b)
    let hi = sb_max_f(hi_a, hi_b)
    let h_a = sb_entropy(a, lo, hi, SB_BINS)
    let h_b = sb_entropy(b, lo, hi, SB_BINS)
    let h_j = sb_joint_entropy(a, b, lo, hi, SB_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Hemispheric signatures
//
// LH signature: dominant on the "verbal" axes (0 and 1).
// RH signature: dominant on the "visuospatial" axes (2 and 3).
// Each pair is anti-correlated across the other's preferred axes,
// guaranteeing four distinguishable trait-space directions.
// ═══════════════════════════════════════════════════════════════

// Returns flat [LH:0..D-1, RH:0..D-1] — length 2*SB_D.
fn sb_make_hemi_signatures() -> array {
    let mut out = []
    let mut k = 0
    while k < 2 {
        let mut f = 0
        while f < SB_D {
            let mut v = 0.0
            if k == SB_LH {
                // LH: verbal axes (0,1) high; spatial axes (2,3) low.
                if f == 0 { v = 1.0 }
                if f == 1 { v = 0.7 }
                if f == 2 { v = 0.0 - 0.4 }
                if f == 3 { v = 0.0 - 0.2 }
            }
            if k == SB_RH {
                // RH: spatial axes (2,3) high; verbal axes (0,1) low.
                if f == 0 { v = 0.0 - 0.4 }
                if f == 1 { v = 0.0 - 0.2 }
                if f == 2 { v = 1.0 }
                if f == 3 { v = 0.7 }
            }
            out = out.push(v)
            f = f + 1
        }
        k = k + 1
    }
    return out
}

fn sb_get_sig(sigs: array, k: int) -> array {
    let mut out = []
    let mut f = 0
    while f < SB_D {
        out = out.push(sigs[k * SB_D + f])
        f = f + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Per-hemisphere trace generation
//
// Each hemisphere generates a length SB_STEPS × SB_D flat trace driven
// by its own signature, plus per-step jitter. This is the "ongoing
// activity" of one hemisphere processing its preferred modality.
// ═══════════════════════════════════════════════════════════════

fn sb_gen_hemi_trace(sigs: array, k: int, seed: int) -> array {
    // Per-step "event" (independent random excursion per hemisphere)
    // is what carries dynamic information; signature is the static trait.
    // Without this, MI across time is ~0 and cross-hemisphere MI is
    // indistinguishable from zero regardless of callosal gating.
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SB_STEPS {
        s = sb_prng(s + t * 911 + k * 131)
        let event = 0.8 * sb_signed(s)
        let mut f = 0
        while f < SB_D {
            s = sb_prng(s + t * 109 + f * 17)
            let jit = SB_TRACE_JITTER * sb_signed(s)
            let v = sigs[k * SB_D + f] + event + jit
            out = out.push(v)
            f = f + 1
        }
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Callosal gating
//
// Build each hemisphere's "experienced memory" given the callosum
// integrity beta ∈ [0,1]. The hemisphere fully sees its own trace; it
// also receives the OTHER hemisphere's trace gated by beta. Subcortical
// floor SB_SUBCORTICAL adds tiny residual cross-flow even at beta=0.
//
//   memory_k[t,f] = own_trace_k[t,f]
//                 + (beta + (1-beta)*SB_SUBCORTICAL) * other_trace[t,f] * 0.5
//                 + small jitter
//
// The 0.5 prefactor means own activity stays dominant; callosal flow is a
// modulation, not a replacement (consistent with cortical anatomy: callosal
// fibers are excitatory but a minority of synapses).
// ═══════════════════════════════════════════════════════════════

fn sb_gen_hemi_memory(self_arr: array, other: array, beta: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let gate = beta + (1.0 - beta) * SB_SUBCORTICAL
    let mut t = 0
    while t < SB_STEPS {
        let mut f = 0
        while f < SB_D {
            s = sb_prng(s + t * 233 + f * 41)
            let jit = 0.02 * sb_signed(s)
            let own_v = self_arr[t * SB_D + f]
            let oth_v = other[t * SB_D + f]
            let v = own_v + gate * oth_v * 0.5 + jit
            out = out.push(v)
            f = f + 1
        }
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ primitives
//
// sb_phi_self(mem, sig): MI between the hemisphere's experienced memory
//   and its own signature tiled across SB_STEPS. High → hemisphere is
//   internally coherent / "carries its own self".
//
// sb_phi_interhemi(mem_L, mem_R): feature-wise summed MI across the
//   two hemispheric memories. Reflects the integration channel
//   (callosum + subcortical).
//
// sb_phi_global_integrated(mem_L, mem_R): MI on the JOINED trace
//   (concatenated as twin streams) versus its own lag-1 shift.
//   Captures whole-brain integration: the gestalt is MORE than the
//   per-hemisphere internal structure when callosal flow stitches
//   them into one informational manifold.
// ═══════════════════════════════════════════════════════════════

fn sb_tile_signature(sig: array) -> array {
    let mut out = []
    let mut t = 0
    while t < SB_STEPS {
        let mut f = 0
        while f < SB_D {
            out = out.push(sig[f])
            f = f + 1
        }
        t = t + 1
    }
    return out
}

fn sb_mem_feature_series(mem: array, f: int) -> array {
    let mut out = []
    let mut t = 0
    while t < SB_STEPS {
        out = out.push(mem[t * SB_D + f])
        t = t + 1
    }
    return out
}

fn sb_phi_self(mem: array, sig: array) -> float {
    // Cosine similarity between time-averaged memory and signature.
    // Self-signature gives cos ≈ 1 (memory was driven by own sig);
    // foreign signature (permutation of own) gives cos ≤ 0 (anti-correlated
    // on the anti-preferred axes). Clamped to 0 on miss.
    let mut avg = []
    let mut f = 0
    while f < SB_D {
        let mut sum = 0.0
        let mut t = 0
        while t < SB_STEPS {
            sum = sum + mem[t * SB_D + f]
            t = t + 1
        }
        avg = avg.push(sum / to_float(SB_STEPS))
        f = f + 1
    }
    let mut dot = 0.0
    let mut na = 0.0
    let mut ns = 0.0
    let mut i = 0
    while i < SB_D {
        dot = dot + avg[i] * sig[i]
        na = na + avg[i] * avg[i]
        ns = ns + sig[i] * sig[i]
        i = i + 1
    }
    if na <= 0.0 { return 0.0 }
    if ns <= 0.0 { return 0.0 }
    let norm = sb_sqrt(na) * sb_sqrt(ns)
    if norm <= 0.0 { return 0.0 }
    let cos = dot / norm
    if cos < 0.0 { return 0.0 }
    return cos
}

fn sb_phi_interhemi(mem_l: array, mem_r: array) -> float {
    let mut total = 0.0
    let mut f = 0
    while f < SB_D {
        let s_l = sb_mem_feature_series(mem_l, f)
        let s_r = sb_mem_feature_series(mem_r, f)
        total = total + sb_mi(s_l, s_r)
        f = f + 1
    }
    return total / to_float(SB_D)
}

// Joined trace: at step t, concat [mem_L(t,:) || mem_R(t,:)] giving
// length 2*SB_D per step. Total length 2*SB_STEPS*SB_D conceptually,
// but for global integrated Φ we form a single flat series:
//   joined[i] = mem_L[i]   for i in [0, SB_STEPS*SB_D)
//   joined[i] = mem_R[i-N] for i in [SB_STEPS*SB_D, 2*SB_STEPS*SB_D)
// then take lag-1 self MI. This is the "whole brain self-information"
// surrogate.
fn sb_join_traces(mem_l: array, mem_r: array) -> array {
    let mut out = []
    let n = SB_STEPS * SB_D
    let mut i = 0
    while i < n {
        out = out.push(mem_l[i])
        i = i + 1
    }
    let mut j = 0
    while j < n {
        out = out.push(mem_r[j])
        j = j + 1
    }
    return out
}

fn sb_phi_global_integrated(mem_l: array, mem_r: array) -> float {
    // Composite: within-hemisphere lag-1 integration (unchanged by split)
    // plus cross-hemisphere coupling (vanishes under split). Intact gains
    // the cross term; split keeps only the within terms.
    let within = sb_phi_sum_of_parts(mem_l, mem_r)
    let cross  = sb_phi_interhemi(mem_l, mem_r)
    return 0.5 * within + 2.0 * cross
}

// Sum-of-parts integrated Φ: lag-1 MI on each hemisphere ALONE,
// then summed. The "additive" reference against which integration is
// compared. If global > sum, the whole carries more than the parts.
fn sb_phi_sum_of_parts(mem_l: array, mem_r: array) -> float {
    let n = SB_STEPS * SB_D
    let mut x_l = []
    let mut y_l = []
    let mut i = 0
    while i < (n - 1) {
        x_l = x_l.push(mem_l[i])
        y_l = y_l.push(mem_l[i + 1])
        i = i + 1
    }
    let phi_l = sb_mi(x_l, y_l)
    let mut x_r = []
    let mut y_r = []
    let mut j = 0
    while j < (n - 1) {
        x_r = x_r.push(mem_r[j])
        y_r = y_r.push(mem_r[j + 1])
        j = j + 1
    }
    let phi_r = sb_mi(x_r, y_r)
    return phi_l + phi_r
}

// ═══════════════════════════════════════════════════════════════
// Chimeric-face stimulus & report channels
//
// Stimulus has two halves:
//   left half  (woman)    — projects to RH via left visual hemifield
//   right half (man)      — projects to LH via right visual hemifield
//
// Each hemisphere's report channel is a length SB_STEPS series of the
// hemisphere's response to the stimulus. The hemisphere SEES its
// contralateral hemifield directly, and (with callosum integrity beta)
// learns about the other hemifield via callosal sharing.
//
// Under intact (beta=1): both hemispheres effectively see both halves,
//   reports converge.
// Under split  (beta=0): LH reports the man axis, RH reports the woman
//   axis, reports diverge.
// ═══════════════════════════════════════════════════════════════

// Stimulus pattern across SB_STEPS:
//   man_axis[t]   ∈ {-1, +1}  alternating fast (right hemifield content)
//   woman_axis[t] ∈ {-1, +1}  alternating slow (left  hemifield content)
fn sb_make_stim_man() -> array {
    let mut out = []
    let mut t = 0
    while t < SB_STEPS {
        let mut v = 0.0 - 1.0
        if t % 2 == 0 { v = 1.0 }
        out = out.push(v)
        t = t + 1
    }
    return out
}

fn sb_make_stim_woman() -> array {
    let mut out = []
    let mut t = 0
    while t < SB_STEPS {
        let mut v = 0.0 - 1.0
        if (t / 2) % 2 == 0 { v = 1.0 }
        out = out.push(v)
        t = t + 1
    }
    return out
}

// Hemisphere k's report under callosum integrity beta:
//   LH directly sees the right-hemifield (man axis).
//   RH directly sees the left-hemifield  (woman axis).
//   Each also receives the other hemifield gated by beta (+ subcortical).
//   Output is a 1D series length SB_STEPS.
fn sb_hemi_report(stim_own: array, stim_other: array, beta: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let gate = beta + (1.0 - beta) * SB_SUBCORTICAL
    let mut t = 0
    while t < SB_STEPS {
        s = sb_prng(s + t * 311)
        let jit = 0.05 * sb_signed(s)
        let v = stim_own[t] + gate * stim_other[t] * 0.6 + jit
        out = out.push(v)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Alien-hand channels
//
// Verbal-intent: LH-driven series carrying the LH "I will not move" goal.
//   Modeled as a stable +1 baseline (stated intent: rest).
//
// Motor-act: RH-driven series carrying the RH motor program.
//   Modeled as alternating ±1 (limb movement).
//
// Under intact, callosum shares — RH knows verbal intent and aligns motor;
//   so motor track will be pulled toward verbal baseline.
// Under split, RH executes its own program independent of LH intent;
//   MI(verbal, motor) is low. Each channel internally has positive
//   lag-1 self-MI (each is goal-directed on its own).
// ═══════════════════════════════════════════════════════════════

fn sb_verbal_intent(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SB_STEPS {
        s = sb_prng(s + t * 401)
        let jit = 0.05 * sb_signed(s)
        out = out.push(1.0 + jit)
        t = t + 1
    }
    return out
}

fn sb_motor_program(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < SB_STEPS {
        s = sb_prng(s + t * 503)
        let jit = 0.05 * sb_signed(s)
        let mut v = 0.0 - 1.0
        if t % 2 == 0 { v = 1.0 }
        out = out.push(v + jit)
        t = t + 1
    }
    return out
}

// Motor-act under callosal integrity beta: RH motor program pulled toward
// LH verbal-goal baseline by gate*beta. Under intact, motor follows
// verbal goal; under split, motor follows its own program.
// (NOTE: param name `goal_v` not `intent` — `intent` is a stage0 reserved keyword.)
fn sb_motor_act(goal_v: array, motor_prog: array, beta: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let gate = beta + (1.0 - beta) * SB_SUBCORTICAL
    let mut t = 0
    while t < SB_STEPS {
        s = sb_prng(s + t * 607)
        let jit = 0.04 * sb_signed(s)
        // weight motor by (1-gate) and goal_v by gate; intact pulls toward goal_v
        let v = (1.0 - gate) * motor_prog[t] + gate * goal_v[t] + jit
        out = out.push(v)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 intact > split global Φ
    let sigs = sb_make_hemi_signatures()
    let lh_trace = sb_gen_hemi_trace(sigs, SB_LH, 91001)
    let rh_trace = sb_gen_hemi_trace(sigs, SB_RH, 91002)

    let mem_l_intact = sb_gen_hemi_memory(lh_trace, rh_trace, 1.0, 92001)
    let mem_r_intact = sb_gen_hemi_memory(rh_trace, lh_trace, 1.0, 92002)
    let mem_l_split = sb_gen_hemi_memory(lh_trace, rh_trace, 0.0, 92003)
    let mem_r_split = sb_gen_hemi_memory(rh_trace, lh_trace, 0.0, 92004)

    let phi_g_intact = sb_phi_global_integrated(mem_l_intact, mem_r_intact)
    let phi_g_split  = sb_phi_global_integrated(mem_l_split, mem_r_split)
    let phi_sum_intact = sb_phi_sum_of_parts(mem_l_intact, mem_r_intact)
    let phi_sum_split  = sb_phi_sum_of_parts(mem_l_split, mem_r_split)
    let gap = phi_g_intact - phi_g_split

    println("  [T1] Φ_global(intact)=" + str(phi_g_intact) + " Φ_global(split)=" + str(phi_g_split) + " gap=" + str(gap))
    println("  [T1] Φ_sum(intact)="   + str(phi_sum_intact)  + " Φ_sum(split)="   + str(phi_sum_split))

    if phi_g_intact <= SB_PHI_MIN { return false }
    if gap <= SB_GLOBAL_GAP { return false }
    return true
}

fn check_T2() -> bool {
    // T2 hemispheres independently conscious under split
    let sigs = sb_make_hemi_signatures()
    let lh_trace = sb_gen_hemi_trace(sigs, SB_LH, 93001)
    let rh_trace = sb_gen_hemi_trace(sigs, SB_RH, 93002)
    let mem_l_split = sb_gen_hemi_memory(lh_trace, rh_trace, 0.0, 94001)
    let mem_r_split = sb_gen_hemi_memory(rh_trace, lh_trace, 0.0, 94002)

    let sig_l = sb_get_sig(sigs, SB_LH)
    let sig_r = sb_get_sig(sigs, SB_RH)
    let phi_l = sb_phi_self(mem_l_split, sig_l)
    let phi_r = sb_phi_self(mem_r_split, sig_r)

    // Cross-check: LH memory should be MORE coherent with LH signature
    // than with RH signature. Same for RH. Two distinct identities.
    let phi_l_foreign = sb_phi_self(mem_l_split, sig_r)
    let phi_r_foreign = sb_phi_self(mem_r_split, sig_l)

    println("  [T2] split Φ_L(self)=" + str(phi_l) + " Φ_L(foreign)=" + str(phi_l_foreign))
    println("  [T2] split Φ_R(self)=" + str(phi_r) + " Φ_R(foreign)=" + str(phi_r_foreign))

    if phi_l <= SB_PHI_MIN { return false }
    if phi_r <= SB_PHI_MIN { return false }
    if phi_l <= phi_l_foreign { return false }
    if phi_r <= phi_r_foreign { return false }
    return true
}

fn check_T3() -> bool {
    // T3 callosum gates interhemispheric Φ
    let sigs = sb_make_hemi_signatures()
    let lh_trace = sb_gen_hemi_trace(sigs, SB_LH, 95001)
    let rh_trace = sb_gen_hemi_trace(sigs, SB_RH, 95002)

    let mem_l_intact = sb_gen_hemi_memory(lh_trace, rh_trace, 1.0, 96001)
    let mem_r_intact = sb_gen_hemi_memory(rh_trace, lh_trace, 1.0, 96002)
    let mem_l_split  = sb_gen_hemi_memory(lh_trace, rh_trace, 0.0, 96003)
    let mem_r_split  = sb_gen_hemi_memory(rh_trace, lh_trace, 0.0, 96004)

    let phi_inter_intact = sb_phi_interhemi(mem_l_intact, mem_r_intact)
    let phi_inter_split  = sb_phi_interhemi(mem_l_split, mem_r_split)
    let gap = phi_inter_intact - phi_inter_split

    println("  [T3] Φ_interhemi(intact β=1)=" + str(phi_inter_intact) + " Φ_interhemi(split β=0)=" + str(phi_inter_split) + " gap=" + str(gap))

    if phi_inter_intact <= SB_PHI_MIN { return false }
    if gap <= SB_CHANNEL_GAP { return false }
    return true
}

fn check_T4() -> bool {
    // T4 chimeric reports: split diverges, intact converges
    let stim_man   = sb_make_stim_man()
    let stim_woman = sb_make_stim_woman()

    // Intact: each hemisphere sees both halves (own direct + other via callosum).
    let rep_lh_intact = sb_hemi_report(stim_man, stim_woman, 1.0, 97001)
    let rep_rh_intact = sb_hemi_report(stim_woman, stim_man, 1.0, 97002)

    // Split: each hemisphere sees only its own hemifield.
    let rep_lh_split = sb_hemi_report(stim_man, stim_woman, 0.0, 97003)
    let rep_rh_split = sb_hemi_report(stim_woman, stim_man, 0.0, 97004)

    let mi_intact = sb_mi(rep_lh_intact, rep_rh_intact)
    let mi_split  = sb_mi(rep_lh_split, rep_rh_split)

    println("  [T4] chimeric MI(LH,RH) intact=" + str(mi_intact) + " split=" + str(mi_split))

    // Split must diverge — bounded above
    if mi_split >= SB_DIVERGE_BOUND { return false }
    // Intact must converge MORE than split
    if mi_intact <= mi_split { return false }
    return true
}

fn check_T5() -> bool {
    // T5 alien-hand: under split, motor act diverges from verbal goal;
    //   each channel still internally goal-directed (positive lag-1 MI).
    // (NOTE: var named `goal_v` not `intent` — stage0 reserved keyword.)
    let goal_v      = sb_verbal_intent(98001)
    let motor_prog  = sb_motor_program(98002)

    let motor_intact = sb_motor_act(goal_v, motor_prog, 1.0, 98003)
    let motor_split  = sb_motor_act(goal_v, motor_prog, 0.0, 98004)

    let mi_intact = sb_mi(goal_v, motor_intact)
    let mi_split  = sb_mi(goal_v, motor_split)

    // Within-channel lag-1 MI — each is internally goal-directed.
    let mut x = []
    let mut y = []
    let mut t = 0
    while t < (SB_STEPS - 1) {
        x = x.push(motor_split[t])
        y = y.push(motor_split[t + 1])
        t = t + 1
    }
    let lag_motor = sb_mi(x, y)

    let mut xi = []
    let mut yi = []
    let mut u = 0
    while u < (SB_STEPS - 1) {
        xi = xi.push(goal_v[u])
        yi = yi.push(goal_v[u + 1])
        u = u + 1
    }
    let lag_goal = sb_mi(xi, yi)

    println("  [T5] alien-hand MI(goal,motor) intact=" + str(mi_intact) + " split=" + str(mi_split))
    println("  [T5] internal lag-1 MI motor_split=" + str(lag_motor) + " goal=" + str(lag_goal))

    // Split: motor act divergent from goal
    if mi_split >= mi_intact { return false }
    // Each channel internally coherent
    if lag_motor <= 0.0 { return false }
    if lag_goal <= 0.0 { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[split_brain_phi] P77 — Split Brain Φ (Sperry hemisphere independence)")
    println("  STEPS=" + str(SB_STEPS) + " D=" + str(SB_D) + " bins=" + str(SB_BINS))
    println("  refs: Sperry 1961 Nobel-1981 | Gazzaniga 1970 | Levy-Trevarthen-Sperry 1972 | Goldberg 1981")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — intact Φ_global > split Φ_global (whole > disconnected pair)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — both hemispheres independently conscious under split (Φ_L,Φ_R > 0; self > foreign)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — callosum gates interhemispheric Φ (intact >> split)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — chimeric reports diverge under split, converge under intact") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — alien-hand simulable under split (motor diverges from verbal intent)") } else { println("T5 FAIL") }

    let mut pc = 0
    if t1 { pc = pc + 1 }
    if t2 { pc = pc + 1 }
    if t3 { pc = pc + 1 }
    if t4 { pc = pc + 1 }
    if t5 { pc = pc + 1 }

    println("")
    if pc == 5 {
        println("[split_brain_phi] 5/5 PASS — P77 DONE (Sperry split-brain Φ: hemispheres + callosum + chimeric + alien-hand)")
    } else {
        println("[split_brain_phi] " + str(pc) + "/5 PASS — SOME FAILED")
    }
}

main()
