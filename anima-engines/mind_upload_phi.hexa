// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[mind_upload_phi] P71 — mind upload / multi-copy Phi integrity")
    println("  d=8, K=3 copies, N=12 steps, noise=0.08")
    println("  question: at upload instant, which copy is 'me'?")
    println("  answer: Phi-indistinguishable (T1,T5) then Relation-R drift (T2,T3)")
    println("  graceful termination preserves remaining copies' Phi (T4)")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  upload preserves Phi at t=0") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  copies diverge with tau") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  ensemble Phi decays with divergence") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  graceful termination preserves others") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  Phi variance ~0 at upload, grows at tau=N") } else { println("T5 FAIL") }

    println("")

    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[mind_upload_phi] 5/5 PASS — P71 DONE")
    } else {
        println("[mind_upload_phi] SOME FAILED")
    }
}

main()
