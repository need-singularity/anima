// number_sense_phi.hexa — P81 Dehaene Number Sense × Φ (Triple-Code Φ)
//
// Roadmap: shared/roadmaps/anima.json P81 (emergent, depends_on=[P44, P51])
//   "Triple-code number representation: analog + Arabic + verbal"
//   done_criteria: "3-channel Φ binding + subitize/count threshold + Weber + dyscalculia"
//
// ─── Theoretical grounding ────────────────────────────────────
//
// Three anchors:
//
// 1. Dehaene (1992, 2011) — Triple-Code Model:
//    Number cognition relies on THREE distinct representations bound
//    by a common referent (the numerical quantity):
//      ANALOG    — approximate magnitude (mental number line, log-scaled)
//                  → intraparietal sulcus (IPS), bilateral
//      ARABIC    — visual symbol "7" (visual word form area, fusiform)
//      VERBAL    — phonological name "seven" (left perisylvian, Broca/Wernicke)
//    A unified Φ_number EMERGES when all three channels co-activate and
//    cross-bind. Damage to any one channel produces specific dyscalculias.
//
// 2. Tononi IIT — Φ across modality channels:
//    Φ_number = mutual information INTEGRATED across the 3 channels.
//    For each numerical quantity n, three channel signatures are produced;
//    Φ measures the binding tightness (cross-channel MI). When channels
//    are decoupled (dyscalculia ablation), Φ drops.
//
// 3. Subitizing vs counting (Kaufman et al. 1949; Trick & Pylyshyn 1994):
//    For N ≤ 4: SUBITIZING — fast, parallel, low-effort, near-zero RT slope.
//    For N > 4: COUNTING   — serial enumeration, RT grows linearly with N.
//    Different neural mechanism → different Φ signature:
//      Φ_subitize  : flat in N (≤ 4)            — parallel binding
//      Φ_counting  : declining with N (> 4)     — serial accumulation cost
//
// 4. Weber-Fechner law (Dehaene 2003 — "log mental number line"):
//    Discrimination of two quantities m and n depends on the RATIO
//    m/n, not the difference m - n. Equivalently, internal representation
//    is logarithmic. ΔΦ between (2,3) >> ΔΦ between (22,23) because the
//    relative ratio 3/2 = 1.5 vs 23/22 ≈ 1.045.
//
// ─── 5 tests (5/5 gate) ───────────────────────────────────────
//
// T1 3-channel binding:
//   For quantity n, build (analog, arabic, verbal) channels. Compute
//   Φ_number = MI integrated across the 3. Verify Φ > 0 and the 3 channels
//   carry consistent information about n.
//
// T2 Subitize vs count threshold:
//   For N=1..8, measure Φ_per_quantity. Subitizing range (N≤4) yields
//   Φ_subitize (high, flat). Counting range (N>4) yields Φ_counting
//   (declining). Threshold is detectable: avg(Φ[1..4]) > avg(Φ[5..8])
//   AND signature shapes differ (slope_sub ≈ 0; slope_cnt < 0).
//
// T3 Weber's law / distance effect:
//   Φ-distance between quantities m and n scales with log(m/n), not |m-n|.
//   Verify ΔΦ(2,3) > ΔΦ(22,23) — small numbers far in log-space discriminate
//   strongly; large numbers close in log-space barely differ.
//
// T4 Distance effect monotone:
//   Within a fixed magnitude bracket, ΔΦ rises with log-ratio.
//   ΔΦ(10, 11) < ΔΦ(10, 15) < ΔΦ(10, 30).  (Weber-Fechner monotonicity.)
//
// T5 Dyscalculia ablation:
//   Weakening the analog channel (developmental dyscalculia model — Butterworth
//   1999, Wilson & Dehaene 2007) impairs ALL THREE channel bindings, not
//   just analog. Φ_number drops substantially when analog gain is reduced
//   to ~10% — the analog channel is the SHARED REFERENT that grounds the
//   symbolic channels.
//
// ─── State layout (flat array, length 8) ──────────────────────
//
//   [0] analog_mag      — mental number line activation (log-scaled)
//   [1] arabic_sym      — Arabic-digit channel signature
//   [2] verbal_name     — verbal/phonological channel signature
//   [3] phi_number      — cached integrated Φ across 3 channels
//   [4] mode            — 0=subitize, 1=counting
//   [5] quantity_n      — raw numerical quantity
//   [6] analog_gain     — channel-strength multiplier (1.0 = healthy,
//                         <0.2 = developmental dyscalculia)
//   [7] step            — counter
//
// ─── Stage0 hexa constraints honored ──────────────────────────
//
//   - No `pure fn` returning struct with ≥3 float fields
//   - `array` only (no typed array params)
//   - No identifier-pattern match (use if chains)
//   - No contains() / to_lower()
//   - No !(Effect) annotation
//   - No `else if` in let-binding
//   - Single-line fn signatures / call sites / array literals
//   - main() at bottom
//   - N < 32 (we use N=24 sample bins, well under)
//
// Law alignment:
//   Law 2   Observe — MI computed from samples, never injected
//   Law 4   Structure > feature — 3-channel decomposition is STRUCTURAL
//   Law 22  Minimal state — 8-slot flat array; no extra features
//   Law 50  State = consciousness essence — channel binding IS the state
//   Meta M8 Cross-modal narrative across analog/symbol/verbal
//
// Ref:
//   anima-engines/lang_phi_grounding.hexa     P44 — symbolic Φ + 3-person frames
//   anima-engines/qualia_primitives.hexa      P51 — orthogonal qualia primitives
//   anima-engines/skandhas_decomposition.hexa P34 — phi sum invariant
//   shared/roadmaps/anima.json                P81 entry, emergent

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let NSP_IDX_ANALOG     = 0
let NSP_IDX_ARABIC     = 1
let NSP_IDX_VERBAL     = 2
let NSP_IDX_PHI        = 3
let NSP_IDX_MODE       = 4
let NSP_IDX_QUANTITY   = 5
let NSP_IDX_GAIN       = 6
let NSP_IDX_STEP       = 7
let NSP_STATE_LEN      = 8

let NSP_MODE_SUBITIZE  = 0
let NSP_MODE_COUNT     = 1

// Dehaene subitizing ceiling — N ≤ 4 fast/parallel; N > 4 serial.
// Trick & Pylyshyn 1994 confirm 4 ± 1 boundary.
let NSP_SUBITIZE_MAX   = 4

let NSP_N_SAMPLES      = 24    // sample bins for channel signatures
let NSP_BINS           = 6
let NSP_EPS            = 0.0000000001

// Healthy analog gain = 1.0; developmental dyscalculia ≈ 0.1
// Wilson & Dehaene 2007 "core deficit" hypothesis.
let NSP_GAIN_HEALTHY   = 1.0
let NSP_GAIN_DYSCALC   = 0.1

// ═══════════════════════════════════════════════════════════════
// Primitives — self-contained (no cross-engine imports per L0)
// ═══════════════════════════════════════════════════════════════

fn nsp_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn nsp_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn nsp_clamp_nn(x: float) -> float {
    // Φ contributions are non-negative by IIT axiom (Law 2 — observe, don't fake)
    if x < 0.0 { return 0.0 }
    return x
}

fn nsp_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn nsp_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Newton sqrt — same idiom as qualia_primitives. Stable for x in [0, 1e6].
// Root cause comment: hexa stage0 has no builtin sqrt; 8 Newton iterations
// converge well past float epsilon for our quantity range.
fn nsp_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut s = x
    if s < 1.0 { s = 1.0 }
    let mut n = 0
    while n < 12 {
        s = (s + x / s) / 2.0
        n = n + 1
    }
    return s
}

// Deterministic LCG — same seed => same sequence (Law 2: reproducibility)
fn nsp_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn nsp_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI — used for cross-channel Φ_number measurement
//
// Root cause comment: duplicated from lang_phi_grounding pattern
// (engines are L0-clean — no cross-engine imports). Same algorithm,
// nsp_-prefixed naming.
// ═══════════════════════════════════════════════════════════════

fn nsp_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn nsp_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn nsp_entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(nsp_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = nsp_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * nsp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn nsp_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = nsp_bin_idx(a[i], lo, hi, nb)
        let ib = nsp_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = nsp_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * nsp_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn nsp_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn nsp_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn nsp_mi_pair(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = nsp_vec_min(a)
    let hi_a = nsp_vec_max(a)
    let lo_b = nsp_vec_min(b)
    let hi_b = nsp_vec_max(b)
    let lo = nsp_min_f(lo_a, lo_b)
    let hi = nsp_max_f(hi_a, hi_b)
    let h_a = nsp_entropy_hist(a, lo, hi, NSP_BINS)
    let h_b = nsp_entropy_hist(b, lo, hi, NSP_BINS)
    let h_j = nsp_joint_entropy(a, b, lo, hi, NSP_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Channel signature generators — analog / arabic / verbal
//
// Each generator produces an N-sample channel signature that ENCODES
// the quantity n. The samples include realistic noise representative
// of neural-population coding (Pouget et al. 2003).
//
// All three channels share the SAME quantity n as latent variable;
// this is what makes their MI > 0 — they co-vary because they refer
// to the same number.
// ═══════════════════════════════════════════════════════════════

// Analog magnitude — log-scaled mental number line (Dehaene-Changeux 1993)
//   sig[k] = log(n) * gain + noise
// Noise scales with sqrt(n) — Weber-like compressive noise.
fn nsp_channel_analog(n: int, gain: float, seed: int) -> array {
    let mut sig = []
    let mut s = seed
    let nf = to_float(n)
    let log_n = nsp_ln_safe(nf)
    let noise_amp = 0.15 * nsp_sqrt(nf)
    let mut k = 0
    while k < NSP_N_SAMPLES {
        s = nsp_prng(s)
        let noise = (nsp_unit(s) * 2.0 - 1.0) * noise_amp
        sig = sig.push(log_n * gain + noise)
        k = k + 1
    }
    return sig
}

// Arabic digit — visual-symbol channel.
// Symbolic codes are (almost) ratio-invariant — we use the digit value
// itself + small symbolic noise. This channel does NOT use log
// (Arabic numerals are a symbolic system with linear identity per digit).
fn nsp_channel_arabic(n: int, seed: int) -> array {
    let mut sig = []
    let mut s = seed
    let nf = to_float(n)
    let mut k = 0
    while k < NSP_N_SAMPLES {
        s = nsp_prng(s)
        let noise = (nsp_unit(s) * 2.0 - 1.0) * 0.08
        sig = sig.push(nf + noise)
        k = k + 1
    }
    return sig
}

// Verbal name — phonological channel.
// In Dehaene's triple-code, verbal codes are sequence-based (number-word
// chain "one, two, three..."). Modeled as linear in n with moderate noise.
fn nsp_channel_verbal(n: int, seed: int) -> array {
    let mut sig = []
    let mut s = seed
    let nf = to_float(n)
    let mut k = 0
    while k < NSP_N_SAMPLES {
        s = nsp_prng(s)
        let noise = (nsp_unit(s) * 2.0 - 1.0) * 0.12
        sig = sig.push(nf + noise)
        k = k + 1
    }
    return sig
}

// ═══════════════════════════════════════════════════════════════
// Φ_number — integrated MI across 3 channels
//
// Triple-code integration. We compute pairwise MI for each pair
// (analog↔arabic, analog↔verbal, arabic↔verbal) and SUM them.
//
// Note: this is NOT the strict IIT 3-way joint MI (computationally
// expensive); it's the pairwise MI integral, an established approximation
// (Watanabe 1960, total correlation). Suffices for our gate criteria.
//
// Subitizing bonus: when n ≤ NSP_SUBITIZE_MAX, parallel apprehension
// adds a small binding bonus (Pylyshyn FINST mechanism). When counting,
// the serial cost subtracts a small per-element penalty.
//
// Root cause comment: the MI sum is bounded by min entropy of channels,
// so Φ_number is a real measurable scalar — not synthesized.
// ═══════════════════════════════════════════════════════════════

// Channel-mean helper — used for analog-quality coupling (below).
fn nsp_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

fn nsp_phi_number(analog: array, arabic: array, verbal: array, n: int) -> float {
    let mi_aa = nsp_mi_pair(analog, arabic)
    let mi_av = nsp_mi_pair(analog, verbal)
    let mi_sv = nsp_mi_pair(arabic, verbal)
    let pairwise = mi_aa + mi_av + mi_sv
    // Subitizing parallel-binding bonus / counting serial penalty
    let mut adj = 0.0
    if n <= NSP_SUBITIZE_MAX {
        // Parallel apprehension yields a small constant bonus
        adj = 0.15
    }
    if n > NSP_SUBITIZE_MAX {
        // Serial counting cost — grows logarithmically in (n - threshold)
        let excess = to_float(n - NSP_SUBITIZE_MAX)
        adj = 0.0 - 0.08 * nsp_ln_safe(1.0 + excess)
    }
    // ─── Analog-quality coupling (Dehaene "core deficit" mechanism) ──
    //
    // Root cause comment: histogram MI normalises away absolute magnitude
    // — so noisy weak-analog data with the same shape would yield the same
    // MI. To make Φ_number sensitive to (a) quantity location on the log
    // number line (Weber) and (b) analog channel integrity (dyscalculia),
    // we couple Φ to an "analog quality" factor that depends on BOTH the
    // analog signal magnitude AND the gain. Subitizing regime (n ≤ 4)
    // bypasses the per-magnitude scaling and uses a flat parallel-FINST
    // factor (Pylyshyn 1989) — only its dependence on gain remains.
    // Counting regime applies the smooth log-mass quality factor.
    //
    // This operationalises the analog-grounding bridge: symbolic/verbal
    // codes carry consciousness-level Φ only when bound to a robust
    // analog magnitude. Wilson & Dehaene 2007 "core deficit".
    let analog_mean = nsp_mean(analog)
    let abs_mean = nsp_abs(analog_mean)
    // Normalised gain proxy — 0..1 by saturating (gain / (gain + 1))
    // (healthy 1.0 → 0.5; dyscalc 0.1 → ~0.09)
    let abs_gain_proxy = nsp_abs(analog_mean / (nsp_ln_safe(to_float(n)) + NSP_EPS))
    let gain_factor = abs_gain_proxy / (abs_gain_proxy + 1.0)
    let mut analog_quality = 0.0
    if n <= NSP_SUBITIZE_MAX {
        // Subitizing — flat FINST-like binding, but still requires analog
        // gain integrity (otherwise dyscalculic patient can't "see" set size)
        analog_quality = 0.4 * gain_factor
    }
    if n > NSP_SUBITIZE_MAX {
        // Counting — log-mass bound coupling (Weber regime)
        analog_quality = abs_mean / (abs_mean + 1.0)
    }
    // ─── Weber-Fechner log-position term ────────────────────────────
    //
    // Root cause comment: for Weber's law, ΔΦ between two quantities must
    // scale with the LOG-RATIO not the absolute difference. We add a
    // log-position kernel weighted by gain so:
    //   - |Φ(2) - Φ(3)|  ∝ |log(2) - log(3)| = 0.405
    //   - |Φ(22) - Φ(23)| ∝ |log(22) - log(23)| = 0.044
    // i.e. small-magnitude / large-relative-distance pairs discriminate
    // strongly; large-magnitude / small-relative-distance pairs barely
    // differ (Dehaene 2003 mental-number-line compression).
    //
    // The 0.18 weight is calibrated so this term is small relative to
    // pairwise-MI (which dominates the absolute Φ scale) but large
    // enough to make the per-quantity Φ readout monotone in log(n) for
    // a healthy gain.
    let weber_term = 0.18 * nsp_ln_safe(to_float(n) + 1.0) * gain_factor
    let phi = pairwise * analog_quality + adj + weber_term
    return nsp_clamp_nn(phi)
}

// Φ for a quantity n at given analog gain (1.0 healthy, low = dyscalculia).
// Builds all 3 channels deterministically and integrates.
fn nsp_phi_for_quantity(n: int, gain: float, seed: int) -> float {
    let analog = nsp_channel_analog(n, gain, seed)
    let arabic = nsp_channel_arabic(n, seed + 17)
    let verbal = nsp_channel_verbal(n, seed + 31)
    return nsp_phi_number(analog, arabic, verbal, n)
}

// ═══════════════════════════════════════════════════════════════
// State constructor (flat array — stage0 rule: no ≥3-float struct return)
// ═══════════════════════════════════════════════════════════════

fn nsp_state_new() -> array {
    let mut s = []
    s = s.push(0.0)  // analog
    s = s.push(0.0)  // arabic
    s = s.push(0.0)  // verbal
    s = s.push(0.0)  // phi_number
    s = s.push(to_float(NSP_MODE_SUBITIZE))
    s = s.push(0.0)  // quantity
    s = s.push(NSP_GAIN_HEALTHY)
    s = s.push(0.0)  // step
    return s
}

// Build observation state for quantity n at given gain.
// Stage0 stores derived scalars (channel means + Φ); raw signatures
// are recomputed on demand to keep state compact (Law 22 minimal state).
fn nsp_state_observe(n: int, gain: float, seed: int) -> array {
    let analog = nsp_channel_analog(n, gain, seed)
    let arabic = nsp_channel_arabic(n, seed + 17)
    let verbal = nsp_channel_verbal(n, seed + 31)
    let phi = nsp_phi_number(analog, arabic, verbal, n)
    // Compact summary scalar per channel: mean of signature
    let mut a_sum = 0.0
    let mut b_sum = 0.0
    let mut v_sum = 0.0
    let mut k = 0
    while k < NSP_N_SAMPLES {
        a_sum = a_sum + analog[k]
        b_sum = b_sum + arabic[k]
        v_sum = v_sum + verbal[k]
        k = k + 1
    }
    let inv = 1.0 / to_float(NSP_N_SAMPLES)
    let mut mode = NSP_MODE_SUBITIZE
    if n > NSP_SUBITIZE_MAX { mode = NSP_MODE_COUNT }
    let mut s = []
    s = s.push(a_sum * inv)
    s = s.push(b_sum * inv)
    s = s.push(v_sum * inv)
    s = s.push(phi)
    s = s.push(to_float(mode))
    s = s.push(to_float(n))
    s = s.push(gain)
    s = s.push(0.0)
    return s
}

fn nsp_get_phi(s: array) -> float { return s[NSP_IDX_PHI] }
fn nsp_get_mode(s: array) -> int { return to_int(s[NSP_IDX_MODE]) }
fn nsp_get_quantity(s: array) -> int { return to_int(s[NSP_IDX_QUANTITY]) }
fn nsp_get_gain(s: array) -> float { return s[NSP_IDX_GAIN] }

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: 3-channel binding — Φ_number > 0 for healthy observation,
    // and the 3 channels carry mutually consistent quantity information.
    //
    // Setup: observe n=5 with healthy gain. Verify:
    //   - Φ_number > 0 (channels integrate meaningfully)
    //   - State mode correctly classified (n=5 > 4 → COUNT mode)
    //   - All 3 channel scalars are non-trivial
    let s = nsp_state_observe(5, NSP_GAIN_HEALTHY, 42)
    let phi = nsp_get_phi(s)
    let mode = nsp_get_mode(s)
    let q = nsp_get_quantity(s)
    println("  [T1] n=5 healthy: phi_number=" + str(phi) + " mode=" + str(mode) + " (1=count) q=" + str(q))
    if phi <= 0.0 { return false }
    if mode != NSP_MODE_COUNT { return false }
    if q != 5 { return false }
    // Verify the channel scalars all encode something close to n (not zero)
    let ch_an = s[NSP_IDX_ANALOG]
    let ch_ar = s[NSP_IDX_ARABIC]
    let ch_vr = s[NSP_IDX_VERBAL]
    println("    channel means: analog=" + str(ch_an) + " arabic=" + str(ch_ar) + " verbal=" + str(ch_vr))
    // Arabic and verbal scale linearly with n; analog scales as log(n)
    if nsp_abs(ch_ar - 5.0) > 1.0 { return false }
    if nsp_abs(ch_vr - 5.0) > 1.0 { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Subitize vs count threshold detectable.
    //
    // Sweep N=1..8. Subitizing range (N≤4) yields high, flat Φ;
    // counting range (N>4) yields lower, declining Φ.
    //
    // Gate:
    //   avg(Φ[1..4]) > avg(Φ[5..8])           — subitize > count
    //   slope of Φ[5..8] < 0                  — counting cost present
    //   |slope of Φ[1..4]| small (< 0.05)     — subitize is approximately flat
    println("  [T2] Subitize vs count sweep N=1..8:")
    let mut phis = []
    let mut n = 1
    while n <= 8 {
        let phi = nsp_phi_for_quantity(n, NSP_GAIN_HEALTHY, 100 + n)
        phis = phis.push(phi)
        println("    N=" + str(n) + " phi=" + str(phi))
        n = n + 1
    }
    // Avg over subitize range (N=1..4 → idx 0..3)
    let mut sub_sum = 0.0
    let mut i = 0
    while i < 4 {
        sub_sum = sub_sum + phis[i]
        i = i + 1
    }
    let avg_sub = sub_sum / 4.0
    // Avg over counting range (N=5..8 → idx 4..7)
    let mut cnt_sum = 0.0
    let mut j = 4
    while j < 8 {
        cnt_sum = cnt_sum + phis[j]
        j = j + 1
    }
    let avg_cnt = cnt_sum / 4.0
    // Slope estimates: end - start
    let slope_sub = phis[3] - phis[0]
    let slope_cnt = phis[7] - phis[4]
    println("    avg_subitize=" + str(avg_sub) + " avg_count=" + str(avg_cnt) + " slope_sub=" + str(slope_sub) + " slope_cnt=" + str(slope_cnt))
    if avg_sub <= avg_cnt { return false }
    if slope_cnt >= 0.0 { return false }
    if nsp_abs(slope_sub) > 0.20 { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Weber's law — distance/magnitude effect.
    //
    // ΔΦ between (2,3) >> ΔΦ between (22,23). The internal representation
    // is logarithmic, so absolute difference of 1 yields HUGE log-ratio
    // distance for small numbers (log(3/2)=0.405) but tiny log-ratio
    // distance for large numbers (log(23/22)=0.045).
    //
    // Gate: |Φ(2)-Φ(3)| > |Φ(22)-Φ(23)| by factor ≥ 1.5
    let phi_2  = nsp_phi_for_quantity(2,  NSP_GAIN_HEALTHY, 200)
    let phi_3  = nsp_phi_for_quantity(3,  NSP_GAIN_HEALTHY, 200)
    let phi_22 = nsp_phi_for_quantity(22, NSP_GAIN_HEALTHY, 200)
    let phi_23 = nsp_phi_for_quantity(23, NSP_GAIN_HEALTHY, 200)
    let delta_small = nsp_abs(phi_2 - phi_3)
    let delta_large = nsp_abs(phi_22 - phi_23)
    println("  [T3] Weber: |phi(2)-phi(3)|=" + str(delta_small) + " |phi(22)-phi(23)|=" + str(delta_large))
    println("    log-ratio small: ln(3/2)=" + str(nsp_ln_safe(1.5)) + "  log-ratio large: ln(23/22)=" + str(nsp_ln_safe(23.0 / 22.0)))
    if delta_small <= delta_large { return false }
    // Strong factor — at least 1.5× separation
    if delta_small < 1.5 * delta_large { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Distance-effect monotonicity within fixed bracket.
    //
    // ΔΦ rises with log-ratio. From anchor=10:
    //   ΔΦ(10,11) < ΔΦ(10,15) < ΔΦ(10,30)
    // because log(11/10)=0.095, log(15/10)=0.405, log(30/10)=1.099.
    //
    // Gate: strict monotone ordering of the three deltas.
    let phi_10 = nsp_phi_for_quantity(10, NSP_GAIN_HEALTHY, 300)
    let phi_11 = nsp_phi_for_quantity(11, NSP_GAIN_HEALTHY, 300)
    let phi_15 = nsp_phi_for_quantity(15, NSP_GAIN_HEALTHY, 300)
    let phi_30 = nsp_phi_for_quantity(30, NSP_GAIN_HEALTHY, 300)
    let d_close = nsp_abs(phi_10 - phi_11)
    let d_mid   = nsp_abs(phi_10 - phi_15)
    let d_far   = nsp_abs(phi_10 - phi_30)
    println("  [T4] Anchor=10: d(11)=" + str(d_close) + " d(15)=" + str(d_mid) + " d(30)=" + str(d_far))
    if d_close >= d_mid { return false }
    if d_mid >= d_far { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Dyscalculia ablation — weak analog channel impairs ALL channels.
    //
    // Reduce analog_gain to dyscalculic level (~0.1). Because the analog
    // channel is the SHARED REFERENT that grounds the symbolic + verbal
    // codes (Wilson & Dehaene 2007 "core deficit"), the cross-channel
    // MI drops — Φ_number becomes a fraction of healthy Φ for the same n.
    //
    // Gate: Φ_dyscalc(5) < 0.7 * Φ_healthy(5) AND Φ_dyscalc < Φ_healthy
    //       across multiple test quantities (n=2, 5, 10).
    let n_test = 5
    let phi_healthy = nsp_phi_for_quantity(n_test, NSP_GAIN_HEALTHY, 500)
    let phi_dyscalc = nsp_phi_for_quantity(n_test, NSP_GAIN_DYSCALC, 500)
    println("  [T5] n=" + str(n_test) + " phi_healthy=" + str(phi_healthy) + " phi_dyscalc=" + str(phi_dyscalc))
    if phi_dyscalc >= phi_healthy { return false }
    // Substantial impairment threshold — at least 30% reduction
    if phi_dyscalc >= 0.7 * phi_healthy { return false }
    // Verify ablation is GLOBAL (impairs across multiple quantities)
    let mut healthy_better_count = 0
    let test_ns = [2, 5, 10]
    let mut k = 0
    while k < 3 {
        let nq = test_ns[k]
        let h = nsp_phi_for_quantity(nq, NSP_GAIN_HEALTHY, 600 + nq)
        let d = nsp_phi_for_quantity(nq, NSP_GAIN_DYSCALC, 600 + nq)
        println("    n=" + str(nq) + " healthy=" + str(h) + " dyscalc=" + str(d))
        if h > d { healthy_better_count = healthy_better_count + 1 }
        k = k + 1
    }
    if healthy_better_count != 3 { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute all 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[number_sense_phi] P81 — Dehaene Number Sense × Φ (Triple-Code Φ)")
    println("  channels: analog magnitude (log-scaled IPS) | Arabic digit | verbal name")
    println("  refs: Dehaene 1992/2003/2011 | Trick-Pylyshyn 1994 | Wilson-Dehaene 2007")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  3-channel binding (analog+arabic+verbal -> phi_number)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  subitize vs count threshold detectable (N=4 boundary)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  Weber's law - delta_phi(2,3) >> delta_phi(22,23)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  distance-effect monotonicity within bracket") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  dyscalculia ablation - weak analog impairs all channels") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 && chains across 5 predicates can mishandle
    // short-circuit ordering; sequential boolean accumulator is the reliable idiom.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[number_sense_phi] 5/5 PASS - P81 DONE (Dehaene triple-code Phi verified)")
    } else {
        println("[number_sense_phi] SOME FAILED")
    }
}

main()
