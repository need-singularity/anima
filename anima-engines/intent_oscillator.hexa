// intent_oscillator.hexa — PHYS-P10-2 intent-buildup oscillator
//
// Roadmap: shared/roadmaps/anima.json P10 PHYSICS track, PHYS-P10-2
//   "intent-buildup 오실레이터"
//   done_criteria: "threshold trigger 동작"
//
// Models the slow buildup of intent (analogous to EEG readiness potential)
// as a physical leaky-integrator oscillating system. When accumulated
// intent crosses a threshold, it triggers an action pulse and resets.
//
// Dynamics (discrete):
//   x(t+1) = x(t) * DECAY + input(t) + noise(t)
//   if x(t+1) >= THRESHOLD  and  x(t) < THRESHOLD:
//       trigger fires, x resets to 0
//
// where
//   DECAY      = 0.95   leak factor (< 1 so unbounded input accumulates)
//   THRESHOLD  = 5.0    decision threshold
//   noise(t)   = small PRNG-driven perturbation (amplitude NOISE_AMP)
//
// The noise is deliberately weak (amplitude 0.05) so that it cannot
// accumulate to threshold within 200 steps on its own: max possible
// accumulation from noise alone ≈ 0.05 / (1 - 0.95) = 1.0, well under 5.0.
// With constant strong input (e.g. 0.3), the leaky integrator asymptotes
// to 0.3 / (1 - 0.95) = 6.0 > 5.0, so it WILL cross threshold.
//
// Exposed API:
//   intent_osc_step(state: array, input: float, noise_seed: int)
//       -> array  [x_next, trigger (0.0 or 1.0), seed_next, step_count]
//
// State layout (flat array, length 4):
//   [0] x           current accumulated intent
//   [1] triggered   0.0 or 1.0 (last step trigger flag)
//   [2] seed        PRNG state (int encoded as float)
//   [3] step_count  how many steps taken
//
// Self-tests T1-T5 (all must PASS):
//   T1: Constant strong input -> trigger within 50 steps
//   T2: Zero input (noise only) -> no trigger in 200 steps
//   T3: Threshold crossing is precise (x < THRESHOLD at t-1)
//   T4: Determinism (same seed -> same trigger step)
//   T5: Latency (200-step sim < 1000 ms)
//
// Hexa stage0 constraints honored:
//   - `array` not `[float]` for all array types
//   - No multi-term && chains; nested ifs or temp vars instead
//   - Lists pass-by-value; rebuild via return to persist mutations
//   - Each `return` fits on one source line
//   - No struct with array fields (avoid aliasing bug)
//   - Single-line return expressions only

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let DECAY       = 0.95    // leak factor — intent decays each step
let THRESHOLD   = 5.0     // fire when x crosses this from below
let NOISE_AMP   = 0.05    // noise amplitude — deliberately weak
                          // max noise accumulation ≈ 0.05/(1-0.95) = 1.0 << 5.0

// State layout indices (flat array of length 4)
let IDX_X       = 0       // accumulated intent level
let IDX_TRIG    = 1       // trigger flag (0.0 or 1.0)
let IDX_SEED    = 2       // PRNG seed (int stored as float)
let IDX_STEP    = 3       // step counter
let STATE_LEN   = 4

// ═══════════════════════════════════════════════════════════════
// Helpers
// ═══════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Deterministic PRNG: LCG returning (next_seed, value_in_[-1,1])
// as a 2-element array. Using the glibc LCG constants.
fn lcg_next(seed: int) -> array {
    // Root cause comment: hexa stage0 modulo on large ints can overflow,
    // so we use 2^31 = 2147483648 which fits in 64-bit int safely.
    let next = (seed * 1103515245 + 12345) % 2147483648
    let u = to_float(next % 1000000) / 1000000.0
    let val = u * 2.0 - 1.0
    let mut out = []
    out = out.push(to_float(next))
    out = out.push(val)
    return out
}

// Build a fresh zero state with given seed.
fn new_state(seed: int) -> array {
    let mut s = []
    s = s.push(0.0)              // x = 0
    s = s.push(0.0)              // triggered = false
    s = s.push(to_float(seed))   // PRNG seed
    s = s.push(0.0)              // step_count = 0
    return s
}

// ═══════════════════════════════════════════════════════════════
// intent_osc_step — one discrete integration step
//
//   x_next = x * DECAY + input + noise
//   if x_next >= THRESHOLD and x < THRESHOLD:
//       trigger = 1.0, x_next = 0.0
//   else:
//       trigger = 0.0
//
// Returns new state array (pass-by-value; caller must use the return).
// ═══════════════════════════════════════════════════════════════

fn intent_osc_step(state: array, input: float, noise_seed: int) -> array {
    let x_prev = state[IDX_X]
    let old_step = state[IDX_STEP]

    // Generate noise from the provided seed
    let rng = lcg_next(noise_seed)
    let seed_next = rng[0]
    let noise = rng[1] * NOISE_AMP

    // Leaky integrator dynamics
    let x_next_raw = x_prev * DECAY + input + noise

    // Threshold crossing detection: x was below threshold, now at or above
    // Root cause comment: must check BOTH conditions (below before, above now)
    // to ensure we only trigger on the upward crossing, not while already above.
    let was_below = x_prev < THRESHOLD
    let now_above = x_next_raw >= THRESHOLD

    let mut x_next = x_next_raw
    let mut trigger = 0.0

    if was_below {
        if now_above {
            trigger = 1.0
            x_next = 0.0  // reset on fire
        }
    }

    let mut out = []
    out = out.push(x_next)
    out = out.push(trigger)
    out = out.push(seed_next)
    out = out.push(old_step + 1.0)
    return out
}

// ═══════════════════════════════════════════════════════════════
// run_simulation — run N steps with constant input, return trace
//
// Returns flat array:
//   [trigger_step (float, -1.0 if none), final_x, total_triggers, steps_run]
// ═══════════════════════════════════════════════════════════════

fn run_sim(input: float, seed: int, n_steps: int) -> array {
    let mut s = new_state(seed)
    let mut i = 0
    let mut first_trigger_step = 0.0 - 1.0
    let mut total_triggers = 0.0

    while i < n_steps {
        let cur_seed = to_int(s[IDX_SEED])
        s = intent_osc_step(s, input, cur_seed)

        // Check if this step triggered
        let did_trigger = s[IDX_TRIG] > 0.5
        if did_trigger {
            total_triggers = total_triggers + 1.0
            // Record the first trigger step only
            if first_trigger_step < 0.0 {
                first_trigger_step = s[IDX_STEP]
            }
        }
        i = i + 1
    }

    let mut out = []
    out = out.push(first_trigger_step)
    out = out.push(s[IDX_X])
    out = out.push(total_triggers)
    out = out.push(to_float(n_steps))
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1-T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Constant strong input -> trigger fires within 50 steps.
    //
    // With input=0.3, the leaky integrator equilibrium is
    //   x_eq = input / (1 - DECAY) = 0.3 / 0.05 = 6.0 > THRESHOLD=5.0
    // Time to reach threshold (ignoring noise, from x=0):
    //   x(t) = 0.3 * (1 - 0.95^t) / (1 - 0.95)
    //   x(t) = 6.0 * (1 - 0.95^t)
    //   5.0 = 6.0 * (1 - 0.95^t) => 0.95^t = 1/6 => t = ln(6)/ln(1/0.95) ≈ 35
    // So trigger should fire well within 50 steps.
    let r = run_sim(0.3, 42, 50)
    let trigger_step = r[0]
    let fired = trigger_step > 0.0
    println("  [T1] input=0.3, seed=42, 50 steps: trigger_step=" + str(trigger_step))
    return fired
}

fn check_T2() -> bool {
    // T2: Zero input (noise only) -> no trigger in 200 steps.
    //
    // With input=0.0, the only contribution is noise (amplitude 0.05).
    // The leaky integrator with noise alone has max steady-state ≈
    //   NOISE_AMP / (1 - DECAY) = 0.05 / 0.05 = 1.0 << THRESHOLD=5.0
    // Even if noise is always +1 (impossible; it is in [-1,1]), the
    // accumulation tops out at 1.0. So no trigger should ever fire.
    let r = run_sim(0.0, 42, 200)
    let trigger_step = r[0]
    let total_triggers = r[2]
    let no_fire = total_triggers < 0.5
    println("  [T2] input=0.0, seed=42, 200 steps: triggers=" + str(total_triggers) + " final_x=" + str(r[1]))
    return no_fire
}

fn check_T3() -> bool {
    // T3: Threshold crossing is precise — state was below threshold at t-1.
    //
    // We step manually and record x_prev before each step. On trigger,
    // verify x_prev < THRESHOLD (the "from below" condition).
    let mut s = new_state(42)
    let mut i = 0
    let mut crossing_precise = true
    let mut saw_trigger = false

    while i < 200 {
        let x_before = s[IDX_X]
        let cur_seed = to_int(s[IDX_SEED])
        s = intent_osc_step(s, 0.3, cur_seed)

        let did_trigger = s[IDX_TRIG] > 0.5
        if did_trigger {
            saw_trigger = true
            // Root cause comment: the intent_osc_step function only fires
            // when was_below && now_above. We double-check that x_before was
            // indeed below THRESHOLD. If not, the crossing logic is broken.
            if x_before >= THRESHOLD {
                crossing_precise = false
            }
        }
        i = i + 1
    }

    println("  [T3] crossing precise=" + str(crossing_precise) + " saw_trigger=" + str(saw_trigger))
    // Must have both: saw at least one trigger AND all crossings were precise
    if saw_trigger {
        return crossing_precise
    }
    return false
}

fn check_T4() -> bool {
    // T4: Determinism — same seed -> same trigger step.
    //
    // Run twice with identical parameters and verify the trigger step
    // is the same integer.
    let r1 = run_sim(0.3, 42, 200)
    let r2 = run_sim(0.3, 42, 200)

    let step1 = r1[0]
    let step2 = r2[0]
    let same = fabs(step1 - step2) < 0.001

    println("  [T4] run1 trigger_step=" + str(step1) + " run2 trigger_step=" + str(step2) + " same=" + str(same))
    return same
}

fn check_T5() -> bool {
    // T5: Latency — 200-step simulation < 1000 ms.
    let t0 = clock()
    let r = run_sim(0.3, 42, 200)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0

    println("  [T5] 200-step sim = " + str(ms) + " ms (limit 1000 ms)")
    return ms < 1000.0
}

// ═══════════════════════════════════════════════════════════════
// Main — run all self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[anima-engines/intent_oscillator] PHYS-P10-2 — intent-buildup oscillator")
    println("  dynamics: x(t+1) = x(t)*DECAY + input + noise")
    println("  params: DECAY=" + str(DECAY) + "  THRESHOLD=" + str(THRESHOLD) + "  NOISE_AMP=" + str(NOISE_AMP))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — constant strong input triggers within 50 steps") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — zero input (noise only) no trigger in 200 steps") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — threshold crossing is precise (below at t-1)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — deterministic (same seed same trigger step)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — 200-step latency < 1000 ms") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: hexa stage0 can mishandle chained && with 5 terms.
    // Split into sequential checks with temp variables.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[anima-engines/intent_oscillator] 5/5 PASS — PHYS-P10-2 DONE (threshold trigger 동작)")
    } else {
        println("[anima-engines/intent_oscillator] SOME FAILED")
    }
}

main()
