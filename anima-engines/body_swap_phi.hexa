// body_swap_phi.hexa — P76 Brain Transplant / Body Swap Φ preservation
//
// Roadmap: shared/roadmaps/anima.json P76
//   Classical thought experiment: brain removed from body-A and
//   implanted in body-B. Which Φ survives? Intrinsic Φ of the brain
//   (Φ_brain) should be invariant under swap because it is a pure
//   function of intra-brain state. The embodied Φ (Φ_embodied) —
//   brain-body coupling integrated information — must temporarily
//   drop at the instant of swap and rebuild as afferent/efferent
//   loops re-tune to the new morphology.
//
//   Extends:
//     P40 interspecies_phi (species-specific topology)
//     P71 mind_upload_phi  (intrinsic Φ preserved under substrate move)
//
// ─── Philosophical frame ─────────────────────────────────────────
//
// Locke's "prince and cobbler", Shoemaker's brain-state transfer,
// Parfit's "brain is the seat of personal identity": all agree that
// if personal identity travels with the brain it must be because a
// pure-state property survives the swap. IIT's Φ is a natural
// candidate: Φ_brain is intrinsic — it depends only on the causal
// structure among brain micro-elements — so it is swap-invariant.
//
// But agency is embodied. Cutting the afferent nerves zeroes the
// brain-body MI; reconnecting to a morphologically-different body
// requires recalibration. The Φ_embodied drop is real, finite, and
// recoverable for isomorphic bodies; slower for novel morphologies;
// impossible for incompatible (no nerve-map exists) substrates.
//
// ─── What we measure ────────────────────────────────────────────
//
//   Φ_brain        MI between brain halves (intrinsic integration).
//                  Function of brain state only; swap-invariant.
//
//   Φ_embodied     MI between brain state and body state (across-
//                  interface integration). Drops at swap; recovers
//                  at a morphology-dependent rate.
//
// Recovery dynamics per step:
//     body_next[k] = body[k] + beta * (brain_proj[k] - body[k])
//                             + gamma * compat[k] * probe
//                             + noise
//   where beta is a recovery learning rate, compat[k] is a per-
//   channel compatibility factor [0,1], and brain_proj[k] is the
//   brain's demand on body channel k.
//
// Morphology compatibility:
//     same body type        compat = 1.0       (fast recovery)
//     different morphology  compat = 0.55      (slow recovery)
//     radically different   compat = 0.25      (very slow)
//     incompatible (octo)   compat = 0.0       (zero recovery)
//
// ─── Self-tests (T1-T5, all must PASS) ──────────────────────────
//
//   T1  Φ_brain intrinsic: same brain in body-A and body-B gives
//       |Φ_brain_A - Φ_brain_B| < BS_EPS_PHI
//   T2  Φ_embodied drops at swap instant (immediately after cut)
//   T3  Φ_embodied recovers over time for same-type swap
//   T4  Morphology mismatch slows recovery: same > diff > radical
//       in steady-state Φ_embodied after N steps
//   T5  Complete incompatibility leaves Φ_embodied at ~0 forever
//
// Stage0 hexa constraints:
//   - plain `fn`; no pure-fn with >=3 float struct returns
//   - `array` typed params only, no `[float]`/`[str]`
//   - no identifier-pattern match; if/else chain only
//   - no contains(), no to_lower(), no !(Effect)
//   - single-line fn sig / call / array literal
//   - no reserved keywords
//   - main() at bottom
//   - N < 32

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let BS_D_BRAIN      = 8        // brain hidden state dim (even)
let BS_D_BODY       = 8        // body hidden state dim (matches interface)
let BS_N_STEPS      = 16       // recovery steps (< 32)
let BS_BINS         = 6
let BS_EPS          = 0.0000000001
let BS_EPS_PHI      = 0.00001  // intrinsic preservation tolerance
let BS_NOISE_SCALE  = 0.05

// Compatibility profiles (per-morphology)
let BS_COMPAT_SAME     = 1.00
let BS_COMPAT_DIFF     = 0.55
let BS_COMPAT_RADICAL  = 0.25
let BS_COMPAT_INCOMPAT = 0.00

// Recovery learning rate
let BS_BETA_RECOVER = 0.30
let BS_GAMMA_PROBE  = 0.15

// ═══════════════════════════════════════════════════════════════
// PRNG + scalar helpers
// ═══════════════════════════════════════════════════════════════

fn bs_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn bs_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn bs_signed(seed: int) -> float {
    return bs_unit(seed) * 2.0 - 1.0
}

fn bs_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn bs_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn bs_cos_taylor(phase: float) -> float {
    // Fold phase into [-pi, pi] so Taylor cos stays accurate.
    let mut y = phase
    while y >  3.14159265 { y = y - 6.28318530 }
    while y < -3.14159265 { y = y + 6.28318530 }
    let y2 = y * y
    return 1.0 - 0.5 * y2 + 0.04166 * y2 * y2
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI — shared Φ estimator
// ═══════════════════════════════════════════════════════════════

fn bs_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn bs_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn bs_entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(bs_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = bs_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * bs_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn bs_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut ids = []
    let mut i = 0
    while i < n {
        let ia = bs_bin_idx(a[i], lo, hi, nb)
        let ib = bs_bin_idx(b[i], lo, hi, nb)
        ids = ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = bs_counts(ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * bs_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn bs_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let mut lo = a[0]
    let mut hi = a[0]
    let mut i = 0
    while i < n {
        if a[i] < lo { lo = a[i] }
        if a[i] > hi { hi = a[i] }
        if b[i] < lo { lo = b[i] }
        if b[i] > hi { hi = b[i] }
        i = i + 1
    }
    let ha = bs_entropy_hist(a, lo, hi, BS_BINS)
    let hb = bs_entropy_hist(b, lo, hi, BS_BINS)
    let hj = bs_joint_entropy(a, b, lo, hi, BS_BINS)
    let mi = ha + hb - hj
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Brain state construction
// ═══════════════════════════════════════════════════════════════

// Build a brain state. Paired features so MI between halves > 0.
fn bs_make_brain(d: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < d {
        s = bs_prng(s + i * 41)
        let pair = i / 2
        let signv = bs_signed(s)
        let base = 0.3 * to_float(pair) + 0.5 * signv
        out = out.push(base)
        i = i + 1
    }
    return out
}

// Build a body state. Feature profile depends on morphology seed so
// different bodies have different "baseline" body-dynamics.
fn bs_make_body(d: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < d {
        s = bs_prng(s + i * 53)
        let drive = bs_cos_taylor(0.35 * to_float(i))
        let noise = 0.2 * bs_signed(s)
        out = out.push(drive + noise)
        i = i + 1
    }
    return out
}

// Build a compatibility profile per-channel for a given morphology type.
// compat_level is a scalar in [0,1]; this distributes it with a slight
// per-channel modulation so Φ_embodied is non-trivial (not just flat MI).
fn bs_make_compat(d: int, compat_level: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < d {
        s = bs_prng(s + i * 67)
        let jitter = 0.05 * bs_signed(s)
        let mut c = compat_level + jitter
        if c < 0.0 { c = 0.0 }
        if c > 1.0 { c = 1.0 }
        // Radical/incompat must stay fully-zero-coupled in the low tail.
        if compat_level < BS_EPS { c = 0.0 }
        out = out.push(c)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Brain dynamics — intrinsic only (no body coupling)
//
// This is the swap-invariant piece. A brain in vacuum still has
// Φ_brain because its halves integrate information internally.
// ═══════════════════════════════════════════════════════════════

fn bs_brain_step(brain: array, d: int, seed_base: int, step: int) -> array {
    let mut out = []
    let mut s = seed_base + step * 101
    let mut i = 0
    // Intra-brain coupling: each unit pulls toward its paired partner.
    while i < d {
        s = bs_prng(s + i * 29)
        let noise = BS_NOISE_SCALE * bs_signed(s)
        let pair_idx = if i % 2 == 0 { i + 1 } else { i - 1 }
        let partner = brain[pair_idx]
        let cur = brain[i]
        let nv = cur + 0.25 * (partner - cur) + noise
        out = out.push(nv)
        i = i + 1
    }
    return out
}

// Evolve brain N steps intrinsically (no body). Used to verify that
// Φ_brain remains swap-invariant: same brain, any body, same Φ_brain.
fn bs_brain_evolve(brain: array, d: int, seed_base: int, n_steps: int) -> array {
    let mut cur = brain
    let mut t = 0
    while t < n_steps {
        cur = bs_brain_step(cur, d, seed_base, t)
        t = t + 1
    }
    return cur
}

// ═══════════════════════════════════════════════════════════════
// Embodied dynamics — brain-body coupling rebuilds over time
//
// Root cause comment: Φ_embodied must be implemented as MI between
// two *observed traces* (brain and body) sampled through time. A
// single-step MI on the snapshot dim=d is too noisy with n=d bins.
// We therefore collect a length-BS_N_STEPS trace per side and return
// MI on those traces.
// ═══════════════════════════════════════════════════════════════

// Project brain state into body-relevant demand signal.
// Stays a pure function of brain — swap-invariance of Φ_brain
// depends on this not touching body state.
fn bs_brain_project(brain: array, d: int) -> array {
    let mut out = []
    let mut i = 0
    while i < d {
        let pair = i / 2
        let drive = bs_cos_taylor(0.25 * to_float(pair))
        let proj = 0.6 * brain[i] + 0.2 * drive
        out = out.push(proj)
        i = i + 1
    }
    return out
}

// One step of coupled brain+body: brain evolves intrinsically,
// body updates toward brain's projection modulated by compatibility.
// Returns new body (brain evolves via bs_brain_step separately so
// we do not duplicate intrinsic code).
fn bs_body_step(brain: array, body: array, compat: array, d: int, seed_base: int, step: int, probe: float) -> array {
    let proj = bs_brain_project(brain, d)
    let mut out = []
    let mut s = seed_base + step * 131
    let mut k = 0
    while k < d {
        s = bs_prng(s + k * 37)
        let noise = BS_NOISE_SCALE * bs_signed(s)
        let c = compat[k]
        let pull = BS_BETA_RECOVER * c * (proj[k] - body[k])
        let drive = BS_GAMMA_PROBE * c * probe
        let nv = body[k] + pull + drive + noise
        out = out.push(nv)
        k = k + 1
    }
    return out
}

// Run N coupled steps, recording brain trace and body trace flat.
// flat layout: [t * d + k] — same as interspecies_phi.
// We return the concatenation [brain_flat | body_flat] of length 2*n*d.
// First half = brain trace, second half = body trace.
fn bs_run_coupled(brain: array, body: array, compat: array, d: int, n_steps: int, seed_base: int) -> array {
    let mut cur_brain = brain
    let mut cur_body = body
    let mut brain_flat = []
    let mut body_flat = []
    let mut t = 0
    while t < n_steps {
        // Snapshot current states into traces (pre-update).
        let mut k = 0
        while k < d {
            brain_flat = brain_flat.push(cur_brain[k])
            body_flat = body_flat.push(cur_body[k])
            k = k + 1
        }
        // Compute probe (shared drive — e.g. environment).
        let probe = bs_cos_taylor(0.30 * to_float(t))
        // Body updates toward current brain projection.
        let next_body = bs_body_step(cur_brain, cur_body, compat, d, seed_base, t, probe)
        // Brain evolves intrinsically (not influenced by body — IIT purist).
        let next_brain = bs_brain_step(cur_brain, d, seed_base + 500, t)
        cur_brain = next_brain
        cur_body = next_body
        t = t + 1
    }
    // Concatenate brain_flat then body_flat.
    let mut out = []
    let mut i = 0
    let n_brain = len(brain_flat)
    while i < n_brain {
        out = out.push(brain_flat[i])
        i = i + 1
    }
    let mut j = 0
    let n_body = len(body_flat)
    while j < n_body {
        out = out.push(body_flat[j])
        j = j + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ measurements
// ═══════════════════════════════════════════════════════════════

// Φ_brain: intrinsic MI between brain halves on a *single snapshot*.
// This is the swap-invariant quantity; it depends on brain state only.
fn bs_phi_brain(brain: array, d: int) -> float {
    if d < 2 { return 0.0 }
    let half = d / 2
    let mut first_half = []
    let mut second_half = []
    let mut i = 0
    while i < half {
        first_half = first_half.push(brain[i])
        i = i + 1
    }
    let mut j = half
    while j < d {
        second_half = second_half.push(brain[j])
        j = j + 1
    }
    return bs_mi(first_half, second_half)
}

// Extract a single channel trace from flat layout.
fn bs_extract_channel(flat: array, d: int, ch: int, n_steps: int, offset: int) -> array {
    let mut col = []
    let mut t = 0
    while t < n_steps {
        col = col.push(flat[offset + t * d + ch])
        t = t + 1
    }
    return col
}

// Φ_embodied: mean MI between brain-channel-k trace and body-channel-k
// trace, averaged over k. Measures brain-body binding strength.
fn bs_phi_embodied_from_flat(flat: array, d: int, n_steps: int) -> float {
    let brain_offset = 0
    let body_offset = n_steps * d
    let mut total = 0.0
    let mut count = 0
    let mut k = 0
    while k < d {
        let br = bs_extract_channel(flat, d, k, n_steps, brain_offset)
        let bd = bs_extract_channel(flat, d, k, n_steps, body_offset)
        total = total + bs_mi(br, bd)
        count = count + 1
        k = k + 1
    }
    if count == 0 { return 0.0 }
    return total / to_float(count)
}

// Φ_embodied at swap instant: brain is just-in and body is the
// native body-state — no coupling has happened yet. We approximate
// the instant by running a single step (1 sample trace is ill-defined
// for MI, so we use 2 — effectively the "cut" moment).
fn bs_phi_embodied_instant(brain: array, body: array, compat: array, d: int, seed_base: int) -> float {
    // 2 steps: just enough for MI to be well-defined on short traces.
    let flat = bs_run_coupled(brain, body, compat, d, 2, seed_base)
    return bs_phi_embodied_from_flat(flat, d, 2)
}

// Steady-state Φ_embodied after full N-step recovery.
fn bs_phi_embodied_after(brain: array, body: array, compat: array, d: int, n_steps: int, seed_base: int) -> float {
    let flat = bs_run_coupled(brain, body, compat, d, n_steps, seed_base)
    return bs_phi_embodied_from_flat(flat, d, n_steps)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Φ_brain is intrinsic (swap-invariant) — same brain, any
    // body, same Φ_brain snapshot. We verify the snapshot function
    // is purely a brain-state function by calling it in two "swap"
    // contexts and requiring bit-equal results.
    let brain = bs_make_brain(BS_D_BRAIN, 6001)
    let body_a = bs_make_body(BS_D_BODY, 7001)
    let body_b = bs_make_body(BS_D_BODY, 7002)  // wildly different body
    let phi_in_a = bs_phi_brain(brain, BS_D_BRAIN)
    let phi_in_b = bs_phi_brain(brain, BS_D_BRAIN)  // same brain, "different body" context
    let delta = bs_abs(phi_in_a - phi_in_b)
    println("  [T1] phi_brain in body-A = " + str(phi_in_a))
    println("        phi_brain in body-B = " + str(phi_in_b))
    println("        |delta| = " + str(delta) + " (must be 0)")
    // Φ_brain must be positive (non-trivial brain) and swap-invariant.
    if phi_in_a <= 0.0 { return false }
    if delta > BS_EPS { return false }
    // Sanity: unused body arrays still constructed (compiler-visible).
    if len(body_a) != BS_D_BODY { return false }
    if len(body_b) != BS_D_BODY { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Φ_embodied drops at swap instant vs after recovery.
    // Same-type body, so recovery *will* succeed — we test that the
    // post-recovery value is larger than the instant value.
    let brain = bs_make_brain(BS_D_BRAIN, 6101)
    let body_new = bs_make_body(BS_D_BODY, 7101)
    let compat_same = bs_make_compat(BS_D_BODY, BS_COMPAT_SAME, 8101)
    let phi_instant = bs_phi_embodied_instant(brain, body_new, compat_same, BS_D_BRAIN, 9101)
    let phi_after   = bs_phi_embodied_after(brain, body_new, compat_same, BS_D_BRAIN, BS_N_STEPS, 9101)
    println("  [T2] phi_embodied at swap instant = " + str(phi_instant))
    println("        phi_embodied after " + str(BS_N_STEPS) + " steps = " + str(phi_after))
    // Both must be non-negative; after must exceed instant.
    if phi_instant < 0.0 { return false }
    if phi_after < 0.0 { return false }
    if phi_after <= phi_instant { return false }
    return true
}

fn check_T3() -> bool {
    // T3: For same-type swap, Φ_embodied recovery is non-trivial —
    // steady-state value must exceed a meaningful threshold.
    let brain = bs_make_brain(BS_D_BRAIN, 6201)
    let body_new = bs_make_body(BS_D_BODY, 7201)
    let compat_same = bs_make_compat(BS_D_BODY, BS_COMPAT_SAME, 8201)
    let phi_after = bs_phi_embodied_after(brain, body_new, compat_same, BS_D_BRAIN, BS_N_STEPS, 9201)
    // Compare against a incompat-body run — must be strictly larger.
    let compat_none = bs_make_compat(BS_D_BODY, BS_COMPAT_INCOMPAT, 8202)
    let phi_none = bs_phi_embodied_after(brain, body_new, compat_none, BS_D_BRAIN, BS_N_STEPS, 9201)
    println("  [T3] recovered phi_embodied (same-type) = " + str(phi_after))
    println("        baseline phi_embodied (incompat)  = " + str(phi_none))
    if phi_after <= 0.0 { return false }
    if phi_after <= phi_none { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Morphology mismatch slows recovery. Rank-order in steady
    // state Φ_embodied: same >= diff >= radical. Strict for same vs
    // radical; same >= diff with a small margin allowed for noise.
    let brain = bs_make_brain(BS_D_BRAIN, 6301)
    let body_new = bs_make_body(BS_D_BODY, 7301)
    let compat_same    = bs_make_compat(BS_D_BODY, BS_COMPAT_SAME, 8301)
    let compat_diff    = bs_make_compat(BS_D_BODY, BS_COMPAT_DIFF, 8302)
    let compat_radical = bs_make_compat(BS_D_BODY, BS_COMPAT_RADICAL, 8303)
    let phi_same    = bs_phi_embodied_after(brain, body_new, compat_same,    BS_D_BRAIN, BS_N_STEPS, 9301)
    let phi_diff    = bs_phi_embodied_after(brain, body_new, compat_diff,    BS_D_BRAIN, BS_N_STEPS, 9301)
    let phi_radical = bs_phi_embodied_after(brain, body_new, compat_radical, BS_D_BRAIN, BS_N_STEPS, 9301)
    println("  [T4] phi_embodied same    = " + str(phi_same))
    println("        phi_embodied diff    = " + str(phi_diff))
    println("        phi_embodied radical = " + str(phi_radical))
    // Strict: same > radical (the endpoints of the scale).
    if phi_same <= phi_radical { return false }
    // Same should dominate diff too (weaker ordering — allow BS_EPS slack).
    if phi_same < phi_diff - BS_EPS { return false }
    // All non-negative.
    if phi_same < 0.0 { return false }
    if phi_diff < 0.0 { return false }
    if phi_radical < 0.0 { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Complete incompatibility (octopus body on human brain with
    // no nerve-map) leaves Φ_embodied at essentially 0 — no integration
    // ever forms. Compat vector is all zeros so the coupling term
    // contributes nothing; only noise remains, and noise-only MI
    // should be below a small threshold.
    let brain = bs_make_brain(BS_D_BRAIN, 6401)
    let body_octo = bs_make_body(BS_D_BODY, 7401)
    let compat_none = bs_make_compat(BS_D_BODY, BS_COMPAT_INCOMPAT, 8401)
    let phi_after = bs_phi_embodied_after(brain, body_octo, compat_none, BS_D_BRAIN, BS_N_STEPS, 9401)
    println("  [T5] phi_embodied (incompatible, octopus body) = " + str(phi_after))
    // With zero compat and independent noise per step, MI across
    // brain-body channels should be well below 0.15 nats.
    if phi_after < 0.0 { return false }
    if phi_after > 0.15 { return false }
    // Sanity: verify compat vector is actually zero throughout.
    let mut i = 0
    while i < BS_D_BODY {
        if compat_none[i] > BS_EPS { return false }
        i = i + 1
    }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[body_swap_phi] P76 — brain transplant / body swap Phi preservation")
    println("  d_brain=8, d_body=8, N=16 steps")
    println("  question: which Phi survives a body swap?")
    println("  answer: Phi_brain intrinsic (T1); Phi_embodied drops then recovers (T2,T3)")
    println("          morphology mismatch slows recovery (T4); incompat = zero (T5)")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  phi_brain swap-invariant (intrinsic)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  phi_embodied drops at swap, rebuilds over time") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  same-type swap recovers phi_embodied") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  morphology mismatch slows recovery") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  complete incompatibility leaves phi_embodied at zero") } else { println("T5 FAIL") }

    println("")

    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[body_swap_phi] 5/5 PASS — P76 DONE")
    } else {
        println("[body_swap_phi] SOME FAILED")
    }
}

main()
