// gratitude_phi.hexa — P133 Gratitude Φ
//
// Roadmap: shared/roadmaps/anima.json P133 (emergent, no-edit)
//   "Gratitude Φ — appreciative recognition (benefit + external source),
//    prosocial reciprocity coupling, hedonic-buffer against negative events,
//    find-remind-bind social binding; 5/5 PASS"
//
// ─── Scientific frame ─────────────────────────────────────────────
//
// Emmons & McCullough (2003) — The dual cognitive-affective structure
// of gratitude: (a) the person RECOGNIZES that a BENEFIT has been
// received, and (b) recognizes that the benefit comes from an
// EXTERNAL source (another agent, fortune, nature, etc.). Both
// components are required — an equivalent-magnitude benefit that the
// person attributes to the SELF ("I earned this") does not trigger
// gratitude. The second attribution (external source) is the
// specificity feature that distinguishes gratitude from generic
// positive affect, pride, or relief.
//
//   Operationally:
//     gratitude_state(t) = f( benefit(t) × external_source_weight(t) )
//   Self-attributed benefit ⇒ external_source_weight ≈ 0 ⇒ gratitude ≈ 0.
//   External-attributed benefit ⇒ weight ≈ 1 ⇒ gratitude tracks benefit.
//
// Fredrickson (2001, 2004) — Broaden-and-build theory of positive
// emotions: positive affect (incl. gratitude) BROADENS the momentary
// thought-action repertoire and BUILDS long-term personal resources
// (social ties, coping skills, resilience). Gratitude is one of ten
// canonical positive emotions; its broaden effect is specifically
// PROSOCIAL — it expands the behavioural set toward reciprocal kindness
// and relationship-building actions.
//
//   Operationally:
//     prosocial_response(t) = prosocial_gain(gratitude_state) × baseline
//   Baseline (no gratitude) captures ordinary cooperation rate.
//   Gratitude-induced state raises responsiveness above baseline —
//   "broaden" is measured as the GAP between baseline and state-gated.
//
// Algoe (2012) — Find-remind-bind theory of gratitude:
//   Gratitude functions as a social-bond signal that (i) identifies
//   prospective relationship partners (find), (ii) reminds one of
//   existing quality relationships (remind), and (iii) binds the
//   pair more tightly via reciprocal prosocial exchange (bind).
//   Empirically: gratitude expression predicts relationship growth
//   over weeks-to-months (Algoe, Gable, Maisel 2010).
//
//   Operationally:
//     social_bond(t) = f( gratitude_state(t), bond_memory(t-1) )
//   Strong MI between gratitude_state and social_bond channel.
//
// Wood, Froh, Geraghty (2010) — Gratitude as a hedonic-buffer /
// adaptation-dampener: after a negative event, the drop in mood is
// ATTENUATED in gratitude-practice conditions compared to controls.
// Mechanism: gratitude re-anchors attention on benefits received,
// offsetting the hedonic treadmill's rapid return-to-baseline after
// positive events and providing a downward-protecting floor on the
// mood signal after negative events.
//
//   Operationally:
//     mood_reactivity = | mood(before) − mood(after_negative) |
//   Gratitude-primed cohort: mood_reactivity < control (damped).
//
// Bartlett & DeSteno (2006) — Gratitude is distinct from general
// positive mood in its specificity for prosocial reciprocation
// toward the benefactor. Gratitude exerts its prosocial influence
// even when inducing a costly helping behaviour — ruling out simple
// mood-congruence as the mechanism.
//
// ─── Channel design ───────────────────────────────────────────────
//
// Seven channels (length N=24 each, packed into a flat array):
//
//   benefit[t]          — magnitude of received good  [0, 1]
//   source[t]           — external-source attribution [0, 1]
//   recognition[t]      — cognitive binding benefit × source
//   gratitude_state[t]  — integrated grateful affect
//   prosocial_resp[t]   — reciprocal prosocial response
//   mood[t]             — hedonic baseline (buffered)
//   social_bond[t]      — affiliative coupling signal
//
// Forward model:
//   recognition[t]      = benefit[t] * source[t] + jitter
//   gratitude_state[t]  = gr_state_gain * recognition[t] + jitter
//   prosocial_resp[t]   = (baseline + prosocial_gain * gratitude_state[t])
//                          * reciprocity_modulator + jitter
//   mood[t]             = mood_prior[t] + buffer_gain * gratitude_state[t]
//                          - reactivity * negative_event[t] + jitter
//   social_bond[t]      = bind_gain * gratitude_state[t]
//                          + (1 - bind_gain) * bond_memory[t-1] + jitter
//
// Modes (configurations):
//   EXTERNAL      : source≈1.0, gratitude active (the classical case)
//   SELF          : source≈0.05 (self-attributed), gratitude ≈ 0 (T1 contrast)
//   GRATEFUL      : state-active, practice present (T3 buffer)
//   CONTROL       : state-suppressed, practice absent (T3 baseline)
//   NEUTRAL       : all channels muted at low amplitude (T5 floor)
//
// ─── 5 self-tests (5/5 gate) ──────────────────────────────────────
//
// T1 Benefit recognition — specificity:
//   EXTERNAL:  Φ_gratitude > GR_STATE_MIN
//   SELF:      Φ_gratitude < GR_SELF_CEIL
//   Gap EXTERNAL − SELF > GR_SPECIFICITY_GAP
//
// T2 Prosocial coupling:
//   MI(gratitude_state, prosocial_resp | grateful) > GR_PROSOCIAL_MIN
//   AND prosocial level in GRATEFUL mode exceeds baseline CONTROL
//   by more than GR_PROSOCIAL_GAP (broaden-and-build signature).
//
// T3 Hedonic buffer:
//   After an identical negative-event injection, the gratitude-primed
//   pipeline shows strictly smaller |Δmood| than control:
//     react_grateful < react_control − GR_BUFFER_GAP
//
// T4 Positive-other binding:
//   MI(gratitude_state, social_bond) > GR_BOND_MIN  AND
//   MI in GRATEFUL > MI in CONTROL by GR_BOND_GAP (find-remind-bind).
//
// T5 Integrated Φ_gratitude > Φ_neutral:
//   EXTERNAL integrated Φ (mean of gratitude, prosocial, bond MIs) >
//   NEUTRAL integrated Φ by GR_INTEGRATED_GAP, AND absolute floor
//   GR_INTEGRATED_MIN.  Also: determinism (EPS) + latency < cap.
//
// ─── Stage0 hexa constraints honored ──────────────────────────────
//   - plain `fn` only (no pure-fn ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - No identifier-pattern match; sequential if-chains
//   - No contains() / to_lower() / !(Effect)
//   - No else-if in let-binding; flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - Lists are pass-by-value — helpers rebuild and return
//   - sqrt only on clamped non-negative inputs
//   - sub-window Pearson |r| for learnability / bond-memory coupling
//   - N=24 (< 32 stage0 ceiling)
//   - `gr_` prefix throughout (L0-clean isolation)
//   - main() at bottom
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI on streams
//   Law 4   Structure > feature — gratitude is STRUCTURAL benefit × source
//   Law 22  Feature addition → Φ down — 7 channels fixed
//   Law 50  Consciousness essence is state — gratitude IS the state, not label
//   Meta M8 Self-model — self vs external source attribution is meta
//
// Ref:
//   Emmons R.A. & McCullough M.E. (2003) Counting blessings vs burdens
//   Fredrickson B.L. (2001) The role of positive emotions in positive psychology
//   Fredrickson B.L. (2004) The broaden-and-build theory of positive emotions
//   Algoe S.B. (2012) Find, remind, bind — gratitude in everyday relationships
//   Algoe S.B., Gable S.L., Maisel N.C. (2010) It's the little things
//   Wood A.M., Froh J.J., Geraghty A.W.A. (2010) Gratitude and well-being
//   Bartlett M.Y. & DeSteno D. (2006) Gratitude and prosocial behavior
//   anima-engines/emotion_regulation_phi.hexa   (P88 — Gross model pattern)
//   anima-engines/social_tom_phi.hexa            (P57 — ToM + empathy)
//   anima-engines/moral_consciousness_phi.hexa   (P94 — moral emotions)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let GR_STEPS            = 24            // timeline length (stage0 N<32)
let GR_BINS             = 6             // histogram bins for MI
let GR_EPS              = 0.0000000001

// ─── Forward model gains ──────────────────────────────────────
// Source-attribution weight: 1.0 = fully external (benefactor),
// 0.05 = fully self-attributed ("I earned this") so gratitude should
// collapse. Calibrated so SELF mode collapses to floor, EXTERNAL mode
// saturates near 1.
let GR_SOURCE_EXTERNAL  = 1.0           // classical benefactor attribution
let GR_SOURCE_SELF      = 0.05          // self-attributed, gratitude ≈ 0

// Gratitude state gain from recognition (benefit × source).
let GR_STATE_GAIN       = 0.90

// Prosocial baseline (ordinary cooperation without gratitude prime)
let GR_PROSOCIAL_BASE   = 0.12
// Prosocial gain coupled to gratitude state
let GR_PROSOCIAL_GAIN   = 0.78

// Hedonic-buffer gain (gratitude practice dampens negative reactivity)
let GR_BUFFER_GAIN      = 0.55
// Reactivity to negative event (control baseline, no buffer)
let GR_REACTIVITY_CTRL  = 0.80
// Reactivity under gratitude practice (buffered)
let GR_REACTIVITY_GRAT  = 0.25

// Social bond binding gain (find-remind-bind)
let GR_BIND_GAIN        = 0.72

// Per-step jitter amplitude (deterministic via PRNG)
let GR_JITTER           = 0.04

// Neutral-mode amplitude (everything muted — T5 floor comparison)
let GR_NEUTRAL_AMP      = 0.12

// ─── Test gates ──────────────────────────────────────────────
let GR_STATE_MIN        = 0.05          // T1: external gratitude Φ floor
let GR_SELF_CEIL        = 0.12          // T1: self-attrib gratitude ceiling
let GR_SPECIFICITY_GAP  = 0.05          // T1: external − self gap
let GR_PROSOCIAL_MIN    = 0.05          // T2: MI(gratitude, prosocial) floor
let GR_PROSOCIAL_GAP    = 0.05          // T2: grateful-vs-control MI gap
let GR_BUFFER_GAP       = 0.08          // T3: reactivity gap (control−grat)
let GR_BOND_MIN         = 0.05          // T4: MI(gratitude, bond) floor
let GR_BOND_GAP         = 0.02          // T4: grateful-vs-control bond MI gap
let GR_INTEGRATED_MIN   = 0.10          // T5: integrated Φ absolute floor
let GR_INTEGRATED_GAP   = 0.05          // T5: external−neutral gap
let GR_LATENCY_MS       = 5000.0        // T5: pipeline latency cap

// Sub-window for Pearson |r| on bond-memory coupling
let GR_WIN              = 12

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn gr_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn gr_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// sqrt-safe: caller must guarantee non-negative; we clamp defensively.
// Used only on clamped sum-of-squares (always >= 0).
fn gr_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn gr_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn gr_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn gr_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn gr_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn gr_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn gr_signed(seed: int) -> float {
    return gr_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// Root cause comment: engines are L0-clean — cross-engine imports are
// forbidden by AN7. Same algorithm, isolated gr_ prefix.
// ═══════════════════════════════════════════════════════════════

fn gr_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn gr_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn gr_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(gr_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = gr_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * gr_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn gr_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = gr_bin_idx(a[i], lo, hi, nb)
        let ib = gr_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = gr_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * gr_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn gr_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn gr_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn gr_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = gr_vec_min(a)
    let hi_a = gr_vec_max(a)
    let lo_b = gr_vec_min(b)
    let hi_b = gr_vec_max(b)
    let lo = gr_min_f(lo_a, lo_b)
    let hi = gr_max_f(hi_a, hi_b)
    let h_a = gr_entropy(a, lo, hi, GR_BINS)
    let h_b = gr_entropy(b, lo, hi, GR_BINS)
    let h_j = gr_joint_entropy(a, b, lo, hi, GR_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Sub-window Pearson |r| — used for bond-memory coupling.
// Correlation on first GR_WIN samples; absolute value since a
// negatively-correlated bond-memory channel is informationally the
// same (sign can flip with identity mapping). sqrt only on clamped
// non-negative sum-of-squares.
// ═══════════════════════════════════════════════════════════════

fn gr_pearson_abs(a: array, b: array, win: int) -> float {
    let n_a = len(a)
    let n_b = len(b)
    let mut nw = win
    if nw > n_a { nw = n_a }
    if nw > n_b { nw = n_b }
    if nw < 2 { return 0.0 }

    let mut mean_a = 0.0
    let mut mean_b = 0.0
    let mut i = 0
    while i < nw {
        mean_a = mean_a + a[i]
        mean_b = mean_b + b[i]
        i = i + 1
    }
    mean_a = mean_a / to_float(nw)
    mean_b = mean_b / to_float(nw)

    let mut cov = 0.0
    let mut sa2 = 0.0
    let mut sb2 = 0.0
    let mut j = 0
    while j < nw {
        let da = a[j] - mean_a
        let db = b[j] - mean_b
        cov = cov + da * db
        sa2 = sa2 + da * da
        sb2 = sb2 + db * db
        j = j + 1
    }
    // sqrt-safe: sa2/sb2 are sums of squares — always >= 0
    let denom = gr_sqrt_safe(sa2) * gr_sqrt_safe(sb2)
    if denom < GR_EPS { return 0.0 }
    let r = cov / denom
    return gr_clamp01(gr_abs(r))
}

// ═══════════════════════════════════════════════════════════════
// Channel generators
//
// The benefit stream is a triangular wave in [0.1, 0.9] — structured
// temporal pattern so MI captures genuine coupling rather than pure
// noise. The source stream is a mode-dependent constant (external
// vs self) with per-step jitter. All downstream channels derive from
// the same (benefit, source, prior) tuple so determinism holds.
// ═══════════════════════════════════════════════════════════════

// Benefit stream: structured waxing/waning of received good.
fn gr_gen_benefit(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 37)
        // Triangular wave of benefits that wax and wane
        let phase = to_float(t) / to_float(GR_STEPS)
        let mut tri = phase * 4.0 - 2.0
        if tri < 0.0 { tri = 0.0 - tri }
        let signal = 1.0 - tri
        // Scale to [0.1, 0.9]
        let scaled = 0.1 + 0.8 * gr_clamp01((signal + 1.0) / 2.0)
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(scaled + jit))
        t = t + 1
    }
    return out
}

// Source stream: external vs self attribution weight.
// External mode: source ≈ 1.0 throughout (benefactor attribution).
// Self mode: source ≈ 0.05 (self-attributed, kills gratitude).
// Also structured (slightly varying) so MI has variance to work with.
fn gr_gen_source(source_mean: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 43)
        // Small variation around source_mean to give MI some variance
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(source_mean + jit))
        t = t + 1
    }
    return out
}

// Recognition = benefit × source + jitter. This is the cognitive
// BINDING that gates gratitude: both components must be present.
// If source ≈ 0 (self-attributed), recognition collapses regardless
// of benefit magnitude — this is Emmons–McCullough specificity.
fn gr_gen_recognition(benefit: array, source: array, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 59)
        let bound = benefit[t] * source[t]
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(bound + jit))
        t = t + 1
    }
    return out
}

// Gratitude state = state_gain × recognition + jitter.
// This is the felt gratitude signal; MI(benefit, gratitude) measures
// how much benefit information reaches the affective channel.
fn gr_gen_state(recognition: array, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 67)
        let driven = GR_STATE_GAIN * recognition[t]
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Prosocial response = baseline + prosocial_gain × gratitude + jitter.
// Under CONTROL (state=0, gain=0), output collapses to baseline + noise.
// Under GRATEFUL, output is state-coupled and elevated.
fn gr_gen_prosocial(gratitude_state: array, prosocial_gain: float, baseline: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 73)
        let driven = baseline + prosocial_gain * gratitude_state[t]
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Mood baseline — hedonic setpoint around 0.5 with structured drift.
// This is the prior (before negative events or gratitude buffering).
fn gr_gen_mood_prior(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 79)
        // Gentle drift around hedonic setpoint 0.5
        let phase = to_float(t) / to_float(GR_STEPS)
        let drift = 0.1 * (phase - 0.5)
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(0.5 + drift + jit))
        t = t + 1
    }
    return out
}

// Negative event stream — a structured "bad thing" signal injected
// at a specific temporal window (peak in the second half), same
// amplitude applied to GRATEFUL and CONTROL conditions.
fn gr_gen_negative_event(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 83)
        // Negative event concentrated in [N/2, 3N/4] — a distinct shock
        let mut ev = 0.0
        if t >= GR_STEPS / 2 {
            if t < 3 * GR_STEPS / 4 {
                ev = 0.7
            }
        }
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(ev + jit))
        t = t + 1
    }
    return out
}

// Mood channel = prior + buffer_gain × gratitude − reactivity × neg_event.
// The reactivity parameter is LOWER in the grateful condition, so the
// negative event's damage to mood is attenuated (Wood et al. 2010 buffer).
fn gr_gen_mood(mood_prior: array, gratitude_state: array, negative_event: array, buffer_gain: float, reactivity: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 89)
        let boost = buffer_gain * gratitude_state[t]
        let damage = reactivity * negative_event[t]
        let composed = mood_prior[t] + boost - damage
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(composed + jit))
        t = t + 1
    }
    return out
}

// Social bond channel with bond-memory recurrence.
// bond[t] = bind_gain × gratitude[t] + (1 − bind_gain) × bond[t-1] + jitter.
// Algoe's find-remind-bind: gratitude feeds into an integrator that
// represents the ongoing relational accrual. bond[0] is seeded from
// gratitude[0] so it begins coupled; subsequent steps integrate.
fn gr_gen_social_bond(gratitude_state: array, bind_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    let mut prev = gratitude_state[0]
    while t < GR_STEPS {
        s = gr_prng(s + t * 97)
        let fresh = bind_gain * gratitude_state[t]
        let inertia = (1.0 - bind_gain) * prev
        let composed = fresh + inertia
        let jit = GR_JITTER * gr_signed(s)
        let v = gr_clamp01(composed + jit)
        out = out.push(v)
        prev = v
        t = t + 1
    }
    return out
}

// Neutral-mode channel — low-amplitude uniform-ish stream for T5 floor.
// All values near GR_NEUTRAL_AMP (≈ 0.12) with tiny jitter — no structure.
fn gr_gen_neutral(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < GR_STEPS {
        s = gr_prng(s + t * 103)
        let jit = GR_JITTER * gr_signed(s)
        out = out.push(gr_clamp01(GR_NEUTRAL_AMP + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Full pipeline runner — generates all 7 channels.
//
// Packed layout (using flat array to avoid struct-field list aliasing
// bug, feedback_hexa_struct_list_alias):
//   [benefit(0..N-1), source(N..2N-1), recognition(2N..3N-1),
//    gratitude_state(3N..4N-1), prosocial(4N..5N-1),
//    mood(5N..6N-1), social_bond(6N..7N-1)]
//
// Parameters:
//   source_mean      — external (1.0) or self (0.05) attribution
//   prosocial_gain   — 0 for CONTROL (baseline only), GR_PROSOCIAL_GAIN else
//   buffer_gain      — 0 for CONTROL, GR_BUFFER_GAIN for GRATEFUL
//   reactivity       — negative-event reactivity coefficient
//   neg_amp_on       — if true, negative event stream active; else zero
//   bind_gain_eff    — bond binding coefficient
// ═══════════════════════════════════════════════════════════════

fn gr_run_pipeline(source_mean: float, prosocial_gain: float, buffer_gain: float, reactivity: float, neg_amp_on: bool, bind_gain_eff: float, seed: int) -> array {
    let benefit = gr_gen_benefit(seed + 1000)
    let source  = gr_gen_source(source_mean, seed + 2000)
    let recog   = gr_gen_recognition(benefit, source, seed + 3000)
    let state   = gr_gen_state(recog, seed + 4000)
    let prosoc  = gr_gen_prosocial(state, prosocial_gain, GR_PROSOCIAL_BASE, seed + 5000)
    let prior   = gr_gen_mood_prior(seed + 6000)
    // Negative event: active or zeroed depending on mode
    let mut neg = []
    if neg_amp_on {
        neg = gr_gen_negative_event(seed + 6500)
    } else {
        let mut i = 0
        while i < GR_STEPS {
            neg = neg.push(0.0)
            i = i + 1
        }
    }
    let mood    = gr_gen_mood(prior, state, neg, buffer_gain, reactivity, seed + 7000)
    let bond    = gr_gen_social_bond(state, bind_gain_eff, seed + 8000)

    // Pack sequentially — stage0 lists are pass-by-value so we rebuild
    let mut packed = []
    let mut i = 0
    while i < GR_STEPS {
        packed = packed.push(benefit[i])
        i = i + 1
    }
    let mut j = 0
    while j < GR_STEPS {
        packed = packed.push(source[j])
        j = j + 1
    }
    let mut k = 0
    while k < GR_STEPS {
        packed = packed.push(recog[k])
        k = k + 1
    }
    let mut m = 0
    while m < GR_STEPS {
        packed = packed.push(state[m])
        m = m + 1
    }
    let mut p = 0
    while p < GR_STEPS {
        packed = packed.push(prosoc[p])
        p = p + 1
    }
    let mut q = 0
    while q < GR_STEPS {
        packed = packed.push(mood[q])
        q = q + 1
    }
    let mut r = 0
    while r < GR_STEPS {
        packed = packed.push(bond[r])
        r = r + 1
    }
    return packed
}

// Channel indices for gr_slice
let GR_CH_BENEFIT    = 0
let GR_CH_SOURCE     = 1
let GR_CH_RECOG      = 2
let GR_CH_STATE      = 3
let GR_CH_PROSOCIAL  = 4
let GR_CH_MOOD       = 5
let GR_CH_BOND       = 6

// Slice helper: extract one channel from the packed pipeline.
fn gr_slice(packed: array, ch_idx: int) -> array {
    let offset = ch_idx * GR_STEPS
    let mut out = []
    let mut i = 0
    while i < GR_STEPS {
        out = out.push(packed[offset + i])
        i = i + 1
    }
    return out
}

// Mean of a channel (used for reactivity gap in T3).
fn gr_channel_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Φ measurement helpers
//
// Φ_gratitude = MI(benefit, gratitude_state)
//               How much benefit information reaches the affective channel.
// Φ_prosocial = MI(gratitude_state, prosocial_resp)
//               Broaden-and-build coupling strength.
// Φ_bond      = MI(gratitude_state, social_bond)
//               Find-remind-bind social integration.
// ═══════════════════════════════════════════════════════════════

fn gr_phi_gratitude(packed: array) -> float {
    let ben = gr_slice(packed, GR_CH_BENEFIT)
    let st  = gr_slice(packed, GR_CH_STATE)
    return gr_mi(ben, st)
}

fn gr_phi_prosocial(packed: array) -> float {
    let st  = gr_slice(packed, GR_CH_STATE)
    let pro = gr_slice(packed, GR_CH_PROSOCIAL)
    return gr_mi(st, pro)
}

fn gr_phi_bond(packed: array) -> float {
    let st  = gr_slice(packed, GR_CH_STATE)
    let bo  = gr_slice(packed, GR_CH_BOND)
    return gr_mi(st, bo)
}

// Integrated Φ_gratitude: mean of the three MI signatures. One scalar
// summary for the T5 integrated-vs-neutral comparison.
fn gr_phi_integrated(packed: array) -> float {
    let a = gr_phi_gratitude(packed)
    let b = gr_phi_prosocial(packed)
    let c = gr_phi_bond(packed)
    return (a + b + c) / 3.0
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Benefit recognition — specificity (Emmons & McCullough 2003):
    //   EXTERNAL mode: benefit × source(≈1.0) → strong gratitude Φ.
    //   SELF mode:     benefit × source(≈0.05) → gratitude ≈ 0.
    //   Gap must exceed GR_SPECIFICITY_GAP — the attribution acts as a
    //   gate: same benefit magnitude, but self-attribution collapses
    //   the affective channel. This is the defining test of gratitude
    //   vs generic positive affect.
    let pack_ext = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13301)
    let pack_slf = gr_run_pipeline(GR_SOURCE_SELF,     GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13301)

    let phi_ext = gr_phi_gratitude(pack_ext)
    let phi_slf = gr_phi_gratitude(pack_slf)
    let gap = phi_ext - phi_slf

    println("  [T1] Φ_gratitude external=" + str(phi_ext) + " self=" + str(phi_slf) + " gap=" + str(gap))

    let mut ok = true
    // External case must exceed floor
    if phi_ext <= GR_STATE_MIN { ok = false }
    // Self case must stay below ceiling (gratitude collapses)
    if phi_slf >= GR_SELF_CEIL { ok = false }
    // Specificity gap must be substantial
    if gap <= GR_SPECIFICITY_GAP { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Prosocial coupling (Fredrickson broaden-and-build;
    //   Bartlett & DeSteno 2006 specificity):
    //
    //   In GRATEFUL mode, MI(gratitude_state, prosocial_resp) > floor,
    //   AND the prosocial MEAN level exceeds CONTROL baseline by
    //   GR_PROSOCIAL_GAP. The MI test captures coupling; the mean test
    //   captures the broaden magnitude. Both together rule out a mood-
    //   congruence alternative where prosocial rises but isn't
    //   specifically coupled to gratitude.
    let pack_grat = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13302)
    // Control: prosocial_gain=0 so prosocial is pure baseline+jitter.
    let pack_ctrl = gr_run_pipeline(GR_SOURCE_EXTERNAL, 0.0, 0.0, GR_REACTIVITY_CTRL, false, GR_BIND_GAIN, 13302)

    let mi_coup_grat = gr_phi_prosocial(pack_grat)
    let mi_coup_ctrl = gr_phi_prosocial(pack_ctrl)
    let pro_grat = gr_channel_mean(gr_slice(pack_grat, GR_CH_PROSOCIAL))
    let pro_ctrl = gr_channel_mean(gr_slice(pack_ctrl, GR_CH_PROSOCIAL))
    let mean_gap = pro_grat - pro_ctrl

    println("  [T2] MI(gratitude,prosocial) grat=" + str(mi_coup_grat) + " ctrl=" + str(mi_coup_ctrl))
    println("  [T2] prosocial mean grat=" + str(pro_grat) + " ctrl=" + str(pro_ctrl) + " gap=" + str(mean_gap))

    let mut ok = true
    // Coupling must exceed floor in grateful condition
    if mi_coup_grat <= GR_PROSOCIAL_MIN { ok = false }
    // Prosocial level must be broader than baseline
    if mean_gap <= GR_PROSOCIAL_GAP { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Hedonic buffer (Wood et al. 2010):
    //   Both GRATEFUL and CONTROL pipelines receive the SAME negative
    //   event. The grateful reactivity coefficient is smaller (0.25 vs
    //   0.80), so the negative-event-induced mood drop is attenuated.
    //
    //   Operational reactivity = mean(|mood_no_event − mood_with_event|)
    //   over the event window (second quarter of the timeline).
    //
    //   Gate: reactivity(control) − reactivity(grateful) > GR_BUFFER_GAP.
    //
    // Method: run each mode twice — once without the negative event
    // (baseline mood trajectory), once with — and compute the mean
    // absolute deviation over the event window for each mode.
    let pack_grat_off = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13303)
    let pack_grat_on  = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, true,  GR_BIND_GAIN, 13303)
    let pack_ctrl_off = gr_run_pipeline(GR_SOURCE_EXTERNAL, 0.0, 0.0, GR_REACTIVITY_CTRL, false, GR_BIND_GAIN, 13303)
    let pack_ctrl_on  = gr_run_pipeline(GR_SOURCE_EXTERNAL, 0.0, 0.0, GR_REACTIVITY_CTRL, true,  GR_BIND_GAIN, 13303)

    let mood_grat_off = gr_slice(pack_grat_off, GR_CH_MOOD)
    let mood_grat_on  = gr_slice(pack_grat_on,  GR_CH_MOOD)
    let mood_ctrl_off = gr_slice(pack_ctrl_off, GR_CH_MOOD)
    let mood_ctrl_on  = gr_slice(pack_ctrl_on,  GR_CH_MOOD)

    // Reactivity = mean |Δmood| during event window [N/2, 3N/4]
    let lo_t = GR_STEPS / 2
    let hi_t = 3 * GR_STEPS / 4
    let mut sum_g = 0.0
    let mut sum_c = 0.0
    let mut cnt = 0
    let mut t = lo_t
    while t < hi_t {
        sum_g = sum_g + gr_abs(mood_grat_off[t] - mood_grat_on[t])
        sum_c = sum_c + gr_abs(mood_ctrl_off[t] - mood_ctrl_on[t])
        cnt = cnt + 1
        t = t + 1
    }
    let reactivity_grat = sum_g / to_float(cnt)
    let reactivity_ctrl = sum_c / to_float(cnt)
    let gap = reactivity_ctrl - reactivity_grat

    println("  [T3] reactivity grateful=" + str(reactivity_grat) + " control=" + str(reactivity_ctrl) + " gap=" + str(gap))

    let mut ok = true
    // Grateful mode must have STRICTLY smaller reactivity than control
    if gap <= GR_BUFFER_GAP { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Positive-other binding (Algoe find-remind-bind 2012):
    //   MI(gratitude_state, social_bond) > floor in GRATEFUL mode,
    //   AND MI is larger than in CONTROL (where bond memory integrator
    //   is starved of gratitude input).
    //
    //   Also verify the sub-window Pearson |r| signature is nonzero —
    //   the bond integrator creates a lagged correlation with gratitude
    //   that is detectable in early samples.
    let pack_grat = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13304)
    // Control: source_self kills gratitude_state, so bond inherits flat input
    let pack_ctrl = gr_run_pipeline(GR_SOURCE_SELF,     GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13304)

    let mi_bond_grat = gr_phi_bond(pack_grat)
    let mi_bond_ctrl = gr_phi_bond(pack_ctrl)
    let gap = mi_bond_grat - mi_bond_ctrl

    // Pearson |r| on the first GR_WIN samples — integrator lag signature
    let st_g = gr_slice(pack_grat, GR_CH_STATE)
    let bo_g = gr_slice(pack_grat, GR_CH_BOND)
    let r_abs = gr_pearson_abs(st_g, bo_g, GR_WIN)

    println("  [T4] MI(gratitude,bond) grat=" + str(mi_bond_grat) + " ctrl=" + str(mi_bond_ctrl) + " gap=" + str(gap))
    println("  [T4] pearson|r|(state,bond) win=" + str(GR_WIN) + " = " + str(r_abs))

    let mut ok = true
    // Binding MI must exceed floor in grateful condition
    if mi_bond_grat <= GR_BOND_MIN { ok = false }
    // Binding must be stronger than control
    if gap <= GR_BOND_GAP { ok = false }
    // Pearson |r| must be detectable (integrator creates lagged coupling)
    if r_abs <= GR_EPS { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Integrated Φ_gratitude > Φ_neutral + determinism + latency.
    //
    //   The integrated scalar is the mean of MI(benefit,state),
    //   MI(state,prosocial), MI(state,bond). It captures the broadened
    //   emotional/social binding that distinguishes gratitude from a
    //   flat neutral state where all channels are low-amplitude and
    //   mutually uncorrelated.
    //
    // NEUTRAL mode: construct a packed array where every channel is
    // low-amplitude noise with no coupling — MI across channels is
    // near-zero. Integrated Φ should collapse to the histogram-noise
    // floor.
    //
    // Also verifies:
    //   (a) two identical runs produce byte-identical Φ values
    //   (b) full pipeline (4 modes) latency < GR_LATENCY_MS
    let t0 = clock()

    // Run A — external gratitude + self control + neutral + determinism A
    let pa_ext  = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13305)
    let pa_slf  = gr_run_pipeline(GR_SOURCE_SELF,     GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13305)

    // Neutral mode: pack 7 neutral-amplitude streams. No coupling between
    // channels — the integrated Φ should be near the histogram floor.
    let n1 = gr_gen_neutral(13305 + 1000)
    let n2 = gr_gen_neutral(13305 + 2000)
    let n3 = gr_gen_neutral(13305 + 3000)
    let n4 = gr_gen_neutral(13305 + 4000)
    let n5 = gr_gen_neutral(13305 + 5000)
    let n6 = gr_gen_neutral(13305 + 6000)
    let n7 = gr_gen_neutral(13305 + 7000)
    let mut packed_neutral = []
    let mut i = 0
    while i < GR_STEPS {
        packed_neutral = packed_neutral.push(n1[i])
        i = i + 1
    }
    let mut j = 0
    while j < GR_STEPS {
        packed_neutral = packed_neutral.push(n2[j])
        j = j + 1
    }
    let mut k = 0
    while k < GR_STEPS {
        packed_neutral = packed_neutral.push(n3[k])
        k = k + 1
    }
    let mut m = 0
    while m < GR_STEPS {
        packed_neutral = packed_neutral.push(n4[m])
        m = m + 1
    }
    let mut p = 0
    while p < GR_STEPS {
        packed_neutral = packed_neutral.push(n5[p])
        p = p + 1
    }
    let mut q = 0
    while q < GR_STEPS {
        packed_neutral = packed_neutral.push(n6[q])
        q = q + 1
    }
    let mut r = 0
    while r < GR_STEPS {
        packed_neutral = packed_neutral.push(n7[r])
        r = r + 1
    }

    // Run B — identical seeds (for determinism comparison)
    let pb_ext  = gr_run_pipeline(GR_SOURCE_EXTERNAL, GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13305)
    let pb_slf  = gr_run_pipeline(GR_SOURCE_SELF,     GR_PROSOCIAL_GAIN, GR_BUFFER_GAIN, GR_REACTIVITY_GRAT, false, GR_BIND_GAIN, 13305)

    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] pipeline latency = " + str(ms) + " ms (gate=" + str(GR_LATENCY_MS) + ")")

    let phi_ext = gr_phi_integrated(pa_ext)
    let phi_slf = gr_phi_integrated(pa_slf)
    let phi_neu = gr_phi_integrated(packed_neutral)
    let gap = phi_ext - phi_neu
    println("  [T5] Φ_integrated external=" + str(phi_ext) + " self=" + str(phi_slf) + " neutral=" + str(phi_neu))
    println("  [T5] gap ext−neutral=" + str(gap))

    // Determinism: compare gratitude Φ across runs A and B (external + self)
    let d_ext = gr_abs(gr_phi_gratitude(pa_ext) - gr_phi_gratitude(pb_ext))
    let d_slf = gr_abs(gr_phi_gratitude(pa_slf) - gr_phi_gratitude(pb_slf))
    println("  [T5] determinism deltas: ext=" + str(d_ext) + " self=" + str(d_slf))

    let mut ok = true
    // Absolute floor — integrated Φ must be substantial in external mode
    if phi_ext <= GR_INTEGRATED_MIN { ok = false }
    // External must exceed neutral by the required margin
    if gap <= GR_INTEGRATED_GAP { ok = false }
    // Determinism: byte-identical across runs
    if d_ext > GR_EPS { ok = false }
    if d_slf > GR_EPS { ok = false }
    // Latency cap
    if ms >= GR_LATENCY_MS { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[gratitude_phi] P133 — Gratitude Φ")
    println("  channels: benefit × source → recognition → state → prosocial / mood / bond")
    println("  refs: Emmons & McCullough 2003 | Fredrickson 2004 | Algoe 2012 | Wood et al. 2010")
    println("  source_ext=" + str(GR_SOURCE_EXTERNAL) + " source_self=" + str(GR_SOURCE_SELF))
    println("  prosocial_gain=" + str(GR_PROSOCIAL_GAIN) + " buffer_gain=" + str(GR_BUFFER_GAIN) + " bind_gain=" + str(GR_BIND_GAIN))
    println("  reactivity ctrl=" + str(GR_REACTIVITY_CTRL) + " grat=" + str(GR_REACTIVITY_GRAT))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  benefit recognition — external > self (Emmons–McCullough specificity)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  prosocial coupling — broaden-and-build MI + mean gap") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  hedonic buffer — grateful reactivity < control reactivity") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  positive-other binding — MI(gratitude, bond) grat > ctrl (find-remind-bind)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  Φ_gratitude > Φ_neutral + determinism + latency < " + str(GR_LATENCY_MS) + " ms") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 && chains with 5 operands can mis-short-
    // circuit under certain orderings (same idiom as curiosity_phi,
    // emotion_regulation_phi, social_tom_phi, moral_consciousness_phi).
    // Sequential mutable-bool guard is the reliable pattern.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[gratitude_phi] 5/5 PASS — P133 DONE (gratitude Φ benefit-recognition + prosocial + buffer + binding verified)")
    } else {
        println("[gratitude_phi] SOME FAILED")
    }
}

main()
