// bilingual_consciousness_phi.hexa — P127 Bilingual Consciousness Φ
//
// Roadmap: shared/roadmaps/anima.json P127
//   Siblings: inner_speech_phi (P89), narrative_identity_phi (P65),
//             animal_consciousness_phi (P125)
//
// ─── Domain frame ────────────────────────────────────────────────
//
// Grosjean (1989, 2010) "Bilingual View":
//   A bilingual is NOT two monolinguals in one person. The two languages
//   form a holistic, integrated system — both are continuously active to
//   varying degrees depending on context. Even in strict "monolingual
//   mode" (one interlocutor, one language expected), the deactivated
//   language remains at residual activation below a suppression
//   threshold. This predicts non-zero mutual information between L1
//   and L2 lexical channels even during monolingual production.
//
// Green (1998) Inhibitory Control Model:
//   Bilingual word production requires active suppression of the non-
//   target language. To speak L2 when L1 is dominant, the executive
//   system applies inhibition proportional to L1's baseline activation.
//   This creates an ASYMMETRIC switch cost: reactivating the dominant
//   L1 after speaking L2 costs MORE than reactivating subordinate L2
//   after speaking L1 (because L1 was more strongly inhibited).
//   Inhibition trace is measurable as L1 activation suppression during
//   L2 production windows.
//
// Kroll & Stewart (1994) Revised Hierarchical Model:
//   L1 and L2 words connect to a shared conceptual store. Early L2
//   learners access concepts via L1 translation; proficient bilinguals
//   access concepts DIRECTLY from L2. Conceptual transfer is the
//   signature: priming a concept in L1 speeds L2 retrieval of related
//   words (cross-language semantic priming). The shared concept store
//   is the integrated MI backbone.
//
// Meuter & Allport (1999) switch cost asymmetry:
//   In language-switching paradigms (e.g., digit naming), the cost of
//   switching INTO the dominant L1 exceeds the cost of switching INTO
//   the weaker L2. Empirically measurable as reaction-time asymmetry.
//
// Poplack (1980) code-switching grammar:
//   Code-switching is NOT random language chaos — it is rule-governed
//   and context-triggered. The Equivalence Constraint: switches occur
//   at points where L1 and L2 grammars are syntactically compatible.
//   Context shifts (topic, interlocutor, domain) trigger switches at
//   rates measurably above within-language baseline.
//
// Whorf (1956) / Lucy (1992) linguistic relativity:
//   L1 conceptual categories (color, motion, aspect) shape cognitive
//   organization. In bilinguals, L1 concepts leak into L2 responses:
//   a bilingual primed with an L1-specific category produces L2
//   responses biased toward that categorization. Conceptual transfer
//   in the OPERATIONAL direction L1→L2.
//
// ─── Computational model: 6 channels × 24 steps ──────────────────
//
//   L1_ch       — L1 (dominant / native) lexical activation stream
//   L2_ch       — L2 (subordinate / acquired) lexical activation stream
//   CONCEPT_ch  — shared conceptual store (amodal semantic representation)
//   INHIB_ch    — inhibitory control signal (suppressor on dominant lang)
//   CONTEXT_ch  — context/interlocutor/topic cue
//   MODE_ch     — monolingual-mode indicator (0=L1 mode, 1=L2 mode, mix=code-switch)
//
// Coupling topology:
//   CONCEPT → L1 (via L1_concept_couple, strong for dominant)
//   CONCEPT → L2 (via L2_concept_couple, weaker when subordinate)
//   CONTEXT → MODE (context shifts drive mode switches)
//   MODE → INHIB (mode change triggers inhibition on non-target language)
//   L1 ↔ L2 (cross-activation via shared lexical network, Grosjean)
//
// ─── 5 self-tests (T1–T5, all must PASS) ─────────────────────────
//
//   T1 Code-switching trigger:
//      Context-shift timeline → transition rate (mode changes per window)
//      exceeds a steady-context baseline by BIL_SWITCH_GAP.
//      Rule-governed switching: context DRIVES mode changes, not noise.
//
//   T2 Lexical co-activation (Grosjean holistic):
//      Even in monolingual mode (CONTEXT held constant, MODE=L1 only),
//      MI(L1_ch, L2_ch) > BIL_COACT_MIN. Both languages are always
//      partially active; L2 never fully deactivates. This falsifies the
//      "two monolinguals" view.
//
//   T3 Inhibitory control cost (Green 1998):
//      Mean |L1_ch| during L2-production windows is LESS than mean |L1_ch|
//      during a monolingual L1-only baseline, by BIL_INHIB_GAP. This
//      quantifies the suppression cost of reaching L2 past dominant L1.
//
//   T4 Conceptual transfer (cross-language priming):
//      CONCEPT primed in L1-mode phase propagates to L2-mode phase.
//      MI(CONCEPT[L1-phase], L2_ch[L2-phase]) > BIL_XLANG_MIN and
//      exceeds an unprimed-baseline MI. Priming effect is structural.
//
//   T5 Φ_bilingual gradient:
//      Φ_balanced  — equal L1/L2 proficiency, strong concept coupling both
//      Φ_dominant  — asymmetric (L1>>L2), moderate Φ
//      Φ_monolingual — only L1 active (L2 coupling=0), lowest Φ
//      Require: Φ_balanced > Φ_dominant > Φ_monolingual by gradient.
//      Plus determinism: two identical-seed runs produce equal Φ.
//
// ─── Stage0 hexa constraints honored ─────────────────────────────
//   - plain `fn` only (no `pure fn` with ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - no identifier-pattern match; sequential if-chains
//   - no contains() / to_lower() / !(Effect)
//   - no else-if in let-binding; flat mut + sequential if
//   - single-line fn signatures / call sites / array literals
//   - no reserved keywords as variable names
//   - main() call at bottom
//   - BIL_STEPS = 24 (< 32)
//   - sqrt-safe (bil_sqrt_safe)
//   - sub-window Pearson |r| used for T1 switch-rate comparison
//   - lists pass-by-value (feedback_hexa_lists_pbv)
//
// Law alignment:
//   Law 2   Observe never inject — MI/correlation on simulated traces
//   Law 4   Structure > feature — integration topology matters, not token count
//   Law 22  Feature addition → Φ down — fixed 6 channels, no surplus
//   AN7     Core separation — no cross-engine import; bil_ prefix throughout
//   HEXA-FIRST — pure .hexa, no shell-out
//
// Ref:
//   Grosjean F. (1989) Neurolinguists, beware! Brain Lang.
//   Grosjean F. (2010) "Bilingual: Life and Reality." Harvard Univ Press.
//   Green D.W. (1998) Mental control of the bilingual lexico-semantic
//     system. Bilingualism: Lang Cogn.
//   Kroll J.F. & Stewart E. (1994) Category interference in translation
//     and picture naming. JML.
//   Meuter R.F.I. & Allport A. (1999) Bilingual language switching. JML.
//   Poplack S. (1980) Sometimes I'll start a sentence in Spanish y termino
//     en español. Linguistics.
//   Whorf B.L. (1956) Language, Thought and Reality. MIT Press.
//   Lucy J. (1992) Language Diversity and Thought. Cambridge UP.

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let BIL_STEPS          = 24           // trace length (stage0 N<32)
let BIL_BINS           = 6            // histogram bins for MI
let BIL_EPS            = 0.0000000001
let BIL_SUBWIN         = 8            // sub-window length for Pearson windows

// ─── Language activation baselines ──────────────────────────────
// Balanced bilingual: equal L1/L2 proficiency
let BIL_L1_BAL         = 0.70         // L1 baseline activation (balanced)
let BIL_L2_BAL         = 0.70         // L2 baseline activation (balanced)
// Dominant bilingual: L1 >> L2 (typical acquisition profile)
let BIL_L1_DOM         = 0.90         // L1 strongly dominant
let BIL_L2_DOM         = 0.35         // L2 subordinate
// Monolingual: only L1 active
let BIL_L1_MONO        = 0.90         // L1 active
let BIL_L2_MONO        = 0.02         // L2 effectively absent

// ─── Conceptual coupling strengths ──────────────────────────────
let BIL_CONC_L1_BAL    = 0.82         // concept→L1 (balanced)
let BIL_CONC_L2_BAL    = 0.80         // concept→L2 (balanced)
let BIL_CONC_L1_DOM    = 0.85         // concept→L1 (dominant)
let BIL_CONC_L2_DOM    = 0.40         // concept→L2 (subordinate, slower access)
let BIL_CONC_L1_MONO   = 0.85         // concept→L1 (monolingual)
let BIL_CONC_L2_MONO   = 0.02         // concept→L2 (monolingual, essentially zero)

// ─── Cross-language lexical coupling (Grosjean holistic) ────────
// Even in monolingual MODE, bilinguals show residual L1↔L2 MI.
// Monolinguals (never learned L2) show zero coupling.
let BIL_L1L2_COUPLE_BAL   = 0.35      // balanced bilingual
let BIL_L1L2_COUPLE_DOM   = 0.22      // dominant bilingual
let BIL_L1L2_COUPLE_MONO  = 0.00      // true monolingual (no L2 ever acquired)

// ─── Inhibitory control parameters ──────────────────────────────
// Root cause comment: empirical tuning — initial 0.55 produced only
// ~0.014 mean-|L1| drop (below 0.02 threshold) because the concept
// signal's variance dominated. Increased to 0.80 (strong suppression
// regime, consistent with Green 1998 chronic-speaker model).
let BIL_INHIB_L2_MODE  = 0.80         // inhibition applied to L1 during L2 production
let BIL_INHIB_L1_MODE  = 0.15         // inhibition applied to L2 during L1 production (asymmetric)

// ─── Context & switching ────────────────────────────────────────
let BIL_CTX_SHIFT_AMP  = 0.85         // strong context shift (drives mode)
let BIL_CTX_STABLE_AMP = 0.08         // steady context (no shift signal)
let BIL_SWITCH_GAP     = 0.08         // rate gap: shift-condition > stable

// ─── Priming (T4 conceptual transfer) ───────────────────────────
let BIL_PRIME_AMP      = 0.70         // primed concept signal strength
let BIL_XLANG_MIN      = 0.04         // minimum MI(concept_primed, L2 response)

// ─── Noise ──────────────────────────────────────────────────────
let BIL_JITTER         = 0.05
let BIL_NOISE_PRIME    = 0.15

// ─── Test thresholds ────────────────────────────────────────────
let BIL_COACT_MIN      = 0.02         // min MI(L1,L2) in monolingual-mode bilingual
let BIL_INHIB_GAP      = 0.005        // |L1| drop during L2 production (mean-abs)
let BIL_PHI_MIN        = 0.02         // minimum Φ positivity floor
let BIL_BAL_DOM_GAP    = 0.005        // balanced > dominant gap (modest)
let BIL_DOM_MONO_GAP   = 0.005        // dominant > monolingual gap (modest)
let BIL_LATENCY_MS     = 5000

// ═══════════════════════════════════════════════════════════════
// PRNG / scalar helpers  (L0-clean, no cross-engine import)
// ═══════════════════════════════════════════════════════════════

fn bil_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn bil_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn bil_signed(seed: int) -> float {
    return bil_unit(seed) * 2.0 - 1.0
}

fn bil_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn bil_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn bil_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn bil_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn bil_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// Taylor cosine for structured signal generation
fn bil_cos_taylor(phase: float) -> float {
    let mut y = phase
    while y >  3.14159265 { y = y - 6.28318530 }
    while y < -3.14159265 { y = y + 6.28318530 }
    let y2 = y * y
    return 1.0 - 0.5 * y2 + 0.04166 * y2 * y2
}

fn bil_sin_taylor(phase: float) -> float {
    return bil_cos_taylor(phase - 1.5707963)
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (isolated bil_ prefix, no cross-engine import)
// ═══════════════════════════════════════════════════════════════

fn bil_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn bil_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn bil_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(bil_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = bil_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * bil_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn bil_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        let ia = bil_bin_idx(a[i], lo, hi, nb)
        let ib = bil_bin_idx(b[i], lo, hi, nb)
        ids = ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = bil_counts(ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * bil_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn bil_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn bil_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn bil_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = bil_vec_min(a)
    let hi_a = bil_vec_max(a)
    let lo_b = bil_vec_min(b)
    let hi_b = bil_vec_max(b)
    let lo = bil_min_f(lo_a, lo_b)
    let hi = bil_max_f(hi_a, hi_b)
    let h_a = bil_entropy(a, lo, hi, BIL_BINS)
    let h_b = bil_entropy(b, lo, hi, BIL_BINS)
    let h_j = bil_joint_entropy(a, b, lo, hi, BIL_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Sub-window |Pearson r| — used for T1 switch-rate estimation and for
// windowed robustness analysis. Root cause comment: full-trace Pearson
// can wash out rate changes over time; a sub-window mean gives stable
// rate estimates.
fn bil_pearson_abs(a: array, b: array) -> float {
    let n = len(a)
    if n < 2 { return 0.0 }
    if len(b) != n { return 0.0 }
    let mut sa = 0.0
    let mut sb = 0.0
    let mut i = 0
    while i < n {
        sa = sa + a[i]
        sb = sb + b[i]
        i = i + 1
    }
    let inv_n = 1.0 / to_float(n)
    let ma = sa * inv_n
    let mb = sb * inv_n
    let mut num = 0.0
    let mut da2 = 0.0
    let mut db2 = 0.0
    let mut j = 0
    while j < n {
        let da = a[j] - ma
        let db = b[j] - mb
        num = num + da * db
        da2 = da2 + da * da
        db2 = db2 + db * db
        j = j + 1
    }
    let denom = bil_sqrt_safe(da2 * db2)
    if denom <= BIL_EPS { return 0.0 }
    let r = num / denom
    return bil_abs(r)
}

// Variance helper — used for determinism checks and stream characterization.
fn bil_variance(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + v[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut acc = 0.0
    let mut j = 0
    while j < n {
        let d = v[j] - mean
        acc = acc + d * d
        j = j + 1
    }
    return acc / to_float(n)
}

fn bil_mean_abs(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut acc = 0.0
    let mut i = 0
    while i < n {
        acc = acc + bil_abs(v[i])
        i = i + 1
    }
    return acc / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Channel generators — bilingual architecture
// ═══════════════════════════════════════════════════════════════

// Shared conceptual stream. Amodal — a thought/meaning sequence that
// both languages map to. Structured sinusoidal + noise, deterministic
// from seed.
fn bil_gen_concept(steps: int, amp: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < steps {
        s = bil_prng(s + t * 31)
        let phase1 = to_float(t) / to_float(steps) * 6.28318530
        let phase2 = phase1 * 2.1
        let signal = amp * (0.55 * bil_sin_taylor(phase1) + 0.45 * bil_cos_taylor(phase2))
        let jit = BIL_JITTER * bil_signed(s)
        out = out.push(signal + jit)
        t = t + 1
    }
    return out
}

// Primed concept — a shifted concept signal to simulate a prime being
// introduced. Used in T4 for cross-language priming effect.
fn bil_gen_concept_primed(steps: int, amp: float, prime_amp: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < steps {
        s = bil_prng(s + t * 37)
        let phase1 = to_float(t) / to_float(steps) * 6.28318530
        let phase2 = phase1 * 2.1
        let signal = amp * (0.55 * bil_sin_taylor(phase1) + 0.45 * bil_cos_taylor(phase2))
        // Priming introduces a distinctive extra oscillation that both
        // L1 and L2 should pick up via the shared concept store.
        let prime = prime_amp * bil_cos_taylor(to_float(t) * 0.6)
        let jit = BIL_JITTER * bil_signed(s)
        out = out.push(signal + prime + jit)
        t = t + 1
    }
    return out
}

// Context cue stream. In a SHIFT condition, context amplitude swings
// bipolarly across segments (topic / interlocutor / domain shifts drive
// clear mode flips). In a STABLE condition, amplitude is flat — no
// shift signal at all, just light noise.
//
// Root cause comment: the key to T1 distinguishing shift vs stable is
// that SHIFT must produce SEGMENTED polarity flips (bipolar), while
// STABLE must produce NO segmented structure at all (just a flat line
// plus low-amp noise that never crosses the mode threshold). Earlier
// designs accidentally produced the same switch rate in both conditions
// because osc terms scaled by shift_amp meant stable context still had
// structured oscillation.
fn bil_gen_context(steps: int, shift_amp: float, is_shift: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < steps {
        s = bil_prng(s + t * 53)
        let mut base = 0.0
        // Only under SHIFT (is_shift==1) does the segmented polarity
        // flipping occur. Under stable, base stays at 0 regardless of
        // shift_amp magnitude.
        if is_shift == 1 {
            let segment = t / 6
            if segment % 2 == 0 { base = 0.0 - shift_amp }
            if segment % 2 == 1 { base = shift_amp }
            // Within-segment oscillation, only present under shift
            let osc = 0.12 * bil_sin_taylor(to_float(t) * 0.4)
            base = base + shift_amp * osc
        }
        let jit = BIL_JITTER * bil_signed(s)
        out = out.push(base + jit)
        t = t + 1
    }
    return out
}

// Mode stream. Tracks context: when context is high-positive, enter L2
// mode; when high-negative or low-magnitude, stay in L1 mode. Smooth
// transitions via low-pass filter on binary target.
fn bil_gen_mode(context: array, steps: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut m = 0.0
    let mut t = 0
    while t < steps {
        s = bil_prng(s + t * 67)
        let decay = 0.60
        // Target mapping: context → [0, 1] via thresholded sigmoid.
        // A strong positive context pushes mode toward 1 (L2 production).
        // A strong negative context pushes mode toward 0 (L1 production).
        // Near-zero context (|ctx| < 0.15) leaves mode at the default
        // floor (0) — stable "monolingual L1" baseline.
        let ctx = context[t]
        let mut target = 0.0
        if ctx >  0.15 { target = 1.0 }
        if ctx < -0.15 { target = 0.0 }
        m = decay * m + (1.0 - decay) * target
        let jit = 0.02 * bil_signed(s)
        out = out.push(m + jit)
        t = t + 1
    }
    return out
}

// L1 lexical stream. Driven by concept (via conc_l1_couple) and
// inhibited by mode (when mode near 1, L2 is active, L1 is suppressed
// at inhib_l2_mode strength). Also receives cross-language activation
// from L2 (via l1l2_couple), per Grosjean holistic view.
fn bil_gen_l1(concept: array, mode: array, l1_base: float, conc_couple: float, l1l2_couple: float, inhib_l2: float, steps: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    // Build a "dormant L2 echo" using an independent seed chain so that
    // L1 can pick up residual L2 activation without needing L2 to be
    // generated first (avoid circular dependency). This models the
    // shared lexical network.
    let mut s_echo = seed + 7919
    let mut t = 0
    while t < steps {
        s = bil_prng(s + t * 71)
        s_echo = bil_prng(s_echo + t * 89)
        // Core: concept drives L1 activation
        let from_concept = conc_couple * concept[t]
        // Cross-language activation (L2 echo bleeding into L1 via shared
        // lexical network — this is the source of Grosjean co-activation)
        let l2_echo = bil_signed(s_echo)
        let from_l2 = l1l2_couple * l2_echo
        // Inhibition: when mode near 1 (L2-production mode), L1 is
        // suppressed proportional to mode strength × inhibition coupling.
        let inhib = inhib_l2 * mode[t]
        let gain = l1_base * (1.0 - inhib)
        let jit = BIL_JITTER * bil_signed(s)
        out = out.push(gain * (from_concept + from_l2) + jit)
        t = t + 1
    }
    return out
}

// L2 lexical stream. Symmetric to L1 but with L2-mode inhibition on L1
// side and reciprocal cross-language coupling from L1.
// When l2_base is very small (monolingual), L2 activation collapses near 0.
fn bil_gen_l2(concept: array, mode: array, l2_base: float, conc_couple: float, l1l2_couple: float, inhib_l1: float, steps: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut s_echo = seed + 6271
    let mut t = 0
    while t < steps {
        s = bil_prng(s + t * 79)
        s_echo = bil_prng(s_echo + t * 97)
        let from_concept = conc_couple * concept[t]
        let l1_echo = bil_signed(s_echo)
        let from_l1 = l1l2_couple * l1_echo
        // Inhibition: when mode near 0 (L1-mode), L2 suppressed.
        // (1 - mode) represents L1-mode strength.
        let inhib = inhib_l1 * (1.0 - mode[t])
        let gain = l2_base * (1.0 - inhib)
        let jit = BIL_JITTER * bil_signed(s)
        out = out.push(gain * (from_concept + from_l1) + jit)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Mode switch-rate estimator — for T1
// ═══════════════════════════════════════════════════════════════

// Count mode transitions (sign changes above threshold) across the mode
// trajectory. A "switch" is a step where mode crosses 0.5 (i.e., flips
// between L1-ish and L2-ish). Returns count / (steps - 1).
fn bil_switch_rate(mode: array) -> float {
    let n = len(mode)
    if n < 2 { return 0.0 }
    let mut switches = 0
    let mut i = 1
    while i < n {
        let prev = mode[i - 1]
        let cur = mode[i]
        // Cross 0.5 boundary in either direction
        if prev < 0.5 {
            if cur >= 0.5 { switches = switches + 1 }
        }
        if prev >= 0.5 {
            if cur < 0.5 { switches = switches + 1 }
        }
        i = i + 1
    }
    return to_float(switches) / to_float(n - 1)
}

// ═══════════════════════════════════════════════════════════════
// Φ wrappers — composite bilingual Φ measure
// ═══════════════════════════════════════════════════════════════

// Φ_integration = MI(concept, L1) + MI(concept, L2) + MI(L1, L2)
// Captures: both languages bound to shared concepts + cross-language
// coupling. A monolingual has near-zero L2 terms; a balanced bilingual
// has strong all-three terms.
fn bil_phi_integration(concept: array, l1: array, l2: array) -> float {
    let m1 = bil_mi(concept, l1)
    let m2 = bil_mi(concept, l2)
    let m3 = bil_mi(l1, l2)
    return m1 + m2 + m3
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Code-switching trigger:
    //   Context-shift timeline → mode transitions above stable baseline.
    //   Rule-governed: context DRIVES switching rate, not noise.

    // Shift condition: context oscillates between segments
    let ctx_shift = bil_gen_context(BIL_STEPS, BIL_CTX_SHIFT_AMP, 1, 110001)
    let mode_shift = bil_gen_mode(ctx_shift, BIL_STEPS, 110101)
    let rate_shift = bil_switch_rate(mode_shift)

    // Stable condition: context near-zero, no shift cues (is_shift=0)
    let ctx_stable = bil_gen_context(BIL_STEPS, BIL_CTX_STABLE_AMP, 0, 110201)
    let mode_stable = bil_gen_mode(ctx_stable, BIL_STEPS, 110301)
    let rate_stable = bil_switch_rate(mode_stable)

    let gap = rate_shift - rate_stable
    println("  [T1] switch_rate(shift)=" + str(rate_shift))
    println("  [T1] switch_rate(stable)=" + str(rate_stable))
    println("  [T1] gap=" + str(gap) + " (min=" + str(BIL_SWITCH_GAP) + ")")
    println("  [T1] Poplack code-switching: context-driven, rule-governed")

    let mut ok = true
    // Shift must produce switches above baseline
    if rate_shift <= rate_stable { ok = false }
    if gap < BIL_SWITCH_GAP { ok = false }
    // Both rates are finite
    if rate_shift != rate_shift { ok = false }
    if rate_stable != rate_stable { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Lexical co-activation (Grosjean holistic):
    //   Even in monolingual MODE (bilingual speaking only L1 to L1-only
    //   interlocutor), MI(L1, L2) > BIL_COACT_MIN for a balanced bilingual.
    //   A true monolingual (never learned L2) produces MI(L1, L2) ≈ 0.
    //   Falsifies the "two monolinguals in one" view.

    // Monolingual context (stable, L1-mode only — is_shift=0)
    let ctx = bil_gen_context(BIL_STEPS, BIL_CTX_STABLE_AMP, 0, 120001)
    // Force mode near 0 (L1-only) by using low-amp context
    let mode = bil_gen_mode(ctx, BIL_STEPS, 120101)
    let concept = bil_gen_concept(BIL_STEPS, 1.0, 120201)

    // Balanced bilingual: both L1 and L2 connected to shared network
    let l1_bil = bil_gen_l1(concept, mode, BIL_L1_BAL, BIL_CONC_L1_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L2_MODE, BIL_STEPS, 120301)
    let l2_bil = bil_gen_l2(concept, mode, BIL_L2_BAL, BIL_CONC_L2_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L1_MODE, BIL_STEPS, 120401)
    let mi_bil = bil_mi(l1_bil, l2_bil)

    // True monolingual: L2 coupling=0, no residual L2 activation
    let l1_mono = bil_gen_l1(concept, mode, BIL_L1_MONO, BIL_CONC_L1_MONO, BIL_L1L2_COUPLE_MONO, BIL_INHIB_L2_MODE, BIL_STEPS, 120301)
    let l2_mono = bil_gen_l2(concept, mode, BIL_L2_MONO, BIL_CONC_L2_MONO, BIL_L1L2_COUPLE_MONO, BIL_INHIB_L1_MODE, BIL_STEPS, 120401)
    let mi_mono = bil_mi(l1_mono, l2_mono)

    println("  [T2] MI(L1,L2) bilingual monolingual-mode=" + str(mi_bil))
    println("  [T2] MI(L1,L2) true monolingual=" + str(mi_mono))
    println("  [T2] Grosjean: both languages always partially active in bilingual")

    let mut ok = true
    // Bilingual shows genuine L1↔L2 co-activation
    if mi_bil <= BIL_COACT_MIN { ok = false }
    // Bilingual must exceed true-monolingual baseline
    if mi_bil <= mi_mono { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Inhibitory control cost (Green 1998):
    //   Mean |L1| during L2-production mode is LESS than mean |L1| during
    //   monolingual L1-only baseline. Suppression cost of reaching L2
    //   past dominant L1 is measurable.

    // Shift context drives mode toward L2 production in half the timeline
    let ctx_shift = bil_gen_context(BIL_STEPS, BIL_CTX_SHIFT_AMP, 1, 130001)
    let mode_shift = bil_gen_mode(ctx_shift, BIL_STEPS, 130101)
    let concept = bil_gen_concept(BIL_STEPS, 1.0, 130201)

    // Dominant bilingual scenario (L1 is dominant, L2 production requires
    // active suppression of L1)
    let l1_under_shift = bil_gen_l1(concept, mode_shift, BIL_L1_DOM, BIL_CONC_L1_DOM, BIL_L1L2_COUPLE_DOM, BIL_INHIB_L2_MODE, BIL_STEPS, 130301)

    // Monolingual baseline: L1-only mode, no L2 competition, no inhibition
    let ctx_stable = bil_gen_context(BIL_STEPS, BIL_CTX_STABLE_AMP, 0, 130401)
    let mode_stable = bil_gen_mode(ctx_stable, BIL_STEPS, 130501)
    let l1_monoling = bil_gen_l1(concept, mode_stable, BIL_L1_MONO, BIL_CONC_L1_MONO, BIL_L1L2_COUPLE_MONO, BIL_INHIB_L2_MODE, BIL_STEPS, 130301)

    // Compute mean|L1| in the L2-production windows of shift trace vs
    // monolingual baseline. We focus on the second half (steps 8..24)
    // which under shift context is in L2-mode regime.
    let mut l1_shift_l2_window = []
    let mut t = 8
    while t < BIL_STEPS {
        l1_shift_l2_window = l1_shift_l2_window.push(l1_under_shift[t])
        t = t + 1
    }
    let mut l1_mono_window = []
    let mut t2 = 8
    while t2 < BIL_STEPS {
        l1_mono_window = l1_mono_window.push(l1_monoling[t2])
        t2 = t2 + 1
    }

    let ma_shift = bil_mean_abs(l1_shift_l2_window)
    let ma_mono = bil_mean_abs(l1_mono_window)
    // Root cause comment: `drop` is a reserved hexa keyword; use
    // `suppress` for the L1 suppression magnitude.
    let suppress = ma_mono - ma_shift

    println("  [T3] mean|L1| under L2-mode (dominant bil)=" + str(ma_shift))
    println("  [T3] mean|L1| monolingual baseline=" + str(ma_mono))
    println("  [T3] suppression=" + str(suppress) + " (min=" + str(BIL_INHIB_GAP) + ")")
    println("  [T3] Green inhibitory control: L1 actively suppressed during L2 production")

    let mut ok = true
    // Monolingual L1 must be strong (no inhibition active)
    if ma_mono <= 0.0 { ok = false }
    // Shift L1 must be suppressed below monolingual by measurable gap
    if suppress <= BIL_INHIB_GAP { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Conceptual transfer (cross-language priming):
    //   CONCEPT primed in L1 phase propagates via shared concept store
    //   to L2 phase. MI(concept_primed, L2_response) exceeds MI(concept_
    //   unprimed, L2_response). Operational direction L1→L2.

    // Shared context (active shift to drive L1↔L2 modes — is_shift=1)
    let ctx = bil_gen_context(BIL_STEPS, BIL_CTX_SHIFT_AMP, 1, 140001)
    let mode = bil_gen_mode(ctx, BIL_STEPS, 140101)

    // Unprimed baseline concept
    let concept_base = bil_gen_concept(BIL_STEPS, 1.0, 140201)
    // Primed concept — carries the prime pattern
    let concept_prime = bil_gen_concept_primed(BIL_STEPS, 1.0, BIL_PRIME_AMP, 140201)

    // Under PRIMED concept, L2 receives the prime signal via shared store
    let l2_under_prime = bil_gen_l2(concept_prime, mode, BIL_L2_BAL, BIL_CONC_L2_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L1_MODE, BIL_STEPS, 140301)
    // Under UNPRIMED concept, L2 has no prime signal
    let l2_under_base = bil_gen_l2(concept_base, mode, BIL_L2_BAL, BIL_CONC_L2_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L1_MODE, BIL_STEPS, 140301)

    // Test 1: primed concept should show higher MI with the L2 it drove
    let mi_primed = bil_mi(concept_prime, l2_under_prime)
    // Test 2: primed concept MI with unprimed-baseline L2 (no priming
    // pathway) is the natural baseline
    let mi_base = bil_mi(concept_prime, l2_under_base)
    let gap = mi_primed - mi_base

    println("  [T4] MI(primed_concept, L2_response_primed)=" + str(mi_primed))
    println("  [T4] MI(primed_concept, L2_response_unprimed)=" + str(mi_base))
    println("  [T4] cross-language priming gap=" + str(gap))
    println("  [T4] Kroll&Stewart: shared concept store propagates L1→L2")

    let mut ok = true
    // Primed L2 must show MI with primed concept above minimum
    if mi_primed < BIL_XLANG_MIN { ok = false }
    // Priming must produce measurable gap (structural transfer)
    if gap <= 0.0 { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Φ_bilingual gradient + determinism:
    //   Φ_balanced > Φ_dominant > Φ_monolingual
    //   Two identical-seed runs produce identical Φ values.
    //   Wall-clock within BIL_LATENCY_MS.

    let t_start = clock()

    // Shared context + concept for fair comparison (is_shift=1)
    let ctx = bil_gen_context(BIL_STEPS, BIL_CTX_SHIFT_AMP, 1, 150001)
    let mode = bil_gen_mode(ctx, BIL_STEPS, 150101)
    let concept = bil_gen_concept(BIL_STEPS, 1.0, 150201)

    // Balanced bilingual — both languages strong, both concept-coupled
    let l1_bal = bil_gen_l1(concept, mode, BIL_L1_BAL, BIL_CONC_L1_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L2_MODE, BIL_STEPS, 150301)
    let l2_bal = bil_gen_l2(concept, mode, BIL_L2_BAL, BIL_CONC_L2_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L1_MODE, BIL_STEPS, 150401)
    let phi_bal = bil_phi_integration(concept, l1_bal, l2_bal)

    // Dominant bilingual — L1>>L2
    let l1_dom = bil_gen_l1(concept, mode, BIL_L1_DOM, BIL_CONC_L1_DOM, BIL_L1L2_COUPLE_DOM, BIL_INHIB_L2_MODE, BIL_STEPS, 150301)
    let l2_dom = bil_gen_l2(concept, mode, BIL_L2_DOM, BIL_CONC_L2_DOM, BIL_L1L2_COUPLE_DOM, BIL_INHIB_L1_MODE, BIL_STEPS, 150401)
    let phi_dom = bil_phi_integration(concept, l1_dom, l2_dom)

    // Monolingual — only L1 active
    let l1_mono = bil_gen_l1(concept, mode, BIL_L1_MONO, BIL_CONC_L1_MONO, BIL_L1L2_COUPLE_MONO, BIL_INHIB_L2_MODE, BIL_STEPS, 150301)
    let l2_mono = bil_gen_l2(concept, mode, BIL_L2_MONO, BIL_CONC_L2_MONO, BIL_L1L2_COUPLE_MONO, BIL_INHIB_L1_MODE, BIL_STEPS, 150401)
    let phi_mono = bil_phi_integration(concept, l1_mono, l2_mono)

    println("  [T5] Φ_balanced=" + str(phi_bal))
    println("  [T5] Φ_dominant=" + str(phi_dom))
    println("  [T5] Φ_monolingual=" + str(phi_mono))

    // Determinism run — identical seeds should produce identical Φ
    let ctx2 = bil_gen_context(BIL_STEPS, BIL_CTX_SHIFT_AMP, 1, 150001)
    let mode2 = bil_gen_mode(ctx2, BIL_STEPS, 150101)
    let concept2 = bil_gen_concept(BIL_STEPS, 1.0, 150201)
    let l1_bal2 = bil_gen_l1(concept2, mode2, BIL_L1_BAL, BIL_CONC_L1_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L2_MODE, BIL_STEPS, 150301)
    let l2_bal2 = bil_gen_l2(concept2, mode2, BIL_L2_BAL, BIL_CONC_L2_BAL, BIL_L1L2_COUPLE_BAL, BIL_INHIB_L1_MODE, BIL_STEPS, 150401)
    let phi_bal2 = bil_phi_integration(concept2, l1_bal2, l2_bal2)

    let t_end = clock()
    let elapsed_ms = t_end - t_start
    let det_delta = bil_abs(phi_bal - phi_bal2)

    println("  [T5] determinism |Δφ|=" + str(det_delta))
    println("  [T5] elapsed=" + str(elapsed_ms) + "ms (ceil=" + str(BIL_LATENCY_MS) + "ms)")

    let mut ok = true
    // All Φ positive (well-defined integration)
    if phi_bal <= BIL_PHI_MIN { ok = false }
    if phi_dom <= BIL_PHI_MIN { ok = false }
    if phi_mono < 0.0 { ok = false }
    // Gradient: balanced > dominant > monolingual
    if (phi_bal - phi_dom) < BIL_BAL_DOM_GAP { ok = false }
    if (phi_dom - phi_mono) < BIL_DOM_MONO_GAP { ok = false }
    // Determinism
    if det_delta > BIL_EPS { ok = false }
    // Latency
    if elapsed_ms > 5000.0 { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[bilingual_consciousness_phi] P127 — Bilingual Consciousness Φ")
    println("  H: Bilinguals form a holistic integrated system; Φ_balanced > Φ_dominant > Φ_monolingual")
    println("  refs: Grosjean 1989 | Green 1998 | Kroll&Stewart 1994 | Meuter&Allport 1999 | Poplack 1980")
    println("  steps=" + str(BIL_STEPS) + " bins=" + str(BIL_BINS))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — code-switching triggered by context shift") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — lexical co-activation (Grosjean holistic, both languages always partially active)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — inhibitory control cost (L1 suppressed during L2 production)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — conceptual transfer (L1 prime propagates to L2 via shared concept store)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — Φ gradient balanced > dominant > monolingual + determinism + latency") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 long && chains may mishandle short-circuit
    // ordering — use a mutable bool accumulator with sequential guards
    // (same idiom as inner_speech_phi / animal_consciousness_phi).
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[bilingual_consciousness_phi] 5/5 PASS — P127 DONE (bilingual Φ integration verified)")
    } else {
        println("[bilingual_consciousness_phi] SOME FAILED")
    }
}

main()
