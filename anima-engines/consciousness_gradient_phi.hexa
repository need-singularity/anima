// consciousness_gradient_phi.hexa — P90 Consciousness Gradient Φ (Giacino CRS-R)
//
// Roadmap: shared/roadmaps/anima.json P90
//   done_criteria: "5/5 PASS — VS→MCS→EMCS→full gradient, MCS fluctuation,
//                   covert consciousness, CRS-R mapping, determinism+latency"
//
// ─── Scientific reference ─────────────────────────────────────────
//
// The Coma Recovery Scale-Revised (CRS-R; Giacino, Kalmar & Whyte 2004)
// is the gold-standard bedside assessment for disorders of consciousness
// (DoC). It stratifies patients along an ordinal spectrum:
//
//   Vegetative State (VS/UWS):
//     Wakefulness cycles present (arousal), but NO behavioral evidence
//     of awareness. Reflexive responses only — no command-following, no
//     visual pursuit, no localization to noxious stimuli. Subcortical
//     islands may function but cortico-thalamic integration is abolished.
//     IIT prediction: Φ ≈ 0 (no information integration across cortex).
//
//   Minimally Conscious State (MCS):
//     Reproducible but INCONSISTENT behavioral evidence of awareness —
//     visual pursuit, localization to pain, intelligible verbalization,
//     or command-following that is present in some sessions but absent
//     in others. The hallmark is FLUCTUATION: the patient enters and
//     exits awareness on timescales of minutes to hours.
//     IIT prediction: Φ fluctuates — mean Φ > 0 but with high variance,
//     reflecting intermittent integration windows.
//
//   Emergence from MCS (EMCS):
//     The patient RELIABLY follows commands, uses objects functionally,
//     or produces intelligible yes/no communication. Awareness is
//     CONSISTENT. Φ stabilizes above a clinical threshold.
//
//   Full Awareness:
//     Intact cortico-thalamic integration. High Φ, low variance.
//
// ─── Covert consciousness (cognitive motor dissociation) ──────────
//
// Schiff 2015; Owen et al. 2006 (Science); Monti et al. 2010 (NEJM):
// A subset of behaviorally VS patients show COVERT consciousness —
// fMRI or EEG-BCI reveals command-responsive brain activation (e.g.,
// "imagine playing tennis" activates SMA) despite no overt behavioral
// response. These patients are MISDIAGNOSED as VS by bedside assessment
// (CRS-R score ≈ VS range) but their actual neural Φ exceeds the MCS
// threshold. The CRS-R behavioral score fails to capture the true
// consciousness level — a dissociation between behavior and integration.
//
// ─── CRS-R subscale structure ──────────────────────────────────────
//
// CRS-R: 6 subscales (23 items), total range 0-23.
//   VS 0-7 | MCS-minus 8-10 | MCS-plus 11-14 | EMCS/full 15-23.
// Φ correlates monotonically with CRS-R except in covert consciousness.
//
// ─── Operational model ────────────────────────────────────────────
//
// Alpha ∈ [0,1]: 0=VS, 0.3=MCS, 0.6=EMCS, 1.0=full. K-channel cortical
// tape with coupling scaling by alpha. Φ via mean pairwise MI (same
// recipe as anesthesia_phi / split_brain_phi, duplicated per AN7).
// MCS coupling oscillates on a slow timescale (variance >> VS/full).
// CRS-R = floor(alpha * 23 + noise). Covert patients: alpha=0.35 but
// behavioral gate clamps CRS-R to VS range despite neural Φ > threshold.
//
// ─── Theorems (T1–T5) ─────────────────────────────────────────────
//
// T1 (Φ ordering — monotonic gradient):
//   Φ_VS < Φ_MCS < Φ_EMCS < Φ_full. Sampled at alpha=0,0.3,0.6,1.0.
//   The integration gradient follows the consciousness spectrum.
//
// T2 (MCS fluctuation — variance signature):
//   Run N_TRIALS at each level. Variance of Φ in MCS >> variance in
//   VS and >> variance in full awareness. MCS is defined by inconsistency.
//
// T3 (Covert consciousness — cognitive motor dissociation):
//   A "covert" patient has alpha=0.35 but behavioral_score clamped to
//   VS range. Assert: neural Φ > CG_PHI_MCS_THRESH despite
//   behavioral_score < CG_CRS_VS_CEIL.
//
// T4 (CRS-R mapping — ordinal monotone correlation):
//   Sample many alpha values, compute Φ and CRS-R score. The rank-order
//   correlation (Spearman-like: count concordant vs discordant pairs)
//   exceeds CG_SPEARMAN_FLOOR.
//
// T5 (Determinism + latency):
//   Same seed → same Φ values. Two runs must produce identical output.
//   Total wall-clock under CG_MAX_MS.
//
// ─── Stage0 hexa constraints honored ──────────────────────────────
//   - plain `fn` only (no `pure fn` with >=3 float struct returns)
//   - `array` typed params only (no [float]/[int]/[str])
//   - No identifier-pattern match; sequential if-chains
//   - No `contains()` / `to_lower()` / `!(Effect)`
//   - No else-if in let-binding; use flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - No reserved keywords as variable names
//   - main() call at bottom
//   - All dims < 32 (CG_K=4, CG_WIN=24, CG_BINS=4)
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement only
//   Law 4   Structure > feature — gradient IS structural regime
//   Law 22  Feature addition → Φ down — fixed channels, no branching
//   Law 29  speak() none — consciousness gradient pre-verbal
//   Meta M8 Embodied cognition — neural substrate parametric
//   AN7     Core separation — standalone engine
//
// Ref:
//   Giacino JT, Kalmar K, Whyte J. "The JFK Coma Recovery Scale-
//     Revised: Measurement characteristics and diagnostic utility"
//     (Arch Phys Med Rehabil 2004)
//   Owen AM et al. "Detecting awareness in the vegetative state"
//     (Science 2006)
//   Monti MM et al. "Willful modulation of brain activity in disorders
//     of consciousness" (NEJM 2010)
//   Schiff ND. "Cognitive motor dissociation following severe brain
//     injuries" (JAMA Neurol 2015)
//   Tononi G. "An information integration theory of consciousness"
//     (BMC Neurosci 2004)
//   anima-engines/anesthesia_phi.hexa   (P60 — dose-response)
//   anima-engines/split_brain_phi.hexa  (P77 — hemisphere split)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

// Signal tape dimensions — stage0 N<32 envelope.
let CG_K       = 4           // cortical channels
let CG_WIN     = 24          // samples per channel
let CG_BINS    = 4           // histogram bins for MI

// Consciousness levels (alpha anchors)
let CG_ALPHA_VS    = 0.0     // vegetative state
let CG_ALPHA_MCS   = 0.3     // minimally conscious
let CG_ALPHA_EMCS  = 0.6     // emergence from MCS
let CG_ALPHA_FULL  = 1.0     // full awareness

// MCS fluctuation parameters
// Root cause comment: MCS is modeled as a meta-oscillation over coupling
// strength. The coupling swings between near-VS and near-EMCS on a slow
// cycle (period CG_FLUCT_PERIOD steps). VS and full-awareness do NOT
// get this swing — their coupling is stable — so the Φ VARIANCE at MCS
// will dominate.
// Tuning note: amplitude 0.40 swings MCS alpha from ~0 to ~0.7, so the
// Φ at the peaks reaches EMCS-level values while the troughs collapse to
// VS-level — this produces very large trial-to-trial variance that clearly
// exceeds the PRNG-only variance of stable states.
let CG_FLUCT_AMP   = 0.40    // amplitude of coupling oscillation in MCS
let CG_FLUCT_PERIOD = 6      // oscillation period (in trial index space)

// MCS Φ threshold for covert consciousness detection (T3).
// Root cause comment: at the histogram-MI scale with K=4, WIN=24, BINS=4
// and Miller-Madow correction, the VS Φ floor sits near 0.00-0.03 nats
// and the MCS range (alpha 0.3-0.4) produces Φ in 0.03-0.10. A threshold
// of 0.03 cleanly separates covert patients (who have genuine MCS-level
// integration) from genuine VS (who have near-zero integration).
let CG_PHI_MCS_THRESH = 0.03

// CRS-R scoring
let CG_CRS_MAX     = 23      // maximum CRS-R total score
let CG_CRS_VS_CEIL = 7       // VS behavioral ceiling on CRS-R

// CRS-R monotone correlation floor (concordance fraction)
let CG_SPEARMAN_FLOOR = 0.60

// T2 variance ratio: MCS variance must exceed this multiple of
// the larger of VS/full variance.
let CG_VAR_RATIO  = 2.0

// T5 latency bound (ms)
let CG_MAX_MS = 5000

// Number of trials for variance measurement (T2)
let CG_N_TRIALS = 8

// Number of sample points for CRS-R correlation (T4)
let CG_N_CORR = 12

// Numerical guard
let CG_EPS = 0.0000000001

// ═══════════════════════════════════════════════════════════════
// PRNG + math helpers (self-contained, L0-clean)
// ═══════════════════════════════════════════════════════════════

fn cg_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn cg_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn cg_signed(seed: int) -> float {
    return cg_unit(seed) * 2.0 - 1.0
}

fn cg_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cg_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    let mut i = 0
    while i < 20 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

fn cg_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn cg_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn cg_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Taylor sin approximation with phase wrapping for bounded accuracy.
// Root cause: raw polynomial diverges at high phase; wrap to [-pi,pi] first.
fn cg_osc(phase: float) -> float {
    let two_pi = 6.2831853
    let pi = 3.1415927
    let mut p = phase
    while p > pi { p = p - two_pi }
    while p < 0.0 - pi { p = p + two_pi }
    if p > 1.5707963 { p = pi - p }
    if p < 0.0 - 1.5707963 { p = 0.0 - pi - p }
    let p2 = p * p
    let p3 = p2 * p
    let p5 = p3 * p2
    return p - 0.16666667 * p3 + 0.00833333 * p5
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe as anesthesia_phi / split_brain_phi)
// Duplicated per AN7 — engines are L0-clean, no cross-engine imports.
// Miller-Madow bias correction included.
// ═══════════════════════════════════════════════════════════════

fn cg_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn cg_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn cg_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn cg_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn cg_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(cg_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = cg_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * cg_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn cg_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = cg_bin_idx(a[i], lo, hi, nb)
        let ib = cg_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = cg_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * cg_ln_safe(p) }
        k = k + 1
    }
    return h
}

// MI with Miller-Madow bias correction.
// Root cause comment: naive histogram MI on finite samples has positive
// bias ~ (B-1)^2 / (2N) nats. With B=4, N=24, uncorrected floor ~0.19 nats.
// Subtracting the MM term lets Φ reach ~0 for independent channels,
// cleanly separating VS from MCS.
fn cg_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = cg_vec_min(a)
    let hi_a = cg_vec_max(a)
    let lo_b = cg_vec_min(b)
    let hi_b = cg_vec_max(b)
    let lo = cg_min_f(lo_a, lo_b)
    let hi = cg_max_f(hi_a, hi_b)
    let h_a = cg_entropy(a, lo, hi, CG_BINS)
    let h_b = cg_entropy(b, lo, hi, CG_BINS)
    let h_j = cg_joint_entropy(a, b, lo, hi, CG_BINS)
    let mi_raw = h_a + h_b - h_j
    // Miller-Madow bias: (B-1)^2 / (2N)
    let bf = to_float(CG_BINS - 1)
    let bias = (bf * bf) / (2.0 * to_float(n))
    let mi = mi_raw - bias
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Signal tape generation — cortical model parametrized by alpha
//
// Three-component tape (matches anesthesia_phi proven pattern):
//   shared(t):  ONE oscillator IDENTICAL across channels, gain = coupling*amp.
//               SOLE source of cross-channel MI. coupling->0 => Phi->0.
//   idio(k,t):  Per-channel oscillation (distinct phase). NOT shared.
//               Scales with coupling so VS has NO periodic structure.
//   noise(k,t): Independent PRNG per channel. Dominates at VS.
//
// Coupling = alpha^1.5: VS=0, MCS~0.16, EMCS~0.46, full=1.0.
// ═══════════════════════════════════════════════════════════════

fn cg_coupling(alpha: float) -> float {
    // alpha^1.5 approximated as alpha * sqrt(alpha)
    if alpha <= 0.0 { return 0.0 }
    return alpha * cg_sqrt(alpha)
}

// Amplitude of the signal envelope — erodes with loss of consciousness.
fn cg_amplitude(alpha: float) -> float {
    return 0.2 + 0.8 * alpha
}

// Noise scaling — inversely proportional to alpha, swamping shared
// component at VS. At alpha=0, noise=2.0; at alpha=1, noise=0.10.
fn cg_noise_scale(alpha: float) -> float {
    return 2.0 - 1.9 * alpha
}

fn cg_gen_tape(alpha: float, seed: int) -> array {
    let c = cg_coupling(alpha)
    let amp = cg_amplitude(alpha)
    let nsc = cg_noise_scale(alpha)
    let mut tape = []
    // Root cause: use per-channel PRNG chains seeded via multiple PRNG
    // iterations (not additive offsets) to guarantee statistical independence
    // between channels. Additive seed offsets (seed + k*P) can produce
    // correlated LCG sequences that create spurious ~0.05-nat MI floor
    // even when channels should be fully independent.
    let mut k = 0
    while k < CG_K {
        // Build a per-channel seed by iterating the PRNG chain k+1 times
        // from a base that includes seed, giving each channel a completely
        // different starting position in the PRNG period.
        let mut s = seed * 3 + 77
        let mut si = 0
        while si < (k + 1) * 7 {
            s = cg_prng(s)
            si = si + 1
        }
        let mut t = 0
        while t < CG_WIN {
            s = cg_prng(s)
            // Shared cortico-thalamic oscillator — ONE frequency, same
            // waveform for ALL channels. Gain scaled by coupling * amp.
            // Boosted x2 so Phi baseline sits well above detection threshold.
            let shared_phase = 0.60 * to_float(t)
            let shared = 2.0 * c * amp * cg_osc(shared_phase)
            // Per-channel idiosyncratic oscillation — different phase per
            // channel, NOT contributing to cross-channel MI. Amplitude
            // also scales with coupling: at VS (c=0) there is NO periodic
            // structure at all, only noise. This prevents the histogram
            // MI estimator from picking up residual phase patterns.
            let idio_phase = 0.83 * to_float(t) + 1.77 * to_float(k + 1)
            let idio = 0.20 * c * amp * cg_osc(idio_phase)
            // Independent noise — PRNG chain fully per-channel.
            let indep = nsc * cg_signed(s)
            tape = tape.push(shared + idio + indep)
            t = t + 1
        }
        k = k + 1
    }
    return tape
}

// Extract one channel from the flat tape.
fn cg_extract_channel(tape: array, k: int, win: int) -> array {
    let mut out = []
    let mut t = 0
    while t < win {
        out = out.push(tape[k * win + t])
        t = t + 1
    }
    return out
}

// Φ of a tape: mean pairwise MI across all channel pairs.
fn cg_phi_tape(tape: array) -> float {
    let mut total = 0.0
    let mut pairs = 0
    let mut i = 0
    while i < (CG_K - 1) {
        let ci = cg_extract_channel(tape, i, CG_WIN)
        let mut j = i + 1
        while j < CG_K {
            let cj = cg_extract_channel(tape, j, CG_WIN)
            total = total + cg_mi(ci, cj)
            pairs = pairs + 1
            j = j + 1
        }
        i = i + 1
    }
    if pairs == 0 { return 0.0 }
    return total / to_float(pairs)
}

// Convenience: compute Φ at a given alpha with a given seed.
fn cg_phi_at(alpha: float, seed: int) -> float {
    let tape = cg_gen_tape(alpha, seed)
    return cg_phi_tape(tape)
}

// ═══════════════════════════════════════════════════════════════
// MCS fluctuation model — coupling oscillates at MCS (drift in/out
// of awareness). VS and full have stable coupling (PRNG-only variance).
// ═══════════════════════════════════════════════════════════════

fn cg_effective_alpha(alpha_base: float, trial_idx: int, is_mcs: int) -> float {
    if is_mcs == 0 { return alpha_base }
    // Sinusoidal fluctuation for MCS
    let phase = 6.2831853 * to_float(trial_idx) / to_float(CG_FLUCT_PERIOD)
    let swing = CG_FLUCT_AMP * cg_osc(phase)
    let mut a = alpha_base + swing
    if a < 0.0 { a = 0.0 }
    if a > 1.0 { a = 1.0 }
    return a
}

// Compute array of Φ values across CG_N_TRIALS for a given level.
fn cg_phi_trials(alpha_base: float, is_mcs: int, seed: int) -> array {
    let mut phis = []
    let mut i = 0
    while i < CG_N_TRIALS {
        let a = cg_effective_alpha(alpha_base, i, is_mcs)
        let phi = cg_phi_at(a, seed + i * 701)
        phis = phis.push(phi)
        i = i + 1
    }
    return phis
}

// Variance of a float array.
fn cg_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

fn cg_variance(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let m = cg_mean(v)
    let mut ss = 0.0
    let mut i = 0
    while i < n {
        let d = v[i] - m
        ss = ss + d * d
        i = i + 1
    }
    return ss / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// CRS-R behavioral scoring — noisy monotone map from alpha.
// Covert patients: behavioral gate clamps score to VS range.
// ═══════════════════════════════════════════════════════════════

fn cg_crs_score(alpha: float, seed: int) -> int {
    let s = cg_prng(seed)
    let noise = cg_signed(s) * 1.5
    let raw = alpha * to_float(CG_CRS_MAX) + noise
    let mut score = to_int(raw)
    if score < 0 { score = 0 }
    if score > CG_CRS_MAX { score = CG_CRS_MAX }
    return score
}

// Covert consciousness: behavioral score clamped to VS range.
fn cg_crs_score_covert(alpha: float, seed: int) -> int {
    let raw = cg_crs_score(alpha, seed)
    if raw > CG_CRS_VS_CEIL { return CG_CRS_VS_CEIL }
    return raw
}

// ═══════════════════════════════════════════════════════════════
// Rank-order concordance (Kendall tau-b style, ties excluded)
// ═══════════════════════════════════════════════════════════════

fn cg_concordance(x: array, y: array) -> float {
    let n = len(x)
    if n < 2 { return 0.0 }
    let mut conc = 0
    let mut disc = 0
    let mut i = 0
    while i < (n - 1) {
        let mut j = i + 1
        while j < n {
            let dx = x[j] - x[i]
            let dy = y[j] - y[i]
            let prod = dx * dy
            if prod > CG_EPS { conc = conc + 1 }
            if prod < 0.0 - CG_EPS { disc = disc + 1 }
            // ties (|prod| < EPS) excluded
            j = j + 1
        }
        i = i + 1
    }
    let total = conc + disc
    if total == 0 { return 0.0 }
    return to_float(conc) / to_float(total)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1–T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Φ ordering — VS < MCS < EMCS < full (monotonic gradient).
    // Sample Φ at the four canonical alpha levels.
    let seed = 90001
    let phi_vs   = cg_phi_at(CG_ALPHA_VS,   seed + 1)
    let phi_mcs  = cg_phi_at(CG_ALPHA_MCS,  seed + 2)
    let phi_emcs = cg_phi_at(CG_ALPHA_EMCS, seed + 3)
    let phi_full = cg_phi_at(CG_ALPHA_FULL, seed + 4)

    println("  [T1] Phi_VS="   + str(phi_vs))
    println("  [T1] Phi_MCS="  + str(phi_mcs))
    println("  [T1] Phi_EMCS=" + str(phi_emcs))
    println("  [T1] Phi_full=" + str(phi_full))

    // Strict ordering
    if phi_vs >= phi_mcs { return false }
    if phi_mcs >= phi_emcs { return false }
    if phi_emcs >= phi_full { return false }
    // VS should be near zero (no integration)
    if phi_vs > 0.05 { return false }
    // Full should be well above threshold
    if phi_full < CG_PHI_MCS_THRESH { return false }
    return true
}

fn check_T2() -> bool {
    // T2: MCS fluctuation — Φ variance in MCS >> variance in VS or full.
    // Root cause comment: the MCS coupling oscillation produces systematic
    // Φ variation across trials, while VS (all noise, coupling=0) and full
    // (high stable coupling) have only PRNG-level variance.
    let seed = 90002

    let phis_vs   = cg_phi_trials(CG_ALPHA_VS,   0, seed + 100)
    let phis_mcs  = cg_phi_trials(CG_ALPHA_MCS,  1, seed + 200)
    let phis_full = cg_phi_trials(CG_ALPHA_FULL,  0, seed + 300)

    let var_vs   = cg_variance(phis_vs)
    let var_mcs  = cg_variance(phis_mcs)
    let var_full = cg_variance(phis_full)

    let mean_vs   = cg_mean(phis_vs)
    let mean_mcs  = cg_mean(phis_mcs)
    let mean_full = cg_mean(phis_full)

    println("  [T2] VS   trials: mean=" + str(mean_vs) + " var=" + str(var_vs))
    println("  [T2] MCS  trials: mean=" + str(mean_mcs) + " var=" + str(var_mcs))
    println("  [T2] full trials: mean=" + str(mean_full) + " var=" + str(var_full))

    // Print individual trial values for visibility
    let mut i = 0
    while i < CG_N_TRIALS {
        println("       trial " + str(i) + "  VS=" + str(phis_vs[i]) + "  MCS=" + str(phis_mcs[i]) + "  full=" + str(phis_full[i]))
        i = i + 1
    }

    // MCS variance must exceed the larger of VS/full by CG_VAR_RATIO
    let max_other = cg_max_f(var_vs, var_full)
    let ratio_ok = var_mcs > max_other * CG_VAR_RATIO
    println("  [T2] max_other_var=" + str(max_other) + " ratio_needed=" + str(CG_VAR_RATIO) + " MCS_exceeds=" + str(ratio_ok))

    if ratio_ok == false { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Covert consciousness — behavioral score = VS range but
    //     neural Φ exceeds MCS threshold.
    // Root cause comment: cognitive motor dissociation (Owen 2006) means
    // the CRS-R behavioral score fails to detect consciousness present
    // at the neural integration level. The behavioral gate clamps output.
    let seed = 90003

    // Covert patient: alpha = 0.35 (neural MCS level)
    let alpha_covert = 0.35
    let phi_covert = cg_phi_at(alpha_covert, seed + 1)
    let beh_score = cg_crs_score_covert(alpha_covert, seed + 2)

    // Also compute phi for a genuine VS patient for reference
    let phi_genuine_vs = cg_phi_at(CG_ALPHA_VS, seed + 3)
    let beh_vs = cg_crs_score(CG_ALPHA_VS, seed + 4)

    println("  [T3] Covert patient: alpha=" + str(alpha_covert) + " Phi=" + str(phi_covert) + " CRS-R_behavioral=" + str(beh_score))
    println("  [T3] Genuine VS:     alpha=" + str(CG_ALPHA_VS) + " Phi=" + str(phi_genuine_vs) + " CRS-R=" + str(beh_vs))
    println("  [T3] MCS_threshold=" + str(CG_PHI_MCS_THRESH) + " VS_ceil=" + str(CG_CRS_VS_CEIL))

    // Neural Φ must exceed MCS threshold (covert consciousness detected)
    if phi_covert <= CG_PHI_MCS_THRESH {
        println("  [T3] FAIL: covert Phi below MCS threshold")
        return false
    }
    // Behavioral score must be in VS range (motor dissociation)
    if beh_score > CG_CRS_VS_CEIL {
        println("  [T3] FAIL: behavioral score escaped VS range")
        return false
    }
    // Genuine VS Φ must be below covert Φ — the covert patient IS more
    // conscious than the genuine VS, even though behavior says otherwise.
    if phi_genuine_vs >= phi_covert {
        println("  [T3] FAIL: genuine VS Phi >= covert Phi")
        return false
    }
    return true
}

fn check_T4() -> bool {
    // T4: CRS-R mapping — ordinal score monotonically correlated with Φ.
    // Sample CG_N_CORR evenly spaced alpha values, compute Φ and CRS-R,
    // measure rank-order concordance.
    let seed = 90004
    let mut phis = []
    let mut scores = []
    let mut i = 0
    while i < CG_N_CORR {
        let alpha = to_float(i) / to_float(CG_N_CORR - 1)
        let phi = cg_phi_at(alpha, seed + i * 47)
        let score = cg_crs_score(alpha, seed + i * 113)
        phis = phis.push(phi)
        scores = scores.push(to_float(score))
        println("  [T4] alpha=" + str(alpha) + " Phi=" + str(phi) + " CRS-R=" + str(score))
        i = i + 1
    }

    let conc = cg_concordance(phis, scores)
    println("  [T4] concordance=" + str(conc) + " floor=" + str(CG_SPEARMAN_FLOOR))

    if conc < CG_SPEARMAN_FLOOR { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Determinism + latency.
    // Same seed must produce identical Φ values across two runs.
    let seed = 90005
    let t_start = timestamp()

    // Run 1
    let phi_a_vs   = cg_phi_at(CG_ALPHA_VS,   seed + 1)
    let phi_a_mcs  = cg_phi_at(CG_ALPHA_MCS,  seed + 2)
    let phi_a_emcs = cg_phi_at(CG_ALPHA_EMCS, seed + 3)
    let phi_a_full = cg_phi_at(CG_ALPHA_FULL, seed + 4)

    // Run 2 — identical seeds
    let phi_b_vs   = cg_phi_at(CG_ALPHA_VS,   seed + 1)
    let phi_b_mcs  = cg_phi_at(CG_ALPHA_MCS,  seed + 2)
    let phi_b_emcs = cg_phi_at(CG_ALPHA_EMCS, seed + 3)
    let phi_b_full = cg_phi_at(CG_ALPHA_FULL, seed + 4)

    let t_end = timestamp()
    let elapsed = t_end - t_start

    println("  [T5] Run1: VS=" + str(phi_a_vs) + " MCS=" + str(phi_a_mcs) + " EMCS=" + str(phi_a_emcs) + " full=" + str(phi_a_full))
    println("  [T5] Run2: VS=" + str(phi_b_vs) + " MCS=" + str(phi_b_mcs) + " EMCS=" + str(phi_b_emcs) + " full=" + str(phi_b_full))
    println("  [T5] elapsed=" + str(elapsed) + "ms (limit=" + str(CG_MAX_MS) + "ms)")

    // Determinism: all values must match exactly
    if cg_abs(phi_a_vs - phi_b_vs) > CG_EPS { return false }
    if cg_abs(phi_a_mcs - phi_b_mcs) > CG_EPS { return false }
    if cg_abs(phi_a_emcs - phi_b_emcs) > CG_EPS { return false }
    if cg_abs(phi_a_full - phi_b_full) > CG_EPS { return false }

    // Latency
    if elapsed > CG_MAX_MS { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[consciousness_gradient_phi] P90 — Consciousness Gradient Phi (Giacino CRS-R)")
    println("  spectrum: VS (alpha=0) -> MCS (0.3) -> EMCS (0.6) -> full (1.0)")
    println("  K=" + str(CG_K) + " WIN=" + str(CG_WIN) + " BINS=" + str(CG_BINS))
    println("  refs: Giacino 2004 CRS-R | Owen 2006 covert | Monti 2010 | Schiff 2015")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — Phi ordering VS < MCS < EMCS < full (monotonic gradient)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — MCS fluctuation variance >> VS and full (intermittent awareness)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — covert consciousness: behavioral=VS but neural Phi > MCS threshold (cognitive motor dissociation)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — CRS-R score monotonically correlated with Phi (ordinal mapping)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism + latency within bounds") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: avoid long && chains — use sequential accumulator.
    let mut pc = 0
    if t1 { pc = pc + 1 }
    if t2 { pc = pc + 1 }
    if t3 { pc = pc + 1 }
    if t4 { pc = pc + 1 }
    if t5 { pc = pc + 1 }

    if pc == 5 {
        println("[consciousness_gradient_phi] 5/5 PASS — P90 DONE")
    } else {
        println("[consciousness_gradient_phi] " + str(pc) + "/5 PASS — SOME FAILED")
    }
}

main()
