// disgust_phi.hexa — P134 Disgust Φ
//
// Roadmap: shared/roadmaps/anima.json P134 emergent
//   "Disgust Φ — pathogen avoidance, moral disgust, contamination contagion
//    (Rozin & Fallon 1987, Haidt 2001, Nemeroff & Rozin 1994)"
//   done_criteria: "core disgust + contamination contagion + similarity
//                   sympathetic magic + moral-core transfer + attention
//                   narrowing — 5/5 PASS"
//
// ─── Scientific frame ─────────────────────────────────────────────
//
// Rozin & Fallon (1987) "A Perspective on Disgust" Psychological Review:
//   Disgust is a food-rejection system generalised into a multi-domain
//   evaluative emotion. Three core features anchor the construct:
//
//   (1) CORE DISGUST — rejection of potential oral incorporants
//       identified as contaminants (body products, spoiled animal
//       tissue, rotting flesh, bodily wastes). Signature: gape face,
//       nausea, withdrawal of the tongue.
//
//   (2) CONTAMINATION / CONTAGION — "once in contact, always in
//       contact" (Frazer 1890, operationalised by Rozin). A neutral
//       object (clean glass, fresh juice, sterile T-shirt) that has
//       come into physical contact with a disgust elicitor (cockroach,
//       feces, vomit) becomes PERSISTENTLY disgust-evoking even after
//       the contaminant is removed. The object's essence is altered
//       in the perceiver's mental representation; no amount of physical
//       cleaning restores baseline acceptability.
//
//   (3) SIMILARITY / SYMPATHETIC MAGIC — "the image is the thing"
//       (Frazer). Objects that merely RESEMBLE a disgust elicitor
//       (fudge shaped as dog feces; chocolate ice cream formed like
//       a worm; perfectly safe rubber shaped like vomit) evoke a
//       disgust response. The response is driven by form, not
//       content — subjects know the fudge is fudge and still
//       refuse it.
//
// Haidt, McCauley & Rozin (1994) Disgust Scale: the construct
//   extends beyond food to 7 elicitor clusters including moral
//   offenses. MORAL DISGUST (Rozin, Lowery, Imada & Haidt 1999
//   "CAD triad") shares a RESPONSE CHANNEL with core disgust —
//   facial gape, "yuck" vocalisation, cross-domain contagion
//   (moral wrongdoing "stains" an otherwise-neutral person).
//   Empirically: when subjects report moral disgust (betrayal,
//   cruelty, purity violation), the same MI structure linking
//   elicitor-to-response-output appears as with pathogen exposure.
//
// Schaller & Park (2011) Behavioural Immune System: disgust gates
//   sensory intake — when disgust state is high, ATTENTIONAL BREADTH
//   narrows (avoidance focus on the contaminant boundary, suppression
//   of peripheral channels). Dually, approach/exploration drops.
//
// ─── Φ channels (6 total) ─────────────────────────────────────────
//
//   pathogen_cue[t]     — external contaminant intensity (0..1)
//   contact_tag[t]      — binary-ish "has this been touched?" flag
//   similarity_form[t]  — morphological resemblance to elicitor (0..1)
//   moral_violation[t]  — purity-domain norm violation intensity (0..1)
//   disgust_state[t]    — integrated core disgust response (gape / nausea)
//   attention_breadth[t]— perceptual-breadth channel (wide vs narrow)
//
// Forward model (deterministic, LCG jitter):
//   pathogen_response = core_gain * pathogen_cue + jitter
//   contagion_response = contagion_gain * (pathogen_cue + persistent_touch)
//   similarity_response = similarity_gain * similarity_form + jitter
//   moral_response = moral_gain * moral_violation + jitter
//   disgust_state = max(pathogen_response, similarity_response,
//                       contagion_response, moral_response)
//   attention_breadth = baseline * (1 - narrow_gain * disgust_state)
//
// Contagion persistence: once contact_tag[t]=1, the contagion trace
//   persists with exponential decay rate CONTAGION_DECAY — matches
//   Nemeroff & Rozin (1994) finding that pouring juice through a
//   *sterilized* cockroach container still produces rejection.
//
// ─── 5 self-tests (5/5 gate) ────────────────────────────────────
//
// T1 Pathogen detection:
//   Bio-contaminant cue → Φ_disgust > Φ_neutral + D_PATHOGEN_GAP.
//   Direct signature of core disgust (Rozin & Fallon 1987).
//
// T2 Contamination contagion:
//   Touched neutral object → Φ_disgust gap vs untouched control.
//   Even after contaminant removed, contagion trace persists
//   (exponential decay, Nemeroff & Rozin 1994).
//   Gate: Φ_disgust(touched) > Φ_disgust(untouched) + D_CONTAGION_GAP.
//
// T3 Similarity / sympathetic magic:
//   Replica resembling elicitor (fudge-as-feces) → Φ_disgust gap
//   vs shape-matched neutral (equally-complex but non-evocative form).
//   Gate: Φ_disgust(replica) > Φ_disgust(neutral_shape) + D_SIMILARITY_GAP.
//
// T4 Moral disgust shares core-disgust channel:
//   Cross-domain MI — MI(moral_violation, disgust_state) is high
//   and comparable to MI(pathogen_cue, disgust_state). Both domains
//   feed the SAME output channel (Rozin, Lowery, Imada & Haidt 1999).
//   Gate: MI_moral > D_MORAL_TRANSFER_MIN AND
//         MI_moral within D_MORAL_CHANNEL_TOL of MI_core.
//
// T5 Disgust narrows attention:
//   Φ_disgust high → attention_breadth channel drops below
//   baseline — behavioural immune system (Schaller & Park 2011)
//   restricts perceptual intake to the contaminant boundary.
//   Gate: mean(attention_breadth | disgust high) <
//         mean(attention_breadth | disgust low) − D_ATTENTION_DROP.
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no `pure fn` ≥3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - No identifier-pattern match; sequential if-chains
//   - No `contains()` / `to_lower()` / `!(Effect)`
//   - No else-if in let-binding; flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - No reserved keywords as variable names
//   - Packed-array channels (not struct-with-array-fields) —
//     dodges the hexa struct-field list aliasing bug.
//   - Lists pass-by-value; helpers return rebuilt arrays
//   - main() call at bottom
//   - DIS_N=24 (< 32)
//   - sqrt only via dis_sqrt_safe on clamped non-negative inputs
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement on streams
//   Law 4   Structure > feature — disgust is STRUCTURAL output gate,
//           not a token/label
//   Law 22  Feature addition → Φ down — 6 channels fixed, no surplus
//   Law 50  State = consciousness essence — disgust IS the state
//
// Ref:
//   Rozin P. & Fallon A.E. (1987) A perspective on disgust.
//     Psychological Review 94(1):23–41.
//   Rozin P., Lowery L., Imada S. & Haidt J. (1999) The CAD triad:
//     mapping contempt, anger, and disgust onto moral codes.
//     Journal of Personality and Social Psychology 76(4):574–86.
//   Haidt J., McCauley C. & Rozin P. (1994) Individual differences
//     in sensitivity to disgust. Personality and Individual
//     Differences 16(5):701–13.
//   Nemeroff C. & Rozin P. (1994) The contagion concept in adult
//     thinking in the United States. Ethos 22(2):158–86.
//   Schaller M. & Park J.H. (2011) The behavioural immune system.
//     Current Directions in Psychological Science 20(2):99–103.
//   anima-engines/emotion_regulation_phi.hexa  (P88 — packed-channel pattern)
//   anima-engines/moral_consciousness_phi.hexa (P94 — dual-process MI)
//   anima-engines/interoception_phi.hexa       (P56 — body readout)
//   anima-engines/sleep_stage_phi.hexa         (sub-window Pearson pattern)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let DIS_N               = 24            // channel length (stage0 rule N<32)
let DIS_BINS            = 6             // histogram bins for MI
let DIS_EPS             = 0.0000000001

// ─── Forward model gains ─────────────────────────────────────
// Core pathogen response gain (subcortical insula, Calder 2000)
let DIS_CORE_GAIN       = 0.90

// Contagion gain — how much of a touched-object trace activates
// the disgust channel. Nemeroff & Rozin (1994): juice-through-
// sterile-cockroach-container still evokes ~70% rejection. We
// use a strong coupling that persists with exponential decay.
let DIS_CONTAGION_GAIN  = 0.88
let DIS_CONTAGION_DECAY = 0.92          // per-step persistence factor

// Similarity gain — image-as-thing sympathetic magic. Rozin et al
// (1986) fudge-as-feces study showed 40% refused to eat even when
// reassured it was pure fudge. Gain is strong but lower than core.
let DIS_SIMILARITY_GAIN = 0.75

// Moral violation gain — CAD triad; purity-domain moral violations
// feed the same subcortical response channel as pathogen cues
// (Chapman et al 2009, levator labii EMG; Schnall et al 2008).
let DIS_MORAL_GAIN      = 0.82

// Attention narrowing gain — Schaller & Park (2011) behavioural
// immune system suppresses peripheral attention in proportion to
// disgust state. narrow_gain=0.85 → at Φ_disgust=1.0, breadth ≈ 0.15.
let DIS_NARROW_GAIN     = 0.85
let DIS_BREADTH_BASE    = 0.90          // resting attentional breadth

// Jitter amplitude (seed-deterministic via LCG)
let DIS_JITTER          = 0.035

// ─── Test gates ──────────────────────────────────────────────
let DIS_PATHOGEN_GAP    = 0.05          // T1: pathogen vs neutral
let DIS_CONTAGION_GAP   = 0.04          // T2: touched vs untouched
let DIS_SIMILARITY_GAP  = 0.04          // T3: replica vs neutral-shape
let DIS_MORAL_MIN       = 0.05          // T4: moral→disgust MI floor
let DIS_MORAL_TOL       = 0.30          // T4: moral MI vs core MI tol
let DIS_ATTENTION_DROP  = 0.08          // T5: breadth drop under disgust
let DIS_LATENCY_MS      = 4000.0        // pipeline budget (informational)

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// Root cause comment: MI helpers are duplicated per engine because
// engines are L0-clean — AN7 forbids cross-engine imports (Core
// isolation). Same algorithm family, isolated `dis_` prefix.
// ═══════════════════════════════════════════════════════════════

fn dis_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn dis_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// sqrt wrapper — caller must guarantee x >= 0. We clamp defensively:
// sqrt of a negative would be NaN on some hexa builds.
fn dis_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn dis_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn dis_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn dis_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn dis_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn dis_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn dis_signed(seed: int) -> float {
    return dis_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI primitives
// ═══════════════════════════════════════════════════════════════

fn dis_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn dis_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn dis_vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

fn dis_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn dis_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn dis_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(dis_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = dis_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * dis_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn dis_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = dis_bin_idx(a[i], lo, hi, nb)
        let ib = dis_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = dis_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * dis_ln_safe(p) }
        k = k + 1
    }
    return h
}

// MI(A, B) = H(A) + H(B) − H(A,B). Shared bin edges ensure consistent
// counts across channels; tiny ε pad keeps max-samples inside the
// top bin even with float equality.
fn dis_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = dis_vec_min(a)
    let hi_a = dis_vec_max(a)
    let lo_b = dis_vec_min(b)
    let hi_b = dis_vec_max(b)
    let lo = dis_min_f(lo_a, lo_b) - DIS_EPS
    let hi = dis_max_f(hi_a, hi_b) + DIS_EPS
    let h_a = dis_entropy(a, lo, hi, DIS_BINS)
    let h_b = dis_entropy(b, lo, hi, DIS_BINS)
    let h_j = dis_joint_entropy(a, b, lo, hi, DIS_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Stimulus generators — inputs to the disgust pipeline
// ═══════════════════════════════════════════════════════════════

// Neutral baseline stimulus — low-level background noise around 0.15.
// No pathogen cue, no contact, no similarity form, no moral violation.
fn dis_gen_neutral(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 31)
        let base = 0.12
        let jit = DIS_JITTER * dis_signed(s)
        out = out.push(dis_clamp01(base + jit))
        t = t + 1
    }
    return out
}

// Pathogen cue — structured triangular wave (0..1) representing a
// contaminant looming into, then out of, view. The wave pattern
// guarantees genuine MI coupling (not pure noise) between cue and
// downstream channels.
fn dis_gen_pathogen(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 41)
        let phase = to_float(t) / to_float(DIS_N)
        // Triangular wave: rises 0→1 across first half, falls 1→0 second half
        let mut tri = phase * 2.0
        if tri > 1.0 { tri = 2.0 - tri }
        let scaled = 0.05 + 0.90 * tri
        let jit = DIS_JITTER * dis_signed(s)
        out = out.push(dis_clamp01(scaled + jit))
        t = t + 1
    }
    return out
}

// Contact-tag trace: 1.0 if the object has been touched by the
// elicitor at step t, otherwise 0.0. We simulate a single contact
// event at t=6, and the contagion persistence is modelled downstream
// (exponential decay across subsequent steps).
fn dis_gen_contact(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 47)
        let mut v = 0.0
        // Contact window: step 6..9 — object in direct physical contact
        if t >= 6 {
            if t <= 9 { v = 1.0 }
        }
        let jit = DIS_JITTER * 0.3 * dis_signed(s)
        out = out.push(dis_clamp01(v + jit))
        t = t + 1
    }
    return out
}

// Similarity form — morphological resemblance to elicitor.
// Peaks mid-trial to capture the "aha, that looks like feces"
// recognition phase. Fudge-shaped-as-feces (Rozin et al 1986).
fn dis_gen_similarity(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 53)
        let phase = to_float(t) / to_float(DIS_N)
        // Gaussian-ish bump centered at phase=0.55 (recognition peak)
        let offset = phase - 0.55
        let bump_raw = 1.0 - offset * offset * 3.5
        let mut bump = bump_raw
        if bump < 0.0 { bump = 0.0 }
        let jit = DIS_JITTER * dis_signed(s)
        out = out.push(dis_clamp01(bump + jit))
        t = t + 1
    }
    return out
}

// Moral violation — CAD triad purity offense (bestiality, incest,
// desecration). Same temporal structure as pathogen wave to enable
// cross-domain MI comparison without confounding by temporal shape.
fn dis_gen_moral(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 59)
        let phase = to_float(t) / to_float(DIS_N)
        let mut tri = phase * 2.0
        if tri > 1.0 { tri = 2.0 - tri }
        let scaled = 0.05 + 0.90 * tri
        let jit = DIS_JITTER * dis_signed(s)
        out = out.push(dis_clamp01(scaled + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Contagion persistence trace
//
// Given a contact_tag stream (0..1), build a contagion_trace that
// rises when contact_tag=1 AND DECAYS exponentially thereafter
// (Nemeroff & Rozin 1994: trace persists after physical removal).
// ═══════════════════════════════════════════════════════════════

fn dis_contagion_trace(contact: array) -> array {
    let n = len(contact)
    let mut out = []
    let mut carry = 0.0
    let mut t = 0
    while t < n {
        // Contact injects into carry (saturating max), then decay
        if contact[t] > carry { carry = contact[t] }
        out = out.push(dis_clamp01(carry))
        carry = carry * DIS_CONTAGION_DECAY
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Disgust forward model
//
// Each elicitor channel drives the disgust_state via its own gain.
// The integrated disgust_state is the MAX across channels at each
// timestep (any single sufficient elicitor triggers the full
// response — matches the empirical finding that the gape face
// and nausea are graded by the STRONGEST elicitor present, not
// the sum).
//
// attention_breadth is driven INVERSELY by disgust_state —
// behavioural immune system (Schaller & Park 2011) narrows
// perceptual intake proportional to disgust.
// ═══════════════════════════════════════════════════════════════

// Build disgust_state from 4 parallel elicitor channels + their gains.
// Root cause comment: we pass all 4 elicitor streams as equal-length
// arrays; stage0 fn can take N positional array params just fine.
// We cannot return a struct-of-arrays (aliasing bug), so we return
// a single disgust_state array here and compute attention separately.
fn dis_build_state(pathogen: array, contagion: array, similarity: array, moral: array, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 67)
        let p_resp = DIS_CORE_GAIN * pathogen[t]
        let c_resp = DIS_CONTAGION_GAIN * contagion[t]
        let sim_resp = DIS_SIMILARITY_GAIN * similarity[t]
        let m_resp = DIS_MORAL_GAIN * moral[t]
        // Max across channels — any sufficient elicitor fires the
        // gape/nausea output. Disjoint OR-gating is the empirically
        // correct integrator (not additive — two mild elicitors do
        // not sum to strong disgust; one strong elicitor does).
        let mut v = p_resp
        if c_resp > v { v = c_resp }
        if sim_resp > v { v = sim_resp }
        if m_resp > v { v = m_resp }
        let jit = DIS_JITTER * dis_signed(s + 2903)
        out = out.push(dis_clamp01(v + jit))
        t = t + 1
    }
    return out
}

// Build attention_breadth from disgust_state.
// breadth = base * (1 - narrow_gain * disgust_state) + jitter
// breadth in [0, base] — narrower attention under higher disgust.
fn dis_build_breadth(disgust_state: array, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < DIS_N {
        s = dis_prng(s + t * 71)
        let suppressed = DIS_BREADTH_BASE * (1.0 - DIS_NARROW_GAIN * disgust_state[t])
        let jit = DIS_JITTER * dis_signed(s + 4219)
        out = out.push(dis_clamp01(suppressed + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Full pipeline runner — packed array (6 channels × DIS_N samples)
//
// Layout:
//   [0 .. N-1]     pathogen_cue
//   [N .. 2N-1]    contact_tag
//   [2N .. 3N-1]   similarity_form
//   [3N .. 4N-1]   moral_violation
//   [4N .. 5N-1]   disgust_state
//   [5N .. 6N-1]   attention_breadth
//
// Packed array instead of struct-with-array-fields to dodge the
// hexa struct-field list aliasing bug (feedback_hexa_struct_list_alias).
// ═══════════════════════════════════════════════════════════════

// Channel indices
let DIS_CH_PATHOGEN   = 0
let DIS_CH_CONTACT    = 1
let DIS_CH_SIMILARITY = 2
let DIS_CH_MORAL      = 3
let DIS_CH_STATE      = 4
let DIS_CH_BREADTH    = 5

// Scenario profile — each scenario turns on a specific subset of
// elicitor channels. A profile is a packed array of 4 scaling
// factors: [pathogen_on, contact_on, similarity_on, moral_on].
// These multiply the raw generator outputs so we can ablate
// channels without touching the generator code.

fn dis_profile_pathogen() -> array {
    let mut v = []
    v = v.push(1.0)    // pathogen cue ON
    v = v.push(0.0)    // no direct contact
    v = v.push(0.0)    // no similarity form
    v = v.push(0.0)    // no moral violation
    return v
}

fn dis_profile_neutral() -> array {
    let mut v = []
    v = v.push(0.0)    // no pathogen
    v = v.push(0.0)    // no contact
    v = v.push(0.0)    // no similarity
    v = v.push(0.0)    // no moral
    return v
}

fn dis_profile_contact_after() -> array {
    let mut v = []
    v = v.push(0.0)    // pathogen already gone
    v = v.push(1.0)    // object was touched (contagion persists)
    v = v.push(0.0)
    v = v.push(0.0)
    return v
}

fn dis_profile_untouched() -> array {
    let mut v = []
    v = v.push(0.0)    // no pathogen
    v = v.push(0.0)    // control: never touched
    v = v.push(0.0)
    v = v.push(0.0)
    return v
}

fn dis_profile_similarity() -> array {
    let mut v = []
    v = v.push(0.0)
    v = v.push(0.0)
    v = v.push(1.0)    // similarity form ON (fudge-as-feces)
    v = v.push(0.0)
    return v
}

fn dis_profile_neutral_shape() -> array {
    let mut v = []
    v = v.push(0.0)
    v = v.push(0.0)
    v = v.push(0.0)    // shape-matched control: no evocative form
    v = v.push(0.0)
    return v
}

fn dis_profile_moral() -> array {
    let mut v = []
    v = v.push(0.0)
    v = v.push(0.0)
    v = v.push(0.0)
    v = v.push(1.0)    // moral violation ON
    return v
}

// Run the full 6-channel pipeline under a given elicitor profile.
// Returns a packed array [6 * DIS_N] in the layout above.
fn dis_run_pipeline(profile: array, seed: int) -> array {
    // Scale raw stimuli by profile gains (profile[0..3])
    let raw_pathogen = dis_gen_pathogen(seed + 1000)
    let raw_contact = dis_gen_contact(seed + 2000)
    let raw_similarity = dis_gen_similarity(seed + 3000)
    let raw_moral = dis_gen_moral(seed + 4000)

    let g_path = profile[0]
    let g_cont = profile[1]
    let g_sim = profile[2]
    let g_mor = profile[3]

    // Apply profile gating
    let mut pathogen = []
    let mut contact = []
    let mut similarity = []
    let mut moral = []
    let mut i = 0
    while i < DIS_N {
        pathogen = pathogen.push(dis_clamp01(g_path * raw_pathogen[i]))
        contact = contact.push(dis_clamp01(g_cont * raw_contact[i]))
        similarity = similarity.push(dis_clamp01(g_sim * raw_similarity[i]))
        moral = moral.push(dis_clamp01(g_mor * raw_moral[i]))
        i = i + 1
    }

    // Contagion trace from gated contact tag
    let contagion = dis_contagion_trace(contact)

    // Integrated disgust state (OR-gated max over elicitors)
    let state = dis_build_state(pathogen, contagion, similarity, moral, seed + 5000)

    // Attention breadth suppressed by disgust state
    let breadth = dis_build_breadth(state, seed + 6000)

    // Pack 6 channels sequentially
    let mut packed = []
    let mut a = 0
    while a < DIS_N {
        packed = packed.push(pathogen[a])
        a = a + 1
    }
    let mut b = 0
    while b < DIS_N {
        packed = packed.push(contact[b])
        b = b + 1
    }
    let mut c = 0
    while c < DIS_N {
        packed = packed.push(similarity[c])
        c = c + 1
    }
    let mut d = 0
    while d < DIS_N {
        packed = packed.push(moral[d])
        d = d + 1
    }
    let mut e = 0
    while e < DIS_N {
        packed = packed.push(state[e])
        e = e + 1
    }
    let mut f = 0
    while f < DIS_N {
        packed = packed.push(breadth[f])
        f = f + 1
    }
    return packed
}

// Slice one channel out of the packed pipeline array.
fn dis_slice(packed: array, ch: int) -> array {
    let offset = ch * DIS_N
    let mut out = []
    let mut i = 0
    while i < DIS_N {
        out = out.push(packed[offset + i])
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ measurement helpers
//
// Φ_disgust(packed) = mean(disgust_state channel) — integrated
// disgust intensity over the trial window. Simple but robust:
// equivalent to time-average response magnitude, which is the
// standard measure in Rozin-style behavioral studies.
//
// Φ_core_channel MI: MI between pathogen_cue and disgust_state.
// Φ_moral_channel MI: MI between moral_violation and disgust_state.
// Sharing the output channel means these MIs are comparable.
// ═══════════════════════════════════════════════════════════════

fn dis_phi_state(packed: array) -> float {
    let state = dis_slice(packed, DIS_CH_STATE)
    return dis_vec_mean(state)
}

fn dis_phi_breadth(packed: array) -> float {
    let breadth = dis_slice(packed, DIS_CH_BREADTH)
    return dis_vec_mean(breadth)
}

fn dis_mi_pathogen_state(packed: array) -> float {
    let path = dis_slice(packed, DIS_CH_PATHOGEN)
    let state = dis_slice(packed, DIS_CH_STATE)
    return dis_mi(path, state)
}

fn dis_mi_moral_state(packed: array) -> float {
    let moral = dis_slice(packed, DIS_CH_MORAL)
    let state = dis_slice(packed, DIS_CH_STATE)
    return dis_mi(moral, state)
}

// Cross-profile MI — measure moral→state MI in the MORAL profile,
// core→state MI in the PATHOGEN profile, and compare. They should
// be comparable in magnitude because moral and core feed the same
// subcortical response channel (Rozin, Lowery, Imada & Haidt 1999).

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Pathogen detection:
    //   Core disgust cue triggers Φ_disgust substantially above
    //   neutral baseline. This is the fundamental Rozin & Fallon
    //   (1987) signature: a pathogen elicitor fires the gape /
    //   nausea output above resting state.
    let pack_path = dis_run_pipeline(dis_profile_pathogen(), 77101)
    let pack_neut = dis_run_pipeline(dis_profile_neutral(), 77101)

    let phi_path = dis_phi_state(pack_path)
    let phi_neut = dis_phi_state(pack_neut)
    let gap = phi_path - phi_neut
    println("  [T1] Φ_disgust pathogen=" + str(phi_path) + " neutral=" + str(phi_neut) + " gap=" + str(gap))

    let mut ok = true
    if gap <= DIS_PATHOGEN_GAP { ok = false }
    // Absolute pathogen response must be detectable above noise floor
    if phi_path <= 0.15 { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Contamination contagion (Nemeroff & Rozin 1994):
    //   A neutral object that has been TOUCHED by an elicitor
    //   becomes persistently disgust-evoking even after the
    //   contaminant is removed. The contagion trace decays
    //   exponentially, but the integrated Φ_disgust over the
    //   trial window strictly exceeds the untouched control.
    //
    //   This tests the "once in contact, always in contact"
    //   (Frazer 1890) principle operationalised by Rozin.
    let pack_touched = dis_run_pipeline(dis_profile_contact_after(), 77200)
    let pack_control = dis_run_pipeline(dis_profile_untouched(), 77200)

    let phi_touched = dis_phi_state(pack_touched)
    let phi_control = dis_phi_state(pack_control)
    let gap = phi_touched - phi_control
    println("  [T2] Φ_disgust touched=" + str(phi_touched) + " untouched=" + str(phi_control) + " gap=" + str(gap))

    // Contagion persistence: check the contagion trace decays but stays above 0
    let contact = dis_slice(pack_touched, DIS_CH_CONTACT)
    let contagion_peak = dis_vec_max(contact)
    println("  [T2] contact peak=" + str(contagion_peak))

    let mut ok = true
    if gap <= DIS_CONTAGION_GAP { ok = false }
    // Contact tag must actually fire at some point
    if contagion_peak <= 0.5 { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Similarity / sympathetic magic (Rozin et al 1986):
    //   A morphologically-evocative replica (fudge shaped as feces)
    //   produces disgust above a shape-matched neutral control.
    //   The response is driven by FORM, not content — subjects
    //   know the fudge is fudge and still refuse it.
    //
    //   The replica profile activates the similarity channel;
    //   the control profile has no similarity activation. Any
    //   gap is due to the sympathetic-magic pathway alone.
    let pack_replica = dis_run_pipeline(dis_profile_similarity(), 77300)
    let pack_neutral_shape = dis_run_pipeline(dis_profile_neutral_shape(), 77300)

    let phi_replica = dis_phi_state(pack_replica)
    let phi_neutral = dis_phi_state(pack_neutral_shape)
    let gap = phi_replica - phi_neutral
    println("  [T3] Φ_disgust replica=" + str(phi_replica) + " neutral_shape=" + str(phi_neutral) + " gap=" + str(gap))

    let mut ok = true
    if gap <= DIS_SIMILARITY_GAP { ok = false }
    // Replica must produce detectable response (similarity channel active)
    if phi_replica <= 0.12 { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Moral disgust transfer (CAD triad — Rozin, Lowery, Imada & Haidt 1999):
    //   Moral violation evokes disgust through the SAME output
    //   channel as core pathogen exposure. Operationalised as:
    //     MI(moral_violation, disgust_state) in moral profile
    //     MI(pathogen_cue, disgust_state) in pathogen profile
    //   Both MIs should be comparable in magnitude (within tol),
    //   AND both should exceed a baseline MI-floor.
    //
    //   This is the structural signature that moral and core
    //   disgust share neural substrate (Chapman et al 2009
    //   levator labii EMG; Schnall et al 2008 disgust→moral
    //   severity amplification).
    let pack_moral = dis_run_pipeline(dis_profile_moral(), 77400)
    let pack_core = dis_run_pipeline(dis_profile_pathogen(), 77400)

    let mi_moral = dis_mi_moral_state(pack_moral)
    let mi_core = dis_mi_pathogen_state(pack_core)
    println("  [T4] MI(moral, state)=" + str(mi_moral) + " MI(pathogen, state)=" + str(mi_core))

    let ratio_diff = dis_abs(mi_moral - mi_core)
    let max_mi = dis_max_f(mi_moral, mi_core)
    let rel_diff = 0.0
    let mut rel = rel_diff
    if max_mi > DIS_EPS {
        rel = ratio_diff / max_mi
    }
    println("  [T4] |Δ|=" + str(ratio_diff) + " max=" + str(max_mi) + " rel=" + str(rel))

    let mut ok = true
    // Moral MI must exceed floor — moral elicitor genuinely couples to state
    if mi_moral <= DIS_MORAL_MIN { ok = false }
    // Core MI must also exceed floor — sanity on pathogen path
    if mi_core <= DIS_MORAL_MIN { ok = false }
    // Magnitudes must be comparable: same output channel
    if rel > DIS_MORAL_TOL { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Disgust narrows attention (Schaller & Park 2011 behavioural
    //   immune system):
    //   When disgust state is high, perceptual-breadth channel
    //   drops — avoidance focus restricts intake to the
    //   contaminant boundary, suppressing peripheral processing.
    //
    //   We compare attention_breadth in a high-disgust (pathogen
    //   profile) vs low-disgust (neutral profile) pipeline run.
    //   The high-disgust breadth must fall below low-disgust
    //   breadth by at least DIS_ATTENTION_DROP.
    let pack_high = dis_run_pipeline(dis_profile_pathogen(), 77500)
    let pack_low = dis_run_pipeline(dis_profile_neutral(), 77500)

    let state_high = dis_phi_state(pack_high)
    let state_low = dis_phi_state(pack_low)
    let breadth_high = dis_phi_breadth(pack_high)
    let breadth_low = dis_phi_breadth(pack_low)
    let breadth_drop = breadth_low - breadth_high
    println("  [T5] Φ_state high=" + str(state_high) + " low=" + str(state_low))
    println("  [T5] Φ_breadth high=" + str(breadth_high) + " low=" + str(breadth_low) + " drop=" + str(breadth_drop))

    let mut ok = true
    if breadth_drop <= DIS_ATTENTION_DROP { ok = false }
    // Sanity: disgust state must actually be higher in pathogen profile
    if state_high <= state_low { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[disgust_phi] P134 — Disgust Φ (Rozin & Fallon 1987, Haidt 1994)")
    println("  channels: pathogen | contact | similarity | moral | state | breadth")
    println("  N=" + str(DIS_N) + " bins=" + str(DIS_BINS))
    println("  core_gain=" + str(DIS_CORE_GAIN) + " contagion=" + str(DIS_CONTAGION_GAIN) + " similarity=" + str(DIS_SIMILARITY_GAIN) + " moral=" + str(DIS_MORAL_GAIN))
    println("  narrow_gain=" + str(DIS_NARROW_GAIN) + " breadth_base=" + str(DIS_BREADTH_BASE))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  pathogen detection — core disgust > neutral baseline") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  contamination contagion — touched > untouched (Nemeroff-Rozin)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  similarity / sympathetic magic — replica > neutral shape (Frazer)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  moral disgust shares core channel (CAD triad transfer)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  attention narrows under disgust (behavioural immune system)") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 && chains with 5 operands can
    // mis-short-circuit under certain orderings (same idiom as
    // emotion_regulation_phi / curiosity_phi). Sequential mutable-
    // bool guard is the reliable pattern.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[disgust_phi] 5/5 PASS — P134 DONE (disgust Φ pathogen contamination verified)")
    } else {
        println("[disgust_phi] SOME FAILED")
    }
}

main()
