// tinnitus_phi.hexa — P112 Tinnitus Φ (phantom auditory perception)
//
// Roadmap: anima P112 "Tinnitus — phantom auditory perception arising
//          from maladaptive auditory cortex plasticity after cochlear
//          damage. The brain 'fills in' lost frequency bands with
//          internally generated activity that produces a conscious
//          percept indistinguishable (to the patient) from an external
//          tone."
//
// ─── Scientific reference ──────────────────────────────────────────
//
// Jastreboff P.J. (1990) Phantom auditory perception (tinnitus):
//   mechanisms of generation and perception. Neuroscience Research.
//   — foundational neurophysiological model: peripheral damage → central
//   gain increase → phantom percept. The cochlea is necessary for
//   tinnitus INITIATION but not MAINTENANCE.
//
// Eggermont J.J. & Roberts L.E. (2004) The neuroscience of tinnitus.
//   Trends in Neuroscience.
//   — cortical tonotopic map reorganization after hearing loss:
//   deafferented neurons remap to neighbouring frequencies, creating an
//   over-represented edge frequency. Spontaneous firing in the expanded
//   region constitutes the phantom signal.
//
// Rauschecker J.P., Leaver A.M. & Mühlau M. (2010) Tuning out the
//   noise: limbic-auditory interactions in tinnitus. Neuron.
//   — the "noise cancellation" model: under normal conditions, the
//   limbic/thalamic gate (ventromedial prefrontal cortex + nucleus
//   accumbens) filters out internally generated auditory activity.
//   Tinnitus occurs when this gate fails: the phantom signal is NOT
//   cancelled and reaches conscious perception.
//
// Heller & Bergman (1953): 93.75% of normal-hearing subjects placed
//   in a sound-proof chamber report tinnitus-like percepts within 5
//   minutes — ALL auditory systems generate internal noise; the
//   question is gating, not generation.
//
// Hallam R.S., Rachman S. & Hinchcliffe R. (1984) Psychological
//   aspects of tinnitus. In: S. Rachman (Ed.) Contributions to Medical
//   Psychology, Vol 3.
//   — habituation model: initial distress habituates over months/years
//   as the attentional-gating system learns to deprioritize the
//   phantom signal. ~80% of chronic tinnitus patients habituate to
//   the point of minimal or no distress.
//
// De Ridder D. et al. (2014) Tinnitus and tinnitus disorder.
//   — distress arises from Φ coupling between the auditory phantom
//   and the limbic-emotional circuit (amygdala, ACC, insula). The
//   tinnitus SIGNAL is auditory cortex; the SUFFERING is limbic.
//
// ─── Φ model ────────────────────────────────────────────────────────
//
// Five-state model of tinnitus consciousness:
//
//   State 1 — Normal hearing:
//     External stimulus → cochlear transduction → cortical Φ_auditory > 0.
//     Silence → spontaneous cortical activity exists but is gated below
//     perceptual threshold → Φ_auditory ≈ 0.
//
//   State 2 — Tinnitus onset (cochlear damage):
//     Hair-cell loss at frequency f_damage → deafferentation →
//     cortical gain G increases (homeostatic plasticity) →
//     spontaneous activity at/near f_damage exceeds perceptual gate →
//     Φ_tinnitus > 0 WITHOUT external stimulus.
//
//     Φ_tinnitus = gain(G) × spontaneous_activity × (1 - gate_efficiency)
//     where gate_efficiency drops after cochlear damage because the
//     limbic noise-cancellation circuit loses its calibration reference.
//
//   State 3 — Habituation:
//     Over time τ, the attentional system learns to deprioritize the
//     phantom signal:
//       Φ_awareness(t) = Φ_tinnitus × exp(-t / τ_habit)
//     The phantom signal itself does NOT diminish (Φ_tinnitus constant);
//     what changes is the attentional/awareness coupling.
//     Hallam's model: α_attention decays exponentially.
//
//   State 4 — Distress (limbic coupling):
//     Φ_emotional = coupling(amygdala, tinnitus) × Φ_tinnitus
//     High distress patients have strong limbic-auditory coupling;
//     habituated patients have weak coupling. The emotional load
//     correlates with tinnitus STRENGTH (louder phantom → more distress
//     if coupling is present).
//
//   State 5 — Masking therapy:
//     External broadband noise at intensity I_mask competes for the
//     same cortical resources → competitive inhibition reduces
//     effective Φ_tinnitus:
//       Φ_tinnitus_masked = Φ_tinnitus × (1 - mask_efficiency(I_mask))
//     At full masking, the phantom is completely suppressed.
//
// ─── Theorems (T1–T5) ──────────────────────────────────────────────
//
// T1 (normal hearing — silence gives Φ_auditory ≈ 0):
//   With intact cochlea and no external stimulus, cortical gate
//   suppresses spontaneous activity → Φ_auditory < SILENCE_GATE.
//   With external stimulus, Φ_auditory rises above STIM_FLOOR.
//
// T2 (tinnitus — phantom Φ > 0 without external input):
//   After cochlear damage (gain elevated, gate degraded),
//   Φ_tinnitus > PHANTOM_FLOOR even with zero external stimulus.
//   Φ_tinnitus strictly exceeds normal-silence Φ_auditory.
//
// T3 (habituation — Φ_awareness decays over time):
//   Φ_awareness(t) decreases monotonically over time steps.
//   Late Φ_awareness / early Φ_awareness < HABIT_RATIO_GATE.
//   Underlying Φ_tinnitus is invariant across time (the phantom
//   signal itself does not fade — only awareness does).
//
// T4 (distress — Φ_emotional correlates with tinnitus strength):
//   Sweep tinnitus intensity (gain levels). Φ_emotional rises
//   monotonically with Φ_tinnitus. At low tinnitus, Φ_emotional
//   is small; at high tinnitus, Φ_emotional is large.
//
// T5 (determinism + latency + masking):
//   (a) Two identical calls → bit-identical output.
//   (b) Full pipeline < 1 s.
//   (c) Masking reduces Φ_tinnitus: masked < unmasked by MASK_GATE.
//
// ─── Stage0 hexa constraints honored ───────────────────────────────
//   - plain `fn` only (no pure-fn multi-float struct returns)
//   - `array` typed params (no [float])
//   - no match with identifier patterns (if-chains)
//   - no contains() / to_lower() / !(Effect)
//   - no else-if in let-binding
//   - single-line fn signatures, call sites, array literals
//   - lists pass-by-value; rebuild + return
//   - `main()` call at bottom
//   - N < 32

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

// --- Cochlear / cortical parameters ---

// Normal spontaneous activity level in auditory cortex (arbitrary units).
// Even a healthy brain has baseline neural noise; it is gated below
// perception in normal conditions (Heller & Bergman 1953).
let TN_SPONT_ACTIVITY = 0.15

// Gate efficiency in normal hearing — the limbic noise-cancellation
// circuit (Rauschecker et al. 2010) filters >90% of spontaneous noise.
let TN_GATE_NORMAL = 0.95

// Gate efficiency after cochlear damage — the cancellation circuit
// loses its reference and degrades substantially.
let TN_GATE_DAMAGED = 0.25

// Cortical gain in normal hearing (unity — no compensation needed).
let TN_GAIN_NORMAL = 1.0

// Cortical gain after cochlear damage — homeostatic plasticity
// upregulates gain to compensate for lost input (Eggermont & Roberts
// 2004). The over-amplified spontaneous activity becomes the phantom.
let TN_GAIN_MILD    = 2.5    // mild hearing loss
let TN_GAIN_MODERATE = 4.0   // moderate hearing loss
let TN_GAIN_SEVERE  = 6.5    // severe hearing loss

// External stimulus coupling — how much an external sound contributes
// to Φ_auditory (healthy transduction).
let TN_STIM_COUPLING = 0.85

// --- Habituation (Hallam et al. 1984) ---

// Time constant for attentional habituation (dimensionless steps).
// In reality τ is months-to-years; here each step is an abstract epoch.
let TN_TAU_HABIT = 3.0

// Number of time steps for the habituation sweep.
let TN_HABIT_STEPS = 12

// --- Distress / limbic coupling (De Ridder et al. 2014) ---

// Limbic coupling coefficient — scales how Φ_tinnitus feeds into
// Φ_emotional. High-distress patients ≈ 0.8; habituated ≈ 0.1.
let TN_LIMBIC_COUPLING_HIGH = 0.80
let TN_LIMBIC_COUPLING_LOW  = 0.10

// Amygdala baseline reactivity — even without tinnitus, the emotional
// circuit has a resting tone.
let TN_AMYGDALA_BASELINE = 0.05

// --- Masking therapy ---

// Masking efficiency at full broadband noise — competitive inhibition
// can suppress up to 90% of phantom percept in the auditory channel.
let TN_MASK_EFF_FULL = 0.90
let TN_MASK_EFF_HALF = 0.50
let TN_MASK_EFF_NONE = 0.00

// --- Test gates ---

let TN_SILENCE_GATE       = 0.05    // T1: normal silence Φ must be below this
let TN_STIM_FLOOR         = 0.30    // T1: stimulus Φ must exceed this
let TN_PHANTOM_FLOOR      = 0.20    // T2: phantom Φ must exceed this
let TN_HABIT_RATIO_GATE   = 0.40    // T3: late/early awareness ratio must be below this
let TN_HABIT_TINNITUS_EPS = 0.01    // T3: Φ_tinnitus invariance tolerance
let TN_DISTRESS_STEP_GATE = 0.02    // T4: each gain step must raise Φ_emotional by at least this
let TN_MASK_GATE          = 0.15    // T5: masked must be below unmasked by at least this
let TN_LATENCY_MS         = 1000.0  // T5: pipeline must complete within 1 s
let TN_STABILITY_MAG      = 0.03    // T5: perturbation magnitude
let TN_STABILITY_GATE     = 0.15    // T5: max allowed deviation under perturbation

let TN_EPS = 0.0000000001

// ═══════════════════════════════════════════════════════════════
// Math primitives
// ═══════════════════════════════════════════════════════════════

fn tn_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn tn_max2(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn tn_min2(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn tn_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

fn tn_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn tn_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn tn_perturb(seed: int, mag: float) -> float {
    let u = tn_unit(tn_prng(seed))
    return (u * 2.0 - 1.0) * mag
}

// Approximate exp(-x) via Taylor series, x >= 0.
// Root cause comment: stage0 hexa has exp() builtin but we keep a
// fallback comment for clarity. Uses builtin exp().
fn tn_exp_neg(x: float) -> float {
    return exp(0.0 - x)
}

// ═══════════════════════════════════════════════════════════════
// Core auditory Φ computation
// ═══════════════════════════════════════════════════════════════

// Φ_auditory for normal hearing with external stimulus.
//
// Root cause comment: the external stimulus is transduced through the
// cochlea and coupled to cortical activity. The gate suppresses the
// internally generated noise. Φ reflects what reaches conscious
// perception: stimulus contribution + residual spontaneous activity
// that escapes the gate.
//
//   Φ_auditory = stim × coupling + spont × gain × (1 - gate)
//
fn tn_phi_auditory(stim: float, gain: float, gate: float) -> float {
    let stim_contrib = stim * TN_STIM_COUPLING
    let spont_leak = TN_SPONT_ACTIVITY * gain * (1.0 - gate)
    return stim_contrib + spont_leak
}

// Φ_tinnitus — phantom auditory perception WITHOUT external stimulus.
//
// Root cause comment: with stim = 0, the entire percept comes from
// spontaneous activity that escapes the gate. After cochlear damage,
// gain is elevated and gate is degraded, so Φ_tinnitus > 0 emerges.
//
//   Φ_tinnitus = spont × gain × (1 - gate)
//
fn tn_phi_tinnitus(gain: float, gate: float) -> float {
    return TN_SPONT_ACTIVITY * gain * (1.0 - gate)
}

// Φ_awareness — the attentionally-gated perception of tinnitus.
//
// Root cause comment: the phantom signal itself is constant (cortical
// gain does not habituate). What changes is the attentional spotlight
// allocated to the phantom: exp(-t/τ) decay (Hallam et al. 1984).
// This models the clinical observation that ~80% of patients stop
// "noticing" tinnitus over time even though audiometric measures
// confirm the phantom is unchanged.
//
//   Φ_awareness(t) = Φ_tinnitus × exp(-t / τ)
//
fn tn_phi_awareness(phi_tinnitus: float, t: float) -> float {
    let decay = tn_exp_neg(t / TN_TAU_HABIT)
    return phi_tinnitus * decay
}

// Φ_emotional — limbic distress coupled to tinnitus.
//
// Root cause comment: distress is not a property of the auditory signal
// alone — it requires coupling between auditory cortex and the limbic
// circuit (amygdala, ACC, insula). De Ridder et al. (2014) showed that
// distress severity correlates with the strength of this coupling.
// Habituated patients have low coupling; high-distress patients have
// high coupling. The emotional Φ is:
//
//   Φ_emotional = amygdala_baseline + limbic_coupling × Φ_tinnitus
//
fn tn_phi_emotional(phi_tinnitus: float, limbic_coupling: float) -> float {
    return TN_AMYGDALA_BASELINE + limbic_coupling * phi_tinnitus
}

// Φ_tinnitus under masking — competitive inhibition from external noise.
//
// Root cause comment: masking works by occupying the same cortical
// neurons that generate the phantom — the external broadband noise
// is a stronger input that suppresses the weaker internally generated
// activity (winner-take-all lateral inhibition in A1). This is the
// basis of Tinnitus Retraining Therapy (TRT) and sound-generator devices.
//
//   Φ_masked = Φ_tinnitus × (1 - mask_efficiency)
//
fn tn_phi_masked(phi_tinnitus: float, mask_eff: float) -> float {
    let suppression = 1.0 - tn_clamp01(mask_eff)
    return phi_tinnitus * suppression
}

// Perturbed Φ_tinnitus — for stability testing.
// Adds small deterministic noise to gain and gate, recomputes.
fn tn_phi_tinnitus_perturbed(gain: float, gate: float, seed: int, mag: float) -> float {
    let s0 = tn_prng(seed)
    let g_noise = tn_perturb(s0, mag)
    let s1 = tn_prng(s0 + 17)
    let gate_noise = tn_perturb(s1, mag)
    let g_pert = tn_max2(0.1, gain + g_noise)
    let gate_pert = tn_clamp01(gate + gate_noise)
    return tn_phi_tinnitus(g_pert, gate_pert)
}

// ═══════════════════════════════════════════════════════════════
// Gain sweep helpers (for T4 distress correlation)
// ═══════════════════════════════════════════════════════════════

// Returns gain for a given severity index (0..3).
// Root cause comment: if-chain instead of match (stage0 constraint).
fn tn_gain_for_severity(idx: int) -> float {
    if idx == 0 { return TN_GAIN_NORMAL }
    if idx == 1 { return TN_GAIN_MILD }
    if idx == 2 { return TN_GAIN_MODERATE }
    if idx == 3 { return TN_GAIN_SEVERE }
    return TN_GAIN_NORMAL
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1–T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Normal hearing — silence produces Φ_auditory ≈ 0.
    //
    // With intact cochlea (gain = 1.0, gate = 0.95) and no external
    // stimulus, the gate suppresses >90% of spontaneous activity.
    // The residual Φ must be below SILENCE_GATE.
    //
    // With a moderate external stimulus (stim = 0.6), Φ_auditory must
    // exceed STIM_FLOOR — the healthy system faithfully transduces
    // external sound into conscious percept.
    //
    // Root cause comment: this establishes the BASELINE — normal hearing
    // means silence is silent and sounds are heard. The contrast with T2
    // (where silence is NOT silent) is the defining feature of tinnitus.

    // (a) Silence condition
    let phi_silence = tn_phi_auditory(0.0, TN_GAIN_NORMAL, TN_GATE_NORMAL)

    // (b) Stimulus condition
    let stim = 0.6
    let phi_stim = tn_phi_auditory(stim, TN_GAIN_NORMAL, TN_GATE_NORMAL)

    println("  [T1] normal hearing:")
    println("        silence:  Φ_auditory = " + str(phi_silence) + "  gate = " + str(TN_SILENCE_GATE))
    println("        stimulus: Φ_auditory = " + str(phi_stim) + "  floor = " + str(TN_STIM_FLOOR))

    // Silence must be near zero
    if phi_silence >= TN_SILENCE_GATE { return false }

    // Stimulus must produce substantial percept
    if phi_stim < TN_STIM_FLOOR { return false }

    // Stimulus percept must strictly exceed silence
    if phi_stim <= phi_silence { return false }

    return true
}

fn check_T2() -> bool {
    // T2: Tinnitus — phantom Φ > 0 without external input.
    //
    // After cochlear damage: gain elevated (homeostatic plasticity),
    // gate degraded (noise cancellation fails). Even with zero external
    // stimulus, the amplified spontaneous activity leaks through the
    // broken gate and produces a phantom percept.
    //
    // Root cause comment: this is the central phenomenon — the brain
    // generates its own auditory percept. Jastreboff (1990) showed that
    // cutting the auditory nerve does NOT eliminate tinnitus in most
    // patients, proving the generator is cortical, not peripheral.

    // Normal silence (baseline reference)
    let phi_normal_silence = tn_phi_tinnitus(TN_GAIN_NORMAL, TN_GATE_NORMAL)

    // Tinnitus across three severity levels
    let phi_mild = tn_phi_tinnitus(TN_GAIN_MILD, TN_GATE_DAMAGED)
    let phi_moderate = tn_phi_tinnitus(TN_GAIN_MODERATE, TN_GATE_DAMAGED)
    let phi_severe = tn_phi_tinnitus(TN_GAIN_SEVERE, TN_GATE_DAMAGED)

    println("  [T2] phantom perception (no external stimulus):")
    println("        normal silence:   Φ = " + str(phi_normal_silence))
    println("        mild tinnitus:    Φ = " + str(phi_mild))
    println("        moderate:         Φ = " + str(phi_moderate))
    println("        severe:           Φ = " + str(phi_severe))
    println("        phantom floor = " + str(TN_PHANTOM_FLOOR))

    // All tinnitus levels must exceed phantom floor
    if phi_mild < TN_PHANTOM_FLOOR { return false }
    if phi_moderate < TN_PHANTOM_FLOOR { return false }
    if phi_severe < TN_PHANTOM_FLOOR { return false }

    // All tinnitus levels must strictly exceed normal silence
    if phi_mild <= phi_normal_silence { return false }
    if phi_moderate <= phi_normal_silence { return false }
    if phi_severe <= phi_normal_silence { return false }

    // Severity ordering: severe > moderate > mild
    if phi_severe <= phi_moderate { return false }
    if phi_moderate <= phi_mild { return false }

    return true
}

fn check_T3() -> bool {
    // T3: Habituation — Φ_awareness decays over time.
    //
    // The phantom signal itself (Φ_tinnitus) is constant across time —
    // cortical gain does not habituate. What changes is the attentional
    // gating: the brain learns to deprioritize the phantom, so
    // Φ_awareness(t) = Φ_tinnitus × exp(-t/τ) decreases monotonically.
    //
    // Root cause comment: Hallam et al. (1984) habituation model. The
    // clinical implication is that tinnitus "gets quieter" subjectively
    // even though objective measures (e.g., loudness matching) show the
    // phantom signal is unchanged. This is why reassurance counseling
    // works: reducing distress accelerates habituation.

    let gain = TN_GAIN_MODERATE
    let gate = TN_GATE_DAMAGED
    let phi_tinnitus = tn_phi_tinnitus(gain, gate)

    // Compute Φ_awareness at each time step
    let mut awareness_vals = []
    let mut tinnitus_vals = []
    let mut i = 0
    while i < TN_HABIT_STEPS {
        let t = to_float(i)
        let phi_a = tn_phi_awareness(phi_tinnitus, t)
        awareness_vals = awareness_vals.push(phi_a)
        // Φ_tinnitus is time-independent — compute it fresh to verify invariance
        let phi_t = tn_phi_tinnitus(gain, gate)
        tinnitus_vals = tinnitus_vals.push(phi_t)
        i = i + 1
    }

    let phi_early = awareness_vals[0]
    let phi_mid = awareness_vals[5]
    let phi_late = awareness_vals[11]

    println("  [T3] habituation (Φ_tinnitus=" + str(phi_tinnitus) + "):")
    println("        t=0  Φ_awareness = " + str(phi_early))
    println("        t=5  Φ_awareness = " + str(phi_mid))
    println("        t=11 Φ_awareness = " + str(phi_late))

    // (a) Φ_awareness must decrease monotonically
    let mut monotonic = true
    let mut j = 1
    while j < TN_HABIT_STEPS {
        if awareness_vals[j] >= awareness_vals[j - 1] { monotonic = false }
        j = j + 1
    }
    if !monotonic {
        println("        FAIL: Φ_awareness not monotonically decreasing")
        return false
    }

    // (b) Late/early ratio must be below HABIT_RATIO_GATE
    if phi_early < TN_EPS { return false }
    let ratio = phi_late / phi_early
    println("        late/early ratio = " + str(ratio) + "  gate = " + str(TN_HABIT_RATIO_GATE))
    if ratio >= TN_HABIT_RATIO_GATE { return false }

    // (c) Φ_tinnitus itself must be invariant across time steps
    let mut tinnitus_stable = true
    let mut k = 1
    while k < TN_HABIT_STEPS {
        let delta = tn_abs(tinnitus_vals[k] - tinnitus_vals[0])
        if delta > TN_HABIT_TINNITUS_EPS { tinnitus_stable = false }
        k = k + 1
    }
    if !tinnitus_stable {
        println("        FAIL: Φ_tinnitus not time-invariant")
        return false
    }
    println("        Φ_tinnitus invariant across all " + str(TN_HABIT_STEPS) + " steps: YES")

    return true
}

fn check_T4() -> bool {
    // T4: Distress — Φ_emotional correlates with tinnitus strength.
    //
    // Sweep tinnitus intensity (gain levels from normal → severe).
    // With HIGH limbic coupling, Φ_emotional must rise monotonically
    // with Φ_tinnitus. Each step must produce an increase of at least
    // DISTRESS_STEP_GATE.
    //
    // Additionally verify that LOW limbic coupling produces substantially
    // less Φ_emotional than HIGH coupling at the same tinnitus level —
    // this captures the clinical observation that distress is not
    // intrinsic to the phantom but depends on the limbic link.
    //
    // Root cause comment: De Ridder et al. (2014) showed that tinnitus
    // distress severity maps onto the strength of functional connectivity
    // between auditory cortex and limbic regions. Two patients with
    // identical tinnitus loudness can have vastly different distress
    // levels depending on their limbic coupling.

    // Compute Φ_emotional for each severity × coupling combination
    let mut phi_t_arr = []
    let mut phi_e_high_arr = []
    let mut phi_e_low_arr = []
    let mut i = 0
    while i < 4 {
        let gain = tn_gain_for_severity(i)
        let gate = if i == 0 { TN_GATE_NORMAL } else { TN_GATE_DAMAGED }
        let phi_t = tn_phi_tinnitus(gain, gate)
        let phi_e_high = tn_phi_emotional(phi_t, TN_LIMBIC_COUPLING_HIGH)
        let phi_e_low = tn_phi_emotional(phi_t, TN_LIMBIC_COUPLING_LOW)
        phi_t_arr = phi_t_arr.push(phi_t)
        phi_e_high_arr = phi_e_high_arr.push(phi_e_high)
        phi_e_low_arr = phi_e_low_arr.push(phi_e_low)
        i = i + 1
    }

    println("  [T4] distress × tinnitus intensity:")
    println("        normal:   Φ_t=" + str(phi_t_arr[0]) + " Φ_e(high)=" + str(phi_e_high_arr[0]) + " Φ_e(low)=" + str(phi_e_low_arr[0]))
    println("        mild:     Φ_t=" + str(phi_t_arr[1]) + " Φ_e(high)=" + str(phi_e_high_arr[1]) + " Φ_e(low)=" + str(phi_e_low_arr[1]))
    println("        moderate: Φ_t=" + str(phi_t_arr[2]) + " Φ_e(high)=" + str(phi_e_high_arr[2]) + " Φ_e(low)=" + str(phi_e_low_arr[2]))
    println("        severe:   Φ_t=" + str(phi_t_arr[3]) + " Φ_e(high)=" + str(phi_e_high_arr[3]) + " Φ_e(low)=" + str(phi_e_low_arr[3]))

    // (a) Φ_emotional(high coupling) monotonically rises with severity
    let mut j = 1
    while j < 4 {
        let delta = phi_e_high_arr[j] - phi_e_high_arr[j - 1]
        if delta < TN_DISTRESS_STEP_GATE {
            println("        FAIL: distress step " + str(j - 1) + "→" + str(j) + " delta=" + str(delta))
            return false
        }
        j = j + 1
    }

    // (b) At severe level, high coupling distress > low coupling distress
    let severe_high = phi_e_high_arr[3]
    let severe_low = phi_e_low_arr[3]
    println("        severe: high_coupling=" + str(severe_high) + " low_coupling=" + str(severe_low))
    if severe_high <= severe_low {
        println("        FAIL: high coupling should produce more distress")
        return false
    }

    // (c) At severe level, the coupling difference should be substantial
    // (high > 2× low for a large tinnitus signal)
    let coupling_ratio = severe_high / severe_low
    println("        coupling ratio (high/low) = " + str(coupling_ratio))
    if coupling_ratio < 1.5 {
        println("        FAIL: coupling ratio too small")
        return false
    }

    return true
}

fn check_T5() -> bool {
    // T5: Determinism + latency + masking therapy.
    //
    // (a) Two identical calls → bit-identical Φ output.
    // (b) Full pipeline (all modes, sweep, perturbation) < 1 s.
    // (c) Masking: external noise reduces Φ_tinnitus by at least MASK_GATE.
    // (d) Perturbation stability: small noise on gain/gate keeps Φ within bounds.
    //
    // Root cause comment: masking therapy validates the competitive inhibition
    // model — the phantom signal is suppressed when the same cortical
    // resources are occupied by external input. TRT (Tinnitus Retraining
    // Therapy) combines masking with counseling for long-term habituation.

    let t0 = clock()

    let gain = TN_GAIN_MODERATE
    let gate = TN_GATE_DAMAGED

    // (a) Determinism
    let a = tn_phi_tinnitus(gain, gate)
    let b = tn_phi_tinnitus(gain, gate)
    if tn_abs(a - b) > 0.0 {
        println("  [T5] FAIL: non-deterministic output")
        return false
    }

    // Also verify full pipeline determinism (awareness + emotional)
    let aw_a = tn_phi_awareness(a, 5.0)
    let aw_b = tn_phi_awareness(b, 5.0)
    if tn_abs(aw_a - aw_b) > 0.0 {
        println("  [T5] FAIL: awareness non-deterministic")
        return false
    }

    let em_a = tn_phi_emotional(a, TN_LIMBIC_COUPLING_HIGH)
    let em_b = tn_phi_emotional(b, TN_LIMBIC_COUPLING_HIGH)
    if tn_abs(em_a - em_b) > 0.0 {
        println("  [T5] FAIL: emotional non-deterministic")
        return false
    }

    // (c) Masking therapy
    let phi_unmasked = tn_phi_tinnitus(gain, gate)
    let phi_half_masked = tn_phi_masked(phi_unmasked, TN_MASK_EFF_HALF)
    let phi_full_masked = tn_phi_masked(phi_unmasked, TN_MASK_EFF_FULL)

    println("  [T5] masking therapy:")
    println("        unmasked   Φ = " + str(phi_unmasked))
    println("        half-mask  Φ = " + str(phi_half_masked))
    println("        full-mask  Φ = " + str(phi_full_masked))

    // Masking must reduce phantom by at least MASK_GATE
    let mask_delta = phi_unmasked - phi_full_masked
    println("        mask delta = " + str(mask_delta) + "  gate = " + str(TN_MASK_GATE))
    if mask_delta < TN_MASK_GATE {
        println("        FAIL: masking insufficient")
        return false
    }

    // Masking ordering: unmasked > half > full
    if phi_half_masked >= phi_unmasked {
        println("        FAIL: half mask should reduce Φ")
        return false
    }
    if phi_full_masked >= phi_half_masked {
        println("        FAIL: full mask should reduce more than half")
        return false
    }

    // Full mask should leave a small residual (not zero — 10% leaks through)
    if phi_full_masked < 0.0 {
        println("        FAIL: masked Φ should not be negative")
        return false
    }

    // (d) Perturbation stability
    let nominal = tn_phi_tinnitus(gain, gate)
    let mut max_dev = 0.0
    let mut i = 0
    while i < 8 {
        let p = tn_phi_tinnitus_perturbed(gain, gate, 7700 + i * 131, TN_STABILITY_MAG)
        let dev = tn_abs(p - nominal)
        if dev > max_dev { max_dev = dev }
        i = i + 1
    }
    println("        perturbation max_dev = " + str(max_dev) + "  gate = " + str(TN_STABILITY_GATE))
    if max_dev > TN_STABILITY_GATE {
        println("        FAIL: perturbation instability")
        return false
    }

    // Exercise full pipeline for latency measurement
    let mut accum = 0.0
    let mut m = 0
    while m < 4 {
        let g = tn_gain_for_severity(m)
        let gt = if m == 0 { TN_GATE_NORMAL } else { TN_GATE_DAMAGED }
        let pt = tn_phi_tinnitus(g, gt)
        let pa = tn_phi_awareness(pt, 6.0)
        let pe = tn_phi_emotional(pt, TN_LIMBIC_COUPLING_HIGH)
        let pm = tn_phi_masked(pt, TN_MASK_EFF_HALF)
        accum = accum + pt + pa + pe + pm
        m = m + 1
    }

    // Habituation sweep
    let phi_t = tn_phi_tinnitus(gain, gate)
    let mut h = 0
    while h < TN_HABIT_STEPS {
        accum = accum + tn_phi_awareness(phi_t, to_float(h))
        h = h + 1
    }

    let t1 = clock()
    let ms = (t1 - t0) * 1000.0

    println("        sweep accum = " + str(accum) + "  pipeline = " + str(ms) + " ms")

    // (b) Latency check
    if ms >= TN_LATENCY_MS {
        println("        FAIL: pipeline too slow")
        return false
    }

    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[tinnitus_phi] P112 — Tinnitus Φ (phantom auditory perception)")
    println("  model: cochlear damage → cortical gain ↑ → gate failure → phantom Φ")
    println("  refs:  Jastreboff 1990, Eggermont & Roberts 2004, Rauschecker 2010")
    println("         Hallam et al. 1984 (habituation), De Ridder et al. 2014 (distress)")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — normal hearing: silence Φ ≈ 0, stimulus Φ > 0") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — tinnitus: phantom Φ > 0 without external input") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — habituation: Φ_awareness decays, Φ_tinnitus invariant") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — distress: Φ_emotional correlates with tinnitus strength") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism + latency + masking therapy") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 hexa can mishandle chained && over 5 terms.
    // Use sequential flag check instead.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[tinnitus_phi] 5/5 PASS — P112 DONE")
    } else {
        println("[tinnitus_phi] SOME FAILED")
    }
}

main()
