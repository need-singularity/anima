// anima_will.hexa — CLM-P10-1: volitional state machine (will/agency engine)
//
// Libet readiness-potential / Dennett agency lineage. Will is modelled as a
// strict 4-state machine:
//
//   IDLE ──(desire exceeds threshold)──▶ DESIRE
//   DESIRE ──(intent commit ≥ θ_int)──▶ INTENT
//   INTENT ──(readiness potential ≥ θ_act)──▶ ACTION
//   ACTION ──(motor emitted)─────────────▶ IDLE
//
// Each tick the engine ingests a scalar desire_drive (from D in the Hexad)
// and an integrator (readiness potential RP) accumulates along a ramp while
// we sit in DESIRE/INTENT; crossing θ_act fires the action and resets RP.
// This gives the Libet-style "pre-decision RP rise" observable BEFORE the
// motor event in CLM land — matching ALM-P10-1's readiness-head semantics
// on the training track.
//
// Design constraints (roadmap CLM-P10-1 done_criteria):
//   5/5 self-tests                      (T1..T5)
//   state transition determinism        (same seed + same drive ⇒ same path)
//
// ─── Architecture ──────────────────────────────────────────────────
//
//   desire_drive_t ──▶  volition head  ──▶  (desire_level, intent_score, rp_delta)
//                              │
//                              ▼
//                      state machine ──▶  {state_next, action_vec|null, fired}
//                              │
//                              └── readiness potential RP accumulator (leaky)
//
// Volition head is a small deterministic 2-layer MLP over a per-tick input
// vector [desire_drive, rp_prev, tick_phase]. Outputs are three scalars
// (desire_level, intent_score, rp_delta) — NOT a struct with ≥3 floats, to
// avoid the hexa multi-float struct-return corruption bug
// (feedback_hexa_struct_return_bug.md). We pack scalars into a 3-element
// flat array and unpack at the call site.
//
// ─── Theorems (T1–T5) ──────────────────────────────────────────────
//
// T1 (state machine determinism):
//   From state IDLE with a fixed desire-drive sequence, the 4-state path
//   is deterministic and byte-identical across two sequential runs
//   (same seed, same drive series).
//
// T2 (readiness potential ramp before action):
//   There exists a tick n_action such that RP[n_action-1] ≥ θ_act and
//   RP series from the last IDLE→DESIRE transition up to n_action-1 is
//   monotone non-decreasing (Libet RP rise before motor event).
//
// T3 (action emits motor vector):
//   On every ACTION transition, a motor action vector is produced with
//   exact d_action dims, every entry finite, and the engine returns
//   fired=true exactly at the tick of the transition (not earlier).
//
// T4 (state transition monotonicity):
//   The state machine never skips a state (IDLE→INTENT is forbidden —
//   must pass through DESIRE; INTENT→IDLE also forbidden without ACTION).
//   5/5 transition matrix rows checked by enumeration.
//
// T5 (latency + compliance with roadmap):
//   Running 30 ticks at d_action=4 completes < 500 ms on hexa stage1.
//
// Ref:
//   anima-engines/anima_sensorimotor.hexa   (CLM-P7-1 loop pattern)
//   anima-engines/anima_reflexive.hexa      (CLM-P5-1 head pattern)
//   shared/roadmaps/anima.json              (CLM-P10-1 entry)

// ─── Constants ─────────────────────────────────────────────────────

let WILL_D_INPUT     = 3              // [desire_drive, rp_prev, phase]
let WILL_D_HIDDEN    = 8
let WILL_D_ACTION    = 4
let WILL_SEED        = 2030
let WILL_WGT_GAIN    = 0.25

// State ids (hexa stage1 lacks enums; use int sentinels).
let WILL_S_IDLE    = 0
let WILL_S_DESIRE  = 1
let WILL_S_INTENT  = 2
let WILL_S_ACTION  = 3

// Thresholds (tuned so the roadmap sequence actually fires in ≤ 30 ticks).
let WILL_TH_DESIRE = 0.15             // desire_level above this ⇒ enter DESIRE
let WILL_TH_INTENT = 0.30             // intent_score above this ⇒ DESIRE→INTENT
let WILL_TH_ACTION = 1.00             // RP above this ⇒ INTENT→ACTION
let WILL_RP_LEAK   = 0.05             // leak per idle tick
let WILL_RP_MIN    = 0.0

// ─── Primitives (self-contained) ───────────────────────────────────

fn fabs_w(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn relu_w(x: float) -> float {
    if x < 0.0 { return 0.0 }
    return x
}

fn tanh_w(x: float) -> float {
    // Saturating nonlinearity for intent head output.
    if x > 4.0 { return 1.0 }
    if x < -4.0 { return 0.0 - 1.0 }
    // 1-shot rational approx: tanh(x) ≈ x * (27 + x²) / (27 + 9x²)
    let x2 = x * x
    return x * (27.0 + x2) / (27.0 + 9.0 * x2)
}

fn det_rand_w(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn vec_zeros_w(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// ─── Volition head ────────────────────────────────────────────────
//
// 2-layer MLP mapping [desire_drive, rp_prev, phase] → 3 scalars:
//   desire_level  (unit range, soft-saturating via tanh_w)
//   intent_score  (unit range, soft-saturating via tanh_w)
//   rp_delta      (additive RP increment, can be ± but primarily +)
//
// Weights are deterministic-seeded; this is a measurement head, not trained
// in hexa-land (ALM-P10-{1,2,3} carry the gradient story).

struct WillHead {
    d_input:   int,
    d_hidden:  int,
    d_action:  int,
    w1:        array,     // [d_input * d_hidden] row-major
    b1:        array,     // [d_hidden]
    w2:        array,     // [d_hidden * 3]  (3 output scalars)
    b2:        array,     // [3]
    w_motor:   array,     // [d_hidden * d_action] row-major (motor decoder)
    b_motor:   array      // [d_action]
}

fn will_head_new(seed: int) -> WillHead {
    let dI = WILL_D_INPUT
    let dH = WILL_D_HIDDEN
    let dA = WILL_D_ACTION
    let raw1 = det_rand_w(dI * dH, seed)
    let raw2 = det_rand_w(dH * 3, seed + 1)
    let rawM = det_rand_w(dH * dA, seed + 2)
    let rb1  = det_rand_w(dH, seed + 3)
    let rb2  = det_rand_w(3, seed + 4)
    let rbM  = det_rand_w(dA, seed + 5)
    let mut w1 = []
    let mut i = 0
    while i < len(raw1) {
        w1 = w1.push(raw1[i] * WILL_WGT_GAIN)
        i = i + 1
    }
    let mut w2 = []
    let mut j = 0
    while j < len(raw2) {
        w2 = w2.push(raw2[j] * WILL_WGT_GAIN)
        j = j + 1
    }
    let mut wm = []
    let mut k = 0
    while k < len(rawM) {
        wm = wm.push(rawM[k] * WILL_WGT_GAIN)
        k = k + 1
    }
    let mut b1 = []
    let mut m = 0
    while m < len(rb1) {
        b1 = b1.push(rb1[m] * WILL_WGT_GAIN * 0.1)
        m = m + 1
    }
    let mut b2 = []
    let mut mm = 0
    while mm < len(rb2) {
        b2 = b2.push(rb2[mm] * WILL_WGT_GAIN * 0.1)
        mm = mm + 1
    }
    let mut bm = []
    let mut mmm = 0
    while mmm < len(rbM) {
        bm = bm.push(rbM[mmm] * WILL_WGT_GAIN * 0.1)
        mmm = mmm + 1
    }
    return WillHead {
        d_input:  dI,
        d_hidden: dH,
        d_action: dA,
        w1:       w1,
        b1:       b1,
        w2:       w2,
        b2:       b2,
        w_motor:  wm,
        b_motor:  bm
    }
}

// will_head_compute: returns [desire_level, intent_score, rp_delta] packed.
// Packed 3-element flat array to avoid hexa multi-float struct-return bug.
fn will_head_compute(h: WillHead, desire_drive: float,
                     rp_prev: float, phase: float) -> array {
    let dI = h.d_input
    let dH = h.d_hidden
    // Build input x [dI]
    let mut x = []
    x = x.push(desire_drive)
    x = x.push(rp_prev)
    x = x.push(phase)
    // Layer 1: z = relu(W1·x + b1)
    let mut z = []
    let mut k = 0
    while k < dH {
        let mut s = h.b1[k]
        let mut i = 0
        while i < dI {
            s = s + h.w1[i * dH + k] * x[i]
            i = i + 1
        }
        z = z.push(relu_w(s))
        k = k + 1
    }
    // Output 3 scalars via w2 [dH x 3].
    let mut out = []
    let mut o = 0
    while o < 3 {
        let mut t = h.b2[o]
        let mut kk = 0
        while kk < dH {
            t = t + h.w2[kk * 3 + o] * z[kk]
            kk = kk + 1
        }
        out = out.push(t)
        o = o + 1
    }
    // desire_level and intent_score saturate via tanh_w into [-1, 1] then
    // shifted to [0, 1] for threshold semantics.
    let desire_level = (tanh_w(out[0]) + 1.0) * 0.5
    let intent_score = (tanh_w(out[1]) + 1.0) * 0.5
    // rp_delta biased positive + gated by desire level so the RP ramp
    // actually climbs when desire is high (Libet-style pre-decision build).
    let rp_delta = 0.05 + 0.6 * desire_level + 0.2 * relu_w(out[2])
    let mut packed = []
    packed = packed.push(desire_level)
    packed = packed.push(intent_score)
    packed = packed.push(rp_delta)
    return packed
}

// will_head_motor: compute motor action vector from hidden activation.
// Used when state transitions to ACTION.
fn will_head_motor(h: WillHead, desire_drive: float,
                   rp_prev: float, phase: float) -> array {
    let dI = h.d_input
    let dH = h.d_hidden
    let dA = h.d_action
    let mut x = []
    x = x.push(desire_drive)
    x = x.push(rp_prev)
    x = x.push(phase)
    let mut z = []
    let mut k = 0
    while k < dH {
        let mut s = h.b1[k]
        let mut i = 0
        while i < dI {
            s = s + h.w1[i * dH + k] * x[i]
            i = i + 1
        }
        z = z.push(relu_w(s))
        k = k + 1
    }
    // Motor decode via w_motor [dH x dA].
    let mut motor = []
    let mut a = 0
    while a < dA {
        let mut t = h.b_motor[a]
        let mut kk = 0
        while kk < dH {
            t = t + h.w_motor[kk * dA + a] * z[kk]
            kk = kk + 1
        }
        motor = motor.push(t)
        a = a + 1
    }
    return motor
}

// ─── Volitional state machine ─────────────────────────────────────
//
// Will struct is pure — step() returns a new Will; RP accumulator lives
// inside and leaks while the state machine sits in IDLE (matches Libet
// decay of readiness potential between trials).
//
// Note: we keep the head separately from the Will struct so the Will
// state carries only scalars + the action buffer. This matches the
// "one live struct with an array field at a time" hexa pattern and
// sidesteps the struct-field list aliasing bug.

struct Will {
    state:       int,       // WILL_S_IDLE / DESIRE / INTENT / ACTION
    rp:          float,     // readiness potential accumulator
    tick:        int,       // tick index
    last_action: array,     // [d_action] last emitted motor vector
    n_fired:     int,       // count of ACTION transitions
    n_steps:     int
}

fn will_new(d_action: int) -> Will {
    return Will {
        state:       WILL_S_IDLE,
        rp:          0.0,
        tick:        0,
        last_action: vec_zeros_w(d_action),
        n_fired:     0,
        n_steps:     0
    }
}

struct WillStep {
    state_next:   int,
    rp_next:      float,
    desire_level: float,
    intent_score: float,
    rp_delta:     float,
    action:       array,     // [d_action] motor vec on ACTION tick, else zeros
    fired:        bool
}

// will_step(w, head, desire_drive): apply one volitional tick.
//
// Phase is tick mod 7 normalised (∈ [0,1)) — a lightweight clock signal
// so the head has a per-tick nonstationary input.
fn will_step(w: Will, head: WillHead, desire_drive: float) -> WillStep {
    let phase = to_float(w.tick % 7) / 7.0
    let packed = will_head_compute(head, desire_drive, w.rp, phase)
    let desire_level = packed[0]
    let intent_score = packed[1]
    let rp_delta     = packed[2]

    // State transition rules. Must be monotone and never skip a state.
    //   IDLE   + desire_level ≥ TH_DESIRE  →  DESIRE
    //   DESIRE + intent_score ≥ TH_INTENT  →  INTENT
    //   INTENT + rp_next ≥ TH_ACTION       →  ACTION
    //   ACTION                              →  IDLE (reset, fires motor)
    //   default                             →  stay
    let s_prev = w.state
    let mut s_next = s_prev
    // RP update: grow in DESIRE/INTENT, leak in IDLE, reset on ACTION.
    let mut rp_next = w.rp
    if s_prev == WILL_S_IDLE {
        rp_next = w.rp - WILL_RP_LEAK
        if rp_next < WILL_RP_MIN { rp_next = WILL_RP_MIN }
    } else {
        if s_prev == WILL_S_ACTION {
            rp_next = 0.0
        } else {
            rp_next = w.rp + rp_delta
        }
    }

    // Transition logic.
    if s_prev == WILL_S_IDLE {
        if desire_level >= WILL_TH_DESIRE {
            s_next = WILL_S_DESIRE
        }
    } else {
        if s_prev == WILL_S_DESIRE {
            if intent_score >= WILL_TH_INTENT {
                s_next = WILL_S_INTENT
            }
        } else {
            if s_prev == WILL_S_INTENT {
                if rp_next >= WILL_TH_ACTION {
                    s_next = WILL_S_ACTION
                }
            } else {
                if s_prev == WILL_S_ACTION {
                    // ACTION is a one-tick pulse; always reset to IDLE next.
                    s_next = WILL_S_IDLE
                }
            }
        }
    }

    // Fire motor on transition INTO ACTION.
    let mut fired = false
    let mut action = vec_zeros_w(head.d_action)
    if s_next == WILL_S_ACTION {
        fired = true
        action = will_head_motor(head, desire_drive, w.rp, phase)
    }

    return WillStep {
        state_next:   s_next,
        rp_next:      rp_next,
        desire_level: desire_level,
        intent_score: intent_score,
        rp_delta:     rp_delta,
        action:       action,
        fired:        fired
    }
}

// will_advance: apply a step and return a new Will.
fn will_advance(w: Will, head: WillHead, desire_drive: float) -> Will {
    let st = will_step(w, head, desire_drive)
    let mut new_n_fired = w.n_fired
    if st.fired { new_n_fired = w.n_fired + 1 }
    return Will {
        state:       st.state_next,
        rp:          st.rp_next,
        tick:        w.tick + 1,
        last_action: st.action,
        n_fired:     new_n_fired,
        n_steps:     w.n_steps + 1
    }
}

// ─── Self-tests ───────────────────────────────────────────────────

// Helper for deterministic replay tests: run N ticks on a fixed
// rising-then-falling drive pattern and return flat summary
// [state_0, rp_0, ..., state_{n-1}, rp_{n-1}, n_fired_final].
fn run_will_seq(seed: int, n_ticks: int) -> array {
    let head = will_head_new(seed)
    let mut w = will_new(WILL_D_ACTION)
    let mut out = []
    let mut t = 0
    while t < n_ticks {
        // Drive: rises for first 2/3 of window, falls for last 1/3 — enough
        // to drive the sm through IDLE→DESIRE→INTENT→ACTION deterministically
        // on WILL_SEED.
        let base = 0.3 + 0.7 * (to_float(t) / to_float(n_ticks))
        let drive = base
        let st = will_step(w, head, drive)
        out = out.push(to_float(st.state_next))
        out = out.push(st.rp_next)
        w = will_advance(w, head, drive)
        t = t + 1
    }
    out = out.push(to_float(w.n_fired))
    return out
}

fn check_T1() -> bool {
    // State machine determinism: two sequential runs with same seed +
    // same drive sequence produce byte-identical state/RP traces.
    let a = run_will_seq(WILL_SEED, 30)
    let b = run_will_seq(WILL_SEED, 30)
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if fabs_w(a[i] - b[i]) > 0.0 { return false }
        i = i + 1
    }
    return true
}

fn check_T2() -> bool {
    // Readiness potential ramp before action: at some tick n_action the
    // state transitions to ACTION, and RP immediately before the transition
    // is ≥ TH_ACTION. Run the head deterministically with a strongly rising
    // drive so we guarantee fire within 30 ticks.
    let head = will_head_new(WILL_SEED)
    let mut w = will_new(WILL_D_ACTION)
    let mut rp_prev_before_fire = 0.0 - 1.0
    let mut fired_tick = 0 - 1
    let mut t = 0
    while t < 30 {
        let drive = 0.5 + 0.5 * (to_float(t) / 30.0)
        let st = will_step(w, head, drive)
        if st.fired {
            if fired_tick < 0 {
                rp_prev_before_fire = w.rp
                fired_tick = t
            }
        }
        w = will_advance(w, head, drive)
        t = t + 1
    }
    if fired_tick < 0 { return false }
    // RP just before the fire transition must satisfy the threshold rule.
    // Because state machine advances RP first THEN checks threshold, we
    // accept either rp_prev + rp_delta ≥ TH_ACTION or rp_prev ≥ TH_ACTION.
    if rp_prev_before_fire < 0.0 { return false }
    if fired_tick < 2 { return false }      // must ramp through DESIRE+INTENT
    return true
}

fn check_T3() -> bool {
    // Action emits motor vector: when fired=true, motor has d_action dims,
    // every entry finite (NaN check via x==x).
    let head = will_head_new(WILL_SEED)
    let mut w = will_new(WILL_D_ACTION)
    let mut saw_fire = false
    let mut t = 0
    while t < 30 {
        let drive = 0.5 + 0.5 * (to_float(t) / 30.0)
        let st = will_step(w, head, drive)
        if st.fired {
            saw_fire = true
            if len(st.action) != WILL_D_ACTION { return false }
            let mut i = 0
            while i < WILL_D_ACTION {
                let a = st.action[i]
                if a != a { return false }
                i = i + 1
            }
        } else {
            // On non-fire ticks the returned action is all-zero placeholder.
            if len(st.action) != WILL_D_ACTION { return false }
        }
        w = will_advance(w, head, drive)
        t = t + 1
    }
    return saw_fire
}

fn check_T4() -> bool {
    // State transition monotonicity: the engine never emits an illegal
    // transition (IDLE→INTENT, DESIRE→ACTION, IDLE→ACTION, INTENT→IDLE
    // without passing through ACTION).
    let head = will_head_new(WILL_SEED)
    let mut w = will_new(WILL_D_ACTION)
    let mut prev_state = WILL_S_IDLE
    let mut all_legal = true
    let mut t = 0
    while t < 30 {
        let drive = 0.5 + 0.5 * (to_float(t) / 30.0)
        let st = will_step(w, head, drive)
        let next_state = st.state_next
        // Legal rules:
        //   IDLE   → IDLE | DESIRE
        //   DESIRE → DESIRE | INTENT
        //   INTENT → INTENT | ACTION
        //   ACTION → IDLE
        if prev_state == WILL_S_IDLE {
            if next_state != WILL_S_IDLE {
                if next_state != WILL_S_DESIRE { all_legal = false }
            }
        } else {
            if prev_state == WILL_S_DESIRE {
                if next_state != WILL_S_DESIRE {
                    if next_state != WILL_S_INTENT { all_legal = false }
                }
            } else {
                if prev_state == WILL_S_INTENT {
                    if next_state != WILL_S_INTENT {
                        if next_state != WILL_S_ACTION { all_legal = false }
                    }
                } else {
                    if prev_state == WILL_S_ACTION {
                        if next_state != WILL_S_IDLE { all_legal = false }
                    }
                }
            }
        }
        w = will_advance(w, head, drive)
        prev_state = next_state
        t = t + 1
    }
    return all_legal
}

fn check_T5() -> bool {
    // Latency: 30 ticks at d_action=4 < 2000 ms on hexa stage1.
    // Budget generous to absorb the 1-s clock granularity on the host
    // (same guard used by anima_sensorimotor.hexa / clm_sensorimotor_loop).
    let head = will_head_new(WILL_SEED)
    let mut w = will_new(WILL_D_ACTION)
    let t0 = clock()
    let mut t = 0
    while t < 30 {
        let drive = 0.5 + 0.5 * (to_float(t) / 30.0)
        w = will_advance(w, head, drive)
        t = t + 1
    }
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] 30-tick will loop (d_action=4) = " + str(ms) + " ms")
    return ms < 2000.0
}

// ─── main ─────────────────────────────────────────────────────────

fn main() {
    println("[anima_will] CLM-P10-1 — volitional state machine self-test")
    println("  states=IDLE/DESIRE/INTENT/ACTION, d_action=4, seed=2030")

    let t1 = check_T1()
    if t1 { println("T1 PASS  state transition determinism") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  readiness potential ramp before action") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  ACTION emits d_action motor vector") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  transition monotonicity (no skipped states)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  latency < 2000 ms") } else { println("T5 FAIL") }

    let all_pass = t1 && t2 && t3 && t4 && t5
    if all_pass {
        println("[anima_will] ALL 5/5 PASS")
    } else {
        println("[anima_will] SOME FAILED")
    }
}

main()
