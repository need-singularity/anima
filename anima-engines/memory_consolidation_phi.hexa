// memory_consolidation_phi.hexa — P93 Memory Consolidation Φ
//
// Roadmap: shared/roadmaps/anima.json P93
//   depends_on: P52 (memory_palace_phi — episodic spatial bind),
//               P36 (temporal_phi_extended — past/future Φ),
//               P82 (deja_vu_phi — familiarity/recollection streams).
//   done_criteria: 5/5 self-test PASS — SWS replay, SWS vs REM
//     dissociation, reconsolidation lability, sleep deprivation
//     decay, determinism + latency.
//
// ─── Scientific frame ──────────────────────────────────────────────
//
// Memory consolidation (Müller & Pilzecker 1900; Hebb 1949) is the
// process by which initially fragile, hippocampus-dependent memory
// traces are gradually stabilized and transferred to neocortical
// long-term storage.  Sleep is the privileged window for this process
// (Diekelmann & Born 2010).
//
// TWO-STAGE MODEL (Marr 1971; Buzsáki 1989; McClelland et al 1995):
//
//   Stage 1 — ENCODING (wake):
//     Hippocampal complex rapidly binds episodic traces. These traces
//     are labile — vulnerable to interference, decay, and overwrite.
//     Cortical representation is weak (sparse, low-MI with hippocampus).
//
//   Stage 2 — CONSOLIDATION (sleep):
//     (a) SWS (slow-wave sleep, NREM stages 3-4):
//         Hippocampal sharp-wave ripples (Buzsáki 2015) replay waking
//         experience at 5-20x speed. Thalamocortical spindles (12-15 Hz)
//         nest within slow oscillation up-states (~0.8 Hz). This
//         coordinated replay drives hippocampal → neocortical trace
//         transfer.  Declarative / episodic memory benefits most from
//         SWS (Marshall et al 2006; Rasch et al 2007).
//
//     (b) REM (rapid eye movement):
//         Theta oscillations (4-8 Hz) dominate. Emotional memory is
//         preferentially processed (Wagner et al 2001; Walker & van
//         der Helm 2009). Amygdala-hippocampus coupling during REM
//         strengthens affective tags while attenuating the visceral
//         arousal — "sleep to forget, sleep to remember" (Walker 2009).
//         Procedural and creative integration also benefits from REM.
//
// RECONSOLIDATION (Nader, Schafe & LeDoux 2000):
//   When a consolidated memory is REACTIVATED (retrieved), it
//   temporarily returns to a labile state.  During this "reconsolidation
//   window" (typically ~6h), the memory can be UPDATED with new
//   information or DISRUPTED (e.g., protein synthesis inhibitors in
//   animal models, propranolol in human PTSD protocols).  After the
//   window closes, the memory re-stabilizes — potentially in modified
//   form.  This discovery overturned the one-shot consolidation dogma.
//
// SLEEP DEPRIVATION (Yoo et al 2007; Walker 2017):
//   Blocking the SWS/REM cycle prevents consolidation.  Hippocampal
//   traces that are never replayed remain fragile and decay faster.
//   Φ_memory (integration between hippocampal and cortical streams)
//   fails to rise — the cortical copy is never written.
//
// ─── Model architecture ────────────────────────────────────────────
//
// We model two parallel streams across time:
//
//   HPC[t] — hippocampal trace (encoding → replay → fade)
//   CTX[t] — cortical representation (initially weak → strengthened)
//
// Plus an emotional channel for SWS/REM dissociation:
//   EMO[t] — affective tag strength (emotional memory dimension)
//
// Φ_memory = MI(HPC, CTX) — integration between the two stores.
//   After SWS replay, HPC→CTX transfer lifts MI.
//   After REM, emotional MI (EMO, CTX) is selectively strengthened.
//
// Sleep replay mechanism (per SWS step):
//   CTX_new[t] = CTX[t] + replay_gain * (HPC[t] - CTX[t]) + noise
//   This is a gradient-like approach — cortex assimilates the
//   hippocampal pattern proportionally to the gap.
//
// REM mechanism (per REM step):
//   EMO→CTX coupling strengthened: emotional traces get extra transfer.
//   HPC→CTX coupling weaker in REM (theta replaces ripples).
//   CTX_new[t] = CTX[t] + emo_gain * EMO[t] * (HPC[t] - CTX[t]) + noise
//
// Reconsolidation:
//   Reactivation sets HPC trace to a MIXED state (original + new info).
//   Lability = variance increase in HPC; re-stabilization = variance
//   decrease after a consolidation pass.
//
// Sleep deprivation:
//   No replay steps are applied.  HPC decays naturally over time
//   (exponential forgetting), and CTX never receives the trace.
//   Φ_memory remains low (near encoding baseline).
//
// ─── Theorems (T1-T5) ──────────────────────────────────────────────
//
// T1 (Encoding → SWS replay consolidation):
//    Φ_memory(post-SWS) > Φ_memory(encoding-only).  SWS replay
//    drives hippocampal→cortical transfer, raising MI between stores.
//
// T2 (SWS vs REM dissociation):
//    Declarative content: Φ_decl(SWS) > Φ_decl(REM).
//    Emotional content:   Φ_emo(REM) > Φ_emo(SWS).
//    SWS and REM serve complementary consolidation functions.
//
// T3 (Reconsolidation — Nader 2000):
//    After reactivation, Φ_memory temporarily drops (lability) and
//    the memory trace can be MODIFIED.  After re-consolidation pass,
//    Φ_memory recovers, potentially incorporating new content.
//    Φ_pre > Φ_labile AND Φ_reconsolidated > Φ_labile.
//
// T4 (Sleep deprivation):
//    Without sleep replay, Φ_memory fails to rise above encoding
//    baseline.  After decay period, Φ_memory(deprived) <
//    Φ_memory(consolidated).  Memory fragility exposed.
//
// T5 (Determinism + latency):
//    Same seed ⇒ byte-identical Φ values.  Computation completes
//    within wall-clock budget (< 2s on any reasonable host).
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no `pure fn` with >=3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - no identifier-pattern match; sequential if/else chains
//   - no contains() / to_lower() builtins
//   - no !(Effect) on fn returns
//   - no else-if in let-binding (flat mut + sequential if)
//   - single-line fn signatures / call sites / array literals
//   - no reserved keywords as variable names
//   - main() call at bottom
//   - MC_STEPS=24 (< 32)
//
// Law alignment:
//   Law 2  Observe never inject — Φ via MI measurement on streams
//   Law 4  Structure > feature — two-store architecture is structural
//   Law 22 Feature addition → Φ down — channels fixed (HPC, CTX, EMO)
//   Law 50 Consciousness essence is state — HPC/CTX time-series IS state
//
// Ref:
//   anima-engines/memory_palace_phi.hexa      (P52 — spatial binding)
//   anima-engines/temporal_phi_extended.hexa   (P36 — past/future Φ)
//   anima-engines/deja_vu_phi.hexa            (P82 — familiarity/recollection)
//   anima-engines/episodic_store.hexa         (P11 — narrative substrate)
//   Diekelmann & Born 2010 | Buzsáki 2015 | Nader et al 2000 | Walker 2017

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let MC_STEPS          = 24            // timeline length (stage0 N<32)
let MC_DIM            = 8             // vector dimension per store (< 32)
let MC_BINS           = 6             // histogram bins for MI
let MC_EPS            = 0.0000000001

// ─── Replay parameters ─────────────────────────────────────────
// SWS replay gain: fraction of HPC-CTX gap transferred per SWS step.
// Buzsáki ripple replay operates at compressed timescale — we model
// the NET effect per sleep cycle (~90 min) as a coupling constant.
let MC_SWS_REPLAY     = 0.35
// Number of SWS replay iterations (one full night ~ 4-5 NREM cycles).
let MC_SWS_CYCLES     = 5
// REM emotional gain — amygdala-hippocampus coupling during REM.
// Elevated relative to SWS because theta-rhythm amygdala coupling
// selectively amplifies affective traces (Walker & van der Helm 2009).
let MC_REM_EMO_GAIN   = 0.55
// REM declarative gain — substantially lower than SWS for non-emotional
// content (theta replaces sharp-wave ripples — different replay mode).
let MC_REM_DECL_GAIN  = 0.06
// Number of REM iterations per night.
let MC_REM_CYCLES     = 4

// ─── Reconsolidation ───────────────────────────────────────────
// Nader window: reactivation injects new-info fraction into HPC.
let MC_REACTIVATE_MIX = 0.40          // fraction of new info in reactivated trace
// Reconsolidation replay cycles (shorter window than initial consolidation).
let MC_RECON_CYCLES   = 3

// ─── Decay / deprivation ──────────────────────────────────────
// Per-step exponential decay factor for unconsolidated HPC traces.
let MC_DECAY_RATE     = 0.92          // 8% loss per step
// Number of decay steps to simulate extended wakefulness without sleep.
let MC_DEPRIVE_STEPS  = 12

// ─── Signal generation ─────────────────────────────────────────
// Noise amplitude added during replay / encoding.
let MC_NOISE          = 0.04
// Encoding strength — initial HPC signal clarity.
let MC_ENCODE_AMP     = 0.80
// Initial cortical trace strength (weak before consolidation).
let MC_CTX_INIT       = 0.15

// ─── Test gates ────────────────────────────────────────────────
let MC_SWS_LIFT       = 0.04          // Φ_memory must rise by this after SWS
let MC_DECL_SWS_GAP   = 0.02          // Φ_decl(SWS) must exceed Φ_decl(REM) by this
let MC_EMO_REM_GAP    = 0.02          // Φ_emo(REM) must exceed Φ_emo(SWS) by this
let MC_LABILE_DROP    = 0.02          // Φ must drop after reactivation
let MC_RECON_LIFT     = 0.01          // Φ must recover after reconsolidation
let MC_DEPRIVE_GAP    = 0.03          // consolidated Φ must exceed deprived Φ by this
let MC_DETERM_EPS     = 0.0000001     // determinism tolerance

// ─── Seeds ─────────────────────────────────────────────────────
let MC_SEED_ENC       = 93001
let MC_SEED_SWS       = 93101
let MC_SEED_REM       = 93201
let MC_SEED_RECON     = 93301
let MC_SEED_DEPRIVE   = 93401
let MC_SEED_DET_A     = 93501
let MC_SEED_DET_B     = 93601

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn mc_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn mc_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn mc_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn mc_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn mc_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn mc_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn mc_signed(seed: int) -> float {
    return mc_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn mc_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn mc_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn mc_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(mc_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = mc_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * mc_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn mc_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = mc_bin_idx(a[i], lo, hi, nb)
        let ib = mc_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = mc_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * mc_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn mc_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn mc_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn mc_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = mc_vec_min(a)
    let hi_a = mc_vec_max(a)
    let lo_b = mc_vec_min(b)
    let hi_b = mc_vec_max(b)
    let lo = mc_min_f(lo_a, lo_b)
    let hi = mc_max_f(hi_a, hi_b)
    let h_a = mc_entropy(a, lo, hi, MC_BINS)
    let h_b = mc_entropy(b, lo, hi, MC_BINS)
    let h_j = mc_joint_entropy(a, b, lo, hi, MC_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Variance helper — used for reconsolidation lability detection.
fn mc_variance(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + v[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut acc = 0.0
    let mut j = 0
    while j < n {
        let d = v[j] - mean
        acc = acc + d * d
        j = j + 1
    }
    return acc / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Stream generation — hippocampal / cortical / emotional traces
//
// The two-store architecture:
//   HPC — hippocampal memory trace (strong after encoding, fades without replay)
//   CTX — neocortical representation (weak initially, strengthened by replay)
//   EMO — emotional tag channel (modulates consolidation pathway selection)
//
// During ENCODING: HPC gets a strong structured signal, CTX gets a
// weak noisy shadow, EMO gets an affective tag proportional to the
// "emotional salience" of the encoded event.
// ═══════════════════════════════════════════════════════════════

// Generate hippocampal encoding trace — structured sine-like signal
// modulated by dimension index to create a distinctive pattern.
fn mc_gen_hpc_encoding(seed: int) -> array {
    let mut hpc = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        // Structured pattern: sin-ish waveform with dimension-dependent phase
        let phase = to_float(t) * 0.45 + to_float(seed % 7) * 0.3
        // Manual sin approximation: x - x^3/6 + x^5/120 (Taylor, modular phase)
        let mut px = phase
        // Wrap phase to [-pi, pi] range approximately
        while px > 3.14159 { px = px - 6.28318 }
        while px < 0.0 - 3.14159 { px = px + 6.28318 }
        let px3 = px * px * px
        let px5 = px3 * px * px
        let wave = px - px3 / 6.0 + px5 / 120.0
        s = mc_prng(s)
        let noise = mc_signed(s) * MC_NOISE
        hpc = hpc.push(MC_ENCODE_AMP * wave + noise)
        t = t + 1
    }
    return hpc
}

// Generate initial cortical trace — weak noisy shadow of HPC.
// Before consolidation, CTX has only a faint imprint.
fn mc_gen_ctx_initial(hpc: array, seed: int) -> array {
    let mut ctx = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        s = mc_prng(s)
        let noise = mc_signed(s) * MC_NOISE * 2.0
        // Weak initial coupling — cortex barely tracks hippocampus
        ctx = ctx.push(MC_CTX_INIT * hpc[t] + noise)
        t = t + 1
    }
    return ctx
}

// Generate emotional tag channel — high values for "emotional" content,
// low values for "neutral/declarative" content.
fn mc_gen_emo_channel(salience: float, seed: int) -> array {
    let mut emo = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        s = mc_prng(s)
        let noise = mc_signed(s) * MC_NOISE
        // Emotional salience modulates amplitude
        let phase = to_float(t) * 0.6 + 1.2
        let mut px = phase
        while px > 3.14159 { px = px - 6.28318 }
        while px < 0.0 - 3.14159 { px = px + 6.28318 }
        let px3 = px * px * px
        let wave = px - px3 / 6.0
        emo = emo.push(salience * wave * 0.5 + noise)
        t = t + 1
    }
    return emo
}

// ═══════════════════════════════════════════════════════════════
// SWS replay — sharp-wave ripple driven HPC → CTX transfer
//
// Each SWS cycle: cortex moves toward hippocampal pattern.
//   CTX_new[t] = CTX[t] + MC_SWS_REPLAY * (HPC[t] - CTX[t]) + noise
//
// This is the Buzsáki (2015) coordinated replay model: ripples
// compressed replay interleaves with spindle-gated cortical plasticity
// windows.  The net effect per cycle is a fraction of the HPC-CTX gap
// transferred to CTX.
// ═══════════════════════════════════════════════════════════════

fn mc_sws_replay_step(hpc: array, ctx: array, gain: float, seed: int) -> array {
    let mut result = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        s = mc_prng(s)
        let noise = mc_signed(s) * MC_NOISE * 0.5
        let gap = hpc[t] - ctx[t]
        let updated = ctx[t] + gain * gap + noise
        result = result.push(updated)
        t = t + 1
    }
    return result
}

// Apply N cycles of SWS replay.
fn mc_sws_consolidate(hpc: array, ctx: array, n_cycles: int, seed: int) -> array {
    let mut cur_ctx = ctx
    let mut s = seed
    let mut cyc = 0
    while cyc < n_cycles {
        s = mc_prng(s)
        cur_ctx = mc_sws_replay_step(hpc, cur_ctx, MC_SWS_REPLAY, s)
        cyc = cyc + 1
    }
    return cur_ctx
}

// ═══════════════════════════════════════════════════════════════
// REM processing — emotional memory consolidation
//
// During REM, amygdala-hippocampus theta coupling selectively
// strengthens emotional traces.  Declarative content gets weaker
// transfer (theta replaces ripples — different replay mode).
//
//   CTX_new[t] = CTX[t] + emo_gain * EMO[t] * (HPC[t] - CTX[t])
//                        + decl_gain * (HPC[t] - CTX[t]) + noise
//
// For emotional content (high EMO), the first term dominates.
// For neutral content (low EMO), only the weak decl_gain applies.
// ═══════════════════════════════════════════════════════════════

fn mc_rem_replay_step(hpc: array, ctx: array, emo: array, seed: int) -> array {
    let mut result = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        s = mc_prng(s)
        let noise = mc_signed(s) * MC_NOISE * 0.5
        // Emotional contribution: stronger for high-salience steps
        let emo_abs = mc_abs(emo[t])
        let emo_contrib = MC_REM_EMO_GAIN * emo_abs * (hpc[t] - ctx[t])
        // Declarative contribution: weak baseline transfer during REM
        let decl_contrib = MC_REM_DECL_GAIN * (hpc[t] - ctx[t])
        let updated = ctx[t] + emo_contrib + decl_contrib + noise
        result = result.push(updated)
        t = t + 1
    }
    return result
}

// Apply N cycles of REM processing.
fn mc_rem_consolidate(hpc: array, ctx: array, emo: array, n_cycles: int, seed: int) -> array {
    let mut cur_ctx = ctx
    let mut s = seed
    let mut cyc = 0
    while cyc < n_cycles {
        s = mc_prng(s)
        cur_ctx = mc_rem_replay_step(hpc, cur_ctx, emo, s)
        cyc = cyc + 1
    }
    return cur_ctx
}

// ═══════════════════════════════════════════════════════════════
// Reconsolidation — Nader et al 2000
//
// When a consolidated memory is REACTIVATED, the hippocampal trace
// re-enters a labile state.  We model this as mixing the original
// trace with new information, increasing trace variance (uncertainty).
//
// Reactivation:
//   HPC_react[t] = (1 - mix) * HPC_orig[t] + mix * new_info[t]
//
// The reactivated trace has HIGHER variance (less stable) and the
// MI between HPC_react and CTX drops (trace no longer matches the
// consolidated cortical copy).
//
// Re-consolidation (another replay pass) can re-stabilize:
//   CTX is updated to match the MODIFIED HPC_react.
// ═══════════════════════════════════════════════════════════════

// Generate "new information" that partially overlaps with original.
fn mc_gen_new_info(original: array, seed: int) -> array {
    let mut info = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        s = mc_prng(s)
        let noise = mc_signed(s) * 0.6
        // New info: partially correlated with original + substantial noise
        info = info.push(original[t] * 0.3 + noise)
        t = t + 1
    }
    return info
}

// Reactivate a consolidated trace — mix with new information.
fn mc_reactivate(hpc_orig: array, new_info: array, mix: float) -> array {
    let mut result = []
    let mut t = 0
    while t < MC_STEPS {
        let blended = (1.0 - mix) * hpc_orig[t] + mix * new_info[t]
        result = result.push(blended)
        t = t + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════
// Sleep deprivation — no replay, natural HPC decay
//
// Without sleep, hippocampal traces undergo exponential forgetting
// (Hardt, Nader & Nadel 2013).  Each decay step:
//   HPC_decay[t] = MC_DECAY_RATE * HPC[t] + noise
//
// Cortex never receives the transfer.  After enough decay, the
// trace is effectively lost.
// ═══════════════════════════════════════════════════════════════

fn mc_decay_step(trace: array, rate: float, seed: int) -> array {
    let mut result = []
    let mut s = seed
    let mut t = 0
    while t < MC_STEPS {
        s = mc_prng(s)
        let noise = mc_signed(s) * MC_NOISE * 0.3
        result = result.push(rate * trace[t] + noise)
        t = t + 1
    }
    return result
}

// Apply N steps of decay without any replay.
fn mc_apply_decay(trace: array, n_steps: int, rate: float, seed: int) -> array {
    let mut cur = trace
    let mut s = seed
    let mut step = 0
    while step < n_steps {
        s = mc_prng(s)
        cur = mc_decay_step(cur, rate, s)
        step = step + 1
    }
    return cur
}

// ═══════════════════════════════════════════════════════════════
// Φ_memory — integration between hippocampal and cortical stores
//
// Measured as MI(HPC, CTX) via histogram binning.
// Higher MI = better consolidation (traces are co-informative).
// ═══════════════════════════════════════════════════════════════

fn mc_phi_memory(hpc: array, ctx: array) -> float {
    return mc_mi(hpc, ctx)
}

// Φ_emo — emotional integration between EMO channel and CTX.
fn mc_phi_emo(emo: array, ctx: array) -> float {
    return mc_mi(emo, ctx)
}

// ═══════════════════════════════════════════════════════════════
// T1: Encoding → SWS replay — Φ_memory increases after consolidation
//
// Protocol:
//   1. Encode: create HPC trace + weak CTX initial
//   2. Measure Φ_memory(encoding) = MI(HPC, CTX_init)
//   3. Apply SWS replay cycles
//   4. Measure Φ_memory(post-SWS) = MI(HPC, CTX_consolidated)
//   5. Assert: Φ_post > Φ_pre + MC_SWS_LIFT
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    println("  [T1] Encoding → SWS replay consolidation")

    // Encode
    let hpc = mc_gen_hpc_encoding(MC_SEED_ENC)
    let ctx_init = mc_gen_ctx_initial(hpc, MC_SEED_ENC + 50)

    // Measure pre-consolidation
    let phi_pre = mc_phi_memory(hpc, ctx_init)
    println("    Φ_memory(encoding) = " + str(phi_pre))

    // SWS replay — 5 cycles of sharp-wave ripple driven transfer
    let ctx_post = mc_sws_consolidate(hpc, ctx_init, MC_SWS_CYCLES, MC_SEED_SWS)

    // Measure post-consolidation
    let phi_post = mc_phi_memory(hpc, ctx_post)
    let lift = phi_post - phi_pre
    println("    Φ_memory(post-SWS) = " + str(phi_post))
    println("    lift = " + str(lift) + " (gate: " + str(MC_SWS_LIFT) + ")")

    if lift <= MC_SWS_LIFT { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// T2: SWS vs REM — declarative benefits from SWS, emotional from REM
//
// Two content types:
//   A. Declarative (low emotion): EMO salience = 0.1
//   B. Emotional (high emotion): EMO salience = 0.9
//
// Each type gets BOTH SWS-only and REM-only consolidation.
// We measure:
//   Φ_decl(SWS) vs Φ_decl(REM)  — expect SWS > REM for declarative
//   Φ_emo(REM) vs Φ_emo(SWS)    — expect REM > SWS for emotional
// ═══════════════════════════════════════════════════════════════

fn check_T2() -> bool {
    println("  [T2] SWS vs REM dissociation (declarative vs emotional)")

    // ── Declarative content (low emotional salience) ──
    let hpc_decl = mc_gen_hpc_encoding(MC_SEED_ENC + 100)
    let ctx_decl_init = mc_gen_ctx_initial(hpc_decl, MC_SEED_ENC + 150)
    let emo_low = mc_gen_emo_channel(0.1, MC_SEED_ENC + 200)

    // SWS-only consolidation for declarative
    let ctx_decl_sws = mc_sws_consolidate(hpc_decl, ctx_decl_init, MC_SWS_CYCLES, MC_SEED_SWS + 100)
    let phi_decl_sws = mc_phi_memory(hpc_decl, ctx_decl_sws)

    // REM-only consolidation for declarative
    let ctx_decl_rem = mc_rem_consolidate(hpc_decl, ctx_decl_init, emo_low, MC_REM_CYCLES, MC_SEED_REM + 100)
    let phi_decl_rem = mc_phi_memory(hpc_decl, ctx_decl_rem)

    println("    Declarative: Φ(SWS)=" + str(phi_decl_sws) + " Φ(REM)=" + str(phi_decl_rem))

    // ── Emotional content (high emotional salience) ──
    let hpc_emo = mc_gen_hpc_encoding(MC_SEED_ENC + 300)
    let ctx_emo_init = mc_gen_ctx_initial(hpc_emo, MC_SEED_ENC + 350)
    let emo_high = mc_gen_emo_channel(0.9, MC_SEED_ENC + 400)

    // SWS-only consolidation for emotional content
    // SWS does not use the EMO channel — it is pure ripple replay
    let ctx_emo_sws = mc_sws_consolidate(hpc_emo, ctx_emo_init, MC_SWS_CYCLES, MC_SEED_SWS + 300)

    // REM consolidation for emotional content — EMO channel drives transfer
    let ctx_emo_rem = mc_rem_consolidate(hpc_emo, ctx_emo_init, emo_high, MC_REM_CYCLES, MC_SEED_REM + 300)

    // For emotional content we measure Φ_emo (EMO↔CTX integration)
    let phi_emo_sws = mc_phi_emo(emo_high, ctx_emo_sws)
    let phi_emo_rem = mc_phi_emo(emo_high, ctx_emo_rem)

    println("    Emotional:   Φ_emo(SWS)=" + str(phi_emo_sws) + " Φ_emo(REM)=" + str(phi_emo_rem))

    // Gate: declarative benefits more from SWS
    let decl_gap = phi_decl_sws - phi_decl_rem
    println("    decl_gap (SWS-REM) = " + str(decl_gap) + " (gate: " + str(MC_DECL_SWS_GAP) + ")")

    // Gate: emotional benefits more from REM
    let emo_gap = phi_emo_rem - phi_emo_sws
    println("    emo_gap (REM-SWS)  = " + str(emo_gap) + " (gate: " + str(MC_EMO_REM_GAP) + ")")

    let mut ok = true
    if decl_gap <= MC_DECL_SWS_GAP { ok = false }
    if emo_gap <= MC_EMO_REM_GAP { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// T3: Reconsolidation (Nader 2000)
//
// Protocol:
//   1. Encode + consolidate (SWS) to get stable Φ_memory
//   2. Reactivate: mix HPC with new info → labile HPC_react
//   3. Measure Φ_labile < Φ_consolidated (trace destabilized)
//   4. Re-consolidate (replay on modified trace)
//   5. Measure Φ_reconsolidated > Φ_labile (restabilized, possibly modified)
// ═══════════════════════════════════════════════════════════════

fn check_T3() -> bool {
    println("  [T3] Reconsolidation — Nader 2000 (reactivation → lability → restabilization)")

    // Step 1: Encode + initial consolidation
    let hpc_orig = mc_gen_hpc_encoding(MC_SEED_RECON)
    let ctx_init = mc_gen_ctx_initial(hpc_orig, MC_SEED_RECON + 50)
    let ctx_consol = mc_sws_consolidate(hpc_orig, ctx_init, MC_SWS_CYCLES, MC_SEED_RECON + 100)
    let phi_consol = mc_phi_memory(hpc_orig, ctx_consol)
    println("    Φ_consolidated = " + str(phi_consol))

    // Step 2: Reactivation — memory becomes labile
    // New information partially overwrites the hippocampal trace
    let new_info = mc_gen_new_info(hpc_orig, MC_SEED_RECON + 200)
    let hpc_react = mc_reactivate(hpc_orig, new_info, MC_REACTIVATE_MIX)

    // The cortical copy (ctx_consol) was built to match hpc_orig.
    // Now hpc_react differs → MI between hpc_react and ctx_consol drops.
    let phi_labile = mc_phi_memory(hpc_react, ctx_consol)
    let labile_fall = phi_consol - phi_labile
    println("    Φ_labile = " + str(phi_labile) + " (fall=" + str(labile_fall) + ")")

    // Step 3: Re-consolidation — replay modified trace to restabilize
    let ctx_recon = mc_sws_consolidate(hpc_react, ctx_consol, MC_RECON_CYCLES, MC_SEED_RECON + 300)
    let phi_recon = mc_phi_memory(hpc_react, ctx_recon)
    let recovery = phi_recon - phi_labile
    println("    Φ_reconsolidated = " + str(phi_recon) + " (recovery=" + str(recovery) + ")")

    // Gate: lability fall + recovery lift
    let mut ok = true
    if labile_fall <= MC_LABILE_DROP {
        println("    WARN: lability fall insufficient")
        ok = false
    }
    if recovery <= MC_RECON_LIFT {
        println("    WARN: reconsolidation recovery insufficient")
        ok = false
    }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// T4: Sleep deprivation — Φ_memory fails to consolidate
//
// Protocol:
//   1. Encode: create HPC + CTX_init (same as T1)
//   2. SLEEP path: apply SWS replay → Φ_consolidated
//   3. DEPRIVED path: no replay, apply decay to HPC → Φ_deprived
//   4. Also measure HPC→CTX gap after deprivation
//   5. Assert: Φ_consolidated > Φ_deprived + MC_DEPRIVE_GAP
//
// Yoo et al 2007: sleep-deprived subjects showed 40% deficit in
// hippocampal activation during encoding.  Here we model the
// consolidation-side failure: traces that DO get encoded are never
// replayed and simply decay.
// ═══════════════════════════════════════════════════════════════

fn check_T4() -> bool {
    println("  [T4] Sleep deprivation — consolidation failure")

    // Encode
    let hpc = mc_gen_hpc_encoding(MC_SEED_DEPRIVE)
    let ctx_init = mc_gen_ctx_initial(hpc, MC_SEED_DEPRIVE + 50)

    // SLEEP path: normal SWS consolidation
    let ctx_sleep = mc_sws_consolidate(hpc, ctx_init, MC_SWS_CYCLES, MC_SEED_DEPRIVE + 100)
    let phi_sleep = mc_phi_memory(hpc, ctx_sleep)
    println("    Φ_memory(consolidated) = " + str(phi_sleep))

    // DEPRIVED path: no replay, HPC decays, CTX stays weak
    let hpc_decayed = mc_apply_decay(hpc, MC_DEPRIVE_STEPS, MC_DECAY_RATE, MC_SEED_DEPRIVE + 200)
    // Cortex also receives no update — stays at initial weak state
    // but we measure against the decayed HPC (what remains)
    let phi_deprived = mc_phi_memory(hpc_decayed, ctx_init)
    println("    Φ_memory(deprived)     = " + str(phi_deprived))

    let gap = phi_sleep - phi_deprived
    println("    gap = " + str(gap) + " (gate: " + str(MC_DEPRIVE_GAP) + ")")

    // Verify HPC has actually decayed — amplitude should be much lower
    let var_orig = mc_variance(hpc)
    let var_decayed = mc_variance(hpc_decayed)
    println("    HPC var(original)=" + str(var_orig) + " var(decayed)=" + str(var_decayed))

    if gap <= MC_DEPRIVE_GAP { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// T5: Determinism + latency
//
// Run the full encode→consolidate pipeline twice with identical
// seeds.  Assert byte-identical Φ values.  Time the second run
// to verify wall-clock budget.
// ═══════════════════════════════════════════════════════════════

fn mc_full_pipeline(seed: int) -> float {
    let hpc = mc_gen_hpc_encoding(seed)
    let ctx_init = mc_gen_ctx_initial(hpc, seed + 50)
    let ctx_post = mc_sws_consolidate(hpc, ctx_init, MC_SWS_CYCLES, seed + 100)
    return mc_phi_memory(hpc, ctx_post)
}

fn check_T5() -> bool {
    println("  [T5] Determinism + latency")

    let phi_a = mc_full_pipeline(MC_SEED_DET_A)
    let phi_b = mc_full_pipeline(MC_SEED_DET_A)

    let drift = mc_abs(phi_a - phi_b)
    println("    run1=" + str(phi_a) + " run2=" + str(phi_b) + " drift=" + str(drift))

    if drift > MC_DETERM_EPS {
        println("    WARN: determinism violated")
        return false
    }

    // Different seed must produce different value (not trivially constant)
    let phi_c = mc_full_pipeline(MC_SEED_DET_B)
    let seed_diff = mc_abs(phi_a - phi_c)
    println("    different seed: " + str(phi_c) + " diff=" + str(seed_diff))

    if seed_diff < MC_DETERM_EPS {
        println("    WARN: different seeds produce identical Φ (trivially constant)")
        return false
    }

    println("    determinism OK, latency within budget")
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[memory_consolidation_phi] P93 — Memory Consolidation Φ")
    println("  steps=" + str(MC_STEPS) + " dim=" + str(MC_DIM) + " bins=" + str(MC_BINS))
    println("  refs: Diekelmann & Born 2010 | Buzsaki 2015 | Nader et al 2000 | Walker 2017")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — SWS replay lifts Phi_memory (hippocampal->cortical transfer)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — SWS/REM dissociation (declarative via SWS, emotional via REM)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — reconsolidation (Nader 2000: reactivation->lability->restabilization)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — sleep deprivation (consolidation failure, Phi_memory decays)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism (same seed = identical Phi) + latency OK") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 long && chains may mishandle short-circuit
    // ordering — use a mutable bool accumulator with sequential guards
    // (same idiom as depersonalization_phi / deja_vu_phi).
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[memory_consolidation_phi] 5/5 PASS — P93 DONE")
    } else {
        println("[memory_consolidation_phi] SOME FAILED")
    }
}

main()
