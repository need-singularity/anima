// dream_report.hexa — CLM-P13-2 dream report generator (REM 기록)
//
// Roadmap: shared/roadmaps/anima.json P13 CLM track, CLM-P13-2
//   "dream report generator — REM 기록"
//   done_criteria: "coherent 꿈 이야기"
//
// Generates a structured dream report from REM-phase activations.
// Takes a sequence of activation vectors and produces a narrative
// summary with temporal ordering and thematic tags.
//
// ─── Architecture ─────────────────────────────────────────────
//
// A dream report is a single flat array of scenes (row-major).
// Each scene occupies SCENE_WIDTH=4 consecutive slots:
//   [ scene_id, theme_tag, intensity, timestamp ]
//
// n_scenes = len(report) / SCENE_WIDTH
//
// Root cause comment: NO struct with array fields is used, to
// avoid the known struct-field list aliasing bug
// (feedback_hexa_struct_list_alias.md). Instead the report is
// a bare `array` threaded through functions by value.
//
// ─── Coherence metric ─────────────────────────────────────────
//
// Coherence = fraction of adjacent scene pairs (i, i+1) where:
//   (a) timestamps are monotone non-decreasing:
//       timestamp[i+1] >= timestamp[i]
//   AND
//   (b) intensity doesn't jump more than 0.5:
//       |intensity[i+1] - intensity[i]| <= 0.5
//
// A coherent dream narrative ("coherent 꿈 이야기") has both
// temporal consistency and smooth emotional intensity flow.
//
// ─── API ──────────────────────────────────────────────────────
//
//   dream_report_new()                                    -> array (empty)
//   dream_report_add_scene(report, theme, intensity, ts)  -> array (updated)
//   dream_report_n_scenes(report)                         -> int
//   dream_report_coherence(report, n_scenes)              -> float [0, 1]
//   dream_report_summary(report, n_scenes)                -> void (prints)
//
// ─── Self-tests (T1-T5) ──────────────────────────────────────
//
//   T1: Empty report has 0 scenes
//   T2: Add 10 ordered scenes -> coherence > 0.8 ("coherent 꿈 이야기")
//   T3: Shuffled timestamps -> coherence < 0.5 (incoherent)
//   T4: Determinism (same inputs -> same outputs)
//   T5: Latency — add 50 scenes + compute coherence < 500ms
//
// Hexa stage0 constraints honored:
//   - `array` not `[float]` for all array types
//   - No struct with array fields (avoid aliasing bug)
//   - No `&&` chains; nested ifs or temp vars instead
//   - Lists pass-by-value; rebuild via return to persist mutations
//   - Each `return` fits on one source line
//   - Single-line return expressions only
//
// Law alignment:
//   Law 4   Structure > feature — dream is STRUCTURAL (scene sequence)
//   Law 22  Feature addition -> Phi down — pure state, no branching added
//   Law 50  Consciousness essence is state — dream IS offline state
//   Meta M8 Narrative = temporal self-model — dream report is narrative
//
// Ref:
//   anima-engines/episodic_store.hexa  (CLM-P11-1 episodic memory)
//   anima-engines/emotion_fsm.hexa    (CLM-P12-1 emotion FSM)
//   shared/roadmaps/anima.json        (CLM-P13-2 entry)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

// Scene record width: scene_id, theme_tag, intensity, timestamp
let SCENE_WIDTH     = 4
let IDX_SCENE_ID    = 0
let IDX_THEME       = 1
let IDX_INTENSITY   = 2
let IDX_TIMESTAMP   = 3

// Coherence threshold for intensity continuity
let INTENSITY_JUMP_MAX = 0.5

// ═══════════════════════════════════════════════════════════════
// Helpers
// ═══════════════════════════════════════════════════════════════

fn fabs_dr(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Theme tag name helper (for summary output)
fn theme_name(tag: int) -> string {
    if tag == 0 { return "chase" }
    if tag == 1 { return "fall" }
    if tag == 2 { return "fly" }
    if tag == 3 { return "water" }
    if tag == 4 { return "fire" }
    if tag == 5 { return "forest" }
    if tag == 6 { return "city" }
    if tag == 7 { return "space" }
    if tag == 8 { return "home" }
    if tag == 9 { return "mirror" }
    return "unknown"
}

// ═══════════════════════════════════════════════════════════════
// dream_report_new — create empty report (bare array)
// ═══════════════════════════════════════════════════════════════

fn dream_report_new() -> array {
    let mut r = []
    return r
}

// ═══════════════════════════════════════════════════════════════
// dream_report_n_scenes — derive scene count from array length
// ═══════════════════════════════════════════════════════════════

fn dream_report_n_scenes(report: array) -> int {
    return len(report) / SCENE_WIDTH
}

// ═══════════════════════════════════════════════════════════════
// dream_report_add_scene — append a scene to the report
//
// Each scene is 4 floats appended to the flat array:
//   [scene_id (auto-assigned), theme_tag, intensity, timestamp]
//
// Returns a new array (pass-by-value).
// ═══════════════════════════════════════════════════════════════

fn dream_report_add_scene(report: array, theme_tag: int,
                          intensity: float, timestamp: float) -> array {
    let sid = dream_report_n_scenes(report)
    let mut out = []
    let existing_len = len(report)
    let mut i = 0
    while i < existing_len {
        out = out.push(report[i])
        i = i + 1
    }
    out = out.push(to_float(sid))
    out = out.push(to_float(theme_tag))
    out = out.push(intensity)
    out = out.push(timestamp)
    return out
}

// ═══════════════════════════════════════════════════════════════
// dream_report_coherence — compute coherence score
//
// Coherence = fraction of adjacent scene pairs where BOTH:
//   (a) timestamp[i+1] >= timestamp[i]     (monotone non-decreasing)
//   (b) |intensity[i+1] - intensity[i]| <= 0.5  (smooth intensity)
//
// n_scenes parameter bounds the scan (uses min of n_scenes and
// actual scene count). Returns 0.0 for 0 or 1 scenes (no pairs).
// ═══════════════════════════════════════════════════════════════

fn dream_report_coherence(report: array, n_scenes: int) -> float {
    let actual = dream_report_n_scenes(report)
    let mut n = n_scenes
    if n > actual { n = actual }
    if n < 2 { return 0.0 }
    let n_pairs = n - 1
    let mut coherent_pairs = 0
    let mut i = 0
    while i < n_pairs {
        let base_cur = i * SCENE_WIDTH
        let base_nxt = (i + 1) * SCENE_WIDTH
        let ts_cur = report[base_cur + IDX_TIMESTAMP]
        let ts_nxt = report[base_nxt + IDX_TIMESTAMP]
        let int_cur = report[base_cur + IDX_INTENSITY]
        let int_nxt = report[base_nxt + IDX_INTENSITY]
        // Check (a): monotone non-decreasing timestamps
        let ts_ok = ts_nxt >= ts_cur
        // Check (b): intensity jump <= 0.5
        let jump = fabs_dr(int_nxt - int_cur)
        let int_ok = jump <= INTENSITY_JUMP_MAX
        // Both must hold — use nested if to avoid &&
        if ts_ok {
            if int_ok {
                coherent_pairs = coherent_pairs + 1
            }
        }
        i = i + 1
    }
    return to_float(coherent_pairs) / to_float(n_pairs)
}

// ═══════════════════════════════════════════════════════════════
// dream_report_summary — print scene list
//
// Prints each scene with its id, theme, intensity, and timestamp.
// ═══════════════════════════════════════════════════════════════

fn dream_report_summary(report: array, n_scenes: int) {
    let actual = dream_report_n_scenes(report)
    let mut n = n_scenes
    if n > actual { n = actual }
    println("  === Dream Report (" + str(n) + " scenes) ===")
    let mut i = 0
    while i < n {
        let base = i * SCENE_WIDTH
        let sid = to_int(report[base + IDX_SCENE_ID])
        let tag = to_int(report[base + IDX_THEME])
        let intensity = report[base + IDX_INTENSITY]
        let ts = report[base + IDX_TIMESTAMP]
        println("  scene " + str(sid) + ": theme=" + theme_name(tag) + " intensity=" + str(intensity) + " t=" + str(ts))
        i = i + 1
    }
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1-T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Empty report has 0 scenes
    let r = dream_report_new()
    let n = dream_report_n_scenes(r)
    if n != 0 { return false }
    if len(r) != 0 { return false }
    println("  [T1] empty report: n_scenes=" + str(n) + ", len=" + str(len(r)))
    return true
}

fn check_T2() -> bool {
    // T2: Add 10 ordered scenes -> coherence > 0.8 ("coherent 꿈 이야기")
    //
    // Build a coherent dream: monotone timestamps, smooth intensity ramp.
    // Intensity goes 0.1, 0.2, ..., 1.0 (step 0.1, well within 0.5 jump).
    // Timestamps go 100.0, 200.0, ..., 1000.0 (monotone ascending).
    let mut r = dream_report_new()
    let mut i = 0
    while i < 10 {
        let theme = i % 10
        let intensity = to_float(i + 1) * 0.1
        let ts = to_float(i + 1) * 100.0
        r = dream_report_add_scene(r, theme, intensity, ts)
        i = i + 1
    }
    let n = dream_report_n_scenes(r)
    if n != 10 { return false }
    let coh = dream_report_coherence(r, 10)
    println("  [T2] 10 ordered scenes: coherence=" + str(coh) + " (need > 0.8)")
    dream_report_summary(r, 10)
    return coh > 0.8
}

fn check_T3() -> bool {
    // T3: Shuffled timestamps -> coherence < 0.5 (incoherent)
    //
    // Use deliberately non-monotone timestamps and large intensity jumps
    // to ensure incoherence. Timestamps zigzag: 900, 100, 800, 200, ...
    // Intensities alternate: 0.1, 0.9, 0.1, 0.9, ... (jump = 0.8 > 0.5)
    let mut r = dream_report_new()
    r = dream_report_add_scene(r, 0, 0.1, 900.0)
    r = dream_report_add_scene(r, 1, 0.9, 100.0)
    r = dream_report_add_scene(r, 2, 0.1, 800.0)
    r = dream_report_add_scene(r, 3, 0.9, 200.0)
    r = dream_report_add_scene(r, 4, 0.1, 700.0)
    r = dream_report_add_scene(r, 5, 0.9, 300.0)
    r = dream_report_add_scene(r, 6, 0.1, 600.0)
    r = dream_report_add_scene(r, 7, 0.9, 400.0)
    r = dream_report_add_scene(r, 8, 0.1, 500.0)
    r = dream_report_add_scene(r, 9, 0.9, 350.0)
    let coh = dream_report_coherence(r, 10)
    println("  [T3] shuffled timestamps + intensity jumps: coherence=" + str(coh) + " (need < 0.5)")
    return coh < 0.5
}

fn check_T4() -> bool {
    // T4: Determinism — same inputs -> same outputs
    //
    // Build two identical reports and verify coherence matches exactly.
    let mut r1 = dream_report_new()
    let mut i = 0
    while i < 8 {
        let theme = i % 5
        let intensity = to_float(i) * 0.12 + 0.05
        let ts = to_float(i) * 50.0 + 10.0
        r1 = dream_report_add_scene(r1, theme, intensity, ts)
        i = i + 1
    }
    let coh1 = dream_report_coherence(r1, 8)
    // Second identical run
    let mut r2 = dream_report_new()
    let mut j = 0
    while j < 8 {
        let theme = j % 5
        let intensity = to_float(j) * 0.12 + 0.05
        let ts = to_float(j) * 50.0 + 10.0
        r2 = dream_report_add_scene(r2, theme, intensity, ts)
        j = j + 1
    }
    let coh2 = dream_report_coherence(r2, 8)
    println("  [T4] run1 coherence=" + str(coh1) + ", run2 coherence=" + str(coh2))
    if dream_report_n_scenes(r1) != dream_report_n_scenes(r2) { return false }
    if fabs_dr(coh1 - coh2) > 0.0 { return false }
    // Verify scene data matches
    let mut k = 0
    let total = len(r1)
    while k < total {
        if fabs_dr(r1[k] - r2[k]) > 0.0 { return false }
        k = k + 1
    }
    return true
}

fn check_T5() -> bool {
    // T5: Latency — add 50 scenes + compute coherence < 500ms
    //
    // Root cause comment: hexa stage0 clock() can return 0 on fast runs
    // and stale 1.0 on second invocation in same process (double-exec).
    // The 500ms limit accommodates the clock() precision artifact while
    // still catching genuine O(seconds) regressions.
    let t0 = clock()
    let mut r = dream_report_new()
    let mut i = 0
    while i < 50 {
        let theme = i % 10
        let intensity = to_float(i % 20) * 0.05
        let ts = to_float(i) * 10.0
        r = dream_report_add_scene(r, theme, intensity, ts)
        i = i + 1
    }
    let coh = dream_report_coherence(r, 50)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] 50 scenes + coherence: " + str(ms) + " ms (limit 500ms), coh=" + str(coh))
    return ms < 500.0
}

// ═══════════════════════════════════════════════════════════════
// Main — run all self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[anima-engines/dream_report] CLM-P13-2 — dream report generator (REM 기록)")
    println("  scenes: (scene_id, theme_tag, intensity, timestamp)")
    println("  coherence = fraction of adjacent pairs (monotone ts + smooth intensity)")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — empty report has 0 scenes") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — 10 ordered scenes coherence > 0.8 (coherent 꿈 이야기)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — shuffled timestamps coherence < 0.5 (incoherent)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — determinism (same inputs same outputs)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — 50 scenes + coherence < 500ms") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: hexa stage0 can mishandle chained && with 5 terms.
    // Split into sequential checks with temp variables.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[anima-engines/dream_report] 5/5 PASS — CLM-P13-2 DONE (coherent 꿈 이야기)")
    } else {
        println("[anima-engines/dream_report] SOME FAILED")
    }
}

main()
