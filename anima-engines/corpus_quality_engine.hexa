fn corpus_latin_heavy() -> string {
    return "Hello world this is English content only\n"
         + "We are testing the language detection filter here\n"
         + "Lorem ipsum dolor sit amet consectetur adipiscing elit\n"
         + "The quick brown fox jumps over the lazy dog repeatedly\n"
}

fn corpus_mixed() -> string {
    return "안녕하세요 hello 반갑습니다 world\n"
         + "기계학습 machine learning 매우 중요하다\n"
         + "의식 consciousness 은 복잡한 현상이다\n"
         + "한국어 Korean 자연어 natural language 처리 processing\n"
         + "인공지능 artificial intelligence 분야의 핵심 주제\n"
