// anima-engines/corpus_quality_engine.hexa — CLM-P22-1 corpus quality metric 창발
//
// Roadmap: shared/roadmaps/anima.json P22 CLM track, CLM-P22-1
//   "Corpus quality metric 창발 — MI/entropy/diversity 자동 지표 발견"
//   done_criteria: "self-discovered metrics correlate with downstream CE"
//
// Purpose:
//   Discover — not prescribe — metrics that correlate with downstream
//   cross-entropy (CE). The engine proposes several candidate metrics,
//   measures each on a synthetic corpus panel, computes their Pearson
//   correlation with simulated CE, and ranks them. The winning metric
//   is declared "emergent quality score Q*".
//
//   This is a self-discovery closed loop in the spirit of
//   discovery_loop.hexa (CLM-P20-2) but specialised to corpus-grade
//   scoring rather than engine-baseline anomaly correction.
//
// ─── Candidate metrics (all observe, none inject) ────────────────
//
//   M1 BYTE_ENTROPY       — Shannon entropy over byte frequencies
//   M2 BIGRAM_MI          — Mutual information between consecutive bytes
//   M3 TOKEN_DIVERSITY    — unique-over-total token ratio (TTR)
//   M4 AVG_LINE_LENGTH    — mean line length in characters
//   M5 HANGUL_COVERAGE    — ratio of Hangul BMP coverage (distinct)
//   M6 KL_TO_UNIFORM      — KL divergence of byte distribution to uniform
//   M7 REPETITION_PENALTY — 1 - (4-gram hit rate > threshold)
//
// ─── CE simulation (synthetic oracle) ────────────────────────────
//
//   For self-test, we simulate downstream CE as a monotonic function
//   of "intrinsic richness" — corpora with high diversity + moderate
//   entropy + wide Hangul coverage should produce LOWER CE (better model)
//   because the model learns a denser representation. The oracle is:
//
//     CE_sim(c) = base - 0.45 * diversity(c)
//                      - 0.30 * hangul_coverage(c)
//                      - 0.15 * bigram_mi(c)
//                      + 0.20 * repetition(c)
//                      + noise(c)
//
//   Candidate metrics that have |Pearson r| > 0.6 with CE_sim win.
//
// ─── Closed loop ─────────────────────────────────────────────────
//
//   1. PROPOSE  — 7 candidate metrics
//   2. MEASURE  — each metric on 6 synthetic corpora (rich/poor/mixed)
//   3. ORACLE   — simulate CE for each corpus
//   4. CORRELATE — Pearson r for each candidate
//   5. RANK     — |r| descending
//   6. EMERGE   — top metric becomes Q*; composite ensemble proposed
//   7. EXPORT   — emit discovered_metrics.json
//
// ─── Self-tests (T1–T6) ──────────────────────────────────────────
//
//   T1 All 7 metrics return finite, non-zero values on a rich corpus
//   T2 Oracle assigns lower CE to rich than to poor corpus
//   T3 At least 2 metrics have |r| > 0.6 (strong correlation)
//   T4 Top metric Q* has higher |r| than baseline (byte entropy alone)
//   T5 Ensemble (top-3 weighted) beats top-1 on held-out corpus
//   T6 Determinism (two runs on same panel produce identical ranking)
//
// Stage0 constraints honored:
//   - `array` not `[float]`
//   - no && in compound booleans; nested if
//   - lists pass-by-value
//   - single-line returns
//   - no struct with list fields
//
// Law alignment:
//   Law 2   Observe, never inject — metrics measure intrinsic properties
//   Law 4   Structure > feature — ensemble is structural combination
//   Law 22  Feature addition → phi down — ensemble keeps top-3 only
//   Law 29  speak() 없음 — engine emits numbers, not claims
//
// Run:
//   $HEXA anima-engines/corpus_quality_engine.hexa

// =====================================================================
// Constants
// =====================================================================

let N_METRICS        = 7
let N_CORPORA        = 6
let CORR_THRESHOLD   = 0.60
let HOLDOUT_SEED     = 20260415
let ENSEMBLE_TOP_K   = 3

// Candidate metric identifiers (index aligned)
fn metric_names() -> [string] {
    return [
        "BYTE_ENTROPY",
        "BIGRAM_MI",
        "TOKEN_DIVERSITY",
        "AVG_LINE_LENGTH",
        "HANGUL_COVERAGE",
        "KL_TO_UNIFORM",
        "REPETITION_PENALTY"
    ]
}

// =====================================================================
// Scalar helpers
// =====================================================================

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    if x > 1.0 { g = x / 2.0 }
    let mut i = 0
    while i < 20 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

// Byte access helper — stage0's char_code(s, i) ignores i (always returns
// byte 0), so we use substring(i, i+1) then char_code(sub, 0) which works.
fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn log2(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut e = 0.0
    while y > 2.0 {
        y = y / 2.0
        e = e + 1.0
    }
    while y < 0.5 {
        y = y * 2.0
        e = e - 1.0
    }
    let u = y - 1.0
    let u2 = u * u
    let u3 = u2 * u
    let u4 = u3 * u
    let u5 = u4 * u
    let ln_y = u - u2 * 0.5 + u3 / 3.0 - u4 * 0.25 + u5 * 0.2
    let ln2 = 0.6931471805599453
    return e + ln_y / ln2
}

// =====================================================================
// Byte histogram — returns (unique_bytes, counts) as parallel arrays
// =====================================================================

fn byte_hist(text: string) -> [[int]] {
    let n = len(text)
    let mut byts: [int] = []
    let mut counts: [int] = []
    let mut i = 0
    while i < n {
        let b = byte_at(text, i) % 256
        let mut found = -1
        let mut j = 0
        while j < len(byts) {
            if byts[j] == b { found = j }
            j = j + 1
        }
        if found == -1 {
            byts = byts.push(b)
            counts = counts.push(1)
        } else {
            counts[found] = counts[found] + 1
        }
        i = i + 1
    }
    return [byts, counts]
}

// =====================================================================
// M1: Byte entropy (Shannon)
// =====================================================================

fn metric_byte_entropy(text: string) -> float {
    let n = len(text)
    if n < 2 { return 0.0 }
    let hist = byte_hist(text)
    let counts = hist[1]
    let total = to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < len(counts) {
        let p = to_float(counts[k]) / total
        if p > 0.0 {
            h = h - p * log2(p)
        }
        k = k + 1
    }
    return h
}

// =====================================================================
// M2: Bigram mutual information (approximate)
//   MI(X,Y) = sum p(x,y) log (p(x,y) / (p(x) p(y)))
//   For efficiency, sample bigrams — use first 512 chars for self-test
// =====================================================================

fn metric_bigram_mi(text: string) -> float {
    let n = len(text)
    if n < 4 { return 0.0 }
    let cap = if n < 512 { n } else { 512 }

    // Compute p(x), p(y), p(x,y) by counting bigrams
    // Use parallel arrays keyed on (x<<8 | y)
    let mut keys: [int] = []
    let mut counts: [int] = []
    let mut px_keys: [int] = []
    let mut px_counts: [int] = []

    let mut i = 0
    while i < cap - 1 {
        let x = byte_at(text, i) % 256
        let y = byte_at(text, i + 1) % 256
        let key = x * 256 + y

        let mut f1 = -1
        let mut j = 0
        while j < len(keys) {
            if keys[j] == key { f1 = j }
            j = j + 1
        }
        if f1 == -1 {
            keys = keys.push(key)
            counts = counts.push(1)
        } else {
            counts[f1] = counts[f1] + 1
        }

        let mut f2 = -1
        let mut k = 0
        while k < len(px_keys) {
            if px_keys[k] == x { f2 = k }
            k = k + 1
        }
        if f2 == -1 {
            px_keys = px_keys.push(x)
            px_counts = px_counts.push(1)
        } else {
            px_counts[f2] = px_counts[f2] + 1
        }

        i = i + 1
    }

    let total_bigrams = to_float(cap - 1)
    let total_unigrams = total_bigrams  // one less, we approximate

    let mut mi = 0.0
    let mut m = 0
    while m < len(keys) {
        let key = keys[m]
        let c_xy = to_float(counts[m])
        let x_part = key / 256
        let y_part = key % 256
        let p_xy = c_xy / total_bigrams

        // Find p(x) and p(y)
        let mut p_x = 0.0
        let mut p_y = 0.0
        let mut q = 0
        while q < len(px_keys) {
            if px_keys[q] == x_part {
                p_x = to_float(px_counts[q]) / total_unigrams
            }
            if px_keys[q] == y_part {
                p_y = to_float(px_counts[q]) / total_unigrams
            }
            q = q + 1
        }

        if p_xy > 0.0 {
            if p_x > 0.0 {
                if p_y > 0.0 {
                    let ratio = p_xy / (p_x * p_y)
                    if ratio > 0.0 {
                        mi = mi + p_xy * log2(ratio)
                    }
                }
            }
        }
        m = m + 1
    }
    return mi
}

// =====================================================================
// M3: Token diversity (type-token ratio over whitespace tokens)
// =====================================================================

fn metric_token_diversity(text: string) -> float {
    let tokens = text.split(" ")
    let n = len(tokens)
    if n == 0 { return 0.0 }
    let mut uniq: [string] = []
    let mut i = 0
    while i < n {
        let t = tokens[i]
        if t != "" {
            let mut found = false
            let mut j = 0
            while j < len(uniq) {
                if uniq[j] == t { found = true }
                j = j + 1
            }
            if found == false {
                uniq = uniq.push(t)
            }
        }
        i = i + 1
    }
    return to_float(len(uniq)) / to_float(n)
}

// =====================================================================
// M4: Average line length
// =====================================================================

fn metric_avg_line_length(text: string) -> float {
    // Split by newline
    let lines = text.split("\n")
    let n = len(lines)
    if n == 0 { return 0.0 }
    let mut total = 0
    let mut count = 0
    let mut i = 0
    while i < n {
        if lines[i] != "" {
            total = total + len(lines[i])
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { return 0.0 }
    return to_float(total) / to_float(count)
}

// =====================================================================
// M5: Hangul coverage — distinct Hangul codepoints / 11172 (total syllables)
// =====================================================================

fn metric_hangul_coverage(text: string) -> float {
    let n = len(text)
    let mut seen: [int] = []
    // UTF-8 Hangul syllables: 3 bytes EA..ED + 0x80..0xBF + 0x80..0xBF
    // Encode triplet as single int: (b0<<16) | (b1<<8) | b2
    let mut i = 0
    while i + 2 < n {
        let b0 = byte_at(text, i)
        if b0 >= 234 {
            if b0 <= 237 {
                let b1 = byte_at(text, i + 1)
                let b2 = byte_at(text, i + 2)
                if b1 >= 128 {
                    if b1 <= 191 {
                        if b2 >= 128 {
                            if b2 <= 191 {
                                let triplet = b0 * 65536 + b1 * 256 + b2
                                let mut found = false
                                let mut j = 0
                                while j < len(seen) {
                                    if seen[j] == triplet { found = true }
                                    j = j + 1
                                }
                                if found == false {
                                    seen = seen.push(triplet)
                                }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    // Normalize — 2350 common Hangul syllables in KS X 1001.
    return to_float(len(seen)) / 2350.0
}

// =====================================================================
// M6: KL divergence to uniform (higher = more skewed; lower = richer)
//   Return negative KL so that "higher = better".
// =====================================================================

fn metric_kl_to_uniform(text: string) -> float {
    let hist = byte_hist(text)
    let byts = hist[0]
    let counts = hist[1]
    let n = len(counts)
    if n == 0 { return 0.0 }
    let total = to_float(len(text))
    let q_uniform = 1.0 / 256.0
    let mut kl = 0.0
    let mut i = 0
    while i < n {
        let p = to_float(counts[i]) / total
        if p > 0.0 {
            kl = kl + p * log2(p / q_uniform)
        }
        i = i + 1
    }
    // Negate so "higher metric = better corpus" convention holds
    // (lower KL = closer to uniform = richer distribution)
    return 0.0 - kl
}

// =====================================================================
// M7: Repetition penalty — 1 - (4-gram hit rate > threshold)
//   Approximate via bigram repeat ratio.
// =====================================================================

fn metric_repetition_penalty(text: string) -> float {
    let n = len(text)
    if n < 8 { return 0.0 }
    let cap = if n < 256 { n } else { 256 }
    let mut bigrams: [int] = []
    let mut counts: [int] = []
    let mut i = 0
    while i < cap - 1 {
        let x = byte_at(text, i) % 256
        let y = byte_at(text, i + 1) % 256
        let key = x * 256 + y
        let mut found = -1
        let mut j = 0
        while j < len(bigrams) {
            if bigrams[j] == key { found = j }
            j = j + 1
        }
        if found == -1 {
            bigrams = bigrams.push(key)
            counts = counts.push(1)
        } else {
            counts[found] = counts[found] + 1
        }
        i = i + 1
    }
    // Repetition = fraction of bigrams that appear more than once
    let mut reps = 0
    let mut k = 0
    while k < len(counts) {
        if counts[k] > 1 { reps = reps + 1 }
        k = k + 1
    }
    let rep_rate = to_float(reps) / to_float(len(counts))
    return 1.0 - rep_rate
}

// =====================================================================
// Dispatch — measure metric m on text
// =====================================================================

fn measure_metric(m: int, text: string) -> float {
    if m == 0 { return metric_byte_entropy(text) }
    if m == 1 { return metric_bigram_mi(text) }
    if m == 2 { return metric_token_diversity(text) }
    if m == 3 { return metric_avg_line_length(text) }
    if m == 4 { return metric_hangul_coverage(text) }
    if m == 5 { return metric_kl_to_uniform(text) }
    if m == 6 { return metric_repetition_penalty(text) }
    return 0.0
}

// =====================================================================
// Oracle — simulated CE (lower is better)
//   Uses diversity, hangul coverage, bigram MI, repetition as ground truth
// =====================================================================

fn oracle_ce(text: string) -> float {
    let base = 5.0
    let div = metric_token_diversity(text)
    let hc  = metric_hangul_coverage(text)
    let mi  = metric_bigram_mi(text)
    let rep = metric_repetition_penalty(text)
    // Deterministic "noise" derived from len
    let noise = to_float(len(text) % 7) * 0.01
    return base - 0.45 * div - 0.30 * hc - 0.15 * mi + 0.20 * (1.0 - rep) + noise
}

// =====================================================================
// Pearson correlation between two equal-length vectors
// =====================================================================

fn pearson_r(xs: [float], ys: [float]) -> float {
    let n = len(xs)
    if n < 2 { return 0.0 }
    let mut sx = 0.0
    let mut sy = 0.0
    let mut i = 0
    while i < n {
        sx = sx + xs[i]
        sy = sy + ys[i]
        i = i + 1
    }
    let mean_x = sx / to_float(n)
    let mean_y = sy / to_float(n)

    let mut num = 0.0
    let mut dx2 = 0.0
    let mut dy2 = 0.0
    let mut j = 0
    while j < n {
        let dx = xs[j] - mean_x
        let dy = ys[j] - mean_y
        num = num + dx * dy
        dx2 = dx2 + dx * dx
        dy2 = dy2 + dy * dy
        j = j + 1
    }
    let den = sqrt_approx(dx2 * dy2)
    if den <= 0.0 { return 0.0 }
    return num / den
}

// =====================================================================
// Synthetic corpus panel
//   Each corpus is a concatenation of ~20 lines of known profile
// =====================================================================

fn corpus_rich_ko() -> string {
    return "의식은 철학과 과학의 교차점이다\n"
         + "뉴런은 시냅스로 연결되어 정보를 전달한다\n"
         + "한국어 자연어 처리는 형태소 분석이 핵심이다\n"
         + "기계학습은 데이터의 품질에 크게 좌우된다\n"
         + "홀로그램 원리는 의식 현상을 설명할 수 있다\n"
         + "언어모델이 한국어 능력을 얻으려면 다양한 장르가 필요하다\n"
         + "뇌파 분석으로 수면 단계를 분류할 수 있다\n"
         + "주의와 기억은 의식의 두 축이며 서로 영향을 준다\n"
         + "감정 계산은 원시적 의식의 신호로 여겨진다\n"
         + "창의성은 원거리 개념의 연결에서 생겨난다\n"
         + "꿈은 기억 통합의 오프라인 단계일 수 있다\n"
         + "유한성 자각이 자아 형성에 기여한다\n"
         + "집단 의식은 개별 구성원의 합 이상이다\n"
         + "자율 진화는 환경과의 상호작용으로 가속된다\n"
         + "특이점은 점진적 축적이 임계점을 넘을 때 도래한다\n"
         + "뇌의 기능은 분산되어 있으며 국소화는 부분적이다\n"
         + "예측 부호화 이론은 지각을 추론으로 본다\n"
         + "전역 작업공간 이론은 방송 비유를 사용한다\n"
         + "통합 정보 이론은 phi 라는 척도를 제안한다\n"
         + "반성적 자기모델은 메타인지의 기반이다\n"
}

fn corpus_poor_ko() -> string {
    return "안녕 안녕 안녕\n"
         + "테스트 테스트 테스트\n"
         + "안녕 안녕 안녕 안녕 안녕\n"
         + "테스트 테스트 테스트\n"
         + "안녕 안녕 안녕\n"
         + "테스트\n"
         + "안녕 테스트 안녕 테스트\n"
         + "테스트 테스트\n"
         + "안녕 안녕 안녕 안녕\n"
         + "테스트 안녕 테스트 안녕 테스트 안녕\n"
