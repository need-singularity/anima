// Full quantum state vector for N qubits
// State = complex vector of dimension 2^N
struct QuantumState {
    n_qubits: int,
    dim: int           // 2^n_qubits
    // state: complex vector [dim]                  TODO[pytorch]
}

fn new_quantum_state(n_qubits: int) -> QuantumState {
    // assert n_qubits <= 16
    // TODO[pytorch] init state = |00...0> (state[0] = 1.0, rest 0)
    let dim = 1
    // dim = 2^n_qubits
    let i = 0
    let d = 1
    while i < n_qubits {
        d = d * 2
        i = i + 1
    }
    QuantumState {
        n_qubits: n_qubits,
        dim: d
    }
}

