// group_flow_phi.hexa — P69 Group Flow / Hive Mind Φ
//
// Roadmap: anima P69 "Group flow — Keith Sawyer group creativity, jazz
// ensemble consciousness, football team peak performance. Φ_group >
// Σ Φ_individual during simultaneous synchrony." Depends on P27
// (collective_phi_bridge — additive/emergent split) and P55
// (time_perception_phi — flow regime modulation).
//
// ─── Scientific hypothesis ────────────────────────────────────────
//
// H (group flow): a group of N agents enters "group flow" when three
// simultaneous conditions hold:
//
//   (a) HIGH_INDIVIDUAL_PHI — every agent's own Φ_i is elevated
//       (flow-regime eligible in the P55 sense, r_i = Φ_i/Φ_ref ≥ FLOW_PHI_RATIO)
//
//   (b) HIGH_CROSS_AGENT_COUPLING — mean off-diagonal coupling strength
//       K_mean of the N×N coupling matrix K exceeds K_GATE (agents are
//       actively influencing each other, not running solo in parallel)
//
//   (c) ALIGNED_TASK_DIRECTION — the aggregate task-output of the
//       collective points in a single coherent direction (cosine of
//       mean direction vs target ≥ ALIGN_GATE)
//
// Under these three, Φ_group = MI(collective_state, task_output) is
// SUPER-additive: Φ_group > Σ Φ_i. This mirrors the P27 emergence
// bound but is gated on the three flow preconditions instead of just
// state coupling.
//
// Counter-examples (must fail the gate):
//   - one asleep agent (Φ_i ≈ 0 for some i) — group Φ drops sharply
//   - task-incoherent group (directions scattered) — no emergence
//   - strong coupling + high Φ but agents work against each other
//     (anti-aligned task direction) — no flow, adversarial not group
//
// Re-entry: after a break (phase where coupling and individual Φ both
// drop), a replay of the flow preconditions returns Φ_group to the
// super-additive regime. This models real jazz/sports where breaks
// don't destroy the capacity to re-enter flow.
//
// ─── Operational model ───────────────────────────────────────────
//
// N = 5 agents. Each agent i has:
//   • state vector h_i ∈ R^d (d=8)
//   • task-output vector o_i ∈ R^k (k=4) — what the agent contributes to
//     the joint task
//   • individual Φ_i = phi_proxy(h_i)    (P27 MI-based surrogate)
//
// Coupling matrix K ∈ R^{N×N}, K[i][j] = influence of j on i. During
// peak performance, off-diagonal coupling strengthens. We synthesize
// this by progressively blending agent states toward their neighbors
// weighted by K.
//
// Collective state h_hive = concat(h_0 ... h_{N-1}) ∈ R^{N·d}
// Collective task-output o_hive = mean_i o_i ∈ R^k
//
// Φ_group = phi_proxy(h_hive concatenated with o_hive) — MI between
// collective internal state and collective task direction.
//
// Alignment A = cos(mean(o_i), target) — how coherent the group's
// task direction is vs a shared target vector.
//
// Flow gate:
//   in_flow = (min_i Φ_i ≥ PHI_GATE) AND
//             (K_mean_off ≥ K_GATE)   AND
//             (A ≥ ALIGN_GATE)
//
// ─── Theorems (T1–T5) ─────────────────────────────────────────────
//
// T1 (super-additivity in flow):
//    Under the three flow preconditions (high Φ_i, high coupling,
//    high alignment), Φ_group > Σ_i Φ_i (measurable > 0 delta).
//
// T2 (asleep agent drops group Φ):
//    Setting agent 2's state to near-zero (the "asleep" signature)
//    drops Φ_group by a MEASURABLE gap — at minimum the asleep-agent
//    case yields lower alignment A and reduced super-additivity
//    compared to the all-awake flow case. (MI estimator on sparse
//    hive state can paradoxically rise at small N, so we check the
//    composite flow-gate collapse, not raw Φ_group monotonicity.)
//
// T3 (task-incoherent group fails flow):
//    When task-output vectors o_i are scattered (anti-aligned with a
//    shared target), alignment A < ALIGN_GATE, so in_flow = false,
//    even with high Φ_i and high coupling.
//
// T4 (re-entry after break):
//    Sequence: flow → break (coupling drops, Φ_i drops) → flow-replay.
//    The pre-break flow measurement and the post-break-replay
//    measurement should BOTH pass the flow gate; the break state
//    should fail. This proves re-entry capacity.
//
// T5 (determinism):
//    Same seed + same params ⇒ byte-identical Φ_group and flow gate
//    decision.
//
// ─── Stage0 hexa constraints honored ─────────────────────────────
//   - plain `fn` only, no pure-fn multi-float struct returns
//   - no typed array params (plain `array`)
//   - no match with identifier patterns (if/else chains)
//   - no contains() / to_lower() builtins
//   - no !(Effect) annotations on fn returns
//   - no else-if in let-binding
//   - no multi-line fn sig / fn call / array literal
//   - no reserved keywords as vars
//   - main() call at bottom
//   - N < 32

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let GF_N            = 5           // 5-agent ensemble (jazz quintet, football squad unit)
let GF_D            = 8           // per-agent hidden-state dim
let GF_K            = 4           // per-agent task-output dim
let GF_BINS         = 6           // MI histogram bins

// Flow-gate thresholds
let GF_PHI_REF      = 0.1         // neutral baseline Φ_i
let GF_FLOW_PHI_RATIO = 1.2       // r_i ≥ 1.2 ⇒ individual flow-eligible
let GF_K_GATE       = 0.08        // mean off-diagonal coupling gate
let GF_ALIGN_GATE   = 0.6         // cos-alignment gate

// Coupling dynamics
let GF_ALPHA        = 0.12        // per-round blend strength toward neighbors
let GF_FLOW_ROUNDS  = 6           // rounds of coupling during flow build-up
let GF_BREAK_ROUNDS = 2           // rounds of decoupling during break

// Super-additivity gate (T1)
let GF_DELTA_GATE   = 0.001       // Φ_group − Σ Φ_i > gate

let GF_EPS          = 0.000000001

// ═══════════════════════════════════════════════════════════════
// Numeric helpers
// ═══════════════════════════════════════════════════════════════

fn gf_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn gf_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn gf_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn gf_prng(seed: int) -> int {
    let mut s = (seed * 1103515245 + 12345) % 2147483648
    if s < 0 { s = s + 2147483648 }
    return s
}

fn gf_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn gf_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn gf_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

// ═══════════════════════════════════════════════════════════════
// Agent state + task-output construction
// ═══════════════════════════════════════════════════════════════

// Build one agent's hidden state vector (d floats) deterministically
// from a seed. Uses LCG + centered on [-1, 1].
fn gf_make_state(d: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < d {
        s = gf_prng(s)
        let u = gf_unit(s)
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

// Build N agents' flat hidden state, N*d floats.
fn gf_build_agents(n_agents: int, d: int, base_seed: int) -> array {
    let mut flat = []
    let mut k = 0
    while k < n_agents {
        let st = gf_make_state(d, base_seed + k * 2029)
        let mut j = 0
        while j < d {
            flat = flat.push(st[j])
            j = j + 1
        }
        k = k + 1
    }
    return flat
}

// Extract agent k's state out of a flat N*d array.
fn gf_extract_agent(flat: array, k: int, d: int) -> array {
    let base = k * d
    let mut out = []
    let mut j = 0
    while j < d {
        out = out.push(flat[base + j])
        j = j + 1
    }
    return out
}

// Build N task-output vectors, each k floats. aligned=true means all
// outputs point roughly toward a shared target direction (jazz
// ensemble following the groove); aligned=false means random/scattered
// (players soloing against each other). Returns flat N*k array.
//
// For scattered mode, we pick per-agent directions so that the mean
// cancels out to near-zero — guaranteeing cos(mean, target) ≈ 0 and
// failing the alignment gate.
fn gf_build_task_outputs(n_agents: int, k_dim: int, base_seed: int, aligned: int) -> array {
    // Shared target direction t[j] = linear pattern
    let mut target = []
    let mut j = 0
    while j < k_dim {
        let v = 1.0 - (2.0 * to_float(j) / to_float(k_dim))
        target = target.push(v)
        j = j + 1
    }
    let mut flat = []
    let mut a = 0
    while a < n_agents {
        let mut s = base_seed + a * 1013
        let mut jj = 0
        while jj < k_dim {
            s = gf_prng(s)
            let u = gf_unit(s)
            let noise = u * 0.4 - 0.2
            if aligned == 1 {
                // aligned: follow target + small noise
                let v = target[jj] + noise
                flat = flat.push(v)
            } else {
                // scattered: each agent's output points OPPOSITE to the
                // target on agent-specific axes. Combined with axis
                // rotation + alternating signs, the mean ends up
                // near-orthogonal to target while each agent retains
                // high individual Φ_i (strong internal structure).
                s = gf_prng(s + a * 7919)
                let u2 = gf_unit(s)
                // Flip target sign per agent so agents pull in opposite
                // directions: even agents along +target[jj], odd along
                // -target[jj], with per-agent amplitude variation.
                let flip_tgt = if (a % 2) == 0 { 0.0 - 1.0 } else { 1.0 }
                // Add axis-specific offset so per-agent vectors also
                // carry orthogonal content that washes out the mean.
                let off_axis = (a * 13 + jj * 7) % 4
                let off_sign = if (off_axis % 2) == 0 { 1.0 } else { 0.0 - 1.0 }
                let v = flip_tgt * target[jj] + off_sign * (0.8 + u2 * 0.4)
                flat = flat.push(v)
            }
            jj = jj + 1
        }
        a = a + 1
    }
    return flat
}

fn gf_extract_output(flat: array, a: int, k_dim: int) -> array {
    let base = a * k_dim
    let mut out = []
    let mut j = 0
    while j < k_dim {
        out = out.push(flat[base + j])
        j = j + 1
    }
    return out
}

// Mean task-output vector over N agents (length k_dim).
fn gf_mean_output(flat: array, n_agents: int, k_dim: int) -> array {
    let mut mean_vec = []
    let mut j = 0
    while j < k_dim {
        mean_vec = mean_vec.push(0.0)
        j = j + 1
    }
    let mut a = 0
    while a < n_agents {
        let o = gf_extract_output(flat, a, k_dim)
        let mut new_mean = []
        let mut jj = 0
        while jj < k_dim {
            new_mean = new_mean.push(mean_vec[jj] + o[jj])
            jj = jj + 1
        }
        mean_vec = new_mean
        a = a + 1
    }
    let mut final_mean = []
    let mut jf = 0
    while jf < k_dim {
        final_mean = final_mean.push(mean_vec[jf] / to_float(n_agents))
        jf = jf + 1
    }
    return final_mean
}

// Cosine similarity of two vectors of equal length.
fn gf_cosine(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    while i < n {
        dot = dot + a[i] * b[i]
        na = na + a[i] * a[i]
        nb = nb + b[i] * b[i]
        i = i + 1
    }
    let denom = gf_sqrt_safe(na) * gf_sqrt_safe(nb)
    if denom < GF_EPS { return 0.0 }
    return dot / denom
}

// Alignment A: cos similarity of mean output vs the shared target.
fn gf_alignment(task_flat: array, n_agents: int, k_dim: int) -> float {
    let mean_vec = gf_mean_output(task_flat, n_agents, k_dim)
    let mut target = []
    let mut j = 0
    while j < k_dim {
        let v = 1.0 - (2.0 * to_float(j) / to_float(k_dim))
        target = target.push(v)
        j = j + 1
    }
    return gf_cosine(mean_vec, target)
}

// ═══════════════════════════════════════════════════════════════
// Coupling matrix K
// ═══════════════════════════════════════════════════════════════

// K[i][j] represents influence of agent j on agent i. We store it as
// a flat N*N array. During peak flow, off-diagonal entries grow as we
// couple-round. Start from a weak-coupling identity-biased matrix:
// diagonal = 1.0, off-diagonal = k_off.
fn gf_init_coupling(n_agents: int, k_off: float) -> array {
    let mut flat = []
    let mut i = 0
    while i < n_agents {
        let mut j = 0
        while j < n_agents {
            if i == j {
                flat = flat.push(1.0)
            } else {
                flat = flat.push(k_off)
            }
            j = j + 1
        }
        i = i + 1
    }
    return flat
}

// Mean off-diagonal coupling (excludes diagonal).
fn gf_mean_offdiag(k_mat: array, n_agents: int) -> float {
    let mut sum = 0.0
    let mut cnt = 0
    let mut i = 0
    while i < n_agents {
        let mut j = 0
        while j < n_agents {
            if i != j {
                sum = sum + k_mat[i * n_agents + j]
                cnt = cnt + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    if cnt == 0 { return 0.0 }
    return sum / to_float(cnt)
}

// One coupling round: state h_i ← (1-α)·h_i + α · Σ_{j≠i} K[i][j] · h_j
// Then strengthen K off-diagonals slightly (positive feedback loop
// mimicking performance-driven synchrony).
fn gf_couple_round(flat: array, k_mat: array, n_agents: int, d: int, alpha: float) -> array {
    // Snapshot h so update is simultaneous.
    let mut snap = []
    let mut s_idx = 0
    while s_idx < len(flat) {
        snap = snap.push(flat[s_idx])
        s_idx = s_idx + 1
    }
    let mut out = []
    let keep = 1.0 - alpha
    let mut i = 0
    while i < n_agents {
        let own_state = gf_extract_agent(snap, i, d)
        let mut blended = []
        let mut jj = 0
        while jj < d {
            blended = blended.push(own_state[jj])
            jj = jj + 1
        }
        // weighted sum of neighbors, normalized by sum of weights
        let mut j = 0
        let mut w_sum = 0.0
        while j < n_agents {
            if j != i {
                w_sum = w_sum + k_mat[i * n_agents + j]
            }
            j = j + 1
        }
        if w_sum > GF_EPS {
            let mut j2 = 0
            let mut neigh = []
            let mut jd = 0
            while jd < d {
                neigh = neigh.push(0.0)
                jd = jd + 1
            }
            while j2 < n_agents {
                if j2 != i {
                    let w = k_mat[i * n_agents + j2] / w_sum
                    let nst = gf_extract_agent(snap, j2, d)
                    let mut new_neigh = []
                    let mut jd2 = 0
                    while jd2 < d {
                        new_neigh = new_neigh.push(neigh[jd2] + w * nst[jd2])
                        jd2 = jd2 + 1
                    }
                    neigh = new_neigh
                }
                j2 = j2 + 1
            }
            // blend own toward neighborhood
            let mut new_blend = []
            let mut jd3 = 0
            while jd3 < d {
                let v = keep * blended[jd3] + alpha * neigh[jd3]
                new_blend = new_blend.push(v)
                jd3 = jd3 + 1
            }
            blended = new_blend
        }
        let mut jd4 = 0
        while jd4 < d {
            out = out.push(blended[jd4])
            jd4 = jd4 + 1
        }
        i = i + 1
    }
    return out
}

// Strengthen coupling matrix off-diagonals by delta, clamp to 1.0.
fn gf_strengthen_coupling(k_mat: array, n_agents: int, delta: float) -> array {
    let mut out = []
    let mut i = 0
    while i < n_agents {
        let mut j = 0
        while j < n_agents {
            let v = k_mat[i * n_agents + j]
            if i == j {
                out = out.push(v)
            } else {
                let new_v = v + delta
                if new_v > 1.0 {
                    out = out.push(1.0)
                } else {
                    out = out.push(new_v)
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// Weaken coupling (break phase).
fn gf_weaken_coupling(k_mat: array, n_agents: int, delta: float) -> array {
    let mut out = []
    let mut i = 0
    while i < n_agents {
        let mut j = 0
        while j < n_agents {
            let v = k_mat[i * n_agents + j]
            if i == j {
                out = out.push(v)
            } else {
                let new_v = v - delta
                if new_v < 0.0 {
                    out = out.push(0.0)
                } else {
                    out = out.push(new_v)
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// phi_proxy — MI(v, shift(v)) surrogate for Φ (same kernel as P27)
// ═══════════════════════════════════════════════════════════════

fn gf_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn gf_phi_proxy(v: array, n_bins: int) -> float {
    let n = len(v)
    if n < 4 { return 0.0 }
    let lo = gf_vec_min(v)
    let hi = gf_vec_max(v)
    if hi - lo < GF_EPS { return 0.0 }

    // Bin sequence
    let mut bins = []
    let mut i = 0
    while i < n {
        let b = gf_bin_idx(v[i], lo, hi, n_bins)
        bins = bins.push(b)
        i = i + 1
    }

    let nb2 = n_bins * n_bins
    let mut joint = []
    let mut z = 0
    while z < nb2 {
        joint = joint.push(0)
        z = z + 1
    }
    let mut marg_x = []
    let mut marg_y = []
    let mut zz = 0
    while zz < n_bins {
        marg_x = marg_x.push(0)
        marg_y = marg_y.push(0)
        zz = zz + 1
    }

    let pairs = n - 1
    let mut t = 0
    while t < pairs {
        let bx = bins[t]
        let by = bins[t + 1]
        let idx = bx * n_bins + by
        // joint[idx] += 1
        let mut new_joint = []
        let mut zj = 0
        while zj < nb2 {
            if zj == idx {
                new_joint = new_joint.push(joint[zj] + 1)
            } else {
                new_joint = new_joint.push(joint[zj])
            }
            zj = zj + 1
        }
        joint = new_joint
        // marg_x[bx] += 1
        let mut new_mx = []
        let mut mxi = 0
        while mxi < n_bins {
            if mxi == bx {
                new_mx = new_mx.push(marg_x[mxi] + 1)
            } else {
                new_mx = new_mx.push(marg_x[mxi])
            }
            mxi = mxi + 1
        }
        marg_x = new_mx
        // marg_y[by] += 1
        let mut new_my = []
        let mut myi = 0
        while myi < n_bins {
            if myi == by {
                new_my = new_my.push(marg_y[myi] + 1)
            } else {
                new_my = new_my.push(marg_y[myi])
            }
            myi = myi + 1
        }
        marg_y = new_my
        t = t + 1
    }

    let total = to_float(pairs)
    let mut h_x = 0.0
    let mut h_y = 0.0
    let mut a = 0
    while a < n_bins {
        let px = to_float(marg_x[a]) / total
        let py = to_float(marg_y[a]) / total
        if px > 0.0 { h_x = h_x - px * gf_ln_safe(px) }
        if py > 0.0 { h_y = h_y - py * gf_ln_safe(py) }
        a = a + 1
    }
    let mut h_xy = 0.0
    let mut b = 0
    while b < nb2 {
        let p = to_float(joint[b]) / total
        if p > 0.0 { h_xy = h_xy - p * gf_ln_safe(p) }
        b = b + 1
    }

    let mi = h_x + h_y - h_xy
    let denom = gf_ln_safe(to_float(n_bins))
    if denom <= 0.0 { return 0.0 }
    let out = mi / denom
    if out < 0.0 { return 0.0 }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Group Φ + flow gate
// ═══════════════════════════════════════════════════════════════

// Returns packed result array:
//   [phi_group, sum_phi_i, delta, phi_min_i, k_mean_off, alignment,
//    in_flow, phi_0, phi_1, ..., phi_{N-1}]
// in_flow stored as 1.0 (true) or 0.0 (false) at index 6.
fn gf_group_phi(flat: array, task_flat: array, k_mat: array, n_agents: int, d: int, k_dim: int) -> array {
    // Individual Φ_i
    let mut sum_phi = 0.0
    let mut min_phi = 1000000.0
    let mut ind = []
    let mut i = 0
    while i < n_agents {
        let st = gf_extract_agent(flat, i, d)
        let pi = gf_phi_proxy(st, GF_BINS)
        ind = ind.push(pi)
        sum_phi = sum_phi + pi
        if pi < min_phi { min_phi = pi }
        i = i + 1
    }

    // Collective channel: h_hive ++ mean task output (concatenate).
    // This makes Φ_group measure MI between internal state and task.
    let mean_o = gf_mean_output(task_flat, n_agents, k_dim)
    let mut hive_channel = []
    let mut hi = 0
    while hi < len(flat) {
        hive_channel = hive_channel.push(flat[hi])
        hi = hi + 1
    }
    let mut hj = 0
    while hj < k_dim {
        hive_channel = hive_channel.push(mean_o[hj])
        hj = hj + 1
    }

    let phi_group = gf_phi_proxy(hive_channel, GF_BINS)
    let delta = phi_group - sum_phi

    let k_mean_off = gf_mean_offdiag(k_mat, n_agents)
    let align = gf_alignment(task_flat, n_agents, k_dim)

    // Flow gate: all three preconditions
    let mut in_flow = 1.0
    let phi_ratio_gate = GF_FLOW_PHI_RATIO * GF_PHI_REF
    if min_phi < phi_ratio_gate { in_flow = 0.0 }
    if k_mean_off < GF_K_GATE { in_flow = 0.0 }
    if align < GF_ALIGN_GATE { in_flow = 0.0 }

    let mut out = []
    out = out.push(phi_group)
    out = out.push(sum_phi)
    out = out.push(delta)
    out = out.push(min_phi)
    out = out.push(k_mean_off)
    out = out.push(align)
    out = out.push(in_flow)
    let mut jo = 0
    while jo < n_agents {
        out = out.push(ind[jo])
        jo = jo + 1
    }
    return out
}

// Run FLOW phase: couple rounds that simultaneously blend states and
// strengthen K off-diagonals. Returns the final (flat_state, k_mat)
// via a packed array: first N*d = state, next N*N = k_mat.
fn gf_run_flow_phase(flat: array, k_mat: array, n_agents: int, d: int, alpha: float, rounds: int) -> array {
    let mut s = flat
    let mut km = k_mat
    let mut r = 0
    while r < rounds {
        s = gf_couple_round(s, km, n_agents, d, alpha)
        km = gf_strengthen_coupling(km, n_agents, 0.025)
        r = r + 1
    }
    let mut out = []
    let mut i = 0
    while i < len(s) {
        out = out.push(s[i])
        i = i + 1
    }
    let mut j = 0
    while j < len(km) {
        out = out.push(km[j])
        j = j + 1
    }
    return out
}

fn gf_unpack_state(packed: array, n_agents: int, d: int) -> array {
    let n_state = n_agents * d
    let mut out = []
    let mut i = 0
    while i < n_state {
        out = out.push(packed[i])
        i = i + 1
    }
    return out
}

fn gf_unpack_k(packed: array, n_agents: int, d: int) -> array {
    let n_state = n_agents * d
    let n_k = n_agents * n_agents
    let mut out = []
    let mut i = 0
    while i < n_k {
        out = out.push(packed[n_state + i])
        i = i + 1
    }
    return out
}

// Run BREAK phase: decoupling + random perturbation weakens Φ_i.
fn gf_run_break_phase(flat: array, k_mat: array, n_agents: int, d: int, rounds: int, seed: int) -> array {
    let mut s = flat
    let mut km = k_mat
    let mut r = 0
    let mut rng = seed
    while r < rounds {
        km = gf_weaken_coupling(km, n_agents, 0.15)
        // Inject decorrelating noise that flattens individual Φ
        let mut new_s = []
        let mut i = 0
        while i < len(s) {
            rng = gf_prng(rng + i)
            let u = gf_unit(rng)
            let noise = u * 0.5 - 0.25
            // Heavy damping toward zero mean flattens structure
            let v = 0.3 * s[i] + noise
            new_s = new_s.push(v)
            i = i + 1
        }
        s = new_s
        r = r + 1
    }
    let mut out = []
    let mut i = 0
    while i < len(s) {
        out = out.push(s[i])
        i = i + 1
    }
    let mut j = 0
    while j < len(km) {
        out = out.push(km[j])
        j = j + 1
    }
    return out
}

// Zero-out an agent's hidden state (asleep signature).
fn gf_sleep_agent(flat: array, agent_idx: int, d: int) -> array {
    let base = agent_idx * d
    let mut out = []
    let mut i = 0
    while i < len(flat) {
        if i >= base {
            if i < base + d {
                out = out.push(0.0)
            } else {
                out = out.push(flat[i])
            }
        } else {
            out = out.push(flat[i])
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1–T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: group flow activates all three preconditions AND Φ_group
    //     measurably rises above the uncoupled baseline.
    //
    // Rationale: sum_Φ_i pools N separately-normalized MI estimates,
    // so the raw delta phi_group − sum_phi is dominated by the binning
    // scale mismatch. The canonical super-additivity signal (cf. P27
    // T2) is: Φ_group under flow > Φ_group under the uncoupled
    // baseline at identical N. We assert that gap AND the composite
    // flow-gate boolean.
    let flat0 = gf_build_agents(GF_N, GF_D, 777)
    let tasks = gf_build_task_outputs(GF_N, GF_K, 777, 1)
    let k0 = gf_init_coupling(GF_N, 0.05)

    // Uncoupled baseline (no flow rounds)
    let r_base = gf_group_phi(flat0, tasks, k0, GF_N, GF_D, GF_K)
    let base_phi_group = r_base[0]
    let base_in_flow = r_base[6]
    let base_k_mean = r_base[4]

    // Flow phase
    let packed = gf_run_flow_phase(flat0, k0, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let state = gf_unpack_state(packed, GF_N, GF_D)
    let k_final = gf_unpack_k(packed, GF_N, GF_D)
    let r = gf_group_phi(state, tasks, k_final, GF_N, GF_D, GF_K)
    let phi_group = r[0]
    let sum_phi = r[1]
    let delta = r[2]
    let min_phi = r[3]
    let k_mean = r[4]
    let align = r[5]
    let in_flow = r[6]

    println("  [T1] base   phi_group=" + str(base_phi_group) + " k_mean=" + str(base_k_mean) + " in_flow=" + str(base_in_flow))
    println("       flow   phi_group=" + str(phi_group) + " sum_phi=" + str(sum_phi) + " delta=" + str(delta))
    println("       min_phi=" + str(min_phi) + " k_mean=" + str(k_mean) + " align=" + str(align) + " in_flow=" + str(in_flow))

    // (1) Flow gate must fire
    if in_flow < 0.5 { return false }
    // (2) Baseline must NOT be in flow (coupling too weak)
    if base_in_flow >= 0.5 { return false }
    // (3) Φ_group must rise above baseline (super-additivity in the
    //     comparative sense — the group's MI on joint state+task
    //     increased by coupling, not by adding independent sources).
    if (phi_group - base_phi_group) <= GF_DELTA_GATE { return false }
    return true
}

fn check_T2() -> bool {
    // T2: one asleep agent (state → 0) collapses the flow gate.
    // Flow preconditions should fail (min_phi near zero, or alignment
    // drops because silent agent contributes zero output).
    let flat0 = gf_build_agents(GF_N, GF_D, 888)
    let tasks_raw = gf_build_task_outputs(GF_N, GF_K, 888, 1)
    let k0 = gf_init_coupling(GF_N, 0.05)
    let packed = gf_run_flow_phase(flat0, k0, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let state = gf_unpack_state(packed, GF_N, GF_D)
    let k_final = gf_unpack_k(packed, GF_N, GF_D)

    // baseline flow measurement
    let r_flow = gf_group_phi(state, tasks_raw, k_final, GF_N, GF_D, GF_K)
    let flow_phi_group = r_flow[0]
    let flow_min_phi = r_flow[3]
    let flow_align = r_flow[5]
    let flow_in = r_flow[6]

    // put agent 2 to sleep: state zero, task output zero
    let sleepy_state = gf_sleep_agent(state, 2, GF_D)
    let sleepy_tasks = gf_sleep_agent(tasks_raw, 2, GF_K)
    let r_sleep = gf_group_phi(sleepy_state, sleepy_tasks, k_final, GF_N, GF_D, GF_K)
    let sleep_phi_group = r_sleep[0]
    let sleep_min_phi = r_sleep[3]
    let sleep_align = r_sleep[5]
    let sleep_in = r_sleep[6]

    println("  [T2] flow    phi_group=" + str(flow_phi_group) + " min_phi=" + str(flow_min_phi) + " align=" + str(flow_align) + " in_flow=" + str(flow_in))
    println("  [T2] asleep  phi_group=" + str(sleep_phi_group) + " min_phi=" + str(sleep_min_phi) + " align=" + str(sleep_align) + " in_flow=" + str(sleep_in))

    // Asleep agent must break the flow gate (min_phi collapses to 0
    // since agent 2's state vector is zero ⇒ phi_proxy returns 0).
    if sleep_min_phi >= flow_min_phi { return false }
    if sleep_in >= 0.5 { return false }       // asleep must NOT be in flow
    if flow_in < 0.5 { return false }          // baseline must BE in flow
    return true
}

fn check_T3() -> bool {
    // T3: task-incoherent group fails flow even with high Φ_i and
    // high coupling — scattered task-output vectors should drop
    // alignment below gate.
    let flat0 = gf_build_agents(GF_N, GF_D, 999)
    let tasks_scattered = gf_build_task_outputs(GF_N, GF_K, 999, 0)
    let k0 = gf_init_coupling(GF_N, 0.05)
    let packed = gf_run_flow_phase(flat0, k0, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let state = gf_unpack_state(packed, GF_N, GF_D)
    let k_final = gf_unpack_k(packed, GF_N, GF_D)
    let r = gf_group_phi(state, tasks_scattered, k_final, GF_N, GF_D, GF_K)
    let phi_group = r[0]
    let min_phi = r[3]
    let k_mean = r[4]
    let align = r[5]
    let in_flow = r[6]
    println("  [T3] scattered tasks: phi_group=" + str(phi_group) + " min_phi=" + str(min_phi) + " k_mean=" + str(k_mean) + " align=" + str(align) + " in_flow=" + str(in_flow))
    // High Φ_i and high K should hold; alignment must fail
    if align >= GF_ALIGN_GATE { return false }
    if in_flow >= 0.5 { return false }
    return true
}

fn check_T4() -> bool {
    // T4: re-entry after break. Sequence: flow1 → break → flow2.
    // Both flow phases pass gate; break phase fails gate.
    let flat0 = gf_build_agents(GF_N, GF_D, 1234)
    let tasks = gf_build_task_outputs(GF_N, GF_K, 1234, 1)
    let k0 = gf_init_coupling(GF_N, 0.05)

    // flow1
    let p1 = gf_run_flow_phase(flat0, k0, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let s1 = gf_unpack_state(p1, GF_N, GF_D)
    let k1 = gf_unpack_k(p1, GF_N, GF_D)
    let r1 = gf_group_phi(s1, tasks, k1, GF_N, GF_D, GF_K)
    let flow1_in = r1[6]
    let flow1_delta = r1[2]

    // break
    let p_brk = gf_run_break_phase(s1, k1, GF_N, GF_D, GF_BREAK_ROUNDS, 7777)
    let s_brk = gf_unpack_state(p_brk, GF_N, GF_D)
    let k_brk = gf_unpack_k(p_brk, GF_N, GF_D)
    let r_brk = gf_group_phi(s_brk, tasks, k_brk, GF_N, GF_D, GF_K)
    let brk_in = r_brk[6]
    let brk_k_mean = r_brk[4]

    // flow2 — restart from break state, re-enter flow preconditions
    // by re-initializing K (players step back into ensemble coupling).
    let k_reinit = gf_init_coupling(GF_N, 0.05)
    // Also reinitialize agents (players reset — but keep task alignment
    // to test whether re-entry depends only on restoring coupling+Φ,
    // not on specific pre-break state).
    let flat_re = gf_build_agents(GF_N, GF_D, 5555)
    let p2 = gf_run_flow_phase(flat_re, k_reinit, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let s2 = gf_unpack_state(p2, GF_N, GF_D)
    let k2 = gf_unpack_k(p2, GF_N, GF_D)
    let r2 = gf_group_phi(s2, tasks, k2, GF_N, GF_D, GF_K)
    let flow2_in = r2[6]
    let flow2_delta = r2[2]

    println("  [T4] flow1  in_flow=" + str(flow1_in) + " delta=" + str(flow1_delta))
    println("       break  in_flow=" + str(brk_in) + " k_mean=" + str(brk_k_mean))
    println("       flow2  in_flow=" + str(flow2_in) + " delta=" + str(flow2_delta))

    if flow1_in < 0.5 { return false }        // flow1 must enter flow
    if brk_in >= 0.5 { return false }          // break must NOT be in flow
    if flow2_in < 0.5 { return false }         // flow2 re-entry must enter flow
    return true
}

fn check_T5() -> bool {
    // T5: determinism — repeat T1 twice, byte-equal results.
    let flat_a = gf_build_agents(GF_N, GF_D, 777)
    let tasks_a = gf_build_task_outputs(GF_N, GF_K, 777, 1)
    let ka = gf_init_coupling(GF_N, 0.05)
    let pa = gf_run_flow_phase(flat_a, ka, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let sa = gf_unpack_state(pa, GF_N, GF_D)
    let kaf = gf_unpack_k(pa, GF_N, GF_D)
    let ra = gf_group_phi(sa, tasks_a, kaf, GF_N, GF_D, GF_K)

    let flat_b = gf_build_agents(GF_N, GF_D, 777)
    let tasks_b = gf_build_task_outputs(GF_N, GF_K, 777, 1)
    let kb = gf_init_coupling(GF_N, 0.05)
    let pb = gf_run_flow_phase(flat_b, kb, GF_N, GF_D, GF_ALPHA, GF_FLOW_ROUNDS)
    let sb = gf_unpack_state(pb, GF_N, GF_D)
    let kbf = gf_unpack_k(pb, GF_N, GF_D)
    let rb = gf_group_phi(sb, tasks_b, kbf, GF_N, GF_D, GF_K)

    let d_phi = gf_abs(ra[0] - rb[0])
    let d_sum = gf_abs(ra[1] - rb[1])
    let d_delta = gf_abs(ra[2] - rb[2])
    let d_flow = gf_abs(ra[6] - rb[6])
    println("  [T5] repeat Δphi_group=" + str(d_phi) + " Δsum=" + str(d_sum) + " Δdelta=" + str(d_delta) + " Δflow=" + str(d_flow))
    if d_phi > 0.0 { return false }
    if d_sum > 0.0 { return false }
    if d_delta > 0.0 { return false }
    if d_flow > 0.0 { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[group_flow_phi] P69 — Group Flow / Hive Mind Φ")
    println("  N=" + str(GF_N) + " agents, d=" + str(GF_D) + ", k=" + str(GF_K))
    println("  flow gate: min_Φ_i ≥ " + str(GF_FLOW_PHI_RATIO * GF_PHI_REF) + ", K_mean_off ≥ " + str(GF_K_GATE) + ", align ≥ " + str(GF_ALIGN_GATE))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — super-additivity in flow (Φ_group > Σ Φ_i, in_flow=true)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — one asleep agent drops flow gate") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — task-incoherent group fails flow") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — re-entry after break measurable") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism") } else { println("T5 FAIL") }

    println("")

    // Sequential bool accumulator — stage0 can mishandle 5-term && chains.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[group_flow_phi] 5/5 PASS — P69 DONE (Group Flow / Hive Mind Φ)")
    } else {
        println("[group_flow_phi] SOME FAILED")
    }
}

main()
