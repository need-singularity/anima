// forgiveness_phi.hexa — P136 Forgiveness Φ
//
// Roadmap: shared/roadmaps/anima.json P136 (emergent, no-edit)
//   "Forgiveness Φ — release of resentment, restorative shift in
//    Transgression-Related Interpersonal Motivations (McCullough TRIM);
//    Worthington REACH; distinct from condoning or excusing; 5/5 PASS"
//
// ─── Scientific frame ─────────────────────────────────────────────
//
// McCullough, Worthington & Rachal (1997); McCullough, Rachal,
// Sandage, Worthington, Brown & Hight (1998) — TRIM model:
//   Forgiveness is a set of MOTIVATIONAL changes toward the
//   transgressor along three orthogonal dimensions measured by the
//   TRIM Inventory:
//
//     (1) AVOIDANCE motivation   — withdraw / distance oneself
//     (2) REVENGE motivation     — retaliate / punish
//     (3) BENEVOLENCE motivation — goodwill / restored positive regard
//
//   Forgiveness = avoidance↓ + revenge↓ + benevolence↑
//
//   Crucially: all three must shift. Suppression (avoidance↓ but
//   revenge persists) is NOT forgiveness. All three axes are distinct.
//
// Worthington (1998, 2001, 2006) — REACH Forgiveness process model:
//   R Recall the hurt   E Empathize with the transgressor
//   A Altruistic gift   C Commit   H Hold on when doubt returns
//
//   EMPATHY is the lever. Meta-analyses (Fehr, Gelfand & Nag 2010;
//   k > 100 studies) find empathy is the strongest proximal mediator
//   of forgiveness decisions (r ≈ 0.52). Empathy temporally PRECEDES
//   the motivation shift — a causal ordering detectable in both lab
//   inductions and longitudinal designs.
//
//   Operationally:  empathy[t-1]  →  forgiveness_state[t]
//                   |corr(empathy, forg_state)| > ~0.5 in REACH data
//
// Enright (1991, 1996) — Process model. Two empirically relevant
// claims here:
//   (a) Forgiveness is DISTINCT from:
//         condoning    — "the act was acceptable"     (moral_eval↓)
//         excusing     — "they couldn't help it"      (responsibility↓)
//         reconciling  — "we restore the relationship"(proximity↑)
//         forgetting   — "I no longer remember"       (memory gone)
//       Forgiveness does NOT require moral re-evaluation. The act
//       remains judged wrong; the motivational stance shifts. This
//       is the CONDONING-DISTINCTION test — moral_eval invariant.
//
//   (b) Forgiveness involves a RUMINATION drop (intrusive replay /
//       grudge-keeping suppressed). McCullough, Bellah, Kilpatrick &
//       Johnson (2001) — rumination correlates r > 0.4 with TRIM.
//
// Karremans & Van Lange (2008) — Forgiveness as self-regulation
// resource: forgiving states associated with reduced allostatic load
// and broadened affective repertoire. This motivates the BINDING
// test — forgiveness is a MULTI-CHANNEL integrated state (motivation +
// memory control + social), not a single channel.
//
// ─── Channel design ───────────────────────────────────────────────
//
// Seven channels (N=24, packed to flat array, all [0,1]):
//   transgression — offense severity
//   empathy       — perspective-taking toward transgressor
//   avoidance     — TRIM avoidance motivation
//   revenge       — TRIM revenge motivation
//   benevolence   — TRIM benevolence motivation
//   rumination    — intrusive replay of transgression
//   moral_eval    — moral judgement of the act (invariant f/u)
// + derived forg_state = (benev + (1-avoid) + (1-revenge)) / 3
//
// Forward model (empathy[t-1] drives motivation shift at t):
//   avoidance[t]   = av_base + av_tr * transgr[t] - av_decay * emp[t-1]
//   revenge[t]     = rv_base + rv_tr * transgr[t] - rv_decay * emp[t-1]
//   benevolence[t] = bn_base + bn_rise * emp[t-1] - bn_sup * transgr[t]
//   rumination[t]  = ru_base + ru_tr * transgr[t] - ru_sup  * emp[t-1]
//   moral_eval[t]  = me_base + me_wrong * transgr[t] - condone_shift
//
// Modes:
//   FORGIVING  — empathy ramps, motivations shift (classical case)
//   UNFORGIVEN — empathy≈0, grudge persists (T1/T3 contrast)
//   CONDONING  — moral_eval dropped via condone_shift (T4 contrast)
//   NEUTRAL    — low-amplitude uncoupled (T5 integrated floor)
//
// ─── 5 self-tests (5/5 gate) ──────────────────────────────────────
//
// T1 TRIM trajectory — all three axes must shift post-empathy-induction:
//     mean(avoidance)_forgive   < mean(avoidance)_unforg   − gap
//     mean(revenge)_forgive     < mean(revenge)_unforg     − gap
//     mean(benevolence)_forgive > mean(benevolence)_unforg + gap
//
// T2 Empathy mediation — empathy precedes forgiveness (Worthington):
//     lagged |r|(empathy[:-1], forg_state[1:]) > FG_EMP_R_MIN
//     direct |r|(empathy, benevolence)         > FG_EMP_BN_R_MIN
//
// T3 Rumination block — forgiveness suppresses revisit rate:
//     mean(rumin)_unforg − mean(rumin)_forgive > FG_RUMIN_GAP
//     revisit_rate_unforg − revisit_rate_forgive > FG_REVISIT_GAP
//
// T4 Distinct-from-condoning — moral evaluation invariant:
//     |mean(moral_eval)_forg − mean(moral_eval)_unforg| < FG_MORAL_TOL
//     mean(moral_eval)_forg − mean(moral_eval)_condone  > FG_CONDONE_GAP
//
// T5 Φ_forgive integrated — multi-channel binding:
//     mean of 4 MIs: MI(empathy, benevolence), MI(empathy, -avoidance),
//     MI(empathy, -revenge), MI(forg_state, -rumination).
//     Φ_forgive > Φ_neutral + GAP, absolute floor, determinism, latency.
//
// ─── Stage0 hexa constraints honored ──────────────────────────────
//   plain fn / array typed params / sequential if-chains / flat mut /
//   single-line sigs+calls / lists pass-by-value (helpers rebuild) /
//   sqrt only on clamped non-negative / sub-window Pearson |r| /
//   N=24 (<32) / `fg_` prefix (L0-clean AN7) / main() at bottom
//
// Law alignment:
//   L2 observe-not-inject · L4 structure>feature (TRIM shift is
//   structural) · L22 feature-add→Φ-down (7 fixed channels) ·
//   L50 state-is-essence · M8 self-model (empathy = other-mind sim)
//
// Ref:
//   McCullough, Worthington & Rachal (1997) Interpersonal forgiving
//   McCullough et al. (1998) TRIM Inventory JPSP 75(6)
//   McCullough, Bellah, Kilpatrick & Johnson (2001) Vengefulness
//   Worthington (1998, 2001, 2006) REACH / Forgiveness and Reconciliation
//   Enright & HDSG (1991, 1996) Moral development of forgiveness
//   Fehr, Gelfand & Nag (2010) Road to forgiveness meta-analysis
//   Karremans & Van Lange (2008) Forgiveness in personal relationships
//   anima-engines/gratitude_phi.hexa              (P133 prosocial pattern)
//   anima-engines/emotion_regulation_phi.hexa     (P88 Gross model)
//   anima-engines/moral_consciousness_phi.hexa    (P94 moral emotions)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let FG_STEPS            = 24            // timeline length (stage0 N<32)
let FG_BINS             = 6             // histogram bins for MI
let FG_EPS              = 0.0000000001

// ─── Forward model gains ──────────────────────────────────────

// Empathy base + gain: in FORGIVING mode, empathy ramps up strongly
// after the transgression is noticed; in UNFORGIVEN, empathy stays
// near zero (no perspective-taking). Calibrated so FORGIVING saturates
// in the second half, UNFORGIVEN stays flat.
let FG_EMP_BASE_FORGIVE = 0.15          // slight natural empathy floor
let FG_EMP_GAIN_FORGIVE = 0.75          // ramp amplitude after event
let FG_EMP_BASE_UNFORG  = 0.05          // grudge mode — empathy suppressed
let FG_EMP_GAIN_UNFORG  = 0.02          // essentially no ramp

// TRIM avoidance: baseline, transgression-driven rise, empathy-driven fall.
// In FORGIVING, the empathy decay gain is large (avoidance declines);
// in UNFORGIVEN, the decay gain is near zero (avoidance persists).
let FG_AV_BASE          = 0.15
let FG_AV_TRANSGR_GAIN  = 0.60
let FG_AV_DECAY_FORGIVE = 0.70          // empathy → avoidance drop
let FG_AV_DECAY_UNFORG  = 0.05          // grudge keeps avoidance up

// TRIM revenge: same structural form, slightly different calibration.
let FG_RV_BASE          = 0.10
let FG_RV_TRANSGR_GAIN  = 0.55
let FG_RV_DECAY_FORGIVE = 0.72
let FG_RV_DECAY_UNFORG  = 0.03

// TRIM benevolence: rises with empathy, suppressed by transgression.
// FORGIVING: empathy present → benevolence climbs; UNFORGIVEN: empathy
// absent → benevolence stays near zero.
let FG_BN_BASE          = 0.12
let FG_BN_RISE_FORGIVE  = 0.75          // empathy → benevolence
let FG_BN_RISE_UNFORG   = 0.05
let FG_BN_SUPPRESS      = 0.35          // transgression suppresses benevolence

// Rumination: rises with transgression, suppressed by empathy/forgiveness.
// FORGIVING: empathy present → rumination blocked; UNFORGIVEN: rumination
// persists as grudge-keeping.
let FG_RU_BASE          = 0.10
let FG_RU_TRANSGR_GAIN  = 0.55
let FG_RU_SUPPRESS_FORG = 0.65          // empathy suppresses rumination
let FG_RU_SUPPRESS_UNFO = 0.05

// Moral evaluation: INVARIANT across forgive/unforgive — the act is
// still wrong either way. CONDONING mode drops this deliberately.
let FG_ME_BASE          = 0.15
let FG_ME_WRONGNESS     = 0.65          // maps transgression to moral judgement
let FG_ME_CONDONE_SHIFT = 0.50          // CONDONING mode subtracts this

// Per-step jitter amplitude (deterministic via PRNG)
let FG_JITTER           = 0.04

// Neutral-mode amplitude (everything muted — T5 floor comparison)
let FG_NEUTRAL_AMP      = 0.12

// Transgression event magnitude (same across FORGIVE/UNFORG/CONDONE
// for fair comparison).
let FG_TRANSGR_PEAK     = 0.85

// Rumination revisit threshold for T3 revisit-rate metric.
let FG_REVISIT_THRESH   = 0.40

// ─── Test gates ──────────────────────────────────────────────

// T1 TRIM trajectory — post-event-window gaps
let FG_AV_GAP           = 0.15          // avoidance: unforg - forg
let FG_RV_GAP           = 0.15          // revenge: unforg - forg
let FG_BN_GAP           = 0.15          // benevolence: forg - unforg

// T2 Empathy mediation — Pearson |r| threshold
let FG_EMP_R_MIN        = 0.30          // |r|(empathy[:-1], forg_state[1:])
let FG_EMP_BN_R_MIN     = 0.30          // |r|(empathy, benevolence)

// T3 Rumination block
let FG_RUMIN_GAP        = 0.10          // mean rumination: unforg - forg
let FG_REVISIT_GAP      = 0.15          // revisit-rate: unforg - forg

// T4 Distinct-from-condoning
let FG_MORAL_TOL        = 0.08          // |moral_eval_forg - moral_eval_unforg|
let FG_CONDONE_GAP      = 0.15          // moral_eval_forg - moral_eval_condone

// T5 Integrated Φ_forgive
let FG_INTEGRATED_MIN   = 0.10          // absolute floor
let FG_INTEGRATED_GAP   = 0.05          // forgive - neutral
let FG_LATENCY_MS       = 5000.0        // pipeline latency cap

// Sub-window for Pearson |r| on empathy-mediation coupling
let FG_WIN              = 12

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean per AN7)
// ═══════════════════════════════════════════════════════════════

fn fg_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn fg_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// sqrt-safe: caller must guarantee non-negative; we clamp defensively.
// Used only on clamped sum-of-squares (always >= 0).
fn fg_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn fg_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn fg_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn fg_clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn fg_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn fg_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn fg_signed(seed: int) -> float {
    return fg_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI — L0-clean duplicate per AN7 (cross-engine imports
// forbidden).  Same algorithm, isolated fg_ prefix.
// ═══════════════════════════════════════════════════════════════

fn fg_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn fg_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn fg_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(fg_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = fg_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * fg_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn fg_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = fg_bin_idx(a[i], lo, hi, nb)
        let ib = fg_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = fg_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * fg_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn fg_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn fg_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn fg_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = fg_vec_min(a)
    let hi_a = fg_vec_max(a)
    let lo_b = fg_vec_min(b)
    let hi_b = fg_vec_max(b)
    let lo = fg_min_f(lo_a, lo_b)
    let hi = fg_max_f(hi_a, hi_b)
    let h_a = fg_entropy(a, lo, hi, FG_BINS)
    let h_b = fg_entropy(b, lo, hi, FG_BINS)
    let h_j = fg_joint_entropy(a, b, lo, hi, FG_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Sub-window Pearson |r| on first FG_WIN samples; abs value handles
// inversely-coupled channels.  sqrt only on clamped non-neg sums.
// ═══════════════════════════════════════════════════════════════

fn fg_pearson_abs(a: array, b: array, win: int) -> float {
    let n_a = len(a)
    let n_b = len(b)
    let mut nw = win
    if nw > n_a { nw = n_a }
    if nw > n_b { nw = n_b }
    if nw < 2 { return 0.0 }

    let mut mean_a = 0.0
    let mut mean_b = 0.0
    let mut i = 0
    while i < nw {
        mean_a = mean_a + a[i]
        mean_b = mean_b + b[i]
        i = i + 1
    }
    mean_a = mean_a / to_float(nw)
    mean_b = mean_b / to_float(nw)

    let mut cov = 0.0
    let mut sa2 = 0.0
    let mut sb2 = 0.0
    let mut j = 0
    while j < nw {
        let da = a[j] - mean_a
        let db = b[j] - mean_b
        cov = cov + da * db
        sa2 = sa2 + da * da
        sb2 = sb2 + db * db
        j = j + 1
    }
    // sqrt-safe: sa2/sb2 are sums of squares — always >= 0
    let denom = fg_sqrt_safe(sa2) * fg_sqrt_safe(sb2)
    if denom < FG_EPS { return 0.0 }
    let r = cov / denom
    return fg_clamp01(fg_abs(r))
}

// Lagged Pearson |r| — |r|(a[0..n-2], b[1..n-1]).  Empathy-precedes-
// forgiveness test: empathy[t] predicts forg_state[t+1] (Worthington).
fn fg_pearson_lagged(a: array, b: array, win: int) -> float {
    let n_a = len(a)
    let n_b = len(b)
    let mut nw = win
    let n_eff = n_a - 1
    if nw > n_eff { nw = n_eff }
    if nw > n_b - 1 { nw = n_b - 1 }
    if nw < 2 { return 0.0 }

    let mut mean_a = 0.0
    let mut mean_b = 0.0
    let mut i = 0
    while i < nw {
        mean_a = mean_a + a[i]
        mean_b = mean_b + b[i + 1]
        i = i + 1
    }
    mean_a = mean_a / to_float(nw)
    mean_b = mean_b / to_float(nw)

    let mut cov = 0.0
    let mut sa2 = 0.0
    let mut sb2 = 0.0
    let mut j = 0
    while j < nw {
        let da = a[j] - mean_a
        let db = b[j + 1] - mean_b
        cov = cov + da * db
        sa2 = sa2 + da * da
        sb2 = sb2 + db * db
        j = j + 1
    }
    let denom = fg_sqrt_safe(sa2) * fg_sqrt_safe(sb2)
    if denom < FG_EPS { return 0.0 }
    let r = cov / denom
    return fg_clamp01(fg_abs(r))
}

// ═══════════════════════════════════════════════════════════════
// Channel generators
// Transgression: quarter-1 baseline ~0.05, quarter-2 ramp to peak,
// second half gradual decay.  Empathy: pre-event low; in FORGIVING
// ramps UP in the second half (REACH step E induction); in UNFORGIVEN
// stays flat.  Motivations use empathy[t-1] (lagged causal order).
// ═══════════════════════════════════════════════════════════════

// Transgression stream: structured "offense" event.
// Zero in quarter 1, rises sharply in quarter 2, decays in the second
// half (event fades but motivational residue persists).
fn fg_gen_transgression(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < FG_STEPS {
        s = fg_prng(s + t * 37)
        let quarter1 = FG_STEPS / 4
        let quarter2 = FG_STEPS / 2
        let mut level = 0.0
        if t < quarter1 {
            // Pre-event baseline
            level = 0.05
        }
        if t >= quarter1 {
            if t < quarter2 {
                // Event in progress — rise to peak
                let phase = to_float(t - quarter1) / to_float(quarter2 - quarter1)
                level = 0.05 + (FG_TRANSGR_PEAK - 0.05) * phase
            }
        }
        if t >= quarter2 {
            // Post-event — gradual decay of the event signal itself
            // (residue persists but the acute moment passes)
            let phase = to_float(t - quarter2) / to_float(FG_STEPS - quarter2)
            level = FG_TRANSGR_PEAK * (1.0 - 0.4 * phase)
        }
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(level + jit))
        t = t + 1
    }
    return out
}

// Empathy stream: post-event ramp in FORGIVING, flat in UNFORGIVEN.
fn fg_gen_empathy(emp_base: float, emp_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < FG_STEPS {
        s = fg_prng(s + t * 43)
        let quarter2 = FG_STEPS / 2
        let mut level = emp_base
        if t >= quarter2 {
            // Ramp empathy in the second half (post-event REACH induction)
            let phase = to_float(t - quarter2) / to_float(FG_STEPS - quarter2)
            level = emp_base + emp_gain * phase
        }
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(level + jit))
        t = t + 1
    }
    return out
}

// TRIM avoidance: rises with transgression, falls with empathy[t-1].
fn fg_gen_avoidance(transgression: array, empathy: array, decay_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    let mut prev_emp = empathy[0]
    while t < FG_STEPS {
        s = fg_prng(s + t * 59)
        let driven = FG_AV_BASE + FG_AV_TRANSGR_GAIN * transgression[t] - decay_gain * prev_emp
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(driven + jit))
        prev_emp = empathy[t]
        t = t + 1
    }
    return out
}

// TRIM revenge: same structural form as avoidance.
fn fg_gen_revenge(transgression: array, empathy: array, decay_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    let mut prev_emp = empathy[0]
    while t < FG_STEPS {
        s = fg_prng(s + t * 67)
        let driven = FG_RV_BASE + FG_RV_TRANSGR_GAIN * transgression[t] - decay_gain * prev_emp
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(driven + jit))
        prev_emp = empathy[t]
        t = t + 1
    }
    return out
}

// TRIM benevolence: rises with empathy, suppressed by transgression.
fn fg_gen_benevolence(transgression: array, empathy: array, rise_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    let mut prev_emp = empathy[0]
    while t < FG_STEPS {
        s = fg_prng(s + t * 71)
        let driven = FG_BN_BASE + rise_gain * prev_emp - FG_BN_SUPPRESS * transgression[t]
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(driven + jit))
        prev_emp = empathy[t]
        t = t + 1
    }
    return out
}

// Rumination: rises with transgression, suppressed by empathy (forgiveness).
fn fg_gen_rumination(transgression: array, empathy: array, suppress_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    let mut prev_emp = empathy[0]
    while t < FG_STEPS {
        s = fg_prng(s + t * 73)
        let driven = FG_RU_BASE + FG_RU_TRANSGR_GAIN * transgression[t] - suppress_gain * prev_emp
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(driven + jit))
        prev_emp = empathy[t]
        t = t + 1
    }
    return out
}

// Moral evaluation: transgression → "wrongness" judgement.
// INVARIANT across forgive/unforgive; only CONDONING shifts this.
fn fg_gen_moral_eval(transgression: array, condone_shift: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < FG_STEPS {
        s = fg_prng(s + t * 79)
        let driven = FG_ME_BASE + FG_ME_WRONGNESS * transgression[t] - condone_shift
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(driven + jit))
        t = t + 1
    }
    return out
}

// Neutral-mode channel — low-amplitude flat stream for T5 floor.
fn fg_gen_neutral(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < FG_STEPS {
        s = fg_prng(s + t * 103)
        let jit = FG_JITTER * fg_signed(s)
        out = out.push(fg_clamp01(FG_NEUTRAL_AMP + jit))
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Full pipeline runner — 7 channels + derived forgiveness_state.
// Flat packed layout (avoids struct-field list aliasing bug —
// feedback_hexa_struct_list_alias):
//   [transgr(0..N-1), empathy(N..2N-1), avoidance(2N..3N-1),
//    revenge(3N..4N-1), benev(4N..5N-1), rumin(5N..6N-1),
//    moral_eval(6N..7N-1), forg_state(7N..8N-1)]
// forg_state[t] = (benev + (1-avoid) + (1-revenge)) / 3 — scalar TRIM.
// ═══════════════════════════════════════════════════════════════

fn fg_run_pipeline(emp_base: float, emp_gain: float, av_decay: float, rv_decay: float, bn_rise: float, ru_suppress: float, condone_shift: float, seed: int) -> array {
    let transgr  = fg_gen_transgression(seed + 1000)
    let empathy  = fg_gen_empathy(emp_base, emp_gain, seed + 2000)
    let avoid    = fg_gen_avoidance(transgr, empathy, av_decay, seed + 3000)
    let revenge  = fg_gen_revenge(transgr, empathy, rv_decay, seed + 4000)
    let benev    = fg_gen_benevolence(transgr, empathy, bn_rise, seed + 5000)
    let rumin    = fg_gen_rumination(transgr, empathy, ru_suppress, seed + 6000)
    let moral    = fg_gen_moral_eval(transgr, condone_shift, seed + 7000)

    // Derived forgiveness_state: TRIM scalar summary
    // fs[t] = (benev + (1-avoid) + (1-revenge)) / 3
    let mut forg_state = []
    let mut i = 0
    while i < FG_STEPS {
        let fs = (benev[i] + (1.0 - avoid[i]) + (1.0 - revenge[i])) / 3.0
        forg_state = forg_state.push(fg_clamp01(fs))
        i = i + 1
    }

    // Pack sequentially — stage0 lists are pass-by-value so we rebuild
    let mut packed = []
    let mut a = 0
    while a < FG_STEPS {
        packed = packed.push(transgr[a])
        a = a + 1
    }
    let mut b = 0
    while b < FG_STEPS {
        packed = packed.push(empathy[b])
        b = b + 1
    }
    let mut c = 0
    while c < FG_STEPS {
        packed = packed.push(avoid[c])
        c = c + 1
    }
    let mut d = 0
    while d < FG_STEPS {
        packed = packed.push(revenge[d])
        d = d + 1
    }
    let mut e = 0
    while e < FG_STEPS {
        packed = packed.push(benev[e])
        e = e + 1
    }
    let mut f = 0
    while f < FG_STEPS {
        packed = packed.push(rumin[f])
        f = f + 1
    }
    let mut g = 0
    while g < FG_STEPS {
        packed = packed.push(moral[g])
        g = g + 1
    }
    let mut h = 0
    while h < FG_STEPS {
        packed = packed.push(forg_state[h])
        h = h + 1
    }
    return packed
}

// Channel indices for fg_slice
let FG_CH_TRANSGR      = 0
let FG_CH_EMPATHY      = 1
let FG_CH_AVOIDANCE    = 2
let FG_CH_REVENGE      = 3
let FG_CH_BENEVOLENCE  = 4
let FG_CH_RUMINATION   = 5
let FG_CH_MORAL_EVAL   = 6
let FG_CH_FORG_STATE   = 7

// Slice helper: extract one channel from the packed pipeline.
fn fg_slice(packed: array, ch_idx: int) -> array {
    let offset = ch_idx * FG_STEPS
    let mut out = []
    let mut i = 0
    while i < FG_STEPS {
        out = out.push(packed[offset + i])
        i = i + 1
    }
    return out
}

// Mean of second half of channel (post-empathy-induction window).
// T1 trajectory gaps use this (pre-event window is identical f/u).
fn fg_post_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let lo = n / 2
    let mut s = 0.0
    let mut cnt = 0
    let mut i = lo
    while i < n {
        s = s + v[i]
        cnt = cnt + 1
        i = i + 1
    }
    if cnt == 0 { return 0.0 }
    return s / to_float(cnt)
}

// Full-channel mean (T4 moral_eval invariance).
fn fg_channel_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

// Revisit rate: fraction of post-event steps where rumination ≥ thresh.
// Operationalizes "how often the mind returns to the transgression".
fn fg_revisit_rate(rumin: array, threshold: float) -> float {
    let n = len(rumin)
    if n == 0 { return 0.0 }
    let lo = n / 2
    let mut hits = 0
    let mut cnt = 0
    let mut i = lo
    while i < n {
        if rumin[i] >= threshold { hits = hits + 1 }
        cnt = cnt + 1
        i = i + 1
    }
    if cnt == 0 { return 0.0 }
    return to_float(hits) / to_float(cnt)
}

// Negated channel — avoidance/rumination drop with forgiveness;
// negating aligns sign with empathy/benevolence for integrated MI.
fn fg_negate(v: array) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(fg_clamp01(1.0 - v[i]))
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ measurement helpers (each MI captures one TRIM/REACH coupling):
//   MI(empathy, benevolence)     — prosocial binding
//   MI(empathy, -avoidance)      — approach restoration
//   MI(empathy, -revenge)        — retaliation release
//   MI(forg_state, -rumination)  — memory control (Karremans)
// ═══════════════════════════════════════════════════════════════

fn fg_phi_empathy_benev(packed: array) -> float {
    let emp = fg_slice(packed, FG_CH_EMPATHY)
    let bn  = fg_slice(packed, FG_CH_BENEVOLENCE)
    return fg_mi(emp, bn)
}

fn fg_phi_empathy_avoid_neg(packed: array) -> float {
    let emp = fg_slice(packed, FG_CH_EMPATHY)
    let av  = fg_slice(packed, FG_CH_AVOIDANCE)
    let av_neg = fg_negate(av)
    return fg_mi(emp, av_neg)
}

fn fg_phi_empathy_rev_neg(packed: array) -> float {
    let emp = fg_slice(packed, FG_CH_EMPATHY)
    let rv  = fg_slice(packed, FG_CH_REVENGE)
    let rv_neg = fg_negate(rv)
    return fg_mi(emp, rv_neg)
}

fn fg_phi_forg_rumin_neg(packed: array) -> float {
    let fs  = fg_slice(packed, FG_CH_FORG_STATE)
    let ru  = fg_slice(packed, FG_CH_RUMINATION)
    let ru_neg = fg_negate(ru)
    return fg_mi(fs, ru_neg)
}

// Integrated Φ_forgive: mean of the four MIs (T5 scalar summary).
fn fg_phi_integrated(packed: array) -> float {
    let a = fg_phi_empathy_benev(packed)
    let b = fg_phi_empathy_avoid_neg(packed)
    let c = fg_phi_empathy_rev_neg(packed)
    let d = fg_phi_forg_rumin_neg(packed)
    return (a + b + c + d) / 4.0
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 TRIM trajectory — avoidance↓ + revenge↓ + benevolence↑
    //   (McCullough et al. 1998).  Same transgression seed in both
    //   pipelines; only empathy/decay gains differ.  All three axes
    //   must clear FG_*_GAP — three-dimensional model means a single
    //   axis failure disqualifies as "not TRIM forgiveness".
    let pack_forg = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, 0.0, 13601)
    let pack_unfg = fg_run_pipeline(FG_EMP_BASE_UNFORG,  FG_EMP_GAIN_UNFORG,  FG_AV_DECAY_UNFORG,  FG_RV_DECAY_UNFORG,  FG_BN_RISE_UNFORG,  FG_RU_SUPPRESS_UNFO, 0.0, 13601)

    let av_forg = fg_post_mean(fg_slice(pack_forg, FG_CH_AVOIDANCE))
    let av_unfg = fg_post_mean(fg_slice(pack_unfg, FG_CH_AVOIDANCE))
    let rv_forg = fg_post_mean(fg_slice(pack_forg, FG_CH_REVENGE))
    let rv_unfg = fg_post_mean(fg_slice(pack_unfg, FG_CH_REVENGE))
    let bn_forg = fg_post_mean(fg_slice(pack_forg, FG_CH_BENEVOLENCE))
    let bn_unfg = fg_post_mean(fg_slice(pack_unfg, FG_CH_BENEVOLENCE))

    let av_gap = av_unfg - av_forg
    let rv_gap = rv_unfg - rv_forg
    let bn_gap = bn_forg - bn_unfg

    println("  [T1] avoidance  forg=" + str(av_forg) + " unforg=" + str(av_unfg) + " gap=" + str(av_gap))
    println("  [T1] revenge    forg=" + str(rv_forg) + " unforg=" + str(rv_unfg) + " gap=" + str(rv_gap))
    println("  [T1] benevolence forg=" + str(bn_forg) + " unforg=" + str(bn_unfg) + " gap=" + str(bn_gap))

    let mut ok = true
    // All three axes must shift — TRIM is three-dimensional
    if av_gap <= FG_AV_GAP { ok = false }
    if rv_gap <= FG_RV_GAP { ok = false }
    if bn_gap <= FG_BN_GAP { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Empathy mediation (Worthington REACH; Fehr et al. 2010).
    //   Empathy is the proximal mediator.  (a) lagged
    //   |r|(empathy[:-1], forg_state[1:]) > FG_EMP_R_MIN — empathy
    //   precedes the shift.  (b) |r|(empathy, benevolence)
    //   > FG_EMP_BN_R_MIN — empathy directly drives positive motivation.
    let pack_forg = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, 0.0, 13602)

    let emp = fg_slice(pack_forg, FG_CH_EMPATHY)
    let fs  = fg_slice(pack_forg, FG_CH_FORG_STATE)
    let bn  = fg_slice(pack_forg, FG_CH_BENEVOLENCE)

    let r_lag = fg_pearson_lagged(emp, fs, FG_WIN)
    let r_emp_bn = fg_pearson_abs(emp, bn, FG_WIN)

    println("  [T2] lagged |r|(empathy, forg_state[+1]) win=" + str(FG_WIN) + " = " + str(r_lag))
    println("  [T2] |r|(empathy, benevolence) win=" + str(FG_WIN) + " = " + str(r_emp_bn))

    let mut ok = true
    // Lagged empathy-forgiveness correlation must exceed Worthington threshold
    if r_lag <= FG_EMP_R_MIN { ok = false }
    // Direct empathy-benevolence correlation also required
    if r_emp_bn <= FG_EMP_BN_R_MIN { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Rumination block (McCullough, Bellah, Kilpatrick & Johnson
    //   2001).  (a) post-event rumination mean: UNFORG > FORGIVE
    //   by FG_RUMIN_GAP.  (b) revisit rate (fraction of steps where
    //   rumination ≥ FG_REVISIT_THRESH): UNFORG − FORG > FG_REVISIT_GAP.
    //   Both must favor the forgiving condition.
    let pack_forg = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, 0.0, 13603)
    let pack_unfg = fg_run_pipeline(FG_EMP_BASE_UNFORG,  FG_EMP_GAIN_UNFORG,  FG_AV_DECAY_UNFORG,  FG_RV_DECAY_UNFORG,  FG_BN_RISE_UNFORG,  FG_RU_SUPPRESS_UNFO, 0.0, 13603)

    let ru_forg = fg_post_mean(fg_slice(pack_forg, FG_CH_RUMINATION))
    let ru_unfg = fg_post_mean(fg_slice(pack_unfg, FG_CH_RUMINATION))
    let rumin_gap = ru_unfg - ru_forg

    let rev_forg = fg_revisit_rate(fg_slice(pack_forg, FG_CH_RUMINATION), FG_REVISIT_THRESH)
    let rev_unfg = fg_revisit_rate(fg_slice(pack_unfg, FG_CH_RUMINATION), FG_REVISIT_THRESH)
    let revisit_gap = rev_unfg - rev_forg

    println("  [T3] rumination mean forg=" + str(ru_forg) + " unforg=" + str(ru_unfg) + " gap=" + str(rumin_gap))
    println("  [T3] revisit rate    forg=" + str(rev_forg) + " unforg=" + str(rev_unfg) + " gap=" + str(revisit_gap))

    let mut ok = true
    // Rumination mean must drop in forgiving condition
    if rumin_gap <= FG_RUMIN_GAP { ok = false }
    // Revisit rate must also drop
    if revisit_gap <= FG_REVISIT_GAP { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Distinct-from-condoning (Enright 1991; Worthington 2006).
    //   Forgiveness preserves moral_eval; condoning drops it.
    //   (a) |moral_eval_forg − moral_eval_unforg| < FG_MORAL_TOL —
    //       invariance across forgiveness states.
    //   (b) moral_eval_forg − moral_eval_condone > FG_CONDONE_GAP —
    //       explicit contrast ruling out "forgiveness = condoning".
    let pack_forg = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, 0.0, 13604)
    let pack_unfg = fg_run_pipeline(FG_EMP_BASE_UNFORG,  FG_EMP_GAIN_UNFORG,  FG_AV_DECAY_UNFORG,  FG_RV_DECAY_UNFORG,  FG_BN_RISE_UNFORG,  FG_RU_SUPPRESS_UNFO, 0.0, 13604)
    // CONDONING: same empathy/motivation profile as FORGIVING, but
    // with moral_eval deliberately dropped via condone_shift. This
    // is the "forgiveness != condoning" contrast.
    let pack_cond = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, FG_ME_CONDONE_SHIFT, 13604)

    let me_forg = fg_channel_mean(fg_slice(pack_forg, FG_CH_MORAL_EVAL))
    let me_unfg = fg_channel_mean(fg_slice(pack_unfg, FG_CH_MORAL_EVAL))
    let me_cond = fg_channel_mean(fg_slice(pack_cond, FG_CH_MORAL_EVAL))

    let invariance = fg_abs(me_forg - me_unfg)
    let condone_diff = me_forg - me_cond

    println("  [T4] moral_eval forg=" + str(me_forg) + " unforg=" + str(me_unfg) + " condone=" + str(me_cond))
    println("  [T4] invariance (forg-unforg) |Δ|=" + str(invariance) + " (tol=" + str(FG_MORAL_TOL) + ")")
    println("  [T4] condoning gap (forg-cond)=" + str(condone_diff) + " (gate=" + str(FG_CONDONE_GAP) + ")")

    let mut ok = true
    // Moral_eval must be stable across forgive/unforgive (act still wrong)
    if invariance >= FG_MORAL_TOL { ok = false }
    // Condoning must show the moral_eval drop (explicit contrast)
    if condone_diff <= FG_CONDONE_GAP { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Φ_forgive integrated > Φ_neutral + determinism + latency
    //   (Karremans & Van Lange 2008; multi-channel binding).
    //   Integrated = mean of 4 MIs: MI(empathy, benevolence) prosocial,
    //   MI(empathy, -avoidance) approach, MI(empathy, -revenge)
    //   release, MI(forg_state, -rumination) memory control.
    //   NEUTRAL = low-amp uncoupled streams (histogram-noise floor).
    //   Also verifies byte-identical runs + pipeline < FG_LATENCY_MS.
    let t0 = clock()

    // Run A — forgiving pipeline
    let pa_forg = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, 0.0, 13605)
    let pa_unfg = fg_run_pipeline(FG_EMP_BASE_UNFORG,  FG_EMP_GAIN_UNFORG,  FG_AV_DECAY_UNFORG,  FG_RV_DECAY_UNFORG,  FG_BN_RISE_UNFORG,  FG_RU_SUPPRESS_UNFO, 0.0, 13605)

    // Neutral mode: pack 8 neutral-amplitude streams. No coupling.
    let n1 = fg_gen_neutral(13605 + 1000)
    let n2 = fg_gen_neutral(13605 + 2000)
    let n3 = fg_gen_neutral(13605 + 3000)
    let n4 = fg_gen_neutral(13605 + 4000)
    let n5 = fg_gen_neutral(13605 + 5000)
    let n6 = fg_gen_neutral(13605 + 6000)
    let n7 = fg_gen_neutral(13605 + 7000)
    let n8 = fg_gen_neutral(13605 + 8000)
    let mut packed_neutral = []
    let mut i = 0
    while i < FG_STEPS {
        packed_neutral = packed_neutral.push(n1[i])
        i = i + 1
    }
    let mut j = 0
    while j < FG_STEPS {
        packed_neutral = packed_neutral.push(n2[j])
        j = j + 1
    }
    let mut k = 0
    while k < FG_STEPS {
        packed_neutral = packed_neutral.push(n3[k])
        k = k + 1
    }
    let mut m = 0
    while m < FG_STEPS {
        packed_neutral = packed_neutral.push(n4[m])
        m = m + 1
    }
    let mut p = 0
    while p < FG_STEPS {
        packed_neutral = packed_neutral.push(n5[p])
        p = p + 1
    }
    let mut q = 0
    while q < FG_STEPS {
        packed_neutral = packed_neutral.push(n6[q])
        q = q + 1
    }
    let mut r = 0
    while r < FG_STEPS {
        packed_neutral = packed_neutral.push(n7[r])
        r = r + 1
    }
    let mut u = 0
    while u < FG_STEPS {
        packed_neutral = packed_neutral.push(n8[u])
        u = u + 1
    }

    // Run B — identical seeds (for determinism comparison)
    let pb_forg = fg_run_pipeline(FG_EMP_BASE_FORGIVE, FG_EMP_GAIN_FORGIVE, FG_AV_DECAY_FORGIVE, FG_RV_DECAY_FORGIVE, FG_BN_RISE_FORGIVE, FG_RU_SUPPRESS_FORG, 0.0, 13605)
    let pb_unfg = fg_run_pipeline(FG_EMP_BASE_UNFORG,  FG_EMP_GAIN_UNFORG,  FG_AV_DECAY_UNFORG,  FG_RV_DECAY_UNFORG,  FG_BN_RISE_UNFORG,  FG_RU_SUPPRESS_UNFO, 0.0, 13605)

    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] pipeline latency = " + str(ms) + " ms (gate=" + str(FG_LATENCY_MS) + ")")

    let phi_forg = fg_phi_integrated(pa_forg)
    let phi_unfg = fg_phi_integrated(pa_unfg)
    let phi_neu  = fg_phi_integrated(packed_neutral)
    let gap = phi_forg - phi_neu
    println("  [T5] Φ_integrated forgive=" + str(phi_forg) + " unforg=" + str(phi_unfg) + " neutral=" + str(phi_neu))
    println("  [T5] gap forg−neutral=" + str(gap))

    // Determinism: compare integrated Φ across runs A and B
    let d_forg = fg_abs(fg_phi_integrated(pa_forg) - fg_phi_integrated(pb_forg))
    let d_unfg = fg_abs(fg_phi_integrated(pa_unfg) - fg_phi_integrated(pb_unfg))
    println("  [T5] determinism deltas: forg=" + str(d_forg) + " unforg=" + str(d_unfg))

    let mut ok = true
    // Absolute floor — integrated Φ must be substantial in forgiving mode
    if phi_forg <= FG_INTEGRATED_MIN { ok = false }
    // Forgiving must exceed neutral by the required margin
    if gap <= FG_INTEGRATED_GAP { ok = false }
    // Determinism: byte-identical across runs
    if d_forg > FG_EPS { ok = false }
    if d_unfg > FG_EPS { ok = false }
    // Latency cap
    if ms >= FG_LATENCY_MS { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[forgiveness_phi] P136 — Forgiveness Φ (McCullough TRIM)")
    println("  channels: transgression → empathy → {avoidance, revenge, benevolence, rumination, moral_eval} → forg_state")
    println("  refs: McCullough et al. 1998 TRIM | Worthington REACH | Enright 1991 | Fehr et al. 2010")
    println("  empathy forg_base=" + str(FG_EMP_BASE_FORGIVE) + " forg_gain=" + str(FG_EMP_GAIN_FORGIVE))
    println("  empathy unforg_base=" + str(FG_EMP_BASE_UNFORG) + " unforg_gain=" + str(FG_EMP_GAIN_UNFORG))
    println("  decay gains forg: av=" + str(FG_AV_DECAY_FORGIVE) + " rv=" + str(FG_RV_DECAY_FORGIVE) + " ru=" + str(FG_RU_SUPPRESS_FORG))
    println("  benevolence rise forg=" + str(FG_BN_RISE_FORGIVE) + " condone shift=" + str(FG_ME_CONDONE_SHIFT))
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  TRIM trajectory — avoidance↓ + revenge↓ + benevolence↑ (McCullough 1998)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  empathy mediation — lagged |r|(empathy, forg_state) + direct |r|(empathy, benevolence)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  rumination block — forgiving revisit rate < unforgiving revisit rate") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  distinct-from-condoning — moral_eval invariant forg/unforg, collapses in condone") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  Φ_forgive > Φ_neutral + determinism + latency < " + str(FG_LATENCY_MS) + " ms") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 && chains with 5 operands can mis-short-
    // circuit under certain orderings (same idiom as gratitude_phi,
    // curiosity_phi, emotion_regulation_phi, moral_consciousness_phi).
    // Sequential mutable-bool guard is the reliable pattern.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[forgiveness_phi] 5/5 PASS — P136 DONE (forgiveness Φ TRIM + REACH + rumination-block + condoning-distinct verified)")
    } else {
        println("[forgiveness_phi] SOME FAILED")
    }
}

main()
