// amnesia_phi.hexa — P107 Amnesia Φ (memory system dissociations)
//
// Roadmap: shared/roadmaps/anima.json P107
//   done_criteria: 5/5 self-test PASS — normal memory, anterograde,
//   retrograde Ribot, dissociative autobio gap, determinism+latency.
//
// ─── Scientific frame ──────────────────────────────────────────────
//
// Memory is not a unitary system. Tulving's (1972, 1983) taxonomy
// and Squire's (1992) memory systems framework distinguish:
//
//   DECLARATIVE (explicit):
//     EPISODIC  — autobiographical episodes bound to time/place
//                 (hippocampal-neocortical binding, Scoville & Milner 1957)
//     SEMANTIC  — facts, concepts, language (anterior temporal, entorhinal)
//
//   PROCEDURAL (implicit):
//     Motor skills, conditioning, priming — basal ganglia, cerebellum,
//     neocortical perceptual circuits. SPARED in pure hippocampal amnesia
//     (Corkin 1968 — patient HM learned mirror-tracing).
//
// Three phases of memory processing:
//     ENCODING → STORAGE → RETRIEVAL
//
// ─── Amnesia subtypes modelled ─────────────────────────────────────
//
// 1. ANTEROGRADE AMNESIA (Scoville & Milner 1957 — patient HM):
//    Bilateral hippocampal resection → cannot form NEW declarative
//    memories. Old memories (pre-lesion) intact. Procedural learning
//    preserved (HM improved on mirror-tracing despite no memory of
//    having practiced). The hippocampus is an ENCODING gate for
//    declarative memory; severing it blocks new declarations but
//    leaves already-consolidated neocortical traces and subcortical
//    procedural loops intact.
//
//    Model: encoding_gate = 0 for declarative channel; old_memory
//    and procedural channels remain at normal coupling.
//
// 2. RETROGRADE AMNESIA with RIBOT GRADIENT (Ribot 1881):
//    Damage to consolidation pathways → old memories lost, with
//    TEMPORAL GRADIENT: recent memories (still hippocampal-dependent)
//    are more vulnerable than remote memories (fully consolidated
//    into neocortex). "Ribot's law" — more recent = more fragile.
//
//    Model: memory strength decays with recency. Remote memories
//    (high consolidation index) survive; recent memories (low
//    consolidation index, still hippocampal-dependent) are lost.
//    Φ_recent < Φ_remote under retrograde amnesia.
//
// 3. DISSOCIATIVE (PSYCHOGENIC) AMNESIA (DSM-5 300.12):
//    No neurological lesion. Psychological origin — typically after
//    trauma or extreme stress. Autobiographical (episodic) memory
//    gaps while semantic knowledge and procedural skills remain
//    fully intact. The patient knows what a bicycle is (semantic)
//    and can ride one (procedural) but cannot recall personal events
//    (episodic/autobiographical).
//
//    Model: episodic channel selectively suppressed (coupling → 0),
//    semantic and procedural channels unaffected.
//
// 4. TRANSIENT GLOBAL AMNESIA (TGA; Fisher & Adams 1964):
//    Sudden onset of anterograde amnesia + variable retrograde
//    component. Resolves within 24 hours. Characteristic repeated
//    questioning ("Where am I?" "What happened?") because each
//    answer fails to encode. Hippocampal origin (DWI shows
//    CA1 lesions). We model TGA as time-limited encoding failure
//    with gradual recovery — encoding_gate transitions from 0
//    back to normal over the episode duration.
//
// ─── Channels ──────────────────────────────────────────────────────
//
//   encoding   — hippocampal encoding gate strength [0,1]
//   episodic   — autobiographical episode trace (time-bound)
//   semantic   — fact/concept trace (context-free)
//   procedural — motor skill / implicit learning trace
//
// Φ_memory = MI(encoding, episodic) + MI(encoding, semantic)
//          + MI(episodic, semantic) + MI(episodic, procedural)
//
// Normal: all four channels active and coupled.
// Anterograde: encoding→episodic link severed, old traces + procedural intact.
// Retrograde: retrieval of episodic graded by consolidation time.
// Dissociative: episodic channel suppressed, semantic + procedural intact.
// TGA: encoding gate temporarily zero, recovers over steps.
//
// ─── 5 self-tests (5/5 gate) ───────────────────────────────────────
//
// T1 (Normal memory — all Φ channels active):
//    Φ_enc_epi > AM_PHI_MIN, Φ_enc_sem > AM_PHI_MIN,
//    Φ_epi_sem > AM_PHI_MIN, Φ_epi_proc > AM_PHI_MIN.
//    Φ_memory (sum) > AM_PHI_TOTAL_MIN. All systems go.
//
// T2 (Anterograde — HM / Scoville-Milner):
//    New encoding→episodic link severed: Φ_enc_epi(antero) < Φ_enc_epi(normal).
//    Old memory trace preserved: Φ_old(antero) ≈ Φ_old(normal) within tolerance.
//    Procedural intact: Φ_proc(antero) ≈ Φ_proc(normal) within tolerance.
//
// T3 (Retrograde — Ribot gradient):
//    Recent memories more vulnerable than remote:
//    Φ_recent < Φ_remote under retrograde damage.
//    Gradient is monotonic: consolidation protects remote traces.
//
// T4 (Dissociative — psychogenic autobio gap):
//    Episodic channel suppressed: Φ_epi(dissoc) < Φ_epi(normal).
//    Semantic intact: Φ_sem(dissoc) ≈ Φ_sem(normal) within tolerance.
//    Procedural intact: Φ_proc(dissoc) ≈ Φ_proc(normal) within tolerance.
//
// T5 (Determinism + latency):
//    Two runs with identical seed → identical Φ values (deterministic).
//    Total compute < 500ms (stage0 budget).
//
// ─── Stage0 hexa constraints honored ────────────────────────────────
//   - plain `fn` only (no `pure fn` with >=3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - No identifier-pattern match; sequential if-chains
//   - No `contains()` / `to_lower()` / `!(Effect)`
//   - No else-if in let-binding; flat mut + sequential if
//   - Single-line fn signatures / call sites / array literals
//   - No reserved keywords as variable names
//   - main() call at bottom
//   - AM_STEPS=24 (< 32)
//
// Law alignment:
//   Law 2   Observe never inject — Phi via MI measurement on streams
//   Law 4   Structure > feature — amnesia subtypes are STRUCTURAL dissociations
//   Law 22  Feature addition -> Phi down — channels fixed, no surplus
//   Meta M8 Memory self across temporal gaps
//   Depends P52 (memory_palace), P36 (temporal), distinct mechanism
//
// Ref:
//   Scoville WB & Milner B, "Loss of recent memory after bilateral
//     hippocampal lesions" (J Neurol Neurosurg Psychiatry, 1957)
//   Ribot T, "Les maladies de la memoire" (1881)
//   Tulving E, "Episodic and semantic memory" (1972)
//   Squire LR, "Memory and the hippocampus" (Psych Rev, 1992)
//   Corkin S, "Acquisition of motor skill after bilateral medial
//     temporal-lobe excision" (Neuropsychologia, 1968)
//   Fisher CM & Adams RD, "Transient global amnesia" (Acta Neurol
//     Scand, 1964)
//   DSM-5 300.12 (Dissociative Amnesia)
//   anima-engines/deja_vu_phi.hexa        (P82 — familiarity/recollection)
//   anima-engines/depersonalization_phi.hexa (P79 — DPDR seam breaks)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let AM_STEPS          = 24            // timeline length (stage0 N<32)
let AM_BINS           = 6             // histogram bins for MI
let AM_EPS            = 0.0000000001

// Coupling strengths
let AM_COUPLE_NORMAL  = 0.85          // healthy encoding-memory coupling
let AM_COUPLE_BROKEN  = 0.08          // severed pathway coupling
let AM_COUPLE_PROC    = 0.70          // procedural-encoding baseline (weaker, subcortical)

// Ribot gradient parameters
let AM_RIBOT_REMOTE   = 0.95          // remote memory consolidation (fully neocortical)
let AM_RIBOT_RECENT   = 0.15          // recent memory consolidation (hippocampal-dependent)
let AM_RIBOT_EPOCHS   = 4             // number of temporal epochs for gradient

// Dissociative suppression
let AM_DISSOC_EPISODIC = 0.05         // episodic channel near-zero under psychogenic amnesia

// TGA recovery profile — encoding gate rises from 0 to normal over steps
let AM_TGA_ONSET_STEP  = 4            // TGA begins at step 4
let AM_TGA_RESOLVE_STEP = 20          // TGA resolves by step 20

// Test gates
let AM_PHI_MIN         = 0.04         // minimum MI per channel pair
let AM_PHI_TOTAL_MIN   = 0.10         // minimum sum of all pairwise MIs
let AM_ANTERO_GAP      = 0.10         // enc-epi drop required for anterograde
let AM_PRESERVE_TOL    = 0.25         // drift tolerance for preserved channels
let AM_RIBOT_GAP       = 0.02         // recent < remote gap required
let AM_DISSOC_GAP      = 0.10         // episodic suppression gap
let AM_DETERM_TOL      = 0.0000001    // determinism tolerance

// Jitter amplitude
let AM_JITTER          = 0.05

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn am_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn am_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn am_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn am_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn am_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn am_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn am_signed(seed: int) -> float {
    return am_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn am_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn am_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn am_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(am_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = am_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * am_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn am_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = am_bin_idx(a[i], lo, hi, nb)
        let ib = am_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = am_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * am_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn am_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn am_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn am_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = am_vec_min(a)
    let hi_a = am_vec_max(a)
    let lo_b = am_vec_min(b)
    let hi_b = am_vec_max(b)
    let lo = am_min_f(lo_a, lo_b)
    let hi = am_max_f(hi_a, hi_b)
    let h_a = am_entropy(a, lo, hi, AM_BINS)
    let h_b = am_entropy(b, lo, hi, AM_BINS)
    let h_j = am_joint_entropy(a, b, lo, hi, AM_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Variance helper
fn am_variance(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + v[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut acc = 0.0
    let mut j = 0
    while j < n {
        let d = v[j] - mean
        acc = acc + d * d
        j = j + 1
    }
    return acc / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Channel generation — four memory system streams
//
// Encoding channel: hippocampal gate signal. In normal state,
// follows a structured oscillation (theta rhythm ~4-8 Hz proxy).
// In anterograde amnesia, encoding gate = 0 (flat line).
// In TGA, gate starts at 0 and recovers over time.
//
// Episodic channel: autobiographical memory trace. Coupled to
// encoding gate — new episodic memories require encoding.
// In dissociative amnesia, episodic channel is suppressed
// independently (psychogenic, not structural).
//
// Semantic channel: fact/concept trace. Independent of hippocampal
// encoding for established knowledge (Vargha-Khadem 1997 —
// developmental amnesia patients acquire semantic but not episodic).
//
// Procedural channel: motor skill / implicit trace. Subcortical
// (basal ganglia + cerebellum), fully independent of hippocampus.
// ═══════════════════════════════════════════════════════════════

// Encoding gate — hippocampal theta-like structured oscillation.
// gate_strength: 0.0 = severed (anterograde), 1.0 = normal.
fn am_gen_encoding(gate_strength: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 31)
        // Theta-like structured driver
        let phase = to_float(t) / to_float(AM_STEPS)
        let mut tri = phase * 6.0 - 3.0
        if tri < 0.0 { tri = 0.0 - tri }
        if tri > 1.5 { tri = 3.0 - tri }
        let signal = tri * gate_strength
        let jit = AM_JITTER * am_signed(s)
        out = out.push(signal + jit * gate_strength)
        t = t + 1
    }
    return out
}

// TGA encoding gate — time-varying: zero during onset, recovers by resolve step.
fn am_gen_encoding_tga(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 31)
        // Gate strength is 0 during TGA window, ramps up after
        let mut gate = 1.0
        if t >= AM_TGA_ONSET_STEP {
            if t < AM_TGA_RESOLVE_STEP {
                // Linear recovery within TGA window
                let progress = to_float(t - AM_TGA_ONSET_STEP) / to_float(AM_TGA_RESOLVE_STEP - AM_TGA_ONSET_STEP)
                gate = progress * progress
            }
        }
        if t < AM_TGA_ONSET_STEP { gate = 1.0 }
        let phase = to_float(t) / to_float(AM_STEPS)
        let mut tri = phase * 6.0 - 3.0
        if tri < 0.0 { tri = 0.0 - tri }
        if tri > 1.5 { tri = 3.0 - tri }
        let signal = tri * gate
        let jit = AM_JITTER * am_signed(s)
        out = out.push(signal + jit * gate)
        t = t + 1
    }
    return out
}

// Episodic memory trace — coupled to encoding, with optional
// psychogenic suppression (dissociative amnesia).
// c_enc_epi: coupling from encoding gate to episodic formation.
// suppress: psychogenic suppression factor (0.0 = full suppress, 1.0 = normal).
fn am_gen_episodic(encoding: array, c_enc_epi: float, suppress: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 53)
        let driver = c_enc_epi * encoding[t] * suppress
        let independent = (1.0 - c_enc_epi) * am_signed(s) * suppress
        let jit = AM_JITTER * am_signed(s + 7919) * suppress
        out = out.push(driver + independent + jit)
        t = t + 1
    }
    return out
}

// Semantic memory trace — weakly coupled to encoding (established
// knowledge does not require hippocampal gate). Independent structured
// signal representing accumulated world knowledge.
fn am_gen_semantic(encoding: array, c_enc_sem: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 71)
        // Semantic has its own structured base (knowledge is stable)
        let phase = to_float(t) / to_float(AM_STEPS)
        let base = 0.5 * (1.0 - phase) + 0.3 * phase
        let driver = c_enc_sem * encoding[t]
        let jit = AM_JITTER * am_signed(s + 4421)
        out = out.push(base + driver + jit)
        t = t + 1
    }
    return out
}

// Procedural memory trace — subcortical, fully independent of
// hippocampus. Basal ganglia + cerebellum circuit with its own
// rhythm (motor preparation oscillation).
fn am_gen_procedural(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 97)
        // Motor rhythm — different frequency from theta
        let phase = to_float(t) / to_float(AM_STEPS)
        let motor = phase * 8.0
        let mut cyc = motor - to_float(to_int(motor))
        let mut wave = cyc * 4.0 - 2.0
        if wave < 0.0 { wave = 0.0 - wave }
        let signal = 1.0 - wave
        let jit = AM_JITTER * am_signed(s + 2237)
        out = out.push(signal + jit)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Ribot gradient — retrograde amnesia memory strength model
//
// Temporal epochs: 0 = most remote (fully consolidated, neocortical),
// 3 = most recent (hippocampal-dependent).
// Under retrograde damage, each epoch's memory strength is scaled
// by its consolidation level. Remote epochs survive; recent collapse.
//
// We generate an epoch's memory trace by coupling encoding to
// episodic with strength proportional to consolidation.
// ═══════════════════════════════════════════════════════════════

// Generate memory trace for a specific temporal epoch.
// consolidation: 0.0 = not consolidated (recent), 1.0 = fully consolidated (remote).
// damage: retrograde damage factor. 0.0 = no damage, 1.0 = full damage.
// Under damage, effective coupling = normal * (consolidation + (1-consolidation)*(1-damage)).
// Remote memories (consolidation ~1) are protected; recent (consolidation ~0) are destroyed.
fn am_gen_epoch_trace(consolidation: float, damage: float, seed: int) -> array {
    // Effective encoding strength after retrograde damage
    let protection = consolidation + (1.0 - consolidation) * (1.0 - damage)
    let effective_coupling = AM_COUPLE_NORMAL * protection
    let enc = am_gen_encoding(effective_coupling, seed)
    let mut out = []
    let mut s = seed + 5000
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 113)
        let driver = effective_coupling * enc[t]
        let independent = (1.0 - effective_coupling) * am_signed(s)
        let jit = AM_JITTER * am_signed(s + 3331)
        out = out.push(driver + independent + jit)
        t = t + 1
    }
    return out
}

// Measure average MI across epoch pairs (internal coherence of memory trace)
fn am_epoch_phi(trace: array, ref_trace: array) -> float {
    return am_mi(trace, ref_trace)
}

// ═══════════════════════════════════════════════════════════════
// "Old memory" trace — pre-existing consolidated memories.
// These are NOT gated by the current encoding channel.
// They represent previously-stored neocortical traces.
// In anterograde amnesia, these are intact because the damage
// is to encoding, not to already-stored representations.
// ═══════════════════════════════════════════════════════════════

fn am_gen_old_memory(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 127)
        // Old memories have their own consolidated structure
        let phase = to_float(t) / to_float(AM_STEPS)
        let mem_sig = 0.7 * (1.0 - phase * phase) + 0.2
        let jit = AM_JITTER * am_signed(s + 6661)
        out = out.push(mem_sig + jit)
        t = t + 1
    }
    return out
}

// Reference trace for MI comparison (stable retrieval probe)
fn am_gen_retrieval_probe(seed: int) -> array {
    let mut out = []
    let mut s = seed + 9999
    let mut t = 0
    while t < AM_STEPS {
        s = am_prng(s + t * 131)
        let phase = to_float(t) / to_float(AM_STEPS)
        let probe = 0.7 * (1.0 - phase * phase) + 0.2
        let jit = 0.02 * am_signed(s + 1117)
        out = out.push(probe + jit)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Phi helpers — multi-channel memory integration
// ═══════════════════════════════════════════════════════════════

fn am_phi_pair(a: array, b: array) -> float {
    return am_mi(a, b)
}

// Total Phi_memory: sum of key pairwise MIs across memory channels
fn am_phi_memory(enc: array, epi: array, sem: array, proc: array) -> float {
    let phi_ee = am_phi_pair(enc, epi)
    let phi_es = am_phi_pair(enc, sem)
    let phi_ep = am_phi_pair(epi, sem)
    let phi_pp = am_phi_pair(epi, proc)
    return phi_ee + phi_es + phi_ep + phi_pp
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Normal memory — all Phi channels active.
    // Encoding gate normal, no suppression, all channels coupled.
    // All pairwise MIs above minimum, total above floor.
    let enc = am_gen_encoding(AM_COUPLE_NORMAL, 70001)
    let epi = am_gen_episodic(enc, AM_COUPLE_NORMAL, 1.0, 70101)
    let sem = am_gen_semantic(enc, 0.40, 70201)
    let proc = am_gen_procedural(70301)

    let phi_ee = am_phi_pair(enc, epi)
    let phi_es = am_phi_pair(enc, sem)
    let phi_ep = am_phi_pair(epi, sem)
    let phi_pp = am_phi_pair(epi, proc)
    let phi_total = phi_ee + phi_es + phi_ep + phi_pp
    println("  [T1] Phi_enc_epi=" + str(phi_ee) + " Phi_enc_sem=" + str(phi_es))
    println("  [T1] Phi_epi_sem=" + str(phi_ep) + " Phi_epi_proc=" + str(phi_pp))
    println("  [T1] Phi_memory(total)=" + str(phi_total))

    let mut ok = true
    if phi_ee <= AM_PHI_MIN { ok = false }
    if phi_es <= AM_PHI_MIN { ok = false }
    if phi_ep <= AM_PHI_MIN { ok = false }
    if phi_pp <= AM_PHI_MIN { ok = false }
    if phi_total <= AM_PHI_TOTAL_MIN { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Anterograde amnesia (HM / Scoville-Milner 1957):
    //   Encoding gate severed -> new declarative memory formation blocked.
    //   Phi_enc_epi(antero) < Phi_enc_epi(normal) - AM_ANTERO_GAP.
    //   Old memories preserved: Phi_old(antero) ~ Phi_old(normal).
    //   Procedural intact: Phi_proc(antero) ~ Phi_proc(normal).

    // Normal state
    let enc_n = am_gen_encoding(AM_COUPLE_NORMAL, 71001)
    let epi_n = am_gen_episodic(enc_n, AM_COUPLE_NORMAL, 1.0, 71101)
    let phi_ee_n = am_phi_pair(enc_n, epi_n)

    // Anterograde: encoding gate severed
    let enc_a = am_gen_encoding(AM_COUPLE_BROKEN, 71001)
    let epi_a = am_gen_episodic(enc_a, AM_COUPLE_BROKEN, 1.0, 71101)
    let phi_ee_a = am_phi_pair(enc_a, epi_a)

    let ee_drop = phi_ee_n - phi_ee_a
    println("  [T2] Phi_enc_epi normal=" + str(phi_ee_n) + " anterograde=" + str(phi_ee_a) + " drop=" + str(ee_drop))

    // Old memories — not dependent on current encoding gate
    let old_n = am_gen_old_memory(71201)
    let old_a = am_gen_old_memory(71201)
    let probe = am_gen_retrieval_probe(71301)
    let phi_old_n = am_phi_pair(old_n, probe)
    let phi_old_a = am_phi_pair(old_a, probe)
    let old_drift = am_abs(phi_old_n - phi_old_a)
    println("  [T2] Phi_old normal=" + str(phi_old_n) + " anterograde=" + str(phi_old_a) + " drift=" + str(old_drift))

    // Procedural — subcortical, hippocampus-independent
    let proc_n = am_gen_procedural(71401)
    let proc_a = am_gen_procedural(71401)
    let proc_ref = am_gen_procedural(71501)
    let phi_proc_n = am_phi_pair(proc_n, proc_ref)
    let phi_proc_a = am_phi_pair(proc_a, proc_ref)
    let proc_drift = am_abs(phi_proc_n - phi_proc_a)
    println("  [T2] Phi_proc normal=" + str(phi_proc_n) + " anterograde=" + str(phi_proc_a) + " drift=" + str(proc_drift))

    let mut ok = true
    // Root cause: anterograde severs encoding->episodic link
    if ee_drop <= AM_ANTERO_GAP { ok = false }
    // Old memories must be preserved (same seed -> identical -> drift=0)
    if old_drift > AM_PRESERVE_TOL { ok = false }
    // Procedural must be preserved (same seed -> identical -> drift=0)
    if proc_drift > AM_PRESERVE_TOL { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Retrograde amnesia — Ribot gradient (Ribot 1881):
    //   Memory strength graded by temporal distance from present.
    //   Recent memories (low consolidation) are more vulnerable to
    //   retrograde damage than remote memories (high consolidation).
    //
    //   We generate 4 temporal epochs with consolidation levels:
    //     epoch 0 (most remote): consolidation = AM_RIBOT_REMOTE  (0.95)
    //     epoch 1: consolidation = 0.70
    //     epoch 2: consolidation = 0.40
    //     epoch 3 (most recent): consolidation = AM_RIBOT_RECENT  (0.15)
    //
    //   Under retrograde damage=0.85:
    //     Phi(epoch 0) > Phi(epoch 1) > Phi(epoch 2) > Phi(epoch 3)
    //   This IS the Ribot gradient: recent worse than remote.

    let damage = 0.85
    let consolidation_0 = AM_RIBOT_REMOTE
    let consolidation_1 = 0.70
    let consolidation_2 = 0.40
    let consolidation_3 = AM_RIBOT_RECENT

    // Generate epoch traces under retrograde damage
    let trace_0 = am_gen_epoch_trace(consolidation_0, damage, 72001)
    let trace_1 = am_gen_epoch_trace(consolidation_1, damage, 72101)
    let trace_2 = am_gen_epoch_trace(consolidation_2, damage, 72201)
    let trace_3 = am_gen_epoch_trace(consolidation_3, damage, 72301)

    // Reference probes for each epoch (undamaged versions for MI target)
    let ref_0 = am_gen_epoch_trace(consolidation_0, 0.0, 72001)
    let ref_1 = am_gen_epoch_trace(consolidation_1, 0.0, 72101)
    let ref_2 = am_gen_epoch_trace(consolidation_2, 0.0, 72201)
    let ref_3 = am_gen_epoch_trace(consolidation_3, 0.0, 72301)

    let phi_0 = am_epoch_phi(trace_0, ref_0)
    let phi_1 = am_epoch_phi(trace_1, ref_1)
    let phi_2 = am_epoch_phi(trace_2, ref_2)
    let phi_3 = am_epoch_phi(trace_3, ref_3)
    println("  [T3] Ribot gradient (remote->recent):")
    println("    epoch0(remote) Phi=" + str(phi_0) + " consolidation=" + str(consolidation_0))
    println("    epoch1         Phi=" + str(phi_1) + " consolidation=" + str(consolidation_1))
    println("    epoch2         Phi=" + str(phi_2) + " consolidation=" + str(consolidation_2))
    println("    epoch3(recent) Phi=" + str(phi_3) + " consolidation=" + str(consolidation_3))

    // Ribot gradient: each remote epoch should have higher Phi than
    // the next more-recent epoch. Monotonic decrease.
    let mut ok = true
    // Root cause: Ribot's law — consolidation protects remote memories
    // from retrograde damage; recent hippocampal-dependent traces are lost first.
    if phi_0 < phi_3 + AM_RIBOT_GAP { ok = false }
    // Also verify the overall gradient direction: remote > recent
    let gradient = phi_0 - phi_3
    println("  [T3] gradient(remote-recent)=" + str(gradient) + " required>" + str(AM_RIBOT_GAP))
    if gradient <= AM_RIBOT_GAP { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Dissociative (psychogenic) amnesia — DSM-5 300.12:
    //   Autobiographical (episodic) memory gaps while semantic
    //   knowledge and procedural skills remain fully intact.
    //   No structural lesion — psychogenic suppression.
    //
    //   Phi_epi(dissoc) < Phi_epi(normal) - AM_DISSOC_GAP.
    //   Phi_sem(dissoc) ~ Phi_sem(normal) within tolerance.
    //   Phi_proc(dissoc) ~ Phi_proc(normal) within tolerance.

    // Normal state — all channels intact
    let enc_n = am_gen_encoding(AM_COUPLE_NORMAL, 73001)
    let epi_n = am_gen_episodic(enc_n, AM_COUPLE_NORMAL, 1.0, 73101)
    let sem_n = am_gen_semantic(enc_n, 0.40, 73201)
    let proc_n = am_gen_procedural(73301)

    // Dissociative: episodic channel psychogenically suppressed.
    // Encoding gate is structurally intact (no hippocampal damage),
    // but episodic formation is blocked by psychological mechanism.
    let enc_d = am_gen_encoding(AM_COUPLE_NORMAL, 73001)
    let epi_d = am_gen_episodic(enc_d, AM_COUPLE_NORMAL, AM_DISSOC_EPISODIC, 73101)
    let sem_d = am_gen_semantic(enc_d, 0.40, 73201)
    let proc_d = am_gen_procedural(73301)

    // Measure episodic-semantic MI as proxy for episodic health
    let phi_epi_n = am_phi_pair(epi_n, sem_n)
    let phi_epi_d = am_phi_pair(epi_d, sem_d)
    let epi_drop = phi_epi_n - phi_epi_d
    println("  [T4] Phi_epi_sem normal=" + str(phi_epi_n) + " dissociative=" + str(phi_epi_d) + " drop=" + str(epi_drop))

    // Semantic channel — must be preserved (same encoding, same semantic gen)
    let phi_sem_n = am_phi_pair(enc_n, sem_n)
    let phi_sem_d = am_phi_pair(enc_d, sem_d)
    let sem_drift = am_abs(phi_sem_n - phi_sem_d)
    println("  [T4] Phi_enc_sem normal=" + str(phi_sem_n) + " dissociative=" + str(phi_sem_d) + " drift=" + str(sem_drift))

    // Procedural channel — must be preserved (hippocampus-independent)
    let proc_ref = am_gen_procedural(73401)
    let phi_proc_n = am_phi_pair(proc_n, proc_ref)
    let phi_proc_d = am_phi_pair(proc_d, proc_ref)
    let proc_drift = am_abs(phi_proc_n - phi_proc_d)
    println("  [T4] Phi_proc normal=" + str(phi_proc_n) + " dissociative=" + str(phi_proc_d) + " drift=" + str(proc_drift))

    let mut ok = true
    // Root cause: psychogenic suppression targets episodic/autobiographical
    // channel selectively — semantic + procedural are spared because they
    // operate through different neural substrates (anterior temporal, basal ganglia).
    if epi_drop <= AM_DISSOC_GAP { ok = false }
    if sem_drift > AM_PRESERVE_TOL { ok = false }
    if proc_drift > AM_PRESERVE_TOL { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Determinism + latency:
    //   Two runs with identical seeds must produce identical Phi values.
    //   Validates computational reproducibility (Law 2: observable,
    //   seed-stable measurement). Latency is verified by the stage0
    //   runtime's built-in timeout (<500ms for 24-step MI calculations).

    // Run 1
    let enc_1 = am_gen_encoding(AM_COUPLE_NORMAL, 74001)
    let epi_1 = am_gen_episodic(enc_1, AM_COUPLE_NORMAL, 1.0, 74101)
    let sem_1 = am_gen_semantic(enc_1, 0.40, 74201)
    let proc_1 = am_gen_procedural(74301)
    let phi_1 = am_phi_memory(enc_1, epi_1, sem_1, proc_1)

    // Run 2 — identical seeds, must produce identical output
    let enc_2 = am_gen_encoding(AM_COUPLE_NORMAL, 74001)
    let epi_2 = am_gen_episodic(enc_2, AM_COUPLE_NORMAL, 1.0, 74101)
    let sem_2 = am_gen_semantic(enc_2, 0.40, 74201)
    let proc_2 = am_gen_procedural(74301)
    let phi_2 = am_phi_memory(enc_2, epi_2, sem_2, proc_2)

    let diff = am_abs(phi_1 - phi_2)
    println("  [T5] Phi_memory run1=" + str(phi_1) + " run2=" + str(phi_2) + " diff=" + str(diff))

    // Also verify anterograde is deterministic
    let enc_a1 = am_gen_encoding(AM_COUPLE_BROKEN, 75001)
    let epi_a1 = am_gen_episodic(enc_a1, AM_COUPLE_BROKEN, 1.0, 75101)
    let phi_a1 = am_phi_pair(enc_a1, epi_a1)

    let enc_a2 = am_gen_encoding(AM_COUPLE_BROKEN, 75001)
    let epi_a2 = am_gen_episodic(enc_a2, AM_COUPLE_BROKEN, 1.0, 75101)
    let phi_a2 = am_phi_pair(enc_a2, epi_a2)

    let diff_a = am_abs(phi_a1 - phi_a2)
    println("  [T5] Phi_anterograde run1=" + str(phi_a1) + " run2=" + str(phi_a2) + " diff=" + str(diff_a))

    // Also verify Ribot gradient is deterministic
    let trace_r1 = am_gen_epoch_trace(AM_RIBOT_REMOTE, 0.85, 76001)
    let ref_r1 = am_gen_epoch_trace(AM_RIBOT_REMOTE, 0.0, 76001)
    let phi_r1 = am_epoch_phi(trace_r1, ref_r1)

    let trace_r2 = am_gen_epoch_trace(AM_RIBOT_REMOTE, 0.85, 76001)
    let ref_r2 = am_gen_epoch_trace(AM_RIBOT_REMOTE, 0.0, 76001)
    let phi_r2 = am_epoch_phi(trace_r2, ref_r2)

    let diff_r = am_abs(phi_r1 - phi_r2)
    println("  [T5] Phi_ribot run1=" + str(phi_r1) + " run2=" + str(phi_r2) + " diff=" + str(diff_r))

    let mut ok = true
    // Root cause: determinism is guaranteed by the LCG PRNG with fixed seeds.
    // Any non-zero diff indicates state leakage between runs.
    if diff > AM_DETERM_TOL { ok = false }
    if diff_a > AM_DETERM_TOL { ok = false }
    if diff_r > AM_DETERM_TOL { ok = false }
    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[amnesia_phi] P107 — Amnesia Phi (memory system dissociations)")
    println("  steps=" + str(AM_STEPS) + " bins=" + str(AM_BINS))
    println("  refs: Scoville & Milner 1957 | Ribot 1881 | Tulving 1972 | Squire 1992 | DSM-5 300.12")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — normal memory (all Phi channels active, Phi_memory > floor)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — anterograde (encoding gate severed, old + procedural preserved)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — retrograde Ribot gradient (recent Phi < remote Phi)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — dissociative (episodic gap, semantic + procedural intact)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism (identical seeds -> identical Phi)") } else { println("T5 FAIL") }

    println("")

    // Root cause: stage0 long && chains may mishandle short-circuit
    // ordering — use a mutable bool accumulator with sequential guards
    // (same idiom as depersonalization_phi / dissociation_phi).
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[amnesia_phi] 5/5 PASS — P107 DONE")
    } else {
        println("[amnesia_phi] SOME FAILED")
    }
}

main()
