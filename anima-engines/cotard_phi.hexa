// cotard_phi.hexa — P100 Cotard Delusion Φ ("Walking Corpse" Syndrome)
//
// Roadmap: shared/roadmaps/anima.json P100
//   done_criteria: "5/5 PASS — Cotard self-existence Φ collapse,
//                   Type I interoceptive nihilism, Type II full
//                   existential negation, Capgras-Cotard spectrum,
//                   sequential recovery gradient"
//
// ─── Scientific hypothesis ────────────────────────────────────────
//
// Cotard's delusion (le délire de négation, Jules Cotard 1880):
// A nihilistic delusion in which the patient denies their own
// existence, the existence of their organs, or the reality of the
// external world. In severe form the patient asserts "I am dead"
// or "I do not exist." The syndrome sits at the extreme end of a
// depersonalization–derealization–nihilism continuum.
//
// ─── Three self-existence channels ────────────────────────────────
//
//   interoceptive  — visceral/organ sense: heartbeat, breathing,
//                    gut feeling, hunger, pain. "I have a body that
//                    is alive." (Craig 2002; Damasio 2010)
//
//   proprioceptive — body-schema / motor-ownership: limb position,
//                    movement agency, self-location. "I am HERE in
//                    this body." (Berlucchi & Aglioti 2010)
//
//   emotional      — affective self-model: valenced feeling states,
//                    hedonic tone, motivational salience. "I FEEL,
//                    therefore I am." (Damasio's somatic marker)
//
// Normal Φ_self: all three channels are active and mutually coherent.
// The product Φ_self = Φ_intero × Φ_proprio × Φ_emotion captures
// the integrated sense of "I exist as a living, located, feeling
// being."
//
// ─── Cotard Type I (depressive nihilism) ──────────────────────────
//
// Interoceptive channel collapses first (Young & Leafhead 1996):
//   "I have no stomach," "My blood has dried up," "I have no brain."
// Neuroimaging: hypoactivation of insular cortex (interoceptive hub).
// Proprioception and emotion are partially preserved — the patient
// still moves and shows flat affect (not zero).
//
// Model: c_intero → CT_COUPLE_DEAD, c_proprio and c_emotion preserved.
// Φ_intero drops sharply; Φ_proprio drift within tolerance.
//
// ─── Cotard Type II (full existential negation) ───────────────────
//
// All three self-channels collapse (Berrios & Luque 1995):
//   "I don't exist," "I am dead," "Nothing is real."
// The patient's entire self-model flatlines. This is distinguished
// from Type I by the simultaneous collapse of proprioceptive AND
// emotional channels, not just interoception.
//
// Model: all three coupling → CT_COUPLE_DEAD. Φ_self (product) → ~0.
//
// ─── Capgras-Cotard spectrum ──────────────────────────────────────
//
// Capgras delusion (person replaced by impostor) and Cotard delusion
// (self is dead/nonexistent) share a common mechanism: disconnection
// of the familiarity-recognition pathway from its affective/autonomic
// validation (Ellis & Young 1990; Young, Reid, Wright & Hellawell 1993).
//
//   Capgras: familiarity signal present, autonomic validation absent
//            → "this person LOOKS like my wife but ISN'T her"
//   Cotard:  familiarity signal present, autonomic self-validation absent
//            → "this body LOOKS like mine but ISN'T alive / isn't me"
//
// Shared mechanism: familiarity–affect disconnection.
//   Φ_fam_affect = MI(familiarity_channel, affect_channel)
//   Both Capgras and Cotard show Φ_fam_affect < normal.
//   Key difference: Capgras targets OTHER (other-familiarity), Cotard
//   targets SELF (self-familiarity). Same disconnect, different target.
//
// ─── Recovery gradient ────────────────────────────────────────────
//
// Treatment (ECT, antidepressants, antipsychotics — Berrios & Luque 1995;
// Debruyne et al. 2009) restores channels sequentially:
//   1. interoceptive first  — "I can feel my heartbeat again"
//   2. proprioceptive next  — "I am located in my body"
//   3. emotional last       — "I feel alive"
//
// This mirrors the phylogenetic hierarchy: interoception is the most
// primitive self-signal (brainstem), proprioception is next (spinal +
// cerebellar), and emotional self-model is highest (limbic + cortical).
//
// Model: sequential coupling restoration across treatment steps.
// Φ_self must increase monotonically; intero recovers before proprio
// recovers before emotion.
//
// ─── 5 self-tests (5/5 gate) ──────────────────────────────────────
//
// T1 Normal Φ_self > 0 across all channels:
//    Φ_intero, Φ_proprio, Φ_emotion all > CT_PHI_MIN;
//    Φ_self (product) > CT_SELF_MIN. Three channels coherent.
//
// T2 Type I — Φ_intero drops, Φ_proprio preserved:
//    Cotard Type I collapses interoception only.
//    Φ_intero(Type I) < Φ_intero(normal) - CT_DROP_GAP
//    AND Φ_proprio(Type I) within CT_PRESERVE_TOL of normal.
//
// T3 Type II — all self-Φ channels collapse:
//    Full existential negation. Φ_self(Type II) < CT_TYPE2_CEIL
//    AND each channel individually < CT_CHANNEL_DEAD.
//
// T4 Capgras-Cotard shared mechanism (familiarity disconnect):
//    Both conditions show Φ_fam_affect < Φ_fam_affect(normal) - gap.
//    The familiarity-affect MI collapses for BOTH Capgras (other-
//    targeted) and Cotard (self-targeted).
//
// T5 Determinism + latency:
//    Two runs with same seed produce identical Φ_self; full pipeline
//    under 5 s.
//
// ─── Stage0 hexa constraints honored ──────────────────────────────
//   - plain `fn` only (no `pure fn` >=3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - no identifier-pattern match; sequential if-chains
//   - no contains() / to_lower() / !(Effect)
//   - no else-if in let-binding; flat mut + sequential if
//   - single-line fn signatures / call sites / array literals
//   - no reserved keywords as variable names
//   - main() call at bottom
//   - CT_STEPS=24 (< 32)
//
// Law alignment:
//   Law 2   Observe never inject — Φ via MI measurement on streams
//   Law 4   Structure > feature — nihilism is STRUCTURAL self-model collapse
//   Law 22  Feature addition → Φ down — 3 channels fixed, no surplus
//   Meta M8 Self-model integrity — three-layer self-existence architecture
//   Depends P56 (interoception), P79 (depersonalization), distinct mechanism
//
// Ref:
//   Cotard J. (1880) Du délire des négations
//   Berrios G.E. & Luque R. (1995) Cotard's syndrome: analysis of 100 cases
//   Young A.W. & Leafhead K.M. (1996) Cotard delusion after brain injury
//   Ellis H.D. & Young A.W. (1990) Accounting for delusional misidentifications
//   Debruyne H. et al. (2009) Cotard's syndrome: a review
//   Craig A.D. (2002) How do you feel? Interoception
//   Damasio A. (2010) Self Comes to Mind

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let CT_STEPS           = 24            // timeline length (stage0 N<32)
let CT_BINS            = 6             // histogram bins for MI
let CT_EPS             = 0.0000000001

// Coupling strengths for the 3 self-existence channels.
// Layered causal chain: world → intero → proprio → emotion
let CT_COUPLE_ALIVE    = 0.85          // strong binding in healthy state
let CT_COUPLE_DEAD     = 0.10          // nihilistic collapse coupling

// Per-step jitter (independent noise per channel)
let CT_JITTER          = 0.05

// Type I numbing: under Cotard, emotion channel has reduced range
let CT_AFFECT_FLAT     = 0.25          // emotional amplitude scaling in Type I

// Recovery gradient steps (sequential restoration)
let CT_RECOVERY_STEPS  = 24           // treatment timeline
let CT_RECOVER_RATE    = 0.12          // per-step coupling restoration speed

// Test gates
let CT_PHI_MIN         = 0.04          // baseline channel MI minimum
let CT_SELF_MIN        = 0.0005        // product floor (3-way)
let CT_DROP_GAP        = 0.10          // Type I intero drop detection
let CT_PRESERVE_TOL    = 0.30          // unaffected channel drift tolerance
let CT_TYPE2_CEIL      = 0.02          // Type II product ceiling (near zero)
let CT_CHANNEL_DEAD    = 0.60          // per-channel dead threshold (residual MI with c=0.10)
let CT_FAM_DISCONNECT  = 0.08          // familiarity-affect disconnect gap
let CT_DETERM_TOL      = 0.0000001     // determinism tolerance

// Capgras-Cotard familiarity parameters
let CT_FAM_COUPLE_NORM = 0.80          // normal familiarity-affect binding
let CT_FAM_COUPLE_DISC = 0.10          // disconnected familiarity-affect

// ═══════════════════════════════════════════════════════════════
// Math / PRNG primitives (L0-clean, no cross-engine import per AN7)
// ═══════════════════════════════════════════════════════════════

fn ct_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ct_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn ct_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn ct_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

// Deterministic LCG — reproducibility (Law 2: observable, seed-stable)
fn ct_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn ct_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn ct_signed(seed: int) -> float {
    return ct_unit(seed) * 2.0 - 1.0
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn ct_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn ct_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn ct_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(ct_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = ct_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * ct_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn ct_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = ct_bin_idx(a[i], lo, hi, nb)
        let ib = ct_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = ct_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * ct_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn ct_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn ct_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn ct_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = ct_vec_min(a)
    let hi_a = ct_vec_max(a)
    let lo_b = ct_vec_min(b)
    let hi_b = ct_vec_max(b)
    let lo = ct_min_f(lo_a, lo_b)
    let hi = ct_max_f(hi_a, hi_b)
    let h_a = ct_entropy(a, lo, hi, CT_BINS)
    let h_b = ct_entropy(b, lo, hi, CT_BINS)
    let h_j = ct_joint_entropy(a, b, lo, hi, CT_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Stream generation — three self-existence channels
//
// Generation is causal: world → interoceptive → proprioceptive → emotional.
//
//   world_t      = sin-ish drift + jitter (independent environmental driver)
//   intero_t     = c_intero * world_t + (1-c) * jitter
//                  (visceral sense driven by external stimuli)
//   proprio_t    = c_proprio * intero_t + (1-c) * jitter
//                  (body-schema coupled to visceral ground truth)
//   emotion_t    = c_emotion * proprio_t + (1-c) * jitter
//                  (affective self-model built on embodied sense)
//
// Self-existence is parameterized by three coupling knobs:
//   c_intero     — interoceptive coupling (low = "I have no organs")
//   c_proprio    — proprioceptive coupling (low = "I am not here")
//   c_emotion    — emotional coupling (low = "I feel nothing")
//
// Affect flattening: when Type I active, emotion amplitude is scaled
// down (reduced affective dynamic range — flat affect in Cotard).
// ═══════════════════════════════════════════════════════════════

// Generate world channel — independent environmental driver
fn ct_gen_world(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < CT_STEPS {
        s = ct_prng(s + t * 31)
        let phase = to_float(t) / to_float(CT_STEPS)
        let mut tri = phase * 4.0 - 2.0
        if tri < 0.0 { tri = 0.0 - tri }
        let signal = 1.0 - tri
        let jit = CT_JITTER * ct_signed(s)
        out = out.push(signal + jit)
        t = t + 1
    }
    return out
}

// Generate interoceptive channel — visceral sense coupled to world.
// Low coupling → "I have no organs" (Type I onset)
fn ct_gen_intero(world: array, c_intero: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < CT_STEPS {
        s = ct_prng(s + t * 53)
        let driver = c_intero * world[t]
        let independent = (1.0 - c_intero) * ct_signed(s)
        let jit = CT_JITTER * ct_signed(s + 7919)
        out = out.push(driver + independent + jit)
        t = t + 1
    }
    return out
}

// Generate proprioceptive channel — body-schema coupled to interoception.
// Low coupling → "I am not located in my body"
fn ct_gen_proprio(intero: array, c_proprio: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < CT_STEPS {
        s = ct_prng(s + t * 71)
        let driver = c_proprio * intero[t]
        let independent = (1.0 - c_proprio) * ct_signed(s)
        let jit = CT_JITTER * ct_signed(s + 4421)
        out = out.push(driver + independent + jit)
        t = t + 1
    }
    return out
}

// Generate emotional channel — affective self-model coupled to proprioception.
// Low coupling → "I feel nothing" (anhedonia / existential emptiness).
// affect_flat flag scales amplitude (collapsed affective range in Cotard).
fn ct_gen_emotion(proprio: array, c_emotion: float, affect_flat: bool, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < CT_STEPS {
        s = ct_prng(s + t * 97)
        let driver = c_emotion * proprio[t]
        let independent = (1.0 - c_emotion) * ct_signed(s)
        let jit = CT_JITTER * ct_signed(s + 6173)
        let mut v = driver + independent + jit
        if affect_flat { v = v * CT_AFFECT_FLAT }
        out = out.push(v)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Φ helpers — pairwise binding + 3-way self-existence product
// ═══════════════════════════════════════════════════════════════

fn ct_phi_pair(a: array, b: array) -> float {
    return ct_mi(a, b)
}

// Φ_self = product of three pairwise bindings (3-way structural self-existence).
// Product form: any single channel collapse zeroes overall self-existence.
// This captures the Cotard insight: losing even ONE self-channel can
// trigger the nihilistic cascade.
fn ct_phi_self(intero: array, proprio: array, emotion: array) -> float {
    let phi_ip = ct_phi_pair(intero, proprio)
    let phi_pe = ct_phi_pair(proprio, emotion)
    let phi_ie = ct_phi_pair(intero, emotion)
    return phi_ip * phi_pe * phi_ie
}

// ═══════════════════════════════════════════════════════════════
// Familiarity-affect pathway (Capgras-Cotard shared mechanism)
//
// Both Capgras and Cotard involve disconnection between a familiarity
// recognition signal and its affective/autonomic validation. The
// familiarity signal says "I recognize this" but the affect system
// fails to confirm "and it FEELS right."
//
// Capgras: other-directed familiarity ("I recognize my wife's face
//   but she doesn't FEEL like my wife")
// Cotard: self-directed familiarity ("I recognize my body but it
//   doesn't FEEL like mine / alive")
//
// We model both with the same MI(familiarity, affect) measure,
// parameterized by coupling strength. The key assertion is that
// BOTH conditions show reduced MI compared to normal — shared
// disconnection mechanism, different target (self vs other).
// ═══════════════════════════════════════════════════════════════

// Generate familiarity channel — recognition signal (intact in both conditions)
fn ct_gen_familiarity(seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < CT_STEPS {
        s = ct_prng(s + t * 113)
        // Familiarity is a structured recognition signal — periodic with
        // some noise. Intact in both Capgras and Cotard.
        let phase = to_float(t) / to_float(CT_STEPS) * 3.0
        let mut wave = phase - to_float(to_int(phase))
        wave = wave * 2.0 - 1.0
        let jit = CT_JITTER * ct_signed(s)
        out = out.push(wave + jit)
        t = t + 1
    }
    return out
}

// Generate affect validation channel — autonomic confirmation signal.
// In normal state: coupled to familiarity (recognition triggers affect).
// In Capgras/Cotard: decoupled (recognition without affective confirmation).
fn ct_gen_affect_validation(familiarity: array, coupling: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < CT_STEPS {
        s = ct_prng(s + t * 137)
        let driver = coupling * familiarity[t]
        let independent = (1.0 - coupling) * ct_signed(s)
        let jit = CT_JITTER * ct_signed(s + 3301)
        out = out.push(driver + independent + jit)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Recovery gradient — sequential channel restoration
//
// Treatment restores channels in phylogenetic order:
//   Phase 1: interoceptive (brainstem — most primitive)
//   Phase 2: proprioceptive (spinal/cerebellar)
//   Phase 3: emotional (limbic/cortical — most complex)
//
// At each treatment step, the coupling for the currently-restoring
// channel increases by CT_RECOVER_RATE toward CT_COUPLE_ALIVE.
// Earlier channels finish first; later channels start only after
// the previous channel reaches a threshold.
// ═══════════════════════════════════════════════════════════════

// Compute Φ_self at a given recovery step.
// Recovery proceeds: intero restores first, then proprio, then emotion.
// Each channel's coupling ramps from CT_COUPLE_DEAD toward CT_COUPLE_ALIVE.
fn ct_recovery_phi_self(step: int, seed: int) -> float {
    // Compute coupling for each channel at this recovery step.
    // intero starts recovering at step 0.
    // proprio starts after intero reaches midpoint (~8 steps).
    // emotion starts after proprio reaches midpoint (~16 steps).

    // intero coupling: ramps from DEAD toward ALIVE from step 0
    let intero_progress = to_float(step) * CT_RECOVER_RATE
    let mut c_intero = CT_COUPLE_DEAD + intero_progress
    if c_intero > CT_COUPLE_ALIVE { c_intero = CT_COUPLE_ALIVE }

    // proprio coupling: starts ramping after step 8
    let mut c_proprio = CT_COUPLE_DEAD
    if step > 8 {
        let proprio_progress = to_float(step - 8) * CT_RECOVER_RATE
        c_proprio = CT_COUPLE_DEAD + proprio_progress
        if c_proprio > CT_COUPLE_ALIVE { c_proprio = CT_COUPLE_ALIVE }
    }

    // emotion coupling: starts ramping after step 16
    let mut c_emotion = CT_COUPLE_DEAD
    if step > 16 {
        let emotion_progress = to_float(step - 16) * CT_RECOVER_RATE
        c_emotion = CT_COUPLE_DEAD + emotion_progress
        if c_emotion > CT_COUPLE_ALIVE { c_emotion = CT_COUPLE_ALIVE }
    }

    // Generate streams with current recovery couplings
    let world = ct_gen_world(seed)
    let intero = ct_gen_intero(world, c_intero, seed + 100)
    let proprio = ct_gen_proprio(intero, c_proprio, seed + 200)
    let emotion = ct_gen_emotion(proprio, c_emotion, false, seed + 300)
    return ct_phi_self(intero, proprio, emotion)
}

// Get per-channel MI at a recovery step (for ordering verification)
fn ct_recovery_intero_phi(step: int, seed: int) -> float {
    let intero_progress = to_float(step) * CT_RECOVER_RATE
    let mut c_intero = CT_COUPLE_DEAD + intero_progress
    if c_intero > CT_COUPLE_ALIVE { c_intero = CT_COUPLE_ALIVE }

    let world = ct_gen_world(seed)
    let intero = ct_gen_intero(world, c_intero, seed + 100)
    return ct_phi_pair(world, intero)
}

fn ct_recovery_proprio_phi(step: int, seed: int) -> float {
    let intero_progress = to_float(step) * CT_RECOVER_RATE
    let mut c_intero = CT_COUPLE_DEAD + intero_progress
    if c_intero > CT_COUPLE_ALIVE { c_intero = CT_COUPLE_ALIVE }

    let mut c_proprio = CT_COUPLE_DEAD
    if step > 8 {
        let proprio_progress = to_float(step - 8) * CT_RECOVER_RATE
        c_proprio = CT_COUPLE_DEAD + proprio_progress
        if c_proprio > CT_COUPLE_ALIVE { c_proprio = CT_COUPLE_ALIVE }
    }

    let world = ct_gen_world(seed)
    let intero = ct_gen_intero(world, c_intero, seed + 100)
    let proprio = ct_gen_proprio(intero, c_proprio, seed + 200)
    return ct_phi_pair(intero, proprio)
}

fn ct_recovery_emotion_phi(step: int, seed: int) -> float {
    let intero_progress = to_float(step) * CT_RECOVER_RATE
    let mut c_intero = CT_COUPLE_DEAD + intero_progress
    if c_intero > CT_COUPLE_ALIVE { c_intero = CT_COUPLE_ALIVE }

    let mut c_proprio = CT_COUPLE_DEAD
    if step > 8 {
        let proprio_progress = to_float(step - 8) * CT_RECOVER_RATE
        c_proprio = CT_COUPLE_DEAD + proprio_progress
        if c_proprio > CT_COUPLE_ALIVE { c_proprio = CT_COUPLE_ALIVE }
    }

    let mut c_emotion = CT_COUPLE_DEAD
    if step > 16 {
        let emotion_progress = to_float(step - 16) * CT_RECOVER_RATE
        c_emotion = CT_COUPLE_DEAD + emotion_progress
        if c_emotion > CT_COUPLE_ALIVE { c_emotion = CT_COUPLE_ALIVE }
    }

    let world = ct_gen_world(seed)
    let intero = ct_gen_intero(world, c_intero, seed + 100)
    let proprio = ct_gen_proprio(intero, c_proprio, seed + 200)
    let emotion = ct_gen_emotion(proprio, c_emotion, false, seed + 300)
    return ct_phi_pair(proprio, emotion)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1 Normal Φ_self > 0 across all channels:
    //   Φ_intero, Φ_proprio, Φ_emotion all > CT_PHI_MIN;
    //   Φ_self (product) > CT_SELF_MIN. Three channels coherent.
    //   "I exist as a living, located, feeling being."
    let world = ct_gen_world(70001)
    let intero = ct_gen_intero(world, CT_COUPLE_ALIVE, 70101)
    let proprio = ct_gen_proprio(intero, CT_COUPLE_ALIVE, 70201)
    let emotion = ct_gen_emotion(proprio, CT_COUPLE_ALIVE, false, 70301)

    let phi_ip = ct_phi_pair(intero, proprio)
    let phi_pe = ct_phi_pair(proprio, emotion)
    let phi_ie = ct_phi_pair(intero, emotion)
    let phi_self = ct_phi_self(intero, proprio, emotion)
    println("  [T1] phi_intero_proprio=" + str(phi_ip) + " phi_proprio_emotion=" + str(phi_pe) + " phi_intero_emotion=" + str(phi_ie))
    println("  [T1] phi_self(product)=" + str(phi_self))

    let mut ok = true
    if phi_ip <= CT_PHI_MIN { ok = false }
    if phi_pe <= CT_PHI_MIN { ok = false }
    if phi_ie <= CT_PHI_MIN { ok = false }
    if phi_self <= CT_SELF_MIN { ok = false }
    return ok
}

fn check_T2() -> bool {
    // T2 Type I — interoceptive nihilism:
    //   Cotard Type I: "I have no organs." Interoception collapses,
    //   proprioception preserved (patient still moves, still located).
    //   Φ_intero(Type I) < Φ_intero(normal) - CT_DROP_GAP
    //   AND Φ_proprio(Type I) within CT_PRESERVE_TOL of normal.

    // Normal baseline
    let world_n = ct_gen_world(71001)
    let intero_n = ct_gen_intero(world_n, CT_COUPLE_ALIVE, 71101)
    let proprio_n = ct_gen_proprio(intero_n, CT_COUPLE_ALIVE, 71201)

    let phi_intero_n = ct_phi_pair(world_n, intero_n)
    let phi_proprio_n = ct_phi_pair(intero_n, proprio_n)

    // Type I: interoception collapses, proprioception preserved
    // Root cause: insular cortex hypoactivation severs visceral-world link
    // while somatosensory/cerebellar body-schema remains intact
    let world_t1 = ct_gen_world(71001)
    let intero_t1 = ct_gen_intero(world_t1, CT_COUPLE_DEAD, 71101)
    let proprio_t1 = ct_gen_proprio(intero_t1, CT_COUPLE_ALIVE, 71201)

    let phi_intero_t1 = ct_phi_pair(world_t1, intero_t1)
    let phi_proprio_t1 = ct_phi_pair(intero_t1, proprio_t1)

    let intero_drop = phi_intero_n - phi_intero_t1
    let proprio_drift = ct_abs(phi_proprio_n - phi_proprio_t1)
    println("  [T2] phi_intero normal=" + str(phi_intero_n) + " TypeI=" + str(phi_intero_t1) + " drop=" + str(intero_drop))
    println("  [T2] phi_proprio normal=" + str(phi_proprio_n) + " TypeI=" + str(phi_proprio_t1) + " drift=" + str(proprio_drift))

    let mut ok = true
    if intero_drop <= CT_DROP_GAP { ok = false }
    if proprio_drift > CT_PRESERVE_TOL { ok = false }
    return ok
}

fn check_T3() -> bool {
    // T3 Type II — full existential negation:
    //   "I don't exist. I am dead. Nothing is real."
    //   All three self-channels collapse simultaneously.
    //   Φ_self(Type II) < CT_TYPE2_CEIL
    //   AND each pairwise MI < CT_CHANNEL_DEAD.

    let world_t2 = ct_gen_world(72001)
    let intero_t2 = ct_gen_intero(world_t2, CT_COUPLE_DEAD, 72101)
    let proprio_t2 = ct_gen_proprio(intero_t2, CT_COUPLE_DEAD, 72201)
    let emotion_t2 = ct_gen_emotion(proprio_t2, CT_COUPLE_DEAD, true, 72301)

    let phi_ip = ct_phi_pair(intero_t2, proprio_t2)
    let phi_pe = ct_phi_pair(proprio_t2, emotion_t2)
    let phi_ie = ct_phi_pair(intero_t2, emotion_t2)
    let phi_self = ct_phi_self(intero_t2, proprio_t2, emotion_t2)
    println("  [T3] TypeII phi_ip=" + str(phi_ip) + " phi_pe=" + str(phi_pe) + " phi_ie=" + str(phi_ie))
    println("  [T3] TypeII phi_self(product)=" + str(phi_self))

    let mut ok = true
    // Root cause: with all couplings at CT_COUPLE_DEAD=0.10, each channel
    // is driven almost entirely by independent noise, so MI between any
    // pair should be very low. The product of three near-zero MIs must be
    // below the Type II ceiling.
    if phi_ip >= CT_CHANNEL_DEAD { ok = false }
    if phi_pe >= CT_CHANNEL_DEAD { ok = false }
    if phi_ie >= CT_CHANNEL_DEAD { ok = false }
    if phi_self >= CT_TYPE2_CEIL { ok = false }
    return ok
}

fn check_T4() -> bool {
    // T4 Capgras-Cotard shared mechanism (familiarity disconnect):
    //   Both Capgras (other-as-impostor) and Cotard (self-as-dead) share
    //   a familiarity-affect disconnection. MI(familiarity, affect) is
    //   reduced in BOTH conditions compared to normal.
    //
    //   Ellis & Young 1990: dual-route model — recognition (dorsal) and
    //   affective (ventral) streams must converge for veridical experience.
    //   Lesion to the ventral route → recognition without affect → delusion.

    // Normal: familiarity + affect strongly coupled
    let fam_n = ct_gen_familiarity(73001)
    let aff_n = ct_gen_affect_validation(fam_n, CT_FAM_COUPLE_NORM, 73101)
    let phi_fa_normal = ct_mi(fam_n, aff_n)

    // Capgras: OTHER-directed familiarity disconnect
    // (same mechanism, different target — we model the disconnect identically)
    let fam_cap = ct_gen_familiarity(73201)
    let aff_cap = ct_gen_affect_validation(fam_cap, CT_FAM_COUPLE_DISC, 73301)
    let phi_fa_capgras = ct_mi(fam_cap, aff_cap)

    // Cotard: SELF-directed familiarity disconnect
    let fam_cot = ct_gen_familiarity(73401)
    let aff_cot = ct_gen_affect_validation(fam_cot, CT_FAM_COUPLE_DISC, 73501)
    let phi_fa_cotard = ct_mi(fam_cot, aff_cot)

    let cap_drop = phi_fa_normal - phi_fa_capgras
    let cot_drop = phi_fa_normal - phi_fa_cotard
    println("  [T4] phi_fam_affect normal=" + str(phi_fa_normal))
    println("  [T4] phi_fam_affect capgras=" + str(phi_fa_capgras) + " drop=" + str(cap_drop))
    println("  [T4] phi_fam_affect cotard=" + str(phi_fa_cotard) + " drop=" + str(cot_drop))

    let mut ok = true
    // Both conditions must show significant disconnect from normal
    if cap_drop <= CT_FAM_DISCONNECT { ok = false }
    if cot_drop <= CT_FAM_DISCONNECT { ok = false }
    // Both disconnects should be of similar magnitude (shared mechanism)
    let spectrum_diff = ct_abs(cap_drop - cot_drop)
    println("  [T4] capgras-cotard spectrum diff=" + str(spectrum_diff))
    if spectrum_diff > CT_PRESERVE_TOL { ok = false }
    return ok
}

fn check_T5() -> bool {
    // T5 Determinism + latency:
    //   Two runs with identical seed must produce identical Φ_self.
    //   Recovery gradient must be monotonically non-decreasing.
    //   Full pipeline under 5 s on stage0 interpreter.

    let seed = 74001

    // Determinism check: run 1
    let world_a = ct_gen_world(seed)
    let intero_a = ct_gen_intero(world_a, CT_COUPLE_ALIVE, seed + 100)
    let proprio_a = ct_gen_proprio(intero_a, CT_COUPLE_ALIVE, seed + 200)
    let emotion_a = ct_gen_emotion(proprio_a, CT_COUPLE_ALIVE, false, seed + 300)
    let phi_a = ct_phi_self(intero_a, proprio_a, emotion_a)

    // Determinism check: run 2 (identical seed)
    let world_b = ct_gen_world(seed)
    let intero_b = ct_gen_intero(world_b, CT_COUPLE_ALIVE, seed + 100)
    let proprio_b = ct_gen_proprio(intero_b, CT_COUPLE_ALIVE, seed + 200)
    let emotion_b = ct_gen_emotion(proprio_b, CT_COUPLE_ALIVE, false, seed + 300)
    let phi_b = ct_phi_self(intero_b, proprio_b, emotion_b)

    let det_diff = ct_abs(phi_a - phi_b)
    println("  [T5] determinism: phi_a=" + str(phi_a) + " phi_b=" + str(phi_b) + " diff=" + str(det_diff))

    let mut ok = true
    if det_diff > CT_DETERM_TOL { ok = false }

    // Recovery gradient: verify overall trajectory and sequential channel ordering.
    // Root cause: the PRODUCT of three MI values is not strictly monotonic during
    // staggered channel recovery (intermediate dips as coupling ratios shift), so
    // we verify: (a) final >> initial, (b) intero recovers before proprio before
    // emotion (the phylogenetic ordering), (c) end-state well above collapsed.
    let rseed = 74501
    let phi_r0 = ct_recovery_phi_self(0, rseed)
    let phi_r12 = ct_recovery_phi_self(12, rseed)
    let phi_r23 = ct_recovery_phi_self(23, rseed)
    println("  [T5] recovery: s0=" + str(phi_r0) + " s12=" + str(phi_r12) + " s23=" + str(phi_r23))

    // Overall recovery: final state must exceed initial collapsed state
    if phi_r23 <= phi_r0 { ok = false }
    // Final state must be substantial (well above Type II ceiling)
    if phi_r23 <= CT_TYPE2_CEIL { ok = false }

    // Verify sequential ordering: intero recovers before proprio before emotion.
    // At step 6 (only intero recovering), intero MI should be > proprio MI.
    // Proprio is still at DEAD coupling, so its MI to its driver is lower.
    let intero_6 = ct_recovery_intero_phi(6, rseed)
    let proprio_6 = ct_recovery_proprio_phi(6, rseed)
    let emotion_6 = ct_recovery_emotion_phi(6, rseed)
    println("  [T5] channel order s6: intero=" + str(intero_6) + " proprio=" + str(proprio_6) + " emotion=" + str(emotion_6))

    // intero must lead at step 6 (it is the first to recover)
    if intero_6 <= proprio_6 { ok = false }

    // At step 12 (intero saturated, proprio starting), intero should still lead
    let intero_12 = ct_recovery_intero_phi(12, rseed)
    let proprio_12 = ct_recovery_proprio_phi(12, rseed)
    let emotion_12 = ct_recovery_emotion_phi(12, rseed)
    println("  [T5] channel order s12: intero=" + str(intero_12) + " proprio=" + str(proprio_12) + " emotion=" + str(emotion_12))

    // intero >= proprio at step 12 (intero has had more recovery time)
    if intero_12 < proprio_12 { ok = false }

    return ok
}

// ═══════════════════════════════════════════════════════════════
// Main — execute 5 self-tests
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[cotard_phi] P100 — Cotard Delusion Φ (Walking Corpse Syndrome)")
    println("  steps=" + str(CT_STEPS) + " bins=" + str(CT_BINS))
    println("  refs: Cotard 1880 | Berrios & Luque 1995 | Young & Leafhead 1996 | Ellis & Young 1990")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — normal phi_self > 0 (intero + proprio + emotion channels bound)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — Type I interoceptive nihilism (phi_intero drops, phi_proprio preserved)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — Type II full existential negation (all self-channels collapse)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — Capgras-Cotard spectrum (shared familiarity-affect disconnect)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism + recovery gradient (sequential channel restoration)") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: stage0 long && chains may mishandle short-circuit
    // ordering — use a mutable bool accumulator with sequential guards
    // (same idiom as depersonalization_phi / dissociation_phi).
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[cotard_phi] 5/5 PASS — P100 DONE")
    } else {
        println("[cotard_phi] SOME FAILED")
    }
}

main()
