// suffering_arrows_phi.hexa — P85 Suffering vs Pain (Second Arrow Φ)
//
// Roadmap: P85 "Buddhist two-arrows teaching — first arrow (physical
//          pain) is unavoidable; second arrow (suffering, resistance,
//          rumination, story-making) is the Φ of meta-pain. Equanimity
//          training attenuates the second arrow while the first is
//          unchanged."
// Parallel reference: jhana_meditation_phi.hexa (P62), interoception_phi.hexa (P56),
//                     placebo_phi.hexa (P58).
//
// ─── Scriptural basis ────────────────────────────────────────────
//
// Sallatha Sutta (SN 36.6, "The Arrow"):
//
//   "Bhikkhus, when the uninstructed worldling is touched by a
//    painful (bodily) feeling, he sorrows, grieves and laments,
//    weeps beating his breast and becomes distraught. So he feels
//    two pains, physical and mental. Just as if a man were pierced
//    by an arrow and, following the first piercing, he were hit by
//    a second arrow."
//
//   "But the well-instructed noble disciple, when touched by a
//    painful feeling, will not worry nor grieve and lament, will
//    not weep beating his breast nor become distraught. He feels
//    one pain — bodily, but not mental."
//
// Modern operationalization (Williams & Penman 2011, "Mindfulness";
// Garland et al. 2017 "Mindfulness-Oriented Recovery Enhancement"):
//
//   First arrow  = bare nociceptive afferent — sensory cortex S1/S2 +
//                  insula (sensory component of the pain matrix).
//   Second arrow = aversive reaction, rumination, catastrophizing,
//                  identity-fusion ("I am suffering") — ACC + dlPFC
//                  appraisal + DMN narrative loop.
//
// Equanimity (upekkhā) training (vipassanā, MBSR, MBCT) selectively
// attenuates the second-arrow circuitry while leaving first-arrow
// signal intact — replicated in fMRI studies of long-term meditators
// (Grant et al. 2010; Lutz et al. 2013).
//
// ─── Φ model ─────────────────────────────────────────────────────
//
//   Φ_first  = nociceptive_intensity · sensory_coupling
//   Φ_second = (reaction + resistance + rumination + identification)
//              · narrative_coupling · amplification
//   Φ_total  = Φ_first + Φ_second
//
// "amplification" is the trainable parameter:
//   - untrained / catastrophizing : amp ≈ 2.0 – 3.0
//   - normal baseline             : amp ≈ 1.0
//   - mindfulness practitioner    : amp ≈ 0.4 – 0.6
//   - deep equanimity (J4-grade)  : amp → 0
//
// The "stuck loop" of chronic pain corresponds to a self-sustaining
// second-arrow that no longer requires fresh first-arrow input —
// the rumination + identification feedback exceeds the gate even
// when nociceptive signal drops to baseline. This is the Φ-signature
// of central sensitization / nociplastic pain.
//
// ─── Theorems (T1–T5) ────────────────────────────────────────────
//
// T1 (two arrows present in untrained subject under noxious input):
//   Φ_first > 0 AND Φ_second > 0 AND Φ_second ≥ Φ_first × 0.5
//   for an untrained subject receiving moderate nociceptive input.
//
// T2 (equanimity preserves first arrow, drops second arrow):
//   Under equanimity mode (amp → 0), Φ_first is unchanged within ε,
//   Φ_second drops below a small fraction of its untrained value,
//   and Φ_total drops by a substantial margin. Physical pain remains
//   detectable (the body still hurts) but suffering is gone.
//
// T3 (rumination raises second arrow without adding first):
//   When rumination factor is increased, Φ_first stays constant
//   while Φ_second rises strictly. This isolates the second-arrow
//   channel and shows it is a distinct dimension.
//
// T4 (chronic pain = stuck second arrow loop with low first arrow):
//   With low/baseline nociceptive input but high rumination +
//   identification + amplification (sensitized state), Φ_second
//   alone exceeds the chronic-suffering gate while Φ_first is small.
//   This reproduces nociplastic / central-sensitization phenotype.
//
// T5 (determinism + latency + perturbation stability):
//   Same inputs → bit-identical outputs. Pipeline < 1 s.
//   Small noise on nociceptive input leaves Φ_total within 3·eps.
//
// ─── Stage0 hexa constraints honored ────────────────────────────
//   - plain `fn` only (no pure-fn multi-float struct returns)
//   - `array` typed params (no [float])
//   - no match with identifier patterns (if-chains)
//   - no contains() / to_lower()
//   - no !(Effect) annotations
//   - no else-if in let-binding
//   - no multi-line fn signatures / call sites / array literals
//   - main() call at bottom
//   - N < 32

// ═══════════════════════════════════════════════════════════════
// Constants — channel weights and gates
// ═══════════════════════════════════════════════════════════════

// Mode codes (untrained → equanimous)
let SA_MODE_UNTRAINED = 1     // catastrophizing — high amplification
let SA_MODE_NORMAL    = 2     // ordinary baseline reactivity
let SA_MODE_TRAINED   = 3     // mindfulness practitioner
let SA_MODE_EQUANIMOUS = 4    // deep equanimity (J4-grade) — amp ≈ 0

// Amplification factors per mode
// Root cause comment: amplification is the trainable parameter; it
// multiplies the second-arrow channel ONLY. First arrow is invariant.
let SA_AMP_UNTRAINED  = 2.50
let SA_AMP_NORMAL     = 1.00
let SA_AMP_TRAINED    = 0.50
let SA_AMP_EQUANIMOUS = 0.05      // not exactly zero — some residual reactivity

// Sensory coupling (S1/S2 + insula) — first arrow integration
let SA_SENSORY_COUPLING = 0.85

// Narrative coupling (ACC + dlPFC + DMN) — second arrow integration
let SA_NARRATIVE_COUPLING = 0.90

// Channel weights inside the second-arrow vector
//   slot 0 = reaction        (immediate aversion)
//   slot 1 = resistance      (push-away effort)
//   slot 2 = rumination      (repetitive thought loop)
//   slot 3 = identification  ("I am the one suffering")
let SA_W_REACTION       = 1.10
let SA_W_RESISTANCE     = 1.20
let SA_W_RUMINATION     = 1.30
let SA_W_IDENTIFICATION = 1.40

// Gates for tests
let SA_T1_RATIO_GATE       = 0.50   // Φ_second / Φ_first must be ≥ this for untrained
let SA_T2_FIRST_PRESERVE   = 0.05   // equanimity must preserve Φ_first within this delta
let SA_T2_SECOND_DROP      = 0.20   // equanimity: Φ_second_eq / Φ_second_untrained ≤ this
let SA_T2_TOTAL_DROP_GATE  = 0.40   // equanimity: Φ_total_eq / Φ_total_untrained ≤ this
let SA_T3_RUMI_GATE        = 0.10   // each rumination step must raise Φ_second by ≥ this
let SA_T4_CHRONIC_GATE     = 1.20   // Φ_second alone must exceed this in chronic phenotype
let SA_T4_FIRST_SMALL_GATE = 0.30   // Φ_first must stay below this in chronic phenotype
let SA_LATENCY_MS          = 1000.0
let SA_STABILITY_MAG       = 0.05
let SA_STABILITY_GATE      = 0.30   // 3 · (sum_of_weights · mag · couplings)

let SA_EPS = 0.0000000001

// ═══════════════════════════════════════════════════════════════
// Primitives
// ═══════════════════════════════════════════════════════════════

fn sa_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sa_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn sa_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

// Deterministic small-magnitude perturbation in [-mag, mag]
fn sa_perturb(seed: int, mag: float) -> float {
    let u = sa_unit(sa_prng(seed))
    return (u * 2.0 - 1.0) * mag
}

// Mode → amplification lookup (no match with identifiers — if-chain)
fn sa_amp_for_mode(mode: int) -> float {
    if mode == SA_MODE_UNTRAINED { return SA_AMP_UNTRAINED }
    if mode == SA_MODE_NORMAL { return SA_AMP_NORMAL }
    if mode == SA_MODE_TRAINED { return SA_AMP_TRAINED }
    if mode == SA_MODE_EQUANIMOUS { return SA_AMP_EQUANIMOUS }
    return SA_AMP_NORMAL
}

// ═══════════════════════════════════════════════════════════════
// Second-arrow factor vector constructors (4 slots)
// ═══════════════════════════════════════════════════════════════
//
// Layout: [reaction, resistance, rumination, identification]
//
// Root cause comment: flat 4-slot array used because stage0 hexa
// prefers array over struct for hot-path numeric work
// (struct-list aliasing bug — feedback_hexa_struct_list_alias.md).

// Untrained subject's reactive profile under moderate noxious input
fn sa_second_factors_untrained() -> array {
    // Worldling response (Sallatha Sutta) — full reactive cascade.
    // Reaction + resistance fire immediately; rumination + identity
    // fusion build over seconds-to-minutes.
    let mut f = []
    f = f.push(0.85)   // reaction:        strong aversive jerk
    f = f.push(0.80)   // resistance:      pushing the pain away
    f = f.push(0.75)   // rumination:      "why me, when will it end"
    f = f.push(0.70)   // identification:  "I am hurt, I am suffering"
    return f
}

// Equanimous subject's profile under same noxious input — factors
// remain SLIGHTLY non-zero (residual reactivity), but amplification
// in sa_phi_second drives the multiplied total to near zero.
fn sa_second_factors_equanimous() -> array {
    // Noble disciple (Sallatha Sutta) — the body is touched, but
    // the mind does not pile a second arrow on top.
    let mut f = []
    f = f.push(0.20)
    f = f.push(0.15)
    f = f.push(0.10)
    f = f.push(0.05)
    return f
}

// Custom factor vector for rumination titration in T3
fn sa_second_factors_titrated(rumi_level: float, ident_level: float) -> array {
    let mut f = []
    f = f.push(0.30)        // baseline reaction
    f = f.push(0.30)        // baseline resistance
    f = f.push(rumi_level)  // titrated rumination
    f = f.push(ident_level) // titrated identification
    return f
}

// ═══════════════════════════════════════════════════════════════
// Φ computation — first arrow and second arrow
// ═══════════════════════════════════════════════════════════════

// First arrow: bare nociceptive signal × sensory coupling.
// This channel does NOT depend on mode — physical pain is mode-invariant.
//
// Root cause comment: Φ_first is the IIT-style integrated signal
// over the sensory pain matrix (S1/S2/insula). It is what survives
// equanimity training — the body still hurts.
fn sa_phi_first(nociceptive: float) -> float {
    return nociceptive * SA_SENSORY_COUPLING
}

// Sum of weighted second-arrow factors (pre-amplification)
fn sa_second_factor_sum(f: array) -> float {
    let r = f[0] * SA_W_REACTION
    let s = f[1] * SA_W_RESISTANCE
    let m = f[2] * SA_W_RUMINATION
    let i = f[3] * SA_W_IDENTIFICATION
    return r + s + m + i
}

// Second arrow: weighted factor sum × narrative coupling × amplification
//
// Root cause comment: amplification is the ONLY trainable knob in the
// model; it captures the meta-cognitive stance toward the first arrow.
// At amp = 0 the entire suffering channel collapses — this is the
// equanimity invariant.
fn sa_phi_second(f: array, amp: float) -> float {
    let sum = sa_second_factor_sum(f)
    return sum * SA_NARRATIVE_COUPLING * amp
}

// Total suffering Φ
fn sa_phi_total(nociceptive: float, f: array, amp: float) -> float {
    let p1 = sa_phi_first(nociceptive)
    let p2 = sa_phi_second(f, amp)
    return p1 + p2
}

// Perturbed total — apply small noise to nociceptive signal AND
// to each second-arrow slot, recompute Φ_total. Used by T5 to
// verify pipeline stability under input jitter.
fn sa_phi_total_perturbed(nociceptive: float, f_orig: array, amp: float, seed: int, mag: float) -> float {
    let s0 = sa_prng(seed)
    let n_noise = sa_perturb(s0, mag)
    let mut noci = nociceptive + n_noise
    if noci < 0.0 { noci = 0.0 }

    let mut f = []
    let mut i = 0
    let mut s = s0
    while i < 4 {
        s = sa_prng(s + i * 17)
        let noise = sa_perturb(s, mag)
        let mut v = f_orig[i] + noise
        if v < 0.0 { v = 0.0 }
        if v > 1.0 { v = 1.0 }
        f = f.push(v)
        i = i + 1
    }
    return sa_phi_total(noci, f, amp)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1–T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: untrained subject under moderate noxious input shows
    // BOTH arrows present, with Φ_second ≥ Φ_first × 0.5.
    //
    // Expected: nociceptive = 0.7 (moderate); untrained second-arrow
    // factors are high; amplification = 2.5. Both arrows fire and the
    // second arrow is comparable to or larger than the first.
    let noci = 0.7
    let f = sa_second_factors_untrained()
    let amp = sa_amp_for_mode(SA_MODE_UNTRAINED)

    let p1 = sa_phi_first(noci)
    let p2 = sa_phi_second(f, amp)
    let total = p1 + p2

    println("  [T1] untrained: noci=" + str(noci) + " Φ_first=" + str(p1))
    println("        Φ_second=" + str(p2) + " Φ_total=" + str(total))

    if p1 < SA_EPS { return false }
    if p2 < SA_EPS { return false }
    let ratio_floor = p1 * SA_T1_RATIO_GATE
    if p2 < ratio_floor { return false }
    return true
}

fn check_T2() -> bool {
    // T2: equanimity preserves first arrow, drops second arrow.
    //
    // Compare untrained vs equanimous mode under IDENTICAL nociceptive
    // input. Φ_first must be unchanged. Φ_second must drop to a small
    // fraction. Φ_total must drop substantially.
    //
    // Root cause comment: first arrow uses ONLY the nociceptive channel,
    // which is mode-independent. So Φ_first is bit-identical across modes
    // — this is the formal expression of "physical pain is unavoidable".
    let noci = 0.7

    let f_unt = sa_second_factors_untrained()
    let amp_unt = sa_amp_for_mode(SA_MODE_UNTRAINED)
    let p1_unt = sa_phi_first(noci)
    let p2_unt = sa_phi_second(f_unt, amp_unt)
    let total_unt = p1_unt + p2_unt

    let f_eq = sa_second_factors_equanimous()
    let amp_eq = sa_amp_for_mode(SA_MODE_EQUANIMOUS)
    let p1_eq = sa_phi_first(noci)
    let p2_eq = sa_phi_second(f_eq, amp_eq)
    let total_eq = p1_eq + p2_eq

    println("  [T2] untrained:  Φ_first=" + str(p1_unt) + " Φ_second=" + str(p2_unt) + " Φ_total=" + str(total_unt))
    println("        equanimous: Φ_first=" + str(p1_eq) + " Φ_second=" + str(p2_eq) + " Φ_total=" + str(total_eq))

    // (a) First arrow preserved within ε
    let first_delta = sa_abs(p1_eq - p1_unt)
    if first_delta > SA_T2_FIRST_PRESERVE { return false }

    // (b) Second arrow drops to fraction
    if p2_unt < SA_EPS { return false }
    let second_ratio = p2_eq / p2_unt
    println("        second_ratio=" + str(second_ratio) + " gate=" + str(SA_T2_SECOND_DROP))
    if second_ratio > SA_T2_SECOND_DROP { return false }

    // (c) Total drops substantially
    if total_unt < SA_EPS { return false }
    let total_ratio = total_eq / total_unt
    println("        total_ratio=" + str(total_ratio) + " gate=" + str(SA_T2_TOTAL_DROP_GATE))
    if total_ratio > SA_T2_TOTAL_DROP_GATE { return false }

    return true
}

fn check_T3() -> bool {
    // T3: rumination raises second arrow Φ without changing first arrow.
    //
    // Hold nociceptive constant. Sweep rumination factor across four
    // levels. Verify each step strictly raises Φ_second by ≥ T3 gate
    // AND Φ_first is invariant (bit-identical) across the sweep.
    let noci = 0.5
    let amp = sa_amp_for_mode(SA_MODE_NORMAL)

    let p1_base = sa_phi_first(noci)

    let f0 = sa_second_factors_titrated(0.10, 0.10)
    let f1 = sa_second_factors_titrated(0.30, 0.20)
    let f2 = sa_second_factors_titrated(0.55, 0.40)
    let f3 = sa_second_factors_titrated(0.85, 0.65)

    let p2_0 = sa_phi_second(f0, amp)
    let p2_1 = sa_phi_second(f1, amp)
    let p2_2 = sa_phi_second(f2, amp)
    let p2_3 = sa_phi_second(f3, amp)

    let p1_0 = sa_phi_first(noci)
    let p1_1 = sa_phi_first(noci)
    let p1_2 = sa_phi_first(noci)
    let p1_3 = sa_phi_first(noci)

    println("  [T3] rumination sweep — Φ_first(constant)=" + str(p1_base))
    println("        rumi=0.10 Φ_second=" + str(p2_0))
    println("        rumi=0.30 Φ_second=" + str(p2_1))
    println("        rumi=0.55 Φ_second=" + str(p2_2))
    println("        rumi=0.85 Φ_second=" + str(p2_3))

    // First arrow invariant
    if sa_abs(p1_0 - p1_base) > SA_EPS { return false }
    if sa_abs(p1_1 - p1_base) > SA_EPS { return false }
    if sa_abs(p1_2 - p1_base) > SA_EPS { return false }
    if sa_abs(p1_3 - p1_base) > SA_EPS { return false }

    // Second arrow strictly rising by gate
    if (p2_1 - p2_0) < SA_T3_RUMI_GATE { return false }
    if (p2_2 - p2_1) < SA_T3_RUMI_GATE { return false }
    if (p2_3 - p2_2) < SA_T3_RUMI_GATE { return false }

    return true
}

fn check_T4() -> bool {
    // T4: chronic pain phenotype = stuck second-arrow loop with low first arrow.
    //
    // Sensitized / nociplastic state — peripheral nociceptive input is
    // small (the body has minimal acute injury) but rumination,
    // identification, and amplification are HIGH (catastrophizing
    // entrenched). Φ_second alone must exceed the chronic gate while
    // Φ_first stays below the small-arrow gate. This isolates the
    // "central sensitization" Φ-signature.
    //
    // Root cause comment: this is the formal expression of why chronic
    // pain patients still suffer when nociceptors quiet down — the
    // suffering channel has become self-sustaining via the narrative
    // coupling (DMN loop), independent of fresh first-arrow input.
    let noci = 0.20                               // small (background)
    let f = sa_second_factors_titrated(0.95, 0.90) // very high rumination + identification
    let amp = sa_amp_for_mode(SA_MODE_UNTRAINED)   // catastrophizing amplification

    let p1 = sa_phi_first(noci)
    let p2 = sa_phi_second(f, amp)
    let total = p1 + p2

    println("  [T4] chronic phenotype: Φ_first=" + str(p1))
    println("        Φ_second=" + str(p2) + " Φ_total=" + str(total))
    println("        first-small gate=" + str(SA_T4_FIRST_SMALL_GATE) + " chronic gate=" + str(SA_T4_CHRONIC_GATE))

    if p1 >= SA_T4_FIRST_SMALL_GATE { return false }
    if p2 < SA_T4_CHRONIC_GATE { return false }
    // Total should be dominated by the second arrow
    if p2 < (p1 * 2.0) { return false }
    return true
}

fn check_T5() -> bool {
    // T5: determinism + latency + perturbation stability.
    //
    // (a) Two calls with identical inputs return bit-identical Φ_total.
    // (b) Pipeline (full sweep across modes + perturbation seeds) < 1 s.
    // (c) Small noise on nociceptive input + factor slots leaves
    //     Φ_total within SA_STABILITY_GATE of nominal across 8 seeds.
    let t0 = clock()

    let noci = 0.6
    let f = sa_second_factors_untrained()
    let amp = sa_amp_for_mode(SA_MODE_NORMAL)

    let total_nominal = sa_phi_total(noci, f, amp)

    // Determinism — two consecutive calls
    let a = sa_phi_total(noci, f, amp)
    let b = sa_phi_total(noci, f, amp)
    if sa_abs(a - b) > 0.0 { return false }

    // Perturbation sweep across 8 seeds
    let mut max_dev = 0.0
    let mut i = 0
    while i < 8 {
        let p = sa_phi_total_perturbed(noci, f, amp, 4200 + i * 137, SA_STABILITY_MAG)
        let dev = sa_abs(p - total_nominal)
        if dev > max_dev { max_dev = dev }
        i = i + 1
    }

    // Exercise full mode sweep for latency realism
    let mut accum = 0.0
    accum = accum + sa_phi_total(noci, f, sa_amp_for_mode(SA_MODE_UNTRAINED))
    accum = accum + sa_phi_total(noci, f, sa_amp_for_mode(SA_MODE_NORMAL))
    accum = accum + sa_phi_total(noci, f, sa_amp_for_mode(SA_MODE_TRAINED))
    accum = accum + sa_phi_total(noci, f, sa_amp_for_mode(SA_MODE_EQUANIMOUS))

    let t1 = clock()
    let ms = (t1 - t0) * 1000.0

    println("  [T5] nominal Φ_total=" + str(total_nominal))
    println("        max_perturbed_dev=" + str(max_dev) + " gate=" + str(SA_STABILITY_GATE))
    println("        sweep accum=" + str(accum) + " pipeline=" + str(ms) + " ms")

    if max_dev > SA_STABILITY_GATE { return false }
    if ms >= SA_LATENCY_MS { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[suffering_arrows_phi] P85 — Suffering vs Pain (Second Arrow Φ)")
    println("  source: Sallatha Sutta SN 36.6 + Williams/Penman 2011 + Lutz et al. 2013")
    println("  arrows: first(nociceptive) + second(reaction+resistance+rumination+identification)")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — both arrows present in untrained subject") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — equanimity preserves first arrow, drops second") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — rumination raises second arrow without changing first") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — chronic pain = stuck second-arrow loop") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — determinism + latency + stability") } else { println("T5 FAIL") }

    println("")

    // Root cause comment: hexa stage0 can mishandle chained && over 5 terms.
    // Use sequential flag check instead.
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[suffering_arrows_phi] 5/5 PASS — P85 DONE (Sallatha Sutta two arrows)")
    } else {
        println("[suffering_arrows_phi] SOME FAILED")
    }
}

main()
