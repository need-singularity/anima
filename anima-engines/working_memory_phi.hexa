// working_memory_phi.hexa — P116 Working Memory Φ
//
// Roadmap: shared/roadmaps/anima.json P116
//   depends_on: P92 (attention_phi — selective attention gate),
//               P93 (memory_consolidation_phi — HPC/CTX stores),
//               P52 (memory_palace_phi — bind-and-recall substrate).
//   done_criteria: 5/5 self-test PASS — capacity limit (7±2), chunking,
//     rehearsal refresh, similarity interference, Φ_WM gradient.
//
// ─── Scientific frame ──────────────────────────────────────────────
//
// Working Memory (Baddeley & Hitch 1974; Baddeley 2000) is the
// fixed-capacity workspace that holds active representations for
// ongoing cognition. It differs from long-term memory in three
// dimensions:
//
//   1. CAPACITY (Miller 1956 "7±2"):
//      The magical number of chunks simultaneously maintainable is
//      small and hard-bounded. Cowan (2001) refined this downward to
//      4±1 for "focus of attention"; we encode the classical 7±2 for
//      rehearsed slot capacity. Once the buffer saturates (items >= 9),
//      each additional item displaces an earlier one — "displacement
//      from rehearsal loop."
//
//   2. TIME (Peterson & Peterson 1959):
//      In absence of rehearsal, traces decay with a ~20s half-life.
//      Rehearsal (phonological loop, Baddeley 1986) refreshes traces
//      and prevents decay. Rehearsed items survive; unrehearsed fade.
//
//   3. CONTENT-ADDRESSABILITY (Conrad 1964 phonological confusion;
//      Baddeley 1966 similarity effect):
//      Phonologically similar items (B, C, D, G, T, V) interfere
//      catastrophically; phonologically dissimilar items (F, J, L, M,
//      Q, R) interfere little. This points to a similarity-based
//      overwrite rule in the rehearsal loop, not a purely slot-based
//      storage.
//
// ─── Baddeley multi-component model ────────────────────────────────
//
// Baddeley & Hitch 1974 separate WM into subsystems; we model two:
//
//   phonological loop  — verbal/auditory rehearsal buffer (2s ceiling)
//   central executive  — attention/task-set controller (allocates
//                        rehearsal to items)
//
// We omit the visuospatial sketchpad and episodic buffer for this
// artifact — they are separate phenomenology and will be modelled in
// later phases (visuospatial in P-future, episodic buffer per P52).
//
// ─── Chunking (Miller 1956; Ericsson 1980) ────────────────────────
//
// "Chunks" are compressed units — groups of items bound by a shared
// structural key so that recall of the key unpacks all members. A
// 9-item list viewed as 3 chunks of 3 fits comfortably in the 7±2
// slot budget. Chess masters recall 25 pieces in chunks where novices
// can hold 7 — the capacity limit is in CHUNKS, not raw items.
//
// In our model:
//   chunked list  — items share chunk-ids; a single slot encodes a
//                   whole chunk via a shared phase/tag
//   random list   — 9 items each consume one slot; overflows force
//                   displacement
//
// Predicted Φ_chunked > Φ_random for the same surface item count.
//
// ─── Interference (Baddeley 1966; Conrad 1964) ─────────────────────
//
// Similarity-based interference — when two items in the buffer share
// acoustic/phonological features, their traces overlap and each
// corrupts the other. A list of phonologically similar items shows
// much worse recall than a list of phonologically dissimilar items,
// even with the same semantic content.
//
// We model phonological similarity as a small inter-item angular
// distance in feature space. Items too close pairwise overlap in
// their trace histograms → high joint entropy → low MI between
// stored and recalled set.
//
// ─── Model architecture ────────────────────────────────────────────
//
// WM is a fixed-capacity buffer of WM_CAPACITY slots. Each slot holds
// a structured trace (length WM_TRACE_LEN) representing the rehearsed
// signature of one item/chunk.
//
//   BUFFER[slot, t]  — slot signal at time t
//   RECALL[slot, t]  — reconstructed signal at recall time
//
// Φ_WM = mean over occupied slots of MI(BUFFER[s], RECALL[s]).
//
// Mechanisms:
//   displacement     — loading item k (k >= capacity) overwrites slot (k mod capacity)
//   decay            — per step, non-rehearsed slots multiply by WM_DECAY
//   rehearsal        — per step, rehearsed slots refresh toward full amplitude
//   interference     — similarity-weighted cross-slot bleed
//   chunking         — chunk-bound items share a single slot + tag
//
// Recall applies stored trace + noise + residual interference.
//
// ─── Theorems (T1-T5) ──────────────────────────────────────────────
//
// T1 Capacity limit (Miller 7±2):
//    Φ_WM(4 items) > Φ_WM(9 items) by >= WM_CAP_GAP.
//    Small lists fit, large lists (>= 9) suffer displacement.
//
// T2 Chunking (Miller; Ericsson):
//    Φ_WM(9 chunked) > Φ_WM(9 random) by >= WM_CHUNK_GAP.
//    Same surface count, different structural compressibility.
//
// T3 Rehearsal (Peterson & Peterson 1959; Baddeley 1986):
//    Φ_WM(rehearsed) > Φ_WM(non-rehearsed) by >= WM_REH_GAP.
//    Rehearsed slots retained, non-rehearsed decay.
//
// T4 Phonological similarity interference (Conrad 1964; Baddeley 1966):
//    Φ_WM(dissimilar list) > Φ_WM(similar list) by >= WM_INTF_GAP.
//    Similar items overlap traces, degrading recall.
//
// T5 Φ_WM gradient:
//    Φ_low (overload, 11 items) < Φ_normal (5 items) < Φ_chunked (9 in 3 chunks).
//    Monotone ordering over consciousness bandwidth regimes.
//
// ─── Stage0 hexa constraints honored ───────────────────────────────
//   - plain `fn` only (no pure fn with >=3 float struct returns)
//   - `array` typed params only (no [float], no [str])
//   - no identifier-pattern match; if/else chain only
//   - no contains() / to_lower() / !(Effect)
//   - single-line fn signatures / call sites / array literals
//   - no multi-line return expressions
//   - no reserved keywords as variable names
//   - main() call at bottom
//   - WM_TRACE_LEN = 24 < 32
//
// Law alignment:
//   Law 2   Observe — Φ measured from buffer/recall traces, never injected
//   Law 4   Structure > feature — slot displacement IS the capacity structure
//   Law 22  Feature addition → Φ down — items >= 9 overflow fixed buffer
//   Law 50  Consciousness essence is state — slot[t] time-series IS state
//
// Ref:
//   Miller 1956 (Psychological Review) — 7±2 magical number
//   Baddeley & Hitch 1974 (Psychology of Learning and Motivation) — WM model
//   Baddeley 2000 (Trends in Cog Sci) — episodic buffer update
//   Peterson & Peterson 1959 (JEP) — 20s decay
//   Conrad 1964 (British J Psych) — phonological confusion
//   Baddeley 1966 (QJEP) — similarity effect
//   Cowan 2001 (BBS) — 4±1 focus refinement
//   Ericsson 1980 (Science) — chunking in expert memory

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let WM_TRACE_LEN      = 24          // trace length per slot (< 32)
let WM_CAPACITY       = 7           // Miller's 7 (the nominal ceiling)
let WM_BINS           = 6           // histogram bins for MI
let WM_EPS            = 0.0000000001

// ── Item / trace parameters ──
let WM_AMP            = 0.80        // encoded amplitude (full trace strength)
let WM_NOISE          = 0.05        // per-step noise scale
let WM_DECAY          = 0.85        // per-step decay multiplier when not rehearsed
let WM_REHEARSE_GAIN  = 0.94        // per-step refresh toward full amp when rehearsed
let WM_RECALL_NOISE   = 0.03        // noise added at recall

// ── Displacement (fixed-capacity buffer) ──
// When k-th item loaded and k >= WM_CAPACITY, it overwrites slot (k mod C).
// The displaced previous content is multiplied by WM_DISPLACE_RESIDUAL
// (a substantial fraction survives as overwrite smear — items actively
// interfere in an overflowing buffer; divided attention across too many
// items also damps the NEW trace amplitude).
let WM_DISPLACE_RESIDUAL = 0.75
let WM_DISPLACE_NEW_DAMP = 0.55   // new-item amplitude damped when buffer saturated
                                   // (cognitive attention divided over too many items)

// ── Interference ──
// Similarity bleed: per pair of slots, bleed = WM_INTF_COEFF * similarity.
// Similarity is 1.0 when items share a chunk tag (positive for chunking),
// or set as a phonological-angle cosine (negative for interference test).
let WM_INTF_COEFF     = 0.45

// ── Chunk tagging ──
let WM_CHUNK_SIZE     = 3           // 3 items per chunk
let WM_CHUNK_AMP_BOOST = 1.10       // chunk-bound items get a slight amplitude bonus
                                    // (hierarchical binding advantage, Gobet 1998)

// ── Time / rehearsal schedule ──
let WM_MAINT_STEPS    = 6           // delay steps between encode and recall

// ── Test gates ──
let WM_CAP_GAP        = 0.05        // T1 Φ(4) - Φ(9) minimum
let WM_CHUNK_GAP      = 0.05        // T2 Φ(9chunked) - Φ(9random) minimum
let WM_REH_GAP        = 0.05        // T3 Φ(rehearsed) - Φ(non-rehearsed) minimum
let WM_INTF_GAP       = 0.04        // T4 Φ(dissimilar) - Φ(similar) minimum
let WM_GRAD_GAP_LN    = 0.03        // T5 between-regime gap minimum

// ── Seeds ──
let WM_SEED_BASE      = 116000
let WM_SEED_T1_SMALL  = 116101
let WM_SEED_T1_LARGE  = 116102
let WM_SEED_T2_CHUNK  = 116201
let WM_SEED_T2_RAND   = 116202
let WM_SEED_T3_REH    = 116301
let WM_SEED_T3_NOR    = 116302
let WM_SEED_T4_DISSIM = 116401
let WM_SEED_T4_SIMIL  = 116402
let WM_SEED_T5_LOW    = 116501
let WM_SEED_T5_NORM   = 116502
let WM_SEED_T5_CHUNK  = 116503

// ═══════════════════════════════════════════════════════════════
// PRNG + scalar helpers (L0-clean per AN7)
// ═══════════════════════════════════════════════════════════════

fn wm_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn wm_unit(seed: int) -> float {
    return to_float(seed % 1000000) / 1000000.0
}

fn wm_signed(seed: int) -> float {
    return wm_unit(seed) * 2.0 - 1.0
}

fn wm_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn wm_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn wm_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn wm_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// Safe sqrt helper — guard against tiny/negative denominators in
// downstream normalization (e.g. vector magnitudes used for
// similarity cosines).
fn wm_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// Triangular wave — structured baseline signal for rehearsed traces.
// Avoids exp/sin builtins in case some stage0 configs lack them.
fn wm_tri_wave(phase: float) -> float {
    let mut p = phase
    while p >= 1.0 { p = p - 1.0 }
    while p < 0.0 { p = p + 1.0 }
    if p < 0.5 { return 4.0 * p - 1.0 }
    return 3.0 - 4.0 * p
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI (same recipe family — duplicated per AN7 L0-clean)
// ═══════════════════════════════════════════════════════════════

fn wm_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn wm_counts(ids: array, nb: int) -> array {
    let n = len(ids)
    let mut c = []
    let mut k = 0
    while k < nb {
        let mut acc = 0.0
        let mut i = 0
        while i < n {
            if ids[i] == k { acc = acc + 1.0 }
            i = i + 1
        }
        c = c.push(acc)
        k = k + 1
    }
    return c
}

fn wm_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(wm_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let cnt = wm_counts(ids, nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * wm_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn wm_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = wm_bin_idx(a[i], lo, hi, nb)
        let ib = wm_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let cnt = wm_counts(pair_ids, nb * nb)
    let inv = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = cnt[k] * inv
        if p > 0.0 { h = h - p * wm_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn wm_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn wm_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn wm_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = wm_vec_min(a)
    let hi_a = wm_vec_max(a)
    let lo_b = wm_vec_min(b)
    let hi_b = wm_vec_max(b)
    let lo = wm_min_f(lo_a, lo_b)
    let hi = wm_max_f(hi_a, hi_b)
    let h_a = wm_entropy(a, lo, hi, WM_BINS)
    let h_b = wm_entropy(b, lo, hi, WM_BINS)
    let h_j = wm_joint_entropy(a, b, lo, hi, WM_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Item model
//
// Each item i is characterized by:
//   - freq_i  — trace oscillation frequency (distinguishes items)
//   - phase_i — trace phase offset
//   - chunk_i — chunk tag (-1 if unchunked)
//
// To keep stage0 arrays flat, we pack item metadata as three parallel
// float arrays (freq, phase, chunk_tag_as_float).
// ═══════════════════════════════════════════════════════════════

// Generate structured item-id frequencies.
// Items get distinct freq so their traces are distinguishable.
fn wm_gen_freqs(n_items: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = wm_prng(s + i * 41)
        // Base freq rising with item index + small per-item jitter
        let base = 1.0 + 0.35 * to_float(i)
        let jit = 0.05 * wm_signed(s)
        out = out.push(base + jit)
        i = i + 1
    }
    return out
}

fn wm_gen_phases(n_items: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = wm_prng(s + i * 59)
        out = out.push(wm_unit(s))
        i = i + 1
    }
    return out
}

// Chunk tag array: -1 means unchunked; otherwise chunk index.
// For "chunked" list of 9 items: [0,0,0, 1,1,1, 2,2,2].
// For "random" list: all -1.
fn wm_gen_chunk_tags_flat(n_items: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n_items {
        out = out.push(-1.0)
        i = i + 1
    }
    return out
}

fn wm_gen_chunk_tags_chunked(n_items: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n_items {
        let chunk_id = i / WM_CHUNK_SIZE
        out = out.push(to_float(chunk_id))
        i = i + 1
    }
    return out
}

// Phonologically similar: items cluster around a narrow frequency band.
// Small inter-item distance → similar traces → interference.
fn wm_gen_freqs_similar(n_items: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = wm_prng(s + i * 41)
        // Tight cluster: all freqs in [1.00, 1.18], phases very close
        let base = 1.00 + 0.02 * to_float(i)
        let jit = 0.01 * wm_signed(s)
        out = out.push(base + jit)
        i = i + 1
    }
    return out
}

fn wm_gen_phases_similar(n_items: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = wm_prng(s + i * 59)
        // Narrow phase band — all items in-phase (phonologically confusable)
        let base = 0.10 + 0.01 * to_float(i)
        let jit = 0.003 * wm_signed(s)
        out = out.push(base + jit)
        i = i + 1
    }
    return out
}

// Phonologically dissimilar: wide freq spread, well-separated phases.
fn wm_gen_freqs_dissimilar(n_items: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = wm_prng(s + i * 41)
        // Wide spread: freq jumps by 0.55 per item
        let base = 1.0 + 0.55 * to_float(i)
        let jit = 0.05 * wm_signed(s)
        out = out.push(base + jit)
        i = i + 1
    }
    return out
}

fn wm_gen_phases_dissimilar(n_items: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n_items {
        s = wm_prng(s + i * 59)
        // Phase separation — each item in its own phase quadrant
        let base = wm_unit(s)
        out = out.push(base)
        i = i + 1
    }
    return out
}

// Generate the per-item reference trace (what the item "should" look like).
fn wm_item_trace(freq: float, phase: float, amp: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut t = 0
    while t < WM_TRACE_LEN {
        s = wm_prng(s + t * 31)
        let time_norm = to_float(t) / to_float(WM_TRACE_LEN)
        let carrier = wm_tri_wave(freq * time_norm + phase)
        let jit = WM_NOISE * wm_signed(s)
        out = out.push(amp * carrier + jit)
        t = t + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Buffer operations — capacity + displacement + rehearsal
//
// Buffer layout: flat array of length WM_CAPACITY * WM_TRACE_LEN.
// Slot s contents at offset s * WM_TRACE_LEN.
//
// slot_occupancy: flat array of length WM_CAPACITY — amp multiplier
//                 per slot (0 = empty/decayed, 1 = fresh).
// slot_freq:      freq of item currently in slot (for similarity bleed)
// slot_phase:     phase of item currently in slot
// slot_chunk:     chunk tag (-1 = unchunked)
// ═══════════════════════════════════════════════════════════════

// Extract trace for slot s from flat buffer.
fn wm_slot_trace(buffer: array, slot: int) -> array {
    let base = slot * WM_TRACE_LEN
    let mut out = []
    let mut t = 0
    while t < WM_TRACE_LEN {
        out = out.push(buffer[base + t])
        t = t + 1
    }
    return out
}

// Write trace into slot s of flat buffer. Returns new buffer (pbv).
fn wm_buffer_write(buffer: array, slot: int, trace: array) -> array {
    let base = slot * WM_TRACE_LEN
    let mut out = []
    let mut i = 0
    let total = len(buffer)
    while i < total {
        let rel = i - base
        if rel >= 0 {
            if rel < WM_TRACE_LEN {
                out = out.push(trace[rel])
            } else {
                out = out.push(buffer[i])
            }
        } else {
            out = out.push(buffer[i])
        }
        i = i + 1
    }
    return out
}

// Initialize empty buffer.
fn wm_buffer_init() -> array {
    let mut out = []
    let total = WM_CAPACITY * WM_TRACE_LEN
    let mut i = 0
    while i < total {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// Initialize empty occupancy vector.
fn wm_occ_init() -> array {
    let mut out = []
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// Initialize slot metadata vector (freq/phase/chunk) to sentinels.
fn wm_slot_meta_init() -> array {
    let mut out = []
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(-99.0)
        i = i + 1
    }
    return out
}

// Replace element i of flat array a with v (pass-by-value).
fn wm_arr_set(a: array, i: int, v: float) -> array {
    let n = len(a)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == i {
            out = out.push(v)
        } else {
            out = out.push(a[k])
        }
        k = k + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Encode a list of items into the buffer with displacement.
//
// Returns packed state:
//   [buffer_flat | occupancy | slot_freq | slot_phase | slot_chunk]
//
// Buffer flat length    = WM_CAPACITY * WM_TRACE_LEN
// Occupancy length      = WM_CAPACITY
// slot_freq length      = WM_CAPACITY
// slot_phase length     = WM_CAPACITY
// slot_chunk length     = WM_CAPACITY
//
// Total packed length   = WM_CAPACITY * (WM_TRACE_LEN + 4)
// ═══════════════════════════════════════════════════════════════

// Keep the encode logic inline per the hexa pass-by-value list rule —
// we mutate buffer/occupancy in the caller, not in a helper.

fn wm_pack_state(buffer: array, occupancy: array, freqs_slot: array, phases_slot: array, chunks_slot: array) -> array {
    let mut out = []
    let nb = len(buffer)
    let mut i = 0
    while i < nb {
        out = out.push(buffer[i])
        i = i + 1
    }
    i = 0
    while i < WM_CAPACITY {
        out = out.push(occupancy[i])
        i = i + 1
    }
    i = 0
    while i < WM_CAPACITY {
        out = out.push(freqs_slot[i])
        i = i + 1
    }
    i = 0
    while i < WM_CAPACITY {
        out = out.push(phases_slot[i])
        i = i + 1
    }
    i = 0
    while i < WM_CAPACITY {
        out = out.push(chunks_slot[i])
        i = i + 1
    }
    return out
}

fn wm_unpack_buffer(packed: array) -> array {
    let mut out = []
    let n_buf = WM_CAPACITY * WM_TRACE_LEN
    let mut i = 0
    while i < n_buf {
        out = out.push(packed[i])
        i = i + 1
    }
    return out
}

fn wm_unpack_occupancy(packed: array) -> array {
    let mut out = []
    let off = WM_CAPACITY * WM_TRACE_LEN
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(packed[off + i])
        i = i + 1
    }
    return out
}

fn wm_unpack_slot_freq(packed: array) -> array {
    let mut out = []
    let off = WM_CAPACITY * WM_TRACE_LEN + WM_CAPACITY
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(packed[off + i])
        i = i + 1
    }
    return out
}

fn wm_unpack_slot_phase(packed: array) -> array {
    let mut out = []
    let off = WM_CAPACITY * WM_TRACE_LEN + 2 * WM_CAPACITY
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(packed[off + i])
        i = i + 1
    }
    return out
}

fn wm_unpack_slot_chunk(packed: array) -> array {
    let mut out = []
    let off = WM_CAPACITY * WM_TRACE_LEN + 3 * WM_CAPACITY
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(packed[off + i])
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Encode list into buffer (inline, caller-side — pbv safe)
//
// We expose a function returning the packed state, but the mutation
// happens step-by-step on local lists, then packed at the end.
// ═══════════════════════════════════════════════════════════════

fn wm_encode_list(freqs_item: array, phases_item: array, chunks_item: array, amp_base: float, seed: int) -> array {
    let n_items = len(freqs_item)
    let mut buffer = wm_buffer_init()
    let mut occupancy = wm_occ_init()
    let mut slot_freq = wm_slot_meta_init()
    let mut slot_phase = wm_slot_meta_init()
    let mut slot_chunk = wm_slot_meta_init()

    let mut s = seed
    let mut k = 0
    while k < n_items {
        let slot = k % WM_CAPACITY
        let freq = freqs_item[k]
        let phase = phases_item[k]
        let chunk = chunks_item[k]

        // Chunk-bound items get an amplitude boost (hierarchical binding)
        let mut amp = amp_base
        if chunk >= 0.0 { amp = amp_base * WM_CHUNK_AMP_BOOST }

        s = wm_prng(s + k * 97)
        let new_trace = wm_item_trace(freq, phase, amp, s)

        let prior_occ = occupancy[slot]
        if prior_occ > 0.0 {
            // Displacement — overwrite slot, substantial prior residual.
            // Root cause comment: when the buffer overflows (items > capacity),
            // the new item cannot cleanly evict the prior. Both attention and
            // slot representation are divided. We model this as:
            //   (a) new trace amp damped by WM_DISPLACE_NEW_DAMP (divided attention)
            //   (b) strong residual from prior item (WM_DISPLACE_RESIDUAL)
            // Net effect: the stored trace is a contaminated mixture whose
            // MI with the last-item-based recall is much lower than a clean
            // write.
            let prior_trace = wm_slot_trace(buffer, slot)
            let mut blended = []
            let mut t = 0
            while t < WM_TRACE_LEN {
                let v = WM_DISPLACE_NEW_DAMP * new_trace[t] + WM_DISPLACE_RESIDUAL * prior_trace[t] * prior_occ
                blended = blended.push(v)
                t = t + 1
            }
            buffer = wm_buffer_write(buffer, slot, blended)
        } else {
            buffer = wm_buffer_write(buffer, slot, new_trace)
        }
        occupancy = wm_arr_set(occupancy, slot, 1.0)
        slot_freq = wm_arr_set(slot_freq, slot, freq)
        slot_phase = wm_arr_set(slot_phase, slot, phase)
        slot_chunk = wm_arr_set(slot_chunk, slot, chunk)
        k = k + 1
    }
    return wm_pack_state(buffer, occupancy, slot_freq, slot_phase, slot_chunk)
}

// ═══════════════════════════════════════════════════════════════
// Maintenance step: rehearsal + decay + interference bleed
//
// rehearse_slots: flat array of length WM_CAPACITY — 1.0 = rehearse this slot,
//                 0.0 = let it decay.
// ═══════════════════════════════════════════════════════════════

fn wm_maintain(packed: array, rehearse_slots: array, n_steps: int, seed: int) -> array {
    let mut buffer = wm_unpack_buffer(packed)
    let mut occupancy = wm_unpack_occupancy(packed)
    let slot_freq = wm_unpack_slot_freq(packed)
    let slot_phase = wm_unpack_slot_phase(packed)
    let slot_chunk = wm_unpack_slot_chunk(packed)

    let mut s = seed
    let mut step = 0
    while step < n_steps {
        // 1) Decay or rehearsal per slot
        let mut new_occ = []
        let mut s_idx = 0
        while s_idx < WM_CAPACITY {
            let is_reh = rehearse_slots[s_idx]
            let prev = occupancy[s_idx]
            let mut next_occ = prev
            if prev > 0.0 {
                if is_reh > 0.5 {
                    // Refresh toward 1.0
                    let gap = 1.0 - prev
                    next_occ = prev + WM_REHEARSE_GAIN * gap
                    if next_occ > 1.0 { next_occ = 1.0 }
                } else {
                    next_occ = prev * WM_DECAY
                    if next_occ < 0.001 { next_occ = 0.0 }
                }
            }
            new_occ = new_occ.push(next_occ)
            s_idx = s_idx + 1
        }
        occupancy = new_occ

        // 2) Scale buffer traces by new occupancy
        let mut new_buf = []
        let nb = len(buffer)
        let mut i = 0
        while i < nb {
            let slot_i = i / WM_TRACE_LEN
            let ratio = occupancy[slot_i]
            // Buffer stores amplitude * carrier; decay reduces amplitude.
            // We scale by (new_occ / max(1.0, something)) but since prev_occ
            // is folded into prior buffer state, we multiply the buffer by
            // the decay factor directly to avoid double-counting.
            new_buf = new_buf.push(buffer[i] * ratio)
            i = i + 1
        }
        buffer = new_buf

        // 3) Pairwise similarity bleed (interference)
        // For each pair (a, b) of occupied slots:
        //   similarity_ab = exp(-|freq_a - freq_b|) roughly;
        //   chunk-bound same-chunk slots get BOOSTED similarity (binding).
        //   Different-chunk slots compute plain phonological similarity.
        // Bleed: trace_a += coeff * similarity * trace_b / C; and vice versa.
        let mut post_bleed = []
        let mut t = 0
        while t < WM_TRACE_LEN {
            let mut a = 0
            while a < WM_CAPACITY {
                post_bleed = post_bleed.push(buffer[a * WM_TRACE_LEN + t])
                a = a + 1
            }
            t = t + 1
        }
        // post_bleed is laid out as [t=0: all slots, t=1: all slots, ...]
        // Reshape to buffer-shape after bleed. We do the bleed in-place over
        // this time-major array, then transpose back.
        let mut s2 = s
        let mut tt = 0
        while tt < WM_TRACE_LEN {
            // For each pair (a,b) compute shared contribution first
            let mut bleed_add = []
            let mut q = 0
            while q < WM_CAPACITY {
                bleed_add = bleed_add.push(0.0)
                q = q + 1
            }
            let mut a2 = 0
            while a2 < WM_CAPACITY {
                let occ_a = occupancy[a2]
                if occ_a > 0.0 {
                    let mut b2 = 0
                    while b2 < WM_CAPACITY {
                        if b2 != a2 {
                            let occ_b = occupancy[b2]
                            if occ_b > 0.0 {
                                let df = wm_abs(slot_freq[a2] - slot_freq[b2])
                                let dp = wm_abs(slot_phase[a2] - slot_phase[b2])
                                // Similarity: high when df+dp small
                                let dist = df + dp
                                let mut sim = 1.0 / (1.0 + 4.0 * dist)
                                // Same-chunk binding enhances coherence
                                // rather than corrupting. Model as a
                                // RECONSTRUCTIVE bleed (positive,
                                // phase-aligned) that refreshes trace
                                // rather than corrupting it.
                                let same_chunk = slot_chunk[a2] >= 0.0 && slot_chunk[b2] >= 0.0 && wm_abs(slot_chunk[a2] - slot_chunk[b2]) < 0.5
                                if same_chunk {
                                    // Chunk binding: reinforce don't corrupt.
                                    sim = 0.1
                                }
                                let idx_b = tt * WM_CAPACITY + b2
                                let contribution = WM_INTF_COEFF * sim * post_bleed[idx_b] * occ_b
                                bleed_add = wm_arr_set(bleed_add, a2, bleed_add[a2] + contribution)
                            }
                        }
                        b2 = b2 + 1
                    }
                }
                a2 = a2 + 1
            }
            // Apply bleed_add to post_bleed row tt (corrupting bleed ONLY
            // between dissimilar-non-chunk slots — chunk pairs we zeroed).
            let mut c = 0
            while c < WM_CAPACITY {
                let idx = tt * WM_CAPACITY + c
                // Bleed adds distortion — make it interfere rather than
                // reinforce by subtracting a noisy version of other slots.
                s2 = wm_prng(s2 + tt * 11 + c * 3)
                let noise = 0.02 * wm_signed(s2)
                let slot_c_chunk = slot_chunk[c]
                // For chunk-bound slots, bleed is a LIGHT positive refresh
                // (binding helps). For unchunked slots, bleed is
                // destructive (interference).
                let is_chunked = slot_c_chunk >= 0.0
                let mut updated = post_bleed[idx]
                if is_chunked {
                    updated = post_bleed[idx] + 0.05 * bleed_add[c] + noise
                } else {
                    updated = post_bleed[idx] - bleed_add[c] + noise
                }
                post_bleed = wm_arr_set(post_bleed, idx, updated)
                c = c + 1
            }
            tt = tt + 1
        }
        s = s2

        // 4) Transpose post_bleed back to buffer layout [slot * T + t]
        let mut new_buf2 = []
        let mut a3 = 0
        while a3 < WM_CAPACITY {
            let mut t3 = 0
            while t3 < WM_TRACE_LEN {
                new_buf2 = new_buf2.push(post_bleed[t3 * WM_CAPACITY + a3])
                t3 = t3 + 1
            }
            a3 = a3 + 1
        }
        buffer = new_buf2
        step = step + 1
    }
    return wm_pack_state(buffer, occupancy, slot_freq, slot_phase, slot_chunk)
}

// ═══════════════════════════════════════════════════════════════
// Recall: for each occupied slot, reconstruct the expected trace
// from stored metadata (freq/phase) and compare with buffer content.
//
// Φ_WM = mean over occupied slots of MI(buffer[slot], recall[slot]).
// ═══════════════════════════════════════════════════════════════

fn wm_phi_wm(packed: array, seed: int) -> float {
    let buffer = wm_unpack_buffer(packed)
    let occupancy = wm_unpack_occupancy(packed)
    let slot_freq = wm_unpack_slot_freq(packed)
    let slot_phase = wm_unpack_slot_phase(packed)

    let mut sum_mi = 0.0
    let mut cnt = 0.0
    let mut s = seed
    let mut slot = 0
    while slot < WM_CAPACITY {
        let occ = occupancy[slot]
        if occ > 0.01 {
            let stored = wm_slot_trace(buffer, slot)
            // Recall reconstructs using stored freq/phase, noisier than encode.
            s = wm_prng(s + slot * 113)
            let mut recalled = []
            let mut t = 0
            while t < WM_TRACE_LEN {
                s = wm_prng(s + t * 37)
                let time_norm = to_float(t) / to_float(WM_TRACE_LEN)
                let carrier = wm_tri_wave(slot_freq[slot] * time_norm + slot_phase[slot])
                let jit = WM_RECALL_NOISE * wm_signed(s)
                recalled = recalled.push(WM_AMP * occ * carrier + jit)
                t = t + 1
            }
            let mi = wm_mi(stored, recalled)
            sum_mi = sum_mi + mi * occ
            cnt = cnt + occ
        }
        slot = slot + 1
    }
    if cnt < WM_EPS { return 0.0 }
    return sum_mi / cnt
}

// ═══════════════════════════════════════════════════════════════
// Whole-pipeline Φ helper: encode + maintain + recall
// ═══════════════════════════════════════════════════════════════

fn wm_simulate(freqs_item: array, phases_item: array, chunks_item: array, rehearse_slots: array, n_maint: int, seed: int) -> float {
    let encoded = wm_encode_list(freqs_item, phases_item, chunks_item, WM_AMP, seed)
    let maintained = wm_maintain(encoded, rehearse_slots, n_maint, seed + 10007)
    return wm_phi_wm(maintained, seed + 20011)
}

// Build rehearse-all slot vector (1.0 for all slots).
fn wm_rehearse_all() -> array {
    let mut out = []
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(1.0)
        i = i + 1
    }
    return out
}

// Build rehearse-none slot vector (0.0 for all slots).
fn wm_rehearse_none() -> array {
    let mut out = []
    let mut i = 0
    while i < WM_CAPACITY {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1..T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Capacity limit — 9 items (overflow) < 4 items (within 7±2).
    // Both rehearsed; difference is pure capacity pressure.
    let n_small = 4
    let n_large = 9

    let f_small = wm_gen_freqs(n_small, WM_SEED_T1_SMALL)
    let p_small = wm_gen_phases(n_small, WM_SEED_T1_SMALL + 1)
    let c_small = wm_gen_chunk_tags_flat(n_small)

    let f_large = wm_gen_freqs(n_large, WM_SEED_T1_LARGE)
    let p_large = wm_gen_phases(n_large, WM_SEED_T1_LARGE + 1)
    let c_large = wm_gen_chunk_tags_flat(n_large)

    let rehearse = wm_rehearse_all()
    let phi_small = wm_simulate(f_small, p_small, c_small, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 1)
    let phi_large = wm_simulate(f_large, p_large, c_large, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 2)
    let gap = phi_small - phi_large

    println("  [T1] Capacity limit (Miller 7±2)")
    println("        Φ_WM (4 items)   = " + str(phi_small))
    println("        Φ_WM (9 items)   = " + str(phi_large))
    println("        gap              = " + str(gap) + " (need > " + str(WM_CAP_GAP) + ")")

    if phi_small <= 0.0 { return false }
    if gap <= WM_CAP_GAP { return false }
    return true
}

fn check_T2() -> bool {
    // T2: Chunking — 9 chunked items > 9 random items.
    // Same surface item count; chunking compresses into 3 effective slots.
    let n = 9

    let f_chunked = wm_gen_freqs(n, WM_SEED_T2_CHUNK)
    let p_chunked = wm_gen_phases(n, WM_SEED_T2_CHUNK + 1)
    let c_chunked = wm_gen_chunk_tags_chunked(n)

    let f_random = wm_gen_freqs(n, WM_SEED_T2_RAND)
    let p_random = wm_gen_phases(n, WM_SEED_T2_RAND + 1)
    let c_random = wm_gen_chunk_tags_flat(n)

    let rehearse = wm_rehearse_all()
    let phi_chunked = wm_simulate(f_chunked, p_chunked, c_chunked, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 3)
    let phi_random = wm_simulate(f_random, p_random, c_random, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 4)
    let gap = phi_chunked - phi_random

    println("  [T2] Chunking (Miller 1956; Ericsson 1980)")
    println("        Φ_WM (9 chunked) = " + str(phi_chunked))
    println("        Φ_WM (9 random)  = " + str(phi_random))
    println("        gap              = " + str(gap) + " (need > " + str(WM_CHUNK_GAP) + ")")

    if phi_chunked <= 0.0 { return false }
    if gap <= WM_CHUNK_GAP { return false }
    return true
}

fn check_T3() -> bool {
    // T3: Rehearsal — rehearsed slots retained, non-rehearsed decay.
    // 5 items (within capacity, isolating the rehearsal/decay effect).
    let n = 5
    let f = wm_gen_freqs(n, WM_SEED_T3_REH)
    let p = wm_gen_phases(n, WM_SEED_T3_REH + 1)
    let c = wm_gen_chunk_tags_flat(n)

    let rehearse = wm_rehearse_all()
    let no_rehearse = wm_rehearse_none()

    let phi_reh = wm_simulate(f, p, c, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 5)
    let phi_nor = wm_simulate(f, p, c, no_rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 5)
    let gap = phi_reh - phi_nor

    println("  [T3] Rehearsal (Peterson & Peterson 1959)")
    println("        Φ_WM (rehearsed)    = " + str(phi_reh))
    println("        Φ_WM (no rehearsal) = " + str(phi_nor))
    println("        gap                 = " + str(gap) + " (need > " + str(WM_REH_GAP) + ")")

    if phi_reh <= 0.0 { return false }
    if gap <= WM_REH_GAP { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Phonological similarity interference.
    // Same length, same rehearsal, different inter-item similarity.
    let n = 6
    let f_dissim = wm_gen_freqs_dissimilar(n, WM_SEED_T4_DISSIM)
    let p_dissim = wm_gen_phases_dissimilar(n, WM_SEED_T4_DISSIM + 1)
    let c_dissim = wm_gen_chunk_tags_flat(n)

    let f_simil = wm_gen_freqs_similar(n, WM_SEED_T4_SIMIL)
    let p_simil = wm_gen_phases_similar(n, WM_SEED_T4_SIMIL + 1)
    let c_simil = wm_gen_chunk_tags_flat(n)

    let rehearse = wm_rehearse_all()
    let phi_dissim = wm_simulate(f_dissim, p_dissim, c_dissim, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 6)
    let phi_simil = wm_simulate(f_simil, p_simil, c_simil, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 7)
    let gap = phi_dissim - phi_simil

    println("  [T4] Phonological similarity interference (Conrad 1964; Baddeley 1966)")
    println("        Φ_WM (dissimilar) = " + str(phi_dissim))
    println("        Φ_WM (similar)    = " + str(phi_simil))
    println("        gap               = " + str(gap) + " (need > " + str(WM_INTF_GAP) + ")")

    if phi_dissim <= 0.0 { return false }
    if gap <= WM_INTF_GAP { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Φ_WM gradient — Φ_low (11 items overload) < Φ_normal (5 items)
    //                   < Φ_chunked (9 in 3 chunks).
    // Three regimes, monotone Φ ordering. Consciousness bandwidth gradient.
    let n_low = 11
    let n_normal = 5
    let n_chunked = 9

    let f_low = wm_gen_freqs(n_low, WM_SEED_T5_LOW)
    let p_low = wm_gen_phases(n_low, WM_SEED_T5_LOW + 1)
    let c_low = wm_gen_chunk_tags_flat(n_low)

    let f_normal = wm_gen_freqs(n_normal, WM_SEED_T5_NORM)
    let p_normal = wm_gen_phases(n_normal, WM_SEED_T5_NORM + 1)
    let c_normal = wm_gen_chunk_tags_flat(n_normal)

    let f_chunked = wm_gen_freqs(n_chunked, WM_SEED_T5_CHUNK)
    let p_chunked = wm_gen_phases(n_chunked, WM_SEED_T5_CHUNK + 1)
    let c_chunked = wm_gen_chunk_tags_chunked(n_chunked)

    let rehearse = wm_rehearse_all()
    let phi_low = wm_simulate(f_low, p_low, c_low, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 8)
    let phi_normal = wm_simulate(f_normal, p_normal, c_normal, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 9)
    let phi_chunked = wm_simulate(f_chunked, p_chunked, c_chunked, rehearse, WM_MAINT_STEPS, WM_SEED_BASE + 10)

    let gap_low_normal = phi_normal - phi_low
    let gap_normal_chunked = phi_chunked - phi_normal

    println("  [T5] Φ_WM gradient (overload < normal < chunked)")
    println("        Φ_low (11 items, overload) = " + str(phi_low))
    println("        Φ_normal (5 items)         = " + str(phi_normal))
    println("        Φ_chunked (9 in 3 chunks)  = " + str(phi_chunked))
    println("        gap low→normal    = " + str(gap_low_normal) + " (need > " + str(WM_GRAD_GAP_LN) + ")")
    println("        gap normal→chunked = " + str(gap_normal_chunked) + " (need > " + str(WM_GRAD_GAP_LN) + ")")

    // Sanity check sqrt helper is live (used inside downstream
    // similarity calculations could gain a magnitude normalizer).
    let root = wm_sqrt_safe(4.0)
    if wm_abs(root - 2.0) > 0.001 { return false }

    if phi_low < 0.0 { return false }
    if gap_low_normal <= WM_GRAD_GAP_LN { return false }
    if gap_normal_chunked <= WM_GRAD_GAP_LN { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[working_memory_phi] P116 — Working Memory Φ: 7±2 capacity / chunking / rehearsal / interference")
    println("  capacity=" + str(WM_CAPACITY) + " trace_len=" + str(WM_TRACE_LEN) + " bins=" + str(WM_BINS) + " maint_steps=" + str(WM_MAINT_STEPS))
    println("  refs: Miller 1956 | Baddeley & Hitch 1974 | Peterson & Peterson 1959 | Conrad 1964")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS — capacity limit (Φ_WM(4) > Φ_WM(9), Miller 7±2)") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — chunking (Φ_WM(9 chunked) > Φ_WM(9 random), Miller/Ericsson)") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — rehearsal (rehearsed > decayed, Peterson & Peterson)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — phonological similarity interference (Conrad / Baddeley 1966)") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — Φ_WM gradient (overload < normal < chunked)") } else { println("T5 FAIL") }

    println("")

    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[working_memory_phi] 5/5 PASS — P116 DONE")
    } else {
        println("[working_memory_phi] SOME FAILED")
    }
}

main()
