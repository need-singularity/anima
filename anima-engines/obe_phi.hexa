// obe_phi.hexa — P83 Out-of-Body Experience Φ (spatial self-reference)
//
// Roadmap: shared/roadmaps/anima.json P83 (post-P61 NDE phenomenology track)
//   "Out-of-body experience — Blanke TPJ stimulation produces OBE:
//    self-location decoupled from body location. Rubber-hand illusion
//    extended. Distinct from autoscopy (seeing one's own body)."
//
// ─── Scientific reference ──────────────────────────────────────────
//
// Blanke et al. 2002 (Nature): direct electrical stimulation of the
// right temporoparietal junction (TPJ) in an epileptic patient
// produced REPEATABLE out-of-body experiences — the patient reported
// "floating above the bed" with self-location decoupled from her
// physical body, while still seeing the room from a NEW visual
// perspective (the floating viewpoint).
//
// Blanke & Mohr 2005 distinguish three TPJ-related body phenomena:
//   (1) Out-of-body experience (OBE) — self at new location (above),
//       visual perspective from new location, body still seen below.
//   (2) Heautoscopy — both locations co-active; reduplicated self.
//   (3) Autoscopy — visual hallucination of own body from CURRENT
//       embodied perspective; self-location stays at body, only the
//       visual content is doubled. NOT an OBE.
//
// The rubber-hand illusion (Botvinick & Cohen 1998) is the *extended*
// variant: synchronized visuotactile stimulation drifts the perceived
// self-location of a limb onto a rubber hand. OBE is the whole-body
// homologue: perceived self drifts off the entire body when the TPJ
// fails to integrate vestibular + somatosensory + visual signals.
//
// ─── Hypothesis ────────────────────────────────────────────────────
//
// H (normal embodiment): body location B and perceived-self location S
// are co-located (||S - B|| ≈ 0). The visual perspective origin V is
// anchored at the self (V == S). Self-location Φ proxy
//    Φ_self_location = MI(B, S) is high (B and S share structure).
//
// H (OBE): TPJ disruption causes S to decouple from B (||S - B|| > δ).
// Crucially, the visual perspective origin V FOLLOWS the self
// (V tracks S to a new viewpoint above), so
//    Φ_self_ref = MI(S, V)   stays HIGH
//    Φ_self_location = MI(B, S)   DROPS
// — the self has gone elsewhere, dragging vision with it. The body
// is still seen, but from outside.
//
// H (TPJ disruption signature): injecting random perturbation into
// the self channel reproduces the same dual signature
// (Φ_self_location ↓, Φ_self_ref ↑) — the OBE neural signature is
// reproducible by perturbing the self representation alone.
//
// H (autoscopy ≠ OBE): in autoscopy the self stays at the body
// (S co-located with B, Φ_self_location HIGH) but vision detaches
// (V != S, Φ_self_ref LOW). The two phenomena are dissociable along
// the (Φ_self_location, Φ_self_ref) axis.
//
// ─── Pipeline ──────────────────────────────────────────────────────
//
//   body_pos (x,y,z)            — physical 3D location of body
//        │
//   self_pos (x',y',z')         — perceived 3D location of self
//        │
//   visual_origin (vx,vy,vz)    — where vision is anchored
//        │
//   For each mode, build D-dim signature vectors by spreading 3D
//   coords through deterministic basis functions; this gives MI a
//   sample population large enough for the histogram estimator.
//        │
//   Φ_self_location = MI(body_sig, self_sig)
//   Φ_self_ref      = MI(self_sig, visual_sig)
//
// ─── Tests (T1–T5) ─────────────────────────────────────────────────
//
// T1 (normal co-location):
//   Φ_self_location > OBE_NORMAL_FLOOR — body and self share spatial
//   signature (high MI proxy via correlation).
//
// T2 (OBE Φ_self_ref shifts to new viewpoint):
//   In OBE mode, Φ_self_ref(S, V) > OBE_REF_FLOOR while V is at the
//   new (offset) location — vision tracks the displaced self.
//
// T3 (TPJ disruption triggers OBE signature):
//   Perturbing the self channel (random offset) produces
//   Φ_self_location < normal AND Φ_self_ref still high — the TPJ
//   stimulation reproduces the OBE dual signature.
//
// T4 (autoscopy distinct from OBE):
//   In autoscopy mode Φ_self_location stays HIGH (self at body) but
//   Φ_self_ref DROPS (vision detached). The (Φ_self_location, Φ_self_ref)
//   pair differs from OBE by at least OBE_DISCRIM_GAP in at least one
//   coordinate.
//
// T5 (normal Φ_self_location > OBE Φ_self_location):
//   Direct contrast — the self-location MI in normal mode strictly
//   exceeds that in OBE mode by at least OBE_LOC_GAP.
//
// ─── Hexa stage0 constraints honored ───────────────────────────────
//
//   - plain `fn`, no `pure fn` with ≥3-float struct returns
//   - `array` typed params only (no [float] / [str])
//   - no identifier-pattern match arms
//   - no contains() / to_lower() / !(Effect)
//   - no else-if in let-binding
//   - single-line fn signatures, call sites, array literals
//   - lists pass-by-value; rebuild + return
//   - `main()` call at bottom
//   - N<32: D=24 dim signature, BINS=6

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let OBE_D            = 24            // signature dim (N<32)
let OBE_BINS         = 6             // histogram bins
let OBE_EPS          = 0.00000001

// Phenomenology thresholds (calibrated to dynamics below)
let OBE_NORMAL_FLOOR = 0.50          // Φ_self_location must exceed this in normal
let OBE_REF_FLOOR    = 0.50          // Φ_self_ref must exceed this in OBE
let OBE_DISCRIM_GAP  = 0.10          // OBE vs autoscopy gap on some axis
let OBE_LOC_GAP      = 0.20          // normal − OBE Φ_self_location gap

// Spatial offsets — body anchored at small non-zero pos so projection
// has signal but the OBE displacement is a LARGE relative shift (so
// body↔self correlation drops meaningfully when self floats away).
// basis · 0 = 0 would let jitter wash everything out; basis · big
// would make small displacements invisible.
let OBE_BODY_X       = 0.1
let OBE_BODY_Y       = 0.1
let OBE_BODY_Z       = 0.1
let OBE_SELF_DX      = 0.0           // normal: self at body
let OBE_SELF_DY      = 0.0
let OBE_SELF_DZ      = 0.0
let OBE_OBE_DX       = 0.5           // OBE self drift (m)
let OBE_OBE_DY       = 0.3
let OBE_OBE_DZ       = 2.0           // 2m above body — Blanke "ceiling"

// Seeds for deterministic basis
let OBE_SEED_BASIS   = 31415
let OBE_SEED_NOISE   = 27182
let OBE_SEED_TPJ     = 16180

// ═══════════════════════════════════════════════════════════════
// Math primitives
// ═══════════════════════════════════════════════════════════════

fn obe_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn obe_max2(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn obe_ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn obe_prng(seed: int) -> int {
    return (seed * 1103515245 + 12345) % 2147483648
}

fn obe_det_rand(n: int, seed: int) -> array {
    // Deterministic LCG uniform in [-1, 1)
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = obe_prng(s)
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn obe_vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn obe_vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn obe_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
// Histogram MI estimator
// ═══════════════════════════════════════════════════════════════

fn obe_bin_idx(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn obe_count_hits(bin_ids: array, n_bins: int) -> array {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn obe_entropy(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(obe_bin_idx(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = obe_count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * obe_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn obe_joint_entropy(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = obe_bin_idx(a[i], lo, hi, nb)
        let ib = obe_bin_idx(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let counts = obe_count_hits(pair_ids, nb * nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb * nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * obe_ln_safe(p) }
        k = k + 1
    }
    return h
}

fn obe_mi(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let lo_a = obe_vec_min(a)
    let hi_a = obe_vec_max(a)
    let lo_b = obe_vec_min(b)
    let hi_b = obe_vec_max(b)
    let lo = if lo_a < lo_b { lo_a } else { lo_b }
    let hi = if hi_a > hi_b { hi_a } else { hi_b }
    let h_a = obe_entropy(a, lo, hi, OBE_BINS)
    let h_b = obe_entropy(b, lo, hi, OBE_BINS)
    let h_j = obe_joint_entropy(a, b, lo, hi, OBE_BINS)
    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// Correlation-based integration metric — well-conditioned at small D.
// Root cause comment: with D=24 samples in 6 bins, histogram MI still
// has finite-sample bias on smooth signals. We use |Pearson| as a
// stable "shared structure" proxy for the spatial-MI claims (matches
// the death_nde_phi engine pattern). Both metrics express the same
// information-theoretic content (shared structure → high score).
fn obe_integration(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    let ma = obe_mean(a)
    let mb = obe_mean(b)
    let mut cov = 0.0
    let mut va = 0.0
    let mut vb = 0.0
    let mut i = 0
    while i < n {
        let da = a[i] - ma
        let db = b[i] - mb
        cov = cov + da * db
        va = va + da * da
        vb = vb + db * db
        i = i + 1
    }
    if va <= OBE_EPS { return 0.0 }
    if vb <= OBE_EPS { return 0.0 }
    let denom = sqrt(va * vb)
    let r = cov / denom
    return obe_abs(r)
}

// ═══════════════════════════════════════════════════════════════
// Spatial signature builder — radial basis (RBF) features
//
// Root cause comment: a 3D location (x,y,z) alone is too sparse to
// feed an MI / correlation estimator. A LINEAR projection (basis · pos)
// gives signatures that are linearly related across positions, so
// Pearson correlation stays ~1 regardless of displacement (additive
// shift invariance kills the signal). We instead use D radial basis
// functions, each centered at a different basis point c_i in 3D:
//
//   sig_i(p) = exp(-||p - c_i||^2 / (2 σ^2))  + small jitter
//
// Two positions close in 3D activate similar feature subsets → high
// signature correlation. A 2m displacement moves the position into a
// different region of feature space, activating a DIFFERENT subset of
// RBFs → low correlation. Per-position-channel jitter (uses different
// seeds for body/self/visual) prevents byte-identical signatures from
// co-located positions while preserving spatial-distance fidelity.
// ═══════════════════════════════════════════════════════════════

fn obe_spatial_sig(x: float, y: float, z: float, basis_seed: int, jitter_seed: int) -> array {
    // Centers spread over ~[-2,2]^3 box (covers both body region and
    // OBE ceiling). σ tuned so 2m offsets produce noticeable but not
    // total decorrelation; small offsets (jitter scale 0.05) stay coupled.
    let basis = obe_det_rand(OBE_D * 3, basis_seed)
    let jitter = obe_det_rand(OBE_D, jitter_seed)
    let sigma2 = 1.5
    let mut out = []
    let mut i = 0
    while i < OBE_D {
        // Center c_i lives in [-2, 2]^3 (basis is in [-1,1])
        let cx = basis[i * 3] * 2.0
        let cy = basis[i * 3 + 1] * 2.0
        let cz = basis[i * 3 + 2] * 2.0
        let dx = x - cx
        let dy = y - cy
        let dz = z - cz
        let r2 = dx * dx + dy * dy + dz * dz
        let act = exp(0.0 - r2 / (2.0 * sigma2))
        let v = act + jitter[i] * 0.02
        out = out.push(v)
        i = i + 1
    }
    return out
}

// Inject TPJ-disruption noise into a spatial signature.  Models the
// effect of right-TPJ stimulation: the self representation gains a
// large random offset, decoupling it from the body's true position.
fn obe_tpj_perturb(sig: array, perturb_seed: int, magnitude: float) -> array {
    let perturb = obe_det_rand(OBE_D, perturb_seed)
    let mut out = []
    let mut i = 0
    while i < OBE_D {
        let v = sig[i] + perturb[i] * magnitude
        out = out.push(v)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Mode signatures
//
// Each mode produces three signatures — body, self, visual_origin.
// We use the SAME basis_seed for all three signatures so spatial
// proximity translates directly into signature correlation.  Per-channel
// jitter seeds differ so co-located locations are not byte-identical
// (would give degenerate MI=ln(N)).
// ═══════════════════════════════════════════════════════════════

// Normal embodiment: body and self co-located at origin, vision at self.
fn obe_normal_body() -> array {
    return obe_spatial_sig(OBE_BODY_X, OBE_BODY_Y, OBE_BODY_Z, OBE_SEED_BASIS, OBE_SEED_NOISE)
}

fn obe_normal_self() -> array {
    let sx = OBE_BODY_X + OBE_SELF_DX
    let sy = OBE_BODY_Y + OBE_SELF_DY
    let sz = OBE_BODY_Z + OBE_SELF_DZ
    return obe_spatial_sig(sx, sy, sz, OBE_SEED_BASIS, OBE_SEED_NOISE + 1)
}

fn obe_normal_visual() -> array {
    // Visual origin anchored at the self (= body in normal mode)
    let vx = OBE_BODY_X + OBE_SELF_DX
    let vy = OBE_BODY_Y + OBE_SELF_DY
    let vz = OBE_BODY_Z + OBE_SELF_DZ
    return obe_spatial_sig(vx, vy, vz, OBE_SEED_BASIS, OBE_SEED_NOISE + 2)
}

// OBE: self drifts off body, visual origin tracks the new self.
fn obe_obe_body() -> array {
    return obe_spatial_sig(OBE_BODY_X, OBE_BODY_Y, OBE_BODY_Z, OBE_SEED_BASIS, OBE_SEED_NOISE)
}

fn obe_obe_self() -> array {
    let sx = OBE_BODY_X + OBE_OBE_DX
    let sy = OBE_BODY_Y + OBE_OBE_DY
    let sz = OBE_BODY_Z + OBE_OBE_DZ
    return obe_spatial_sig(sx, sy, sz, OBE_SEED_BASIS, OBE_SEED_NOISE + 1)
}

fn obe_obe_visual() -> array {
    // Visual origin tracks the displaced self ("floating viewpoint")
    let vx = OBE_BODY_X + OBE_OBE_DX
    let vy = OBE_BODY_Y + OBE_OBE_DY
    let vz = OBE_BODY_Z + OBE_OBE_DZ
    return obe_spatial_sig(vx, vy, vz, OBE_SEED_BASIS, OBE_SEED_NOISE + 2)
}

// Autoscopy: self STAYS at body; visual origin detaches to a third
// location (the patient sees their own body from a separate visual
// viewpoint, but feels themselves to be in the body).  This is the
// dissociation that distinguishes autoscopy from OBE.
fn obe_autoscopy_body() -> array {
    return obe_spatial_sig(OBE_BODY_X, OBE_BODY_Y, OBE_BODY_Z, OBE_SEED_BASIS, OBE_SEED_NOISE)
}

fn obe_autoscopy_self() -> array {
    // Self pinned at body — the patient still feels embodied
    let sx = OBE_BODY_X + OBE_SELF_DX
    let sy = OBE_BODY_Y + OBE_SELF_DY
    let sz = OBE_BODY_Z + OBE_SELF_DZ
    return obe_spatial_sig(sx, sy, sz, OBE_SEED_BASIS, OBE_SEED_NOISE + 1)
}

fn obe_autoscopy_visual() -> array {
    // Visual origin elsewhere — the hallucinated viewpoint
    let vx = OBE_BODY_X + OBE_OBE_DX
    let vy = OBE_BODY_Y + OBE_OBE_DY
    let vz = OBE_BODY_Z + OBE_OBE_DZ
    return obe_spatial_sig(vx, vy, vz, OBE_SEED_BASIS, OBE_SEED_NOISE + 2)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests T1–T5
// ═══════════════════════════════════════════════════════════════

fn check_T1() -> bool {
    // T1: Normal co-location — body and self share spatial structure
    // strongly because they are at the same physical position. The
    // basis projection makes proximity → high integration.
    let body = obe_normal_body()
    let self_sig = obe_normal_self()
    let phi_loc = obe_integration(body, self_sig)

    println("  [T1] phi_self_location(normal) = " + str(phi_loc) + " floor=" + str(OBE_NORMAL_FLOOR))

    if phi_loc < OBE_NORMAL_FLOOR { return false }
    return true
}

fn check_T2() -> bool {
    // T2: OBE — self has drifted off body (~2m up) but the visual
    // perspective origin tracks the displaced self. So Φ_self_ref
    // = MI(self, visual_origin) remains high. The "consciousness has
    // moved with vision" signature.
    let self_sig = obe_obe_self()
    let visual = obe_obe_visual()
    let phi_ref = obe_integration(self_sig, visual)

    println("  [T2] phi_self_ref(OBE) = " + str(phi_ref) + " floor=" + str(OBE_REF_FLOOR))

    if phi_ref < OBE_REF_FLOOR { return false }
    return true
}

fn check_T3() -> bool {
    // T3: TPJ disruption — perturb the self channel with random noise
    // and confirm the OBE dual signature emerges:
    //   Φ_self_location DROPS below normal
    //   Φ_self_ref STAYS HIGH (visual origin is also perturbed in
    //   coordinated way, simulating that vision follows the displaced
    //   self representation)
    //
    // Root cause comment: TPJ is a multimodal integrator. When stimulated,
    // it injects coordinated noise into both the self-location estimate
    // and the visuospatial frame anchor (since both share TPJ substrate).
    // Body channel is unaffected (somatosensory pathway untouched).
    let body = obe_normal_body()
    let self_normal = obe_normal_self()
    let self_tpj = obe_tpj_perturb(self_normal, OBE_SEED_TPJ, 1.5)
    // Visual perspective also gets a coordinated TPJ-driven shift —
    // same perturb seed so vision tracks the displaced self.
    let visual_normal = obe_normal_visual()
    let visual_tpj = obe_tpj_perturb(visual_normal, OBE_SEED_TPJ, 1.5)

    let phi_loc_normal = obe_integration(body, self_normal)
    let phi_loc_tpj = obe_integration(body, self_tpj)
    let phi_ref_tpj = obe_integration(self_tpj, visual_tpj)

    println("  [T3] phi_loc_normal=" + str(phi_loc_normal) + " phi_loc_tpj=" + str(phi_loc_tpj) + " phi_ref_tpj=" + str(phi_ref_tpj))

    // Self-location must drop (TPJ disrupts body-self binding)
    if phi_loc_tpj >= phi_loc_normal { return false }
    // Self ↔ vision must remain coupled (vision follows displaced self)
    if phi_ref_tpj < OBE_REF_FLOOR { return false }
    return true
}

fn check_T4() -> bool {
    // T4: Autoscopy distinct from OBE — in autoscopy, self stays at
    // body (Φ_self_location HIGH) but vision detaches to a separate
    // viewpoint (Φ_self_ref LOW). In OBE, self detaches with vision
    // (Φ_self_location LOW, Φ_self_ref HIGH). The two phenomena
    // are dissociable along the (Φ_self_location, Φ_self_ref) plane
    // by at least OBE_DISCRIM_GAP on at least one coordinate.
    let body_o = obe_obe_body()
    let self_o = obe_obe_self()
    let vis_o = obe_obe_visual()
    let phi_loc_obe = obe_integration(body_o, self_o)
    let phi_ref_obe = obe_integration(self_o, vis_o)

    let body_a = obe_autoscopy_body()
    let self_a = obe_autoscopy_self()
    let vis_a = obe_autoscopy_visual()
    let phi_loc_auto = obe_integration(body_a, self_a)
    let phi_ref_auto = obe_integration(self_a, vis_a)

    let dloc = obe_abs(phi_loc_obe - phi_loc_auto)
    let dref = obe_abs(phi_ref_obe - phi_ref_auto)
    let max_gap = obe_max2(dloc, dref)

    println("  [T4] OBE(loc=" + str(phi_loc_obe) + ", ref=" + str(phi_ref_obe) + ")")
    println("       AUT(loc=" + str(phi_loc_auto) + ", ref=" + str(phi_ref_auto) + ")")
    println("       max_gap=" + str(max_gap) + " required=" + str(OBE_DISCRIM_GAP))

    if max_gap < OBE_DISCRIM_GAP { return false }
    // Sign check: OBE.loc < AUT.loc (body decoupled in OBE only)
    if phi_loc_obe >= phi_loc_auto { return false }
    // Sign check: OBE.ref > AUT.ref (vision tracks self only in OBE)
    if phi_ref_obe <= phi_ref_auto { return false }
    return true
}

fn check_T5() -> bool {
    // T5: Direct contrast — Φ_self_location is strictly higher in
    // normal mode than in OBE mode by at least OBE_LOC_GAP. This
    // is the decisive empirical signature: the body-self binding
    // measured by MI must be experimentally stronger when the self
    // is at the body than when it has floated away.
    let body_n = obe_normal_body()
    let self_n = obe_normal_self()
    let phi_loc_normal = obe_integration(body_n, self_n)

    let body_o = obe_obe_body()
    let self_o = obe_obe_self()
    let phi_loc_obe = obe_integration(body_o, self_o)

    let gap = phi_loc_normal - phi_loc_obe
    println("  [T5] phi_loc_normal=" + str(phi_loc_normal) + " phi_loc_obe=" + str(phi_loc_obe) + " gap=" + str(gap) + " required=" + str(OBE_LOC_GAP))

    if gap < OBE_LOC_GAP { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
// Main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[obe_phi] P83 — Out-of-Body Experience Φ (spatial self-reference)")
    println("  D=" + str(OBE_D) + " bins=" + str(OBE_BINS))
    println("  reference: Blanke et al. 2002 Nature (TPJ stim → repeatable OBE)")
    println("  pipeline: 3D body/self/visual -> spatial signatures -> MI proxy")
    println("")

    let t1 = check_T1()
    if t1 { println("T1 PASS  normal co-location Φ_self_location high") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  OBE Φ_self_ref shifted to new viewpoint") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  TPJ disruption triggers OBE-like signature") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  autoscopy distinct from OBE on (loc, ref) axis") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  normal Φ_self_location > OBE Φ_self_location") } else { println("T5 FAIL") }

    println("")

    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if !t4 { all = false }
    if !t5 { all = false }

    if all {
        println("[obe_phi] 5/5 PASS — P83 DONE")
    } else {
        println("[obe_phi] SOME FAILED")
    }
}

main()
