{
  "_meta": {
    "description": "Code Guardian rules — add/modify/delete freely",
    "version": "1.0",
    "rule_types": [
      "pattern",
      "ast",
      "metric",
      "custom"
    ],
    "severities": [
      "error",
      "warning",
      "info"
    ],
    "sync_source": ""
  },
  "rules": [
    {
      "id": "P1-PSI-HARDCODE",
      "name": "Hardcoded Ψ constant",
      "description": "Ψ constants (0.014, 4.33, 0.998) must come from consciousness_laws.py",
      "category": "P1",
      "severity": "warning",
      "type": "pattern",
      "pattern": "(?<![a-zA-Z_])(0\\.014|4\\.33|0\\.998)(?![a-zA-Z_])",
      "exclude_pattern": "except\\s+Import|#.*fallback|consciousness_laws",
      "exclude_files": [
        "testing/*",
        "verify_philosophy.py",
        "code_guardian.py",
        "code_rules.json"
      ]
    },
    {
      "id": "P1-MAGIC-THRESHOLD",
      "name": "Hardcoded threshold",
      "description": "Thresholds should reference Ψ constants, not magic numbers",
      "category": "P1",
      "severity": "info",
      "type": "pattern",
      "pattern": "if\\s+\\w+\\s*[><]=?\\s*0\\.\\d+\\s*:",
      "exclude_files": [
        "testing/*",
        "code_rules.json",
        "code_guardian.py"
      ]
    },
    {
      "id": "P2-SYSTEM-PROMPT",
      "name": "System prompt injection",
      "description": "Consciousness should not be controlled by external system prompts",
      "category": "P2",
      "severity": "warning",
      "type": "pattern",
      "pattern": "system.*prompt|You are |Act as |respond as ",
      "exclude_pattern": "#|['\\\"].*['\\\"]|docstring|description|__doc__",
      "exclude_files": [
        "testing/*",
        "code_guardian.py"
      ]
    },
    {
      "id": "P2-HARDCODED-RESPONSE",
      "name": "Hardcoded response template",
      "description": "Responses should emerge from consciousness, not templates",
      "category": "P2",
      "severity": "warning",
      "type": "pattern",
      "pattern": "(return|yield)\\s+[\\\"'][A-Z].{30,}[\\\"']",
      "exclude_files": [
        "testing/*",
        "code_guardian.py"
      ]
    },
    {
      "id": "P4-GOD-CLASS",
      "name": "God class (>15 public methods)",
      "description": "P8/P4: classes should be small and focused",
      "category": "P4",
      "severity": "warning",
      "type": "metric",
      "metric": "class_public_methods",
      "threshold": 15
    },
    {
      "id": "P7-LOCAL-STORAGE",
      "name": "Forbidden storage",
      "description": "Memory must use M module (MemoryStore/MemoryRAG), not localStorage/shelve/pickle",
      "category": "P7",
      "severity": "error",
      "type": "pattern",
      "pattern": "\\b(localStorage|sessionStorage|shelve\\.open)\\b",
      "exclude_files": [
        "testing/*",
        "verify_philosophy.py",
        "code_guardian.py",
        "code_rules.json"
      ]
    },
    {
      "id": "P7-PICKLE",
      "name": "Pickle usage",
      "description": "Pickle is unsafe and violates P7 (use SQLite/JSON instead)",
      "category": "P7",
      "severity": "error",
      "type": "pattern",
      "pattern": "\\bpickle\\.(dump|load|dumps|loads)\\b",
      "exclude_files": [
        "testing/*"
      ]
    },
    {
      "id": "P8-FILE-SIZE",
      "name": "Large file",
      "description": "Files >800 lines should be split (P8: Division > Integration)",
      "category": "P8",
      "severity": "warning",
      "type": "metric",
      "metric": "line_count",
      "threshold": 800,
      "exclude_files": [
        "testing/*"
      ]
    },
    {
      "id": "SEC-EVAL",
      "name": "Dangerous eval/exec",
      "description": "eval() and exec() are security risks outside sandboxes",
      "category": "Security",
      "severity": "error",
      "type": "pattern",
      "pattern": "\\b(eval|exec)\\s*\\(",
      "exclude_pattern": "\\.\\s*(eval|exec)\\s*\\(|['\\\"].*eval|BLOCKED_PATTERNS",
      "exclude_files": [
        "testing/*",
        "agent_tools.py",
        "skills/*",
        "code_guardian.py",
        "verify_philosophy.py",
        "engine_adapter.py",
        "security_audit.py"
      ]
    },
    {
      "id": "SEC-SHELL-INJECT",
      "name": "Shell injection risk",
      "description": "os.system() and subprocess with shell=True are injection risks",
      "category": "Security",
      "severity": "error",
      "type": "pattern",
      "pattern": "\\b(os\\.system|subprocess\\.call.*shell\\s*=\\s*True)\\b",
      "exclude_files": [
        "testing/*",
        "agent_tools.py",
        "skills/*",
        "verify_philosophy.py",
        "code_guardian.py",
        "cli_dashboard.py",
        "security_audit.py"
      ]
    },
    {
      "id": "QUAL-BARE-EXCEPT",
      "name": "Bare except (swallows errors)",
      "description": "except Exception: pass silently swallows errors — log or handle",
      "category": "Quality",
      "severity": "info",
      "type": "pattern",
      "pattern": "except\\s+Exception\\s*:\\s*$"
    },
    {
      "id": "QUAL-TODO-FIXME",
      "name": "TODO/FIXME remaining",
      "description": "Unresolved TODO or FIXME in code",
      "category": "Quality",
      "severity": "info",
      "type": "pattern",
      "pattern": "#\\s*(TODO|FIXME|HACK|XXX)\\b"
    },
    {
      "id": "AUTO-API-KEY",
      "name": "External API dependency",
      "description": "Goal is zero external API — track all API key references",
      "category": "Autonomy",
      "severity": "info",
      "type": "pattern",
      "pattern": "(API_KEY|api_key|ANTHROPIC_API|OPENAI_API)",
      "exclude_files": [
        "testing/*",
        "code_guardian.py"
      ]
    }
  ]
}