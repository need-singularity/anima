fn lens_meta(scanner: &PhilosophyScanner) -> LensResult {
    // Meta-analysis: are the lenses themselves consistent?
    let mut findings = []
    let mut score = 1.0
    // Verify 12 lenses cover all aspects
    if len(LENSES) < 12 {
        append(findings, "Less than 12 lenses active")
        score = score - 0.1
    }
    LensResult { lens: "meta", score: score, findings: findings, discoveries: [], data: {} }
}

fn scan_agent(scanner: &PhilosophyScanner, agent: &AnimaAgent) -> PhilosophyReport {
    // Live agent scan -- run all lenses against a running agent
    full_scan(scanner)
}

fn print_philosophy_report(report: &PhilosophyReport) {
    println("")
    println("=== Philosophy Report ===")
    println("  Overall: " + to_string(report_overall_score(report)))
    println("  Discoveries: " + to_string(len(report.discoveries)))
    println("  Duration: " + to_string(report.duration_ms) + "ms")
    for r in report.results {
        println("  [" + r.lens + "] " + to_string(r.score))
    }
    println("=========================")
}

fn main() {
    let scanner = new_philosophy_scanner()
    let report = full_scan(&scanner)
    print_philosophy_report(&report)
}
