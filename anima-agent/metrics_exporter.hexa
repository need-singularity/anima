// metrics_exporter.hexa -- Prometheus metrics exporter for Anima agent
// Port of metrics_exporter.py
// Exposes HTTP endpoint on :9090 for Prometheus scraping

comptime const REGIMES = ["CALM", "NORMAL", "ELEVATED", "CRITICAL"]

struct Metric {
    name: string,
    help_text: string,
    metric_type: string,
    value: float,
    enum_state: string,
    enum_values: array,
}

fn new_metric(name: string, help_text: string, metric_type: string) -> Metric {
    Metric {
        name: name,
        help_text: help_text,
        metric_type: metric_type,
        value: 0.0,
        enum_state: "",
        enum_values: [],
    }
}

fn metric_set(m: &mut Metric, value: float) {
    m.value = value
}

fn metric_inc(m: &mut Metric, amount: float) {
    m.value = m.value + amount
}

fn metric_set_enum(m: &mut Metric, state: string) {
    m.enum_state = state
}

fn metric_format(m: &Metric) -> string {
    let mut lines = []
    append(lines, "# HELP " + m.name + " " + m.help_text)
    if m.metric_type == "enum" {
        append(lines, "# TYPE " + m.name + " gauge")
        for val in m.enum_values {
            let v = if val == m.enum_state { "1" } else { "0" }
            append(lines, m.name + "{state=\"" + val + "\"} " + v)
        }
    } else {
        append(lines, "# TYPE " + m.name + " " + m.metric_type)
        append(lines, m.name + " " + to_string(m.value))
    }
    join(lines, "\n")
}

struct MetricsRegistry {
    metrics: map,
}

fn new_metrics_registry() -> MetricsRegistry {
    let mut reg = MetricsRegistry { metrics: {} }
    reg.metrics["anima_phi_current"] = new_metric("anima_phi_current", "Current Phi value", "gauge")
    reg.metrics["anima_tension_current"] = new_metric("anima_tension_current", "Current tension", "gauge")
    reg.metrics["anima_cells_total"] = new_metric("anima_cells_total", "Number of cells", "gauge")
    reg.metrics["anima_interactions_total"] = new_metric("anima_interactions_total", "Total interactions", "counter")
    reg.metrics["anima_trading_pnl_total"] = new_metric("anima_trading_pnl_total", "Portfolio P&L", "gauge")
    reg.metrics["anima_pain_current"] = new_metric("anima_pain_current", "VaR pain signal", "gauge")
    reg.metrics["anima_action_gate"] = new_metric("anima_action_gate", "Action gate value", "gauge")

    let mut regime = new_metric("anima_regime_current", "Current consciousness regime", "enum")
    regime.enum_values = REGIMES
    regime.enum_state = "CALM"
    reg.metrics["anima_regime_current"] = regime
    reg
}

fn format_all_metrics(reg: &MetricsRegistry) -> string {
    let mut parts = []
    for name, m in reg.metrics {
        append(parts, metric_format(&m))
    }
    join(parts, "\n\n") + "\n"
}

struct MetricsExporter {
    registry: MetricsRegistry,
    running: bool,
}

fn new_metrics_exporter() -> MetricsExporter {
    MetricsExporter {
        registry: new_metrics_registry(),
        running: false,
    }
}

fn exporter_poll(exporter: &mut MetricsExporter, agent_status: map, trading_status: map) {
    if len(agent_status) > 0 {
        metric_set(&mut exporter.registry.metrics["anima_phi_current"], agent_status["phi"])
        metric_set(&mut exporter.registry.metrics["anima_tension_current"], agent_status["tension"])
        metric_set(&mut exporter.registry.metrics["anima_cells_total"], agent_status["cells"])
        metric_set(&mut exporter.registry.metrics["anima_interactions_total"], agent_status["interactions"])
    }
    if len(trading_status) > 0 {
        metric_set(&mut exporter.registry.metrics["anima_trading_pnl_total"], trading_status["pnl"])
        metric_set(&mut exporter.registry.metrics["anima_pain_current"], trading_status["pain"])
    }
}

fn exporter_start(exporter: &mut MetricsExporter, port: int, blocking: bool) {
    // TODO[python-sdk]: HTTPServer with MetricsHandler
    println("Prometheus metrics exporter started on :" + to_string(port) + "/metrics")
    exporter.running = true
}

fn exporter_stop(exporter: &mut MetricsExporter) {
    exporter.running = false
}

fn main() {
    println("=== Anima Prometheus Metrics Exporter ===")
    let mut exporter = new_metrics_exporter()
    exporter_start(&mut exporter, 9090, true)
}
