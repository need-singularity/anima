// providers/__init__.hexa -- Pluggable LLM backends for consciousness-driven generation
// Port of providers/__init__.py

// Provider registry
comptime const PROVIDERS = {
    "animalm": "AnimaLMProvider",
    "claude": "ClaudeProvider",
    "conscious-lm": "ConsciousLMProvider",
}

fn get_best_provider(config: ProviderConfig) -> string {
    // Try AnimaLM first (independence goal), then Claude
    // TODO[python-sdk]: check checkpoint existence, API key availability
    "claude"
}

fn get_provider(name: string, config: ProviderConfig) -> string {
    if has_key(PROVIDERS, name) {
        return PROVIDERS[name]
    }
    "ClaudeProvider"
}

fn main() {
    println("providers module loaded: " + to_string(len(PROVIDERS)) + " providers")
}
