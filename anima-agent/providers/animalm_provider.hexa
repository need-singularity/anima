struct AnimaLMProvider {
    config: ProviderConfig,
    checkpoint_path: string,
    model_loaded: bool,
    vocab_size: int,
    memory_store: any,
    memory_rag: any,
}

fn new_animalm_provider(config: ProviderConfig) -> AnimaLMProvider {
    let checkpoint = discover_checkpoint()
    AnimaLMProvider {
        config: config,
        checkpoint_path: checkpoint,
        model_loaded: false,
        vocab_size: 0,
        memory_store: null,
        memory_rag: null,
    }
}

