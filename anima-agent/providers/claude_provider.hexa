    let last_msg = if len(messages) > 0 { messages[len(messages) - 1] } else { ProviderMessage{role:"user", content:""} }
    let text = last_msg.content

    let mut history = []
    for m in messages {
        if m.role != "system" {
            append(history, {"role": m.role, "content": m.content})
        }
    }

    // TODO[python-sdk]: from anima_alive import ask_claude
    // return ask_claude(text, system, history)
