struct ClaudeProvider {
    config: ProviderConfig,
    available: bool,
}

fn new_claude_provider(config: ProviderConfig) -> ClaudeProvider {
    // TODO[python-sdk]: check ANTHROPIC_API_KEY env var
    ClaudeProvider {
        config: config,
        available: false,
    }
}

fn claude_name() -> string { "claude" }

fn claude_is_available(provider: &ClaudeProvider) -> bool {
    provider.available
}

async fn claude_query(provider: &ClaudeProvider, messages: array,
                      system: string, consciousness_state: map,
                      max_tokens: int) -> string {
