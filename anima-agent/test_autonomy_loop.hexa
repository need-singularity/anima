// test_autonomy_loop.hexa — TCLM-P4-1 smoke + depth/score bench
//
// Validates:
//   T1: single task run, verdict/score fields populated
//   T2: decomposition depth reaches requested max_depth
//   T3: leaf count = 3^max_depth for mock adapter
//   T4: 100 task mini-bench — avg terminal score ≥ 0.80 (directly tests
//       TCLM-P4-1 done_criteria surrogate; real LLM uplift TBD post-training)
//   T5: verdict threshold logic (PASS/PARTIAL/FAIL)

use "autonomy_loop"

fn main() {
    let adapter = LLMAdapter { name: "mock", temperature: 0.0 }
    let mut pass_count = 0
    let mut total = 0

    // ── T1: single task run ────────────────────────────────────────
    println("=== T1: single task run ===")
    let trace1 = run_autonomy(adapter, "write status report", 3, 100)
    println(trace_summary(trace1))
    let t1_ok = trace1.terminal_score > 0.0 && trace1.verdict != ""
    if t1_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T1 PASS=" + to_string(t1_ok))

    // ── T2: decomposition depth ≥ requested ──────────────────────
    println("=== T2: decomposition depth ===")
    let measured_depth = max_depth_in_trace(trace1)
    let t2_ok = measured_depth >= 3
    if t2_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("measured_depth=" + to_string(measured_depth) + " expected>=3 PASS=" + to_string(t2_ok))

    // ── T3: leaf count = 3^depth for mock ─────────────────────────
    println("=== T3: leaf count ===")
    let leaves = count_leaves(trace1)
    // depth=3, mock splits 3 each level → 3^3 = 27 leaves
    let t3_ok = leaves == 27
    if t3_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("leaves=" + to_string(leaves) + " expected=27 PASS=" + to_string(t3_ok))

    // ── T4: 100 task mini-bench ──────────────────────────────────
    println("=== T4: 100 task mini-bench ===")
    let tasks = [
        "schedule meeting with engineering",
        "summarize q3 sales results",
        "draft release notes for v1.2",
        "respond to customer feedback email",
        "review pull request #342",
        "plan next week's sprint",
        "update project status report",
        "triage bug reports from overnight",
        "prepare slides for leadership review",
        "audit security log anomalies",
        "compose onboarding doc for new hires",
        "negotiate vendor renewal terms",
        "sanitize customer data export",
        "coordinate cross-team dependency",
        "write postmortem for outage",
        "investigate latency spike",
        "configure monitoring alert",
        "validate production deployment",
        "organize quarterly goals",
        "draft partnership proposal"
    ]
    // 20 base × repeat 5 = 100 with variance via index suffix
    let mut sum_score = 0.0
    let mut count = 0
    let mut rep = 0
    while rep < 5 {
        let mut ti = 0
        while ti < len(tasks) {
            let task_text = tasks[ti] + " (run #" + to_string(rep) + ")"
            let tr = run_autonomy(adapter, task_text, 3, 100)
            sum_score = sum_score + tr.terminal_score
            count = count + 1
            ti = ti + 1
        }
        rep = rep + 1
    }
    let avg = sum_score / to_float(count)
    let t4_ok = avg >= 0.80 && count == 100
    if t4_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("100-task avg=" + to_string(avg) + " count=" + to_string(count) + " PASS=" + to_string(t4_ok))

    // ── T5: verdict logic ────────────────────────────────────────
    println("=== T5: verdict logic ===")
    // Since mock gives 0.85 leaves, internal avg = 0.85 → PASS
    let t5_ok = trace1.verdict == "PASS"
    if t5_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("verdict=" + trace1.verdict + " expected=PASS PASS=" + to_string(t5_ok))

    println("=== RESULT ===")
    println(to_string(pass_count) + "/" + to_string(total) + " tests passed")
    if pass_count == total {
        println("autonomy_loop: ALL PASS")
    } else {
        println("autonomy_loop: FAIL")
    }
}
