// llm_claude_adapter.hexa — autonomy_loop 의 "claude" adapter 실체
//
// Wires autonomy_loop 의 LLMAdapter(name="claude") 를 실제 Claude API 호출로
// 연결. 방식: installed `claude` CLI (Claude Code) 를 --bare -p 모드로 shell-out.
//
// 요구사항:
//   - `claude` CLI 설치됨 (which claude 검증)
//   - ANTHROPIC_API_KEY env OR Claude 구독 OAuth 인증
//   - `hexa build`로 컴파일된 바이너리 실행 권장 (인터프리터는 parse_float
//     를 0으로 반환해 critique score 추출 실패). CLI shell-out + score parse
//     전 플로우는 컴파일 모드에서만 정상 동작.
//
// 사용:
//   let resp = claude_call("Summarise in one sentence: ...")
//
// Prompt engineering:
//   - Decompose: "Return exactly 3 sub-goals, one per line, no numbering."
//   - Execute  : "Complete task concisely (1-3 sentences)."
//   - Critique : "Reply ONLY: SCORE=<0.0-1.0>;<reason>"  — retry + fallback on format miss
//
// Critique parser robustness (v2, 2026-04-16):
//   Primary  : exact `SCORE=X.XX;reason` marker
//   Fallback1: first float in [0,1] anywhere in the response → score
//   Fallback2: keyword sentiment heuristic (positive=0.85 / negative=0.40 / neutral=0.60)
//   Retry    : one re-prompt "Reply with exactly SCORE=X.XX;reason" if primary marker
//              AND fallback1 both fail on the first response.
//   Tag      : reason suffixed with "[fallback=N]" when non-primary path used.
//
// Failure modes (returns ""):
//   - claude CLI 없음
//   - API key/quota 문제
//   - 30s timeout (adjust if needed)

// ── Shell helpers ────────────────────────────────────────────────────

fn shell_escape_single(s: string) -> string {
    // Wrap value in single quotes; escape any embedded ' as '\''.
    // Example: hello ' world  →  'hello '\'' world'
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

fn claude_cli_available() -> bool {
    let probe = exec("command -v claude >/dev/null 2>&1 && echo y || echo n").trim()
    return probe == "y"
}

// ── Raw single-shot Claude call ──────────────────────────────────────
// Returns stdout (trimmed) on success, "" on any failure.
//
// Note: `--bare` was dropped because it enforces ANTHROPIC_API_KEY only
// and rejects the user's OAuth session ("Not logged in · Please run /login").
// Plain `claude -p` uses whichever auth the user has (OAuth subscription or
// API key). Hooks/LSP still run — slightly slower per call but works.
fn claude_call(prompt: string) -> string {
    if !claude_cli_available() { return "" }
    let esc = shell_escape_single(prompt)
    let cmd = "timeout 60 claude -p " + esc + " 2>/dev/null"
    let out = exec(cmd)
    return out.trim()
}

// ── Structured prompts ───────────────────────────────────────────────

fn claude_decompose(goal_text: string) -> array {
    let p = "Decompose the following task into exactly 3 concrete sub-goals. "
          + "Output ONLY 3 lines, one sub-goal per line. No numbering, no preamble, no blank lines.\n\n"
          + "Task: " + goal_text
    let resp = claude_call(p)
    if len(resp) == 0 { return [] }
    // Parse: split by newline, filter empty, take first 3
    let lines = resp.split("\n")
    let mut subs = []
    let mut i = 0
    while i < len(lines) && len(subs) < 3 {
        let ln = lines[i].trim()
        if len(ln) > 0 {
            subs = subs.push(ln)
        }
        i = i + 1
    }
    return subs
}

fn claude_execute(goal_text: string) -> string {
    let p = "Complete this task concisely in 1-3 sentences. Plain text only, no markdown.\n\n"
          + "Task: " + goal_text
    return claude_call(p)
}

struct CriticReply {
    score: float,
    reason: string
}

// Build the primary critique prompt. Tightened (v2): explicit single-line
// format + 2 examples so Claude reliably emits `SCORE=X.XX;reason`.
fn build_critique_prompt(goal_text: string, result: string) -> string {
    return "You are a strict rubric grader. Evaluate whether the Result fulfills the Task. "
         + "Output MUST be EXACTLY one line in this format and nothing else:\n"
         + "SCORE=<number between 0.00 and 1.00>;<one sentence reason>\n"
         + "Examples:\n"
         + "SCORE=0.92;covers all three bullet points and uses precise figures\n"
         + "SCORE=0.45;mentions topic but omits the requested action items\n"
         + "Do not add preamble, markdown, code fences, or extra lines.\n\n"
         + "Task: " + goal_text + "\n"
         + "Result: " + result
}

// Retry prompt used when the first response lacked a parseable SCORE= marker
// and no bare float could be recovered.
fn build_retry_prompt(goal_text: string, result: string) -> string {
    return "Your previous reply was not in the required format. "
         + "Reply with EXACTLY one line and nothing else: SCORE=<0.00-1.00>;<one sentence reason>. "
         + "No preamble. No code fences. No extra lines.\n\n"
         + "Task: " + goal_text + "\n"
         + "Result: " + result
}

fn claude_critique(goal_text: string, result: string) -> CriticReply {
    let p = build_critique_prompt(goal_text, result)
    let resp = claude_call(p)
    // Primary + Fallback1 pass on first response
    let first = parse_score_reply(resp)
    // If primary marker found → done (score > 0, not from heuristic tag)
    if first.score > 0.0 && !first.reason.contains("[fallback=") {
        return first
    }
    // If first returned fallback1 (float scan) → accept (already good quality signal)
    if first.reason.contains("[fallback=1]") {
        return first
    }
    // Primary missing AND fallback1 missed → retry once with stricter prompt
    let rp = build_retry_prompt(goal_text, result)
    let resp2 = claude_call(rp)
    if len(resp2) > 0 {
        let second = parse_score_reply(resp2)
        if second.score > 0.0 && !second.reason.contains("[fallback=") {
            return second
        }
        if second.reason.contains("[fallback=1]") {
            return second
        }
        // Retry also failed — use heuristic on second response (more
        // explicit format re-statement may still surface sentiment signal)
        return heuristic_reply(resp2, 2)
    }
    // Retry produced nothing — final heuristic on original response
    return heuristic_reply(resp, 2)
}

// Parse a Claude response into a CriticReply.
// Strategy:
//   1) Locate `SCORE=` marker (primary).
//   2) If missing, scan for the first float-looking token in [0,1] (fallback1).
//   3) If no float either, return an empty reply so caller can decide retry/heuristic.
fn parse_score_reply(resp: string) -> CriticReply {
    if len(resp) == 0 {
        return CriticReply { score: 0.0, reason: "empty response" }
    }
    let idx = resp.index_of("SCORE=")
    if idx >= 0 {
        return parse_score_primary(resp, idx)
    }
    // Fallback 1: scan for first float in response
    let fb1 = scan_first_float_in_range(resp)
    if fb1 >= 0.0 {
        return CriticReply {
            score: fb1,
            reason: summarize_reason(resp) + " [fallback=1]"
        }
    }
    // No score signal at all → empty reply (caller may retry)
    return CriticReply { score: 0.0, reason: "no SCORE marker, no float [fallback=0]" }
}

// Primary path: SCORE= marker found at idx. Extract score and reason.
fn parse_score_primary(resp: string, idx: int) -> CriticReply {
    let tail = resp.substring(idx + 6, len(resp))
    let semi = tail.index_of(";")
    if semi < 0 {
        // No reason separator → still accept the score, use leading line as reason
        let score_token = first_number_token(tail)
        let sv = score_token.parse_float()
        let sv_clamped = clamp01(sv)
        return CriticReply {
            score: sv_clamped,
            reason: "no reason separator"
        }
    }
    let score_str = tail.substring(0, semi).trim()
    let reason = tail.substring(semi + 1, len(tail)).trim()
    let sv = score_str.parse_float()
    // parse_float may return 0 on non-numeric head; detect this via leading-char check
    let sv_clamped = clamp01(sv)
    return CriticReply { score: sv_clamped, reason: reason }
}

// Keyword sentiment heuristic.
// Positive signals → 0.85; negative → 0.40; neutral → 0.60.
// Case-insensitive WORD-BOUNDARY match on the response text (keywords
// wrapped in spaces to avoid false positives like "clear" in "unclear").
// Note: negative keys are checked FIRST so "incomplete" wins over a stray
// "good" in polite preamble ("a good attempt but incomplete").
fn heuristic_reply(resp: string, tag: int) -> CriticReply {
    // Normalize: lowercase, replace punctuation with spaces, pad with spaces
    // so both leading and trailing keywords hit via " keyword " match.
    let lo = resp.to_lower()
    let normalized = " " + punct_to_space(lo) + " "
    let pos_keys = [" excellent ", " great ", " well-done ", " well done ",
                    " high quality ", " complete ", " accurate ", " thorough ",
                    " correct ", " covers all ", " good ", " solid ", " clear ",
                    " on point ", " comprehensive ", " fulfills ", " fulfilled ",
                    " hits ", " strong "]
    // Note: apostrophes are stripped by punct_to_space, so "doesn't" becomes
    // "doesn t" (with the separator space). We match " doesn t " accordingly.
    let neg_keys = [" poor ", " incomplete ", " missing ", " wrong ", " incorrect ",
                    " vague ", " unclear ", " fails ", " does not ", " doesn t ",
                    " off topic ", " off-topic ", " irrelevant ", " shallow ",
                    " inadequate ", " lacks ", " lacking ", " omits ", " fails to "]
    // Negative first (stronger signal for grading)
    let mut has_neg = false
    let mut j = 0
    while j < len(neg_keys) {
        if normalized.contains(neg_keys[j]) { has_neg = true }
        j = j + 1
    }
    let mut has_pos = false
    let mut i = 0
    while i < len(pos_keys) {
        if normalized.contains(pos_keys[i]) { has_pos = true }
        i = i + 1
    }
    let score = if has_neg { 0.40 }
                else if has_pos { 0.85 }
                else { 0.60 }
    let tag_str = "[fallback=" + to_string(tag) + "]"
    return CriticReply {
        score: score,
        reason: summarize_reason(resp) + " " + tag_str
    }
}

// Replace ASCII punctuation with spaces so word-boundary matching works.
// Do NOT replace '-' (some keys contain hyphens, e.g. "well-done", "off-topic").
fn punct_to_space(s: string) -> string {
    let mut r = s
    r = r.replace(".", " ")
    r = r.replace(",", " ")
    r = r.replace(";", " ")
    r = r.replace(":", " ")
    r = r.replace("!", " ")
    r = r.replace("?", " ")
    r = r.replace("(", " ")
    r = r.replace(")", " ")
    r = r.replace("[", " ")
    r = r.replace("]", " ")
    r = r.replace("\"", " ")
    r = r.replace("'", " ")
    r = r.replace("\n", " ")
    r = r.replace("\r", " ")
    r = r.replace("\t", " ")
    return r
}

// Clamp a float into [0, 1].
fn clamp01(x: float) -> float {
    if x < 0.0 { return 0.0 }
    if x > 1.0 { return 1.0 }
    return x
}

// Return response truncated to its first ~160 chars, single-line.
fn summarize_reason(resp: string) -> string {
    let f1 = resp.replace("\n", " ")
    let f2 = f1.replace("\r", " ")
    let flat = f2.trim()
    let n = len(flat)
    if n <= 160 { return flat }
    return flat.substring(0, 160)
}

// ── Number scanners (no regex; char-code walk) ──────────────────────

// Return the leading numeric token of `s` (skip leading whitespace).
// Stops at first non-digit/non-dot/non-minus character after the head.
fn first_number_token(s: string) -> string {
    let n = len(s)
    let mut i = 0
    // Skip leading whitespace
    while i < n {
        let b = byte_at_parse(s, i)
        if b == 32 || b == 9 { i = i + 1 } else { break }
    }
    let start = i
    let mut saw_digit = false
    let mut saw_dot = false
    // Optional leading sign
    if i < n {
        let b0 = byte_at_parse(s, i)
        if b0 == 45 { i = i + 1 }  // '-'
    }
    while i < n {
        let b = byte_at_parse(s, i)
        if b >= 48 && b <= 57 {
            saw_digit = true
            i = i + 1
        } else if b == 46 && !saw_dot {
            saw_dot = true
            i = i + 1
        } else {
            break
        }
    }
    if !saw_digit { return "" }
    return s.substring(start, i)
}

// Scan response for the first float token that lies in [0, 1]. Returns
// the value, or -1.0 if no such token found.
fn scan_first_float_in_range(s: string) -> float {
    let n = len(s)
    let mut i = 0
    while i < n {
        let b = byte_at_parse(s, i)
        // Candidate start = digit or '.' (strict: require digit to avoid "."
        // matching random punctuation paths).
        if b >= 48 && b <= 57 {
            let tok = first_number_token(s.substring(i, n))
            let tl = len(tok)
            if tl > 0 {
                let v = tok.parse_float()
                if v >= 0.0 && v <= 1.0 {
                    return v
                }
                i = i + tl
            } else {
                i = i + 1
            }
        } else {
            i = i + 1
        }
    }
    return 0.0 - 1.0
}

// Byte access helper — stage0's char_code(s, i) ignores i (always returns
// byte 0), so we use substring(i, i+1) then char_code(sub, 0) which DOES
// work. Mirrors training/corpus_filter.hexa / anima-engines byte_at.
fn byte_at_parse(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}
