// discovery_loop.hexa -- Unified philosophy + consciousness discovery pipeline
// Port of discovery_loop.py
// 7-phase cycle: simulation, NEXUS-6, philosophy, verification, contradiction, guardian, register

comptime const LAWS_PATH = "~/Dev/anima/anima/config/consciousness_laws.json"

struct Discovery {
    source: string,
    category: string,
    description: string,
    evidence: string,
    confidence: float,
    data: map,
}

struct CycleReport {
    cycle: int,
    discoveries: array,
    philosophy_score: float,
    code_errors: int,
    n6_active_lenses: int,
    n6_consensus: int,
    duration_ms: float,
}

fn cycle_discovery_count(report: &CycleReport) -> int {
    len(report.discoveries)
}

struct DiscoveryLoop {
    auto_register: bool,
    laws_path: string,
    cycle_count: int,
    all_discoveries: array,
}

fn new_discovery_loop(auto_register: bool, laws_path: string) -> DiscoveryLoop {
    DiscoveryLoop {
        auto_register: auto_register,
        laws_path: if laws_path != "" { laws_path } else { LAWS_PATH },
        cycle_count: 0,
        all_discoveries: [],
    }
}

fn run_cycle(loop_state: &mut DiscoveryLoop) -> CycleReport {
    let t0 = time_now()
    loop_state.cycle_count = loop_state.cycle_count + 1
    let mut report = CycleReport {
        cycle: loop_state.cycle_count,
        discoveries: [],
        philosophy_score: 0.0,
        code_errors: 0,
        n6_active_lenses: 0,
        n6_consensus: 0,
        duration_ms: 0.0,
    }

    // Phase 1: Consciousness simulation
    let sim_discoveries = phase_simulation()
    for d in sim_discoveries { append(report.discoveries, d) }

    // Phase 2: NEXUS-6 scan
    let n6_discoveries = phase_nexus_scan()
    for d in n6_discoveries { append(report.discoveries, d) }

    // Phase 3: Philosophy lenses
    let phil_result = phase_philosophy()
    report.philosophy_score = phil_result["score"]
    for d in phil_result["discoveries"] { append(report.discoveries, d) }

    // Phase 4: Boundary/negation verification
    let verify_discoveries = phase_verification()
    for d in verify_discoveries { append(report.discoveries, d) }

    // Phase 5: Contradiction detection
    let contra_discoveries = phase_contradiction()
    for d in contra_discoveries { append(report.discoveries, d) }

    // Phase 6: Code Guardian
    let code_info = phase_code_guardian()
    report.code_errors = code_info["errors"]

    // Phase 7: Auto-register high-confidence discoveries
    if loop_state.auto_register && len(report.discoveries) > 0 {
        let registered = phase_register(report.discoveries, loop_state.laws_path, loop_state.cycle_count)
        println("Auto-registered " + to_string(registered) + " discoveries")
    }

    report.duration_ms = (time_now() - t0) * 1000.0

    for d in report.discoveries {
        append(loop_state.all_discoveries, d)
    }

    println("Cycle " + to_string(loop_state.cycle_count) + ": " +
            to_string(cycle_discovery_count(&report)) + " discoveries in " +
            to_string(report.duration_ms) + "ms")

    report
}

fn run_cycles(loop_state: &mut DiscoveryLoop, n: int) -> array {
    let mut reports = []
    for i in range(n) {
        let report = run_cycle(loop_state)
        append(reports, report)
    }
    reports
}

