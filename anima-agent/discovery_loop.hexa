fn print_report(report: &CycleReport) {
    println("")
    println("============================================================")
    println("  Discovery Loop -- Cycle " + to_string(report.cycle))
    println("============================================================")
    println("  Duration:    " + to_string(report.duration_ms) + "ms")
    println("  Discoveries: " + to_string(cycle_discovery_count(report)))
    println("  Philosophy:  " + to_string(report.philosophy_score))
    println("  Code:        " + to_string(report.code_errors) + " errors")
    println("  NEXUS-6:     " + to_string(report.n6_active_lenses) + " lenses, " +
            to_string(report.n6_consensus) + " consensus")
    println("============================================================")
}

fn main() {
    println("Discovery Loop")
    let mut loop_state = new_discovery_loop(false, "")
    let report = run_cycle(&mut loop_state)
    print_report(&report)
}
