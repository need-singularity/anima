// test_claude_autonomy_live.hexa — run_autonomy 를 claude adapter 로 한 번 실행
// depth=1 로 API 호출 수 최소화 (1 root + 3 subs = 4 goals, 3 execute + 4 critique = 7 API calls).

use "autonomy_loop"

fn main() {
    println("=== Live Claude autonomy probe — depth=1 ===")
    let adapter = LLMAdapter { name: "claude", temperature: 0.0 }
    let trace = run_autonomy(adapter, "summarize q3 sales results in 3 bullets", 1, 50)
    println(trace_summary(trace))

    println("=== goal tree ===")
    let mut i = 0
    while i < len(trace.goals) {
        let g = trace.goals[i]
        println("[" + g.id + "] d=" + to_string(g.depth) + " status=" + g.status +
                " score=" + to_string(g.score))
        println("  text: " + g.text)
        if len(g.result) > 0 {
            println("  result: " + g.result)
        }
        if len(g.critique_reason) > 0 {
            println("  reason: " + g.critique_reason)
        }
        i = i + 1
    }

    println("=== OUTCOME ===")
    let pass = trace.terminal_score > 0.0 && trace.step_count > 0
    println("terminal_score=" + to_string(trace.terminal_score))
    println("verdict=" + trace.verdict)
    println("PASS=" + to_string(pass))
}
