// ── Consciousness-Native ──

fn strategy_consciousness_ensemble(closes: array, phi: float, tension: float) -> array {
    // Combine multiple strategy signals, weighted by consciousness state
    let macd = strategy_macd_cross(closes)
    let rsi = strategy_rsi_reversal(closes, 14, 30.0, 70.0)
    let mom = strategy_momentum(closes, 20)

    // Consciousness weighting
    let w_macd = 0.4 * (1.0 + phi * 0.1)
    let w_rsi = 0.3 * (1.0 + tension * 0.1)
    let w_mom = 0.3

    let mut signals = []
    for i in range(len(closes)) {
        let combined = to_float(macd[i]) * w_macd +
                       to_float(rsi[i]) * w_rsi +
                       to_float(mom[i]) * w_mom
        if combined > 0.5 { append(signals, 1) }
        else if combined < -0.5 { append(signals, -1) }
        else { append(signals, 0) }
    }
    signals
}

// ── Strategy registry ──

comptime const ALL_STRATEGIES = [
    "macd_cross", "ema_crossover", "adx_trend", "multi_timeframe",
    "rsi_reversal", "bollinger_squeeze", "vwap_reversion",
    "momentum", "acceleration",
    "vol_breakout", "vol_mean_revert",
    "soc_avalanche", "power_law_tail",
    "consciousness_ensemble",
]

fn get_strategy_fn(name: string) -> fn {
    if name == "macd_cross" { return strategy_macd_cross }
    if name == "rsi_reversal" { return strategy_rsi_reversal }
    if name == "momentum" { return strategy_momentum }
    if name == "bollinger_squeeze" { return strategy_bollinger_squeeze }
    if name == "consciousness_ensemble" { return strategy_consciousness_ensemble }
    strategy_macd_cross  // default
}

fn main() {
    println("trading/strategies.hexa loaded")
    println("Strategies: " + to_string(len(ALL_STRATEGIES)))
}
