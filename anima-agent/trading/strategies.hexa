fn strategy_macd_cross(closes: array) -> array {
    // MACD crossover: EMA(12) - EMA(26), signal = EMA(9) of MACD
    let mut signals = []
    // TODO[python-sdk]: calculate EMA, MACD line, signal line
    for i in range(len(closes)) {
        append(signals, 0)  // 0=hold, 1=buy, -1=sell
    }
    signals
}

