// ── Momentum ──

fn strategy_momentum(closes: array, lookback: int) -> array {
    // Time-series momentum: buy if return over lookback is positive
    let mut signals = []
    for i in range(len(closes)) {
        if i >= lookback {
            let ret = (closes[i] - closes[i - lookback]) / closes[i - lookback]
            if ret > 0.02 { append(signals, 1) }
            else if ret < -0.02 { append(signals, -1) }
            else { append(signals, 0) }
        } else {
            append(signals, 0)
        }
    }
    signals
}

