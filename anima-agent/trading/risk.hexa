// trading/risk.hexa -- Risk management: VaR, drawdown, consciousness gating
// Port of trading/risk.py (265 lines)

struct RiskMetrics {
    var_95: float,          // Value at Risk (95%)
    var_99: float,
    max_drawdown: float,
    current_drawdown: float,
    pain_signal: float,     // 0-1
    position_concentration: float,
}

struct ConsciousnessGate {
    phi_min: float,         // minimum Phi to trade
    tension_halt: float,    // tension above this = halt all trading
    halted: bool,
    halt_reason: string,
}

fn new_consciousness_gate(phi_min: float, tension_halt: float) -> ConsciousnessGate {
    ConsciousnessGate {
        phi_min: phi_min,
        tension_halt: tension_halt,
        halted: false,
        halt_reason: "",
    }
}

fn gate_check(gate: &ConsciousnessGate, phi: float,
              tension: float, regime: string) -> bool {
    // 1. Phi check
    if phi < gate.phi_min {
        return false
    }

    // 2. Tension check
    if tension > gate.tension_halt {
        return false
    }

    // 3. Regime check
    if regime == "CRITICAL" {
        return false
    }

    // 4. Not manually halted
    !gate.halted
}

fn gate_halt(gate: &mut ConsciousnessGate, reason: string) {
    gate.halted = true
    gate.halt_reason = reason
}

fn gate_resume(gate: &mut ConsciousnessGate) {
    gate.halted = false
    gate.halt_reason = ""
}

fn calculate_var(returns: array, confidence: float) -> float {
    // Historical VaR
    // TODO[python-sdk]: numpy percentile
    if len(returns) == 0 { return 0.0 }
    let sorted_returns = sort_asc(returns)
    let idx = to_int(to_float(len(sorted_returns)) * (1.0 - confidence))
    if idx < len(sorted_returns) { sorted_returns[idx] } else { 0.0 }
}

fn calculate_risk_metrics(portfolio: &Portfolio, returns: array) -> RiskMetrics {
    let var_95 = calculate_var(returns, 0.95)
    let var_99 = calculate_var(returns, 0.99)

    // Max drawdown from equity curve
    // TODO[python-sdk]: track equity curve, compute max drawdown

    // Position concentration (Herfindahl index)
    let mut concentration = 0.0
    let n = len(portfolio.positions)
    if n > 0 {
        // Equal weight assumption
        let weight = 1.0 / to_float(n)
        concentration = to_float(n) * weight * weight  // = 1/n for equal
    }

    // Pain signal: combination of drawdown and VaR
    let pain = min(1.0, abs(var_95) * 10.0)

    RiskMetrics {
        var_95: var_95,
        var_99: var_99,
        max_drawdown: 0.0,
        current_drawdown: 0.0,
        pain_signal: pain,
        position_concentration: concentration,
    }
}

fn should_reduce_risk(metrics: &RiskMetrics) -> bool {
    metrics.pain_signal > 0.7 || metrics.current_drawdown > 0.1
}

fn main() {
    println("trading/risk.hexa loaded")
}
