fn generate_sample_data(symbol: string, n: int) -> array {
    // Generate synthetic OHLCV for offline testing
    let mut data = []
    let mut price = 100.0
    for i in range(n) {
        let change = (random() - 0.5) * 2.0
        price = max(1.0, price + change)
        let high = price * (1.0 + random() * 0.02)
        let low = price * (1.0 - random() * 0.02)
        append(data, OHLCV {
            timestamp: time_now() - to_float(n - i) * 3600.0,
            open: price - change * 0.5,
            high: high,
            low: low,
            close: price,
            volume: random() * 1000000.0,
        })
    }
    data
}

fn candles_to_arrays(candles: array) -> map {
    let mut opens = []
    let mut highs = []
    let mut lows = []
    let mut closes = []
    let mut volumes = []
    for c in candles {
        append(opens, c.open)
        append(highs, c.high)
        append(lows, c.low)
        append(closes, c.close)
        append(volumes, c.volume)
    }
    {"open": opens, "high": highs, "low": lows, "close": closes, "volume": volumes}
}

fn main() {
    println("trading/data.hexa loaded")
    let data = generate_sample_data("TEST", 100)
    println("Generated " + to_string(len(data)) + " candles")
}
