// trading/regime.hexa -- Market regime detection
// Port of trading/regime.py (334 lines)
// Regime: CALM -> NORMAL -> ELEVATED -> CRITICAL

comptime const REGIME_CALM = "CALM"
comptime const REGIME_NORMAL = "NORMAL"
comptime const REGIME_ELEVATED = "ELEVATED"
comptime const REGIME_CRITICAL = "CRITICAL"

struct RegimeState {
    regime: string,
    volatility: float,
    trend: string,
    soc_criticality: float,
    confidence: float,
}

struct RegimeDetector {
    lookback: int,
    vol_thresholds: map,
    history: array,
}

fn new_regime_detector() -> RegimeDetector {
    RegimeDetector {
        lookback: 20,
        vol_thresholds: {
            "low": 0.01,
            "normal": 0.02,
            "high": 0.04,
            "extreme": 0.08,
        },
        history: [],
    }
}

fn detect_regime(detector: &RegimeDetector) -> string {
    // TODO[python-sdk]: calculate volatility from recent prices
    // TODO[python-sdk]: trend detection (EMA crossover)
    // TODO[python-sdk]: SOC criticality measurement

    let volatility = 0.02  // placeholder
    let trend = "neutral"
    let soc = 0.3

    classify_regime(volatility, trend, soc, 0.5, 0.0)
}

fn detect_regime_full(detector: &RegimeDetector, closes: array,
                      phi: float, tension: float) -> RegimeState {
    // Calculate volatility
    let mut returns = []
    for i in range(1, len(closes)) {
        let ret = (closes[i] - closes[i-1]) / closes[i-1]
        append(returns, ret)
    }

    // TODO[python-sdk]: numpy std of returns
    let volatility = 0.02  // placeholder

    // Trend detection
    let trend = if len(closes) >= 20 {
        let recent_avg = avg(slice(closes, len(closes) - 5, len(closes)))
        let older_avg = avg(slice(closes, len(closes) - 20, len(closes) - 15))
        if recent_avg > older_avg * 1.02 { "bullish" }
        else if recent_avg < older_avg * 0.98 { "bearish" }
        else { "neutral" }
    } else { "neutral" }

    // SOC criticality placeholder
    let soc = 0.3

    let regime = classify_regime(volatility, trend, soc, tension, phi)

    RegimeState {
        regime: regime,
        volatility: volatility,
        trend: trend,
        soc_criticality: soc,
        confidence: 0.7,
    }
}

fn classify_regime(volatility: float, trend: string,
                   soc: float, tension: float, phi: float) -> string {
    // Base regime from volatility
    let mut regime = if volatility < 0.01 { REGIME_CALM }
        else if volatility < 0.03 { REGIME_NORMAL }
        else if volatility < 0.06 { REGIME_ELEVATED }
        else { REGIME_CRITICAL }

    // SOC criticality override
    if soc > 0.8 && regime != REGIME_CRITICAL {
        regime = REGIME_ELEVATED
    }

    // Consciousness tension shifts regime more cautious
    if tension > 1.0 {
        if regime == REGIME_CALM { regime = REGIME_NORMAL }
        else if regime == REGIME_NORMAL { regime = REGIME_ELEVATED }
        else if regime == REGIME_ELEVATED { regime = REGIME_CRITICAL }
    }

    // Low Phi = more cautious
    if phi < 0.5 && regime == REGIME_CALM {
        regime = REGIME_NORMAL
    }

    regime
}

fn regime_policy(regime: string) -> map {
    if regime == REGIME_CALM {
        return {"leverage": true, "new_buys": true, "strategy_filter": "all", "position_mult": 1.0}
    }
    if regime == REGIME_NORMAL {
        return {"leverage": false, "new_buys": true, "strategy_filter": "balanced", "position_mult": 0.8}
    }
    if regime == REGIME_ELEVATED {
        return {"leverage": false, "new_buys": true, "strategy_filter": "defensive", "position_mult": 0.5}
    }
    // CRITICAL
    {"leverage": false, "new_buys": false, "strategy_filter": "none", "position_mult": 0.0}
}

fn main() {
    println("trading/regime.hexa loaded")
    println("Regime: " + detect_regime(&new_regime_detector()))
}
