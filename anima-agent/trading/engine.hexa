struct BacktestResult {
    symbol: string,
    strategy: string,
    total_return: float,
    sharpe: float,
    max_drawdown: float,
    win_rate: float,
    total_trades: int,
    profit_factor: float,
    candles: int,
    duration_ms: float,
}

struct BacktestEngine {
    symbol: string,
    timeframe: string,
    initial_capital: float,
    commission: float,
}

fn new_backtest_engine(symbol: string, timeframe: string) -> BacktestEngine {
    BacktestEngine {
        symbol: symbol,
        timeframe: timeframe,
        initial_capital: 10000.0,
        commission: 0.001,
    }
}

fn backtest_run(engine: &BacktestEngine, strategy_name: string, days: int) -> BacktestResult {
    let t0 = time_now()

    // 1. Fetch data
    let limit = days * 24  // hourly candles
    // TODO[python-sdk]: fetch_binance_klines or generate_sample_data
    let candles = generate_sample_data(engine.symbol, limit)
    let data = candles_to_arrays(candles)

    // 2. Run strategy
    let mut portfolio = new_portfolio(engine.initial_capital)
    let mut trades = 0
    let mut wins = 0
    let mut total_profit = 0.0
    let mut total_loss = 0.0

    for i in range(len(data["close"])) {
        // TODO: apply strategy signals, manage positions
        // Signal: -1 (sell), 0 (hold), 1 (buy)
    }

    // 3. Calculate metrics
    let final_value = portfolio_value(&portfolio, data["close"][len(data["close"]) - 1])
    let total_return = (final_value - engine.initial_capital) / engine.initial_capital
    let win_rate = if trades > 0 { to_float(wins) / to_float(trades) } else { 0.0 }
    let profit_factor = if total_loss > 0.0 { total_profit / total_loss } else { 0.0 }

    // TODO: calculate Sharpe ratio, max drawdown
    let sharpe = 0.0
    let max_drawdown = 0.0

    BacktestResult {
        symbol: engine.symbol,
        strategy: strategy_name,
        total_return: total_return,
        sharpe: sharpe,
        max_drawdown: max_drawdown,
        win_rate: win_rate,
        total_trades: trades,
        profit_factor: profit_factor,
        candles: len(data["close"]),
        duration_ms: (time_now() - t0) * 1000.0,
    }
}

fn print_backtest_result(result: &BacktestResult) {
    println("Backtest: " + result.symbol + " / " + result.strategy)
    println("  Return:      " + to_string(result.total_return * 100.0) + "%")
    println("  Sharpe:      " + to_string(result.sharpe))
    println("  Max DD:      " + to_string(result.max_drawdown * 100.0) + "%")
    println("  Win Rate:    " + to_string(result.win_rate * 100.0) + "%")
    println("  Trades:      " + to_string(result.total_trades))
    println("  Candles:     " + to_string(result.candles))
}

