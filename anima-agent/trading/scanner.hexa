// trading/scanner.hexa -- Market scanner for autonomous opportunity discovery
// Port of trading/scanner.py (384 lines)

struct ScanResult {
    symbol: string,
    score: float,
    reasons: array,
    price: float,
    volume_24h: float,
    change_24h: float,
}

struct MarketScanner {
    universe: array,
    min_volume: float,
    top_movers_n: int,
}

fn new_scanner(universe: array) -> MarketScanner {
    MarketScanner {
        universe: universe,
        min_volume: 1000000.0,
        top_movers_n: 10,
    }
}

fn scan_market(scanner: &MarketScanner) -> array {
    let mut results = []

    for symbol in scanner.universe {
        // TODO[python-sdk]: fetch_ticker(symbol)
        let ticker = {"price": 0.0, "volume_24h": 0.0, "change_24h": 0.0}

        let mut score = 0.0
        let mut reasons = []

        // Volume filter
        if ticker["volume_24h"] < scanner.min_volume { continue }

        // Top mover score
        let change = abs(ticker["change_24h"])
        if change > 3.0 {
            score = score + change * 0.1
            append(reasons, "top_mover: " + to_string(ticker["change_24h"]) + "%")
        }

        // Volume spike detection
        // TODO[python-sdk]: compare to 20-day average volume

        if score > 0.0 {
            append(results, ScanResult {
                symbol: symbol,
                score: score,
                reasons: reasons,
                price: ticker["price"],
                volume_24h: ticker["volume_24h"],
                change_24h: ticker["change_24h"],
            })
        }
    }

    sort_by(results, "score", "desc")
    slice(results, 0, min(scanner.top_movers_n, len(results)))
}

fn scan_multi_strategy_convergence(scanner: &MarketScanner, symbol: string) -> map {
    // Run multiple strategies, check if they agree
    // TODO[python-sdk]: run MACD, RSI, Bollinger on same data
    {"symbol": symbol, "signals": [], "convergence": 0.0}
}

fn main() {
    println("trading/scanner.hexa loaded")
}
