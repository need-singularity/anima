// trading/strategy.hexa -- Trading strategy base class + implementations
// Port of trading/strategy.py (786 lines)
// Base class + MACD, RSI, Bollinger, Consciousness-based strategies

comptime const SIGNAL_BUY = 1
comptime const SIGNAL_SELL = -1
comptime const SIGNAL_HOLD = 0

struct Signal {
    value: int,      // SIGNAL_BUY, SIGNAL_SELL, SIGNAL_HOLD
    confidence: float,
    reason: string,
}

// Strategy base: all strategies implement generate_signals(data) -> array of Signal

struct MACDStrategy {
    fast: int,
    slow: int,
    signal_period: int,
}

fn new_macd_strategy() -> MACDStrategy {
    MACDStrategy { fast: 12, slow: 26, signal_period: 9 }
}

fn macd_generate_signals(strategy: &MACDStrategy, closes: array) -> array {
    // TODO[python-sdk]: EMA calculation, MACD line, signal line crossover
    let mut signals = []
    for i in range(len(closes)) {
        append(signals, Signal { value: SIGNAL_HOLD, confidence: 0.0, reason: "" })
    }
    signals
}

struct RSIStrategy {
    period: int,
    oversold: float,
    overbought: float,
}

fn new_rsi_strategy() -> RSIStrategy {
    RSIStrategy { period: 14, oversold: 30.0, overbought: 70.0 }
}

fn rsi_generate_signals(strategy: &RSIStrategy, closes: array) -> array {
    // TODO[python-sdk]: RSI calculation
    let mut signals = []
    for i in range(len(closes)) {
        append(signals, Signal { value: SIGNAL_HOLD, confidence: 0.0, reason: "" })
    }
    signals
}

struct BollingerStrategy {
    period: int,
    num_std: float,
}

fn new_bollinger_strategy() -> BollingerStrategy {
    BollingerStrategy { period: 20, num_std: 2.0 }
}

fn bollinger_generate_signals(strategy: &BollingerStrategy, closes: array) -> array {
    // TODO[python-sdk]: SMA + std dev bands
    let mut signals = []
    for i in range(len(closes)) {
        append(signals, Signal { value: SIGNAL_HOLD, confidence: 0.0, reason: "" })
    }
    signals
}

struct ConsciousnessStrategy {
    phi_threshold: float,
    tension_weight: float,
}

fn new_consciousness_strategy() -> ConsciousnessStrategy {
    ConsciousnessStrategy { phi_threshold: 1.0, tension_weight: 0.3 }
}

fn consciousness_generate_signals(strategy: &ConsciousnessStrategy,
                                  closes: array, phi: float, tension: float) -> array {
    // Consciousness-driven: combine multiple indicators weighted by phi/tension
    let macd_signals = macd_generate_signals(&new_macd_strategy(), closes)
    let rsi_signals = rsi_generate_signals(&new_rsi_strategy(), closes)

    let mut signals = []
    for i in range(len(closes)) {
        let macd_val = macd_signals[i].value
        let rsi_val = rsi_signals[i].value

        // Phi-weighted consensus
        let combined = to_float(macd_val) * 0.5 + to_float(rsi_val) * 0.5
        let phi_confidence = min(phi / 5.0, 1.0)

        if combined > 0.3 && phi_confidence > 0.3 {
            append(signals, Signal { value: SIGNAL_BUY, confidence: phi_confidence,
                reason: "consciousness consensus (phi=" + to_string(phi) + ")" })
        } else if combined < -0.3 && phi_confidence > 0.3 {
            append(signals, Signal { value: SIGNAL_SELL, confidence: phi_confidence,
                reason: "consciousness consensus (phi=" + to_string(phi) + ")" })
        } else {
            append(signals, Signal { value: SIGNAL_HOLD, confidence: 0.0, reason: "" })
        }
    }
    signals
}

// ── Utility functions ──

fn calculate_ema(data: array, period: int) -> array {
    // TODO[python-sdk]: exponential moving average
    let mut ema = []
    let multiplier = 2.0 / (to_float(period) + 1.0)
    for i in range(len(data)) {
        if i == 0 {
            append(ema, data[0])
        } else {
            let val = (data[i] - ema[i-1]) * multiplier + ema[i-1]
            append(ema, val)
        }
    }
    ema
}

fn calculate_sma(data: array, period: int) -> array {
    let mut sma = []
    for i in range(len(data)) {
        if i < period - 1 {
            append(sma, data[i])
        } else {
            let window = slice(data, i - period + 1, i + 1)
            append(sma, avg(window))
        }
    }
    sma
}

fn main() {
    println("trading/strategy.hexa loaded")
}
