// trading/test_ensemble.hexa -- Backtest comparison: MACD vs RSI vs Consciousness
// Port of trading/test_ensemble.py (249 lines)

fn run_ensemble_test() {
    println("=== Strategy Ensemble Backtest ===")
    println("Symbol: BTCUSDT, Timeframe: 1h, Days: 30")
    println("")

    let engine = new_backtest_engine("BTCUSDT", "1h")

    // Test MACD
    let macd_result = backtest_run(&engine, "macd_cross", 30)
    println("MACD:")
    print_backtest_result(&macd_result)
    println("")

    // Test RSI
    let rsi_result = backtest_run(&engine, "rsi_reversal", 30)
    println("RSI:")
    print_backtest_result(&rsi_result)
    println("")

    // Test Consciousness Ensemble
    let ensemble_result = backtest_run(&engine, "consciousness_ensemble", 30)
    println("Consciousness Ensemble:")
    print_backtest_result(&ensemble_result)
    println("")

    // Compare
    println("=== Comparison ===")
    println("  Strategy              Return    Sharpe    Win Rate")
    println("  MACD                  " + to_string(macd_result.total_return * 100.0) + "%")
    println("  RSI                   " + to_string(rsi_result.total_return * 100.0) + "%")
    println("  Consciousness         " + to_string(ensemble_result.total_return * 100.0) + "%")
    println("==================")
}

fn main() {
    run_ensemble_test()
}
