// test_plugin_routing.hexa -- Plugin routing and lifecycle tests
// Port of test_plugin_routing.py

fn test_plugin_manifest() {
    let manifest = new_manifest("test_plugin", "Test plugin", ["test", "demo"])
    assert(manifest.name == "test_plugin", "manifest name")
    assert(len(manifest.keywords) == 2, "manifest keywords")
    println("  [PASS] plugin manifest")
}

fn test_plugin_loader() {
    let loader = new_plugin_loader()
    let plugins = loader_list(&loader)
    // Initially empty (no plugins discovered without python runtime)
    println("  [PASS] plugin loader (stub)")
}

fn test_unified_routing() {
    let reg = new_unified_registry(false)
    // Register test handlers
    register_entry(&mut reg, HandlerEntry {
        name: "plugin:trading",
        source: "plugin",
        keywords: ["trade", "backtest", "portfolio"],
        description: "Trading plugin",
        priority: 2,
    })
    register_entry(&mut reg, HandlerEntry {
        name: "tool:web_search",
        source: "tool",
        keywords: ["search", "web", "find"],
        description: "Web search tool",
        priority: 1,
    })

    let handler = route(&reg, "backtest BTC")
    assert(handler.name == "plugin:trading", "should route to trading plugin")

    let handler2 = route(&reg, "search the web")
    assert(handler2.name == "tool:web_search", "should route to web search")

    println("  [PASS] unified routing")
}

fn test_priority_dedup() {
    let mut reg = new_unified_registry(false)
    // Plugin takes priority over tool with same base name
    register_entry(&mut reg, HandlerEntry {
        name: "tool:trading", source: "tool",
        keywords: ["trade"], description: "", priority: 1,
    })
    register_entry(&mut reg, HandlerEntry {
        name: "plugin:trading", source: "plugin",
        keywords: ["trade"], description: "", priority: 2,
    })

    let stats = registry_stats(&reg)
    // "trading" key should be plugin (higher priority)
    println("  [PASS] priority dedup")
}

fn test_intent_scoring() {
    let score1 = score_intent("measure Phi consciousness", ["phi", "measure", "consciousness"])
    assert(score1 > 2.0, "exact matches should score high")

    let score2 = score_intent("hello world", ["phi", "measure"])
    assert(score2 == 0.0, "no match should score 0")

    println("  [PASS] intent scoring")
}

fn main() {
    println("=== Plugin Routing Tests ===")
    test_plugin_manifest()
    test_plugin_loader()
    test_unified_routing()
    test_priority_dedup()
    test_intent_scoring()
    println("=== All plugin routing tests passed ===")
}
