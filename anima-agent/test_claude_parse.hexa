// test_claude_parse.hexa — critique score parsing 전용 smoke (compiled)
// Runs 1 claude_critique call, expects a parseable SCORE= response.

use "llm_claude_adapter"

fn main() {
    println("=== Claude critique round-trip (compiled mode) ===")
    let reply = claude_critique(
        "write a 3-sentence summary of a quarterly report",
        "Q3 revenue up 12% QoQ driven by enterprise pipeline. Margins compressed 200bps on R&D spend. Cash position remains strong at $240M."
    )
    println("score=" + to_string(reply.score))
    println("reason=" + reply.reason)
    let pass = reply.score > 0.0 && reply.score <= 1.0 && len(reply.reason) > 0
    println("PASS=" + to_string(pass))
}
