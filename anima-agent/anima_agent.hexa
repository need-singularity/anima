    let curiosity = 0.3
    let emotion = "calm"
    // TODO[python-sdk]: direction_to_emotion(direction)

    agent.tension = tension
    agent.curiosity = curiosity
    agent.emotion = emotion

    // 3. Memory search (RAG + Store fallback)
