fn auto_save_check(agent: &AnimaAgent) {
    if agent.interaction_count > 0 && agent.interaction_count % AUTO_SAVE_INTERVAL == 0 {
        save_state(agent)
    }
}

fn shutdown(agent: &AnimaAgent) {
    println("AnimaAgent shutting down (interactions=" + to_string(agent.interaction_count) + ")")
    save_state(agent)
    // TODO[python-sdk]: persistence.save(), memory_store.close(), memory_rag.save_index()
}

// ── Standalone test ──

fn main() {
    println("=== AnimaAgent standalone test ===")
    let mut agent = new_anima_agent(128, 256, "default", false, false, false, false, "")
    let status = get_status(&agent)
    println("  Phi: " + to_string(status.phi))
    println("  Tension: " + to_string(status.tension))
    println("  Growth: " + status.growth_stage)
    println("=== All tests passed ===")
}
