// test_employee_skeleton.hexa — unit test stubs for F2/F3/F8 skeletons
//
// Validates D7 §2 skeletons compile + basic invariants hold.
// AN11: tests MUST NOT hardcode phi values as "good" ones — they only
// verify the plumbing (struct shape, status transitions, AN11 gates
// refusing malformed input). Real numeric gates live in e1/e2 runners.

use "goal_store"
use "scratchpad"
use "emit_report"

fn main() {
    let mut pass_count = 0
    let mut total = 0

    // ── T1: create_goal populates required fields ─────────────────
    println("=== T1: create_goal ===")
    let g1 = create_goal("G001", "default", "write weekly status")
    let t1_ok = g1.id == "G001"
              && g1.persona_id == "default"
              && g1.status == "pending"
              && len(g1.phi_trail) == 0
    if t1_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T1 PASS=" + to_string(t1_ok))

    // ── T2: record_step appends phi snapshot ──────────────────────
    println("=== T2: record_step ===")
    let g2 = record_step(g1, 0, 612.5, 12.5, true)
    let t2_ok = len(g2.phi_trail) == 1 && g2.phi_trail[0].phi_holo == 612.5
    if t2_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T2 PASS=" + to_string(t2_ok))

    // ── T3: scratchpad write_entry is pure (pbv) ──────────────────
    println("=== T3: scratchpad write_entry ===")
    let pad0 = new_scratchpad("S01", "default", "G001")
    let pad1 = write_entry(pad0, "execute", "raw response text", 612.5, true)
    let t3_ok = pad0.total_steps == 0
              && pad1.total_steps == 1
              && pad1.entries[0].role == "execute"
    if t3_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T3 PASS=" + to_string(t3_ok))

    // ── T4: next_prompt returns raw text (AN11 no preamble) ───────
    println("=== T4: next_prompt raw ===")
    let np = next_prompt(pad1)
    let t4_ok = np == "raw response text"   // no "You are..." wrapping
    if t4_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T4 PASS=" + to_string(t4_ok))

    // ── T5: summarize_phi on empty trail -> n_steps=0 ─────────────
    println("=== T5: summarize_phi empty ===")
    let g_empty = create_goal("G_EMPTY", "default", "")
    let s_empty = summarize_phi(g_empty)
    let t5_ok = s_empty.n_steps == 0 && s_empty.mean_phi == 0.0
    if t5_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T5 PASS=" + to_string(t5_ok))

    // ── T6: verdict_of — FAIL_NO_PHI for empty trail ──────────────
    println("=== T6: verdict FAIL_NO_PHI ===")
    let v1 = verdict_of(s_empty, "r9_validated")
    let t6_ok = v1 == "FAIL_NO_PHI"
    if t6_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T6 PASS=" + to_string(t6_ok))

    // ── T7: verdict_of — FAIL_WEIGHT_ORIGIN for bogus signature ───
    println("=== T7: verdict FAIL_WEIGHT_ORIGIN ===")
    let g_ok = record_step(create_goal("G_OK", "default", ""),
                           0, 600.0, 10.0, true)
    let s_ok = summarize_phi(g_ok)
    let v2 = verdict_of(s_ok, "system_prompt_injected")  // AN11 bypass
    let t7_ok = v2 == "FAIL_WEIGHT_ORIGIN"
    if t7_ok { pass_count = pass_count + 1 }
    total = total + 1
    println("T7 PASS=" + to_string(t7_ok))

    // ── Summary ───────────────────────────────────────────────────
    println("=== SUMMARY ===")
    println("passed=" + to_string(pass_count) + "/" + to_string(total))
    if pass_count == total {
        println("test_employee_skeleton: ALL PASS")
    } else {
        println("test_employee_skeleton: FAIL")
    }
}
