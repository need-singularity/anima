struct EcosystemBridge {
    body: BodyBridge,
    eeg: EEGBridge,
    physics: PhysicsBridge,
    hexa: HexaLangBridge,
    core: CoreBridge,
}

fn new_ecosystem_bridge() -> EcosystemBridge {
    EcosystemBridge {
        body: new_body_bridge(),
        eeg: new_eeg_bridge(),
        physics: new_physics_bridge(),
        hexa: new_hexa_lang_bridge(),
        core: new_core_bridge(),
    }
}

fn ecosystem_status(eco: &EcosystemBridge) -> map {
    {
        "body": eco.body.available,
        "eeg": eco.eeg.available,
        "physics": eco.physics.available,
        "hexa_lang": eco.hexa.available,
        "core": eco.core.available,
    }
}

fn print_ecosystem_status(eco: &EcosystemBridge) {
    let s = ecosystem_status(eco)
    println("Anima Ecosystem Status:")
    for name, ok in s {
        let icon = if ok { "[OK]" } else { "[--]" }
        println("  " + icon + " " + name)
    }
    let mut connected = 0
    for name, ok in s {
        if ok { connected = connected + 1 }
    }
    println("  --- " + to_string(connected) + "/" + to_string(len(s)) + " connected ---")
}

fn main() {
    let eco = new_ecosystem_bridge()
    print_ecosystem_status(&eco)
}
