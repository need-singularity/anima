    return t
}

// ── Task evaluation ──────────────────────────────────────────────────

fn trace_text_blob(trace: AutonomyTrace) -> string {
    // Concatenate all goal texts + results for keyword search
    let mut s = ""
    let mut i = 0
    while i < len(trace.goals) {
        s = s + trace.goals[i].text + " "
        s = s + trace.goals[i].result + " "
        i = i + 1
    }
    return s
}

fn evaluate_task(task: Task, trace: AutonomyTrace, time_s: float, interventions: int) -> TaskResult {
    let blob = trace_text_blob(trace)
    let mut hits = 0
    let mut ki = 0
    let total = len(task.success_keywords)
    while ki < total {
        if blob.contains(task.success_keywords[ki]) {
            hits = hits + 1
        }
        ki = ki + 1
    }
    let score = if total > 0 { to_float(hits) / to_float(total) } else { 0.0 }
    // Deterministic completion: all keywords hit AND trace verdict != FAIL AND within budget
    let all_hit = hits == total
    let budget_ok = interventions <= task.max_interventions && time_s <= to_float(task.max_time_sec)
    let verdict_ok = trace.verdict != "FAIL"
    let completed = all_hit && budget_ok && verdict_ok
    return TaskResult {
        task_id: task.id, domain: task.domain,
        completed: completed, score: score,
        intervention_count: interventions, time_s: time_s,
        keyword_hits: hits, keyword_total: total
    }
}

// ── Runner ───────────────────────────────────────────────────────────

fn run_hire_sim(adapter: LLMAdapter, tasks: array) -> HireSimResult {
    let mut results = []
    let mut total_time = 0.0
    let mut total_score = 0.0
    let mut total_completed = 0
    let mut total_interv = 0

    // Per-domain accumulators (using parallel arrays to avoid struct-list quirk)
    let mut d_names = []
    let mut d_n = []
    let mut d_comp = []
    let mut d_score_sum = []

    let mut ti = 0
    while ti < len(tasks) {
        let task = tasks[ti]
        // Run autonomy loop for this task
        let trace = run_autonomy(adapter, task.prompt, 3, 100)
        // Mock mapping: 1 autonomy step = 1 second for now; real LLM provides actual timing
        let time_s = to_float(trace.step_count)
        let intervs = 0  // scaffold: 0 interventions; wire real clarification count later
        let r = evaluate_task(task, trace, time_s, intervs)
        results = results.push(r)
        total_time = total_time + r.time_s
        total_score = total_score + r.score
        if r.completed { total_completed = total_completed + 1 }
        total_interv = total_interv + r.intervention_count

        // Domain aggregation
        let mut dfound = 0 - 1
        let mut di = 0
        while di < len(d_names) {
            if d_names[di] == task.domain { dfound = di }
            di = di + 1
        }
        if dfound < 0 {
            d_names = d_names.push(task.domain)
            d_n = d_n.push(1)
            d_comp = d_comp.push(if r.completed { 1 } else { 0 })
            d_score_sum = d_score_sum.push(r.score)
        } else {
            d_n = replace_int_at(d_n, dfound, d_n[dfound] + 1)
            d_comp = replace_int_at(d_comp, dfound, d_comp[dfound] + (if r.completed { 1 } else { 0 }))
            d_score_sum = replace_float_at(d_score_sum, dfound, d_score_sum[dfound] + r.score)
        }

        ti = ti + 1
    }

    let n = len(tasks)
    let nf = to_float(n)
    let avg_time = if n > 0 { total_time / nf } else { 0.0 }
    let avg_score = if n > 0 { total_score / nf } else { 0.0 }
    let completion_rate = if n > 0 { to_float(total_completed) / nf } else { 0.0 }
    // interventions per hour, using total simulated time
    let interv_per_hr = if total_time > 0.0 { to_float(total_interv) * 3600.0 / total_time } else { 0.0 }

    // Build per-domain summaries
    let mut per_domain = []
    let mut di2 = 0
    while di2 < len(d_names) {
        let sd = DomainSummary {
            domain: d_names[di2],
            n: d_n[di2],
            completed: d_comp[di2],
            rate: to_float(d_comp[di2]) / to_float(d_n[di2]),
            avg_score: d_score_sum[di2] / to_float(d_n[di2])
        }
        per_domain = per_domain.push(sd)
        di2 = di2 + 1
    }

    // Verdict per TSRV-P4-2 gate
    let gate_rate = completion_rate >= 0.85
    let gate_interv = interv_per_hr <= 5.0
    let gate_time = avg_time <= 600.0   // 10 min = 600s
    let verdict = if gate_rate && gate_interv && gate_time { "PASS" }
                  else if completion_rate >= 0.50 { "PARTIAL" }
                  else { "FAIL" }

    return HireSimResult {
        tasks_run: n,
        completed_count: total_completed,
        completion_rate: completion_rate,
        avg_score: avg_score,
        avg_time_s: avg_time,
        total_interventions: total_interv,
        intervention_rate_per_hour: interv_per_hr,
        per_domain: per_domain,
        verdict: verdict
    }
}

fn replace_int_at(arr: array, idx: int, val: int) -> array {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out = out.push(val) } else { out = out.push(arr[i]) }
        i = i + 1
    }
    return out
}

fn replace_float_at(arr: array, idx: int, val: float) -> array {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out = out.push(val) } else { out = out.push(arr[i]) }
        i = i + 1
    }
    return out
}

// ── Reporter ─────────────────────────────────────────────────────────

fn hire_sim_report(r: HireSimResult) -> string {
    let mut s = "HireSimResult:\n"
    s = s + "  tasks_run: " + to_string(r.tasks_run) + "\n"
    s = s + "  completed: " + to_string(r.completed_count) + "/" + to_string(r.tasks_run) + " = " + to_string(r.completion_rate) + "\n"
    s = s + "  avg_score: " + to_string(r.avg_score) + "\n"
    s = s + "  avg_time_s: " + to_string(r.avg_time_s) + "\n"
    s = s + "  total_interventions: " + to_string(r.total_interventions) + " (rate/hr=" + to_string(r.intervention_rate_per_hour) + ")\n"
    s = s + "  verdict: " + r.verdict + " (gate: rate>=0.85, interv/hr<=5, avg_time<=600)\n"
    s = s + "  per_domain:\n"
    let mut i = 0
    while i < len(r.per_domain) {
        let d = r.per_domain[i]
        s = s + "    " + d.domain + ": " + to_string(d.completed) + "/" + to_string(d.n) + " = " + to_string(d.rate) + " (avg_score=" + to_string(d.avg_score) + ")\n"
        i = i + 1
    }
    return s
}
