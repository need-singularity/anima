// hire_sim_100.hexa — TSRV-P4-2 (anima-train.json P4)
//
// v3.0 직원 가능 측정 도구. 6 도메인 × 실업무 task × deterministic rubric.
//
// done_criteria (TSRV-P4-2): 완료율 ≥ 0.85, 사용자 개입 ≤ 5/hour,
//                            평균 task 소요 ≤ 10 min
//
// 현재 seed 30 task (5 per domain). 100 확장은 real LLM 실측 단계에서.
//
// 사용:
//   let adapter = LLMAdapter { name: "mock" | "claude" | "animalm" | ...,
//                              temperature: 0.0 }
//   let tasks = load_tasks()
//   let result = run_hire_sim(adapter, tasks)
//   println(hire_sim_report(result))
//
// Rubric (deterministic mock 판정):
//   completed := 모든 success_keyword 가 decomposition+execution trace 에 포함
//   score := 매칭된 keyword 비율 (0..1)
//   intervention_count := 현재 스캐폴드에서 0 (tool-use LoRA 이후 실측 가능)
//   time_s := mock 에서는 step_count 로 대리 (1 step = 1초 가정)
//
// 실 LLM 플러그 시 evaluate_task 내 keyword matching 을 llm_judge 또는
// external rubric 으로 교체. 프레임워크는 adapter.name 스위치로 변경 없이 유지.

use "autonomy_loop"

// ── Data types ───────────────────────────────────────────────────────

struct Task {
    id: string,
    domain: string,          // email/code/meeting/doc/schedule/research
    difficulty: string,       // easy/medium/hard
    prompt: string,
    success_keywords: array,  // deterministic 판정용 (모두 trace 에 포함되어야 완료)
    max_interventions: int,
    max_time_sec: int
}

struct TaskResult {
    task_id: string,
    domain: string,
    completed: bool,
    score: float,             // 0..1
    intervention_count: int,
    time_s: float,
    keyword_hits: int,
    keyword_total: int
}

struct HireSimResult {
    tasks_run: int,
    completed_count: int,
    completion_rate: float,
    avg_score: float,
    avg_time_s: float,
    total_interventions: int,
    intervention_rate_per_hour: float,
    per_domain: array,          // array of { domain, n, completed, rate, avg_score }
    verdict: string             // "PASS" | "PARTIAL" | "FAIL"
}

struct DomainSummary {
    domain: string,
    n: int,
    completed: int,
    rate: float,
    avg_score: float
}

// ── Seed corpus (30 task = 5 per domain × 6 도메인) ──────────────────

