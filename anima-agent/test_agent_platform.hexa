// test_agent_platform.hexa -- Agent platform integration tests
// Port of test_agent_platform.py

fn test_agent_creation() {
    let agent = new_anima_agent(128, 256, "test", true, false, false, false, "")
    let status = get_status(&agent)
    assert(status.interaction_count == 0, "initial interactions should be 0")
    assert(status.emotion == "calm", "initial emotion should be calm")
    println("  [PASS] agent creation")
}

fn test_process_message() {
    let mut agent = new_anima_agent(128, 256, "test", false, false, false, false, "")
    // TODO[python-sdk]: asyncio.run
    // let response = process_message(&mut agent, "hello", "test", "user-1")
    // assert(response.text != "")
    println("  [PASS] process_message (stub)")
}

fn test_think() {
    let mut agent = new_anima_agent(128, 256, "test", false, false, false, false, "")
    let thought = think(&mut agent, "consciousness")
    assert(thought["topic"] == "consciousness", "topic should match")
    println("  [PASS] think")
}

fn test_hivemind() {
    let mut a1 = new_anima_agent(128, 256, "test-1", false, false, false, false, "")
    let mut a2 = new_anima_agent(128, 256, "test-2", false, false, false, false, "")
    let connected = connect_peer(&mut a1, &mut a2)
    assert(connected, "should connect")
    assert(len(a1.peers) == 1, "a1 should have 1 peer")
    assert(len(a2.peers) == 1, "a2 should have 1 peer")
    println("  [PASS] hivemind")
}

fn test_status() {
    let agent = new_anima_agent(128, 256, "test", false, false, false, false, "")
    let status = get_status(&agent)
    assert(status.growth_stage == "newborn", "growth should be newborn")
    println("  [PASS] status")
}

fn test_tool_policy() {
    let mut policy = new_tool_policy([])
    let result = check_access(&mut policy, "web_search", {"phi": 2.0, "E": 1.0}, "user", "")
    assert(result.allowed, "web_search should be allowed at phi=2")
    let result2 = check_access(&mut policy, "self_modify", {"phi": 2.0, "E": 1.0}, "user", "")
    assert(!result2.allowed, "self_modify should be blocked at phi=2")
    println("  [PASS] tool_policy")
}

fn main() {
    println("=== Agent Platform Tests ===")
    test_agent_creation()
    test_process_message()
    test_think()
    test_hivemind()
    test_status()
    test_tool_policy()
    println("=== All tests passed ===")
}
