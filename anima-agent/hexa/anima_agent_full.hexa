// ═══════════ alien_index ═══════════
// alien_index.hexa — (d, r) cycle depth x rank grading

mod alien_index {
    pub let max_rank = 10
    pub let promotion_rank = 10
    pub let max_depth = 6                // n=6 closure = AGI

    // Rank from n6_match quality
    pub fn rank_from_n6_quality(quality: float) -> int {
        if quality >= 1.0 { return 9 }
        if quality >= 0.8 { return 7 }
        if quality >= 0.5 { return 5 }
        return 0
    }

    // Rank from mk2 confidence
    pub fn rank_from_mk2_conf(conf: float) -> int {
        if conf >= 0.9 { return 10 }
        if conf >= 0.7 { return 9 }
        if conf >= 0.5 { return 8 }
        if conf >= 0.3 { return 7 }
        return 0
    }

    pub fn can_promote(r: int) -> bool {
        return r == promotion_rank
    }

    pub fn breakthrough_d(d: int, r: int) -> int {
        if can_promote(r) {
            return d + 1
        }
        return d
    }

    pub fn breakthrough_r(r: int) -> int {
        if can_promote(r) {
            return 0
        }
        return r
    }

    pub fn is_agi_closure(d: int) -> bool {
        return d >= max_depth
    }
}

verify "max_depth_is_six" {
    assert alien_index::max_depth == 6
}

verify "promotion_rank_is_ten" {
    assert alien_index::promotion_rank == 10
    assert alien_index::max_rank == 10
}

verify "rank_thresholds_monotonic" {
    let r_low = alien_index::rank_from_n6_quality(0.3)
    let r_mid = alien_index::rank_from_n6_quality(0.7)
    let r_high = alien_index::rank_from_n6_quality(1.0)
    assert r_high >= r_mid
    assert r_mid >= r_low
}

verify "mk2_rank_thresholds_monotonic" {
    let r_low = alien_index::rank_from_mk2_conf(0.2)
    let r_mid = alien_index::rank_from_mk2_conf(0.6)
    let r_high = alien_index::rank_from_mk2_conf(0.95)
    assert r_high > r_mid
    assert r_mid > r_low
}

