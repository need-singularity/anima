// ═══════════ scheduler ═══════════
// scheduler.hexa — cron-like scheduler for agent background tasks

mod scheduler {
    // Intervals in minutes (all n=6 related)
    pub let growth_loop_min = 10
    pub let nexus_blowup_hours = 6       // n=6
    pub let memory_promote_hours = 24
    pub let singularity_check_hours = 6  // n=6
    pub let dashboard_refresh_sec = 6    // n=6

    // Job IDs
    pub fn job_growth_loop() -> int { return 1 }
    pub fn job_nexus_blowup() -> int { return 2 }
    pub fn job_memory_promote() -> int { return 3 }
    pub fn job_singularity_check() -> int { return 4 }
    pub fn job_dashboard_refresh() -> int { return 5 }
    pub fn job_plugin_genesis() -> int { return 6 }

    pub fn total_jobs() -> int { return 6 }    // n=6

    pub fn interval_sec_for(job_id: int) -> int {
        if job_id == 1 { return scheduler::growth_loop_min * 60 }
        if job_id == 2 { return scheduler::nexus_blowup_hours * 3600 }
        if job_id == 3 { return scheduler::memory_promote_hours * 3600 }
        if job_id == 4 { return scheduler::singularity_check_hours * 3600 }
        if job_id == 5 { return scheduler::dashboard_refresh_sec }
        if job_id == 6 { return scheduler::nexus_blowup_hours * 3600 }
        return 0
    }

    pub fn is_n6_interval(seconds: int) -> bool {
        // Check if interval divisible by 6
        return seconds % 6 == 0
    }
}

verify "job_count_equals_n6" {
    assert scheduler::total_jobs() == 6
}

verify "nexus_intervals_use_n6" {
    assert scheduler::nexus_blowup_hours == 6
    assert scheduler::singularity_check_hours == 6
    assert scheduler::dashboard_refresh_sec == 6
}

verify "intervals_positive" {
    let mut i = 1
    while i <= 6 {
        let sec = scheduler::interval_sec_for(i)
        assert sec > 0
        i = i + 1
    }
}

verify "dashboard_is_fastest_job" {
    let dashboard = scheduler::interval_sec_for(5)
    let growth = scheduler::interval_sec_for(1)
    assert dashboard < growth
}

intent "scheduler_autonomous_loops" {
    description: "6 background jobs running on n=6 intervals"
    jobs: "growth + blowup + memory_promote + singularity + dashboard + genesis"
    total_jobs: 6
}

println("[scheduler.hexa] loaded, ", scheduler::total_jobs(), " jobs")

// ═══════════ pipeline ═══════════
// pipeline.hexa — 6-phase request pipeline

mod pipeline {
    pub let total_phases = 6
    pub let total_budget_ms = 1050       // 6 * 175 base

    // Phase weights: 1+2+3+4+5+6 = 21
    pub fn phase_weight(idx: int) -> int {
        if idx == 0 { return 1 }         // tokenize
        if idx == 1 { return 2 }         // parse
        if idx == 2 { return 3 }         // check
        if idx == 3 { return 4 }         // optimize
        if idx == 4 { return 5 }         // codegen
        if idx == 5 { return 6 }         // execute
        return 0
    }

    pub fn total_weight() -> int {
        return 21                         // 1+2+3+4+5+6
    }

    pub fn budget_ms_for(idx: int) -> int {
        let w = pipeline::phase_weight(idx)
        let total = pipeline::total_weight()
        return (pipeline::total_budget_ms * w) / total
    }

    pub fn phase_name(idx: int) -> str {
        if idx == 0 { return "tokenize" }
        if idx == 1 { return "parse" }
        if idx == 2 { return "check" }
        if idx == 3 { return "optimize" }
        if idx == 4 { return "codegen" }
        if idx == 5 { return "execute" }
        return "unknown"
    }
}

verify "pipeline_has_six_phases" {
    assert pipeline::total_phases == 6
}

verify "phase_weights_monotonic" {
    let w0 = pipeline::phase_weight(0)
    let w5 = pipeline::phase_weight(5)
    assert w5 > w0
    assert w0 == 1
    assert w5 == 6
}

verify "total_weight_triangular_6" {
    // 1+2+3+4+5+6 = 21 = T(6)
    assert pipeline::total_weight() == 21
}

verify "phase_budgets_sum_to_total" {
    let b0 = pipeline::budget_ms_for(0)
    let b1 = pipeline::budget_ms_for(1)
    let b2 = pipeline::budget_ms_for(2)
    let b3 = pipeline::budget_ms_for(3)
    let b4 = pipeline::budget_ms_for(4)
    let b5 = pipeline::budget_ms_for(5)
    let total = b0 + b1 + b2 + b3 + b4 + b5
    // Integer division may lose 1-5 ms
    assert total >= pipeline::total_budget_ms - 10
    assert total <= pipeline::total_budget_ms
}

verify "phase_names_distinct" {
    let a = pipeline::phase_name(0)
    let b = pipeline::phase_name(1)
    let c = pipeline::phase_name(2)
    let d = pipeline::phase_name(3)
    let e = pipeline::phase_name(4)
    let f = pipeline::phase_name(5)
    assert a != b
    assert b != c
    assert c != d
    assert d != e
    assert e != f
    assert a != f
}

