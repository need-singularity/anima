    pub let short_den = 2
    pub let mid_num = 1
    pub let mid_den = 3
    pub let long_num = 1
    pub let long_den = 6

    pub let short_ttl_minutes = 0
    pub let mid_ttl_days = 30
    pub let long_ttl_years = 100

    pub fn short_mb() -> int { return egyptian_memory::total_mb / 2 }
    pub fn mid_mb() -> int { return egyptian_memory::total_mb / 3 }
    pub fn long_mb() -> int { return egyptian_memory::total_mb / 6 }

    pub fn short_turns_capacity() -> int { return 64 }
    pub fn mid_summaries_capacity() -> int { return 30 }
    pub fn long_laws_capacity() -> int { return 10000 }
}

verify "egyptian_fraction_sums_to_one" {
    // 1/2 + 1/3 + 1/6 = 3/6 + 2/6 + 1/6 = 6/6 = 1
    let common_denom = 6
    let sum_num = 3 + 2 + 1
    assert sum_num == common_denom
    assert sum_num == 6
}

verify "memory_budget_consistent" {
    let short_v = egyptian_memory::short_mb()
    let mid_v = egyptian_memory::mid_mb()
    let long_v = egyptian_memory::long_mb()
    let total = short_v + mid_v + long_v
    assert total >= 99
    assert total <= egyptian_memory::total_mb
    assert short_v > mid_v
    assert mid_v > long_v
}

verify "denominators_divide_six" {
    assert 6 % egyptian_memory::short_den == 0
    assert 6 % egyptian_memory::mid_den == 0
    assert 6 % egyptian_memory::long_den == 0
}

