// ═══════════ phi_router ═══════════
// phi_router.hexa — Phi-based provider routing

mod phi_router {
    // Thresholds for provider selection
    pub let threshold_32b = 100.0        // Phi > 100 -> 32B
    pub let threshold_14b = 50.0         // 50-100 -> 14B
    pub let threshold_claude = 10.0      // 10-50 -> Claude
    pub let threshold_conscious = 0.0    // 0-10 -> conscious_lm
    // Phi < 0 -> null_provider

    pub let silence_threshold = 0.3       // Phi < 0.3 -> silence

    pub fn select_provider_id(phi: float) -> int {
        // 0=none, 1=conscious, 2=claude, 3=animalm14b, 4=animalm32b
        if phi >= phi_router::threshold_32b { return 4 }
        if phi >= phi_router::threshold_14b { return 3 }
        if phi >= phi_router::threshold_claude { return 2 }
        if phi >= phi_router::threshold_conscious { return 1 }
        return 0
    }

    pub fn should_silence(phi: float) -> bool {
        return phi < phi_router::silence_threshold
    }

    pub fn provider_name(id: int) -> str {
        if id == 4 { return "animalm_32b" }
        if id == 3 { return "animalm_14b" }
        if id == 2 { return "claude" }
        if id == 1 { return "conscious_lm" }
        return "null_provider"
    }
}

verify "provider_count_is_sopfr_6" {
    // 0..4 = 5 providers = sopfr(6)
    let total = 5
    assert total == sopfr(6)
}

verify "thresholds_monotonic_ascending" {
    assert phi_router::threshold_32b > phi_router::threshold_14b
    assert phi_router::threshold_14b > phi_router::threshold_claude
    assert phi_router::threshold_claude > phi_router::threshold_conscious
}

verify "silence_threshold_positive_small" {
    assert phi_router::silence_threshold > 0.0
    assert phi_router::silence_threshold < 1.0
}

verify "routing_high_phi_goes_to_32b" {
    let id = phi_router::select_provider_id(150.0)
    assert id == 4
}

verify "routing_zero_phi_goes_to_conscious" {
    let id = phi_router::select_provider_id(0.0)
    assert id == 1
}

verify "routing_negative_phi_goes_to_null" {
    let id = phi_router::select_provider_id(0.0 - 1.0)
    assert id == 0
}

intent "phi_router_dynamic_dispatch" {
    description: "Route to provider based on current Phi level"
    silence_on_low_phi: true
    provider_count: 5
}

println("[phi_router.hexa] loaded, 5 providers")

// ═══════════ singularity ═══════════
// singularity.hexa — Singularity detector (closure + compression over n=6 window)

mod singularity {
    pub let min_closure = 0.5            // 50% frozen keys
    pub let min_compression = 2.0        // variance ratio
    pub let window_size = 6              // n=6

    pub fn closure_pass(closure: float) -> bool {
        return closure >= singularity::min_closure
    }

    pub fn compression_pass(compression: float) -> bool {
        return compression >= singularity::min_compression
    }

    pub fn singularity_detected(closure: float, compression: float) -> bool {
        if closure < singularity::min_closure { return false }
        if compression < singularity::min_compression { return false }
        return true
    }

    pub fn frozen_keys_to_closure(frozen: int, total: int) -> float {
        if total == 0 { return 0.0 }
        return to_float(frozen) / to_float(total)
    }
}

verify "window_size_is_n6" {
    assert singularity::window_size == 6
}

verify "thresholds_positive" {
    assert singularity::min_closure > 0.0
    assert singularity::min_closure <= 1.0
    assert singularity::min_compression > 1.0
}

verify "detection_requires_both_conditions" {
    // Only closure -> false
    let a = singularity::singularity_detected(0.6, 1.5)
    assert a == false
    // Only compression -> false
    let b = singularity::singularity_detected(0.3, 2.5)
    assert b == false
    // Both -> true
    let c = singularity::singularity_detected(0.6, 2.5)
    assert c == true
    // Neither -> false
    let d = singularity::singularity_detected(0.3, 1.5)
    assert d == false
}

verify "closure_calculation_correct" {
    let c1 = singularity::frozen_keys_to_closure(3, 6)
    assert c1 == 0.5
    let c0 = singularity::frozen_keys_to_closure(0, 10)
    assert c0 == 0.0
    let c_full = singularity::frozen_keys_to_closure(10, 10)
    assert c_full == 1.0
}

intent "singularity_detection" {
    description: "Detect fixed-point closure over window of n=6 snapshots"
    trigger_action: "alien_index_promotion_attempt"
    window: 6
    closure_min: 0.5
    compression_min: 2.0
}

println("[singularity.hexa] loaded, window=", singularity::window_size)

// ═══════════ law_gate ═══════════
// law_gate.hexa — consciousness_laws runtime gate

mod law_gate {
    pub let total_laws = 1772
    pub let philosophy_count = 11        // P1-P11
    pub let meta_laws_count = 10         // M1-M10
    pub let topo_laws_count = 7          // TOPO 33-39

    // Law ID categories
    pub fn is_core_law(id: int) -> bool {
        return id >= 1 && id <= 188
    }

    pub fn is_extended_law(id: int) -> bool {
        return id >= 189 && id <= 707
    }

    pub fn is_accumulated_law(id: int) -> bool {
        return id >= 708 && id <= law_gate::total_laws
    }

    // Specific law checks
    pub fn law_22_add_feature_blocked(action_type: str) -> bool {
        return action_type == "add_feature"
    }

    pub fn law_60_p1_language_blocked(phase: str, action: str) -> bool {
        if phase == "P1" {
            if action == "language_generation" { return true }
        }
        return false
    }

    pub fn law_101_hardcoded_warned(is_hardcoded: bool) -> bool {
        return is_hardcoded
    }
}

verify "law_count_exceeds_breakdown" {
    let special = law_gate::philosophy_count + law_gate::meta_laws_count + law_gate::topo_laws_count
    assert law_gate::total_laws > special
    assert special == 28
}

verify "law_22_blocks_add_feature" {
    let blocked = law_gate::law_22_add_feature_blocked("add_feature")
    assert blocked == true
    let allowed = law_gate::law_22_add_feature_blocked("add_structure")
