}

verify "law_60_phase_discipline" {
    let p1_lang_block = law_gate::law_60_p1_language_blocked("P1", "language_generation")
    assert p1_lang_block == true
    let p3_lang_ok = law_gate::law_60_p1_language_blocked("P3", "language_generation")
    assert p3_lang_ok == false
}

verify "law_id_ranges_valid" {
    assert law_gate::is_core_law(22) == true
    assert law_gate::is_core_law(188) == true
    assert law_gate::is_core_law(189) == false
    assert law_gate::is_extended_law(300) == true
    assert law_gate::is_accumulated_law(1500) == true
}

