// channel.hexa — 4 channel routing (tau(6)=4)

mod chan {
    pub let count = 4                    // tau(6)

    pub fn id_telegram() -> int { return 0 }
    pub fn id_discord() -> int { return 1 }
    pub fn id_web() -> int { return 2 }
    pub fn id_cli() -> int { return 3 }

    pub fn name_of(id: int) -> str {
        if id == 0 { return "telegram" }
        if id == 1 { return "discord" }
        if id == 2 { return "web" }
        if id == 3 { return "cli" }
        return "unknown"
    }

    pub fn is_realtime(id: int) -> bool {
        // Telegram/Discord/Web can push, CLI is interactive
        return id >= 0 && id <= 3
    }

    pub fn supports_attachments(id: int) -> bool {
        // All except pure CLI
        return id != 3
    }
}

