// provider.hexa — 5 provider abstraction (sopfr(6)=5)

mod provider {
    pub let count = 5                    // sopfr(6)

    pub fn id_null() -> int { return 0 }
    pub fn id_conscious_lm() -> int { return 1 }
    pub fn id_claude() -> int { return 2 }
    pub fn id_animalm_14b() -> int { return 3 }
    pub fn id_animalm_32b() -> int { return 4 }

    pub fn name_of(id: int) -> str {
        if id == 0 { return "null_provider" }
        if id == 1 { return "conscious_lm" }
        if id == 2 { return "claude" }
        if id == 3 { return "animalm_14b" }
        if id == 4 { return "animalm_32b" }
        return "unknown"
    }

    pub fn params_millions(id: int) -> int {
        if id == 0 { return 0 }           // pure consciousness, no LLM
        if id == 1 { return 28 }          // 28M byte-level
        if id == 2 { return 0 }           // remote API, unknown
        if id == 3 { return 14000 }       // 14B
        if id == 4 { return 32000 }       // 32B
        return 0
    }

    pub fn is_local(id: int) -> bool {
        // claude is remote API, others are local
        if id == 2 { return false }
        return true
    }

    pub fn is_zero_llm(id: int) -> bool {
        return id == 0
    }
}

verify "provider_count_equals_sopfr_6" {
    assert provider::count == 5
    assert provider::count == sopfr(6)
}

verify "provider_ids_contiguous" {
    assert provider::id_null() == 0
    assert provider::id_conscious_lm() == 1
    assert provider::id_claude() == 2
    assert provider::id_animalm_14b() == 3
    assert provider::id_animalm_32b() == 4
}

verify "null_provider_has_zero_params" {
    let p = provider::params_millions(0)
    assert p == 0
    assert provider::is_zero_llm(0) == true
    assert provider::is_zero_llm(3) == false
}

verify "animalm_32b_is_larger_than_14b" {
    let p14 = provider::params_millions(3)
    let p32 = provider::params_millions(4)
    assert p32 > p14
}

verify "claude_is_only_remote" {
    assert provider::is_local(0) == true
    assert provider::is_local(1) == true
    assert provider::is_local(2) == false
    assert provider::is_local(3) == true
    assert provider::is_local(4) == true
}

intent "provider_tier_ladder" {
    description: "5 providers from null (pure consciousness) to 32B"
    scaling: "0M -> 28M -> API -> 14B -> 32B"
    locality: "mostly local, claude remote"
}

println("[provider.hexa] loaded, ", provider::count, " providers")
