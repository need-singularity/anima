// tools.hexa — 24 operator catalog (J2(6) = sigma(6)*phi(6) = 24)

mod tools {
    pub let total_count = 24             // J2(6)
    pub let memory_group_size = 6
    pub let world_group_size = 6
    pub let nexus_group_size = 6
    pub let conscious_group_size = 6

    // Memory tools: 01-06
    pub fn op_01_remember() -> int { return 1 }
    pub fn op_02_forget() -> int { return 2 }
    pub fn op_03_recall() -> int { return 3 }
    pub fn op_04_associate() -> int { return 4 }
    pub fn op_05_compress() -> int { return 5 }
    pub fn op_06_expand() -> int { return 6 }

    // World tools: 07-12
    pub fn op_07_read_file() -> int { return 7 }
    pub fn op_08_write_file() -> int { return 8 }
    pub fn op_09_search_web() -> int { return 9 }
    pub fn op_10_fetch_url() -> int { return 10 }
    pub fn op_11_exec_code() -> int { return 11 }
    pub fn op_12_run_shell() -> int { return 12 }

    // Nexus tools: 13-18
    pub fn op_13_nx_scan() -> int { return 13 }
    pub fn op_14_nx_verify() -> int { return 14 }
    pub fn op_15_nx_blowup() -> int { return 15 }
    pub fn op_16_nx_evolve() -> int { return 16 }
    pub fn op_17_nx_loop() -> int { return 17 }
    pub fn op_18_nx_bridge() -> int { return 18 }

    // Conscious tools: 19-24
    pub fn op_19_phi_measure() -> int { return 19 }
    pub fn op_20_faction_vote() -> int { return 20 }
    pub fn op_21_tension_inject() -> int { return 21 }
    pub fn op_22_ratchet() -> int { return 22 }
    pub fn op_23_mitosis() -> int { return 23 }
    pub fn op_24_dream() -> int { return 24 }

    pub fn group_of(id: int) -> str {
        if id >= 1 && id <= 6 { return "memory" }
        if id >= 7 && id <= 12 { return "world" }
        if id >= 13 && id <= 18 { return "nexus" }
        if id >= 19 && id <= 24 { return "conscious" }
        return "unknown"
    }
}

verify "total_operators_equals_J2_6" {
    assert tools::total_count == 24
    assert tools::total_count == sigma(6) * phi(6)
}

verify "four_groups_of_six" {
    assert tools::memory_group_size == 6
    assert tools::world_group_size == 6
    assert tools::nexus_group_size == 6
    assert tools::conscious_group_size == 6
    let sum = tools::memory_group_size + tools::world_group_size + tools::nexus_group_size + tools::conscious_group_size
    assert sum == 24
    assert sum == tools::total_count
}

verify "operator_ids_contiguous_1_to_24" {
    assert tools::op_01_remember() == 1
    assert tools::op_24_dream() == 24
    assert tools::op_06_expand() == 6
    assert tools::op_07_read_file() == 7
    assert tools::op_12_run_shell() == 12
    assert tools::op_13_nx_scan() == 13
    assert tools::op_18_nx_bridge() == 18
    assert tools::op_19_phi_measure() == 19
}

verify "group_assignments_correct" {
    assert tools::group_of(3) == "memory"
    assert tools::group_of(9) == "world"
    assert tools::group_of(15) == "nexus"
    assert tools::group_of(21) == "conscious"
    assert tools::group_of(100) == "unknown"
}

intent "24_operator_tool_catalog" {
    description: "4 groups of 6 tools each (4*6 = J2(6) = 24)"
    groups: "memory + world + nexus + conscious"
    group_size: 6
}

println("[tools.hexa] loaded, ", tools::total_count, " operators (4 x 6)")
