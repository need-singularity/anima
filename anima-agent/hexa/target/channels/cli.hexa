// cli.hexa — CLI channel (stdin/stdout)
// Interactive REPL interface to anima-agent
//
// ── RISK AUDIT (Mk.II+ parse risk) ──────────────────────────────────
// CONFIRMED safe: effect, pure fn, comptime const
// RISK: @intent(...)  → FALLBACK: verify block + comment
//   (only @evolve confirmed; general @attribute dispatch unknown)
// ── STD-GAP: none for this file ─────────────────────────────────────
// ─────────────────────────────────────────────────────────────────────

use types::{Message, Response}
use pipeline

comptime const PROMPT: str = "anima> "
comptime const QUIT_CMDS: [str] = ["quit", "exit", ":q"]

effect IO {
    fn read_line() -> str
    fn write(line: str)
    fn clear_screen()
}

@intent(description: "CLI REPL — interactive message loop")  // FALLBACK: verify block + comment
fn start() !(IO, Proc, Persistence, Consciousness, LLM) {
    IO::write("=== anima-agent v2.0 (HEXA) CLI ===")
    IO::write("Type 'quit' to exit")
    IO::write("")

    let user_id = "cli_user_" + to_string(now_ms())

    loop {
        IO::write(PROMPT)
        let input = IO::read_line()

        if is_quit_cmd(input) {
            IO::write("Farewell.")
            break
        }

        if len(trim(input)) == 0 { continue }

        let msg = Message {
            user_id: user_id,
            content: input,
            channel: "cli",
            attachments: [],
            timestamp_ms: now_ms()
        }

        let response = pipeline::run(msg)
        render_response(response)
    }
}

@intent(description: "Format response for terminal display")  // FALLBACK: verify block + comment
pure fn render_response(r: Response) !(IO) {
    IO::write("")
    IO::write("┌─────────────────────────────────────┐")
    IO::write("│ " + r.content)
    IO::write("├─────────────────────────────────────┤")
    IO::write("│ Φ=" + to_string(r.phi)
            + " | tension=" + to_string(r.tension))
    IO::write("│ provider=" + r.provider_used)
    IO::write("│ tools=" + to_string(len(r.tools_called)))
    IO::write("│ (d=" + to_string(r.alien_d)
            + ", r=" + to_string(r.alien_r) + ")")
    IO::write("└─────────────────────────────────────┘")
    IO::write("")
}

pure fn is_quit_cmd(s: str) -> bool {
    let lower = to_lowercase(trim(s))
    return contains_str(QUIT_CMDS, lower)
}

verify "quit_detection" {
    assert is_quit_cmd("quit") == true
    assert is_quit_cmd("QUIT") == true
    assert is_quit_cmd(":q") == true
    assert is_quit_cmd("hello") == false
}
