// std_hashmap.hexa — HashMap built on BTreeMap + SHA-256 bucket hashing
// Proposed addition to HEXA std library
//
// HEXA provides BTreeMap (ordered, O(log n)) but no hash-based map.
// This module wraps btree_* primitives with SHA-256 hashing to provide
// amortized O(1) get/put via bucket distribution.
//
// Architecture:
//   HashMap<K, V> = BTreeMap<int, [(K, V)]>
//   - Key K is hashed via sha256 -> truncated to bucket index
//   - Each bucket is a BTreeMap entry holding a list of (K, V) pairs
//   - Collisions resolved by linear scan within bucket (small lists)
//
// Built on existing primitives:
//   btree_new, btree_get, btree_set, btree_remove, btree_keys (std::collections)
//   sha256 (std::crypto)
//
// ── RISK AUDIT (Mk.II+ parse risk) ──────────────────────────────────
// CONFIRMED safe: struct, pure fn, ensures, where, comptime const, match
// ─────────────────────────────────────────────────────────────────────

use std::collections::{BTreeMap, btree_new, btree_get, btree_set, btree_remove, btree_keys}
use std::crypto::{sha256}

// ── Configuration ───────────────────────────────────────────────────

comptime const DEFAULT_BUCKET_COUNT: int = 256    // 2^8, power of 2 for fast modulo
comptime const MAX_BUCKET_COUNT: int = 65536      // 2^16
comptime const LOAD_FACTOR_THRESHOLD: float = 0.75

// ── Types ───────────────────────────────────────────────────────────

struct HashMap<K, V> {
    buckets: BTreeMap<int, [(K, V)]>,
    bucket_count: int,
    size: int
}

enum HashMapEntry<K, V> {
    Occupied(K, V),
    Vacant(K)
}

// ══════════════════════════════════════════════════════════════════════
// Pure functions — hashing, bucket operations, constructors
// ══════════════════════════════════════════════════════════════════════

// ── Hash computation ────────────────────────────────────────────────

pure fn hash_key(key: str, bucket_count: int) -> int
  where bucket_count > 0
  ensures result >= 0 && result < bucket_count
{
    let digest = sha256(str_to_bytes(key))
    // Take first 4 bytes of SHA-256 as 32-bit integer (big-endian)
    let h = (digest[0] << 24) | (digest[1] << 16) | (digest[2] << 8) | digest[3]
    // Modulo by bucket count (bit-AND when bucket_count is power of 2)
    return h % bucket_count
}

pure fn hash_int_key(key: int, bucket_count: int) -> int
  where bucket_count > 0
  ensures result >= 0 && result < bucket_count
{
    return hash_key(to_string(key), bucket_count)
}

pure fn is_power_of_two(n: int) -> bool
  where n > 0
{
    return (n & (n - 1)) == 0
}

// ── Constructor ─────────────────────────────────────────────────────

pure fn new<K, V>() -> HashMap<K, V>
  ensures result.size == 0
{
    return HashMap {
        buckets: btree_new(),
        bucket_count: DEFAULT_BUCKET_COUNT,
        size: 0
    }
}

pure fn with_capacity<K, V>(bucket_count: int) -> HashMap<K, V>
  where bucket_count > 0 && bucket_count <= MAX_BUCKET_COUNT
  ensures result.size == 0
{
    return HashMap {
        buckets: btree_new(),
        bucket_count: bucket_count,
        size: 0
    }
}

// ── Core operations ─────────────────────────────────────────────────

pure fn put<V>(map: HashMap<str, V>, key: str, value: V) -> HashMap<str, V>
  ensures result.size >= map.size && result.size <= map.size + 1
{
    let idx = hash_key(key, map.bucket_count)
    let bucket = match btree_get(map.buckets, idx) {
        Some(b) => b,
        None    => []
    }

    // Check if key already exists in bucket — update in place
    let mut new_bucket: [(str, V)] = []
    let mut found = false
    for (k, v) in bucket {
        if k == key {
            new_bucket = append(new_bucket, (key, value))
            found = true
        } else {
            new_bucket = append(new_bucket, (k, v))
        }
    }

    // Key not found — append new entry
    if !found {
        new_bucket = append(new_bucket, (key, value))
    }

    let new_buckets = btree_set(map.buckets, idx, new_bucket)
    let new_size = if found { map.size } else { map.size + 1 }

    return HashMap {
        buckets: new_buckets,
        bucket_count: map.bucket_count,
        size: new_size
    }
}

pure fn get<V>(map: HashMap<str, V>, key: str) -> Option<V> {
    let idx = hash_key(key, map.bucket_count)
    match btree_get(map.buckets, idx) {
        Some(bucket) => {
            for (k, v) in bucket {
                if k == key {
                    return Some(v)
                }
            }
            return None
        },
        None => None
    }
}

pure fn contains_key<V>(map: HashMap<str, V>, key: str) -> bool {
    match get(map, key) {
        Some(_) => true,
        None    => false
    }
}

pure fn remove<V>(map: HashMap<str, V>, key: str) -> HashMap<str, V>
  ensures result.size <= map.size
{
    let idx = hash_key(key, map.bucket_count)
    match btree_get(map.buckets, idx) {
        Some(bucket) => {
            let mut new_bucket: [(str, V)] = []
            let mut found = false
            for (k, v) in bucket {
                if k == key {
                    found = true
                    // skip — effectively removes the entry
                } else {
                    new_bucket = append(new_bucket, (k, v))
                }
            }

            let new_buckets = if len(new_bucket) == 0 {
                btree_remove(map.buckets, idx)
            } else {
                btree_set(map.buckets, idx, new_bucket)
            }

            return HashMap {
                buckets: new_buckets,
                bucket_count: map.bucket_count,
                size: if found { map.size - 1 } else { map.size }
            }
        },
        None => map  // key not present, return unchanged
    }
}

// ── Iteration ───────────────────────────────────────────────────────

pure fn keys<V>(map: HashMap<str, V>) -> [str]
  ensures len(result) == map.size
{
    let mut result: [str] = []
    let bucket_indices = btree_keys(map.buckets)
    for idx in bucket_indices {
        match btree_get(map.buckets, idx) {
            Some(bucket) => {
                for (k, _) in bucket {
                    result = append(result, k)
                }
            },
            None => {}
        }
    }
    return result
}

pure fn values<V>(map: HashMap<str, V>) -> [V]
  ensures len(result) == map.size
{
    let mut result: [V] = []
    let bucket_indices = btree_keys(map.buckets)
    for idx in bucket_indices {
        match btree_get(map.buckets, idx) {
            Some(bucket) => {
                for (_, v) in bucket {
                    result = append(result, v)
                }
            },
            None => {}
        }
    }
    return result
}

pure fn entries<V>(map: HashMap<str, V>) -> [(str, V)]
  ensures len(result) == map.size
{
    let mut result: [(str, V)] = []
    let bucket_indices = btree_keys(map.buckets)
    for idx in bucket_indices {
        match btree_get(map.buckets, idx) {
            Some(bucket) => {
                for entry in bucket {
                    result = append(result, entry)
                }
            },
            None => {}
        }
    }
    return result
}

// ── Utility ─────────────────────────────────────────────────────────

pure fn len<K, V>(map: HashMap<K, V>) -> int
  ensures result >= 0
{
    return map.size
}

pure fn is_empty<K, V>(map: HashMap<K, V>) -> bool {
    return map.size == 0
}

pure fn load_factor<K, V>(map: HashMap<K, V>) -> float
  ensures result >= 0.0
{
    return to_float(map.size) / to_float(map.bucket_count)
}

// ── Merge / bulk operations ─────────────────────────────────────────

pure fn merge<V>(a: HashMap<str, V>, b: HashMap<str, V>) -> HashMap<str, V>
  ensures result.size >= a.size && result.size <= a.size + b.size
{
    let mut result = a
    let b_entries = entries(b)
    for (k, v) in b_entries {
        result = put(result, k, v)
    }
    return result
}

pure fn from_entries<V>(items: [(str, V)]) -> HashMap<str, V>
  ensures result.size <= len(items)
{
    let mut map = new()
    for (k, v) in items {
        map = put(map, k, v)
    }
    return map
}

// ── Map / filter / fold ─────────────────────────────────────────────

pure fn map_values<V, U>(map: HashMap<str, V>, f: fn(V) -> U) -> HashMap<str, U> {
    let mut result = new()
    let all = entries(map)
    for (k, v) in all {
        result = put(result, k, f(v))
    }
    return result
}

pure fn filter<V>(map: HashMap<str, V>, pred: fn(str, V) -> bool) -> HashMap<str, V>
  ensures result.size <= map.size
{
    let mut result = new()
    let all = entries(map)
    for (k, v) in all {
        if pred(k, v) {
            result = put(result, k, v)
        }
    }
    return result
}

pure fn fold<V, A>(map: HashMap<str, V>, init: A, f: fn(A, str, V) -> A) -> A {
    let mut acc = init
    let all = entries(map)
    for (k, v) in all {
        acc = f(acc, k, v)
    }
    return acc
}

// ── Get with default ────────────────────────────────────────────────

pure fn get_or<V>(map: HashMap<str, V>, key: str, default: V) -> V {
    match get(map, key) {
        Some(v) => v,
        None    => default
    }
}

pure fn get_or_put<V>(map: HashMap<str, V>, key: str, default: V) -> (HashMap<str, V>, V) {
    match get(map, key) {
        Some(v) => (map, v),
        None    => (put(map, key, default), default)
    }
}

// ══════════════════════════════════════════════════════════════════════
// Verification
// ══════════════════════════════════════════════════════════════════════

verify "new_map_is_empty" {
    let m: HashMap<str, int> = new()
    assert is_empty(m)
    assert len(m) == 0
}

verify "put_then_get" {
    let m = new()
    let m = put(m, "alpha", 1)
    let m = put(m, "beta", 2)
    assert get(m, "alpha") == Some(1)
    assert get(m, "beta") == Some(2)
    assert get(m, "gamma") == None
    assert len(m) == 2
}

verify "put_overwrites" {
    let m = new()
    let m = put(m, "key", 10)
    let m = put(m, "key", 20)
    assert get(m, "key") == Some(20)
    assert len(m) == 1   // size must not double-count
}

verify "remove_works" {
    let m = new()
    let m = put(m, "a", 1)
    let m = put(m, "b", 2)
    let m = remove(m, "a")
    assert get(m, "a") == None
    assert get(m, "b") == Some(2)
    assert len(m) == 1
}

verify "remove_missing_key_is_noop" {
    let m = new()
    let m = put(m, "x", 99)
    let m2 = remove(m, "nonexistent")
    assert len(m2) == 1
    assert get(m2, "x") == Some(99)
}

verify "keys_values_entries_consistent" {
    let m = new()
    let m = put(m, "a", 1)
    let m = put(m, "b", 2)
    let m = put(m, "c", 3)
    assert len(keys(m)) == 3
    assert len(values(m)) == 3
    assert len(entries(m)) == 3
}

verify "from_entries_roundtrip" {
    let items = [("x", 10), ("y", 20), ("z", 30)]
    let m = from_entries(items)
    assert len(m) == 3
    assert get(m, "x") == Some(10)
    assert get(m, "y") == Some(20)
    assert get(m, "z") == Some(30)
}

verify "merge_combines" {
    let a = from_entries([("a", 1), ("b", 2)])
    let b = from_entries([("b", 99), ("c", 3)])
    let merged = merge(a, b)
    assert get(merged, "a") == Some(1)
    assert get(merged, "b") == Some(99)   // b's value wins
    assert get(merged, "c") == Some(3)
    assert len(merged) == 3
}

verify "hash_distribution_no_single_bucket" {
    // Verify that 4 distinct keys hash to at least 2 different buckets
    let h1 = hash_key("alpha", DEFAULT_BUCKET_COUNT)
    let h2 = hash_key("beta", DEFAULT_BUCKET_COUNT)
    let h3 = hash_key("gamma", DEFAULT_BUCKET_COUNT)
    let h4 = hash_key("delta", DEFAULT_BUCKET_COUNT)
    // SHA-256 should distribute well — at least 2 distinct buckets
    let distinct = len(unique([h1, h2, h3, h4]))
    assert distinct >= 2
}

verify "default_bucket_count_is_power_of_two" {
    assert is_power_of_two(DEFAULT_BUCKET_COUNT)
    assert is_power_of_two(MAX_BUCKET_COUNT)
}

verify "load_factor_computation" {
    let m = from_entries([("a", 1), ("b", 2)])
    let lf = load_factor(m)
    // 2 / 256 = 0.0078125
    assert lf > 0.0 && lf < 0.01
}

verify "filter_reduces_size" {
    let m = from_entries([("a", 1), ("b", 2), ("c", 3)])
    let filtered = filter(m, |k, v| v > 1)
    assert len(filtered) == 2
    assert get(filtered, "a") == None
    assert get(filtered, "b") == Some(2)
}

verify "map_values_transforms" {
    let m = from_entries([("x", 10)])
    let doubled = map_values(m, |v| v * 2)
    assert get(doubled, "x") == Some(20)
}

verify "fold_sums" {
    let m = from_entries([("a", 1), ("b", 2), ("c", 3)])
    let total = fold(m, 0, |acc, _k, v| acc + v)
    assert total == 6
}
