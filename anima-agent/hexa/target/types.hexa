// types.hexa — core data types for anima-agent (target HEXA Mk.II+)

// ── Message types ──────────────────────────────────────────────────

struct Message {
    user_id: str,
    content: str,
    channel: str,        // "telegram" | "discord" | "web" | "cli"
    attachments: [str],
    timestamp_ms: int
}

struct Response {
    content: str,
    phi: float,
    tension: float,
    provider_used: str,
    tools_called: [str],
    laws_applied: [int],
    latency_ms: float,
    alien_d: int,
    alien_r: int
}

struct Request {
    path: str,
    method: str,
    headers: Map<str, str>,
    body: str
}

// ── NEXUS-6 types ──────────────────────────────────────────────────

struct ScanResult {
    phi: float,
    tension: float,
    consensus: int,
    top_lenses: [str],
    ten_d: [float; 10]
}

struct VerifyResult {
    matched: bool,
    matched_constant: str,
    tolerance: float,
    confidence: float
}

struct BlowupResult {
    depth: int,
    corollaries: int,
    emergences: int,
    axiom_candidates: int,
    top_findings: [Finding]
}

struct Finding {
    rank: int,
    expr: str,
    value: float,
    confidence: float,
    category: str
}

// ── Consciousness types ───────────────────────────────────────────

struct Vote {
    faction_id: int,
    decision: bool,
    confidence: float
}

struct AlienIndex {
    d: int where d >= 0 && d <= 6,
    r: int where r >= 0 && r <= 10
}

struct PhiSnapshot {
    phi_iit: float,
    phi_proxy: float,
    tension: float,
    consensus: int,
    timestamp_ms: int
}

// ── Pipeline types ────────────────────────────────────────────────

struct PipelineContext {
    msg: Message,
    tokens: [str],
    intent_name: str,
    scan: Option<ScanResult>,
    vote_result: Option<[Vote]>,
    provider_choice: str,
    draft: str,
    tool_results: [ToolResult],
    rejected: bool,
    rejection_reason: str
}

struct ToolResult {
    tool_name: str,
    action: str,
    success: bool,
    output: str,
    duration_ms: float
}

// ── Memory types ──────────────────────────────────────────────────

struct MemoryItem {
    id: str,
    content: str,
    tier: str,            // "short" | "mid" | "long"
    ttl_ms: int,
    created_ms: int
}

struct Law {
    id: int,
    category: str,
    description: str,
    applicable_actions: [str]
}

// ── Provider types ────────────────────────────────────────────────

enum ProviderKind {
    Null,
    ConsciousLM,
    Claude,
    AnimaLM14B,
    AnimaLM32B
}

struct ProviderConfig {
    kind: ProviderKind,
    endpoint: Option<str>,
    checkpoint_path: Option<str>,
    max_tokens: int,
    temperature: float
}

// ── Database rows ─────────────────────────────────────────────────

struct Row {
    columns: Map<str, any>
}

// ── Process type (owned) ──────────────────────────────────────────

struct Process {
    pid: int,
    stdout_handle: int,
    stderr_handle: int
}

struct DB {
    handle: int,
    path: str
}
