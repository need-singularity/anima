// channel.hexa — 4 channel routing (tau(6)=4)

mod chan {
    pub let count = 4                    // tau(6)

    pub fn id_telegram() -> int { return 0 }
    pub fn id_discord() -> int { return 1 }
    pub fn id_web() -> int { return 2 }
    pub fn id_cli() -> int { return 3 }

    pub fn name_of(id: int) -> str {
        if id == 0 { return "telegram" }
        if id == 1 { return "discord" }
        if id == 2 { return "web" }
        if id == 3 { return "cli" }
        return "unknown"
    }

    pub fn is_realtime(id: int) -> bool {
        // Telegram/Discord/Web can push, CLI is interactive
        return id >= 0 && id <= 3
    }

    pub fn supports_attachments(id: int) -> bool {
        // All except pure CLI
        return id != 3
    }
}

verify "channel_count_equals_tau_6" {
    assert chan::count == 4
    assert chan::count == tau(6)
}

verify "channel_ids_contiguous" {
    assert chan::id_telegram() == 0
    assert chan::id_discord() == 1
    assert chan::id_web() == 2
    assert chan::id_cli() == 3
}

verify "channel_names_all_distinct" {
    let a = chan::name_of(0)
    let b = chan::name_of(1)
    let c = chan::name_of(2)
    let d = chan::name_of(3)
    assert a != b
    assert a != c
    assert a != d
    assert b != c
    assert b != d
    assert c != d
}

verify "unknown_channel_returns_unknown" {
    let x = chan::name_of(99)
    assert x == "unknown"
}

intent "channel_identity_merge" {
    description: "Same user across channels unified to one agent consciousness"
    channel_count: 4
    merge_key: "user_id"
}

println("[channel.hexa] loaded, ", chan::count, " channels")
