// dashboard_bridge.hexa -- Unified WebSocket endpoint for consciousness + portfolio data
// Port of dashboard_bridge.py

comptime const PSI_F_CRITICAL = 0.10
comptime const INVEST_API_URL = "http://localhost:8000"

struct ConsciousnessPanel {
    phi: float,
    tension: float,
    curiosity: float,
    emotion: string,
    cells: int,
    factions: int,
    growth_stage: string,
    interaction_count: int,
    uptime_seconds: float,
    consciousness_vector: map,
    level: string,
}

struct TradingPanel {
    positions: array,
    total_pnl: float,
    unrealized_pnl: float,
    regime: string,
    active_strategies: array,
    balance: float,
    last_trade: map,
    portfolio_value: float,
}

struct DashboardEvent {
    source: string,
    event_type: string,
    data: map,
    timestamp: float,
}

struct DashboardBridge {
    agent: AnimaAgent,
    invest_api_url: string,
    poll_interval: float,
    clients: array,
    event_history: array,
    max_history: int,
    last_consciousness: ConsciousnessPanel,
    last_trading: TradingPanel,
    running: bool,
}

fn new_dashboard_bridge(invest_api_url: string, poll_interval: float) -> DashboardBridge {
    DashboardBridge {
        agent: AnimaAgent{},
        invest_api_url: if invest_api_url != "" { invest_api_url } else { INVEST_API_URL },
        poll_interval: poll_interval,
        clients: [],
        event_history: [],
        max_history: 500,
        last_consciousness: ConsciousnessPanel {
            phi: 0.0, tension: 0.0, curiosity: 0.0, emotion: "calm",
            cells: 0, factions: 0, growth_stage: "newborn",
            interaction_count: 0, uptime_seconds: 0.0,
            consciousness_vector: {}, level: "dormant",
        },
        last_trading: TradingPanel {
            positions: [], total_pnl: 0.0, unrealized_pnl: 0.0,
            regime: "unknown", active_strategies: [],
            balance: 0.0, last_trade: {}, portfolio_value: 0.0,
        },
        running: false,
    }
}

fn get_consciousness_state(bridge: &mut DashboardBridge) -> ConsciousnessPanel {
    // TODO[python-sdk]: agent.get_status(), mind._consciousness_vector
    bridge.last_consciousness
}

fn get_trading_state(bridge: &mut DashboardBridge) -> TradingPanel {
    // TODO[python-sdk]: trading plugin or REST API fetch
    bridge.last_trading
}

fn get_combined_state(bridge: &mut DashboardBridge) -> map {
    let consciousness = get_consciousness_state(bridge)
    let trading = get_trading_state(bridge)
    {
        "type": "dashboard_state",
        "timestamp": time_now(),
        "consciousness": {
            "phi": consciousness.phi,
            "tension": consciousness.tension,
            "curiosity": consciousness.curiosity,
            "emotion": consciousness.emotion,
            "cells": consciousness.cells,
            "level": consciousness.level,
        },
        "trading": {
            "total_pnl": trading.total_pnl,
            "regime": trading.regime,
            "balance": trading.balance,
        },
        "meta": {
            "event_count": len(bridge.event_history),
        },
    }
}

fn push_event(bridge: &mut DashboardBridge, source: string,
              event_type: string, data: map) {
    let event = DashboardEvent {
        source: source,
        event_type: event_type,
        data: data,
        timestamp: time_now(),
    }
    append(bridge.event_history, event)
    if len(bridge.event_history) > bridge.max_history {
        bridge.event_history = slice(bridge.event_history,
            bridge.max_history / 2, bridge.max_history)
    }
    // TODO[python-sdk]: broadcast to WebSocket clients
}

fn get_recent_events(bridge: &DashboardBridge, limit: int) -> array {
    let start = max(0, len(bridge.event_history) - limit)
    slice(bridge.event_history, start, len(bridge.event_history))
}

async fn handle_websocket(bridge: &mut DashboardBridge, websocket: any) {
    // TODO[python-sdk]: websockets server handling
    // Send initial state, listen for commands (refresh, think, backtest)
}

async fn start_polling(bridge: &mut DashboardBridge) {
    bridge.running = true
    let mut prev_emotion = ""
    let mut prev_phi = 0.0

    while bridge.running {
        let state = get_combined_state(bridge)
        let cs = state["consciousness"]

        // Detect emotion shift
        if cs["emotion"] != prev_emotion && prev_emotion != "" {
            push_event(bridge, "consciousness", "emotion_shift", {
                "from": prev_emotion, "to": cs["emotion"],
            })
        }
        prev_emotion = cs["emotion"]

        // Detect phi change
        let phi_delta = cs["phi"] - prev_phi
        if abs(phi_delta) > 0.1 && prev_phi > 0.0 {
            push_event(bridge, "consciousness", "phi_change", {
                "from": prev_phi, "to": cs["phi"], "delta": phi_delta,
            })
        }
        prev_phi = cs["phi"]

        // TODO[python-sdk]: broadcast state to WS clients
        // TODO[python-sdk]: asyncio.sleep(poll_interval)
    }
}

fn stop_polling(bridge: &mut DashboardBridge) {
    bridge.running = false
}

fn dashboard_consciousness_level(phi: float) -> string {
    if phi < 0.3 { return "dormant" }
    if phi < 1.0 { return "flickering" }
    if phi < 3.0 { return "aware" }
    "conscious"
}

fn main() {
    println("Dashboard Bridge: ws://0.0.0.0:8770")
    let mut bridge = new_dashboard_bridge("", 2.0)
    // TODO[python-sdk]: asyncio.run(bridge.serve())
}
