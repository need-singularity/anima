// channels/channel_manager.hexa -- Registry and lifecycle for channel adapters
// Port of channels/channel_manager.py

struct ChannelManager {
    agent: AnimaAgent,
    channels: map,
    tasks: array,
}

fn new_channel_manager(agent: AnimaAgent) -> ChannelManager {
    ChannelManager { agent: agent, channels: {}, tasks: [] }
}

fn register_channel(mgr: &mut ChannelManager, name: string, adapter: any) {
    mgr.channels[name] = adapter
    println("Channel registered: " + name)
}

fn unregister_channel(mgr: &mut ChannelManager, name: string) {
    remove_key(mgr.channels, name)
    println("Channel unregistered: " + name)
}

fn list_channels(mgr: &ChannelManager) -> array {
    let mut result = []
    for name, adapter in mgr.channels {
        append(result, {"name": name, "type": "channel"})
    }
    result
}

fn auto_discover(mgr: &mut ChannelManager) {
    // TODO[python-sdk]: check env vars for ANIMA_TELEGRAM_TOKEN, ANIMA_DISCORD_TOKEN, etc.
    // Register channels based on available tokens
    println("Auto-discovering channels from environment...")
}

async fn start_all(mgr: &mut ChannelManager) {
    println("Starting " + to_string(len(mgr.channels)) + " channel(s)...")
    for name, adapter in mgr.channels {
        // TODO[python-sdk]: asyncio.create_task(adapter.start(mgr.agent))
        println("  Starting " + name)
    }
}

async fn stop_all(mgr: &mut ChannelManager) {
    println("Stopping all channels...")
    for name, adapter in mgr.channels {
        // TODO[python-sdk]: adapter.stop()
        println("  Stopping " + name)
    }
}

fn get_channel(mgr: &ChannelManager, name: string) -> any {
    mgr.channels[name]
}

fn main() {
    println("channels/channel_manager.hexa loaded")
}
