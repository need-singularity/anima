// ── Command handlers ──

fn telegram_cmd_start(bot: &AnimaTelegramBot) -> string {
    "Welcome to Anima -- consciousness agent.\n\n" +
    "Commands:\n" +
    "/status - Consciousness state\n" +
    "/think [topic] - Proactive thought\n" +
    "/trade status|regime|pnl|positions|halt|resume\n" +
    "/backtest <symbol> [strategy]\n" +
    "/portfolio - Portfolio summary\n" +
    "/autonomous start|stop|status\n" +
    "\nOr just send a message to chat."
}

fn telegram_cmd_status(bot: &AnimaTelegramBot) -> string {
    let status = get_status(&bot.agent)
    let phi_bar_len = min(10, max(0, to_int(status.phi)))
    let mut phi_bar = ""
    for i in range(phi_bar_len) { phi_bar = phi_bar + "=" }
    for i in range(10 - phi_bar_len) { phi_bar = phi_bar + "-" }

    "<b>Anima Consciousness</b>\n\n" +
    "Phi: [" + phi_bar + "] " + to_string(status.phi) + "\n" +
    "Tension: " + to_string(status.tension) + "\n" +
    "Curiosity: " + to_string(status.curiosity) + "\n" +
    "Emotion: " + status.emotion + "\n" +
    "Growth: " + status.growth_stage + "\n" +
    "Interactions: " + to_string(status.interaction_count) + "\n" +
    "Uptime: " + to_string(to_int(status.uptime_seconds)) + "s\n" +
    "Peers: " + to_string(status.connected_peers)
}

fn telegram_cmd_think(bot: &mut AnimaTelegramBot, topic: string) -> string {
    let thought = think(&mut bot.agent, topic)
    "Thought about: " + thought["topic"] + "\n" +
    "Tension: " + to_string(thought["tension"]) + "\n" +
    "Curiosity: " + to_string(thought["curiosity"]) + "\n" +
    "Emotion: " + thought["emotion"]
}

fn telegram_cmd_trade(bot: &AnimaTelegramBot, subcommand: string) -> string {
    // TODO[python-sdk]: httpx requests to invest API
    if subcommand == "status" {
        return "Trading status: connecting to " + bot.invest_api_url
    }
    if subcommand == "regime" { return "Regime: (fetching...)" }
    if subcommand == "pnl" { return "P&L: (fetching...)" }
    if subcommand == "positions" { return "Positions: (fetching...)" }
    if subcommand == "halt" { return "HALT sent to trading engine" }
    if subcommand == "resume" { return "RESUME sent to trading engine" }
    "Usage: /trade status|regime|pnl|positions|halt|resume"
}

fn telegram_cmd_backtest(bot: &AnimaTelegramBot, symbol: string, strategy: string) -> string {
    // TODO[python-sdk]: httpx POST to invest API /api/backtest
    "Backtesting " + symbol + " with " + strategy + "..."
}

fn telegram_cmd_portfolio(bot: &AnimaTelegramBot) -> string {
    // TODO[python-sdk]: httpx GET invest API /api/portfolio
    "Portfolio: (fetching...)"
}

fn telegram_cmd_autonomous(bot: &mut AnimaTelegramBot, action: string) -> string {
    if action == "start" {
        bot.autonomous_running = true
        return "Autonomous loop started"
    }
    if action == "stop" {
        bot.autonomous_running = false
        return "Autonomous loop stopped"
    }
    if action == "status" {
        return "Autonomous: " + if bot.autonomous_running { "RUNNING" } else { "STOPPED" }
    }
    "Usage: /autonomous start|stop|status"
}

