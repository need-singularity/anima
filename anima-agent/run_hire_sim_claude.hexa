// run_hire_sim_claude.hexa — 실 Claude API baseline (TSRV-P4-2 gate 첫 측정)
//
// 구성:
//   - 100 task corpus 중 도메인 계층화 30 subset (5 per domain × 6 도메인)
//   - depth=1 (1 root + 3 sub = 4 goals/task)
//   - 예상: ~30 × 7 API call = 210 호출, ~25-45분 wall (Claude Code hooks 포함)
//
// 출력:
//   - stdout: 전체 보고
//   - 저장: `training/deploy/hire_sim_claude_stratified30_d1.json` (수동 커밋)
//
// 실행: `hexa build` 로 컴파일된 binary 만 사용 (parse_float 인터프리터 이슈).

use "autonomy_loop"
use "hire_sim_100"
use "llm_claude_adapter"

fn subset_stratified(tasks: array, per_domain: int) -> array {
    let domains = ["email", "code", "meeting", "doc", "schedule", "research"]
    let mut out = []
    let mut di = 0
    while di < len(domains) {
        let dname = domains[di]
        let mut taken = 0
        let mut ti = 0
        while ti < len(tasks) && taken < per_domain {
            if tasks[ti].domain == dname {
                out = out.push(tasks[ti])
                taken = taken + 1
            }
            ti = ti + 1
        }
        di = di + 1
    }
    return out
}

fn main() {
    println("=== Claude baseline — hire_sim stratified30 × depth=1 ===")

    if !claude_cli_available() {
        println("ABORT: claude CLI not available")
        return
    }

    let all_tasks = load_tasks()
    println("loaded " + to_string(len(all_tasks)) + " total tasks from corpus")

    let subset = subset_stratified(all_tasks, 5)
    println("stratified subset: " + to_string(len(subset)) + " tasks (5 per 6 domain)")

    let adapter = LLMAdapter { name: "claude", temperature: 0.0 }

    println("")
    println("=== running run_hire_sim_with_depth(claude, subset, depth=1, budget=20) ===")
    println("(single pass — ~210 Claude API calls, 25-45min expected wall time)")
    let result = run_hire_sim_with_depth(adapter, subset, 1, 20)

    println("")
    println(hire_sim_report(result))

    println("")
    println("=== DONE ===")
    println("verdict: " + result.verdict)
    println("completion_rate: " + to_string(result.completion_rate))
    println("avg_score: " + to_string(result.avg_score))
}
