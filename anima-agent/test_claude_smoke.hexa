// test_claude_smoke.hexa — live probe of Claude CLI shell-out
// Sanity check ONLY — runs 1 call. Skipped gracefully if CLI unavailable.

use "llm_claude_adapter"

fn main() {
    println("=== claude CLI availability ===")
    let avail = claude_cli_available()
    println("available=" + to_string(avail))
    if !avail {
        println("SKIP: claude CLI not found; wiring is structural-only")
        return
    }

    println("=== shell_escape_single probe ===")
    let raw = "hello 'world'"
    let esc = shell_escape_single(raw)
    println("raw=" + raw)
    println("esc=" + esc)

    println("=== claude_call tiny prompt ===")
    let resp = claude_call("Reply with exactly: PONG")
    println("resp=[" + resp + "]")
    let ok = resp.contains("PONG")
    println("PONG probe PASS=" + to_string(ok))

    println("=== decompose probe ===")
    let subs = claude_decompose("plan a team offsite")
    println("got " + to_string(len(subs)) + " sub-goals")
    let mut i = 0
    while i < len(subs) {
        println("  " + to_string(i + 1) + ". " + subs[i])
        i = i + 1
    }

    println("=== DONE ===")
}
