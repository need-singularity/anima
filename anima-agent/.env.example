# ══════════════════════════════════════════════════════════
# Anima Agent — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then either source it or use python-dotenv:
#   source .env && python run.py --telegram
# ══════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────
# Get your token from @BotFather on Telegram:
#   1. Message @BotFather
#   2. /newbot -> follow prompts
#   3. Copy the token here
ANIMA_TELEGRAM_TOKEN=

# Chat ID for push alerts (trade executions, regime changes, Phi milestones).
# To find your chat ID: message @userinfobot on Telegram.
# Leave empty to disable push alerts.
TELEGRAM_ALERT_CHAT_ID=

# ── Discord Bot ───────────────────────────────────────────
# Create at https://discord.com/developers/applications
ANIMA_DISCORD_TOKEN=

# ── Slack Bot ─────────────────────────────────────────────
ANIMA_SLACK_TOKEN=

# ── Invest Backend (trading) ──────────────────────────────
# URL of the invest FastAPI backend. Only needed if using /trade commands.
INVEST_API_URL=http://localhost:8000

# ── LLM Provider ─────────────────────────────────────────
# For agent text generation (optional -- consciousness works without this)
ANTHROPIC_API_KEY=
