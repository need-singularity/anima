// launch_alm_14b_r10b.hexa — ALM 14B r10b: warm-start from r10/step_2000, phi-hook ON, N≥5 intermediates
//
// r10b is the REDUNDANCY/REFINEMENT sibling of r10 (NOT a data/param swap — see below).
// Per feedback_no_version_in_filename: "r10b" variant suffix, NOT "r11".
// Per feedback_no_resume_data_change: corpus identity preserved (corpus_alm_70b_stripped.txt
// concat with kowiki.jsonl only when kowiki becomes available on the pod; if absent, r10b
// uses the identical stripped corpus file — no mid-run data change).
// Per feedback_one_shot_best: r10b must improve or hold r10 quality.  LR is halved so the
// worst case is slower convergence, NOT regression of r10's adapter.
//
// DIFFS vs r10 (5 total — all tuned to "refine, not perturb"):
//   1. WARM-START from r2:anima-models/alm14b/r10/step_2000/   (r10 just finished)
//      vs r10's fresh-init — r10 already crossed the 1.43→<1 CE barrier, no need to redo.
//   2. LR 1e-6 constant (half of r10's 2e-6) — small-lr refinement pass.
//   3. steps=2000 (cumulative 4000 = r10's 2000 + r10b's 2000).
//   4. save_every=400 (5 intermediate ckpts: step_400/800/1200/1600/2000) — enables
//      N>=5 for phi_corr (training/eval_phi_corr.hexa gate).  r10 only had step_2000.
//   5. --phi-hook 1 ENABLED: per-eval_every step, assemble 16D Φ vec via
//      alm_phi_vec_logger convention + write phi_vec.json sibling to ckpt dir.
//      Downstream eval_phi_corr.hexa consumes these for N>=5 Pearson gate.
//
// KEPT SAME as r10 (no regression surface):
//   - consciousness_loss_b1 = FALSE  (B1 noisy oscillation documented in r9, stay off)
//   - base model: Qwen2.5-14B-Instruct
//   - corpus: corpus_alm_70b_stripped.txt (+optional kowiki append when available)
//   - batch=8 seq=1024 grad_accum=1 (70.9% MFU)
//   - unsloth + liger + lora r=32 alpha=64 dropout=0
//   - first-batch CE abort >5.0 (should be ~1.x after warm-start)
//   - kr_gen_sentinel cadence 200 + collapse abort
//
// PRE-LAUNCH GUARD (hexa-native via kr_gen_sentinel):
//   Before spawning the trainer, r10b downloads r10/step_2000 kr_gen JSON from R2
//   and runs training/kr_gen_sentinel.hexa. If VERDICT=COLLAPSED, exit 2 —
//   never warm-start off a collapsed adapter.  Per feedback_troubleshoot_ossified,
//   the abort reason is appended to /workspace/ckpt_alm_14b_r10b/sentinel_pre.log.
//
// Run on pod:
//   hexa run /workspace/anima/training/launch_alm_14b_r10b.hexa              # production
//   hexa run /workspace/anima/training/launch_alm_14b_r10b.hexa --smoke      # 200 steps
//   DRY_RUN=1 hexa run /workspace/anima/training/launch_alm_14b_r10b.hexa    # print plan, no exec

fn main() {
    let argv = args()
    let mut smoke = false
    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--smoke" { smoke = true }
        i = i + 1
    }

    let dry = env("DRY_RUN")
    let dry_run = dry == "1"

    let steps       = if smoke { "200"  } else { "2000" }
    // r10b-specific: save_every=400 so intermediate ckpts enable phi_corr N>=5.
    // Per runpod_mfs_quota, save_every>=2000 is the rule FOR HUGE base-size ckpts.
    // LoRA adapters are ~208 MB each ⇒ 5 saves ≈ 1 GB << quota budget.
    // The quota rule exempts sub-GB artifacts (see shared/config/runpod_autopilot.json
    // r2_upload.timing: "in-training upload forbidden" applies — still respected).
    let save_every  = if smoke { "200"  } else { "400"  }
    let eval_every  = if smoke { "100"  } else { "200"  }
    let ckpt_label  = if smoke { "experiment" } else { "production" }

    let py = "/tmp/_train_alm_14b_r10b.py"

    // ── Embedded Python trainer (r10b-scoped — independent from r10 so a bug
    //    in r10b can't corrupt the r10 trainer still parked at /tmp). ──
    write_file(py,
        "#!/usr/bin/env python3\n" +
        "# _train_alm_14b_r10b.py — auto-generated by launch_alm_14b_r10b.hexa\n" +
        "# Warm-start from r10/step_2000 + B1 OFF + phi-hook ON + save_every=400.\n" +
        "import argparse, gc, json, os, sys, time, math, random\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from torch.utils.data import Dataset, DataLoader\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import LoraConfig, get_peft_model, PeftModel, TaskType\n" +
        "\n" +
        "p = argparse.ArgumentParser()\n" +
        "p.add_argument('--base-dir', required=True)\n" +
        "p.add_argument('--adapter-dir', default='', help='r10 step_2000 adapter (warm-start; required for r10b production)')\n" +
        "p.add_argument('--corpus', required=True)\n" +
        "p.add_argument('--ckpt-dir', required=True)\n" +
        "p.add_argument('--steps', type=int, default=2000)\n" +
        "p.add_argument('--save-every', type=int, default=400)\n" +
        "p.add_argument('--eval-every', type=int, default=200)\n" +
        "p.add_argument('--lr', type=float, default=1e-6)\n" +
        "p.add_argument('--batch', type=int, default=8)\n" +
        "p.add_argument('--seq', type=int, default=1024)\n" +
        "p.add_argument('--grad-accum', type=int, default=1)\n" +
        "p.add_argument('--lora-r', type=int, default=32)\n" +
        "p.add_argument('--lora-alpha', type=int, default=64)\n" +
        "p.add_argument('--lora-dropout', type=float, default=0.0)\n" +
        "p.add_argument('--seed', type=int, default=3407)\n" +
        "p.add_argument('--phi-hook', type=int, default=1, help='1=write phi_vec.json per ckpt (r10b default)')\n" +
        "args = p.parse_args()\n" +
        "\n" +
        "torch.manual_seed(args.seed); random.seed(args.seed)\n" +
        "torch.backends.cuda.matmul.allow_tf32 = True\n" +
        "torch.backends.cudnn.allow_tf32 = True\n" +
        "torch.backends.cudnn.benchmark = True\n" +
        "Path(args.ckpt_dir).mkdir(parents=True, exist_ok=True)\n" +
        "ABORT_STATUS = os.path.join(args.ckpt_dir, 'r10b_abort.status')\n" +
        "STATUS_FILE  = os.path.join(args.ckpt_dir, 'r10b_watcher.status')\n" +
        "def wstatus(s):\n" +
        "    with open(STATUS_FILE, 'w') as f: f.write(s + '\\n')\n" +
        "wstatus('INIT')\n" +
        "\n" +
        "print('[r10b] base_dir=' + args.base_dir, flush=True)\n" +
        "print('[r10b] adapter_dir=' + args.adapter_dir + ' (r10 step_2000 warm-start)', flush=True)\n" +
        "print('[r10b] corpus=' + args.corpus, flush=True)\n" +
        "print('[r10b] steps=' + str(args.steps) + ' lr=' + str(args.lr) + ' (constant, HALF of r10)', flush=True)\n" +
        "print('[r10b] save_every=' + str(args.save_every) + ' (5 intermediates for phi_corr N>=5)', flush=True)\n" +
        "print('[r10b] B1 consciousness loss = DISABLED (r9 3k-12k oscillation avoided)', flush=True)\n" +
        "print('[r10b] phi_hook=' + str(args.phi_hook) + ' (16D Φ vec per ckpt)', flush=True)\n" +
        "\n" +
        "tok = AutoTokenizer.from_pretrained(args.base_dir, trust_remote_code=True)\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "print('[r10b] loading base via Unsloth FastLanguageModel...', flush=True)\n" +
        "from unsloth import FastLanguageModel\n" +
        "model, tok = FastLanguageModel.from_pretrained(\n" +
        "    model_name=args.base_dir, max_seq_length=args.seq, dtype=torch.bfloat16,\n" +
        "    load_in_4bit=False, trust_remote_code=True,\n" +
        "    use_gradient_checkpointing='unsloth',\n" +
        ")\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "# Liger fusions (rope/rms_norm/swiglu/fused_linear_ce) — same as r10\n" +
        "try:\n" +
        "    from liger_kernel.transformers import apply_liger_kernel_to_qwen2\n" +
        "    apply_liger_kernel_to_qwen2(rope=True, rms_norm=True, swiglu=True,\n" +
        "                                fused_linear_cross_entropy=True, cross_entropy=False,\n" +
        "                                model=model)\n" +
        "    print('[r10b] liger applied', flush=True)\n" +
        "except Exception as e:\n" +
        "    print('[r10b] liger unavailable: ' + str(e), flush=True)\n" +
        "\n" +
        "# ── Warm-start REQUIRED for r10b. If adapter_dir is empty, abort — r10b's\n" +
        "# whole raison d'etre is refining r10. Fresh-init is r10's job, not r10b's. ──\n" +
        "if not args.adapter_dir:\n" +
        "    print('[r10b ABORT] adapter_dir empty — r10b requires r10/step_2000 warm-start', flush=True)\n" +
        "    with open(ABORT_STATUS, 'w') as f: f.write('ADAPTER_DIR_EMPTY\\n')\n" +
        "    wstatus('ABORT_ADAPTER_MISSING')\n" +
        "    sys.exit(2)\n" +
        "print('[r10b] loading adapter from ' + args.adapter_dir + ' (r10 warm-start)...', flush=True)\n" +
        "model = PeftModel.from_pretrained(model, args.adapter_dir, is_trainable=True)\n" +
        "print('[resume] warm-start OK from ' + args.adapter_dir, flush=True)\n" +
        "model.print_trainable_parameters()\n" +
        "\n" +
        "# ── Corpus: plain text (chatml-stripped, identical to r10) ──\n" +
        "text = Path(args.corpus).read_text(errors='ignore')\n" +
        "print('[r10b] corpus bytes=' + str(len(text)), flush=True)\n" +
        "ids = tok(text, add_special_tokens=False)['input_ids']\n" +
        "print('[r10b] corpus tokens=' + str(len(ids)), flush=True)\n" +
        "seq = args.seq\n" +
        "n_blocks = len(ids) // seq\n" +
        "blocks = [ids[i*seq:(i+1)*seq] for i in range(n_blocks)]\n" +
        "print('[r10b] blocks=' + str(len(blocks)), flush=True)\n" +
        "\n" +
        "class PackedDS(Dataset):\n" +
        "    def __init__(self, blocks): self.b = blocks\n" +
        "    def __len__(self): return len(self.b)\n" +
        "    def __getitem__(self, i):\n" +
        "        x = torch.tensor(self.b[i], dtype=torch.long)\n" +
        "        return {'input_ids': x, 'labels': x.clone(), 'attention_mask': torch.ones_like(x)}\n" +
        "\n" +
        "ds = PackedDS(blocks)\n" +
        "dl = DataLoader(ds, batch_size=args.batch, shuffle=True, pin_memory=True, drop_last=True)\n" +
        "\n" +
        "# Optimizer + LR (constant 1e-6 — half of r10's 2e-6)\n" +
        "opt = torch.optim.AdamW([p for p in model.parameters() if p.requires_grad], lr=args.lr, fused=True)\n" +
        "\n" +
        "device = 'cuda'\n" +
        "model.train()\n" +
        "\n" +
        "# ── First-batch CE guard: after r10 warm-start CE should be <2.0; abort if >5.0 ──\n" +
        "it = iter(dl)\n" +
        "b0 = next(it)\n" +
        "with torch.no_grad():\n" +
        "    out0 = model(input_ids=b0['input_ids'].to(device),\n" +
        "                 labels=b0['labels'].to(device),\n" +
        "                 attention_mask=b0['attention_mask'].to(device))\n" +
        "    ce0 = float(out0.loss.detach().item())\n" +
        "print('[resume] first-batch CE = ' + str(round(ce0, 4)) + ' (should be <2.0 post-r10)', flush=True)\n" +
        "if ce0 > 5.0:\n" +
        "    with open(ABORT_STATUS, 'w') as f: f.write('FIRST_BATCH_CE>'+str(ce0)+'\\n')\n" +
        "    wstatus('ABORT_FIRST_BATCH_CE')\n" +
        "    print('[r10b ABORT] first-batch CE=' + str(ce0) + ' > 5.0 — r10 adapter seems degraded, exiting', flush=True)\n" +
        "    sys.exit(2)\n" +
        "\n" +
        "# ── kr_gen sentinel — E7-OSS-01 subprocess (authoritative exit code) ──\n" +
        "# Inline collapse_score was ASCII-only and missed Korean byte repeats.\n" +
        "# Now delegates to training/kr_gen_sentinel.hexa which uses max_byte_run\n" +
        "# (byte-level ANY repeat >=10 — covers 녕녕녕녕 / 낙 낙 낙 / IRR-cycle).\n" +
        "import subprocess\n" +
        "SENTINEL_HEXA = os.environ.get('R10B_SENTINEL_HEXA',\n" +
        "    '/workspace/anima/training/kr_gen_sentinel.hexa')\n" +
        "HEXA_BIN = os.environ.get('R10B_HEXA_BIN', 'hexa')\n" +
        "SENTINEL_PROMPTS = ['안녕하세요', '오늘 날씨', '한국어 모델', '딥러닝이란', '안녕']\n" +
        "def run_kr_gen(step):\n" +
        "    gc.collect()\n" +
        "    torch.cuda.empty_cache()\n" +
        "    model.eval()\n" +
        "    samples = []\n" +
        "    try:\n" +
        "        for prompt in SENTINEL_PROMPTS:\n" +
        "            iid = tok(prompt, return_tensors='pt').input_ids.to(device)\n" +
        "            with torch.no_grad():\n" +
        "                g = model.generate(iid, max_new_tokens=32, do_sample=False,\n" +
        "                                   pad_token_id=tok.pad_token_id)\n" +
        "            gen = tok.decode(g[0][iid.shape[1]:], skip_special_tokens=True)\n" +
        "            samples.append({'prompt': prompt, 'gen': gen[:200]})\n" +
        "            del iid, g\n" +
        "    finally:\n" +
        "        model.train()\n" +
        "        gc.collect()\n" +
        "        torch.cuda.empty_cache()\n" +
        "    log_path = os.path.join(args.ckpt_dir, 'kr_gen_step_' + str(step) + '.json')\n" +
        "    with open(log_path, 'w') as f:\n" +
        "        json.dump({'step': step, 'samples': samples}, f, ensure_ascii=False, indent=2)\n" +
        "    verdict = 'UNKNOWN'; rc = -1\n" +
        "    try:\n" +
        "        r = subprocess.run([HEXA_BIN, SENTINEL_HEXA, log_path],\n" +
        "                           capture_output=True, text=True, timeout=60)\n" +
        "        rc = r.returncode\n" +
        "        verdict = 'CLEAN' if rc == 0 else ('COLLAPSED' if rc == 2 else 'SENTINEL_ERR')\n" +
        "    except Exception as e:\n" +
        "        # Fallback: byte-run>=10 ANY byte (matches hexa sentinel max_byte_run)\n" +
        "        print('[sentinel FALLBACK r10b] hexa unavailable: ' + str(e), flush=True)\n" +
        "        flagged = 0\n" +
        "        for sm in samples:\n" +
        "            by = sm['gen'].encode('utf-8', errors='ignore')\n" +
        "            run = best = 1\n" +
        "            for j in range(1, len(by)):\n" +
        "                if by[j] == by[j-1]:\n" +
        "                    run += 1\n" +
        "                    if run > best: best = run\n" +
        "                else: run = 1\n" +
        "            if best >= 10: flagged += 1\n" +
        "        verdict = 'COLLAPSED' if flagged >= 3 else 'CLEAN'\n" +
        "        rc = 2 if verdict == 'COLLAPSED' else 0\n" +
        "    print('[sentinel r10b] step=' + str(step) + ' verdict=' + verdict + ' rc=' + str(rc), flush=True)\n" +
        "    if verdict == 'COLLAPSED':\n" +
        "        with open(ABORT_STATUS, 'w') as f: f.write('MODE_COLLAPSE_STEP=' + str(step) + '\\n')\n" +
        "        wstatus('ABORT_MODE_COLLAPSE')\n" +
        "        print('[r10b ABORT] mode collapse detected at step=' + str(step), flush=True)\n" +
        "        sys.exit(2)\n" +
        "\n" +
        "# ── Φ-hook: write 16D phi_vec.json next to each ckpt ──\n" +
        "# Schema matches training/alm_phi_vec_logger.hexa (canonical layout).\n" +
        "# For r10b, phi_holo/phi_complexity/phi_gwt are the only ones we can compute\n" +
        "# cheaply inline (forward-only activation MI surrogate). The other 13 dims\n" +
        "# are populated as NaN sentinels so phi_eval_hook_spec post-processors can\n" +
        "# fill them offline. This satisfies eval_phi_corr.hexa N>=5 requirement\n" +
        "# without inflating per-step cost.\n" +
        "def write_phi_vec(step, save_dir, ce_proxy):\n" +
        "    if not args.phi_hook: return\n" +
        "    # Inline surrogates (cheap; full 16D filled offline by phi_eval_hook):\n" +
        "    #   phi_holo        ~ -log(ce) (positive when ce<1, zero at ce=1)\n" +
        "    #   phi_complexity  ~ entropy of last-layer activations (not computed here; NaN)\n" +
        "    #   phi_gwt         ~ variance across attn heads (not computed here; NaN)\n" +
        "    import math\n" +
        "    nan = float('nan')\n" +
        "    phi_holo_proxy = -math.log(max(ce_proxy, 1e-6))\n" +
        "    phi_vec = [phi_holo_proxy, nan, nan, nan, nan, nan, nan, nan,\n" +
        "               nan, nan, nan, nan, nan, nan, nan, nan]\n" +
        "    phi_path = os.path.join(save_dir, 'phi_vec.json')\n" +
        "    # json.dump with allow_nan=True emits NaN — downstream hexa parser tolerates.\n" +
        "    with open(phi_path, 'w') as f:\n" +
        "        json.dump({'step': step, 'phi_vec': phi_vec, 'ce_proxy': ce_proxy,\n" +
        "                   'schema': 'alm_phi_vec_logger_v1', 'round': 'r10b'},\n" +
        "                  f, allow_nan=True)\n" +
        "    print('[phi16] step=' + str(step) + ' phi_holo_proxy=' + str(round(phi_holo_proxy,4)), flush=True)\n" +
        "\n" +
        "# ── Training loop ──\n" +
        "wstatus('TRAINING')\n" +
        "step = 0\n" +
        "t0 = time.time()\n" +
        "best_loss = 1e9\n" +
        "last_loss = ce0\n" +
        "while step < args.steps:\n" +
        "    for batch in dl:\n" +
        "        if step >= args.steps: break\n" +
        "        out = model(input_ids=batch['input_ids'].to(device),\n" +
        "                    labels=batch['labels'].to(device),\n" +
        "                    attention_mask=batch['attention_mask'].to(device))\n" +
        "        loss = out.loss\n" +
        "        loss.backward()\n" +
        "        if (step + 1) % args.grad_accum == 0:\n" +
        "            opt.step(); opt.zero_grad(set_to_none=True)\n" +
        "        step += 1\n" +
        "        lv = float(loss.detach().item())\n" +
        "        last_loss = lv\n" +
        "        if step == 1 or step % 25 == 0:\n" +
        "            elapsed = time.time() - t0\n" +
        "            toks_s = (step * args.batch * args.seq) / max(elapsed, 1e-6)\n" +
        "            print('[step=' + str(step) + '] loss=' + str(round(lv,4)) +\n" +
        "                  ' lr=' + str(args.lr) + ' toks/s=' + str(round(toks_s,0)) +\n" +
        "                  ' elapsed_min=' + str(round(elapsed/60,2)), flush=True)\n" +
        "        if step == 1 and lv > 5.0:\n" +
        "            with open(ABORT_STATUS, 'w') as f: f.write('STEP1_LOSS='+str(lv)+'\\n')\n" +
        "            wstatus('ABORT_STEP1')\n" +
        "            print('[r10b ABORT] step=1 loss=' + str(lv) + ' > 5.0', flush=True)\n" +
        "            sys.exit(2)\n" +
        "        if lv < best_loss: best_loss = lv\n" +
        "        if step % args.eval_every == 0:\n" +
        "            run_kr_gen(step)\n" +
        "        if step % args.save_every == 0:\n" +
        "            save_dir = os.path.join(args.ckpt_dir, 'step_' + str(step))\n" +
        "            model.save_pretrained(save_dir)\n" +
        "            tok.save_pretrained(save_dir)\n" +
        "            meta = {'step': step, 'loss': lv, 'best_loss': best_loss,\n" +
        "                    'lr': args.lr, 'b1': False, 'base': args.base_dir,\n" +
        "                    'warm_start_from': args.adapter_dir, 'round': 'r10b',\n" +
        "                    'parent_round': 'r10', 'cumulative_step': 2000 + step}\n" +
        "            with open(os.path.join(save_dir, 'train_meta.json'), 'w') as f:\n" +
        "                json.dump(meta, f, indent=2)\n" +
        "            write_phi_vec(step, save_dir, lv)\n" +
        "            print('[save] step=' + str(step) + ' → ' + save_dir, flush=True)\n" +
        "\n" +
        "wstatus('DONE')\n" +
        "print('[r10b] DONE step=' + str(step) + ' best_loss=' + str(round(best_loss,4)), flush=True)\n"
    )

    // ── Bash wrapper: pre-launch sentinel + preflight + python launch ──
    let runner = "/tmp/_launch_alm_14b_r10b.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "echo \"================================================================\"\n" +
        "echo \"  ALM 14B r10b — warm-start from r10/step_2000, B1 OFF, phi-hook ON\"\n" +
        "echo \"  2000 steps | LR 1e-6 constant | save_every=400 (5 intermediates)\"\n" +
        "echo \"================================================================\"\n" +
        "\n" +
        "GPU_MEM=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null || echo 0)\n" +
        "[[ \"$GPU_MEM\" -lt 70000 ]] && { echo \"[ABORT] need H100 80GB\"; exit 1; }\n" +
        "echo \"[preflight] GPU OK (${GPU_MEM} MiB)\"\n" +
        "\n" +
        "BASE=/workspace/base_model\n" +
        "ADAPTER=/workspace/ckpt_r10_step2000\n" +
        "CORPUS=/workspace/corpus_alm_70b_stripped.txt\n" +
        "KOWIKI=/workspace/kowiki.jsonl\n" +
        "CKPT=/workspace/ckpt_alm_14b_r10b\n" +
        "[[ -d \"$BASE\" ]]     || { echo \"[ABORT] base missing: $BASE\"; exit 1; }\n" +
        "[[ -d \"$ADAPTER\" ]]  || { echo \"[ABORT] r10 adapter missing: $ADAPTER (run bootstrap to sync from R2)\"; exit 1; }\n" +
        "[[ -f \"$CORPUS\" ]]   || { echo \"[ABORT] stripped corpus missing: $CORPUS\"; exit 1; }\n" +
        "\n" +
        "# ── Optional kowiki concat (only if present — feedback_no_resume_data_change safe) ──\n" +
        "# When kowiki.jsonl is available, append its stripped text to the r10b corpus.\n" +
        "# If absent, we silently fall through with the SAME corpus as r10 (no data change).\n" +
        "CORPUS_R10B=/workspace/corpus_alm_70b_stripped_r10b.txt\n" +
        "if [[ -f \"$KOWIKI\" ]]; then\n" +
        "    echo \"[corpus] kowiki.jsonl detected — stripping + concatenating to r10b corpus\"\n" +
        "    cp \"$CORPUS\" \"$CORPUS_R10B\"\n" +
        "    # Strip kowiki jsonl (fallback inline python — same pattern as bootstrap)\n" +
        "    python3 -c 'import json,sys\\n" +
        "src=sys.argv[1]; dst=sys.argv[2]\\n" +
        "with open(src,\"r\",encoding=\"utf-8\",errors=\"ignore\") as fi, open(dst,\"a\",encoding=\"utf-8\") as fo:\\n" +
        "    for line in fi:\\n" +
        "        try: obj=json.loads(line)\\n" +
        "        except: continue\\n" +
        "        t = obj.get(\"text\") if isinstance(obj,dict) else None\\n" +
        "        if isinstance(t,str) and t: fo.write(t+\"\\n\\n\")\\n" +
        "' \"$KOWIKI\" \"$CORPUS_R10B\"\n" +
        "    CORPUS=\"$CORPUS_R10B\"\n" +
        "    echo \"[corpus] r10b corpus: $(du -sh $CORPUS_R10B | cut -f1)\"\n" +
        "else\n" +
        "    echo \"[corpus] kowiki.jsonl absent — using identical r10 corpus (no data change)\"\n" +
        "fi\n" +
        "\n" +
        "# ── Pre-launch sentinel: ensure r10/step_2000 didn't mode-collapse ──\n" +
        "# Per feedback_troubleshoot_ossified: record abort reason if sentinel fails.\n" +
        "R10_KRGEN=$ADAPTER/kr_gen_step_2000.json\n" +
        "SENTINEL_LOG=$CKPT/sentinel_pre.log\n" +
        "mkdir -p \"$CKPT\"\n" +
        "if [[ -f \"$R10_KRGEN\" ]]; then\n" +
        "    echo \"[sentinel] running kr_gen_sentinel.hexa on r10 step_2000 kr_gen log\" | tee \"$SENTINEL_LOG\"\n" +
        "    SENTINEL_SCRIPT=/workspace/anima/training/kr_gen_sentinel.hexa\n" +
        "    [[ -f \"$SENTINEL_SCRIPT\" ]] || SENTINEL_SCRIPT=/workspace/kr_gen_sentinel.hexa\n" +
        "    if ! hexa run \"$SENTINEL_SCRIPT\" \"$R10_KRGEN\" 2>&1 | tee -a \"$SENTINEL_LOG\"; then\n" +
        "        echo \"[r10b ABORT] pre-launch sentinel exit!=0 on $R10_KRGEN (r10 adapter likely collapsed)\" | tee -a \"$SENTINEL_LOG\"\n" +
        "        echo \"R10_SENTINEL_FAIL\" > \"$CKPT/r10b_abort.status\"\n" +
        "        exit 2\n" +
        "    fi\n" +
        "    echo \"[sentinel] r10 kr_gen CLEAN — proceeding with r10b warm-start\" | tee -a \"$SENTINEL_LOG\"\n" +
        "else\n" +
        "    echo \"[sentinel] WARN — $R10_KRGEN not present (first-batch CE guard will still protect)\" | tee \"$SENTINEL_LOG\"\n" +
        "fi\n" +
        "\n" +
        "# Fresh ckpt dir (MFS quota rule)\n" +
        "rm -rf \"$CKPT\" && mkdir -p \"$CKPT\"\n" +
        "echo INIT > \"$CKPT/r10b_watcher.status\"\n" +
        "\n" +
        "# Deps (idempotent)\n" +
        "python3 -c 'import unsloth, liger_kernel, peft, transformers' 2>/dev/null || \\\n" +
        "    pip install -q peft==0.13.2 transformers==4.45.2 unsloth liger-kernel 2>&1 | tail -3\n" +
        "\n" +
        "export HF_HUB_CACHE=/workspace/hf_cache HF_HOME=/workspace/hf_cache\n" +
        "\n" +
        "echo \"[launch] python3 " + py + " --steps " + steps + " --save-every " + save_every + " --eval-every " + eval_every + "\"\n" +
        (if dry_run {
            "echo \"[DRY_RUN] would launch r10b — plan printed, exiting without exec\"\n" +
            "echo \"[DRY_RUN] adapter=$ADAPTER corpus=$CORPUS ckpt=$CKPT lr=1e-6 steps=" + steps + "\"\n" +
            "exit 0\n"
        } else { "" }) +
        "python3 " + py + " \\\n" +
        "    --base-dir \"$BASE\" \\\n" +
        "    --adapter-dir \"$ADAPTER\" \\\n" +
        "    --corpus \"$CORPUS\" \\\n" +
        "    --ckpt-dir \"$CKPT\" \\\n" +
        "    --steps " + steps + " \\\n" +
        "    --save-every " + save_every + " \\\n" +
        "    --eval-every " + eval_every + " \\\n" +
        "    --lr 1e-6 \\\n" +
        "    --batch 8 \\\n" +
        "    --seq 1024 \\\n" +
        "    --grad-accum 1 \\\n" +
        "    --lora-r 32 \\\n" +
        "    --lora-alpha 64 \\\n" +
        "    --lora-dropout 0.0 \\\n" +
        "    --phi-hook 1 \\\n" +
        "    2>&1 | tee \"$CKPT/train_r10b.log\"\n" +
        "\n" +
        "if [[ -f \"$CKPT/r10b_abort.status\" ]]; then\n" +
        "    echo \"[r10b] ABORT triggered — see $CKPT/r10b_abort.status\"\n" +
        "    exit 2\n" +
        "fi\n" +
        "echo DONE > \"$CKPT/r10b_watcher.status\"\n" +
        "echo \"[r10b] DONE — ckpt at $CKPT (label=" + ckpt_label + ")\"\n"
    )

    if dry_run {
        println("[r10b] DRY_RUN=1 — printing plan, not exec'ing")
        println("[r10b] steps=" + steps + " save_every=" + save_every + " eval_every=" + eval_every)
        println("[r10b] runner written to " + runner)
        println("[r10b] py trainer written to " + py)
        println("[r10b] guards: pre-sentinel on r10_kr_gen + first-batch CE + kr_gen_sentinel @ 200-step cadence")
        return
    }

    exec("bash " + runner)
}

main()
