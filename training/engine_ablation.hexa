// training/engine_ablation.hexa — P23 71-engine ablation harness
//
// P23 follow-up: expand engine_integration.hexa (12 main) to the full 71-engine
// catalog (training/engine_catalog.json) with on/off switches + ALM/CLM forward
// hook points. Self-contained — no deep imports (hexa silent-exit bug avoidance).
//
// DESIGN:
//   (a) 71-engine registry in SoA layout (names + gains + phases + families)
//   (b) engine_forward(h, q, name) — cheap surrogate of each engine's metric
//       (variance / mean / lag-1 / sign-change / half-split divergence)
//   (c) compute_total_loss(base, h, q, mask) — Σ gain_i × aux_i × mask_i
//   (d) apply_to_alm(mask) / apply_to_clm(mask) — placeholder hooks for
//       train_alm / train_clm forward loops (wire later at real-train time)
//   (e) make_mask_* helpers — all_on / all_off / one_hot / leave_one_out /
//       family_only — drive ablation_search.hexa over 2^71 tractably
//
// Theorems (self-test):
//   T1 (registry size):      71 engines registered
//   T2 (unique names):       no duplicate names
//   T3 (gain range):         0 < gain <= 1 for every engine
//   T4 (forward API):        engine_forward returns finite aux_loss/phi_delta
//   T5 (total_loss delta):   all-on != base (every engine contributes)
//   T6 (mask builders):      all_on/all_off/one_hot return correct size
//   T7 (gain-sign judge):    judge_gain_signs returns 71-length array
//
// Run:
//   $HEXA_LANG/target/release/hexa training/engine_ablation.hexa
// Expect:
//   [engine_ablation] ALL 7/7 PASS

// ─── Constants ──────────────────────────────────────────────

let EA_N_ENGINES = 71
let EA_EPS       = 0.0000001

// ─── Helpers ────────────────────────────────────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_sum(v: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(v)
    while i < n { s = s + v[i]; i = i + 1 }
    return s
}

fn vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    return vec_sum(v) / (n * 1.0)
}

fn vec_var(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let m = vec_mean(v)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = v[i] - m
        s = s + d * d
        i = i + 1
    }
    return s / (n * 1.0)
}

