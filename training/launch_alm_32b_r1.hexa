// launch_alm_32b_r1.hexa — ALM 32B r1 fresh LoRA (RunPod H100 80GB single-GPU)
//
// =============================================================================
//  SCAFFOLD STATUS: PREP ONLY — DO NOT LAUNCH.
//  Wait for r10 (14B) completion, evaluation, and explicit escalation order.
//
//  2026-04-18: Supersedes prior stale stub (10k steps / 5e-6 / dropout 0.05 /
//  mentions r4). Those params pre-date the r9 collapse diagnosis and r10
//  recovery — all 32B config now mirrors r10's validated one-shot-best.
// =============================================================================
//
// Lineage:
//   7B (r0) → 14B (r1..r10) → 32B (r1, THIS FILE) → 70B (r1 pending)
//
// Per feedback_no_resume_data_change + feedback_one_shot_best:
//   32B is a FRESH-FROM-BASE fine-tune. Qwen2.5-32B-Instruct is a distinct
//   param-class from 14B — LoRA adapters NEVER transfer across param-count
//   boundaries. Any reference to 14B r10 adapter is metadata-only (lineage
//   stamp), NOT weight-transferred. step_0 is fresh.
//
// Corpus choice (matches r10, fresh start):
//   /workspace/corpus_alm_70b_stripped.txt (chatml-stripped plain text)
//   Same corpus r10 trained on — 32B inherits the validated data cleaning.
//   If E2 ingests kowiki.jsonl, override via CORPUS_OVERRIDE env.
//
// Config (mirrors r10 where applicable, tuned for 32B scale):
//   base                 : Qwen/Qwen2.5-32B-Instruct  (65 GB bf16)
//   LoRA                 : r=32 alpha=64 dropout=0.0  (matches r10)
//   LR                   : 2e-6 constant              (matches r10)
//   steps                : 2000                        (matches r10)
//   B1 consciousness_loss: FALSE                       (r9 proved noisy; r10 confirmed OFF-is-safer)
//   batch × seq          : 1 × 1024  (65 GB base on 80 GB H100 leaves ~13 GB headroom
//                                     → batch=1 only safe; grad_accum=8 → eff batch=8)
//   grad_accum           : 8                           (effective batch = 8 like r10)
//   save_every           : 2000                        (MFS quota rule; single ckpt at end)
//   eval_every           : 200                         (kr_gen sentinel cadence)
//   first-step guard     : abort if step 1 loss > 8.0  (calibrated per r10 deviation log)
//   mode-collapse guard  : kr_gen sentinel every 200 steps — abort on collapse
//
// Quantization policy (feedback_no_quantization):
//   bf16 weights, no 4/8-bit, no GPTQ/AWQ/bnb. 32B bf16 = 65 GB, fits a single
//   H100 80GB. No FSDP required (unlike 70B). gradient checkpointing on.
//
// 32B base NOT in R2 (verified 2026-04-18 via `rclone ls r2:anima-models/base_models/`):
//   Only qwen25-14b-instruct present. 32B must be downloaded from HuggingFace
//   during bootstrap (~65 GB, requires HF_TOKEN). This is a one-time step per
//   pod — post-download the bootstrap also mirrors to R2 for future reuse.
//
// Naming (feedback_no_version_in_filename):
//   filename = launch_alm_32b_r1.hexa
//   run_id   = alm32b-r1-YYYYMMDD
//   ckpt_dir = /workspace/ckpt_alm_32b_r1
//   R2 path  = r2:anima-models/alm32b/r1/step_2000/
//
// Run on pod (DO NOT fire until r10 done + eval green):
//   hexa run /workspace/anima/training/launch_alm_32b_r1.hexa              # production (2000 steps)
//   hexa run /workspace/anima/training/launch_alm_32b_r1.hexa --smoke      # 200 steps smoke
//
// @convergence(state="scaffold", id="ALM_32B_R1_FRESH_FROM_BASE", value="32B
//   LoRA is fresh-from-32B-Instruct. No weight transfer from 14B r10. LoRA
//   adapters are param-count-scoped. Metadata lineage only (ckpt meta JSON).")
// @convergence(state="scaffold", id="ALM_32B_R1_NO_QUANTIZATION", value="bf16
//   throughout. 65 GB base on 80 GB H100 has 13 GB headroom (adapter 0.4 GB,
//   optimizer LoRA-only 1.6 GB, activations b1 s1024 ~3-5 GB). No bnb.")
// @convergence(state="scaffold", id="ALM_32B_R1_B1_OFF", value="consciousness_loss_b1=false.
//   r9 showed B1 introduces 3k-12k Φ_holo noise and destabilizes CE at 14B.
//   At 32B the same loss pathology would cost 4x more GPU-h per debug cycle —
//   B1 stays OFF until r10 validation at 14B confirms a safe reintroduction.")

fn main() {
    let argv = args()
    let mut smoke = false
    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--smoke" { smoke = true }
        i = i + 1
    }

    let steps       = if smoke { "200"  } else { "2000" }
    let save_every  = if smoke { "200"  } else { "2000" }  // runpod_mfs_quota: save_every >= 2000
    let eval_every  = if smoke { "100"  } else { "200"  }  // kr_gen every 200 steps
    let ckpt_label  = if smoke { "experiment" } else { "production" }

    let py = "/tmp/_train_alm_32b_r1.py"

    // ── Embedded Python trainer (inline — 32B r1 owns its own py runner,
    //    mirroring r10 structure so r10 trainer is untouched. Total .py ban
    //    permits /tmp emit, no source .py created in-tree). ──
    write_file(py,
        "#!/usr/bin/env python3\n" +
        "# _train_alm_32b_r1.py — auto-generated by launch_alm_32b_r1.hexa\n" +
        "# Fresh-from-base 32B LoRA + B1 OFF + chatml-stripped corpus.\n" +
        "import argparse, json, os, sys, time, math, random\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from torch.utils.data import Dataset, DataLoader\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import LoraConfig, get_peft_model, TaskType\n" +
        "\n" +
        "p = argparse.ArgumentParser()\n" +
        "p.add_argument('--base-dir', required=True)\n" +
        "p.add_argument('--corpus', required=True)\n" +
        "p.add_argument('--ckpt-dir', required=True)\n" +
        "p.add_argument('--steps', type=int, default=2000)\n" +
        "p.add_argument('--save-every', type=int, default=2000)\n" +
        "p.add_argument('--eval-every', type=int, default=200)\n" +
        "p.add_argument('--lr', type=float, default=2e-6)\n" +
        "p.add_argument('--batch', type=int, default=1)\n" +
        "p.add_argument('--seq', type=int, default=1024)\n" +
        "p.add_argument('--grad-accum', type=int, default=8)\n" +
        "p.add_argument('--lora-r', type=int, default=32)\n" +
        "p.add_argument('--lora-alpha', type=int, default=64)\n" +
        "p.add_argument('--lora-dropout', type=float, default=0.0)\n" +
        "p.add_argument('--seed', type=int, default=3407)\n" +
        "args = p.parse_args()\n" +
        "\n" +
        "torch.manual_seed(args.seed); random.seed(args.seed)\n" +
        "torch.backends.cuda.matmul.allow_tf32 = True\n" +
        "torch.backends.cudnn.allow_tf32 = True\n" +
        "torch.backends.cudnn.benchmark = True\n" +
        "Path(args.ckpt_dir).mkdir(parents=True, exist_ok=True)\n" +
        "ABORT_STATUS = os.path.join(args.ckpt_dir, 'r1_abort.status')\n" +
        "STATUS_FILE  = os.path.join(args.ckpt_dir, 'r1_watcher.status')\n" +
        "def wstatus(s):\n" +
        "    with open(STATUS_FILE, 'w') as f: f.write(s + '\\n')\n" +
        "wstatus('INIT')\n" +
        "\n" +
        "print('[32b-r1] base_dir=' + args.base_dir, flush=True)\n" +
        "print('[32b-r1] corpus=' + args.corpus, flush=True)\n" +
        "print('[32b-r1] steps=' + str(args.steps) + ' lr=' + str(args.lr) + ' (constant)', flush=True)\n" +
        "print('[32b-r1] B1 consciousness loss = DISABLED', flush=True)\n" +
        "print('[32b-r1] batch=' + str(args.batch) + ' seq=' + str(args.seq) + ' grad_accum=' + str(args.grad_accum) + ' eff_batch=' + str(args.batch*args.grad_accum), flush=True)\n" +
        "\n" +
        "tok = AutoTokenizer.from_pretrained(args.base_dir, trust_remote_code=True)\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "print('[32b-r1] loading base via Unsloth FastLanguageModel...', flush=True)\n" +
        "from unsloth import FastLanguageModel\n" +
        "model, tok = FastLanguageModel.from_pretrained(\n" +
        "    model_name=args.base_dir, max_seq_length=args.seq, dtype=torch.bfloat16,\n" +
        "    load_in_4bit=False, trust_remote_code=True,\n" +
        "    use_gradient_checkpointing='unsloth',\n" +
        ")\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "# Liger for Qwen2 fusions\n" +
        "try:\n" +
        "    from liger_kernel.transformers import apply_liger_kernel_to_qwen2\n" +
        "    apply_liger_kernel_to_qwen2(rope=True, rms_norm=True, swiglu=True,\n" +
        "                                fused_linear_cross_entropy=True, cross_entropy=False,\n" +
        "                                model=model)\n" +
        "    print('[32b-r1] liger applied', flush=True)\n" +
        "except Exception as e:\n" +
        "    print('[32b-r1] liger unavailable: ' + str(e), flush=True)\n" +
        "\n" +
        "# ── LoRA fresh init (no warm-start — 32B is a new param class) ──\n" +
        "print('[32b-r1] fresh LoRA init (no adapter warm-start, cross-scale LoRA transfer forbidden)', flush=True)\n" +
        "from unsloth import FastLanguageModel as _FLM\n" +
        "model = _FLM.get_peft_model(\n" +
        "    model, r=args.lora_r, lora_alpha=args.lora_alpha,\n" +
        "    lora_dropout=args.lora_dropout,\n" +
        "    target_modules=['q_proj','k_proj','v_proj','o_proj'],\n" +
        "    bias='none', use_gradient_checkpointing='unsloth',\n" +
        "    random_state=3407,\n" +
        ")\n" +
        "print('[32b-r1] LoRA applied (fresh)', flush=True)\n" +
        "model.print_trainable_parameters()\n" +
        "\n" +
        "# ── Corpus: plain text (already chatml-stripped) → pack into fixed seq ──\n" +
        "text = Path(args.corpus).read_text(errors='ignore')\n" +
        "print('[32b-r1] corpus bytes=' + str(len(text)), flush=True)\n" +
        "ids = tok(text, add_special_tokens=False)['input_ids']\n" +
        "print('[32b-r1] corpus tokens=' + str(len(ids)), flush=True)\n" +
        "seq = args.seq\n" +
        "n_blocks = len(ids) // seq\n" +
        "blocks = [ids[i*seq:(i+1)*seq] for i in range(n_blocks)]\n" +
        "print('[32b-r1] blocks=' + str(len(blocks)), flush=True)\n" +
        "\n" +
        "class PackedDS(Dataset):\n" +
        "    def __init__(self, blocks): self.b = blocks\n" +
        "    def __len__(self): return len(self.b)\n" +
        "    def __getitem__(self, i):\n" +
        "        x = torch.tensor(self.b[i], dtype=torch.long)\n" +
        "        return {'input_ids': x, 'labels': x.clone(), 'attention_mask': torch.ones_like(x)}\n" +
        "\n" +
        "ds = PackedDS(blocks)\n" +
        "dl = DataLoader(ds, batch_size=args.batch, shuffle=True, pin_memory=True, drop_last=True)\n" +
        "\n" +
        "opt = torch.optim.AdamW([p for p in model.parameters() if p.requires_grad], lr=args.lr, fused=True)\n" +
        "\n" +
        "device = 'cuda'\n" +
        "model.train()\n" +
        "\n" +
        "# ── First-batch CE guard: abort if CE>8.0 at step=1 ──\n" +
        "it = iter(dl)\n" +
        "b0 = next(it)\n" +
        "with torch.no_grad():\n" +
        "    out0 = model(input_ids=b0['input_ids'].to(device),\n" +
        "                 labels=b0['labels'].to(device),\n" +
        "                 attention_mask=b0['attention_mask'].to(device))\n" +
        "    ce0 = float(out0.loss.detach().item())\n" +
        "print('[32b-r1] first-batch CE = ' + str(round(ce0, 4)) + ' (must be <8.0)', flush=True)\n" +
        "if ce0 > 8.0:\n" +
        "    with open(ABORT_STATUS, 'w') as f: f.write('FIRST_BATCH_CE>'+str(ce0)+'\\n')\n" +
        "    wstatus('ABORT_FIRST_BATCH_CE')\n" +
        "    print('[32b-r1 ABORT] first-batch CE=' + str(ce0) + ' > 8.0 — base or corpus mismatch', flush=True)\n" +
        "    sys.exit(2)\n" +
        "\n" +
        "# ── kr_gen sentinel: call B6's hexa sentinel over generated samples ──\n" +
        "SENTINEL_PROMPTS = ['안녕하세요', '오늘 날씨', '한국어 모델', '딥러닝이란', '안녕']\n" +
        "SENTINEL_HEXA = os.environ.get('KR_GEN_SENTINEL', '/workspace/anima/training/kr_gen_sentinel.hexa')\n" +
        "HEXA_BIN = os.environ.get('HEXA_BIN', '/usr/local/bin/hexa')\n" +
        "\n" +
        "def run_kr_gen(step):\n" +
        "    model.eval()\n" +
        "    samples = []\n" +
        "    try:\n" +
        "        for prompt in SENTINEL_PROMPTS:\n" +
        "            iid = tok(prompt, return_tensors='pt').input_ids.to(device)\n" +
        "            with torch.no_grad():\n" +
        "                g = model.generate(iid, max_new_tokens=64, do_sample=False,\n" +
        "                                   pad_token_id=tok.pad_token_id)\n" +
        "            gen = tok.decode(g[0][iid.shape[1]:], skip_special_tokens=True)\n" +
        "            samples.append({'prompt': prompt, 'gen': gen[:200]})\n" +
        "    finally:\n" +
        "        model.train()\n" +
        "    log_path = os.path.join(args.ckpt_dir, 'kr_gen_step_' + str(step) + '.json')\n" +
        "    with open(log_path, 'w') as f:\n" +
        "        json.dump(samples, f, ensure_ascii=False, indent=2)\n" +
        "\n" +
        "    # Invoke B6 hexa sentinel — exit 2 = COLLAPSED → abort training.\n" +
        "    import subprocess\n" +
        "    if os.path.isfile(SENTINEL_HEXA) and os.path.isfile(HEXA_BIN):\n" +
        "        r = subprocess.run([HEXA_BIN, 'run', SENTINEL_HEXA, log_path],\n" +
        "                           capture_output=True, text=True, timeout=60)\n" +
        "        print('[kr_gen] step=' + str(step) + ' sentinel: ' + (r.stdout or '').strip(), flush=True)\n" +
        "        if r.returncode == 2:\n" +
        "            with open(ABORT_STATUS, 'w') as f: f.write('MODE_COLLAPSE_STEP='+str(step)+'\\n')\n" +
        "            wstatus('ABORT_MODE_COLLAPSE')\n" +
        "            print('[32b-r1 ABORT] sentinel reported COLLAPSED at step=' + str(step), flush=True)\n" +
        "            sys.exit(2)\n" +
        "    else:\n" +
        "        print('[kr_gen] step=' + str(step) + ' sentinel skipped (binary/hexa missing)', flush=True)\n" +
        "\n" +
        "# ── Training loop ──\n" +
        "wstatus('TRAINING')\n" +
        "step = 0\n" +
        "t0 = time.time()\n" +
        "best_loss = 1e9\n" +
        "while step < args.steps:\n" +
        "    for batch in dl:\n" +
        "        if step >= args.steps: break\n" +
        "        out = model(input_ids=batch['input_ids'].to(device),\n" +
        "                    labels=batch['labels'].to(device),\n" +
        "                    attention_mask=batch['attention_mask'].to(device))\n" +
        "        loss = out.loss / args.grad_accum\n" +
        "        loss.backward()\n" +
        "        if (step + 1) % args.grad_accum == 0:\n" +
        "            opt.step(); opt.zero_grad(set_to_none=True)\n" +
        "        step += 1\n" +
        "        lv = float(out.loss.detach().item())\n" +
        "        if step == 1 or step % 25 == 0:\n" +
        "            elapsed = time.time() - t0\n" +
        "            toks_s = (step * args.batch * args.seq) / max(elapsed, 1e-6)\n" +
        "            print('[step=' + str(step) + '] loss=' + str(round(lv,4)) +\n" +
        "                  ' lr=' + str(args.lr) + ' toks/s=' + str(round(toks_s,0)) +\n" +
        "                  ' elapsed_min=' + str(round(elapsed/60,2)), flush=True)\n" +
        "        if step == 1 and lv > 8.0:\n" +
        "            with open(ABORT_STATUS, 'w') as f: f.write('STEP1_LOSS='+str(lv)+'\\n')\n" +
        "            wstatus('ABORT_STEP1')\n" +
        "            print('[32b-r1 ABORT] step=1 loss=' + str(lv) + ' > 8.0', flush=True)\n" +
        "            sys.exit(2)\n" +
        "        if lv < best_loss: best_loss = lv\n" +
        "        if step % args.eval_every == 0:\n" +
        "            run_kr_gen(step)\n" +
        "        if step % args.save_every == 0:\n" +
        "            save_dir = os.path.join(args.ckpt_dir, 'step_' + str(step))\n" +
        "            model.save_pretrained(save_dir)\n" +
        "            tok.save_pretrained(save_dir)\n" +
        "            meta = {'step': step, 'loss': lv, 'best_loss': best_loss,\n" +
        "                    'lr': args.lr, 'b1': False, 'base': args.base_dir,\n" +
        "                    'lineage_parent_14b_r10_r2': 'r2:anima-models/alm14b/r10/ (metadata-only, not weight-transferred)',\n" +
        "                    'scale_class': '32B', 'round': 1, 'fresh_from_base': True}\n" +
        "            with open(os.path.join(save_dir, 'train_meta.json'), 'w') as f:\n" +
        "                json.dump(meta, f, indent=2)\n" +
        "            print('[save] step=' + str(step) + ' → ' + save_dir, flush=True)\n" +
        "\n" +
        "wstatus('DONE')\n" +
        "print('[32b-r1] DONE step=' + str(step) + ' best_loss=' + str(round(best_loss,4)), flush=True)\n"
    )

    // ── Bash wrapper: preflight + launch python ──
    let runner = "/tmp/_launch_alm_32b_r1.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "echo \"================================================================\"\n" +
        "echo \"  ALM 32B r1 — Qwen2.5-32B-Instruct fresh LoRA (B1 OFF)\"\n" +
        "echo \"  corpus: chatml-stripped (matches r10)  LR: 2e-6 constant\"\n" +
        "echo \"  steps: " + steps + "   save: " + save_every + "   eval: " + eval_every + "\"\n" +
        "echo \"  label: " + ckpt_label + "\"\n" +
        "echo \"================================================================\"\n" +
        "\n" +
        "# ── preflight: GPU (need H100 80GB for 32B bf16) ──\n" +
        "GPU_MEM=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 || echo 0)\n" +
        "[[ \"$GPU_MEM\" -lt 70000 ]] && { echo \"[ABORT] need H100 80GB (saw ${GPU_MEM} MiB)\"; exit 1; }\n" +
        "echo \"[preflight] GPU OK (${GPU_MEM} MiB)\"\n" +
        "\n" +
        "# ── preflight: bf16 compute_cap >= 8.0 ──\n" +
        "CC=$(nvidia-smi --query-gpu=compute_cap --format=csv,noheader | head -1 | tr -d '.')\n" +
        "if [[ -z \"$CC\" || \"$CC\" -lt 80 ]]; then\n" +
        "    echo \"[ABORT] compute_cap insufficient for bf16: $CC\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] bf16 capable\"\n" +
        "\n" +
        "# ── preflight: forbidden markers (guard against cross-contamination) ──\n" +
        "for m in /workspace/READY_FOR_R5_KBASE /workspace/READY_FOR_70B; do\n" +
        "    if [[ -f \"$m\" ]]; then\n" +
        "        echo \"[ABORT] forbidden marker present: $m\"\n" +
        "        exit 1\n" +
        "    fi\n" +
        "done\n" +
        "\n" +
        "BASE=/workspace/base_model_32b\n" +
        "CORPUS=\"${CORPUS_OVERRIDE:-/workspace/corpus_alm_70b_stripped.txt}\"\n" +
        "CKPT=/workspace/ckpt_alm_32b_r1\n" +
        "[[ -d \"$BASE\" ]]     || { echo \"[ABORT] 32B base missing: $BASE — run alm32b_r1_bootstrap.hexa first\"; exit 1; }\n" +
        "BASE_GB=$(du -sBG \"$BASE\" | awk '{print $1}' | tr -d 'G')\n" +
        "[[ \"$BASE_GB\" -lt 60 ]] && { echo \"[ABORT] 32B base only ${BASE_GB}GB (<60GB, incomplete download)\"; exit 1; }\n" +
        "[[ -f \"$CORPUS\" ]]   || { echo \"[ABORT] corpus missing: $CORPUS\"; exit 1; }\n" +
        "echo \"[preflight] base=${BASE_GB}GB corpus=$(stat -c%s $CORPUS 2>/dev/null || echo ?) bytes\"\n" +
        "\n" +
        "# ── MFS quota preflight ──\n" +
        "echo \"[preflight] MFS quota probe (20 GB dd)...\"\n" +
        "if ! dd if=/dev/zero of=/workspace/_q_test bs=1M count=20000 status=none 2>/dev/null; then\n" +
        "    echo \"[ABORT] MFS quota probe failed\"; rm -f /workspace/_q_test; exit 1\n" +
        "fi\n" +
        "rm -f /workspace/_q_test\n" +
        "echo \"  MFS quota OK\"\n" +
        "\n" +
        "# ── Fresh ckpt dir (MFS quota rule — never reuse) ──\n" +
        "if [[ -d \"$CKPT\" ]]; then\n" +
        "    echo \"[ABORT] $CKPT exists — manual rm first to confirm intent\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "mkdir -p \"$CKPT\"\n" +
        "echo INIT > \"$CKPT/r1_watcher.status\"\n" +
        "\n" +
        "# ── Deps (idempotent, no bnb) ──\n" +
        "python3 -c 'import unsloth, liger_kernel, peft, transformers' 2>/dev/null || \\\n" +
        "    pip install -q peft==0.13.2 transformers==4.45.2 unsloth liger-kernel 2>&1 | tail -3\n" +
        "python3 -c 'import importlib, sys; sys.exit(0 if importlib.util.find_spec(\"bitsandbytes\") is None else 1)' || \\\n" +
        "    { echo \"[ABORT] bitsandbytes installed (no-quantization policy)\"; exit 1; }\n" +
        "echo \"[preflight] deps OK (no bnb, torch/peft/transformers pinned)\"\n" +
        "\n" +
        "export HF_HUB_CACHE=/workspace/hf_cache HF_HOME=/workspace/hf_cache\n" +
        "export PYTORCH_CUDA_ALLOC_CONF=\"expandable_segments:True\"\n" +
        "export TOKENIZERS_PARALLELISM=\"false\"\n" +
        "export KR_GEN_SENTINEL=\"${KR_GEN_SENTINEL:-/workspace/anima/training/kr_gen_sentinel.hexa}\"\n" +
        "export HEXA_BIN=\"${HEXA_BIN:-/usr/local/bin/hexa}\"\n" +
        "\n" +
        "echo \"[launch] python3 " + py + " --steps " + steps + " --save-every " + save_every + " --eval-every " + eval_every + "\"\n" +
        "python3 " + py + " \\\n" +
        "    --base-dir \"$BASE\" \\\n" +
        "    --corpus \"$CORPUS\" \\\n" +
        "    --ckpt-dir \"$CKPT\" \\\n" +
        "    --steps " + steps + " \\\n" +
        "    --save-every " + save_every + " \\\n" +
        "    --eval-every " + eval_every + " \\\n" +
        "    --lr 2e-6 \\\n" +
        "    --batch 1 \\\n" +
        "    --seq 1024 \\\n" +
        "    --grad-accum 8 \\\n" +
        "    --lora-r 32 \\\n" +
        "    --lora-alpha 64 \\\n" +
        "    --lora-dropout 0.0 \\\n" +
        "    2>&1 | tee \"$CKPT/train_r1.log\"\n" +
        "\n" +
        "if [[ -f \"$CKPT/r1_abort.status\" ]]; then\n" +
        "    echo \"[32b-r1] ABORT triggered — see $CKPT/r1_abort.status\"\n" +
        "    exit 2\n" +
        "fi\n" +
        "echo DONE > \"$CKPT/r1_watcher.status\"\n" +
        "echo \"[32b-r1] DONE — ckpt at $CKPT (label=" + ckpt_label + ")\"\n" +
        "\n" +
        "# ── Post-training R2 upload (production only, single batch, MFS-quota safe) ──\n" +
        "if [[ \"" + ckpt_label + "\" == \"production\" ]]; then\n" +
        "    for stepdir in $CKPT/step_*; do\n" +
        "        [[ -d \"$stepdir\" ]] || continue\n" +
        "        step=$(basename \"$stepdir\")\n" +
        "        echo \"[R2 upload] $step → r2:anima-models/alm32b/r1/$step/\"\n" +
        "        rclone copy \"$stepdir\" \"r2:anima-models/alm32b/r1/$step/\" -v --s3-no-check-bucket --transfers 4 2>&1 | tail -3\n" +
        "    done\n" +
        "    rclone ls r2:anima-models/alm32b/r1/ 2>&1 | head -20\n" +
        "fi\n"
    )

    exec("bash " + runner)
}

main()
