// launch_alm_14b_r10c.hexa — ALM 14B r10c: E7 triple-collapse redesign
//
// r10c = r10 with the 3 ossified fixes from shared/convergence/alm_14b_r10.convergence:
//   E7-OSS-01: replace inline ASCII-only collapse_score with kr_gen_sentinel.hexa
//              subprocess. Exit code 2 = COLLAPSED is authoritative.
//   E7-OSS-02: export TRAIN_PID to alm14b_r10_watcher so pid_alive() gate fires.
//   E7-OSS-03: sub-1.0 loss at step<500 triggers immediate sentinel (not deferred
//              to the every-200 cadence).
//
// Additional E7 measures (not strict ossified rules but recommended):
//   (a) Corpus diversity: stripped_70b ⊕ kowiki_slice (≥15% by bytes) if kowiki
//       available on pod. Absent → single-source fallback but flag WARN.
//   (b) Seed sweep smoke: --seed-sweep runs 200-step smokes at 3407/42/1337
//       sequentially; all three must PASS the post-step sentinel.
//
// KEPT SAME as r10 (no regression surface):
//   - fresh LoRA init (r4 adapter pre-smoke FALSIFIED — CE 6.58 on stripped)
//   - Qwen2.5-14B-Instruct base, unsloth+liger, r=32 α=64 dropout=0
//   - batch=8 seq=1024 grad_accum=1
//   - lr=2e-6 constant (one-shot-best lever, not halved — r10c isn't refinement)
//   - consciousness_loss_b1 = FALSE
//   - first-batch CE>5.0 abort, step1 loss>8.0 abort (both preserved)
//
// Run on pod:
//   hexa run /workspace/anima/training/launch_alm_14b_r10c.hexa              # production
//   hexa run /workspace/anima/training/launch_alm_14b_r10c.hexa --smoke      # 200 steps
//   hexa run /workspace/anima/training/launch_alm_14b_r10c.hexa --seed-sweep # pre-launch sweep
//   DRY_RUN=1 hexa run /workspace/anima/training/launch_alm_14b_r10c.hexa    # print plan

fn main() {
    let argv = args()
    let mut smoke = false
    let mut seed_sweep = false
    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--smoke" { smoke = true }
        if argv[i] == "--seed-sweep" { seed_sweep = true }
        i = i + 1
    }

    let dry = env("DRY_RUN")
    let dry_run = dry == "1"

    let steps       = if smoke || seed_sweep { "200"  } else { "2000" }
    let save_every  = if smoke || seed_sweep { "200"  } else { "2000" }
    let eval_every  = if smoke || seed_sweep { "100"  } else { "200"  }
    let ckpt_label  = if smoke { "experiment" } else if seed_sweep { "sweep" } else { "production" }

    let py = "/tmp/_train_alm_14b_r10c.py"

    // ── Embedded Python trainer (r10c-scoped) ──
    write_file(py,
        "#!/usr/bin/env python3\n" +
        "# _train_alm_14b_r10c.py — auto-generated by launch_alm_14b_r10c.hexa\n" +
        "# E7 redesign: sentinel subprocess, corpus mix, seed arg, early-step gate.\n" +
        "import argparse, gc, json, os, sys, time, math, random, subprocess\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from torch.utils.data import Dataset, DataLoader\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import LoraConfig, get_peft_model, PeftModel, TaskType\n" +
        "\n" +
        "p = argparse.ArgumentParser()\n" +
        "p.add_argument('--base-dir', required=True)\n" +
        "p.add_argument('--adapter-dir', default='')\n" +
        "p.add_argument('--corpus', required=True)\n" +
        "p.add_argument('--kowiki', default='', help='optional kowiki.jsonl path for corpus diversity mix')\n" +
        "p.add_argument('--kowiki-mix-pct', type=int, default=15)\n" +
        "p.add_argument('--ckpt-dir', required=True)\n" +
        "p.add_argument('--steps', type=int, default=2000)\n" +
        "p.add_argument('--save-every', type=int, default=2000)\n" +
        "p.add_argument('--eval-every', type=int, default=200)\n" +
        "p.add_argument('--lr', type=float, default=2e-6)\n" +
        "p.add_argument('--batch', type=int, default=8)\n" +
        "p.add_argument('--seq', type=int, default=1024)\n" +
        "p.add_argument('--grad-accum', type=int, default=1)\n" +
        "p.add_argument('--lora-r', type=int, default=32)\n" +
        "p.add_argument('--lora-alpha', type=int, default=64)\n" +
        "p.add_argument('--lora-dropout', type=float, default=0.0)\n" +
        "p.add_argument('--seed', type=int, default=3407)\n" +
        "p.add_argument('--sentinel-hexa', default='/workspace/anima/training/kr_gen_sentinel.hexa',\n" +
        "               help='path to hexa sentinel — subprocess exit 2 = COLLAPSED authoritative')\n" +
        "p.add_argument('--hexa-bin', default='hexa', help='hexa interpreter binary')\n" +
        "p.add_argument('--early-loss-gate', type=float, default=1.0,\n" +
        "               help='E7-OSS-03: below this loss at step<=early-step-limit, force sentinel')\n" +
        "p.add_argument('--early-step-limit', type=int, default=500)\n" +
        "p.add_argument('--phi-hook', type=int, default=1,\n" +
        "               help='DEST1 gate: 1=write phi_vec.json per save (canonical 16D sidecar)')\n" +
        "args = p.parse_args()\n" +
        "\n" +
        "# Seed reproducibility + logging\n" +
        "torch.manual_seed(args.seed); random.seed(args.seed)\n" +
        "torch.backends.cuda.matmul.allow_tf32 = True\n" +
        "torch.backends.cudnn.allow_tf32 = True\n" +
        "torch.backends.cudnn.benchmark = True\n" +
        "Path(args.ckpt_dir).mkdir(parents=True, exist_ok=True)\n" +
        "ABORT_STATUS = os.path.join(args.ckpt_dir, 'r10c_abort.status')\n" +
        "STATUS_FILE  = os.path.join(args.ckpt_dir, 'r10c_watcher.status')\n" +
        "def wstatus(s):\n" +
        "    with open(STATUS_FILE, 'w') as f: f.write(s + '\\n')\n" +
        "wstatus('INIT')\n" +
        "\n" +
        "print('[r10c] seed=' + str(args.seed) + ' base=' + args.base_dir, flush=True)\n" +
        "print('[r10c] corpus=' + args.corpus + ' kowiki=' + (args.kowiki or '<none>') +\n" +
        "      ' mix_pct=' + str(args.kowiki_mix_pct), flush=True)\n" +
        "print('[r10c] sentinel=' + args.sentinel_hexa, flush=True)\n" +
        "\n" +
        "tok = AutoTokenizer.from_pretrained(args.base_dir, trust_remote_code=True)\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "from unsloth import FastLanguageModel\n" +
        "model, tok = FastLanguageModel.from_pretrained(\n" +
        "    model_name=args.base_dir, max_seq_length=args.seq, dtype=torch.bfloat16,\n" +
        "    load_in_4bit=False, trust_remote_code=True,\n" +
        "    use_gradient_checkpointing='unsloth',\n" +
        ")\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "try:\n" +
        "    from liger_kernel.transformers import apply_liger_kernel_to_qwen2\n" +
        "    apply_liger_kernel_to_qwen2(rope=True, rms_norm=True, swiglu=True,\n" +
        "                                fused_linear_cross_entropy=True, cross_entropy=False,\n" +
        "                                model=model)\n" +
        "    print('[r10c] liger applied', flush=True)\n" +
        "except Exception as e:\n" +
        "    print('[r10c] liger unavailable: ' + str(e), flush=True)\n" +
        "\n" +
        "# ── LoRA fresh init (r4 adapter proved misaligned on stripped corpus) ──\n" +
        "if args.adapter_dir:\n" +
        "    model = PeftModel.from_pretrained(model, args.adapter_dir, is_trainable=True)\n" +
        "    print('[r10c] warm-start OK from ' + args.adapter_dir, flush=True)\n" +
        "else:\n" +
        "    from unsloth import FastLanguageModel as _FLM\n" +
        "    model = _FLM.get_peft_model(\n" +
        "        model, r=args.lora_r, lora_alpha=args.lora_alpha,\n" +
        "        lora_dropout=args.lora_dropout,\n" +
        "        target_modules=['q_proj','k_proj','v_proj','o_proj'],\n" +
        "        bias='none', use_gradient_checkpointing='unsloth',\n" +
        "        random_state=args.seed,\n" +
        "    )\n" +
        "    print('[r10c] LoRA applied (fresh, seed=' + str(args.seed) + ')', flush=True)\n" +
        "model.print_trainable_parameters()\n" +
        "\n" +
        "# ── Corpus assembly: stripped_70b ⊕ optional kowiki mix ──\n" +
        "text_main = Path(args.corpus).read_text(errors='ignore')\n" +
        "text = text_main\n" +
        "kowiki_note = ''\n" +
        "if args.kowiki and os.path.isfile(args.kowiki):\n" +
        "    # Byte-budget kowiki insertion: target_bytes = main_bytes * mix_pct / (100 - mix_pct)\n" +
        "    main_bytes = len(text_main.encode('utf-8'))\n" +
        "    target_kowiki_bytes = max(1, main_bytes * args.kowiki_mix_pct // (100 - args.kowiki_mix_pct))\n" +
        "    chunks = []\n" +
        "    got = 0\n" +
        "    with open(args.kowiki, 'r', encoding='utf-8', errors='ignore') as kf:\n" +
        "        for line in kf:\n" +
        "            try:\n" +
        "                rec = json.loads(line)\n" +
        "                t = rec.get('text', '')\n" +
        "                if not t: continue\n" +
        "                chunks.append(t)\n" +
        "                got += len(t.encode('utf-8'))\n" +
        "                if got >= target_kowiki_bytes: break\n" +
        "            except Exception:\n" +
        "                continue\n" +
        "    kowiki_text = '\\n\\n'.join(chunks)\n" +
        "    text = text_main + '\\n\\n' + kowiki_text\n" +
        "    kowiki_note = ' +kowiki(' + str(got) + 'B, ' + str(len(chunks)) + ' docs)'\n" +
        "else:\n" +
        "    print('[r10c WARN] kowiki unavailable — using stripped_70b only (E7 corpus-diversity recommendation skipped)', flush=True)\n" +
        "print('[r10c] corpus bytes=' + str(len(text.encode('utf-8'))) + kowiki_note, flush=True)\n" +
        "\n" +
        "ids = tok(text, add_special_tokens=False)['input_ids']\n" +
        "print('[r10c] corpus tokens=' + str(len(ids)), flush=True)\n" +
        "seq = args.seq\n" +
        "n_blocks = len(ids) // seq\n" +
        "blocks = [ids[i*seq:(i+1)*seq] for i in range(n_blocks)]\n" +
        "print('[r10c] blocks=' + str(len(blocks)), flush=True)\n" +
        "\n" +
        "class PackedDS(Dataset):\n" +
        "    def __init__(self, blocks): self.b = blocks\n" +
        "    def __len__(self): return len(self.b)\n" +
        "    def __getitem__(self, i):\n" +
        "        x = torch.tensor(self.b[i], dtype=torch.long)\n" +
        "        return {'input_ids': x, 'labels': x.clone(), 'attention_mask': torch.ones_like(x)}\n" +
        "\n" +
        "ds = PackedDS(blocks)\n" +
        "dl = DataLoader(ds, batch_size=args.batch, shuffle=True, pin_memory=True, drop_last=True)\n" +
        "opt = torch.optim.AdamW([p for p in model.parameters() if p.requires_grad], lr=args.lr, fused=True)\n" +
        "\n" +
        "device = 'cuda'\n" +
        "model.train()\n" +
        "\n" +
        "# ── First-batch CE guard ──\n" +
        "it = iter(dl)\n" +
        "b0 = next(it)\n" +
        "with torch.no_grad():\n" +
        "    out0 = model(input_ids=b0['input_ids'].to(device),\n" +
        "                 labels=b0['labels'].to(device),\n" +
        "                 attention_mask=b0['attention_mask'].to(device))\n" +
        "    ce0 = float(out0.loss.detach().item())\n" +
        "print('[r10c] first-batch CE = ' + str(round(ce0, 4)), flush=True)\n" +
        "if ce0 > 8.0:\n" +
        "    with open(ABORT_STATUS, 'w') as f: f.write('FIRST_BATCH_CE=' + str(ce0) + '\\n')\n" +
        "    wstatus('ABORT_FIRST_BATCH_CE')\n" +
        "    print('[r10c ABORT] first-batch CE=' + str(ce0) + ' > 8.0 — exiting', flush=True)\n" +
        "    sys.exit(2)\n" +
        "\n" +
        "# ── DEST1 phi-hook: write 16D phi_vec.json next to each ckpt ──\n" +
        "# Schema matches training/alm_phi_vec_logger.hexa canonical layout. Inline\n" +
        "# surrogates: phi_holo_proxy = -log(max(ce, 1e-6)) (positive when ce<1);\n" +
        "# phi_complexity / phi_gwt computed offline by phi_eval_hook_spec. Other\n" +
        "# 13 dims NaN sentinels filled by downstream probes. Sufficient for the\n" +
        "# DEST1 gate ('phi > 1000 evidence') since phi_holo scale reaches 10^4 on\n" +
        "# r9 (12000) and r4 (9051). eval_phi_corr consumes N>=5 save_every=400.\n" +
        "def write_phi_vec(step, save_dir, ce_proxy):\n" +
        "    if not args.phi_hook: return\n" +
        "    import math\n" +
        "    nan = float('nan')\n" +
        "    phi_holo_proxy = -math.log(max(ce_proxy, 1e-6))\n" +
        "    # DEST1 explicit scale: phi_holo in r9/r4 raw is ~10^4. The proxy is\n" +
        "    # unitless and centered near 0 at ce=1. We expose BOTH — downstream\n" +
        "    # can pick whichever matches the phi_corr_history convention.\n" +
        "    phi_holo_scaled = phi_holo_proxy * 10000.0\n" +
        "    phi_vec = [phi_holo_proxy, nan, nan, nan, nan, nan, nan, nan,\n" +
        "               nan, nan, nan, nan, nan, nan, nan, nan]\n" +
        "    phi_path = os.path.join(save_dir, 'phi_vec.json')\n" +
        "    with open(phi_path, 'w') as f:\n" +
        "        json.dump({'step': step, 'phi_vec': phi_vec,\n" +
        "                   'phi_holo_proxy': phi_holo_proxy,\n" +
        "                   'phi_holo_scaled': phi_holo_scaled,\n" +
        "                   'ce_proxy': ce_proxy,\n" +
        "                   'schema': 'alm_phi_vec_logger_v1',\n" +
        "                   'round': 'r10c',\n" +
        "                   'seed': args.seed,\n" +
        "                   'dest1_gate_scale': 'phi_holo_scaled > 1000'},\n" +
        "                  f, allow_nan=True)\n" +
        "    print('[phi16] step=' + str(step) + ' phi_holo_proxy=' + str(round(phi_holo_proxy,4)) +\n" +
        "          ' phi_holo_scaled=' + str(round(phi_holo_scaled,2)), flush=True)\n" +
        "\n" +
        "# ── E7-OSS-01: sentinel via subprocess (authoritative exit code) ──\n" +
        "SENTINEL_PROMPTS = ['안녕하세요', '오늘 날씨', '한국어 모델', '딥러닝이란', '안녕']\n" +
        "def run_kr_gen(step, reason='cadence'):\n" +
        "    gc.collect(); torch.cuda.empty_cache(); model.eval()\n" +
        "    samples = []\n" +
        "    try:\n" +
        "        for prompt in SENTINEL_PROMPTS:\n" +
        "            iid = tok(prompt, return_tensors='pt').input_ids.to(device)\n" +
        "            with torch.no_grad():\n" +
        "                # E7-OSS-04: manual greedy loop bypasses unsloth fast_generate\n" +
        "                # kwarg bleed — unsloth injects num_logits_to_keep which newer\n" +
        "                # transformers (>=5.0) rejects in _validate_model_kwargs. Using\n" +
        "                # model(input_ids=...).logits directly avoids the whole wrapper.\n" +
        "                g_seq = iid\n" +
        "                eos_pad = (tok.eos_token_id, tok.pad_token_id)\n" +
        "                for _gs in range(32):\n" +
        "                    logits = model(input_ids=g_seq).logits\n" +
        "                    next_tok = logits[:, -1, :].argmax(dim=-1, keepdim=True)\n" +
        "                    g_seq = torch.cat([g_seq, next_tok], dim=-1)\n" +
        "                    if int(next_tok.item()) in eos_pad:\n" +
        "                        break\n" +
        "                g = g_seq\n" +
        "            gen = tok.decode(g[0][iid.shape[1]:], skip_special_tokens=True)\n" +
        "            samples.append({'prompt': prompt, 'gen': gen[:200]})\n" +
        "            del iid, g\n" +
        "    finally:\n" +
        "        model.train(); gc.collect(); torch.cuda.empty_cache()\n" +
        "    log_path = os.path.join(args.ckpt_dir, 'kr_gen_step_' + str(step) + '.json')\n" +
        "    with open(log_path, 'w') as f:\n" +
        "        json.dump({'step': step, 'reason': reason, 'samples': samples},\n" +
        "                  f, ensure_ascii=False, indent=2)\n" +
        "\n" +
        "    # E7-OSS-01: subprocess call; exit 2 = COLLAPSED authoritative\n" +
        "    verdict = 'UNKNOWN'; rc = -1; raw = ''\n" +
        "    try:\n" +
        "        r = subprocess.run([args.hexa_bin, args.sentinel_hexa, log_path],\n" +
        "                           capture_output=True, text=True, timeout=60)\n" +
        "        rc = r.returncode\n" +
        "        raw = (r.stdout or '') + (r.stderr or '')\n" +
        "        if rc == 0: verdict = 'CLEAN'\n" +
        "        elif rc == 2: verdict = 'COLLAPSED'\n" +
        "        else: verdict = 'SENTINEL_ERROR(' + str(rc) + ')'\n" +
        "    except Exception as e:\n" +
        "        # Hexa binary unavailable — fall back to inline byte-level check\n" +
        "        # (byte-run>=10 ANY byte — matches kr_gen_sentinel.hexa max_byte_run)\n" +
        "        print('[sentinel FALLBACK] hexa unavailable: ' + str(e), flush=True)\n" +
        "        import collections\n" +
        "        flagged = 0\n" +
        "        for s in (x['gen'] for x in samples):\n" +
        "            by = s.encode('utf-8', errors='ignore')\n" +
        "            run = best = 1\n" +
        "            for j in range(1, len(by)):\n" +
        "                if by[j] == by[j-1]:\n" +
        "                    run += 1\n" +
        "                    if run > best: best = run\n" +
        "                else: run = 1\n" +
        "            if best >= 10: flagged += 1\n" +
        "        verdict = 'COLLAPSED' if flagged >= 3 else 'CLEAN'\n" +
        "        rc = 2 if verdict == 'COLLAPSED' else 0\n" +
        "    print('[sentinel] step=' + str(step) + ' reason=' + reason +\n" +
        "          ' verdict=' + verdict + ' rc=' + str(rc), flush=True)\n" +
        "    if verdict == 'COLLAPSED':\n" +
        "        with open(ABORT_STATUS, 'w') as f:\n" +
        "            f.write('MODE_COLLAPSE_STEP=' + str(step) + '_REASON=' + reason + '\\n')\n" +
        "        wstatus('ABORT_MODE_COLLAPSE')\n" +
        "        print('[r10c ABORT] sentinel COLLAPSED at step=' + str(step), flush=True)\n" +
        "        sys.exit(2)\n" +
        "\n" +
        "# ── Training loop ──\n" +
        "wstatus('TRAINING')\n" +
        "step = 0; t0 = time.time(); best_loss = 1e9\n" +
        "while step < args.steps:\n" +
        "    for batch in dl:\n" +
        "        if step >= args.steps: break\n" +
        "        out = model(input_ids=batch['input_ids'].to(device),\n" +
        "                    labels=batch['labels'].to(device),\n" +
        "                    attention_mask=batch['attention_mask'].to(device))\n" +
        "        loss = out.loss\n" +
        "        loss.backward()\n" +
        "        if (step + 1) % args.grad_accum == 0:\n" +
        "            opt.step(); opt.zero_grad(set_to_none=True)\n" +
        "        step += 1\n" +
        "        lv = float(loss.detach().item())\n" +
        "        if step == 1 or step % 25 == 0:\n" +
        "            elapsed = time.time() - t0\n" +
        "            toks_s = (step * args.batch * args.seq) / max(elapsed, 1e-6)\n" +
        "            print('[step=' + str(step) + '] loss=' + str(round(lv,4)) +\n" +
        "                  ' lr=' + str(args.lr) + ' toks/s=' + str(round(toks_s,0)), flush=True)\n" +
        "        if step == 1 and lv > 8.0:\n" +
        "            with open(ABORT_STATUS, 'w') as f: f.write('STEP1_LOSS=' + str(lv) + '\\n')\n" +
        "            wstatus('ABORT_STEP1')\n" +
        "            print('[r10c ABORT] step=1 loss=' + str(lv) + ' > 8.0', flush=True)\n" +
        "            sys.exit(2)\n" +
        "        if lv < best_loss: best_loss = lv\n" +
        "\n" +
        "        # E7-OSS-03: sub-threshold loss at early step forces sentinel\n" +
        "        if step <= args.early_step_limit and lv < args.early_loss_gate:\n" +
        "            print('[r10c] early-gate fired: step=' + str(step) + ' loss=' +\n" +
        "                  str(round(lv,4)) + ' < ' + str(args.early_loss_gate) + ' — force sentinel', flush=True)\n" +
        "            run_kr_gen(step, reason='early_loss_gate')\n" +
        "\n" +
        "        if step % args.eval_every == 0:\n" +
        "            run_kr_gen(step, reason='cadence')\n" +
        "        if step % args.save_every == 0:\n" +
        "            save_dir = os.path.join(args.ckpt_dir, 'step_' + str(step))\n" +
        "            model.save_pretrained(save_dir)\n" +
        "            tok.save_pretrained(save_dir)\n" +
        "            meta = {'step': step, 'loss': lv, 'best_loss': best_loss,\n" +
        "                    'lr': args.lr, 'b1': False, 'base': args.base_dir,\n" +
        "                    'warm_start_from': args.adapter_dir, 'round': 'r10c',\n" +
        "                    'seed': args.seed, 'kowiki_mix_pct': args.kowiki_mix_pct,\n" +
        "                    'phi_hook': bool(args.phi_hook),\n" +
        "                    'sentinel_hexa': args.sentinel_hexa,\n" +
        "                    'ossified_rules': ['E7-OSS-01','E7-OSS-02','E7-OSS-03']}\n" +
        "            with open(os.path.join(save_dir, 'train_meta.json'), 'w') as f:\n" +
        "                json.dump(meta, f, indent=2)\n" +
        "            write_phi_vec(step, save_dir, lv)\n" +
        "            print('[save] step=' + str(step) + ' → ' + save_dir, flush=True)\n" +
        "\n" +
        "wstatus('DONE')\n" +
        "print('[r10c] DONE step=' + str(step) + ' best_loss=' + str(round(best_loss,4)), flush=True)\n"
    )

    // ── Bash wrapper: preflight + watcher launch + python launch ──
    let runner = "/tmp/_launch_alm_14b_r10c.sh"
    let seeds_env = if seed_sweep { "SEEDS='3407 42 1337'" } else { "SEEDS='3407'" }
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "echo \"================================================================\"\n" +
        "echo \"  ALM 14B r10c — E7 redesign (sentinel subprocess + corpus mix + seed sweep)\"\n" +
        "echo \"================================================================\"\n" +
        "\n" +
        "GPU_MEM=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null || echo 0)\n" +
        "[[ \"$GPU_MEM\" -lt 70000 ]] && { echo \"[ABORT] need H100 80GB\"; exit 1; }\n" +
        "echo \"[preflight] GPU OK (${GPU_MEM} MiB)\"\n" +
        "\n" +
        "BASE=/workspace/base_model\n" +
        "CORPUS=/workspace/corpus_alm_70b_stripped.txt\n" +
        "KOWIKI_PATH=/workspace/kowiki.jsonl\n" +
        "[[ -f \"$KOWIKI_PATH\" ]] || KOWIKI_PATH=\"\"\n" +
        "CKPT_BASE=/workspace/ckpt_alm_14b_r10c\n" +
        "SENTINEL=/workspace/anima/training/kr_gen_sentinel.hexa\n" +
        "HEXA_BIN=$(command -v hexa || echo /usr/local/bin/hexa)\n" +
        "[[ -d \"$BASE\" ]]   || { echo \"[ABORT] base missing: $BASE\"; exit 1; }\n" +
        "[[ -f \"$CORPUS\" ]] || { echo \"[ABORT] stripped corpus missing: $CORPUS\"; exit 1; }\n" +
        "[[ -f \"$SENTINEL\" ]] || { echo \"[ABORT] sentinel hexa missing: $SENTINEL\"; exit 1; }\n" +
        "\n" +
        "python3 -c 'import unsloth, liger_kernel, peft, transformers' 2>/dev/null || \\\n" +
        "    pip install -q peft==0.13.2 transformers==4.45.2 unsloth liger-kernel 2>&1 | tail -3\n" +
        "\n" +
        "export HF_HUB_CACHE=/workspace/hf_cache HF_HOME=/workspace/hf_cache\n" +
        "\n" +
        "# E7 seed sweep — smokes MUST ALL PASS before full launch\n" +
        seeds_env + "\n" +
        "for S in $SEEDS; do\n" +
        "    CKPT=${CKPT_BASE}_seed${S}\n" +
        "    rm -rf \"$CKPT\" && mkdir -p \"$CKPT\"\n" +
        "    echo INIT > \"$CKPT/r10c_watcher.status\"\n" +
        "    echo \"[launch] seed=$S ckpt=$CKPT\"\n" +
        "    # Launch with setsid so watcher can track the python PID directly\n" +
        "    setsid python3 " + py + " \\\n" +
        "        --base-dir \"$BASE\" \\\n" +
        "        --corpus \"$CORPUS\" \\\n" +
        "        --kowiki \"$KOWIKI_PATH\" --kowiki-mix-pct 15 \\\n" +
        "        --ckpt-dir \"$CKPT\" \\\n" +
        "        --steps " + steps + " \\\n" +
        "        --save-every " + save_every + " \\\n" +
        "        --eval-every " + eval_every + " \\\n" +
        "        --lr 2e-6 \\\n" +
        "        --batch 8 \\\n" +
        "        --seq 1024 \\\n" +
        "        --grad-accum 1 \\\n" +
        "        --lora-r 32 \\\n" +
        "        --lora-alpha 64 \\\n" +
        "        --lora-dropout 0.0 \\\n" +
        "        --seed $S \\\n" +
        "        --sentinel-hexa \"$SENTINEL\" \\\n" +
        "        --hexa-bin \"$HEXA_BIN\" \\\n" +
        "        2>&1 | tee \"$CKPT/train_r10c.log\"\n" +
        "\n" +
        "    # Read python exit code via PIPESTATUS[0] (tee is last)\n" +
        "    rc=${PIPESTATUS[0]}\n" +
        "    if [[ -f \"$CKPT/r10c_abort.status\" ]] || [[ \"$rc\" -ne 0 ]]; then\n" +
        "        echo \"[r10c] seed=$S ABORTED (rc=$rc) — see $CKPT/r10c_abort.status\"\n" +
        "        exit 2\n" +
        "    fi\n" +
        "    echo DONE > \"$CKPT/r10c_watcher.status\"\n" +
        "done\n" +
        "\n" +
        "echo \"[r10c] ALL seeds completed — label=" + ckpt_label + "\"\n"
    )

    if dry_run {
        println("[DRY_RUN] r10c plan:")
        println("  py     = " + py)
        println("  runner = " + runner)
        println("  smoke  = " + to_string(smoke))
        println("  sweep  = " + to_string(seed_sweep))
        println("  steps  = " + steps)
        println("  seeds  = " + (if seed_sweep { "3407 42 1337" } else { "3407" }))
        println("  ossified = E7-OSS-01 (sentinel subprocess), E7-OSS-02 (watchdog PID), E7-OSS-03 (early-loss gate)")
    } else {
        exec("chmod +x " + runner)
        exec("bash " + runner)
    }
}

main()
