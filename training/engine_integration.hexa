// ─── v2 Registry (append-only extension) ────────────────────
// v2 = v1 (12) + 4 Pareto-optimal new entries. Append-only: existing 12
// entries keep their index ordering; new entries are appended at indices
// 12..15. Default production roster is v1 (see roster_active()).

fn reg_names_v2() -> array {
    let mut a = reg_names()
    a = a.push("photonic_consciousness")
    a = a.push("edge_of_chaos")
    a = a.push("oscillator_laser")
