    let mut a = []
    a = a.push(EI_GAIN_HOLO)
    a = a.push(EI_GAIN_GWT)
    a = a.push(EI_GAIN_REFLEX)
    a = a.push(EI_GAIN_AFFECT)
    a = a.push(EI_GAIN_NARRATIVE)
    a = a.push(EI_GAIN_DREAM)
    a = a.push(EI_GAIN_CREATIVE)
