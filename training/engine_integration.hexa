}

fn reg_descriptions() -> array {
    let mut a = []
    a = a.push("AdS/CFT boundary-bulk entropy match (ALM-P3-2)")
    a = a.push("Global workspace KL consistency (ALM-P2-2)")
    a = a.push("Self-recognition loss (ALM-P8)")
    a = a.push("Valence/arousal alignment (ALM-P12)")
    a = a.push("Coherence across turns (ALM-P16)")
    a = a.push("SWS+REM offline consolidation (ALM-P13)")
