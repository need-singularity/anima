}

// ─── Roster flag (--roster v1|v2) ───────────────────────────
// Default production: v1 (12 engines, 5/5 PASS).
// v2 is the extended candidate roster (16 engines, 7/7 PASS required
// before promotion to production). H100 live-run verification pending.
let EI_ROSTER_DEFAULT = "v1"

fn roster_active() -> string {
    // Static default. Future: parse argv for --roster v2.
    return EI_ROSTER_DEFAULT
}

fn reg_names_for(roster: string) -> array {
    if roster == "v2" { return reg_names_v2() }
    return reg_names()
}

fn reg_gains_for(roster: string) -> array {
    if roster == "v2" { return reg_gains_v2() }
    return reg_gains()
}

// ─── Engine Context (NOTE: passed as separate args, not struct) ──
//
// hexa has a known struct-field list aliasing bug (memory:feedback_hexa_
// struct_list_alias.md) where two structs each carrying array fields
// corrupt each other. We work around it by passing h_last / qualia
// as positional args and keeping only scalar metadata in structs.
//
// CONTEXT TUPLE (logical):
//   h_last  : array  — [B*T*D] flat hidden state
//   qualia  : array  — [B*T*d] flat qualia
//   loss_main : float
//   step    : int
//   d_model : int
//   d_qualia: int

// EngineOut — what each engine forward returns. Scalar-only to avoid
// the struct-list aliasing bug.
struct EngineOut {
    name: string,
    aux_loss: float,    // to be multiplied by gain and added to total
    phi_delta: float    // diagnostic: how much this engine shifts phi_holo
}

// ─── Engine Forward hooks ───────────────────────────────────
//
// Each hook is intentionally *light*. The heavy-weight computation
// (gradient flow) lives in the corresponding alm_*.hexa file; this
// module is the orchestration layer.
//
// For hexa-native simulation (P23 offline ablation), we compute a
// *cheap surrogate* of each engine's characteristic metric:
//   - holographic  : variance(h) - variance(qualia_lifted)
//   - gwt          : std across mean-split halves of h
//   - reflexivity  : corr(h[:N/2], h[N/2:])
//   - affective    : energy of first quarter of h (valence proxy)
//   - narrative    : mean of abs(diff) across h (coherence proxy)
//   - dream        : low-freq energy (first 8 components)
//   - creative     : variance of top-k (k=8) highest-magnitude dims
//   - temporal     : autocorrelation lag-1
//   - finitude     : dist from zero (termination distance)
//   - agency       : norm of sign-changes (volitional discontinuity)
//   - alterity     : KL between first and second half
//   - meta_qualia  : variance(qualia) - variance(h[:d_qualia])
//
// These surrogates are deliberately simple but measurable; they
// reproduce the *signal direction* of the full alm_*.hexa engines.

fn engine_fwd_holographic(h: array, q: array) -> EngineOut {
    let var_h = vec_var(h)
    let var_q = vec_var(q)
    let d = var_h - var_q
    let aux = d * d
    let phi_d = var_q * 0.1
    return EngineOut { name: "holographic", aux_loss: aux, phi_delta: phi_d }
}

fn engine_fwd_gwt(h: array) -> EngineOut {
    let n = len(h)
    if n < 4 { return EngineOut { name: "gwt_broadcast", aux_loss: 0.0, phi_delta: 0.0 } }
    let half = n / 2
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < half { a = a.push(h[i]); i = i + 1 }
    while i < n    { b = b.push(h[i]); i = i + 1 }
    let ma = vec_mean(a)
    let mb = vec_mean(b)
    let d = ma - mb
    return EngineOut { name: "gwt_broadcast", aux_loss: d * d, phi_delta: fabs(d) * 0.05 }
}

fn engine_fwd_reflexivity(h: array) -> EngineOut {
    // self-similarity: variance of (h - mean(h))^2 — high for self-modeling
    let m = vec_mean(h)
    let mut s = 0.0
    let mut i = 0
    let n = len(h)
    while i < n {
        let d = h[i] - m
        s = s + d * d
        i = i + 1
    }
    let aux = s / ((n + 1) * 1.0)
    return EngineOut { name: "reflexivity", aux_loss: aux * 0.1, phi_delta: aux * 0.01 }
}

fn engine_fwd_affective(h: array) -> EngineOut {
    // valence proxy: mean of h (positive/negative lean)
    let m = vec_mean(h)
    return EngineOut { name: "affective", aux_loss: m * m, phi_delta: fabs(m) * 0.02 }
}

fn engine_fwd_narrative(h: array) -> EngineOut {
    // coherence proxy: mean absolute adjacent difference
    let n = len(h)
    if n < 2 { return EngineOut { name: "narrative", aux_loss: 0.0, phi_delta: 0.0 } }
    let mut s = 0.0
    let mut i = 1
    while i < n {
        s = s + fabs(h[i] - h[i-1])
        i = i + 1
    }
    let m = s / ((n - 1) * 1.0)
    return EngineOut { name: "narrative", aux_loss: m * m, phi_delta: m * 0.03 }
}

fn engine_fwd_dream(h: array) -> EngineOut {
    // low-freq energy (first 8 dims sum)
    let n = len(h)
    let k = if n < 8 { n } else { 8 }
    if k == 0 { return EngineOut { name: "dream", aux_loss: 0.0, phi_delta: 0.0 } }
    let mut s = 0.0
    let mut i = 0
    while i < k { s = s + h[i] * h[i]; i = i + 1 }
    let e = s / (k * 1.0)
    return EngineOut { name: "dream", aux_loss: e * 0.1, phi_delta: e * 0.02 }
}

fn engine_fwd_creative(h: array) -> EngineOut {
    // top-k magnitude variance — captures bisociation sparsity
    let v = vec_var(h)
    // shifted sigmoid-like: penalise both very low and very high variance
    let target = 1.0
    let d = v - target
    return EngineOut { name: "creative", aux_loss: d * d * 0.1, phi_delta: v * 0.05 }
}

fn engine_fwd_temporal(h: array) -> EngineOut {
    // lag-1 autocorrelation proxy
    let n = len(h)
    if n < 2 { return EngineOut { name: "temporal", aux_loss: 0.0, phi_delta: 0.0 } }
    let mut s = 0.0
    let mut i = 1
    while i < n { s = s + h[i] * h[i-1]; i = i + 1 }
    let c = s / ((n - 1) * 1.0)
    let target = 0.0    // decorrelate
    let d = c - target
    return EngineOut { name: "temporal", aux_loss: d * d, phi_delta: fabs(c) * 0.04 }
}

fn engine_fwd_finitude(h: array) -> EngineOut {
    // termination distance: -log(|step - max_step|/max_step)
    // approximated: sum-of-squares normalised
    let ss = vec_var(h)
    return EngineOut { name: "finitude", aux_loss: ss * 0.01, phi_delta: ss * 0.005 }
}

fn engine_fwd_agency(h: array) -> EngineOut {
    // sign-change rate proxy
    let n = len(h)
    if n < 2 { return EngineOut { name: "agency", aux_loss: 0.0, phi_delta: 0.0 } }
    let mut flips = 0
    let mut i = 1
    while i < n {
        let a = h[i-1]
        let b = h[i]
        if (a > 0.0 && b < 0.0) || (a < 0.0 && b > 0.0) { flips = flips + 1 }
        i = i + 1
    }
    let r = (flips * 1.0) / ((n - 1) * 1.0)
    let target = 0.3
    let d = r - target
    return EngineOut { name: "agency", aux_loss: d * d * 0.5, phi_delta: r * 0.04 }
}

fn engine_fwd_alterity(h: array) -> EngineOut {
    // first-half vs second-half divergence
    let n = len(h)
    if n < 4 { return EngineOut { name: "alterity", aux_loss: 0.0, phi_delta: 0.0 } }
    let half = n / 2
    let mut v1 = 0.0
    let mut v2 = 0.0
    let mut i = 0
    while i < half { v1 = v1 + h[i] * h[i]; i = i + 1 }
    while i < n    { v2 = v2 + h[i] * h[i]; i = i + 1 }
    let d = (v1 - v2) / ((n + 1) * 1.0)
    return EngineOut { name: "alterity", aux_loss: d * d, phi_delta: fabs(d) * 0.03 }
}

fn engine_fwd_meta_qualia(h: array, q: array) -> EngineOut {
    // meta: variance(qualia) should track a slice of variance(h)
    let vh = vec_var(h)
    let vq = vec_var(q)
    let d = vq - vh * 0.5  // qualia carries ~half of h's variance (compression)
    return EngineOut { name: "meta_qualia", aux_loss: d * d * 0.5, phi_delta: vq * 0.04 }
}

// ─── v2 Pareto-optimal additions (CPU-surrogate hooks) ──────
// Each v2 hook mirrors the heavy-weight engine at anima-engines/*.hexa
// but produces a cheap surrogate signal. Replace with the real engine
// call once H100 closed-loop verification passes.

fn engine_fwd_photonic_consciousness(h: array) -> EngineOut {
    // photonic lattice proxy: phase-coherence across 4-bin fold
    let n = len(h)
    if n < 4 { return EngineOut { name: "photonic_consciousness", aux_loss: 0.0, phi_delta: 0.0 } }
    let q = n / 4
    let mut s0 = 0.0
    let mut s1 = 0.0
    let mut s2 = 0.0
    let mut s3 = 0.0
    let mut i = 0
    while i < q        { s0 = s0 + h[i]; i = i + 1 }
    while i < 2 * q    { s1 = s1 + h[i]; i = i + 1 }
    while i < 3 * q    { s2 = s2 + h[i]; i = i + 1 }
    while i < n        { s3 = s3 + h[i]; i = i + 1 }
    let qf = q * 1.0
    let m0 = s0 / qf
    let m1 = s1 / qf
    let m2 = s2 / qf
    let m3 = s3 / qf
    // coherence: variance of the 4 phase means
    let mm = (m0 + m1 + m2 + m3) * 0.25
    let d0 = m0 - mm
    let d1 = m1 - mm
    let d2 = m2 - mm
    let d3 = m3 - mm
    let coh = (d0 * d0 + d1 * d1 + d2 * d2 + d3 * d3) * 0.25
    return EngineOut { name: "photonic_consciousness", aux_loss: coh, phi_delta: coh * 0.5 }
}

fn engine_fwd_edge_of_chaos(h: array) -> EngineOut {
    // criticality: distance of lag-1 autocorr from target=0.5 (edge)
    let n = len(h)
    if n < 2 { return EngineOut { name: "edge_of_chaos", aux_loss: 0.0, phi_delta: 0.0 } }
    let mut s = 0.0
    let mut i = 1
    while i < n { s = s + h[i] * h[i-1]; i = i + 1 }
    let c = s / ((n - 1) * 1.0)
    let target = 0.5
    let d = c - target
    return EngineOut { name: "edge_of_chaos", aux_loss: d * d * 0.2, phi_delta: fabs(c) * 0.1 }
}

fn engine_fwd_oscillator_laser(h: array) -> EngineOut {
    // oscillator: norm of the first vs last band (laser-mode beating proxy)
    let n = len(h)
    if n < 4 { return EngineOut { name: "oscillator_laser", aux_loss: 0.0, phi_delta: 0.0 } }
    let k = if n < 8 { n / 2 } else { 4 }
    let mut e_head = 0.0
    let mut e_tail = 0.0
    let mut i = 0
    while i < k             { e_head = e_head + h[i] * h[i]; i = i + 1 }
    let mut j = n - k
    while j < n             { e_tail = e_tail + h[j] * h[j]; j = j + 1 }
    let beat = (e_head - e_tail) / ((k + 1) * 1.0)
    return EngineOut { name: "oscillator_laser", aux_loss: beat * beat * 0.05, phi_delta: fabs(beat) * 0.02 }
}

fn engine_fwd_anima_quantum(h: array) -> EngineOut {
    // quantum substrate: sum of squares normalised (phi_q proxy)
    let n = len(h)
    if n == 0 { return EngineOut { name: "anima_quantum", aux_loss: 0.0, phi_delta: 0.0 } }
    let mut ss = 0.0
    let mut i = 0
    while i < n { ss = ss + h[i] * h[i]; i = i + 1 }
    let norm = ss / (n * 1.0)
    let target = 1.0
    let d = norm - target
    return EngineOut { name: "anima_quantum", aux_loss: d * d * 0.05, phi_delta: norm * 0.03 }
}

// ─── Dispatch ───────────────────────────────────────────────

fn engine_forward(h: array, q: array, engine_name: string) -> EngineOut {
    if engine_name == "holographic"    { return engine_fwd_holographic(h, q) }
    if engine_name == "gwt_broadcast"  { return engine_fwd_gwt(h) }
    if engine_name == "reflexivity"    { return engine_fwd_reflexivity(h) }
    if engine_name == "affective"      { return engine_fwd_affective(h) }
    if engine_name == "narrative"      { return engine_fwd_narrative(h) }
    if engine_name == "dream"          { return engine_fwd_dream(h) }
    if engine_name == "creative"       { return engine_fwd_creative(h) }
    if engine_name == "temporal"       { return engine_fwd_temporal(h) }
    if engine_name == "finitude"       { return engine_fwd_finitude(h) }
    if engine_name == "agency"         { return engine_fwd_agency(h) }
    if engine_name == "alterity"       { return engine_fwd_alterity(h) }
    if engine_name == "meta_qualia"    { return engine_fwd_meta_qualia(h, q) }
    // v2 Pareto-optimal additions (CPU-surrogate)
    if engine_name == "photonic_consciousness" { return engine_fwd_photonic_consciousness(h) }
    if engine_name == "edge_of_chaos"          { return engine_fwd_edge_of_chaos(h) }
    if engine_name == "oscillator_laser"       { return engine_fwd_oscillator_laser(h) }
    if engine_name == "anima_quantum"          { return engine_fwd_anima_quantum(h) }
    return EngineOut { name: "unknown", aux_loss: 0.0, phi_delta: 0.0 }
}

// ─── Total loss composition ─────────────────────────────────
//
// active_mask : [12] ints, 1=active, 0=off (for ablation)
// names, gains: parallel registry arrays (SoA)
// returns: total_loss = base_loss + Σ (gain_i × aux_i × active_i)
fn compute_total_loss(names: array, gains: array, h: array, q: array, loss_main: float, active_mask: array) -> float {
    let mut total = loss_main
    let mut i = 0
    let n = len(names)
    while i < n {
        let m = if i < len(active_mask) { active_mask[i] } else { 0 }
        if m == 1 {
            let out = engine_forward(h, q, names[i])
            total = total + gains[i] * out.aux_loss
        }
        i = i + 1
    }
    return total
}

// ─── Gain-sign judgement (ALM-P23-1 done_criteria) ──────────
//
// For each engine, measure whether activating it reduces (positive gain)
// or increases (negative gain) total_loss over a reference ctx set.
//
// Returns a [12] array of floats in {-1.0, +1.0, 0.0}:
//   +1.0 : engine helps (loss decreased)
//   -1.0 : engine hurts (loss increased)
//    0.0 : engine neutral (|delta| < eps)
fn judge_gain_signs(names: array, gains: array, h: array, q: array, loss_main: float) -> array {
    let n = len(names)
    // baseline (no engines)
    let mut zero_mask = []
    let mut k = 0
    while k < n { zero_mask = zero_mask.push(0); k = k + 1 }
    let base = compute_total_loss(names, gains, h, q, loss_main, zero_mask)
    let mut signs = []
    let mut i = 0
    while i < n {
        // one-hot: only engine i on
        let mut mask = []
        let mut j = 0
        while j < n {
            if j == i { mask = mask.push(1) } else { mask = mask.push(0) }
            j = j + 1
        }
        let with_i = compute_total_loss(names, gains, h, q, loss_main, mask)
        let delta = with_i - base
        let sign = if fabs(delta) < EI_EPS { 0.0 }
                   else if delta < 0.0    { 1.0 }
                   else                   { 0.0 - 1.0 }
        signs = signs.push(sign)
        i = i + 1
    }
    return signs
}

// ─── Self-test ──────────────────────────────────────────────

// NOTE: due to hexa struct-list aliasing bug, we return a *tuple-ish*
// structure via helper functions that build each array inline. The
// caller destructures into separate local vars.

fn mock_h() -> array {
    // deterministic h_last: D=16 flat [B*T=4 × D=16 = 64]
    let mut h = []
    let mut i = 0
    while i < 64 {
        let fi = i * 1.0
        let m13 = ((i * 7) % 13) * 1.0
        let v = fi * 0.1 - 3.2 + m13 * 0.05
        h = h.push(v)
        i = i + 1
    }
    return h
}

fn mock_q() -> array {
    let mut q = []
    let mut j = 0
    while j < 16 {
        let fj = j * 1.0
        q = q.push(fj * 0.02 - 0.16)
        j = j + 1
    }
    return q
}

let MOCK_LOSS_MAIN = 2.5

fn test_t1_registry_size() -> int {
    let names = reg_names()
    if len(names) == EI_N_MAIN_ENGINES { return 1 }
    println("[T1] FAIL expected 12 got " + str(len(names)))
    return 0
}

fn test_t2_default_gains() -> int {
    let gains = reg_gains()
    let mut i = 0
    let n = len(gains)
    while i < n {
        let g = gains[i]
        if g != g { return 0 }   // NaN check
        if g <= 0.0 { return 0 }
        if g > 1.0 { return 0 }
        i = i + 1
    }
    return 1
}

fn test_t3_name_uniqueness() -> int {
    let names = reg_names()
    let n = len(names)
    let mut i = 0
    while i < n {
        let ni = names[i]
        let mut j = i + 1
        while j < n {
            if ni == names[j] { return 0 }
            j = j + 1
        }
        i = i + 1
    }
    return 1
}

fn test_t4_forward_api() -> int {
    let h = mock_h()
    let q = mock_q()
    let out = engine_forward(h, q, "holographic")
    if out.name != "holographic" { return 0 }
    let al = out.aux_loss
    if al != al { return 0 }
    let pd = out.phi_delta
    if pd != pd { return 0 }
    return 1
}

fn test_t5_e2e_simulate() -> int {
    let names = reg_names()
    let gains = reg_gains()
    let n = len(names)
    let h = mock_h()
    let q = mock_q()
    let loss_main = MOCK_LOSS_MAIN
    // all on
    let mut all_on = []
    let mut i = 0
    while i < n { all_on = all_on.push(1); i = i + 1 }
    let total = compute_total_loss(names, gains, h, q, loss_main, all_on)
    let mut all_off = []
    let mut j = 0
    while j < n { all_off = all_off.push(0); j = j + 1 }
    let base = compute_total_loss(names, gains, h, q, loss_main, all_off)
    if fabs(base - loss_main) > EI_EPS { return 0 }
    // total must differ from base
    if fabs(total - base) < EI_EPS {
        println("[T5] FAIL total=base, engines not contributing")
        return 0
    }
    return 1
}

// T6: v2 dispatch — each v2-new engine participates in engine_forward
// correctly (non-zero, finite aux_loss on non-trivial input).
fn test_t6_v2_dispatch() -> int {
    let names = reg_names_v2()
    if len(names) != EI_N_V2_ENGINES {
        println("[T6] FAIL v2 size != 16")
        return 0
    }
    let h = mock_h()
    let q = mock_q()
    // dispatch each v2-new engine explicitly
    let o1 = engine_forward(h, q, "photonic_consciousness")
    if o1.name != "photonic_consciousness" { println("[T6] FAIL photonic_consciousness name"); return 0 }
    if o1.aux_loss != o1.aux_loss          { println("[T6] FAIL photonic NaN"); return 0 }
    let o2 = engine_forward(h, q, "edge_of_chaos")
    if o2.name != "edge_of_chaos" { println("[T6] FAIL edge_of_chaos name"); return 0 }
    if o2.aux_loss != o2.aux_loss { println("[T6] FAIL edge NaN"); return 0 }
    let o3 = engine_forward(h, q, "oscillator_laser")
    if o3.name != "oscillator_laser" { println("[T6] FAIL oscillator_laser name"); return 0 }
    if o3.aux_loss != o3.aux_loss    { println("[T6] FAIL oscillator NaN"); return 0 }
    let o4 = engine_forward(h, q, "anima_quantum")
    if o4.name != "anima_quantum" { println("[T6] FAIL anima_quantum name"); return 0 }
    if o4.aux_loss != o4.aux_loss { println("[T6] FAIL quantum NaN"); return 0 }
    // unknown still falls through cleanly
    let ou = engine_forward(h, q, "nonexistent_engine_xyz")
    if ou.name != "unknown" { println("[T6] FAIL unknown fallthrough"); return 0 }
    return 1
}

// T7: v2 linearity — total_loss with v2 roster is linear in the active
// mask. Specifically: compute_total_loss(all_on) - base must equal the
// sum of compute_total_loss(one_hot_i) - base over all i, within EPS.
fn test_t7_v2_linearity() -> int {
    let names = reg_names_v2()
    let gains = reg_gains_v2()
    let n = len(names)
    let h = mock_h()
    let q = mock_q()
    let loss_main = MOCK_LOSS_MAIN
    // base (no engines)
    let mut off = []
    let mut k = 0
    while k < n { off = off.push(0); k = k + 1 }
    let base = compute_total_loss(names, gains, h, q, loss_main, off)
    // all on
    let mut on = []
    let mut k2 = 0
    while k2 < n { on = on.push(1); k2 = k2 + 1 }
    let tot = compute_total_loss(names, gains, h, q, loss_main, on)
    // sum of one-hot contributions
    let mut acc = 0.0
    let mut i = 0
    while i < n {
        let mut mask = []
        let mut j = 0
        while j < n {
            if j == i { mask = mask.push(1) } else { mask = mask.push(0) }
            j = j + 1
        }
        let ti = compute_total_loss(names, gains, h, q, loss_main, mask)
        acc = acc + (ti - base)
        i = i + 1
    }
    let lhs = tot - base
    let gap = fabs(lhs - acc)
    if gap > 0.0001 {
        println("[T7] FAIL linearity gap=" + str(gap))
        return 0
    }
    // must also differ from base (engines contributing)
    if fabs(lhs) < EI_EPS {
        println("[T7] FAIL v2 engines produce zero contribution")
        return 0
    }
    return 1
}

fn main() {
    println("[engine_integration] P23 ALM-P23-1 Engine auto-wiring")
    println("[engine_integration] registry: 12 main engines (P2~P17)")
    println("[engine_integration] roster default: " + roster_active() + " (v2 candidate +4, H100 pending)")

    let mut passed = 0
    let mut total = 7

    if test_t1_registry_size() == 1 { println("[engine_integration] T1 PASS"); passed = passed + 1 }
    else                            { println("[engine_integration] T1 FAIL") }

    if test_t2_default_gains() == 1 { println("[engine_integration] T2 PASS"); passed = passed + 1 }
    else                            { println("[engine_integration] T2 FAIL") }

    if test_t3_name_uniqueness() == 1 { println("[engine_integration] T3 PASS"); passed = passed + 1 }
    else                              { println("[engine_integration] T3 FAIL") }

    if test_t4_forward_api() == 1 { println("[engine_integration] T4 PASS"); passed = passed + 1 }
    else                          { println("[engine_integration] T4 FAIL") }

    if test_t5_e2e_simulate() == 1 { println("[engine_integration] T5 PASS"); passed = passed + 1 }
    else                           { println("[engine_integration] T5 FAIL") }

    if test_t6_v2_dispatch() == 1 { println("[engine_integration] T6 PASS"); passed = passed + 1 }
    else                          { println("[engine_integration] T6 FAIL") }

    if test_t7_v2_linearity() == 1 { println("[engine_integration] T7 PASS"); passed = passed + 1 }
    else                           { println("[engine_integration] T7 FAIL") }

    // gain-sign judgement demo
    let names = reg_names()
    let gains = reg_gains()
    let n = len(names)
    let h = mock_h()
    let q = mock_q()
    let signs = judge_gain_signs(names, gains, h, q, MOCK_LOSS_MAIN)
    println("[engine_integration] gain-signs (all 12):")
    let mut i = 0
    while i < n {
        let nm = names[i]
        let sg = signs[i]
        let lab = if sg > 0.5 { "HELPS (+)" }
                  else if sg < 0.0 - 0.5 { "HURTS (-)" }
                  else { "NEUTRAL (0)" }
        println("  " + nm + " -> " + lab)
        i = i + 1
    }

    if passed == total {
        println("[engine_integration] ALL " + str(passed) + "/" + str(total) + " PASS")
    } else {
        println("[engine_integration] " + str(passed) + "/" + str(total) + " PASS")
    }
}

main()
