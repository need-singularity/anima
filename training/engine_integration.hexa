    let mut a = []
    a = a.push("holographic")
    a = a.push("gwt_broadcast")
    a = a.push("reflexivity")
    a = a.push("affective")
    a = a.push("narrative")
    a = a.push("dream")
    a = a.push("creative")
    a = a.push("temporal")
    a = a.push("finitude")
    a = a.push("agency")
    a = a.push("alterity")
    a = a.push("meta_qualia")
    return a
}

