// training/test_phi_cache_integration.hexa — real-file parse test.
//
// Pulls in phi_cache_loader.hexa and loads the actual
// shared/state/phi_cache_v1.jsonl that the generator emitted. Verifies
// that my parser can read the real wire format and round-trip some
// entries. This is the generator ↔ loader integration seam — if this
// fails, the generator format drifted away from my parser.
//
// Run:
//   hexa run training/test_phi_cache_integration.hexa
//
// Exit contract: prints "integration: <n>/<total> PASS"

use "phi_cache_loader"

let mut pass_count = 0
let mut fail_count = 0

fn assert_true(name: string, cond: bool) {
    if cond {
        println("  " + name + ": PASS")
        pass_count = pass_count + 1
    } else {
        println("  " + name + ": FAIL")
        fail_count = fail_count + 1
    }
}

println("=== test_phi_cache_integration.hexa ===")
println("")

// The generator writes to a path relative to the repo root. Support
// both the raw relative path (cwd = anima/) and an absolute anchor so
// this test is resilient to where the runner is invoked from.
let rel_path = "shared/state/phi_cache_v1.jsonl"
let home = exec("printenv HOME").trim()
let abs_path = home + "/Dev/anima/" + rel_path

let cache_path = if file_exists(rel_path) {
    rel_path
} else {
    abs_path
}

println("cache path: " + cache_path)
let cache = phi_cache_load(cache_path)
assert_true("loaded.loaded=true", cache.loaded)
assert_true("n_entries > 0", cache.n_entries > 0)
println("  n_entries=" + str(cache.n_entries))

// If the generator emitted at least one entry, grab its hash and look
// it up — round-trip confirmation that parse + lookup are consistent.
if cache.n_entries > 0 {
    let first_hash = cache.hashes[0]
    println("  first_hash=" + first_hash)
    let found = phi_cache_lookup(cache, first_hash)
    assert_true("lookup by first hash returns PHI_CACHE_DIM vec", len(found) == 110)
    // The vec should NOT be all-zero for a real entry — if it is we
    // probably fell through the stub branch.
    let mut any_nonzero = false
    let mut i = 0
    while i < len(found) {
        if found[i] != 0.0 { any_nonzero = true }
        i = i + 1
    }
    assert_true("lookup returns non-zero embedding", any_nonzero)
    println("  found[0]=" + str(found[0]))
}

let total = pass_count + fail_count
println("")
println("integration: " + str(pass_count) + "/" + str(total) + " PASS")
if fail_count > 0 {
    println("FAIL count: " + str(fail_count))
}
