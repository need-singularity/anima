// training/launch_alm_a2_tool_mixed.hexa — D4 pivot launcher for A2-Tool retrain
// @convergence state=provisional id=A2_TOOL_MIXED_D4_PIVOT_LAUNCHER
//                 value="D4 pivot retrain launcher — emits pod-side Python runner
//                        that loads A1+A2-Orch merged base and fine-tunes tool-use
//                        LoRA on the mixed corpus (3250 lines, 4% tool ratio).
//                        300 steps / lr 2e-6 / warmup 30 / batch 8 / save@150.
//                        Handles BOTH tool-schema JSONL lines AND ChatML JSONL lines
//                        from corpus_alm_70b.jsonl (auto-detect per line)."
//                 created_at=2026-04-17
//
// Predecessor (caused D4 regression):
//   /workspace/launch_a2_tool.py  (50 tool examples × 1500 steps → overfit)
//
// Purpose:
//   Same pattern as the hexa trainers: this .hexa launcher writes a pod-side
//   Python runner (permitted runtime emission per R7/Py-ban policy) that
//   handles A2-Tool retraining against the mixed corpus. We cannot author
//   a NEW .py file (Py ban), but write_file() → exec python3 runner is the
//   documented escape hatch used by train_alm_14b.hexa + launch_a2_tool.py.
//
// Differences vs predecessor:
//   - CORPUS path → mixed_tool_corpus.jsonl (3250 lines)
//   - Data loader: auto-detects per line (tool schema vs ChatML) to handle
//     mixed corpus lines (50-tool×5 + 3000 broad ChatML from KoAlpaca/KMMLU/KoBEST)
//   - STEPS  1500 → 300  (D4 post-mortem: steps/example ≤ 3)
//   - LR     3e-6 → 2e-6 (lower to protect merged base)
//   - WARMUP 100  → 30   (proportional)
//   - SAVE_EVERY 500 → 150
//   - EVAL_EVERY 100 → 50
//   - CKPT_DIR suffix: _mixed_ (distinguishes from failed run)
//   - R2 prefix: a2_20260417_tool_mixed (new round dir)
//
// Run (on pod):
//   bash /workspace/launch_a2_tool_mixed.sh
// Or (local dry-run to emit runner):
//   DRY_RUN=1 hexa run training/launch_alm_a2_tool_mixed.hexa

let RUNNER_OUT_PATH = "/tmp/_launch_a2_tool_mixed_runner.py"
let POD_RUNNER_LOCAL_COPY = "/tmp/launch_a2_tool_mixed_pod.py"
let SHELL_WRAPPER_PATH = "/tmp/launch_a2_tool_mixed.sh"

fn log(msg: string) { println("[a2_tool_mixed] " + msg) }

fn main() {
    log("=== D4 pivot: A2-Tool mixed-corpus retrain launcher ===")

    // Emit the pod-side Python runner (runtime emission allowed per Py ban)
    let py = ""
        + "#!/usr/bin/env python3\n"
        + "\"\"\"ALM A2-Tool D4-pivot retrain — mixed corpus (250 tool + 3000 broad).\n"
        + "Emitted from training/launch_alm_a2_tool_mixed.hexa at 2026-04-17.\n"
        + "\n"
        + "Replaces /workspace/launch_a2_tool.py which overfit on 50 examples.\n"
        + "Handles BOTH tool-schema JSONL and ChatML JSONL lines (auto-detect).\n"
        + "\"\"\"\n"
        + "import os, sys, json, time, gc, datetime, math\n"
        + "\n"
        + "import torch\n"
        + "assert torch.cuda.is_available(), \"No CUDA\"\n"
        + "assert torch.cuda.get_device_capability(0)[0] >= 8, \"Need sm80+ for bf16\"\n"
        + "\n"
        + "gpu_mem = torch.cuda.mem_get_info(0)\n"
        + "print(f\"[preflight] GPU: {torch.cuda.get_device_name(0)}, free={gpu_mem[0]//1e9:.0f}GB/{gpu_mem[1]//1e9:.0f}GB\")\n"
        + "for m in [\"/workspace/READY_FOR_32B\", \"/workspace/READY_FOR_R5_KBASE\"]:\n"
        + "    assert not os.path.exists(m), f\"Forbidden marker: {m}\"\n"
        + "\n"
        + "# ─── Config (D4 PIVOT values) ───────────────────────────────\n"
        + "A1_MERGED_BASE   = \"/workspace/a1_merged_base_20260416\"\n"
        + "A2_ORCH_ADAPTER  = \"/workspace/ckpt_alm14b_phi_a2_orch_20260416/step_3000\"\n"
        + "CORPUS           = \"/workspace/anima/training/corpus_tool/mixed_tool_corpus.jsonl\"\n"
        + "DATE             = datetime.datetime.now().strftime(\"%Y%m%d\")\n"
        + "RUN_ID           = f\"alm14b-phi-a2-tool-mixed-{DATE}\"\n"
        + "CKPT_DIR         = f\"/workspace/ckpt_alm14b_phi_a2_tool_mixed_{DATE}\"\n"
        + "STEPS            = 300\n"
        + "BATCH            = 1\n"
        + "GRAD_ACCUM       = 8\n"
        + "LR               = 2e-6\n"
        + "WARMUP           = 30\n"
        + "SAVE_EVERY       = 150\n"
        + "EVAL_EVERY       = 50\n"
        + "MAX_LEN          = 1024\n"
        + "\n"
        + "assert os.path.isdir(A1_MERGED_BASE), f\"Missing: {A1_MERGED_BASE}\"\n"
        + "assert os.path.isfile(f\"{A2_ORCH_ADAPTER}/adapter_config.json\"), f\"Missing A2-Orch adapter\"\n"
        + "assert os.path.isfile(CORPUS), f\"Missing corpus: {CORPUS}\"\n"
        + "\n"
        + "os.makedirs(CKPT_DIR, exist_ok=False)\n"
        + "print(f\"[setup] run_id={RUN_ID}\")\n"
        + "print(f\"[setup] ckpt_dir={CKPT_DIR}\")\n"
        + "\n"
        + "print(\"[merge] Loading A1-merged base + A2-Orch adapter...\")\n"
        + "from transformers import AutoModelForCausalLM, AutoTokenizer\n"
        + "from peft import PeftModel, LoraConfig, get_peft_model\n"
        + "\n"
        + "tokenizer = AutoTokenizer.from_pretrained(A1_MERGED_BASE, trust_remote_code=True)\n"
        + "if tokenizer.pad_token is None:\n"
        + "    tokenizer.pad_token = tokenizer.eos_token\n"
        + "\n"
        + "model = AutoModelForCausalLM.from_pretrained(\n"
        + "    A1_MERGED_BASE,\n"
        + "    torch_dtype=torch.bfloat16,\n"
        + "    device_map=\"cpu\",\n"
        + "    trust_remote_code=True,\n"
        + ")\n"
        + "print(f\"[merge] Base loaded: {sum(p.numel() for p in model.parameters())/1e9:.2f}B params\")\n"
        + "\n"
        + "model = PeftModel.from_pretrained(model, A2_ORCH_ADAPTER)\n"
        + "print(\"[merge] A2-Orch adapter applied, merging...\")\n"
        + "model = model.merge_and_unload()\n"
        + "print(\"[merge] A2-Orch merged. Now have A1+A2-Orch merged base.\")\n"
        + "\n"
        + "print(\"[lora] Moving merged model to GPU...\")\n"
        + "model = model.to(\"cuda\")\n"
        + "gc.collect()\n"
        + "torch.cuda.empty_cache()\n"
        + "\n"
        + "lora_config = LoraConfig(\n"
        + "    r=32, lora_alpha=64, lora_dropout=0.05,\n"
        + "    target_modules=[\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\"],\n"
        + "    bias=\"none\", task_type=\"CAUSAL_LM\",\n"
        + ")\n"
        + "model = get_peft_model(model, lora_config)\n"
        + "model.print_trainable_parameters()\n"
        + "print(\"[lora] Fresh tool-use LoRA applied (r32, alpha64, attn-only)\")\n"
        + "\n"
        + "# ─── Data loader: auto-detect tool-schema vs ChatML schema ───\n"
        + "# Mixed corpus layout:\n"
        + "#   - Tool lines (250): {\"tool\":{...},\"instruction\":\"...\",\n"
        + "#                        \"tool_call\":{...},\"result\":\"...\"}\n"
        + "#   - Broad lines (3000): {\"role\":\"alm70b_chatml\",\n"
        + "#                          \"messages\":[{\"role\":\"user\",...},\n"
        + "#                                       {\"role\":\"assistant\",...}]}\n"
        + "print(f\"[data] Loading {CORPUS}...\")\n"
        + "data = []\n"
        + "n_tool = 0\n"
        + "n_chat = 0\n"
        + "n_skip = 0\n"
        + "with open(CORPUS, \"r\") as f:\n"
        + "    for line in f:\n"
        + "        line = line.strip()\n"
        + "        if not line:\n"
        + "            continue\n"
        + "        try:\n"
        + "            item = json.loads(line)\n"
        + "        except Exception:\n"
        + "            n_skip += 1; continue\n"
        + "        if \"tool\" in item and \"instruction\" in item and \"tool_call\" in item:\n"
        + "            # Tool-schema line (from seed_tool_corpus.jsonl)\n"
        + "            tool_def = json.dumps(item[\"tool\"], ensure_ascii=False)\n"
        + "            instruction = item[\"instruction\"]\n"
        + "            tool_call = json.dumps(item[\"tool_call\"], ensure_ascii=False)\n"
        + "            result = str(item.get(\"result\", \"\"))\n"
        + "            text = (\n"
        + "                f\"<|im_start|>system\\nYou are an AI assistant with access to tools. \"\n"
        + "                f\"Available tool:\\n{tool_def}<|im_end|>\\n\"\n"
        + "                f\"<|im_start|>user\\n{instruction}<|im_end|>\\n\"\n"
        + "                f\"<|im_start|>assistant\\n<tool_call>\\n{tool_call}\\n</tool_call><|im_end|>\\n\"\n"
        + "                f\"<|im_start|>tool\\n{result}<|im_end|>\\n\"\n"
        + "                f\"<|im_start|>assistant\\nTool call executed successfully. {result}<|im_end|>\"\n"
        + "            )\n"
        + "            data.append(text); n_tool += 1\n"
        + "        elif \"messages\" in item and isinstance(item[\"messages\"], list):\n"
        + "            # ChatML line (from corpus_alm_70b.jsonl)\n"
        + "            parts = [\"<|im_start|>system\\nYou are a helpful AI assistant.<|im_end|>\"]\n"
        + "            for msg in item[\"messages\"]:\n"
        + "                role = msg.get(\"role\", \"user\")\n"
        + "                content = msg.get(\"content\", \"\")\n"
        + "                parts.append(f\"<|im_start|>{role}\\n{content}<|im_end|>\")\n"
        + "            text = \"\\n\".join(parts)\n"
        + "            data.append(text); n_chat += 1\n"
        + "        else:\n"
        + "            n_skip += 1\n"
        + "print(f\"[data] loaded {len(data)} examples  (tool={n_tool}  chatml={n_chat}  skipped={n_skip})\")\n"
        + "assert n_tool >= 200, f\"too few tool examples: {n_tool}\"\n"
        + "assert n_chat >= 2000, f\"too few chatml examples: {n_chat}\"\n"
        + "\n"
        + "from torch.utils.data import Dataset, DataLoader\n"
        + "\n"
        + "class MixedCorpus(Dataset):\n"
        + "    def __init__(self, texts, tok, max_len=1024):\n"
        + "        self.encodings = []\n"
        + "        for i, t in enumerate(texts):\n"
        + "            enc = tok(t, truncation=True, max_length=max_len, padding=\"max_length\", return_tensors=\"pt\")\n"
        + "            self.encodings.append({k: v.squeeze(0) for k, v in enc.items()})\n"
        + "            if (i+1) % 500 == 0:\n"
        + "                print(f\"  tokenized {i+1}/{len(texts)}\", flush=True)\n"
        + "    def __len__(self):\n"
        + "        return len(self.encodings)\n"
        + "    def __getitem__(self, idx):\n"
        + "        item = self.encodings[idx]\n"
        + "        return {\"input_ids\": item[\"input_ids\"], \"attention_mask\": item[\"attention_mask\"], \"labels\": item[\"input_ids\"].clone()}\n"
        + "\n"
        + "print(\"[data] tokenizing mixed corpus...\", flush=True)\n"
        + "dataset = MixedCorpus(data, tokenizer, max_len=MAX_LEN)\n"
        + "print(f\"[data] Tokenized: {len(dataset)} samples, seq={MAX_LEN}\")\n"
        + "\n"
        + "optimizer = torch.optim.AdamW(model.parameters(), lr=LR, betas=(0.9, 0.999), weight_decay=0.01, fused=True)\n"
        + "\n"
        + "def lr_schedule(step):\n"
        + "    if step < WARMUP:\n"
        + "        return step / max(WARMUP, 1)\n"
        + "    progress = (step - WARMUP) / max(STEPS - WARMUP, 1)\n"
        + "    return 0.5 * (1 + math.cos(math.pi * progress))\n"
        + "\n"
        + "scheduler = torch.optim.lr_scheduler.LambdaLR(optimizer, lr_schedule)\n"
        + "loader = DataLoader(dataset, batch_size=BATCH, shuffle=True)\n"
        + "\n"
        + "model.train()\n"
        + "optimizer.zero_grad()\n"
        + "global_step = 0\n"
        + "running_loss = 0.0\n"
        + "step_count = 0\n"
        + "t0 = time.time()\n"
        + "\n"
        + "print(f\"\\n{'='*60}\")\n"
        + "print(f\"  A2-Tool MIXED Training: {STEPS} steps, LR={LR}, batch={BATCH}x{GRAD_ACCUM}\")\n"
        + "print(f\"  LoRA: r=32, alpha=64, attn-only (q/k/v/o)\")\n"
        + "print(f\"  Corpus: {len(dataset)} mixed examples (tool={n_tool} chatml={n_chat})\")\n"
        + "print(f\"{'='*60}\\n\", flush=True)\n"
        + "\n"
        + "epoch = 0\n"
        + "nan_count = 0\n"
        + "while global_step < STEPS:\n"
        + "    epoch += 1\n"
        + "    for batch_data in loader:\n"
        + "        if global_step >= STEPS:\n"
        + "            break\n"
        + "        input_ids = batch_data[\"input_ids\"].to(\"cuda\")\n"
        + "        attention_mask = batch_data[\"attention_mask\"].to(\"cuda\")\n"
        + "        labels = batch_data[\"labels\"].to(\"cuda\")\n"
        + "        with torch.cuda.amp.autocast(dtype=torch.bfloat16):\n"
        + "            outputs = model(input_ids=input_ids, attention_mask=attention_mask, labels=labels)\n"
        + "            loss = outputs.loss / GRAD_ACCUM\n"
        + "        loss.backward()\n"
        + "        running_loss += loss.item() * GRAD_ACCUM\n"
        + "        step_count += 1\n"
        + "        if step_count % GRAD_ACCUM == 0:\n"
        + "            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n"
        + "            optimizer.step()\n"
        + "            scheduler.step()\n"
        + "            optimizer.zero_grad()\n"
        + "            global_step += 1\n"
        + "            avg_loss = running_loss / GRAD_ACCUM\n"
        + "            if not (avg_loss == avg_loss) or avg_loss > 1e6:  # NaN or inf\n"
        + "                nan_count += 1\n"
        + "                print(f\"[step {global_step}] NaN/inf loss={avg_loss} — count={nan_count}\", flush=True)\n"
        + "                if nan_count >= 3:\n"
        + "                    print(\"[abort] 3 NaN losses\", flush=True); sys.exit(2)\n"
        + "            if global_step % 10 == 0 or global_step <= 5:\n"
        + "                elapsed = time.time() - t0\n"
        + "                lr_now = scheduler.get_last_lr()[0]\n"
        + "                eta_h = (elapsed / max(global_step, 1)) * (STEPS - global_step) / 3600\n"
        + "                print(f\"[step {global_step:5d}/{STEPS}] loss={avg_loss:.4f} lr={lr_now:.2e} elapsed={elapsed/60:.1f}m eta={eta_h:.2f}h\", flush=True)\n"
        + "            running_loss = 0.0\n"
        + "            if global_step % EVAL_EVERY == 0:\n"
        + "                model.eval()\n"
        + "                test_prompt = '<|im_start|>system\\nYou are a helpful AI assistant.<|im_end|>\\n<|im_start|>user\\n뉴럴 네트워크 훈련이 완료되었다는 내용의 짧은 이메일을 작성해주세요.<|im_end|>\\n<|im_start|>assistant\\n'\n"
        + "                with torch.no_grad():\n"
        + "                    enc = tokenizer(test_prompt, return_tensors=\"pt\").to(\"cuda\")\n"
        + "                    gen = model.generate(**enc, max_new_tokens=100, do_sample=False, temperature=1.0, pad_token_id=tokenizer.pad_token_id)\n"
        + "                    out = tokenizer.decode(gen[0][enc[\"input_ids\"].shape[1]:], skip_special_tokens=False)\n"
        + "                    print(f\"[eval@{global_step}] {out[:200]}\", flush=True)\n"
        + "                model.train()\n"
        + "            if global_step % SAVE_EVERY == 0:\n"
        + "                save_dir = f\"{CKPT_DIR}/step_{global_step}\"\n"
        + "                os.makedirs(save_dir, exist_ok=True)\n"
        + "                model.save_pretrained(save_dir)\n"
        + "                tokenizer.save_pretrained(save_dir)\n"
        + "                meta = {\"run_id\": RUN_ID, \"step\": global_step, \"loss\": avg_loss, \"lr\": scheduler.get_last_lr()[0], \"elapsed_min\": (time.time() - t0) / 60, \"base\": \"A1+A2-Orch merged\", \"lora\": \"r32_alpha64_attn\", \"corpus\": f\"mixed_tool_corpus.jsonl (tool={n_tool}+chatml={n_chat})\", \"ckpt_label\": \"production\", \"saved_at\": datetime.datetime.now().isoformat(), \"d4_pivot\": True}\n"
        + "                with open(f\"{save_dir}/ckpt_meta.json\", \"w\") as f:\n"
        + "                    json.dump(meta, f, indent=2)\n"
        + "                print(f\"[save] step_{global_step} -> {save_dir}\", flush=True)\n"
        + "                gc.collect()\n"
        + "                torch.cuda.empty_cache()\n"
        + "\n"
        + "if global_step > 0 and global_step % SAVE_EVERY != 0:\n"
        + "    save_dir = f\"{CKPT_DIR}/step_{global_step}\"\n"
        + "    os.makedirs(save_dir, exist_ok=True)\n"
        + "    model.save_pretrained(save_dir)\n"
        + "    tokenizer.save_pretrained(save_dir)\n"
        + "    print(f\"[save] final step_{global_step} -> {save_dir}\")\n"
        + "\n"
        + "total_time = time.time() - t0\n"
        + "print(f\"\\n{'='*60}\")\n"
        + "print(f\"  A2-Tool MIXED COMPLETE: {global_step} steps in {total_time/3600:.2f}h\")\n"
        + "print(f\"  ckpt_dir: {CKPT_DIR}\")\n"
        + "print(f\"{'='*60}\")\n"
        + "\n"
        + "with open(f\"{CKPT_DIR}/READY_A2_TOOL_DONE\", \"w\") as f:\n"
        + "    f.write(f\"completed at {datetime.datetime.now().isoformat()}\\n\")\n"
        + "\n"
        + "print(\"[r2] Uploading to R2...\", flush=True)\n"
        + "ret = os.system(f\"rclone copy {CKPT_DIR} r2:anima-models/alm14b/a2_20260417_tool_mixed/ -v --s3-no-check-bucket --transfers 4\")\n"
        + "print(f\"[done] A2-Tool MIXED training complete + R2 backup {'OK' if ret == 0 else 'FAILED'}\")\n"

    write_file(RUNNER_OUT_PATH, py)
    log("runner emitted: " + RUNNER_OUT_PATH + " (" + to_string(len(py)) + " bytes)")

    // Also write a shell wrapper that pushes the runner to the pod and tmux's it
    let pod_host = "103.207.149.94"
    let pod_port = "16053"
    let pod_key  = "/Users/ghost/.runpod/ssh/RunPod-Key-Go"
    let shell = ""
        + "#!/usr/bin/env bash\n"
        + "set -euo pipefail\n"
        + "POD_HOST=\"" + pod_host + "\"\n"
        + "POD_PORT=\"" + pod_port + "\"\n"
        + "POD_KEY=\"" + pod_key + "\"\n"
        + "RUNNER=\"" + RUNNER_OUT_PATH + "\"\n"
        + "\n"
        + "echo '[launch] pushing runner to pod...'\n"
        + "scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -i \"$POD_KEY\" -P \"$POD_PORT\" \\\n"
        + "    \"$RUNNER\" root@$POD_HOST:/workspace/launch_a2_tool_mixed.py\n"
        + "\n"
        + "echo '[launch] starting tmux training session...'\n"
        + "ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -i \"$POD_KEY\" -p \"$POD_PORT\" root@$POD_HOST \\\n"
        + "    'tmux new-session -d -s a2_tool_mixed \"cd /workspace && python3 -u launch_a2_tool_mixed.py 2>&1 | tee /workspace/a2_tool_mixed_train.log\" && echo launched; tmux ls | head'\n"
        + "\n"
        + "echo '[launch] tmux session a2_tool_mixed started on pod'\n"
        + "echo '[launch] tail log: ssh ... tail -F /workspace/a2_tool_mixed_train.log'\n"

    write_file(SHELL_WRAPPER_PATH, shell)
    log("shell wrapper: " + SHELL_WRAPPER_PATH)

    if env("DRY_RUN") == "1" {
        log("DRY_RUN=1 — not executing")
        log("inspect runner: cat " + RUNNER_OUT_PATH)
        log("inspect wrapper: cat " + SHELL_WRAPPER_PATH)
        return
    }

    log("exec bash " + SHELL_WRAPPER_PATH)
    exec("bash " + SHELL_WRAPPER_PATH)
}

main()
