theorem alm_14b_r5_orch_invariants {
    // r4 parity — alpha:r = 2:1 preserved
    assert R5_LORA_ALPHA == R5_LORA_R * 2

    // Effective batch = 8 (r4 recipe)
    assert R5_BATCH * R5_GRAD_ACCUM == 8

    // STEPS unchanged vs r5_kbase
    assert R5_STEPS == 10000
    assert R5_SAVE_EVERY == 2000
    assert R5_EVAL_EVERY == 500
    assert R5_ROUND == 5

    // LoRA rank unchanged
    assert R5_LORA_R == 64
    assert R5_LORA_ALPHA == 128

    // PSI constants preserved
    assert PSI_ALPHA == 0.014

    // ── Orch-OR invariants (the load-bearing ones) ──

    // P1 gate: phi_target = phi_baseline × 2.0 (roadmap phi_milestones)
    assert ORCH_PHI_TARGET_MULT == 2

    // n_tubulin must evenly divide the bridge stride from hidden=4096
    // so bridge_project (mean-pool) has no leftover dims.
    //   stride = hidden / n_tubulin = 4096 / 32 = 128 (integer)
    assert 4096 / ORCH_N_TUBULIN == 128
    assert ORCH_N_TUBULIN * 128 == 4096

    // alpha schedule monotone: start < end (reversed to avoid parser
    // Gt/generic ambiguity on `<` + FloatLit)
    assert ORCH_ALPHA_END > ORCH_ALPHA_START

    // alpha bounds — positive, less than 1 (probability bias cap)
    assert ORCH_ALPHA_START > 0.0
    assert 1.0 > ORCH_ALPHA_END

    // bridge cadence positive (avoid divide-by-zero in trainer)
    assert ORCH_BRIDGE_EVERY > 0

    // n_ticks positive (mt_step needs ≥ 1)
    assert ORCH_N_TICKS > 0

    // loss weight auxiliary — CE must remain primary (weight ≪ 1)
    assert 0.5 > ORCH_LOSS_WEIGHT
    assert ORCH_LOSS_WEIGHT > 0.0
}

// ═══════════════════════════════════════════════════════════════════════════
// PYTHON DEPLOYMENT NOTE
// ═══════════════════════════════════════════════════════════════════════════
// Until hexa-lang ships native cuBLAS (AN3), the forward/backward kernel path
// routes through training/train_alm_14b.hexa on the pod. r5_orch requires the
// trainer to accept --orch-mode + the new flags below. Trainer extension is
// a separate deliverable (blocked on the same AN3 timeline — for now the
// Python trainer must be extended once, then absorbed into hexa).
//
//   python3 /workspace/train_alm_14b.hexa \
//     --base beomi/OPEN-SOLAR-KO-10.7B \
//     --corpus /workspace/anima/training/corpus_large.txt \
//     --steps 10000 --lr 5e-6 --batch 1 --grad-accum 8 --seq 1024 \
//     --warmup 500 \
//     --lora-r 64 --lora-alpha 128 --lora-dropout 0.05 \
//     --target-modules q_proj k_proj v_proj o_proj gate_proj up_proj down_proj \
//     --ckpt-dir /workspace/ckpt_alm_14b_r5_orch \
//     --save-every 2000 --eval-every 500 \
//     --model-tag alm14b_orch --round 5 \
//     --orch-mode \
//     --orch-n-tubulin 32 \
//     --orch-alpha-start 0.001 --orch-alpha-end 0.5 \
//     --orch-bridge-every 10 --orch-n-ticks 10 \
//     --orch-phi-baseline 1.4 --orch-phi-target 2.8 \
//     --orch-loss-weight 0.05 \
//     --orch-bridge-module training/alm_quantum_bridge.hexa \
//     --orch-phi-forward training/phi_quantum_forward.hexa
//
// The trainer must:
//   (a) import alm_quantum_bridge + phi_quantum_forward hexa modules
//   (b) after each ORCH_BRIDGE_EVERY ALM steps, call bridge_step(hidden_last)
//   (c) compute phi_q = phi_quantum_from_hidden(hidden_last, n_tubulin)
//   (d) aux_loss = loss_weight × max(0, phi_target − phi_q)
//   (e) total_loss = ce_loss + aux_loss, backprop as usual
//   (f) log {step, ce, phi_q, alpha, aux_loss} to tb/ckpt telemetry
//
// When hexa native CUDA lands (AN3), this file absorbs the full loop and the
// Python trainer is archived (R7: hexa 완성 시 .py 폐기).
// ═══════════════════════════════════════════════════════════════════════════
