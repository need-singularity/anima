// eval_persona_lora.hexa — TALM-P2-1 persona consistency eval harness
//
// Missing eval harness that blocked TALM-P2-1 (commit 73c94f55).
// Measures persona consistency across 6 LoRA adapters trained by
// train_persona_lora.hexa.
//
// Methodology:
//   For each adapter i, generate N responses to persona-neutral prompts.
//   Then classify each response: which persona does it sound like?
//   Consistency = fraction correctly identified as persona i.
//   done_criteria: all 6 ≥ 0.85 (from anima-train.json TALM-P2-1).
//
// Classification uses a cross-adapter perplexity method:
//   For response R generated by adapter_i:
//     For each adapter_j (j=0..5):
//       ppl_j = perplexity of R under adapter_j
//     pred = argmin_j ppl_j
//   If pred == i, the response is "consistent" with its persona.
//
// Usage:
//   hexa eval_persona_lora.hexa --ckpt-root /workspace/ckpt_persona_lora
//   hexa eval_persona_lora.hexa --ckpt-root /workspace/ckpt_persona_lora --quick

fn main() {
    let argv = args()
    let mut ckpt_root = "/workspace/ckpt_persona_lora"
    let mut base_model = "Qwen/Qwen2.5-14B-Instruct"
    let mut n_prompts = 10
    let mut max_tokens = 128
    let mut quick = false

    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--ckpt-root" {
            i = i + 1
            if i < argc { ckpt_root = argv[i] }
        }
        if argv[i] == "--base" {
            i = i + 1
            if i < argc { base_model = argv[i] }
        }
        if argv[i] == "--n-prompts" {
            i = i + 1
            if i < argc { n_prompts = to_int(argv[i]) }
        }
        if argv[i] == "--max-tokens" {
            i = i + 1
            if i < argc { max_tokens = to_int(argv[i]) }
        }
        if argv[i] == "--quick" {
            quick = true
            n_prompts = 5
        }
        i = i + 1
    }

    println("[eval_persona_lora] TALM-P2-1 persona consistency eval")
    println("  ckpt_root:  " + ckpt_root)
    println("  base:       " + base_model)
    println("  n_prompts:  " + str(n_prompts))
    println("  max_tokens: " + str(max_tokens))

    let py_script = "/tmp/_eval_persona_lora_runner.py"

    write_file(py_script,
        "#!/usr/bin/env python3\n" +
        "\"\"\"eval_persona_lora — TALM-P2-1 persona consistency evaluation\n" +
        "(auto-generated by eval_persona_lora.hexa)\n" +
        "\n" +
        "Measures persona consistency via cross-adapter perplexity classification.\n" +
        "done_criteria: 6 LoRA × eval persona consistency >= 0.85\n" +
        "\"\"\"\n" +
        "import argparse, json, math, os, sys, time\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import PeftModel\n" +
        "\n" +
        "PERSONA_TAGS = ['school', 'romance', 'fantasy', 'horror', 'daily', 'scifi']\n" +
        "\n" +
        "# Persona-neutral prompts that should elicit persona-specific responses\n" +
        "# when a persona adapter is active. Kept neutral so the adapter's\n" +
        "# training data bias drives the response style.\n" +
        "EVAL_PROMPTS = [\n" +
        "    '오늘 무슨 일이 있었어?',\n" +
        "    '이야기를 하나 해줘.',\n" +
        "    '가장 기억에 남는 경험은?',\n" +
        "    '앞으로 어떤 일이 생길까?',\n" +
        "    '너의 세계에 대해 알려줘.',\n" +
        "    '지금 기분이 어때?',\n" +
        "    '재미있는 사실 하나 말해줘.',\n" +
        "    '가장 좋아하는 것은?',\n" +
        "    '무서운 이야기 알고 있어?',\n" +
        "    '오늘 뭐 할 거야?',\n" +
        "    '최근에 읽은 책이 있어?',\n" +
        "    '미래는 어떻게 변할까?',\n" +
        "    '가장 중요한 것이 뭐야?',\n" +
        "    '주말에 뭐 했어?',\n" +
        "    '새로운 것을 발견했어.',\n" +
        "]\n" +
        "\n" +
        "def compute_perplexity(model, tokenizer, text, device):\n" +
        "    \"\"\"Compute perplexity of text under the given model.\n" +
        "    Lower perplexity = model finds this text more likely = better fit.\"\"\"\n" +
        "    encodings = tokenizer(text, return_tensors='pt', truncation=True, max_length=1024)\n" +
        "    input_ids = encodings.input_ids.to(device)\n" +
        "    if input_ids.shape[1] < 2:\n" +
        "        return float('inf')\n" +
        "    with torch.no_grad():\n" +
        "        with torch.autocast(device_type='cuda', dtype=torch.bfloat16):\n" +
        "            outputs = model(input_ids=input_ids, labels=input_ids)\n" +
        "    # outputs.loss is mean CE over all tokens\n" +
        "    return math.exp(min(outputs.loss.item(), 20.0))  # cap to avoid overflow\n" +
        "\n" +
        "def generate_response(model, tokenizer, prompt, device, max_tokens=128):\n" +
        "    \"\"\"Generate a response from the model given a prompt.\"\"\"\n" +
        "    inputs = tokenizer(prompt, return_tensors='pt').to(device)\n" +
        "    with torch.no_grad():\n" +
        "        with torch.autocast(device_type='cuda', dtype=torch.bfloat16):\n" +
        "            outputs = model.generate(\n" +
        "                **inputs,\n" +
        "                max_new_tokens=max_tokens,\n" +
        "                do_sample=True,\n" +
        "                temperature=0.7,\n" +
        "                top_p=0.9,\n" +
        "                repetition_penalty=1.1,\n" +
        "            )\n" +
        "    # Decode only the generated part (after the prompt)\n" +
        "    gen_ids = outputs[0][inputs.input_ids.shape[1]:]\n" +
        "    return tokenizer.decode(gen_ids, skip_special_tokens=True)\n" +
        "\n" +
        "def find_best_checkpoint(ckpt_dir):\n" +
        "    \"\"\"Find the latest step_N directory in a persona checkpoint dir.\"\"\"\n" +
        "    ckpt_path = Path(ckpt_dir)\n" +
        "    if not ckpt_path.exists():\n" +
        "        return None\n" +
        "    step_dirs = sorted(\n" +
        "        [d for d in ckpt_path.iterdir() if d.is_dir() and d.name.startswith('step_')],\n" +
        "        key=lambda d: int(d.name.split('_')[1]),\n" +
        "        reverse=True\n" +
        "    )\n" +
        "    return step_dirs[0] if step_dirs else None\n" +
        "\n" +
        "def main():\n" +
        "    parser = argparse.ArgumentParser(description='TALM-P2-1 persona consistency eval')\n" +
        "    parser.add_argument('--ckpt-root', required=True)\n" +
        "    parser.add_argument('--base', default='Qwen/Qwen2.5-14B-Instruct')\n" +
        "    parser.add_argument('--n-prompts', type=int, default=10)\n" +
        "    parser.add_argument('--max-tokens', type=int, default=128)\n" +
        "    parser.add_argument('--quick', action='store_true')\n" +
        "    args = parser.parse_args()\n" +
        "    \n" +
        "    if args.quick:\n" +
        "        args.n_prompts = 5\n" +
        "    \n" +
        "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n" +
        "    prompts = EVAL_PROMPTS[:args.n_prompts]\n" +
        "    \n" +
        "    print(f'[eval] device={device}', flush=True)\n" +
        "    print(f'[eval] using {len(prompts)} prompts', flush=True)\n" +
        "    \n" +
        "    # Find all persona checkpoints\n" +
        "    ckpt_paths = {}\n" +
        "    for tag in PERSONA_TAGS:\n" +
        "        best = find_best_checkpoint(os.path.join(args.ckpt_root, tag))\n" +
        "        if best:\n" +
        "            ckpt_paths[tag] = best\n" +
        "            print(f'[eval] {tag}: {best}', flush=True)\n" +
        "        else:\n" +
        "            print(f'[eval] {tag}: NO CHECKPOINT FOUND', flush=True)\n" +
        "    \n" +
        "    if len(ckpt_paths) < 2:\n" +
        "        print('[ERROR] need at least 2 persona checkpoints for cross-eval', flush=True)\n" +
        "        sys.exit(1)\n" +
        "    \n" +
        "    # Load tokenizer\n" +
        "    print('[eval] loading tokenizer...', flush=True)\n" +
        "    tokenizer = AutoTokenizer.from_pretrained(args.base, trust_remote_code=True)\n" +
        "    if tokenizer.pad_token is None:\n" +
        "        tokenizer.pad_token = tokenizer.eos_token\n" +
        "    \n" +
        "    # ── Phase 1: Generate responses from each persona adapter ────\n" +
        "    print('\\n[phase 1] generating persona responses...', flush=True)\n" +
        "    responses = {}  # {tag: [response_text, ...]}\n" +
        "    \n" +
        "    for tag, ckpt_path in ckpt_paths.items():\n" +
        "        print(f'[gen:{tag}] loading base + adapter...', flush=True)\n" +
        "        base_model = AutoModelForCausalLM.from_pretrained(\n" +
        "            args.base, torch_dtype=torch.bfloat16,\n" +
        "            device_map='auto', trust_remote_code=True\n" +
        "        )\n" +
        "        model = PeftModel.from_pretrained(base_model, str(ckpt_path))\n" +
        "        model.eval()\n" +
        "        \n" +
        "        tag_responses = []\n" +
        "        for pi, prompt in enumerate(prompts):\n" +
        "            resp = generate_response(model, tokenizer, prompt, device, args.max_tokens)\n" +
        "            tag_responses.append(resp)\n" +
        "            if pi < 3:  # Show first 3 samples\n" +
        "                preview = resp[:80].replace('\\n', ' ')\n" +
        "                print(f'  [{tag} p{pi}] {preview}...', flush=True)\n" +
        "        responses[tag] = tag_responses\n" +
        "        \n" +
        "        del model, base_model\n" +
        "        torch.cuda.empty_cache()\n" +
        "    \n" +
        "    # ── Phase 2: Cross-adapter perplexity classification ─────────\n" +
        "    print('\\n[phase 2] cross-adapter perplexity classification...', flush=True)\n" +
        "    \n" +
        "    # For each response, compute perplexity under each adapter\n" +
        "    confusion = {}  # {true_tag: {pred_tag: count}}\n" +
        "    for tag in ckpt_paths:\n" +
        "        confusion[tag] = {t: 0 for t in ckpt_paths}\n" +
        "    \n" +
        "    eval_tags = list(ckpt_paths.keys())\n" +
        "    \n" +
        "    for eval_tag, eval_ckpt in ckpt_paths.items():\n" +
        "        print(f'[ppl:{eval_tag}] loading adapter for ppl scoring...', flush=True)\n" +
        "        base_model = AutoModelForCausalLM.from_pretrained(\n" +
        "            args.base, torch_dtype=torch.bfloat16,\n" +
        "            device_map='auto', trust_remote_code=True\n" +
        "        )\n" +
        "        model = PeftModel.from_pretrained(base_model, str(eval_ckpt))\n" +
        "        model.eval()\n" +
        "        \n" +
        "        # Score all responses from all personas under this adapter\n" +
        "        for src_tag in responses:\n" +
        "            for resp in responses[src_tag]:\n" +
        "                if len(resp.strip()) < 5:\n" +
        "                    continue\n" +
        "                ppl = compute_perplexity(model, tokenizer, resp, device)\n" +
        "                # Store for later argmin\n" +
        "                key = (src_tag, responses[src_tag].index(resp))\n" +
        "                if not hasattr(main, '_ppl_cache'):\n" +
        "                    main._ppl_cache = {}\n" +
        "                if key not in main._ppl_cache:\n" +
        "                    main._ppl_cache[key] = {}\n" +
        "                main._ppl_cache[key][eval_tag] = ppl\n" +
        "        \n" +
        "        del model, base_model\n" +
        "        torch.cuda.empty_cache()\n" +
        "    \n" +
        "    # ── Phase 3: Classify and compute consistency ────────────────\n" +
        "    print('\\n[phase 3] computing consistency...', flush=True)\n" +
        "    \n" +
        "    n_correct = 0\n" +
        "    n_total = 0\n" +
        "    per_persona_correct = {t: 0 for t in eval_tags}\n" +
        "    per_persona_total = {t: 0 for t in eval_tags}\n" +
        "    \n" +
        "    for (src_tag, resp_idx), ppl_dict in main._ppl_cache.items():\n" +
        "        if len(ppl_dict) < len(eval_tags):\n" +
        "            continue  # incomplete scoring\n" +
        "        # argmin perplexity = most likely adapter\n" +
        "        pred_tag = min(ppl_dict, key=lambda t: ppl_dict[t])\n" +
        "        confusion[src_tag][pred_tag] += 1\n" +
        "        per_persona_total[src_tag] += 1\n" +
        "        n_total += 1\n" +
        "        if pred_tag == src_tag:\n" +
        "            n_correct += 1\n" +
        "            per_persona_correct[src_tag] += 1\n" +
        "    \n" +
        "    # ── Results ──────────────────────────────────────────────────\n" +
        "    sep = '=' * 60\n" +
        "    print(f'\\n{sep}', flush=True)\n" +
        "    print('[result] TALM-P2-1 persona consistency evaluation', flush=True)\n" +
        "    print(f'{sep}', flush=True)\n" +
        "    \n" +
        "    overall_acc = n_correct / max(n_total, 1)\n" +
        "    print(f'\\nOverall consistency: {n_correct}/{n_total} = {overall_acc:.4f}', flush=True)\n" +
        "    print(f'Threshold: 0.85', flush=True)\n" +
        "    print(f'Verdict: {\"PASS\" if overall_acc >= 0.85 else \"FAIL\"}', flush=True)\n" +
        "    \n" +
        "    print(f'\\nPer-persona breakdown:', flush=True)\n" +
        "    all_pass = True\n" +
        "    for tag in eval_tags:\n" +
        "        total = per_persona_total[tag]\n" +
        "        correct = per_persona_correct[tag]\n" +
        "        acc = correct / max(total, 1)\n" +
        "        status = 'PASS' if acc >= 0.85 else 'FAIL'\n" +
        "        if acc < 0.85:\n" +
        "            all_pass = False\n" +
        "        print(f'  {tag:10s}  {correct}/{total} = {acc:.4f}  {status}', flush=True)\n" +
        "    \n" +
        "    print(f'\\nConfusion matrix:', flush=True)\n" +
        "    header = '          ' + '  '.join(f'{t:>8s}' for t in eval_tags)\n" +
        "    print(header, flush=True)\n" +
        "    for src in eval_tags:\n" +
        "        row = f'{src:10s}'\n" +
        "        for dst in eval_tags:\n" +
        "            row += f'  {confusion[src][dst]:>8d}'\n" +
        "        print(row, flush=True)\n" +
        "    \n" +
        "    done = all_pass and overall_acc >= 0.85\n" +
        "    print(f'\\n{sep}', flush=True)\n" +
        "    print(f'done_criteria (6 LoRA × consistency >= 0.85): {\"MET\" if done else \"NOT MET\"}', flush=True)\n" +
        "    print(f'{sep}', flush=True)\n" +
        "    \n" +
        "    # Write eval result JSON\n" +
        "    result_path = Path(args.ckpt_root) / 'eval_consistency.json'\n" +
        "    result = {\n" +
        "        'task': 'TALM-P2-1',\n" +
        "        'overall_accuracy': overall_acc,\n" +
        "        'threshold': 0.85,\n" +
        "        'done_criteria_met': done,\n" +
        "        'per_persona': {\n" +
        "            tag: {\n" +
        "                'correct': per_persona_correct[tag],\n" +
        "                'total': per_persona_total[tag],\n" +
        "                'accuracy': per_persona_correct[tag] / max(per_persona_total[tag], 1)\n" +
        "            }\n" +
        "            for tag in eval_tags\n" +
        "        },\n" +
        "        'confusion': {src: {dst: confusion[src][dst] for dst in eval_tags} for src in eval_tags},\n" +
        "        'n_prompts': len(prompts),\n" +
        "    }\n" +
        "    with open(result_path, 'w') as f:\n" +
        "        json.dump(result, f, indent=2)\n" +
        "    print(f'[eval] wrote {result_path}', flush=True)\n" +
        "\n" +
        "if __name__ == '__main__':\n" +
        "    main()\n"
    )

    // Build passthrough args
    let mut passthrough = "--ckpt-root " + ckpt_root
    passthrough = passthrough + " --base " + base_model
    passthrough = passthrough + " --n-prompts " + str(n_prompts)
    passthrough = passthrough + " --max-tokens " + str(max_tokens)
    if quick {
        passthrough = passthrough + " --quick"
    }

    println("[eval_persona_lora] launching Python eval")
    exec("python3 " + py_script + " " + passthrough)
}

main()
