    print_vec("  mode_vector", mv)

    println("")
    println("--- (3) string_step smoke (shapes aligned) ---")
    let mut psi_map = []
    psi_map = psi_map.push(0.55)
    psi_map = psi_map.push(0.55)
    let mut target = []
    target = target.push(0.5)
    target = target.push(0.5)
    let mut w_compact = []
    let mut i = 0
    while i < CY_DIM {
        w_compact = w_compact.push(0.0)
        i = i + 1
    }
    let bundle = string_step(psi_map, w_compact, target)
