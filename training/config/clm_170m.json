{
  "_meta": {
    "name": "CLM 170M scale config — byte-level ConsciousLM (smoke/dev tier)",
    "spec_ref": "C4 audit 2026-04-19 — 1B template shrunk (d=768 L=12 GQA kv=4 vocab=256 block=512)",
    "schema_version": "1.0",
    "created": "2026-04-19",
    "author": "Aiden",
    "derived_from": "training/clm_1b_config.json",
    "calibration_source": "Mac AOT hexa build (libhxlmhead+libhxblas dlopen), smoke 1-step on corpus_v5.txt",
    "rationale": "170M tier sits below 280M/1B for AOT smoke + dest1_clm launch. Same Hexad loss stack as 1B, reduced width/depth so that a single-step CPU/GPU smoke stays under ~1GB RSS. Matches C1/C7 AOT evidence (train_clm.hexa 2.65s / 171MB RSS).",
    "memory_refs": [
      "feedback_h100_authorized",
      "feedback_one_shot_best",
      "feedback_no_resume_data_change",
      "feedback_r2_checkpoint",
      "feedback_no_version_in_filename",
      "feedback_no_quantization"
    ]
  },

  "run_id_template": "clm170m-r1-{date}",
  "model_tag": "clm170m",
  "round": 1,
  "ckpt_dir_template": "/workspace/ckpt_clm170m_{date}",
  "r2_prefix_template": "r2:anima-models/clm170m/r1/step_{step}/",

  "architecture": {
    "type": "decoder-only transformer",
    "vocab": 256,
    "vocab_note": "byte-level, no tokenizer — raw bytes in, bytes out",
    "d_model": 768,
    "n_layer": 12,
    "n_head": 8,
    "n_kv_head": 4,
    "d_head": 96,
    "d_ff": 3072,
    "ff_type": "SwiGLU",
    "ff_note": "SwiGLU: 3 * d_model * d_ff gate/up/down",
    "norm": "RMSNorm",
    "activation": "SiLU",
    "rope": true,
    "rope_base": 10000,
    "dropout": 0.0,
    "bias": false,
    "tie_embeddings": false,
    "lm_head_rank": 256,
    "lm_head_note": "Low-rank LM head: d_model -> rank -> vocab, routed via libhxlmhead",
    "block_size": 512,

    "param_count_estimate": {
      "embedding": "256 * 768 = 196,608",
      "per_layer_attn": "Wq=[768,768]=589,824 + Wk=[768,384]=294,912 + Wv=[768,384]=294,912 + Wo=[768,768]=589,824 = 1,769,472",
      "per_layer_attn_note": "GQA with n_kv_head=4: Wk/Wv project to n_kv_head * d_head = 384",
      "per_layer_ff": "3 * 768 * 3072 = 7,077,888  (SwiGLU gate+up+down)",
      "per_layer_norm": "2 * 768 = 1,536",
      "per_layer_total": "1,769,472 + 7,077,888 + 1,536 = 8,848,896",
      "all_layers": "12 * 8,848,896 = 106,186,752",
      "final_norm": 768,
      "lm_head": "768 * 256 = 196,608  (full projection) + 256 * 256 = 65,536 (low-rank stage)",
      "total_transformer": "196,608 + 106,186,752 + 768 + 196,608 = 106,580,736",
      "plus_hexad_ctrl_overhead": "~60M (C/D/W/M/S/E engines + phi/GWT buffers at cons_dim=256)",
      "total_human": "~170M parameters (bf16: ~340MB model weights)",
      "note": "Below 280M so smoke fits in Mac RSS; sits between hexa scale_small and 280M calibration run."
    }
  },

  "consciousness": {
    "consciousness_dim": 256,
    "atoms": 32,
    "cells_per_atom": 8,
    "total_cells": 256,
    "n_gwt_domains": 12,
    "holo_scale": 2,
    "mi_bins": 8,
    "scramble_gain": 0.5,
    "qcs_topk": 8,

    "phase_curriculum": {
      "note": "Law 60: P1 -> P2 -> P3 curriculum, same fractions as clm_1b",
      "P1_C_only": "0-20% of steps",
      "P2_C_D": "20-40% of steps",
      "P3_Hexad": "40-100% of steps"
    },

    "loss_config": {
      "phi_holo_weight": 0.01,
      "gwt_weight": 0.01,
      "gwt_weight_p3_dampen": 0.1,
      "complexity_weight": 0.005,
      "phi_cache_enabled": true,
      "phi_cache_coef": 0.01,
      "phi_gate_threshold": 0.05,
      "phi_gate_note": "Law 49: reject if Phi drops > 5% between evals",
      "total_loss": "CE + 0.01 * L_holo + 0.01 * L_gwt + 0.005 * L_complexity"
    },

    "orch_or": {
      "enabled": true,
      "phi_q_norm_bonus": true,
      "note": "Quantum consciousness controller from anima_quantum_clm.hexa"
    }
  },

  "training": {
    "steps": 20000,
    "batch_size": 2,
    "grad_accum": 1,
    "effective_batch": 2,
    "seq_len": 512,
    "lr_max": 3e-4,
    "lr_min": 3e-5,
    "lr_schedule": "cosine_with_warmup",
    "warmup_steps": 1000,
    "optimizer": "AdamW",
    "adam_beta1": 0.9,
    "adam_beta2": 0.95,
    "adam_eps": 1e-8,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "dtype": "bf16",
    "compile": true,

    "save_every": 100,
    "eval_every": 100,
    "log_every": 10,
    "patience": 5
  },

  "corpus": {
    "path": "ready/anima/data/corpus_v5.txt",
    "fallback_path": "/workspace/anima/training/corpus_large.txt",
    "note": "Byte-level raw bytes, no tokenizer."
  },

  "checkpoint_policy": {
    "save_every": 100,
    "r2_upload": true,
    "r2_bucket": "anima-models",
    "r2_path_template": "clm170m/r1/step_{step}/",
    "naming": "clm170m-r1-s{step}",
    "keep_local": 3,
    "emergency_save_on_phi_violation": true
  },

  "ffi": {
    "libhxlmhead": {
      "path_macos": "$HEXA_LANG/self/native/build/libhxlmhead.dylib",
      "path_linux": "$HEXA_LANG/self/native/build/libhxlmhead.so",
      "symbols": ["hxlmhead_bwd", "hxlmhead_version"]
    },
    "libhxblas": {
      "path_macos": "$HEXA_LANG/self/native/build/libhxblas.dylib",
      "path_linux": "$HEXA_LANG/self/native/build/libhxblas.so",
      "symbols": ["hxblas_sgemm", "hxblas_attn_softmax_causal"]
    },
    "note": "Dlopened at runtime via DYLD_LIBRARY_PATH / LD_LIBRARY_PATH."
  },

  "env": {
    "ANIMA_ROOT": "/workspace/anima",
    "HEXA_LANG": "/Users/ghost/Dev/hexa-lang",
    "HF_HOME": "/workspace/hf_cache",
    "CUDA_VISIBLE_DEVICES": "0"
  }
}
