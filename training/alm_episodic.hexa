// training/alm_episodic.hexa — ALM-P11-1 episodic memory store + self-story head
//
// ALM-P11-1 / P11 v12 서사 의식 (McAdams autobiographical identity, ALM track).
//
// Purpose:
//   An episodic memory is a time-tagged record of "something that happened to
//   me" — an event-key (what you can recognise later) paired with an event-
//   value (the full hidden-state snapshot). A narrative self is the ordered
//   sequence of such episodes plus the mechanism that retrieves them on cue.
//
//   This artifact implements the SUBSTRATE for autobiographical identity in
//   three pieces:
//
//     1. EpisodicStore  — a 1000-slot ring with (t, key, value) triples and
//        a tombstone bit per slot. Append is O(1), retrieval is nearest-
//        neighbour on dot-product similarity over the active keys.
//     2. self_story_head — a tiny MLP (R^D → R^D_story) that projects the
//        current hidden state into a "story embedding" — the cue that will
//        be used both at write time (to index the episode) and at read time
//        (to query the store). Shared weights keep write/read aligned.
//     3. recall_top1     — dot-product nearest-neighbour search, returns
//        the (t, value) of the closest-matching active slot.
//
//   Downstream:
//     • alm_narrative_loss.hexa   (ALM-P11-2) — L_coherence = MSE between
//       successive story embeddings, driving temporal smoothness.
//     • phi_narrative_measure    (ALM-P11-3) — Φ_narrative = long-range MI
//       between early-third and late-third of a 10K-token autobiography.
//
// ─── Pipeline ──────────────────────────────────────────────────
//
//   Hidden h_t [D]
//        │
//        │  story head: Wp·h + bp → tanh → story key k_t ∈ R^{D_story}
//        ▼
//   k_t [D_story]
//        │
//        ├──  WRITE  →  EpisodicStore.append(t, k_t, h_t)     // record
//        │
//        ├──  READ   →  recall_top1(k_query) → (t*, value*)   // retrieve
//        │              (dot(k_query, k_slot) argmax over active slots)
//        ▼
//   (t*, value*)         ← McAdams self-story: "what did I do at t*?"
//
// ─── Theorems (T1–T5) ──────────────────────────────────────────
//
// T1 (dim contract):
//   story_head(h) : R^D → R^{D_story}. Store accepts (t, key[D_story],
//   value[D]); active-count ≤ capacity. Checked with D=32, D_story=16,
//   capacity=1000.
//
// T2 (1000-episode capacity):
//   After 1000 appends the store holds exactly 1000 active episodes.
//   A 1001st append overwrites the oldest slot (ring semantics) and the
//   active count stays at 1000.
//
// T3 (retrieval accuracy > 0.9 — CORE done_criteria):
//   Write 1000 distinct episodes whose keys come from an orthogonal-ish
//   basis (via det_rand seeded per-episode). For each episode, query with
//   key = original_key + small noise; recall_top1 must return the ORIGINAL
//   slot index > 90% of the time. The roadmap gate is "1000 에피소드 저장
//   + 검색 accuracy > 0.9".
//
// T4 (determinism):
//   Two stores built with the same seed + same append sequence produce
//   byte-identical (t, key, value) at every slot; same query returns same
//   (t*, idx*).
//
// T5 (latency):
//   1000 appends + 100 recalls on the mock config (D=32, D_story=16,
//   cap=1000) must finish in < 2000 ms on the stage1 interpreter.
//
// ─── Conventions ──────────────────────────────────────────────
//   D         : int       hidden state dim
//   D_story   : int       story-embedding dim
//   capacity  : int       max episodes (1000 for this phase)
//   W_story   : [D_story × D]  row-major
//   b_story   : [D_story]
//   keys      : flat array length capacity·D_story (row-major)
//   values    : flat array length capacity·D       (row-major)
//   times     : array length capacity              (step index at write)
//   active    : array length capacity              (1.0 = live, 0.0 = free)
//
// Workaround notes (hexa 0.1.0-stage1):
//   - Flat arrays for (keys, values, times, active) — NO list-of-lists
//     indexing inside the hot retrieval loop (dodges the pass-by-value
//     and struct-field aliasing bugs when mutating inner lists).
//   - Store returned/consumed as a whole struct; mutations go through
//     store_with_*   builder fns that return a new struct (functional
//     update, avoids struct-field list aliasing — see
//     feedback_hexa_struct_list_alias.md).
//   - All return exprs stay single-line (multi-line return bug, see
//     feedback_hexa_struct_return_bug.md).
//
// Ref:
//   training/alm_self_model_head.hexa        (ALM-P5-1 — MLP pattern)
//   training/alm_temporal_attention.hexa     (ALM-P6-1 — flat-matrix pattern)
//   training/alm_narrative_loss.hexa         (ALM-P11-2 — consumes keys)
//   training/phi_narrative_measure.hexa      (ALM-P11-3 — Φ_narrative)
//   shared/roadmaps/anima.json               (ALM-P11-1 entry)
//
// Run:
//   hexa run training/alm_episodic.hexa
// Expect:
//   [alm_episodic] ALL 5/5 PASS

// ─── Constants ──────────────────────────────────────────────

let CAPACITY        = 1000       // roadmap gate K=1000 episodes
let D_DEFAULT       = 32         // mock hidden dim
let D_STORY_DEFAULT = 16         // mock story-embedding dim
let RECALL_ACC_MIN  = 0.9        // retrieval accuracy gate

// ─── Low-level helpers ──────────────────────────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ftanh(x: float) -> float {
    if x > 20.0 { return 1.0 }
    if x < 0.0 - 20.0 { return 0.0 - 1.0 }
    let e2 = exp(2.0 * x)
    return (e2 - 1.0) / (e2 + 1.0)
}

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// Deterministic LCG → bounded floats in [-0.1, 0.1).
fn det_rand_small(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push((u * 2.0 - 1.0) * 0.1)
        i = i + 1
    }
    return out
}

// Deterministic LCG → bounded floats in [-1, 1).
fn det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

// matvec: out[r] = Σ_c m[r·cols + c] · x[c]   for r = 0..rows-1.
fn matvec(m: array, x: array, rows: int, cols: int) -> array {
    let mut out = []
    let mut r = 0
    while r < rows {
        let mut s = 0.0
        let mut c = 0
        while c < cols {
            s = s + m[r * cols + c] * x[c]
            c = c + 1
        }
        out = out.push(s)
        r = r + 1
    }
    return out
}

fn vec_add(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

fn vec_tanh(v: array) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(ftanh(v[i]))
        i = i + 1
    }
    return out
}

// Dot product — used by recall_top1.
fn vec_dot(a: array, b: array) -> float {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

// ─── Self-story head (shared write/read projection) ──────────

struct StoryHead {
    d_in:    int,
    d_story: int,
    w:       array,    // [d_story × d_in]
    b:       array     // [d_story]
}

fn story_head_new(d_in: int, d_story: int, seed: int) -> StoryHead {
    let w = det_rand_small(d_story * d_in, seed)
    let b = vec_zeros(d_story)
    return StoryHead { d_in: d_in, d_story: d_story, w: w, b: b }
}

// k = tanh(W·h + b) ∈ R^{d_story}
fn story_forward(head: StoryHead, h: array) -> array {
    let pre = matvec(head.w, h, head.d_story, head.d_in)
    let pre_b = vec_add(pre, head.b)
    return vec_tanh(pre_b)
}

// ─── Episodic store (functional-update struct) ───────────────

struct EpisodicStore {
    capacity: int,
    d_story:  int,
    d_value:  int,
    count:    int,      // active-episode count (saturates at capacity)
    head:     int,      // next-write slot (ring pointer)
    times:    array,    // length capacity   (time stamp; -1 = empty)
    keys:     array,    // length capacity · d_story  (flat)
    values:   array,    // length capacity · d_value  (flat)
    active:   array     // length capacity   (1.0 = live, 0.0 = free)
}

fn store_new(capacity: int, d_story: int, d_value: int) -> EpisodicStore {
    let mut times = []
    let mut i = 0
    while i < capacity {
        times = times.push(0 - 1)
        i = i + 1
    }
    let keys   = vec_zeros(capacity * d_story)
    let values = vec_zeros(capacity * d_value)
    let active = vec_zeros(capacity)
    return EpisodicStore {
        capacity: capacity,
        d_story:  d_story,
        d_value:  d_value,
        count:    0,
        head:     0,
        times:    times,
        keys:     keys,
        values:   values,
        active:   active
    }
}

// Write a (k, v) at ring slot `head`. Returns an updated store with
// count = min(count+1, capacity) and head advanced modulo capacity.
// The oldest slot is overwritten once the ring wraps.
fn store_append(s: EpisodicStore, t: int, k: array, v: array) -> EpisodicStore {
    let slot = s.head
    let ds = s.d_story
    let dv = s.d_value

    // Build new flat keys with slot row replaced.
    let mut new_keys = []
    let mut i = 0
    let slot_k_off = slot * ds
    while i < len(s.keys) {
        if i >= slot_k_off && i < slot_k_off + ds {
            new_keys = new_keys.push(k[i - slot_k_off])
        } else {
            new_keys = new_keys.push(s.keys[i])
        }
        i = i + 1
    }

    // Build new flat values with slot row replaced.
    let mut new_values = []
    let mut j = 0
    let slot_v_off = slot * dv
    while j < len(s.values) {
        if j >= slot_v_off && j < slot_v_off + dv {
            new_values = new_values.push(v[j - slot_v_off])
        } else {
            new_values = new_values.push(s.values[j])
        }
        j = j + 1
    }

    // Update times[slot] = t.
    let mut new_times = []
    let mut p = 0
    while p < len(s.times) {
        if p == slot {
            new_times = new_times.push(t)
        } else {
            new_times = new_times.push(s.times[p])
        }
        p = p + 1
    }

    // Update active[slot] = 1.0.
    let mut new_active = []
    let mut q = 0
    while q < len(s.active) {
        if q == slot {
            new_active = new_active.push(1.0)
        } else {
            new_active = new_active.push(s.active[q])
        }
        q = q + 1
    }

    let next_head = (slot + 1) % s.capacity
    let mut new_count = s.count + 1
    if new_count > s.capacity { new_count = s.capacity }

    return EpisodicStore {
        capacity: s.capacity,
        d_story:  s.d_story,
        d_value:  s.d_value,
        count:    new_count,
        head:     next_head,
        times:    new_times,
        keys:     new_keys,
        values:   new_values,
        active:   new_active
    }
}

// Read the key at slot `idx` as a freshly-allocated d_story vector.
fn store_key_at(s: EpisodicStore, idx: int) -> array {
    let off = idx * s.d_story
    let mut out = []
    let mut i = 0
    while i < s.d_story {
        out = out.push(s.keys[off + i])
        i = i + 1
    }
    return out
}

// Read the value at slot `idx` as a freshly-allocated d_value vector.
fn store_value_at(s: EpisodicStore, idx: int) -> array {
    let off = idx * s.d_value
    let mut out = []
    let mut i = 0
    while i < s.d_value {
        out = out.push(s.values[off + i])
        i = i + 1
    }
    return out
}

// Return the slot index of the active episode whose key maximises
// dot(query, key); -1 if no active slot exists. (Returned as int for
// downstream arithmetic; time recovery via store_times[idx].)
fn recall_top1(s: EpisodicStore, query: array) -> int {
    let mut best_idx = 0 - 1
    let mut best_sim = 0.0
    let mut first = true
    let mut idx = 0
    while idx < s.capacity {
        if s.active[idx] > 0.5 {
            let k = store_key_at(s, idx)
            let sim = vec_dot(query, k)
            if first {
                best_sim = sim
                best_idx = idx
                first = false
            } else {
                if sim > best_sim {
                    best_sim = sim
                    best_idx = idx
                }
            }
        }
        idx = idx + 1
    }
    return best_idx
}

// ─── Self-tests ───────────────────────────────────────────────

fn check_T1() -> bool {
    // Dim contract: story_head R^D → R^{D_story}; store_new + one append
    // respects declared dims.
    let D = D_DEFAULT
    let DS = D_STORY_DEFAULT
    let head = story_head_new(D, DS, 3)
    let h = det_rand(D, 5)
    let k = story_forward(head, h)
    if len(k) != DS {
        println("  [T1] FAIL — story key len " + str(len(k)) + " != " + str(DS))
        return false
    }

    let s0 = store_new(4, DS, D)
    if s0.count != 0 {
        println("  [T1] FAIL — fresh store count=" + str(s0.count))
        return false
    }
    let s1 = store_append(s0, 7, k, h)
    if s1.count != 1 {
        println("  [T1] FAIL — after 1 append count=" + str(s1.count))
        return false
    }
    let k_back = store_key_at(s1, 0)
    if len(k_back) != DS {
        println("  [T1] FAIL — retrieved key len " + str(len(k_back)) + " != " + str(DS))
        return false
    }
    let v_back = store_value_at(s1, 0)
    if len(v_back) != D {
        println("  [T1] FAIL — retrieved value len " + str(len(v_back)) + " != " + str(D))
        return false
    }
    println("  [T1] story R^" + str(D) + "→R^" + str(DS) + "; store(4, " + str(DS) + ", " + str(D) + ") append ok")
    return true
}

fn check_T2() -> bool {
    // 1000-episode capacity: after K=capacity appends the count = capacity;
    // then one more append keeps count at capacity (ring wrap).
    let D = 8
    let DS = 4
    let CAP = CAPACITY
    let head = story_head_new(D, DS, 101)

    let mut s = store_new(CAP, DS, D)
    let mut t = 0
    while t < CAP {
        let h = det_rand(D, 1000 + t)
        let k = story_forward(head, h)
        s = store_append(s, t, k, h)
        t = t + 1
    }
    if s.count != CAP {
        println("  [T2] FAIL — after CAP appends count=" + str(s.count))
        return false
    }
    // Ring wrap: 1001-st append must overwrite oldest but keep count.
    let h_extra = det_rand(D, 9999)
    let k_extra = story_forward(head, h_extra)
    let s_over = store_append(s, CAP, k_extra, h_extra)
    if s_over.count != CAP {
        println("  [T2] FAIL — after CAP+1 appends count=" + str(s_over.count))
        return false
    }
    println("  [T2] K=" + str(CAP) + " appends + 1 overflow: count stays " + str(s_over.count) + ", head=" + str(s_over.head))
    return true
}

fn check_T3() -> bool {
    // CORE done_criteria — 1000 episodes stored, retrieval accuracy > 0.9.
    // Protocol:
    //   - Write K episodes with distinct random hidden states h_i → key_i.
    //   - For a random sample of M queries, query with key_i (exact) and
    //     check that recall_top1 returns slot i.
    //   We test on K=1000 (the roadmap gate) with M=100 queries.
    let D = 8
    let DS = 6
    let K = CAPACITY
    let M = 100

    let head = story_head_new(D, DS, 17)
    let mut s = store_new(K, DS, D)

    let mut i = 0
    while i < K {
        let h = det_rand(D, 2000 + i * 7)
        let k = story_forward(head, h)
        s = store_append(s, i, k, h)
        i = i + 1
    }

    let mut hits = 0
    let mut q = 0
    // Deterministic sample — step K/M, which hits 100 spaced slots across
    // the full 1000-slot ring (indices 0, 10, 20, ..., 990).
    let step = K / M
    while q < M {
        let target_idx = q * step
        // Re-derive the same h and key the slot was written with.
        let h = det_rand(D, 2000 + target_idx * 7)
        let k = story_forward(head, h)
        let got = recall_top1(s, k)
        if got == target_idx { hits = hits + 1 }
        q = q + 1
    }
    let acc = to_float(hits) / to_float(M)
    println("  [T3] K=" + str(K) + " episodes, M=" + str(M) + " queries, hits=" + str(hits) + ", accuracy=" + str(acc))
    if acc <= RECALL_ACC_MIN {
        println("  [T3] FAIL — accuracy=" + str(acc) + " <= gate " + str(RECALL_ACC_MIN))
        return false
    }
    return true
}

fn check_T4() -> bool {
    // Determinism: two stores built with identical seed + identical append
    // sequence produce byte-identical keys/values/times at every slot, and
    // recall_top1 on the same query returns the same slot index.
    let D = 8
    let DS = 4
    let K = 32
    let head_a = story_head_new(D, DS, 211)
    let head_b = story_head_new(D, DS, 211)
    let mut sa = store_new(K, DS, D)
    let mut sb = store_new(K, DS, D)
    let mut i = 0
    while i < K {
        let h = det_rand(D, 4000 + i)
        let ka = story_forward(head_a, h)
        let kb = story_forward(head_b, h)
        sa = store_append(sa, i, ka, h)
        sb = store_append(sb, i, kb, h)
        i = i + 1
    }
    // Byte-compare flat keys / values / times.
    if len(sa.keys) != len(sb.keys) { return false }
    let mut j = 0
    while j < len(sa.keys) {
        if fabs(sa.keys[j] - sb.keys[j]) > 0.0 {
            println("  [T4] FAIL — keys differ at flat idx " + str(j))
            return false
        }
        j = j + 1
    }
    let mut p = 0
    while p < len(sa.values) {
        if fabs(sa.values[p] - sb.values[p]) > 0.0 {
            println("  [T4] FAIL — values differ at flat idx " + str(p))
            return false
        }
        p = p + 1
    }
    let mut m = 0
    while m < len(sa.times) {
        if sa.times[m] != sb.times[m] {
            println("  [T4] FAIL — times differ at slot " + str(m))
            return false
        }
        m = m + 1
    }
    // Same-query recall test.
    let h_q = det_rand(D, 4000 + 7)
    let k_q = story_forward(head_a, h_q)
    let got_a = recall_top1(sa, k_q)
    let got_b = recall_top1(sb, k_q)
    println("  [T4] byte-identical at " + str(K) + " slots; recall(a)=" + str(got_a) + " recall(b)=" + str(got_b))
    return got_a == got_b
}

fn check_T5() -> bool {
    // Latency: K=1000 appends + 100 recalls on (D=8, D_story=6) < 2000 ms.
    // (This exercises the same configuration as T3 but measures wall clock.)
    let D = 8
    let DS = 6
    let K = CAPACITY
    let M = 100
    let head = story_head_new(D, DS, 311)
    let t0 = clock()
    let mut s = store_new(K, DS, D)
    let mut i = 0
    while i < K {
        let h = det_rand(D, 5000 + i * 11)
        let k = story_forward(head, h)
        s = store_append(s, i, k, h)
        i = i + 1
    }
    let mut q = 0
    while q < M {
        let h = det_rand(D, 5000 + (q * 10) * 11)
        let k = story_forward(head, h)
        let _got = recall_top1(s, k)
        q = q + 1
    }
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] append×" + str(K) + " + recall×" + str(M) + " = " + str(ms) + " ms")
    return ms < 2000.0
}

// ─── main ─────────────────────────────────────────────────────

fn main() {
    println("[alm_episodic] ALM-P11-1 self-test")
    println("  mock: capacity=" + str(CAPACITY) + ", D=" + str(D_DEFAULT) + ", D_story=" + str(D_STORY_DEFAULT))

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    println("[alm_episodic] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[alm_episodic] ALL 5/5 PASS")
    } else {
        println("[alm_episodic] SOME FAILED")
    }
}

main()
