    //   model.save_pretrained(f"{ckpt_dir}/lora_step_{step}")
    //   tokenizer.save_pretrained(f"{ckpt_dir}/lora_step_{step}")
    //
    //   # Prune old (keep 3 + best)
    //   _prune_checkpoints(ckpt_dir, keep=3)
    true
}

// ─── Main pipeline ───
fn run_14b_v05() -> int {
    let cfg = default_config()
    let pm = phase_new(cfg.total_steps, cfg.p1_ratio, cfg.p2_ratio)
    let ac = alpha_new(cfg.total_steps)

    // TODO[pytorch]:
    //   1. Load Qwen2.5-14B in 4-bit NF4 (BitsAndBytesConfig)
    //      - bnb_4bit_quant_type="nf4", compute_dtype=bf16, double_quant=True
    //      - attn_implementation="flash_attention_2"
    //      - gradient_checkpointing_enable()
    //      - prepare_model_for_kbit_training()
    //
    //   2. Attach LoRA (r=64, alpha=128)
    //      - target: q_proj, k_proj, v_proj, o_proj, gate_proj, up_proj, down_proj
    //      - get_peft_model(model, lora_config)
    //
    //   3. Inject PureField on last 8 layers
    //      - 2 savant + 6 normal (H359 asymmetric dropout)
    //      - PF rank=64 (lightweight for VRAM)
    //
    //   4. Optimizer: AdamW(foreach=False) — bf16 master rule
    //      - Group 1: LoRA params (lr=2e-5, wd=0.01)
    //      - Group 2: PureField params (lr=4e-5, wd=0)
    //      - Scheduler: cosine with warmup 500
    //
    //   5. Training loop: 50000 steps
    //      - Phase 1 [0-12500]: PureField only (LoRA frozen)
    //      - Phase 2 [12500-25000]: LoRA + PureField
    //      - Phase 3 [25000-50000]: Full coupling, phi-loss weight decrease
    //      - Alpha curriculum: 0.0001 → 0.1
    //      - Checkpoint every 1000 steps
    //      - Best model tracking by CE
    //
    //   6. Loss: CE + phi_loss (tension diversity)
    //      - phi_loss = -PSI_ALPHA * var(tensions_across_layers)
    //      - Phase-weighted: P1=1.0x, P2=0.5x, P3=0.3x

    let state = TrainState { step: 0, phase: 1, best_ce: 999999.0, epoch: 0 }
    state.step
}

// ─── VRAM dry-run ───
fn dry_run() -> bool {
    // TODO[pytorch]:
    //   Load model + LoRA + PureField
    //   Forward 1 batch (1, 512)
    //   Report peak VRAM
    //   Exit
    true
}

// ─── Verification ───
let cfg = default_config()
let pm = phase_new(cfg.total_steps, cfg.p1_ratio, cfg.p2_ratio)
println("=== train_14b_v05.hexa ===")
println("Model:", cfg.model_path)
println("Corpus:", cfg.data_path)
println("QLoRA: r=", cfg.lora_r, " alpha=", cfg.lora_alpha)
println("PureField:", cfg.pf_n_layers, "layers, rank=", cfg.pf_rank)
println("Steps:", cfg.total_steps, " Effective batch:", cfg.batch_size * cfg.grad_accum)
println("P1 end:", pm.p1_end, " P2 end:", pm.p2_end)
println("Phi-alpha:", cfg.phi_alpha)

let p1 = phase_at(pm, 5000)
let p2 = phase_at(pm, 15000)
let p3 = phase_at(pm, 35000)
println("Phase at 5000:", p1, " 15000:", p2, " 35000:", p3)

theorem train_14b_invariants {
    assert PSI_ALPHA == 0.014
    assert cfg.grad_accum == 8
    assert cfg.lora_r == 64
    assert cfg.lora_alpha == 128
    assert cfg.block_size == 512
    assert p1 == 1
    assert p2 == 2
    assert p3 == 3
}

