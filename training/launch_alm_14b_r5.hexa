// launch_alm_14b_r5.hexa — ALM 14B r5 LoRA training (RunPod H100 80GB)
//
// SAME-BASE K-QUALITY RECOVERY PATH.
//
// r4 outcome:   eval_loss 3.6466 -> 0.0289 (108x) but Korean generation at
//               step 2000 is INCOHERENT (broken UTF-8 / CJK leak / English).
// r5 strategy:  stay on Qwen/Qwen2.5-14B-Instruct, retarget hyperparameters
//               at Korean quality (not loss). A parallel agent owns the
//               base-swap lineage (launch_alm_14b_r5_kbase.hexa) -- do NOT
//               share markers, checkpoint dirs, or R2 prefixes.
//
// r5 changes vs r4 (see train_alm_14b_r5.hexa for full diagnosis):
//   - lora_r         :  64   -> 128
//   - lora_alpha     :  128  -> 256
//   - lora_dropout   :  0.05 -> 0.10
//   - lr             :  5e-6 -> 1e-4
//   - warmup         :  500  -> 2000
//   - steps          :  10k  -> 20k
//   - unfreeze       :  NONE -> embed_tokens + lm_head
//   - corpus prep    :  RAW  -> dedupe + shuffle + doc-separator
//
// Run on RunPod H100 80GB:
//   1. Wait for /workspace/READY_FOR_R5 to appear.
//   2. scp launch_alm_14b_r5.hexa + train_alm_14b_r5.hexa to /workspace/
//   3. hexa launch_alm_14b_r5.hexa

fn main() {
    let runner = "/tmp/_launch_alm_14b_r5_runner.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "\n" +
        "echo \"============================================\"\n" +
        "echo \"  ALM 14B r5 -- LoRA r=128 a=256, attn+MLP\"\n" +
        "echo \"                + embed_tokens + lm_head unfrozen\"\n" +
        "echo \"                + LR=1e-4 warmup=2000 steps=20000\"\n" +
        "echo \"                + dedupe/shuffle/doc-separator\"\n" +
        "echo \"                (same-base K-quality recovery)\"\n" +
        "echo \"============================================\"\n" +
        "\n" +
        "MARKER=\"/workspace/READY_FOR_R5\"\n" +
        "FORBIDDEN_KBASE=\"/workspace/READY_FOR_R5_KBASE\"\n" +
        "FORBIDDEN_32B=\"/workspace/READY_FOR_32B\"\n" +
        "\n" +
        "if [[ ! -f \"$MARKER\" ]]; then\n" +
        "    echo \"[preflight] $MARKER missing -- not cleared to launch r5\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] trigger marker present: $MARKER\"\n" +
        "cat \"$MARKER\" 2>/dev/null || true\n" +
        "\n" +
        "if [[ -f \"$FORBIDDEN_KBASE\" ]]; then\n" +
        "    echo \"[preflight] $FORBIDDEN_KBASE also present -- base-swap conflict\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] no base-swap conflict\"\n" +
        "\n" +
        "if [[ -f \"$FORBIDDEN_32B\" ]]; then\n" +
        "    echo \"[preflight] $FORBIDDEN_32B present -- 32B conflict\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] no 32B conflict\"\n" +
        "\n" +
        "R4_CKPT_DIR=\"/workspace/ckpt_alm_14b_r4\"\n" +
        "if [[ -d \"$R4_CKPT_DIR\" ]]; then\n" +
        "    if pgrep -f \"train_alm_14b.*ckpt_alm_14b_r4\" >/dev/null 2>&1; then\n" +
        "        echo \"[preflight] r4 process still running -- refusing\"\n" +
        "        exit 1\n" +
        "    fi\n" +
        "    echo \"[preflight] r4 has stopped\"\n" +
        "fi\n" +
        "\n" +
        "HEXA_BIN=\"${HEXA_BIN:-/usr/local/bin/hexa}\"\n" +
        "HEXA_CFG=\"/workspace/train_alm_14b_r5.hexa\"\n" +
        "if [[ -x \"$HEXA_BIN\" && -f \"$HEXA_CFG\" ]]; then\n" +
        "    echo \"[preflight] parse-checking $HEXA_CFG ...\"\n" +
        "    \"$HEXA_BIN\" \"$HEXA_CFG\" > /workspace/train_alm_14b_r5.plan.log 2>&1 || {\n" +
        "        echo \"[preflight] train_alm_14b_r5.hexa failed to parse\"\n" +
        "        cat /workspace/train_alm_14b_r5.plan.log\n" +
        "        exit 1\n" +
        "    }\n" +
        "    echo \"[preflight] hexa config OK\"\n" +
        "else\n" +
        "    echo \"[preflight] hexa binary or config missing -- continuing without dry-run\"\n" +
        "fi\n" +
        "\n" +
        "echo \"[preflight] checking GPU...\"\n" +
        "nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv,noheader\n" +
        "\n" +
        "echo \"[preflight] checking corpus...\"\n" +
        "CORPUS=\"/workspace/anima/training/corpus_large.txt\"\n" +
        "if [[ ! -f \"$CORPUS\" ]]; then echo \"[preflight] corpus missing: $CORPUS\"; exit 1; fi\n" +
        "ls -lh \"$CORPUS\"\n" +
        "\n" +
        "echo \"[preflight] checking disk...\"\n" +
        "df -h /workspace\n" +
        "echo \"[preflight] HF_TOKEN set: ${HF_TOKEN:+yes}\"\n" +
        "\n" +
        "export HF_HUB_CACHE=\"/workspace/hf_cache\"\n" +
        "export HF_HOME=\"/workspace/hf_cache\"\n" +
        "export TRANSFORMERS_CACHE=\"/workspace/hf_cache\"\n" +
        "\n" +
        "TRAINER=\"/workspace/train_alm_14b.py\"\n" +
        "if [[ ! -f \"$TRAINER\" ]]; then echo \"[preflight] trainer missing: $TRAINER\"; exit 1; fi\n" +
        "HELP_OUT=\"$(python3 \"$TRAINER\" --help 2>&1 || true)\"\n" +
        "MISSING=()\n" +
        "for flag in --target-modules --unfreeze-embed --unfreeze-lm-head --doc-separator --shuffle-docs --dedupe; do\n" +
        "    if ! grep -q -- \"$flag\" <<<\"$HELP_OUT\"; then MISSING+=(\"$flag\"); fi\n" +
        "done\n" +
        "if (( ${#MISSING[@]} > 0 )); then\n" +
        "    echo \"[preflight] trainer missing required r5 flags:\"\n" +
        "    for f in \"${MISSING[@]}\"; do echo \"  $f\"; done\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] trainer supports all r5 flags\"\n" +
        "\n" +
        "CKPT_DIR=\"/workspace/ckpt_alm_14b_r5\"\n" +
        "rm -rf \"$CKPT_DIR\"\n" +
        "mkdir -p \"$CKPT_DIR\"\n" +
        "cp -f \"$HEXA_CFG\" \"$CKPT_DIR/train_alm_14b_r5.hexa\" 2>/dev/null || true\n" +
        "cp -f /workspace/train_alm_14b_r5.plan.log \"$CKPT_DIR/\" 2>/dev/null || true\n" +
        "\n" +
        "python3 \"$TRAINER\" \\\n" +
        "    --base Qwen/Qwen2.5-14B-Instruct \\\n" +
        "    --corpus \"$CORPUS\" \\\n" +
        "    --steps 20000 \\\n" +
        "    --lr 1e-4 \\\n" +
        "    --batch 1 \\\n" +
        "    --grad-accum 8 \\\n" +
        "    --seq 1024 \\\n" +
        "    --warmup 2000 \\\n" +
        "    --lora-r 128 \\\n" +
        "    --lora-alpha 256 \\\n" +
        "    --lora-dropout 0.10 \\\n" +
        "    --target-modules q_proj k_proj v_proj o_proj gate_proj up_proj down_proj \\\n" +
        "    --unfreeze-embed \\\n" +
        "    --unfreeze-lm-head \\\n" +
        "    --doc-separator \\\n" +
        "    --shuffle-docs \\\n" +
        "    --dedupe \\\n" +
        "    --ckpt-dir \"$CKPT_DIR\" \\\n" +
        "    --save-every 2000 \\\n" +
        "    --eval-every 500 \\\n" +
        "    --model-tag alm14b \\\n" +
        "    --round 5 \\\n" +
        "    2>&1 | tee \"$CKPT_DIR/train_r5.log\"\n" +
        "\n" +
        "echo \"[done] 14B r5 training complete -- check $CKPT_DIR\"\n" +
        "echo \"[next] hexa eval_alm_14b.hexa --ckpt $CKPT_DIR/step_20000 --korean-quality\"\n"
    )

    exec("bash " + runner)
}

main()
