    lines = lines.push(build_line(tool_gen, "Generate a diagram of a transformer architecture", "generate_image", "{\"prompt\":\"Technical diagram of a transformer neural network architecture, attention heads, encoder-decoder blocks, labeled components, white background\",\"width\":1920,\"height\":1080}", "Image generated: /tmp/gen_img_002.png (1920x1080, 3.4MB)"))
    lines = lines.push(build_line(tool_gen, "Make a banner image for the blog post about consciousness", "generate_image", "{\"prompt\":\"Abstract visualization of machine consciousness, interconnected glowing nodes forming a brain shape, dark background, purple and cyan colors\",\"width\":1200,\"height\":630}", "Image generated: /tmp/gen_img_003.png (1200x630, 1.8MB)"))
    lines = lines.push(build_line(tool_gen, "Create a simple icon for the settings page", "generate_image", "{\"prompt\":\"Simple flat design gear icon, monochrome gray, 2D, no gradients, centered on transparent background\",\"width\":256,\"height\":256}", "Image generated: /tmp/gen_img_004.png (256x256, 12KB)"))
    lines = lines.push(build_line(tool_gen, "Generate a profile avatar for my account", "generate_image", "{\"prompt\":\"Professional avatar illustration, geometric abstract face, warm earth tones, hexagonal pattern background\",\"width\":512,\"height\":512}", "Image generated: /tmp/gen_img_005.png (512x512, 340KB)"))
    return lines
end

// =====================================================================
// Category 8: translation (5 examples)
