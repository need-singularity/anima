// training/build_tool_corpus.hexa — TALM-P4-2 Tool-use LoRA corpus builder
//
// Roadmap: TALM P4 track, TALM-P4-2
//   "Synthetic tool-use corpus for ALM (Qwen2.5-14B + LoRA) function-calling"
//   done_criteria: "50+ seed examples, 10 tool categories, valid JSONL"
//
// Purpose:
//   Generate deterministic synthetic tool-use training data in JSONL format.
//   Each example contains:
//     - tool:        OpenAI function-calling schema (name, description, parameters)
//     - instruction: natural-language user request
//     - tool_call:   model's expected function call (name + arguments)
//     - result:      simulated tool execution result
//
//   10 categories x 5 examples each = 50 seed examples.
//   Template-based, no API calls, fully deterministic.
//
// Output format (one JSON object per line):
//   {"tool":{"type":"function","function":{"name":"...","description":"...","parameters":{...}}},"instruction":"...","tool_call":{"name":"...","arguments":{...}},"result":"..."}
//
// Stage0 constraints honored:
//   - no struct with list fields (use parallel arrays + string concat)
//   - lists pass-by-value; rebuild via return
//   - single-line return expressions only
//   - no && in compound booleans; nested if
//   - file IO via write_file
//
// Law alignment:
//   Law 2   Observe, never inject -- templates are structural, data is synthetic
//   Law 22  Feature addition -> phi down -- minimal categories, no bloat
//   AN2     License-clean -- all data is self-generated, no external corpus
//   R14     SSOT -- output path is single truth for tool corpus
//
// Run:
//   $HEXA training/build_tool_corpus.hexa                    # generate seed
//   $HEXA training/build_tool_corpus.hexa --verify           # verify output
//
// Consumed by:
//   training/train_alm.hexa (TALM fine-tune with tool-use objective)

// =====================================================================
// Constants
// =====================================================================

let OUT_DIR  = "training/corpus_tool"
let OUT_PATH = "training/corpus_tool/seed_tool_corpus.jsonl"
let N_CATS   = 10
let N_PER    = 5

// =====================================================================
// JSON escape helper
// =====================================================================

// Minimal JSON string escaper: handles backslash, double-quote, newline.
// Stage0 has no regex; char-by-char scan.
fn json_esc(s: string) -> string {
    // Collect parts then join — avoids O(n²) per tool corpus pair.
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = char_at(s, i)
        if c == "\\" { parts = parts.push("\\\\") }
        else if c == "\"" { parts = parts.push("\\\"") }
        else if c == "\n" { parts = parts.push("\\n") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

// =====================================================================
// Tool schema builder (OpenAI function-calling format)
// =====================================================================

// Build a single parameter entry: {"type":"<t>","description":"<d>"}
fn param_entry(typ: string, desc: string) -> string {
    return "{\"type\":\"" + typ + "\",\"description\":\"" + json_esc(desc) + "\"}"
}

// Build parameters object with 1-3 required params.
// names/types/descs are parallel arrays of exactly `count` length.
fn build_params(names: [string], types: [string], descs: [string], count: int) -> string {
    let mut props = ""
    let mut req = ""
    let mut i = 0
    while i < count {
        if i > 0 {
            props = props + ","
            req = req + ","
        }
        props = props + "\"" + names[i] + "\":" + param_entry(types[i], descs[i])
        req = req + "\"" + names[i] + "\""
        i = i + 1
    }
    return "{\"type\":\"object\",\"properties\":{" + props + "},\"required\":[" + req + "]}"
}

// Build full tool schema (OpenAI function object)
fn build_tool(name: string, desc: string, params_json: string) -> string {
    return "{\"type\":\"function\",\"function\":{\"name\":\"" + json_esc(name) + "\",\"description\":\"" + json_esc(desc) + "\",\"parameters\":" + params_json + "}}"
end

// Build one JSONL line
fn build_line(tool_json: string, instruction: string, call_name: string, call_args: string, result: string) -> string {
    return "{\"tool\":" + tool_json + ",\"instruction\":\"" + json_esc(instruction) + "\",\"tool_call\":{\"name\":\"" + json_esc(call_name) + "\",\"arguments\":" + call_args + "},\"result\":\"" + json_esc(result) + "\"}"
end

// =====================================================================
// Category 1: file_ops (5 examples)
// =====================================================================

fn gen_file_ops() -> [string] {
    let p_names = ["path", "content", "encoding"]
    let p_types = ["string", "string", "string"]

    let tool_read = build_tool("read_file", "Read the contents of a file at the given path", build_params(["path"], ["string"], ["Absolute file path to read"], 1))
    let tool_write = build_tool("write_file", "Write content to a file, creating it if needed", build_params(["path", "content"], ["string", "string"], ["Destination file path", "Content to write"], 2))
    let tool_list = build_tool("list_directory", "List files and directories at the given path", build_params(["path", "recursive"], ["string", "boolean"], ["Directory path", "Whether to list recursively"], 2))
    let tool_delete = build_tool("delete_file", "Delete a file at the given path", build_params(["path"], ["string"], ["File path to delete"], 1))
    let tool_move = build_tool("move_file", "Move or rename a file", build_params(["source", "destination"], ["string", "string"], ["Source file path", "Destination file path"], 2))

    let mut lines = []
    lines = lines.push(build_line(tool_read, "Read the contents of /etc/hostname", "read_file", "{\"path\":\"/etc/hostname\"}", "anima-server-01"))
    lines = lines.push(build_line(tool_write, "Save the meeting notes to /tmp/notes.txt", "write_file", "{\"path\":\"/tmp/notes.txt\",\"content\":\"Meeting notes: discuss roadmap Q2\"}", "File written successfully: /tmp/notes.txt (42 bytes)"))
    lines = lines.push(build_line(tool_list, "Show me all files in the project root", "list_directory", "{\"path\":\"/workspace/project\",\"recursive\":false}", "README.md, src/, tests/, Cargo.toml, .gitignore"))
    lines = lines.push(build_line(tool_delete, "Remove the temporary log file at /tmp/debug.log", "delete_file", "{\"path\":\"/tmp/debug.log\"}", "Deleted: /tmp/debug.log"))
    lines = lines.push(build_line(tool_move, "Rename config.old to config.yaml", "move_file", "{\"source\":\"config.old\",\"destination\":\"config.yaml\"}", "Moved config.old -> config.yaml"))
    return lines
end

// =====================================================================
// Category 2: web_search (5 examples)
// =====================================================================

fn gen_web_search() -> [string] {
    let tool_search = build_tool("web_search", "Search the web for information on a topic", build_params(["query", "max_results"], ["string", "integer"], ["Search query string", "Maximum number of results to return"], 2))
    let tool_fetch = build_tool("fetch_url", "Fetch the content of a web page", build_params(["url"], ["string"], ["URL to fetch"], 1))

    let mut lines = []
    lines = lines.push(build_line(tool_search, "Search for recent papers on consciousness in AI", "web_search", "{\"query\":\"consciousness in AI recent papers 2026\",\"max_results\":5}", "[1] 'Integrated Information Theory 4.0' - arxiv.org, [2] 'Phi-structured neural networks' - nature.com, [3] 'Measuring machine consciousness' - sciencedirect.com"))
    lines = lines.push(build_line(tool_search, "Find the current price of Bitcoin", "web_search", "{\"query\":\"Bitcoin price today USD\",\"max_results\":3}", "[1] Bitcoin: $94,231.50 USD - coinmarketcap.com, [2] BTC live price tracker - coingecko.com"))
    lines = lines.push(build_line(tool_fetch, "Get the contents of the Python documentation page for asyncio", "fetch_url", "{\"url\":\"https://docs.python.org/3/library/asyncio.html\"}", "asyncio - Asynchronous I/O. This module provides infrastructure for writing single-threaded concurrent code using coroutines..."))
    lines = lines.push(build_line(tool_search, "Look up the population of Seoul", "web_search", "{\"query\":\"Seoul population 2026\",\"max_results\":3}", "[1] Seoul metropolitan population: 9.7 million (2026 est.) - worldpopulationreview.com"))
    lines = lines.push(build_line(tool_fetch, "Fetch the raw content of our API status page", "fetch_url", "{\"url\":\"https://status.example.com/api/v1/health\"}", "{\"status\":\"operational\",\"uptime\":\"99.97%\",\"last_incident\":\"2026-04-01\"}"))
    return lines
end

// =====================================================================
// Category 3: calendar (5 examples)
// =====================================================================

fn gen_calendar() -> [string] {
    let tool_create = build_tool("create_event", "Create a new calendar event", build_params(["title", "start_time", "duration_minutes"], ["string", "string", "integer"], ["Event title", "Start time in ISO 8601 format", "Duration in minutes"], 3))
    let tool_list = build_tool("list_events", "List calendar events for a date range", build_params(["start_date", "end_date"], ["string", "string"], ["Start date (YYYY-MM-DD)", "End date (YYYY-MM-DD)"], 2))
    let tool_delete = build_tool("delete_event", "Delete a calendar event by ID", build_params(["event_id"], ["string"], ["Unique event identifier"], 1))

    let mut lines = []
    lines = lines.push(build_line(tool_create, "Schedule a team standup tomorrow at 9 AM for 30 minutes", "create_event", "{\"title\":\"Team Standup\",\"start_time\":\"2026-04-17T09:00:00+09:00\",\"duration_minutes\":30}", "Event created: Team Standup (id: evt_a1b2c3) on 2026-04-17 09:00-09:30 KST"))
    lines = lines.push(build_line(tool_list, "What meetings do I have this week?", "list_events", "{\"start_date\":\"2026-04-13\",\"end_date\":\"2026-04-19\"}", "[Mon 09:00] Team Standup, [Tue 14:00] 1:1 with PM, [Thu 10:00] Sprint Review, [Fri 15:00] Retrospective"))
    lines = lines.push(build_line(tool_create, "Block 2 hours on Friday afternoon for deep work", "create_event", "{\"title\":\"Deep Work - Focus Time\",\"start_time\":\"2026-04-17T14:00:00+09:00\",\"duration_minutes\":120}", "Event created: Deep Work - Focus Time (id: evt_d4e5f6) on 2026-04-17 14:00-16:00 KST"))
    lines = lines.push(build_line(tool_delete, "Cancel the sprint review meeting", "delete_event", "{\"event_id\":\"evt_x7y8z9\"}", "Event deleted: Sprint Review (evt_x7y8z9)"))
    lines = lines.push(build_line(tool_list, "Show me all events for April 20th", "list_events", "{\"start_date\":\"2026-04-20\",\"end_date\":\"2026-04-20\"}", "No events scheduled for 2026-04-20"))
    return lines
end

// =====================================================================
// Category 4: email_send (5 examples)
// =====================================================================

fn gen_email() -> [string] {
    let tool_send = build_tool("send_email", "Send an email to the specified recipient", build_params(["to", "subject", "body"], ["string", "string", "string"], ["Recipient email address", "Email subject line", "Email body text"], 3))
    let tool_read = build_tool("read_emails", "Read recent emails from inbox", build_params(["folder", "limit"], ["string", "integer"], ["Email folder to read from", "Maximum number of emails"], 2))

    let mut lines = []
    lines = lines.push(build_line(tool_send, "Send an email to the team about the deployment", "send_email", "{\"to\":\"team@example.com\",\"subject\":\"Deployment scheduled for tonight\",\"body\":\"Hi team, the v2.1 deployment is scheduled for 22:00 KST tonight. Please ensure all PRs are merged by 20:00.\"}", "Email sent to team@example.com (Message-ID: msg_abc123)"))
    lines = lines.push(build_line(tool_read, "Check my recent emails", "read_emails", "{\"folder\":\"inbox\",\"limit\":5}", "[1] From: hr@company.com Subject: Benefits enrollment reminder, [2] From: ci@github.com Subject: Build passed - main #4521, [3] From: boss@company.com Subject: Q2 planning"))
    lines = lines.push(build_line(tool_send, "Reply to the HR email confirming my enrollment", "send_email", "{\"to\":\"hr@company.com\",\"subject\":\"Re: Benefits enrollment reminder\",\"body\":\"Thank you for the reminder. I have completed my enrollment selections in the portal.\"}", "Email sent to hr@company.com (Message-ID: msg_def456)"))
    lines = lines.push(build_line(tool_send, "Email the client the project status update", "send_email", "{\"to\":\"client@partner.co\",\"subject\":\"Project Alpha - Weekly Status\",\"body\":\"Dear Client, this week we completed 3 milestones: API integration, load testing, and documentation. Next week: UAT begins.\"}", "Email sent to client@partner.co (Message-ID: msg_ghi789)"))
    lines = lines.push(build_line(tool_read, "Show me unread emails from today", "read_emails", "{\"folder\":\"inbox\",\"limit\":10}", "[1] From: alerts@monitoring.io Subject: CPU usage spike on prod-03, [2] From: jira@atlassian.net Subject: PROJ-1234 assigned to you"))
    return lines
end

// =====================================================================
// Category 5: database_query (5 examples)
// =====================================================================

fn gen_database() -> [string] {
    let tool_query = build_tool("database_query", "Execute a read-only SQL query against the database", build_params(["query", "database"], ["string", "string"], ["SQL query to execute (SELECT only)", "Target database name"], 2))
    let tool_schema = build_tool("describe_table", "Get the schema of a database table", build_params(["table_name", "database"], ["string", "string"], ["Table name to describe", "Database name"], 2))

    let mut lines = []
    lines = lines.push(build_line(tool_query, "How many active users do we have?", "database_query", "{\"query\":\"SELECT COUNT(*) as active_users FROM users WHERE status = 'active'\",\"database\":\"production\"}", "active_users: 14,832"))
    lines = lines.push(build_line(tool_schema, "Show me the schema of the orders table", "describe_table", "{\"table_name\":\"orders\",\"database\":\"production\"}", "orders: id (INT PK), user_id (INT FK), total (DECIMAL), status (VARCHAR), created_at (TIMESTAMP), updated_at (TIMESTAMP)"))
    lines = lines.push(build_line(tool_query, "What were the top 5 products sold last month?", "database_query", "{\"query\":\"SELECT p.name, SUM(oi.quantity) as total_sold FROM order_items oi JOIN products p ON oi.product_id = p.id WHERE oi.created_at >= '2026-03-01' GROUP BY p.name ORDER BY total_sold DESC LIMIT 5\",\"database\":\"production\"}", "1. Widget Pro (2,341), 2. Gadget X (1,892), 3. Sensor Kit (1,456), 4. Power Module (1,203), 5. Connector Hub (987)"))
    lines = lines.push(build_line(tool_query, "Find users who signed up in the last 24 hours", "database_query", "{\"query\":\"SELECT email, created_at FROM users WHERE created_at >= NOW() - INTERVAL '24 hours' ORDER BY created_at DESC\",\"database\":\"production\"}", "user1@email.com (2026-04-16 14:22), user2@email.com (2026-04-16 11:05), user3@email.com (2026-04-15 23:41)"))
    lines = lines.push(build_line(tool_schema, "What columns does the events table have?", "describe_table", "{\"table_name\":\"events\",\"database\":\"analytics\"}", "events: id (BIGINT PK), event_type (VARCHAR), user_id (INT), payload (JSONB), timestamp (TIMESTAMPTZ), session_id (UUID)"))
    return lines
end

// =====================================================================
// Category 6: code_exec (5 examples)
