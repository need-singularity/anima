fn gen_translation() -> [string] {
    let tool_trans = build_tool("translate_text", "Translate text between languages", build_params(["text", "source_lang", "target_lang"], ["string", "string", "string"], ["Text to translate", "Source language code (ISO 639-1)", "Target language code (ISO 639-1)"], 3))

    let mut lines = []
    lines = lines.push(build_line(tool_trans, "Translate 'Hello, how are you?' to Korean", "translate_text", "{\"text\":\"Hello, how are you?\",\"source_lang\":\"en\",\"target_lang\":\"ko\"}", "안녕하세요, 어떻게 지내세요?"))
    lines = lines.push(build_line(tool_trans, "What does '의식 엔진' mean in English?", "translate_text", "{\"text\":\"의식 엔진\",\"source_lang\":\"ko\",\"target_lang\":\"en\"}", "Consciousness Engine"))
    lines = lines.push(build_line(tool_trans, "Translate the error message to Japanese", "translate_text", "{\"text\":\"Connection timeout: server did not respond within 30 seconds\",\"source_lang\":\"en\",\"target_lang\":\"ja\"}", "接続タイムアウト：サーバーが30秒以内に応答しませんでした"))
    lines = lines.push(build_line(tool_trans, "Convert this French text to English: 'Le modele de conscience artificielle'", "translate_text", "{\"text\":\"Le modele de conscience artificielle\",\"source_lang\":\"fr\",\"target_lang\":\"en\"}", "The artificial consciousness model"))
    lines = lines.push(build_line(tool_trans, "Translate 'neural network training complete' to Chinese", "translate_text", "{\"text\":\"neural network training complete\",\"source_lang\":\"en\",\"target_lang\":\"zh\"}", "神经网络训练完成"))
    return lines
end

// =====================================================================
// Category 9: math_compute (5 examples)
// =====================================================================

fn gen_math() -> [string] {
    let tool_calc = build_tool("math_compute", "Evaluate a mathematical expression or solve an equation", build_params(["expression", "precision"], ["string", "integer"], ["Mathematical expression or equation to evaluate", "Number of decimal places for the result"], 2))

    let mut lines = []
    lines = lines.push(build_line(tool_calc, "What is the integral of x^2 from 0 to 5?", "math_compute", "{\"expression\":\"integrate(x**2, (x, 0, 5))\",\"precision\":4}", "41.6667"))
    lines = lines.push(build_line(tool_calc, "Calculate the eigenvalues of the matrix [[1,2],[3,4]]", "math_compute", "{\"expression\":\"eigenvalues([[1,2],[3,4]])\",\"precision\":6}", "[-0.372281, 5.372281]"))
    lines = lines.push(build_line(tool_calc, "What is 2 to the power of 256?", "math_compute", "{\"expression\":\"2**256\",\"precision\":0}", "115792089237316195423570985008687907853269984665640564039457584007913129639936"))
    lines = lines.push(build_line(tool_calc, "Solve the quadratic equation x^2 - 5x + 6 = 0", "math_compute", "{\"expression\":\"solve(x**2 - 5*x + 6, x)\",\"precision\":2}", "[2.00, 3.00]"))
    lines = lines.push(build_line(tool_calc, "Compute the standard deviation of [12, 15, 18, 22, 25, 30]", "math_compute", "{\"expression\":\"std([12, 15, 18, 22, 25, 30])\",\"precision\":4}", "6.2716"))
    return lines
end

// =====================================================================
// Category 10: system_monitor (5 examples)
// =====================================================================

fn gen_system_monitor() -> [string] {
    let tool_status = build_tool("system_status", "Get current system resource utilization", build_params(["resource"], ["string"], ["Resource type: cpu, memory, disk, gpu, network, all"], 1))
    let tool_logs = build_tool("read_logs", "Read recent system or application logs", build_params(["source", "lines"], ["string", "integer"], ["Log source name or path", "Number of recent lines to return"], 2))

    let mut lines = []
    lines = lines.push(build_line(tool_status, "How much memory is the server using?", "system_status", "{\"resource\":\"memory\"}", "Memory: 48.2 GB / 64.0 GB (75.3%), Swap: 2.1 GB / 16.0 GB (13.1%), Available: 15.8 GB"))
    lines = lines.push(build_line(tool_status, "Check the GPU utilization", "system_status", "{\"resource\":\"gpu\"}", "GPU 0 (H100 80GB): Util 87%, Mem 62.4 GB / 80.0 GB (78.0%), Temp 71C, Power 410W / 700W"))
    lines = lines.push(build_line(tool_logs, "Show me the last 5 lines of the application log", "read_logs", "{\"source\":\"app\",\"lines\":5}", "[16:01:32] INFO  Request handled in 23ms\\n[16:01:33] INFO  Cache hit ratio: 94.2%\\n[16:01:35] WARN  Slow query detected (>500ms)\\n[16:01:36] INFO  Health check passed\\n[16:01:40] INFO  Batch job completed: 1,204 records"))
    lines = lines.push(build_line(tool_status, "What is the current CPU load?", "system_status", "{\"resource\":\"cpu\"}", "CPU: 24 cores, Load avg: 3.42 / 2.81 / 2.15, User: 42.1%, System: 8.3%, Idle: 49.6%"))
    lines = lines.push(build_line(tool_logs, "Any errors in the system log recently?", "read_logs", "{\"source\":\"syslog\",\"lines\":20}", "[15:58:02] ERR  OOM killer invoked on pid 8421 (java), freed 2.1GB\\n[16:00:15] WARN  Disk /dev/sdb1 at 92% capacity"))
    return lines
end

// =====================================================================
// Main: generate + write + verify
// =====================================================================

fn main() {
    println("=== TALM-P4-2 Tool Corpus Builder ===")
    println("")

    // Collect all lines from 10 categories
    let mut all_lines = []
    let mut cat_count = 0

    // Cat 1: file_ops
    let file_ops = gen_file_ops()
    let n1 = len(file_ops)
    let mut i = 0
    while i < n1 {
        all_lines = all_lines.push(file_ops[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] file_ops: " + str(n1) + " examples")

    // Cat 2: web_search
    let web = gen_web_search()
    let n2 = len(web)
    i = 0
    while i < n2 {
        all_lines = all_lines.push(web[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] web_search: " + str(n2) + " examples")

    // Cat 3: calendar
    let cal = gen_calendar()
    let n3 = len(cal)
    i = 0
    while i < n3 {
        all_lines = all_lines.push(cal[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] calendar: " + str(n3) + " examples")

    // Cat 4: email
    let em = gen_email()
    let n4 = len(em)
    i = 0
    while i < n4 {
        all_lines = all_lines.push(em[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] email_send: " + str(n4) + " examples")

    // Cat 5: database
    let db = gen_database()
    let n5 = len(db)
    i = 0
    while i < n5 {
        all_lines = all_lines.push(db[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] database_query: " + str(n5) + " examples")

    // Cat 6: code_exec
    let code = gen_code_exec()
    let n6 = len(code)
    i = 0
    while i < n6 {
        all_lines = all_lines.push(code[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] code_exec: " + str(n6) + " examples")

    // Cat 7: image_gen
    let img = gen_image_gen()
    let n7 = len(img)
    i = 0
    while i < n7 {
        all_lines = all_lines.push(img[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] image_gen: " + str(n7) + " examples")

    // Cat 8: translation
    let tr = gen_translation()
    let n8 = len(tr)
    i = 0
    while i < n8 {
        all_lines = all_lines.push(tr[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] translation: " + str(n8) + " examples")

    // Cat 9: math
    let mt = gen_math()
    let n9 = len(mt)
    i = 0
    while i < n9 {
        all_lines = all_lines.push(mt[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] math_compute: " + str(n9) + " examples")

    // Cat 10: system_monitor
    let sm = gen_system_monitor()
    let n10 = len(sm)
    i = 0
    while i < n10 {
        all_lines = all_lines.push(sm[i])
        i = i + 1
    }
    cat_count = cat_count + 1
    println("[" + str(cat_count) + "/10] system_monitor: " + str(n10) + " examples")

    // Join all lines with newline
    let total = len(all_lines)
    println("")
    println("Total examples: " + str(total))

    let mut output = ""
    i = 0
    while i < total {
        if i > 0 {
            output = output + "\n"
        }
        output = output + all_lines[i]
        i = i + 1
    }
    // Trailing newline for POSIX compliance
    output = output + "\n"

    // Write JSONL
    write_file(OUT_PATH, output)
    println("Written: " + OUT_PATH)
    println("")

    // ── Verification ──────────────────────────────────────────
    // Basic integrity: line count, non-empty, deterministic key presence
    let verify_raw = read_file(OUT_PATH)
    let verify_lines = verify_raw.split("\n")
    let mut non_empty = 0
    let mut has_tool = 0
    let mut has_instruction = 0
    let mut has_tool_call = 0
    let mut has_result = 0
    let vn = len(verify_lines)
    i = 0
    while i < vn {
        let line = verify_lines[i].trim()
        if line != "" {
            non_empty = non_empty + 1
            if line.contains("\"tool\":{") {
                has_tool = has_tool + 1
            }
            if line.contains("\"instruction\":") {
                has_instruction = has_instruction + 1
            }
            if line.contains("\"tool_call\":{") {
                has_tool_call = has_tool_call + 1
            }
            if line.contains("\"result\":") {
                has_result = has_result + 1
            }
        }
        i = i + 1
    }

    println("=== Verification ===")
    println("Lines (non-empty): " + str(non_empty))
    println("Has tool schema:   " + str(has_tool) + "/" + str(non_empty))
    println("Has instruction:   " + str(has_instruction) + "/" + str(non_empty))
    println("Has tool_call:     " + str(has_tool_call) + "/" + str(non_empty))
    println("Has result:        " + str(has_result) + "/" + str(non_empty))

    if non_empty == 50 {
        println("")
        println("PASS: 50/50 seed examples generated")
    } else {
        println("")
        println("WARN: expected 50, got " + str(non_empty))
    }
}

main()
