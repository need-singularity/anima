    t = t.push("all items have been checked and catalogued")
    // happy (7 samples)
    t = t.push("I am so happy and delighted about the results")
    t = t.push("What a wonderful and cheerful sunny morning")
    t = t.push("I feel so glad and excited about this opportunity")
    t = t.push("This joyful celebration filled everyone with smile")
    t = t.push("We laughed together and felt love all around")
    t = t.push("She was delighted and cheerful at the wonderful party")
    t = t.push("The glad news made everyone excited and happy")
    // sad (7 samples)
    t = t.push("I feel so sad and lonely on this dark evening")
    t = t.push("The grief and sorrow overwhelmed me completely")
    t = t.push("Tears of heartbreak streamed down her face")
    t = t.push("He was depressed and lonely after the loss")
    t = t.push("I cry every night mourning the sad departure")
    t = t.push("The sorrow of missing you brings tears again")
    t = t.push("Grief and heartbreak consumed his lonely soul")
    // angry (7 samples)
    t = t.push("I am so angry and furious right now at this")
    t = t.push("This outraged me and filled me with rage")
    t = t.push("I feel hostile and annoyed at this betrayal")
    t = t.push("The wrath and hate boiled inside my angry heart")
    t = t.push("He was furious and irritated by the outraged crowd")
    t = t.push("Such hostile resentment and annoyed angry outburst")
    t = t.push("Rage and wrath consumed the angry furious mob")
    // surprised (7 samples)
    t = t.push("I was so surprised and shocked by the news")
    t = t.push("This is amazing and unbelievable information")
    t = t.push("I was startled and stunned by the unexpected turn")
    t = t.push("Wow that was incredible and astonished everyone")
    t = t.push("The amazed crowd was shocked and surprised")
    t = t.push("Unbelievable and unexpected stunned reactions")
    t = t.push("We were astonished and startled by the incredible surprise")
    // fearful (7 samples)
    t = t.push("I am so scared and terrified of the darkness")
    t = t.push("The horror and dread filled me with panic")
    t = t.push("I feel nervous and frightened by this creepy place")
    t = t.push("Fear and anxiety made me scared and terrified")
