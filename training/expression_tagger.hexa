// training/expression_tagger.hexa — TALM-P3-2: Facial Expression Tagger
//
// Purpose:
//   Classifies text into 7 basic Ekman expressions for avatar lip-sync
//   and emotion display. Keyword-based scoring with tone bias, producing
//   a timestamped expression timeline from input text.
//
// 7 Ekman expressions:
//   0=neutral, 1=happy, 2=sad, 3=angry, 4=surprised, 5=fearful, 6=disgusted
//
// Pipeline:
//   1. Tokenize input text into segments (sentence-split on punctuation)
//   2. Score each segment against keyword dictionaries (Korean + English)
//   3. Apply tone bias from style_preset mapping
//   4. Classify each segment to highest-scoring expression
//   5. Generate timestamped timeline (segment index * segment_duration_ms)
//
// Style preset integration:
//   romance -> happy bias, horror -> fearful bias, drama -> sad bias,
//   action -> angry bias, comedy -> happy bias, thriller -> fearful bias,
//   documentary -> neutral bias
//
// F1 scoring:
//   Built-in 50-sample test set (8 neutral + 7 each for 6 emotion classes)
//   Per-class precision, recall, F1 computed. Gate: all F1 >= 0.85
//
// Self-tests (T1..T5):
//   T1: Each of 7 expressions classifiable from single keyword
//   T2: Korean keyword extraction produces correct class
//   T3: F1 per class >= 0.85 on 50-sample built-in test set
//   T4: Timeline generation produces valid ascending timestamps
//   T5: Tone->expression mapping consistency (7 presets)
//
// Stage0 constraints honored:
//   - Standalone (no imports)
//   - No list fields in structs (parallel arrays)
//   - str_contains() for substring matching (no builtin contains)
//   - Deterministic (hash-based, no random)
//   - No [[type]], no multi-line string concat
//   - .push() for list append (pass-by-value, reassign)
//   - len() not length(), .substring() not char_at()
//
// Run:
//   hexa run training/expression_tagger.hexa
//
// Gate:
//   [gate] 5/5 PASS -> TALM-P3-2 criterion met
//   [gate] <5 PASS  -> merge blocked

// ════════════════════════════════════════════════════════════════════
// Constants
// ════════════════════════════════════════════════════════════════════

let N_CLASSES = 7
let SEGMENT_DURATION_MS = 500
let TONE_BIAS_WEIGHT = 0.3
let KEYWORD_WEIGHT = 1.0
let F1_GATE = 0.85

// Expression labels
let EXPR_NEUTRAL = 0
let EXPR_HAPPY = 1
let EXPR_SAD = 2
let EXPR_ANGRY = 3
let EXPR_SURPRISED = 4
let EXPR_FEARFUL = 5
let EXPR_DISGUSTED = 6

// ════════════════════════════════════════════════════════════════════
// Section 0: String Utilities (stage0 has no builtin contains)
// ════════════════════════════════════════════════════════════════════

// Substring search — returns true if needle is found in hay.
// Uses .substring(start, end) which is the stage0 string slice API.
fn str_contains(hay, needle) {
    let hn = len(hay)
    let nn = len(needle)
    if nn == 0 { return true }
    if nn > hn { return false }
    let mut i = 0
    while i + nn <= hn {
        if hay.substring(i, i + nn) == needle { return true }
        i = i + 1
    }
    return false
}

// Alias: the scoring functions use contains() — wire to str_contains.
fn contains(hay, needle) {
    return str_contains(hay, needle)
}

// ════════════════════════════════════════════════════════════════════
// Section 1: Expression Label Utilities
// ════════════════════════════════════════════════════════════════════

fn expr_name(id) {
    if id == 0 { return "neutral" }
    if id == 1 { return "happy" }
    if id == 2 { return "sad" }
    if id == 3 { return "angry" }
    if id == 4 { return "surprised" }
    if id == 5 { return "fearful" }
    if id == 6 { return "disgusted" }
    return "neutral"
}

fn expr_id(name) {
    if name == "neutral" { return 0 }
    if name == "happy" { return 1 }
    if name == "sad" { return 2 }
    if name == "angry" { return 3 }
    if name == "surprised" { return 4 }
    if name == "fearful" { return 5 }
    if name == "disgusted" { return 6 }
    return 0
}

