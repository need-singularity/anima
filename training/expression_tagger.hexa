    t = t.push("Nervous and anxious in this creepy scared atmosphere")
    t = t.push("I was terrified and filled with fear and panic")
    // disgusted (7 samples)
    t = t.push("This is so gross and revolting to look at")
    t = t.push("The vile and repulsive scene caused nausea")
    t = t.push("Sickening and loathsome behavior that is abhorrent")
    t = t.push("I feel disgusted and gross about this revolting mess")
    t = t.push("The foul and vile smell was sickening and repulsive")
    t = t.push("Nausea from the loathsome abhorrent disgust")
    t = t.push("This revolting gross foul thing was repulsive")
    return t
}

