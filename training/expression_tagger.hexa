// ════════════════════════════════════════════════════════════════════
// Section 3: Classifier — keyword scoring + tone bias
// ════════════════════════════════════════════════════════════════════

fn compute_scores(text) {
    let happy_k = count_happy_keywords(text)
    let sad_k = count_sad_keywords(text)
    let angry_k = count_angry_keywords(text)
    let surprised_k = count_surprised_keywords(text)
    let fearful_k = count_fearful_keywords(text)
    let disgusted_k = count_disgusted_keywords(text)

    let total_k = happy_k + sad_k + angry_k + surprised_k + fearful_k + disgusted_k

    // neutral score: high when no emotion keywords found
    let mut neutral_score = 0.0
    if total_k == 0 {
        neutral_score = 1.0
    }

    let scores = [neutral_score, to_float(happy_k) * KEYWORD_WEIGHT, to_float(sad_k) * KEYWORD_WEIGHT, to_float(angry_k) * KEYWORD_WEIGHT, to_float(surprised_k) * KEYWORD_WEIGHT, to_float(fearful_k) * KEYWORD_WEIGHT, to_float(disgusted_k) * KEYWORD_WEIGHT]
    return scores
}

fn apply_tone_bias(scores, preset) {
    let mut bias_idx = 0
    if preset == "romance" { bias_idx = EXPR_HAPPY }
    if preset == "horror" { bias_idx = EXPR_FEARFUL }
    if preset == "drama" { bias_idx = EXPR_SAD }
    if preset == "action" { bias_idx = EXPR_ANGRY }
    if preset == "comedy" { bias_idx = EXPR_HAPPY }
    if preset == "thriller" { bias_idx = EXPR_FEARFUL }
    if preset == "documentary" { bias_idx = EXPR_NEUTRAL }

    let mut biased = [scores[0], scores[1], scores[2], scores[3], scores[4], scores[5], scores[6]]

    // Add tone bias to the preset's target expression
    biased[bias_idx] = biased[bias_idx] + TONE_BIAS_WEIGHT
    return biased
}

fn classify(text, preset) {
    let scores = compute_scores(text)
    let biased = apply_tone_bias(scores, preset)

    let mut best_idx = 0
    let mut best_val = biased[0]
    let mut i = 1
    while i < N_CLASSES {
        if biased[i] > best_val {
            best_val = biased[i]
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}

fn classify_raw(text) {
    let scores = compute_scores(text)
    let mut best_idx = 0
    let mut best_val = scores[0]
    let mut i = 1
    while i < N_CLASSES {
        if scores[i] > best_val {
            best_val = scores[i]
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}

// ════════════════════════════════════════════════════════════════════
// Section 4: Timeline Generation
// ════════════════════════════════════════════════════════════════════

// Split text into segments on sentence-ending punctuation (. ! ?)
fn split_segments(text) {
    let mut segments = ["_placeholder"]
    let mut current = ""
    let text_len = len(text)
    let mut i = 0
    while i < text_len {
        let ch = text.substring(i, i + 1)
        current = current + ch
        if ch == "." {
            segments = segments.push(current)
            current = ""
        }
        if ch == "!" {
            segments = segments.push(current)
            current = ""
        }
        if ch == "?" {
            segments = segments.push(current)
            current = ""
        }
        i = i + 1
    }
    // Remaining text as final segment
    if len(current) > 0 {
        segments = segments.push(current)
    }
    return segments
}

fn generate_timeline(text, preset) {
    let segments = split_segments(text)
    let mut timeline_exprs = [-1]
    let mut seg_count = 0
    let mut idx = 1
    let n_segs = len(segments)
    while idx < n_segs {
        let seg = segments[idx]
        if len(seg) > 0 {
            let expr = classify(seg, preset)
            timeline_exprs = timeline_exprs.push(expr)
            seg_count = seg_count + 1
        }
        idx = idx + 1
    }
    return timeline_exprs
}

fn generate_timestamps(n_segments) {
    let mut timestamps = [-1]
    let mut i = 0
    while i < n_segments {
        let ts = i * SEGMENT_DURATION_MS
        timestamps = timestamps.push(ts)
        i = i + 1
    }
    return timestamps
}

// ════════════════════════════════════════════════════════════════════
// Section 5: F1 Metric Computation
// ════════════════════════════════════════════════════════════════════

fn calc_precision(tp, fp) {
    if tp + fp == 0 { return 1.0 }
    return to_float(tp) / to_float(tp + fp)
}

fn calc_recall(tp, fn_count) {
    if tp + fn_count == 0 { return 1.0 }
    return to_float(tp) / to_float(tp + fn_count)
}

fn f1_score(prec, rec) {
    if prec + rec == 0.0 { return 0.0 }
    return 2.0 * prec * rec / (prec + rec)
}

// ════════════════════════════════════════════════════════════════════
// Section 6: Built-in 50-Sample Test Set
//   8 neutral + 7 each for 6 emotion classes = 50
// ════════════════════════════════════════════════════════════════════

fn get_test_texts() {
    let mut t = ["_placeholder"]
    // neutral (8 samples) — no emotion keywords
    t = t.push("the meeting is scheduled for three pm today")
    t = t.push("we need to update the project schedule")
    t = t.push("the data has been processed successfully")
    t = t.push("files are ready for the next review cycle")
    t = t.push("the report was submitted on time yesterday")
    t = t.push("please confirm the delivery date and address")
