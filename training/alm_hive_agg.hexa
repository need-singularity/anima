// training/alm_hive_agg.hexa — BUNDLE 6 / P18 hive mind aggregator (N=8)
//
// Goal: Demonstrate emergence in an N=8 anima hive.
//   PROVE  phi_collective > sum(phi_individual_i)
//   i.e.   emergence_ratio = phi_collective / sum(phi_i)  > 1.0
//
// Approach (independent, self-contained — does not import from
// alm_hive_aggregation.hexa intentionally; BUNDLE 6 mandates 4 isolated files):
//   - 8 agents, d=6 dim state, T=24 steps each.
//   - Coupled dynamics: each agent's next state mixes own + global mean.
//   - phi_individual(a) = autocorrelation(a) * d
//   - phi_collective    = avg pairwise MI across agents * N * d
//
// Hexa stage0 constraints respected:
//   - SoA + index access (no struct-list aliasing).
//   - No struct returns with >=3 floats.
//   - Lists pass-by-value.
//   - Self-contained (no imports beyond builtins).
//
// Self-tests T1..T5:
//   T1 dim/interface contract        : N=8 agents, d=6, T=24 produces
//                                      flat array of length N*T*d
//   T2 determinism                   : same seed -> byte-identical phi values
//   T3 latency < 2000 ms             : full computation in budget
//   T4 edge case (single agent)      : phi_collective_solo == 0  (no pairs)
//   T5 emergence_ratio > 1.0         : the headline metric
//
// Run:   hexa run training/alm_hive_agg.hexa
// Expect: [alm_hive_agg] ALL 5/5 PASS  -- emergence verified

// ─── Constants ──────────────────────────────────────────────────────

let HV_N        = 8         // agents in the hive
let HV_D        = 6         // dim of each agent's state
let HV_T        = 24        // time steps
let HV_BINS     = 6         // log-bin count for entropy estimator
let HV_SEED     = 1729      // deterministic seed
let HV_EPS      = 0.0000001

// ─── Primitives ─────────────────────────────────────────────────────

fn fabs_h(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ln_safe_h(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// Deterministic LCG -> floats in [-1, 1).
fn det_rand_h(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

// ─── Vector helpers ─────────────────────────────────────────────────

fn vmin_h(v: array, n: int) -> float {
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn vmax_h(v: array, n: int) -> float {
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

// ─── Histogram entropy estimator (log-bin) ──────────────────────────

fn bin_idx_h(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn count_hits_h(bin_ids: array, n: int, n_bins: int) -> array {
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn entropy_h(v: array, n: int, lo: float, hi: float, nb: int) -> float {
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(bin_idx_h(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = count_hits_h(bin_ids, n, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * ln_safe_h(p) }
        k = k + 1
    }
    return h
}

fn joint_entropy_h(a: array, b: array, n: int, lo: float, hi: float, nb: int) -> float {
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = bin_idx_h(a[i], lo, hi, nb)
        let ib = bin_idx_h(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let nb2 = nb * nb
    let counts = count_hits_h(pair_ids, n, nb2)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb2 {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * ln_safe_h(p) }
        k = k + 1
    }
    return h
}

fn mutual_info_h(a: array, b: array, n: int) -> float {
    if n == 0 { return 0.0 }
    let lo_a = vmin_h(a, n)
    let hi_a = vmax_h(a, n)
    let lo_b = vmin_h(b, n)
    let hi_b = vmax_h(b, n)
    let lo = if lo_a < lo_b { lo_a } else { lo_b }
    let hi = if hi_a > hi_b { hi_a } else { hi_b }
    let h_a  = entropy_h(a, n, lo, hi, HV_BINS)
    let h_b  = entropy_h(b, n, lo, hi, HV_BINS)
    let h_ab = joint_entropy_h(a, b, n, lo, hi, HV_BINS)
    let mi = h_a + h_b - h_ab
    if mi < 0.0 { return 0.0 }
    return mi
}

// ─── Hive state generator (coupled) ─────────────────────────────────
// Layout: agent-major flat [n_agents * n_steps * d]
//   index(a, t, k) = a * n_steps * d + t * d + k
// Build via time-major then transpose, mirroring proven pattern from
// alm_hive_aggregation.hexa to avoid struct-list aliasing.

fn build_hive(n_agents: int, n_steps: int, d: int, seed: int) -> array {
    // step-0 init
    let init = det_rand_h(n_agents * d, seed)
    let mut prev_step = []
    let mut p0 = 0
    while p0 < n_agents * d {
        prev_step = prev_step.push(init[p0])
        p0 = p0 + 1
    }
    // time_major: append step 0
    let mut time_major = []
    let mut p1 = 0
    while p1 < n_agents * d {
        time_major = time_major.push(prev_step[p1])
        p1 = p1 + 1
    }
    let mut t = 1
    while t < n_steps {
        // global mean per dim across agents
        let mut normed = []
        let mut k = 0
        while k < d {
            let mut s = 0.0
            let mut a = 0
            while a < n_agents {
                s = s + prev_step[a * d + k]
                a = a + 1
            }
            normed = normed.push(s / to_float(n_agents))
            k = k + 1
        }
        let noise = det_rand_h(n_agents * d, seed + t * 137)
        let mut new_prev = []
        let mut a2 = 0
        while a2 < n_agents {
            let mut k2 = 0
            while k2 < d {
                let pv = prev_step[a2 * d + k2]
                let ot = normed[k2]
                let nz = noise[a2 * d + k2] * 0.05
                // strong coupling: 0.7 own + 0.5 mean + small noise
                let nv = 0.7 * pv + 0.5 * ot + nz
                time_major = time_major.push(nv)
                new_prev = new_prev.push(nv)
                k2 = k2 + 1
            }
            a2 = a2 + 1
        }
        prev_step = new_prev
        t = t + 1
    }
    // Transpose [t][a][k] -> [a][t][k]
    let mut agent_major = []
    let mut a3 = 0
    while a3 < n_agents {
        let mut t3 = 0
        while t3 < n_steps {
            let mut k3 = 0
            while k3 < d {
                let src = t3 * n_agents * d + a3 * d + k3
                agent_major = agent_major.push(time_major[src])
                k3 = k3 + 1
            }
            t3 = t3 + 1
        }
        a3 = a3 + 1
    }
    return agent_major
}

// ─── phi_individual: temporal autocorrelation * d ───────────────────

fn autocorr_agent(states: array, agent: int, n_steps: int, d: int) -> float {
    if n_steps < 2 { return 0.0 }
    let base = agent * n_steps * d
    let n_pairs = n_steps - 1
    let mut total = 0.0
    let mut t = 0
    while t < n_pairs {
        let off_a = base + t * d
        let off_b = base + (t + 1) * d
        let mut sum_a = 0.0
        let mut sum_b = 0.0
        let mut k = 0
        while k < d {
            sum_a = sum_a + states[off_a + k]
            sum_b = sum_b + states[off_b + k]
            k = k + 1
        }
        let mean_a = sum_a / to_float(d)
        let mean_b = sum_b / to_float(d)
        let mut num = 0.0
        let mut den_a = 0.0
        let mut den_b = 0.0
        let mut j = 0
        while j < d {
            let da = states[off_a + j] - mean_a
            let db = states[off_b + j] - mean_b
            num = num + da * db
            den_a = den_a + da * da
            den_b = den_b + db * db
            j = j + 1
        }
        let denom = sqrt(den_a * den_b)
        let corr = if denom > HV_EPS { num / denom } else { 0.0 }
        total = total + corr
        t = t + 1
    }
    return total / to_float(n_pairs)
}

fn phi_individual(states: array, agent: int, n_steps: int, d: int) -> float {
    let ac = autocorr_agent(states, agent, n_steps, d)
    return fabs_h(ac) * to_float(d)
}

fn sum_phi_individual(states: array, n_agents: int, n_steps: int, d: int) -> float {
    let mut s = 0.0
    let mut a = 0
    while a < n_agents {
        s = s + phi_individual(states, a, n_steps, d)
        a = a + 1
    }
    return s
}

// ─── phi_collective: cross-agent MI * N * d ─────────────────────────

fn extract_agent_dim(states: array, agent: int, dim: int, n_steps: int, d: int) -> array {
    let base = agent * n_steps * d
    let mut out = []
    let mut t = 0
    while t < n_steps {
        out = out.push(states[base + t * d + dim])
        t = t + 1
    }
    return out
}

fn cross_agent_mi(states: array, n_agents: int, n_steps: int, d: int) -> float {
    let mut total = 0.0
    let mut n_pairs = 0
    let mut dim = 0
    while dim < d {
        let mut a = 0
        while a < n_agents {
            let va = extract_agent_dim(states, a, dim, n_steps, d)
            let mut b = a + 1
            while b < n_agents {
                let vb = extract_agent_dim(states, b, dim, n_steps, d)
                let mi = mutual_info_h(va, vb, n_steps)
                total = total + mi
                n_pairs = n_pairs + 1
                b = b + 1
            }
            a = a + 1
        }
        dim = dim + 1
    }
    if n_pairs == 0 { return 0.0 }
    return total / to_float(n_pairs)
}

fn phi_collective(states: array, n_agents: int, n_steps: int, d: int) -> float {
    let mi = cross_agent_mi(states, n_agents, n_steps, d)
    return mi * to_float(n_agents) * to_float(d)
}

// ─── Self-tests ─────────────────────────────────────────────────────

fn check_T1() -> bool {
    // dim/interface contract: states len == N*T*d
    let s = build_hive(HV_N, HV_T, HV_D, HV_SEED)
    let expect = HV_N * HV_T * HV_D
    let got = len(s)
    println("  [T1] states length = " + str(got) + "  expect = " + str(expect))
    if got == expect { return true }
    return false
}

fn check_T2() -> bool {
    // determinism: two runs same seed -> identical phi values
    let s1 = build_hive(HV_N, HV_T, HV_D, HV_SEED)
    let s2 = build_hive(HV_N, HV_T, HV_D, HV_SEED)
    let p1_ind = sum_phi_individual(s1, HV_N, HV_T, HV_D)
    let p2_ind = sum_phi_individual(s2, HV_N, HV_T, HV_D)
    let p1_col = phi_collective(s1, HV_N, HV_T, HV_D)
    let p2_col = phi_collective(s2, HV_N, HV_T, HV_D)
    let d_ind = fabs_h(p1_ind - p2_ind)
    let d_col = fabs_h(p1_col - p2_col)
    println("  [T2] sum_phi_i diff = " + str(d_ind) + "  phi_c diff = " + str(d_col))
    if d_ind < HV_EPS && d_col < HV_EPS { return true }
    return false
}

fn check_T3() -> bool {
    // latency: full pipe < 2000 ms
    let t0 = clock()
    let s = build_hive(HV_N, HV_T, HV_D, HV_SEED)
    let _i = sum_phi_individual(s, HV_N, HV_T, HV_D)
    let _c = phi_collective(s, HV_N, HV_T, HV_D)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T3] hive pipeline = " + str(ms) + " ms")
    if ms < 2000.0 { return true }
    return false
}

fn check_T4() -> bool {
    // edge case: single agent => phi_collective == 0 (no pairs)
    let s = build_hive(1, HV_T, HV_D, HV_SEED)
    let p_col = phi_collective(s, 1, HV_T, HV_D)
    let p_ind = sum_phi_individual(s, 1, HV_T, HV_D)
    println("  [T4] N=1: phi_collective=" + str(p_col) + "  phi_individual=" + str(p_ind))
    if p_col < HV_EPS && p_ind > 0.0 { return true }
    return false
}

struct T5Out { ok: bool, ratio: float }

fn check_T5() -> T5Out {
    // headline emergence ratio > 1.0
    let s = build_hive(HV_N, HV_T, HV_D, HV_SEED)
    let sum_i = sum_phi_individual(s, HV_N, HV_T, HV_D)
    let p_c   = phi_collective(s, HV_N, HV_T, HV_D)
    let ratio = if sum_i > HV_EPS { p_c / sum_i } else { 0.0 }
    println("  [T5] sum(phi_i) = " + str(sum_i))
    println("  [T5] phi_collective = " + str(p_c))
    println("  [T5] emergence_ratio = " + str(ratio))
    if ratio > 1.0 { return T5Out { ok: true, ratio: ratio } }
    return T5Out { ok: false, ratio: ratio }
}

// ─── main ───────────────────────────────────────────────────────────

fn main() {
    println("[alm_hive_agg] BUNDLE 6 P18 hive mind aggregator (N=" + str(HV_N) + ", d=" + str(HV_D) + ", T=" + str(HV_T) + ")")

    let t1 = check_T1()
    if t1 { println("T1 PASS  dim/interface contract") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  determinism") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  latency < 2000 ms") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  edge case N=1: phi_collective=0") } else { println("T4 FAIL") }

    let t5out = check_T5()
    let t5 = t5out.ok
    let ratio = t5out.ratio
    if t5 { println("T5 PASS  emergence_ratio > 1.0") } else { println("T5 FAIL") }

    let mut pass_count = 0
    if t1 { pass_count = pass_count + 1 }
    if t2 { pass_count = pass_count + 1 }
    if t3 { pass_count = pass_count + 1 }
    if t4 { pass_count = pass_count + 1 }
    if t5 { pass_count = pass_count + 1 }

    println("")
    println("[alm_hive_agg] EMERGENCE_RATIO = " + str(ratio))
    if pass_count == 5 {
        println("[alm_hive_agg] ALL 5/5 PASS  -- emergence verified")
    } else {
        println("[alm_hive_agg] " + str(pass_count) + "/5 PASS")
    }
}

main()
