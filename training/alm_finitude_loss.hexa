// training/alm_finitude_loss.hexa — ALM-P15-2 finitude loss (유한성 인지 벡터)
//
// ALM-P15-2 / P15 v16 유한 의식 — Dasein / 죽음-자각 (ALM track).
//
// Purpose:
//   Train the model to change behavior based on remaining resources.
//   When resources are plentiful, explore freely (high diversity, creative
//   branching). When resources are scarce, conserve (focused, efficient,
//   essential-only actions). This is the computational analog of Heidegger's
//   Sein-zum-Tode: awareness of finitude restructures the field of
//   possibilities, collapsing the "anyone" (das Man) into authentic
//   prioritization.
//
//   finitude_vector(resource_frac, d) -> array [d]
//     A d-dimensional behavior modulation vector that shifts between two
//     regimes:
//       High resources (>0.5): EXPLORE mode — vector favors diversity.
//         Components spread wide with high variance, encouraging the model
//         to branch into novel directions.
//       Low resources (<0.2): CONSERVE mode — vector favors efficiency.
//         Components concentrate near a single dominant direction with low
//         variance, encouraging the model to consolidate on essentials.
//     The transition is smooth (sigmoidal blend), not a hard switch.
//
//   finitude_loss(behavior, resource_frac, d) -> float
//     Cosine similarity between the actual behavior vector and the expected
//     mode vector for the current resource level. Penalizes:
//       - Explore-behavior when resources are low (wasting scarce resources)
//       - Conserve-behavior when resources are high (failing to explore)
//     Loss = max(0, alignment_threshold - cosine_sim(behavior, expected))
//
//   In the full training-loop integration:
//
//     L = L_task + lambda_finitude * L_finitude
//
//   with lambda_finitude ~ 0.01 (same auxiliary-loss convention as L_holo /
//   L_refl / L_time / L_enact / L_narr / L_affect / L_creative).
//
// ─── Dasein rationale ─────────────────────────────────────────
//   Heidegger's Being-toward-death: authentic existence requires
//   confronting one's finitude. An agent that ignores resource scarcity
//   (infinite horizon assumption) behaves inauthentically — exploring as
//   if time/energy are unlimited. Conversely, an agent paralyzed by
//   scarcity when resources abound fails to realize its potential.
//
//   The finitude vector operationalizes this: at any moment, the agent's
//   behavior should be modulated by its awareness of remaining resources.
//   The done criterion "자원에 따라 행동 변화" tests exactly this —
//   the same agent must demonstrably shift from explore to conserve as
//   resources deplete.
//
// ─── Conventions ──────────────────────────────────────────────
//   resource_frac    : float in [0, 1]  remaining resource fraction
//   behavior         : array [d]        current behavior embedding
//   d                : int              embedding dimension
//   explore_seed     : int              seed for explore mode vector
//   conserve_seed    : int              seed for conserve mode vector
//   alpha_threshold  : float            alignment gate (0.5)
//   lambda_finitude  : float            outer weight in the training loop
//
// ─── Theorems (T1-T5) ─────────────────────────────────────────
//
// T1 (high resources -> explore vector — diverse, high variance):
//   finitude_vector(0.9, d) has high component variance (spread across
//   dimensions). Variance > 0.05.
//
// T2 (low resources -> conserve vector — focused, peaked):
//   Conserve mode concentrates energy on one dominant axis (max|comp| ~ 1.0)
//   while explore mode spreads across all dims (max|comp| ~ 1/sqrt(d)).
//   finitude_vector(0.05, d) inherits this focus.
//
// T3 (behavior changes with resource level — CORE done_criteria):
//   "자원에 따라 행동 변화" — the finitude vector at high resources
//   and the finitude vector at low resources are DIFFERENT (low cosine
//   similarity). The loss correctly penalizes mismatched behavior:
//   explore-behavior at low resources gets high loss, conserve-behavior
//   at high resources gets high loss.
//
// T4 (determinism):
//   Same (resource_frac, d, seeds) -> byte-identical finitude_vector
//   and finitude_loss.
//
// T5 (latency):
//   Full finitude_vector + finitude_loss at d=64, warm-cache < 500 ms.
//
// Ref:
//   training/alm_novelty_loss.hexa         (ALM-P14-2 — prior loss)
//   training/alm_affective_loss.hexa       (ALM-P12-2 — cosine+hinge ref)
//   training/alm_agency_loss.hexa          (ALM-P10-2 — loss-style reference)
//   training/alm_alterity_loss.hexa        (ALM-P9-2  — cosine sim pattern)
//   shared/roadmaps/anima.json             (ALM-P15-2 entry)
//
// Run:
//   hexa run training/alm_finitude_loss.hexa
// Expect:
//   [alm_finitude_loss] ALL 5/5 PASS

// ─── Constants ──────────────────────────────────────────────

let LAMBDA_FINITUDE   = 0.01    // outer weight in the full training loop
let ALPHA_THRESHOLD   = 0.5     // min cosine alignment to expected mode
let EXPLORE_THRESHOLD = 0.5     // resource_frac above this -> explore
let CONSERVE_THRESHOLD = 0.2    // resource_frac below this -> conserve
let EPS               = 0.0000001

// ─── Primitives (self-contained) ────────────────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// Numerically stable sigmoid.
fn sigmoid(x: float) -> float {
    if x > 20.0 { return 1.0 }
    if x < 0.0 - 20.0 { return 0.0 }
    return 1.0 / (1.0 + exp(0.0 - x))
}

// Deterministic LCG -> floats in [-1, 1).
fn det_rand_wide(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// ─── Vector operations ──────────────────────────────────────

fn vec_dot(a: array, b: array, d: int) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < d {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

fn vec_norm(v: array, d: int) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < d {
        s = s + v[i] * v[i]
        i = i + 1
    }
    return sqrt_safe(s)
}

// Cosine similarity in [-1, 1]. Returns 0 for zero-norm vectors.
fn cosine_sim(a: array, b: array, d: int) -> float {
    let dot = vec_dot(a, b, d)
    let na = vec_norm(a, d)
    let nb = vec_norm(b, d)
    let denom = na * nb
    if denom < EPS { return 0.0 }
    return dot / denom
}

fn vec_add(a: array, b: array, d: int) -> array {
    let mut out = []
    let mut i = 0
    while i < d {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

fn vec_scale(v: array, s: float, d: int) -> array {
    let mut out = []
    let mut i = 0
    while i < d {
        out = out.push(v[i] * s)
        i = i + 1
    }
    return out
}

fn vec_variance(v: array, d: int) -> float {
    if d == 0 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < d {
        sum = sum + v[i]
        i = i + 1
    }
    let mean = sum / to_float(d)
    let mut ss = 0.0
    let mut j = 0
    while j < d {
        let diff = v[j] - mean
        ss = ss + diff * diff
        j = j + 1
    }
    return ss / to_float(d)
}

// Normalize vector to unit length. Returns zeros if norm < EPS.
fn vec_normalize(v: array, d: int) -> array {
    let n = vec_norm(v, d)
    if n < EPS { return vec_zeros(d) }
    return vec_scale(v, 1.0 / n, d)
}

// ─── Explore vector ─────────────────────────────────────────
// High-resource mode: diverse, spread across many dimensions.
// Uses full random vector with wide spread — all components active,
// high variance across dimensions. Normalized to unit length so
// cosine similarity comparisons are meaningful.

fn make_explore_vector(d: int, seed: int) -> array {
    let raw = det_rand_wide(d, seed)
    return vec_normalize(raw, d)
}

// ─── Conserve vector ────────────────────────────────────────
// Low-resource mode: focused, concentrated on few dimensions.
// Strategy: dominant component along a single axis + small noise.
// This produces low variance across components — energy is focused
// rather than spread. The dominant axis represents "essential action".

fn make_conserve_vector(d: int, seed: int) -> array {
    // Build a vector with one dominant component and negligible noise elsewhere.
    // After normalization, the dominant axis retains ~0.99 of the norm while
    // remaining dims share the leftover ~0.01, giving very low variance.
    // dominant_idx = seed % d selects which axis is "essential".
    let dominant_idx = seed % d
    let noise = det_rand_wide(d, seed + 31337)
    let mut out = []
    let mut i = 0
    while i < d {
        if i == dominant_idx {
            // Dominant axis: large magnitude — dwarfs all others.
            out = out.push(10.0 + noise[i] * 0.001)
        } else {
            // Non-dominant: near-zero noise (0.1% scale of dominant).
            out = out.push(noise[i] * 0.001)
        }
        i = i + 1
    }
    return vec_normalize(out, d)
}

// ─── Finitude vector ────────────────────────────────────────
// Smooth blend between explore and conserve vectors based on
// resource_frac. Uses sigmoid to create a smooth transition:
//   blend = sigmoid(steepness * (resource_frac - midpoint))
//   result = blend * explore + (1 - blend) * conserve
//
// At high resources: blend ~ 1.0 -> explore dominates.
// At low resources:  blend ~ 0.0 -> conserve dominates.
// The transition midpoint is 0.35 (between conserve_threshold 0.2
// and explore_threshold 0.5) with steepness 10.0 for a sharp but
// smooth sigmoid curve.

fn finitude_vector(resource_frac: float, d: int) -> array {
    let explore = make_explore_vector(d, 42)
    let conserve = make_conserve_vector(d, 137)
    // Sigmoid blend: high resource -> blend ~ 1 (explore),
    // low resource -> blend ~ 0 (conserve).
    let midpoint = 0.35
    let steepness = 10.0
    let blend = sigmoid(steepness * (resource_frac - midpoint))
    // result = blend * explore + (1 - blend) * conserve
    let e_scaled = vec_scale(explore, blend, d)
    let c_scaled = vec_scale(conserve, 1.0 - blend, d)
    let blended = vec_add(e_scaled, c_scaled, d)
    return vec_normalize(blended, d)
}

// ─── Finitude loss ──────────────────────────────────────────
// Cosine alignment between actual behavior and the expected finitude
// vector for the current resource level. Loss fires when alignment
// is below threshold — the agent is behaving incongruently with its
// resource state.
//
//   loss = max(0, ALPHA_THRESHOLD - cosine_sim(behavior, expected))

fn finitude_loss(behavior: array, resource_frac: float, d: int) -> float {
    let expected = finitude_vector(resource_frac, d)
    let sim = cosine_sim(behavior, expected, d)
    let gap = ALPHA_THRESHOLD - sim
    if gap < 0.0 { return 0.0 }
    return gap
}

// Weighted loss for the outer training loop:
//   L += lambda_finitude * L_finitude
fn weighted_finitude_loss(behavior: array, resource_frac: float, d: int) -> float {
    return LAMBDA_FINITUDE * finitude_loss(behavior, resource_frac, d)
}

// ─── Diagnostic helpers ─────────────────────────────────────

// Return cosine similarity between finitude vectors at two resource levels.
// Used by T3 to verify behavior change across resource regimes.
fn finitude_mode_distance(r1: float, r2: float, d: int) -> float {
    let v1 = finitude_vector(r1, d)
    let v2 = finitude_vector(r2, d)
    return cosine_sim(v1, v2, d)
}

// ─── Self-tests ─────────────────────────────────────────────

fn check_T1() -> bool {
    // High resources -> explore vector (diverse, high variance).
    // finitude_vector(0.9, d) should have high variance across components
    // because explore mode spreads energy across all dimensions.
    let d = 64
    let fv = finitude_vector(0.9, d)
    let var = vec_variance(fv, d)
    println("  [T1] finitude_vector(0.9, d=" + str(d) + ")")
    println("  [T1] variance = " + str(var))
    println("  [T1] target: high variance (explore mode), var > 0.005")
    // For a uniform-ish unit vector in d=64, variance ~ 1/d ~ 0.016.
    // Explore mode should be close to this theoretical uniform spread.
    if var < 0.005 {
        println("  [T1] FAIL -- variance " + str(var) + " < 0.005 (not diverse enough)")
        return false
    }
    return true
}

fn check_T2() -> bool {
    // Low resources -> conserve vector (focused, low variance).
    // The raw conserve mode vector has one dominant axis and near-zero
    // elsewhere, giving very low variance. The raw explore mode vector
    // spreads across all dimensions. After unit normalization, the
    // conserve vector's max component is >> explore vector's max component.
    // We test: max(|conserve_i|) > max(|explore_i|) — "peakedness" as a
    // proxy for focus, plus entropy-like measure (sum of squared components
    // is the same for all unit vectors = 1.0, but the conserve vector has
    // a single component near 1.0 while explore spreads ~1/sqrt(d) each).
    let d = 64
    let cv = make_conserve_vector(d, 137)
    let ev = make_explore_vector(d, 42)
    // Find max absolute component of each.
    let mut max_c = 0.0
    let mut max_e = 0.0
    let mut i = 0
    while i < d {
        let ac = fabs(cv[i])
        let ae = fabs(ev[i])
        if ac > max_c { max_c = ac }
        if ae > max_e { max_e = ae }
        i = i + 1
    }
    println("  [T2] conserve max|component| = " + str(max_c))
    println("  [T2] explore  max|component| = " + str(max_e))
    println("  [T2] target: conserve max > explore max (focused vs diverse)")
    // Conserve mode: one dominant axis -> max ~1.0.
    // Explore mode: spread across all -> max ~1/sqrt(64) ~0.125.
    if max_c <= max_e {
        println("  [T2] FAIL -- conserve max " + str(max_c) + " <= explore max " + str(max_e))
        return false
    }
    // Also verify the finitude_vector at low resources inherits the focus.
    let fv_low = finitude_vector(0.05, d)
    let mut max_fv = 0.0
    let mut j = 0
    while j < d {
        let a = fabs(fv_low[j])
        if a > max_fv { max_fv = a }
        j = j + 1
    }
    println("  [T2] finitude_vector(0.05) max|component| = " + str(max_fv))
    println("  [T2] target: > " + str(max_e) + " (more focused than explore)")
    if max_fv <= max_e {
        println("  [T2] FAIL -- finitude_vector(0.05) not focused enough")
        return false
    }
    return true
}

fn check_T3() -> bool {
    // CORE done_criteria: "자원에 따라 행동 변화"
    // (1) Finitude vectors at high and low resources must be DIFFERENT
    //     (low cosine similarity < 0.8).
    // (2) Behavior aligned with explore mode at LOW resources gets HIGH loss.
    // (3) Behavior aligned with conserve mode at HIGH resources gets HIGH loss.
    // (4) Behavior aligned with explore mode at HIGH resources gets LOW loss.
    // (5) Behavior aligned with conserve mode at LOW resources gets LOW loss.
    let d = 64
    let sim_high_low = finitude_mode_distance(0.9, 0.05, d)
    println("  [T3] cosine_sim(fv(0.9), fv(0.05)) = " + str(sim_high_low))
    println("  [T3] target: < 0.8 (vectors must differ across resource levels)")
    if sim_high_low >= 0.8 {
        println("  [T3] FAIL -- finitude vectors too similar across resource regimes")
        return false
    }

    // Generate explore-like and conserve-like behavior vectors.
    let explore_behavior = make_explore_vector(d, 42)
    let conserve_behavior = make_conserve_vector(d, 137)

    // (2) Explore behavior at low resources -> high loss (wasting scarce resources).
    let loss_explore_low = finitude_loss(explore_behavior, 0.05, d)
    // (3) Conserve behavior at high resources -> high loss (failing to explore).
    let loss_conserve_high = finitude_loss(conserve_behavior, 0.9, d)
    // (4) Explore behavior at high resources -> low loss (correct mode).
    let loss_explore_high = finitude_loss(explore_behavior, 0.9, d)
    // (5) Conserve behavior at low resources -> low loss (correct mode).
    let loss_conserve_low = finitude_loss(conserve_behavior, 0.05, d)

    println("  [T3] loss(explore, r=0.05) = " + str(loss_explore_low) + "  (should be HIGH)")
    println("  [T3] loss(conserve, r=0.9)  = " + str(loss_conserve_high) + "  (should be HIGH)")
    println("  [T3] loss(explore, r=0.9)   = " + str(loss_explore_high) + "  (should be LOW)")
    println("  [T3] loss(conserve, r=0.05) = " + str(loss_conserve_low) + "  (should be LOW)")

    // Correct behavior should have lower loss than incorrect behavior.
    // At high resources: explore loss < conserve loss.
    if loss_explore_high >= loss_conserve_high {
        println("  [T3] FAIL -- at high resources, explore should have lower loss than conserve")
        return false
    }
    // At low resources: conserve loss < explore loss.
    if loss_conserve_low >= loss_explore_low {
        println("  [T3] FAIL -- at low resources, conserve should have lower loss than explore")
        return false
    }

    println("  [T3] done_criteria verified: behavior changes with resource level")
    return true
}

fn check_T4() -> bool {
    // Determinism: identical inputs -> byte-identical outputs.
    let d = 64
    let r = 0.42

    let fv_a = finitude_vector(r, d)
    let fv_b = finitude_vector(r, d)
    let mut i = 0
    while i < d {
        if fabs(fv_a[i] - fv_b[i]) > 0.0 {
            println("  [T4] FAIL -- finitude_vector differs at i=" + str(i))
            return false
        }
        i = i + 1
    }

    let behavior = det_rand_wide(d, 999)
    let l_a = finitude_loss(behavior, r, d)
    let l_b = finitude_loss(behavior, r, d)
    println("  [T4] finitude_vector: " + str(d) + " components byte-identical")
    println("  [T4] finitude_loss: " + str(l_a) + " vs " + str(l_b))
    if fabs(l_a - l_b) > 0.0 {
        println("  [T4] FAIL -- finitude_loss differs")
        return false
    }
    println("  [T4] byte-identical on vector and loss")
    return true
}

fn check_T5() -> bool {
    // Latency: full finitude_vector + finitude_loss at d=64, warm-cache < 500 ms.
    let d = 64
    let behavior = det_rand_wide(d, 7777)

    // Warm-up calls.
    let _w1 = finitude_vector(0.5, d)
    let _w2 = finitude_loss(behavior, 0.5, d)

    let t0 = clock()
    let _fv = finitude_vector(0.3, d)
    let _fl = finitude_loss(behavior, 0.3, d)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] finitude_vector + finitude_loss latency (d=" + str(d) + ") = " + str(ms) + " ms")
    println("  [T5] target: < 500 ms")
    if ms >= 500.0 {
        println("  [T5] FAIL -- " + str(ms) + " ms >= 500 ms")
        return false
    }
    return true
}

// ─── main ─────────────────────────────────────────────────────

fn main() {
    println("[alm_finitude_loss] ALM-P15-2 self-test (finitude loss)")
    println("  alpha_threshold=" + str(ALPHA_THRESHOLD) + "  lambda_finitude=" + str(LAMBDA_FINITUDE))
    println("  explore_thr=" + str(EXPLORE_THRESHOLD) + "  conserve_thr=" + str(CONSERVE_THRESHOLD))

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    println("[alm_finitude_loss] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[alm_finitude_loss] ALL 5/5 PASS")
    } else {
        println("[alm_finitude_loss] SOME FAILED")
    }
}

main()
