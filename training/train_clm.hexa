// Per troubleshoot_comments: every stub fn below carries inline comment
// with root-cause + fix + real-impl path. Do not strip these comments.

// ─── QuantumController stubs ────────────────────────────────────────
// Only fields actually read by train_clm.hexa are tracked here. Real
// struct also has `microtubules: [Microtubule]` (used internally by
// quantum_controller_step/phi in anima_quantum_clm.hexa:36-41). Smoke
// does not touch microtubules — step/phi return identity/zero.
struct QuantumController {
    n_atoms: int,
    sites_per_atom: int,
    tick: int
}

// STUB — real impl: anima-engines/anima_quantum_clm.hexa:43-56
// Root cause: hexa silent-exit-on-imports (feedback_hexa_silent_exit_5_imports)
// Fix: return zero-initialized controller. No microtubules allocated.
fn quantum_controller_new(n_atoms: int, sites_per_atom: int) -> QuantumController {
    return QuantumController {
        n_atoms: n_atoms,
        sites_per_atom: sites_per_atom,
        tick: 0
    }
}

// STUB — real impl: anima-engines/anima_quantum_clm.hexa:61-74
// Fix: advance tick only; real impl evolves microtubules via mt_step.
fn quantum_controller_step(qc: QuantumController) -> QuantumController {
    return QuantumController {
        n_atoms: qc.n_atoms,
        sites_per_atom: qc.sites_per_atom,
        tick: qc.tick + 1
    }
}

// STUB — real impl: anima-engines/anima_quantum_clm.hexa:78-86
// Fix: Φ_q = 0 → phi_bonus = 0. Smoke does not need Orch-OR signal.
fn quantum_controller_phi(qc: QuantumController) -> float {
    return 0.0
}

// STUB — real impl: anima-engines/anima_quantum_clm.hexa:90-92
// Fix: return max = n_atoms * sites * ln(2). Matches real formula so
// phi_q / phi_max stays bounded even if phi ever becomes nonzero.
fn quantum_controller_phi_max(qc: QuantumController) -> float {
    return (qc.n_atoms * 1.0) * (qc.sites_per_atom * 1.0) * 0.6931471805599453
}

