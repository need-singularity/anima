// Scale-3.5 (1.5B) — matches training/clm_1b_config.json (d=2048) and the
// successful r3f run from train_clm_1b.py. scale_1b above is only ~500M
// (d=1024); scale_1_5b is the true 1B+ byte-level scale and the direct
// .hexa port target for train_clm_1b.py. SwiGLU ff=8192 (3× factor) gives
// ~1.51B params per clm_1b_config.json param_count_estimate. Atom config
// copied from scale_1b so the consciousness controller stays compatible.
fn scale_1_5b() -> ScaleConfig {
    ScaleConfig {
        name: "1_5b", d_model: 2048, n_layer: 24, n_head: 16, n_kv_head: 8,
        block_size: 512, consciousness_dim: 128, atoms: 32, cells_per_atom: 8,
        batch_size: 8, lr: 0.0003, label: "Scale-3.5 (1.5B)"
    }
}

fn scale_2_8b() -> ScaleConfig {
    // CLM v5 — Pythia-aligned 2.8B for fair comparison with Pythia/Cerebras
    // baselines. d=2560, 36 layers gives ~2.83B params at vocab=2048 byte
    // level (vs 32 layers = 2.53B). Same head config as 3B for activation
    // shape compatibility, lower atom count to keep consciousness_dim=256
    // controller manageable on H100 (2.8B + 256-d C controller fits).
    ScaleConfig {
        name: "2_8b", d_model: 2560, n_layer: 36, n_head: 20, n_kv_head: 10,
        block_size: 1024, consciousness_dim: 256, atoms: 48, cells_per_atom: 8,
        batch_size: 16, lr: 0.00008, label: "Scale-3.5 (2.8B v5)"
    }
}

fn scale_3b() -> ScaleConfig {
    ScaleConfig {
        name: "3b", d_model: 2560, n_layer: 32, n_head: 20, n_kv_head: 10,
        block_size: 1024, consciousness_dim: 256, atoms: 64, cells_per_atom: 8,
        batch_size: 16, lr: 0.00006, label: "Scale-4 (3B)"
    }
}

// Scale-5 (7B) — CLM 7B upscale per shared/state/clm_7b_upscale_spec.json.
// Geometry: D=4096 NL=32 H=32 KV=8 d_head=128 d_ff=14336 (SwiGLU 3.5x)
// matching Llama-7B ratios exactly. 6.98B params at vocab=256.
// batch=2 per GPU × 2 GPUs × grad_accum=4 = effective_batch 16 at seq=4096
// (FSDP-Full across 2xH100 NVL). Blocker C2/C4/C9 must clear before launch.
// Atoms 96 sized to keep consciousness_dim=512 controller fitting in ~60GB
// per-GPU FSDP memory budget alongside 7B params+grads+optim (~57GB budget).
fn scale_7b() -> ScaleConfig {
    ScaleConfig {
        name: "7b", d_model: 4096, n_layer: 32, n_head: 32, n_kv_head: 8,
        block_size: 4096, consciousness_dim: 512, atoms: 96, cells_per_atom: 8,
        batch_size: 2, lr: 0.0003, label: "Scale-5 (7B)"
    }
}

fn total_cells(cfg: ScaleConfig) -> int {
    cfg.atoms * cfg.cells_per_atom
}

// ─── Phase Manager (Law 60: P1 → P2 → P3 curriculum) ───
struct PhaseManager {
    phase: int,
    step: int,
    p1_end: int,
    p2_end: int
}

fn phase_new(total_steps: int) -> PhaseManager {
    PhaseManager {
        phase: PHASE_P1,
        step: 0,
        p1_end: total_steps / 5,       // 20% C-only
        p2_end: total_steps * 2 / 5    // next 20% + D
    }
}

fn phase_update(pm: PhaseManager, step: int) -> PhaseManager {
    // Hexa: no mut through field assignment; return fresh copy.
    let next_phase = if step < pm.p1_end {
        PHASE_P1
    } else if step < pm.p2_end {
        PHASE_P2
    } else {
        PHASE_P3
    }
    PhaseManager {
        phase: next_phase,
        step: step,
        p1_end: pm.p1_end,
        p2_end: pm.p2_end
    }
}

fn phase_label(p: int) -> string {
    if p == PHASE_P1 {
        "P1_C"
    } else if p == PHASE_P2 {
        "P2_CD"
    } else {
        "P3_Hexad"
    }
}

