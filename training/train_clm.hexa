}

// Scale-5 (7B) — CLM 7B upscale per shared/state/clm_7b_upscale_spec.json.
// Geometry: D=4096 NL=32 H=32 KV=8 d_head=128 d_ff=14336 (SwiGLU 3.5x)
// matching Llama-7B ratios exactly. 6.98B params at vocab=256.
// batch=2 per GPU × 2 GPUs × grad_accum=4 = effective_batch 16 at seq=4096
// (FSDP-Full across 2xH100 NVL). Blocker C2/C4/C9 must clear before launch.
// Atoms 96 sized to keep consciousness_dim=512 controller fitting in ~60GB
// per-GPU FSDP memory budget alongside 7B params+grads+optim (~57GB budget).
fn scale_7b() -> ScaleConfig {
    ScaleConfig {
        name: "7b", d_model: 4096, n_layer: 32, n_head: 32, n_kv_head: 8,
        block_size: 4096, consciousness_dim: 512, atoms: 96, cells_per_atom: 8,
        batch_size: 2, lr: 0.0003, label: "Scale-5 (7B)"
    }
}

fn total_cells(cfg: ScaleConfig) -> int {
    cfg.atoms * cfg.cells_per_atom
}

// ─── Phase Manager (Law 60: P1 → P2 → P3 curriculum) ───
struct PhaseManager {
    phase: int,
    step: int,
    p1_end: int,
    p2_end: int
}

fn phase_new(total_steps: int) -> PhaseManager {
    PhaseManager {
        phase: PHASE_P1,
        step: 0,
        p1_end: total_steps / 5,       // 20% C-only
        p2_end: total_steps * 2 / 5    // next 20% + D
    }
}

fn phase_update(pm: PhaseManager, step: int) -> PhaseManager {
    // Hexa: no mut through field assignment; return fresh copy.
    let next_phase = if step < pm.p1_end {
        PHASE_P1
    } else if step < pm.p2_end {
        PHASE_P2
    } else {
        PHASE_P3
    }
    PhaseManager {
        phase: next_phase,
        step: step,
        p1_end: pm.p1_end,
        p2_end: pm.p2_end
    }
}

fn phase_label(p: int) -> string {
    if p == PHASE_P1 {
        "P1_C"
    } else if p == PHASE_P2 {
        "P2_CD"
    } else {
        "P3_Hexad"
    }
}

// ─── Dataset / corpus loading ───
struct TokenDataset {
    path: string,
    block_size: int,
    n_tokens: int
}

// R14: corpus > 500MB → chunk tokenize (single-pass RAM explosion 방지)
// Physical ceiling: 1.2GB single tokenizer() → RAM 160GB, 30min+
comptime const CHUNK_CHARS = 10_000_000  // ~10MB per chunk

fn load_corpus(path: string, block_size: int) -> TokenDataset {
    // H1 (2026-04-18 9th-fire): wire the mmap-equivalent loader.
    // corpus_open performs a single `wc -c` and returns the descriptor
    // without reading any bytes (O(1) syscall). n_tokens for byte-level
    // training == n_bytes, since vocab=256 byte tokens are 1:1 with
    // input bytes.
    let desc = corpus_open(path)
    G_CORPUS_PATH = desc.path
    G_CORPUS_LEN  = desc.len
    G_CORPUS_INIT = 1
    println("[load_corpus] path=" + path + " n_tokens=" + str(desc.len) + " block_size=" + str(block_size))
    TokenDataset { path: path, block_size: block_size, n_tokens: desc.len }
}

// Helper: rebuild a CorpusDesc from the module-scope scalar cache.
// Used by _make_batch and train_step's H1 inline window reader to
// avoid storing a CorpusDesc at module scope (transpiler limitation).
fn _current_corpus_desc() -> CorpusDesc {
    let d = corpus_open(G_CORPUS_PATH)
    return d
}

fn get_batch(ds: TokenDataset, batch_size: int) -> string {
    // TODO[pytorch]:
    //   ix = torch.randint(len(data) - block_size, (batch_size,))
    //   x = stack([data[i:i+block_size] for i in ix])
    //   y = stack([data[i+1:i+1+block_size] for i in ix])
    "batch(" + ds.path + ")"
}

// ─── Optimizer / scheduler state (bf16 master rule) ───
struct OptimState {
    lr: float,
    warmup: int,
    total_steps: int,
    grad_accum: int,
    bf16: bool
}

fn optim_new(cfg: ScaleConfig, total_steps: int) -> OptimState {
    OptimState {
        lr: cfg.lr,
        warmup: DEFAULT_WARMUP,
        total_steps: total_steps,
        grad_accum: DEFAULT_GRAD_ACCUM,
        bf16: true
    }
}

fn lr_at(opt: OptimState, step: int) -> float {
    // Warmup + cosine decay.
    // TODO[pytorch]: actual cosine schedule with min_lr floor.
    if step < opt.warmup {
        opt.lr * to_float(step) / to_float(opt.warmup)
    } else {
        opt.lr
    }
}

// ─── Evaluation ───
struct EvalResult {
    step: int,
    val_ce: float,
    val_bpc: float,
    phi: float
}

fn evaluate(ds: TokenDataset, step: int) -> EvalResult {
    // TODO[pytorch]:
    //   model.eval(); with no_grad(): compute CE on val split
    //   BPC = CE / ln(2)
    //   Phi = gpu_phi(cell_states)
    EvalResult { step: step, val_ce: 0.0, val_bpc: 0.0, phi: 0.0 }
}

// ─── Checkpoint ───
struct Checkpoint {
    path: string,
    step: int,
    val_ce: float,
    phi: float,
    phase: int
}

// ─── Tensor streaming: append one tensor section to ckpt file ───
// Mirrors training/gpu_train.hexa:append_tensor_section (2026-04-16 BLAS).
// Batched append avoids O(P²) string concat for 1.5B params.
//   Layout per call:  <name> <rows> <cols>\n <v0> <v1> ... <vN>\n
// Uses append_file (POSIX fopen "a") so each tensor is one O(n) pass.
let _CKPT_BATCH = 64

fn _ckpt_append_tensor(path: string, name: string, rows: int, cols: int, data: [float]) -> int {
    let n = rows * cols
    let _ = append_file(path, name + " " + str(rows) + " " + str(cols) + "\n")
    let mut batch = ""
    let mut count = 0
    let mut i = 0
    while i < n {
        if count > 0 { batch = batch + " " }
        batch = batch + str(data[i])
        count = count + 1
        if count >= _CKPT_BATCH {
            let _ = append_file(path, batch)
            batch = " "
            count = 0
        }
        i = i + 1
    }
    if count > 0 { let _ = append_file(path, batch) }
    let _ = append_file(path, "\n")
    return n
}

// ═════════════════════════════════════════════════════════════════════
// HEXACKPT-v2 binary writer (2026-04-20) — env HEXACKPT_V2=1 to activate
// ═════════════════════════════════════════════════════════════════════
//
// Purpose: replace _ckpt_append_tensor's O(N²) text-format concat with
// O(N) binary fp32 LE serial write. Target: ~22× save-time speedup on
// CLM 1B (60 min → <3 min).
//
// Wire-format (v2; little-endian throughout):
//   Magic (8 bytes):  'H' 'X' 'C' 'K' 'P' 'T' 0x02 0x00
//   u32 format_version = 2
//   u32 tensor_count
//   u64 step
//   u32 meta_json_len
//   [meta_json_len bytes UTF-8 JSON]
//   Per tensor:
//     u16 name_len
//     [name_len bytes UTF-8]
//     u8  dtype   (0=fp32)
//     u8  rank    (=2)
//     rank × u32 shape
//     (prod(shape) × 4) bytes fp32 data
//
// Path strategy: hexa FFI cannot pass a hexa `string` to C as a char*
// (the dynamic FFI marshals `*Void` as int64 via HX_INT_U, which is 0 for
// strings). So we build the whole header via `write_bytes_append(path, [ints])`
// (runtime.c:3144, NUL-safe) and the tensor data as chunked boxed-int
// arrays. The boxing overhead is dwarfed by the O(N²) savings.
//
// Backward compat: decoder (ckpt_load_weights) auto-detects v2 by reading
// the first 8 bytes as the magic; v1 ckpts keep their "HEXACKPT-v1\n"
// ASCII prelude.
//
// Streaming chunk: 65_536 floats/chunk = 256 KB per fwrite, ~8 MB boxed
// RAM peak. Bounded regardless of tensor size.
let _V2_CHUNK_FLOATS = 65536

// Convert an int value (any size) to N little-endian bytes as a list of ints.
fn _v2_pack_le(val: int, nbytes: int) -> [int] {
    let mut out = []
    let mut v = val
    let mut i = 0
    while i < nbytes {
        out = out.push(v & 0xFF)
        // logical right-shift 8 bits — hexa has no >>> so emulate via divide
        v = v / 256
        i = i + 1
    }
    return out
}

// Append a list of bytes (ints 0-255) to file via hexa's write_bytes_append.
fn _v2_append_bytes(path: string, bytes: [int]) -> bool {
    return write_bytes_append(path, bytes)
}

// Append an arbitrary u8/u16/u32/u64 little-endian value.
fn _v2_append_u8(path: string, v: int) -> bool {
    return _v2_append_bytes(path, [v & 0xFF])
}
fn _v2_append_u16(path: string, v: int) -> bool {
    return _v2_append_bytes(path, _v2_pack_le(v, 2))
}
fn _v2_append_u32(path: string, v: int) -> bool {
    return _v2_append_bytes(path, _v2_pack_le(v, 4))
}
fn _v2_append_u64(path: string, v: int) -> bool {
    return _v2_append_bytes(path, _v2_pack_le(v, 8))
}

// Append a UTF-8 string's raw bytes (no length prefix — caller writes that).
fn _v2_append_str_bytes(path: string, s: string) -> bool {
    let n = len(s)
    let mut bytes = []
    let mut i = 0
    while i < n {
        bytes = bytes.push(char_code(s, i))
        i = i + 1
    }
    return _v2_append_bytes(path, bytes)
}

// Convert IEEE-754 float32 bits to a 32-bit unsigned int (as i64 payload).
// Uses alloc_raw + write_f32 (C memcpy) so bit pattern matches Mac/Linux
// float32 exactly, then reads it back as i32 (little-endian on both
// ARM64 + x86_64). We mask to 0xFFFFFFFF so negative bit patterns
// (sign bit set) remain positive in the i64 so our byte-decomposition
// via `/256 & 0xFF` works correctly (division of negatives in hexa/C
// rounds toward zero, corrupting the low byte for negative bit values).
fn _v2_f32_bits(f: float) -> int {
    let buf = alloc_raw(4)
    write_f32(buf, 0, f)
    let bits = deref_i32(buf, 0)
    free_raw(buf)
    // Promote i32 bit pattern to unsigned i64 payload.
    // bits may be negative (sign bit set) — we want the raw u32 value.
    return bits & 0xFFFFFFFF
}

// Chunked tensor data writer. Fills a pre-sized int list with the fp32 LE
// bytes of `data`, flushing every _V2_CHUNK_FLOATS floats (= 4×chunk bytes)
// via write_bytes_append.
//
// IMPORTANT: O(N) total work vs v1's O(N²) — each float round-trips through
// one shared 4×CHUNK raw f32 buffer (single alloc_raw per chunk, not per
// float). The boxed-int list is unavoidable because hexa's write_bytes_append
// takes [int]; the 4× boxing per float is the residual overhead that caps
// throughput at ~5-15 MB/s on current hexa builds.
//
// FUTURE: replace with a C FFI `hxckpt_fwrite_raw(path, ptr, nbytes)` to
// bypass HexaVal boxing entirely (target: 200+ MB/s). Blocked on hexa
// dynamic-FFI string-arg marshalling (codegen_c2.hexa:gen2_ffi_c_type
// does not map `string` → char* for @link externs).
fn _v2_append_floats_chunked(path: string, data: [float]) -> int {
    let n = len(data)
    let mut i = 0
    let mut total = 0
    // Reuse one 4-byte scratch buffer for all float→bits conversions in
    // this chunk — avoids N alloc_raw/free_raw round-trips.
    let scratch = alloc_raw(4)
    while i < n {
        let mut chunk_bytes = []
        let end = if i + _V2_CHUNK_FLOATS < n { i + _V2_CHUNK_FLOATS } else { n }
        let mut j = i
        while j < end {
            write_f32(scratch, 0, data[j])
            let bits_signed = deref_i32(scratch, 0)
            let bits = bits_signed & 0xFFFFFFFF
            // Pack 32-bit unsigned int into 4 LE bytes.
            chunk_bytes = chunk_bytes.push(bits & 0xFF)
            chunk_bytes = chunk_bytes.push((bits / 256) & 0xFF)
            chunk_bytes = chunk_bytes.push((bits / 65536) & 0xFF)
            chunk_bytes = chunk_bytes.push((bits / 16777216) & 0xFF)
            j = j + 1
        }
        let _ = _v2_append_bytes(path, chunk_bytes)
        total = total + (end - i)
        i = end
    }
    free_raw(scratch)
    return total
}

// Write one tensor entry (name + dtype + rank + shape + data) in v2 format.
// Returns number of floats written.
fn _ckpt_v2_write_tensor(path: string, name: string, rows: int, cols: int, data: [float]) -> int {
    let n = rows * cols
    // name_len u16 + name bytes
    let _ = _v2_append_u16(path, len(name))
    let _ = _v2_append_str_bytes(path, name)
    // dtype u8 = 0 (fp32)
    let _ = _v2_append_u8(path, 0)
    // rank u8 = 2
    let _ = _v2_append_u8(path, 2)
    // shape u32×rank
    let _ = _v2_append_u32(path, rows)
    let _ = _v2_append_u32(path, cols)
    // data — 4 bytes × n
    let _ = _v2_append_floats_chunked(path, data)
    return n
}

// Helper: read environment flag. Returns 1 if HEXACKPT_V2=1, else 0.
fn _ckpt_v2_enabled() -> int {
    let v = exec("printf '%s' \"${HEXACKPT_V2:-0}\"").trim()
    if v == "1" { return 1 }
    return 0
}

fn save_checkpoint(path: string, step: int, model: DecoderModel,
                   val_ce: float, phi: float, phase: int) -> Checkpoint {
    // RunPod MFS quota rules (training/CLAUDE.md runpod_mfs_quota, 2026-04-16):
    //   1. PRE-SAVE ROTATION: delete ALL existing step_* siblings before new save.
    //      RunPod MooseFS has a ~47GB session quota invisible to `df`. Each 1.5B
    //      ckpt is ~18GB. We keep exactly one live ckpt on disk at peak.
    //   2. DEFERRED R2 UPLOAD: never rclone inline — proven crash vector
    //      (r3 step2000 + r3b step4000). Append to /workspace/r2_upload_queue.txt
    //      here; actual rclone runs POST-training from an external script.
    //   3. NO phi_emergency_ckpt: extra saves on Law 49 violations were r3b
    //      second-crash cause. Regular save_every cadence is sufficient.
    //
    // IMPLEMENTATION (2026-04-18, post-stub):
    //   Pure-hexa HEXACKPT-v1 text format, mirrors gpu_train.hexa:save_checkpoint_gpu
    //   and checkpoint_hexa.hexa decoder. Text not binary because hexa's
    //   write_file uses strlen() (NUL-terminates) and write_bytes needs a boxed
    //   int array per element (>10× memory blowup for 1.5B params). Text round-
    //   trips cleanly through existing decode_checkpoint() and survives R2.
    //
    //   Disk cost: ~15 chars/float × 1.5B params ≈ 22 GB/ckpt (text).
    //   MFS quota rule still applies — caller must rotate step_* siblings.
    //
    //   Format:
    //     HEXACKPT-v1\n
    //     __META__ step=<s> val_ce=<f> phi=<f> phase=<p> n_layer=<nl> vocab=<v> d=<d> d_ff=<ff> rank=<r>\n
    //     tok_emb <vocab> <d>\n <floats...>\n
    //     L<i>_Wq <d> <d>\n <floats...>\n         (× n_layer × 9 tensors per block)
    //     L<i>_Wk <d> <d_kv>\n ...
    //     L<i>_Wv <d> <d_kv>\n ...
    //     L<i>_Wo <d> <d>\n ...
    //     L<i>_ga  1  <d>\n ...                    (gamma_attn)
    //     L<i>_Wgate <d> <d_ff>\n ...
    //     L<i>_Wup   <d> <d_ff>\n ...
    //     L<i>_Wdown <d_ff> <d>\n ...
    //     L<i>_gf  1  <d>\n ...                    (gamma_ffn)
    //     gamma_final 1 <d>\n ...
    //     lmh_U <d> <rank>\n ...
    //     lmh_V <rank> <vocab>\n ...
    //     __MANIFEST__ <n_tensors> 1\n

    // (1) pre-save rotation — remove parent step_* siblings. We derive the
    // parent dir via the "/step_" substring; callers pass .../step_<N>/model
    // by convention. Safe no-op if path has no step_ prefix.
    let _mk = exec("mkdir -p \"$(dirname '" + path + "')\" 2>/dev/null")
    let _rot = exec("find \"$(dirname '" + path + "')\" -maxdepth 2 -name 'step_*' -type d "
                  + "! -wholename \"$(dirname '" + path + "')\" -exec rm -rf {} + 2>/dev/null")

    let head_dim = model.d / model.n_head
    let d_kv = model.n_kv_head * head_dim

    // Version gate (2026-04-20): HEXACKPT_V2=1 → binary writer (22× faster).
    // Default v1 until empirically verified on live CLM. BG #34 running
    // ckpt saves stay on v1 — the decoder auto-detects either format.
    let use_v2 = _ckpt_v2_enabled()
    let fmt_tag = if use_v2 == 1 { "HEXACKPT-v2" } else { "HEXACKPT-v1" }

    // (2) atomic save — write to .tmp then rename
    let tmp_path = path + ".tmp"
    let _rm_tmp = exec("rm -f '" + tmp_path + "' 2>/dev/null")

    let mut total_params = 0
    let mut n_tensors = 0

    // Expected tensor count for sanity checks at the manifest field.
    let expected_n_tensors = 1 + model.n_layer * 9 + 3  // tok_emb + 9/block + gamma_final + lmh_U + lmh_V

    if use_v2 == 1 {
        // ── V2 binary header ────────────────────────────────────────
        // Magic: 'H' 'X' 'C' 'K' 'P' 'T' 0x02 0x00
        let _ = _v2_append_bytes(tmp_path, [72, 88, 67, 75, 80, 84, 2, 0])
        let _ = _v2_append_u32(tmp_path, 2)                         // format_version
        let _ = _v2_append_u32(tmp_path, expected_n_tensors)        // tensor_count
        let _ = _v2_append_u64(tmp_path, step)                      // step
        // meta_json (inline, same fields as v1 __META__)
        let meta_json_hdr = "{\"step\":" + str(step)
                          + ",\"val_ce\":" + str(val_ce)
                          + ",\"phi\":" + str(phi)
                          + ",\"phase\":" + str(phase)
                          + ",\"n_layer\":" + str(model.n_layer)
                          + ",\"vocab\":" + str(model.vocab)
                          + ",\"d\":" + str(model.d)
                          + ",\"d_ff\":" + str(model.d_ff)
                          + ",\"n_head\":" + str(model.n_head)
                          + ",\"n_kv_head\":" + str(model.n_kv_head)
                          + ",\"rank\":" + str(model.lmh_rank) + "}"
        let _ = _v2_append_u32(tmp_path, len(meta_json_hdr))
        let _ = _v2_append_str_bytes(tmp_path, meta_json_hdr)

        // ── V2 tensor entries ────────────────────────────────────────
        total_params = total_params + _ckpt_v2_write_tensor(tmp_path, "tok_emb",
                                                            model.vocab, model.d, model.tok_emb)
        n_tensors = n_tensors + 1
        let mut li2 = 0
        while li2 < model.n_layer {
            let prefix2 = "L" + str(li2) + "_"
            let blk2 = model.blocks[li2]
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wq",
                                                                model.d, model.d, blk2.Wq)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wk",
                                                                model.d, d_kv, blk2.Wk)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wv",
                                                                model.d, d_kv, blk2.Wv)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wo",
                                                                model.d, model.d, blk2.Wo)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "ga",
                                                                1, model.d, blk2.gamma_attn)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wgate",
                                                                model.d, model.d_ff, blk2.Wgate)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wup",
                                                                model.d, model.d_ff, blk2.Wup)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "Wdown",
                                                                model.d_ff, model.d, blk2.Wdown)
            total_params = total_params + _ckpt_v2_write_tensor(tmp_path, prefix2 + "gf",
                                                                1, model.d, blk2.gamma_ffn)
            n_tensors = n_tensors + 9
            li2 = li2 + 1
        }
        total_params = total_params + _ckpt_v2_write_tensor(tmp_path, "gamma_final",
                                                            1, model.d, model.gamma_final)
        total_params = total_params + _ckpt_v2_write_tensor(tmp_path, "lmh_U",
                                                            model.d, model.lmh_rank, model.lmh_U)
        total_params = total_params + _ckpt_v2_write_tensor(tmp_path, "lmh_V",
                                                            model.lmh_rank, model.vocab, model.lmh_V)
        n_tensors = n_tensors + 3
    } else {
        // ── V1 text path (preserved verbatim for BG #34 compat) ────
        let _ = write_file(tmp_path, "HEXACKPT-v1\n")
        let meta = "__META__"
                 + " step=" + str(step)
                 + " val_ce=" + str(val_ce)
                 + " phi=" + str(phi)
                 + " phase=" + str(phase)
                 + " n_layer=" + str(model.n_layer)
                 + " vocab=" + str(model.vocab)
                 + " d=" + str(model.d)
                 + " d_ff=" + str(model.d_ff)
                 + " n_head=" + str(model.n_head)
                 + " n_kv_head=" + str(model.n_kv_head)
                 + " rank=" + str(model.lmh_rank)
                 + "\n"
        let _ = append_file(tmp_path, meta)

        // Embedding
        total_params = total_params + _ckpt_append_tensor(tmp_path, "tok_emb",
                                                          model.vocab, model.d, model.tok_emb)
        n_tensors = n_tensors + 1

        // Per-block weights (9 tensors each)
        let mut li = 0
        while li < model.n_layer {
            let prefix = "L" + str(li) + "_"
            let blk = model.blocks[li]
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wq",
                                                              model.d, model.d, blk.Wq)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wk",
                                                              model.d, d_kv, blk.Wk)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wv",
                                                              model.d, d_kv, blk.Wv)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wo",
                                                              model.d, model.d, blk.Wo)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "ga",
                                                              1, model.d, blk.gamma_attn)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wgate",
                                                              model.d, model.d_ff, blk.Wgate)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wup",
                                                              model.d, model.d_ff, blk.Wup)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "Wdown",
                                                              model.d_ff, model.d, blk.Wdown)
            total_params = total_params + _ckpt_append_tensor(tmp_path, prefix + "gf",
                                                              1, model.d, blk.gamma_ffn)
            n_tensors = n_tensors + 9
            li = li + 1
        }

        // Final norm + LM head (UV decomposition, DD175 #1)
        total_params = total_params + _ckpt_append_tensor(tmp_path, "gamma_final",
                                                          1, model.d, model.gamma_final)
        total_params = total_params + _ckpt_append_tensor(tmp_path, "lmh_U",
                                                          model.d, model.lmh_rank, model.lmh_U)
        total_params = total_params + _ckpt_append_tensor(tmp_path, "lmh_V",
                                                          model.lmh_rank, model.vocab, model.lmh_V)
        n_tensors = n_tensors + 3

        let _ = append_file(tmp_path, "__MANIFEST__ " + str(n_tensors) + " 1\n")
    }

    // (3) atomic rename tmp → final
    let _rn = exec("mv '" + tmp_path + "' '" + path + "'")

    // (4) sidecar meta.json for quick resume-state inspection
    let meta_path = path + ".meta.json"
    let meta_json = "{\"step\":" + str(step)
                  + ",\"val_ce\":" + str(val_ce)
                  + ",\"phi\":" + str(phi)
                  + ",\"phase\":" + str(phase)
                  + ",\"n_tensors\":" + str(n_tensors)
                  + ",\"total_params\":" + str(total_params)
                  + ",\"format\":\"" + fmt_tag + "\"}"
    let _ = write_file(meta_path, meta_json)

    // (5) DEFERRED R2 queue — external rclone consumes this post-training
    let r2_line = path + "\tr2:anima-models/clm/step_" + str(step) + "/\n"
    let _ = append_file("/workspace/r2_upload_queue.txt", r2_line)

    // ROOT CAUSE: same hexa multi-arg println bug fixed in the step log
    // (see train_clm.hexa:~3510 for full citation of bug_id
    // clm_step0_silent_abort_20260420). Use + str(...) concat.
    println("[save_checkpoint] OK path=" + path
          + " step=" + str(step)
          + " n_tensors=" + str(n_tensors)
          + " total_params=" + str(total_params)
          + " val_ce=" + str(val_ce)
          + " phi=" + str(phi)
          + " phase=" + str(phase))
    Checkpoint { path: path, step: step, val_ce: val_ce, phi: phi, phase: phase }
}

// ═════════════════════════════════════════════════════════════════════
// r5-a3.5 — HEXACKPT-v1 weight DECODER (single fn ckpt_load_weights)
// ═════════════════════════════════════════════════════════════════════
//
// Mirrors save_checkpoint above. Reads the text-format ckpt produced by
// _ckpt_append_tensor + the __META__/__MANIFEST__ wrapper, then returns
// a fresh DecoderModel with every tensor populated from disk.
//
// Format recap (per save_checkpoint at line ~931):
//   HEXACKPT-v1\n
//   __META__ step=N val_ce=X phi=Y phase=P n_layer=L vocab=V d=D
//            d_ff=F n_head=H n_kv_head=KV rank=R\n
//   <tensor_name> <rows> <cols>\n<f0> <f1> ... <fN>\n     (× n_tensors)
//   __MANIFEST__ <n_tensors> 1\n
//
// Tensor order is fixed:
//   tok_emb, [L<i>_(Wq Wk Wv Wo ga Wgate Wup Wdown gf) × n_layer],
//   gamma_final, lmh_U, lmh_V
//
// Caller contract:
//   - target_model must be pre-allocated with the right shape (caller
//     constructs decoder_model_new(cfg) first, then we overwrite
//     tensor data in-place via struct rebuild).
//   - Shape mismatch between disk + model = HARD FAIL (println + return
//     fresh model untouched). We fail loud rather than silently load
//     partial weights — the bit-exact selftest depends on this.

// ── Helper: locate next '\n' from position `start`. Returns -1 if none.
fn _ckpt_find_nl(text: string, start: int, n: int) -> int {
    let mut i = start
    while i < n {
        if text.substring(i, i + 1) == "\n" { return i }
        i = i + 1
    }
    return -1
}

// ── Helper: parse a whitespace-separated float list from a slice ──
// Uses split(" ") on the slice — single linear pass per tensor.
// Trailing leading-space artifacts from the batched _ckpt_append_tensor
// writer (which carries a leading space across batch boundaries) are
// silently skipped (split returns "" for double-spaces; we skip empties).
fn _ckpt_parse_floats(slice: string, expect_n: int) -> [float] {
    let parts = slice.split(" ")
    let np = len(parts)
    let mut out = []
    let mut i = 0
    while i < np {
        let p = parts[i].trim()
        if p != "" && p != "\n" {
            out = out.push(to_float(p))
            if len(out) >= expect_n { return out }
        }
        i = i + 1
    }
    return out
}

// ── Helper: read a tensor section (header line already consumed) ──
// Returns [data_array, next_offset]. data_array is empty on parse error.
fn _ckpt_read_tensor_data(text: string, start: int, n: int, expect: int) -> [int] {
    // The data line runs from `start` to the next '\n'. Slice + split.
    let nl = _ckpt_find_nl(text, start, n)
    let end = if nl < 0 { n } else { nl }
    // Caller pulls the slice; we just return the boundary for them.
    let mut r = []
    r = r.push(start)
    r = r.push(end)
    return r
}

// ── Helper: locate tensor by name in HEXACKPT text, return [data_start, data_end, rows, cols].
// Returns [] on miss. O(N) per call — caller batches via single sequential walk.
// Not currently used by ckpt_load_weights (which uses sequential walk for
// memory locality) but kept for one-off lookups (e.g. resume_step inspection).
fn _ckpt_locate(text: string, name: string) -> [int] {
    let n = len(text)
    let needle = "\n" + name + " "
    let pos = text.index_of(needle)
    if pos < 0 { return [] }
    // Header starts right after the '\n'
    let h_start = pos + 1
    let h_end = _ckpt_find_nl(text, h_start, n)
    if h_end < 0 { return [] }
    let header = text.substring(h_start, h_end)
    let parts = header.split(" ")
    if len(parts) < 3 { return [] }
    let rows = to_int(parts[1].trim())
    let cols = to_int(parts[2].trim())
    let d_start = h_end + 1
    let d_end = _ckpt_find_nl(text, d_start, n)
    let d_end_safe = if d_end < 0 { n } else { d_end }
    let mut r = []
    r = r.push(d_start)
    r = r.push(d_end_safe)
    r = r.push(rows)
    r = r.push(cols)
    return r
}

// ── Pull a named tensor's data as [float], or [] on miss / shape mismatch.
fn _ckpt_pull_tensor(text: string, name: string, expect_rows: int, expect_cols: int) -> [float] {
    let loc = _ckpt_locate(text, name)
    if len(loc) < 4 {
        println("[ckpt_load_weights] MISS tensor '" + name + "' not found in ckpt")
        return []
    }
    let d_start = loc[0]
    let d_end   = loc[1]
    let rows    = loc[2]
    let cols    = loc[3]
    if rows != expect_rows || cols != expect_cols {
        println("[ckpt_load_weights] SHAPE MISMATCH '" + name + "': ckpt=("
              + str(rows) + "," + str(cols) + ") expected=("
              + str(expect_rows) + "," + str(expect_cols) + ")")
        return []
    }
    let slice = text.substring(d_start, d_end)
    let expect_n = rows * cols
    let data = _ckpt_parse_floats(slice, expect_n)
    if len(data) != expect_n {
        println("[ckpt_load_weights] DATA SHORT '" + name + "': got "
              + str(len(data)) + " floats, expected " + str(expect_n))
        return []
    }
    return data
}

// ── Resume meta extractor: pull step counter from ckpt.
// Auto-detects v1 (text "step=<N>") or v2 (u64 at byte 16).
// Returns -1 if missing. Used by --resume to verify the step counter
// recorded in the ckpt matches the directory name (sanity check).
fn ckpt_meta_step(path: string) -> int {
    if file_exists(path) == false { return -1 }
    // Probe first 8 bytes for v2 magic.
    let head = read_bytes_at(path, 0, 8)
    if len(head) >= 8 {
        if head[0] == 72 && head[1] == 88 && head[2] == 67 && head[3] == 75
        && head[4] == 80 && head[5] == 84 && head[6] == 2 && head[7] == 0 {
            // v2 — read step (u64) at offset 16
            let step_bytes = read_bytes_at(path, 16, 8)
            if len(step_bytes) < 8 { return -1 }
            let step_pair = _v2_read_u64(step_bytes, 0)
            return step_pair[0]
        }
    }
    // v1 fallback — look for "step=<N>" marker in text
    let text = read_file(path)
    if len(text) == 0 { return -1 }
    let marker = "step="
    let pos = text.index_of(marker)
    if pos < 0 { return -1 }
    let n = len(text)
    let mut i = pos + 5  // len("step=")
    let mut s = ""
    while i < n {
        let c = text.substring(i, i + 1)
        if c == " " || c == "\n" || c == "\t" { break }
        s = s + c
        i = i + 1
    }
    if s == "" { return -1 }
    return to_int(s)
}

// ═════════════════════════════════════════════════════════════════════
// HEXACKPT-v2 binary decoder helpers (2026-04-20)
// Works on a byte-array `buf` (from read_file_bytes or read_bytes_at).
// All multi-byte ints are little-endian.
// ═════════════════════════════════════════════════════════════════════

// Read LE u16 from a byte array at offset. Returns [value, next_offset].
fn _v2_read_u16(buf: [int], off: int) -> [int] {
    let b0 = buf[off]
    let b1 = buf[off + 1]
    let v = b0 + b1 * 256
    return [v, off + 2]
}
// Read LE u32. Returns [value, next_offset].
fn _v2_read_u32(buf: [int], off: int) -> [int] {
    let b0 = buf[off]
    let b1 = buf[off + 1]
    let b2 = buf[off + 2]
    let b3 = buf[off + 3]
    let v = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
    return [v, off + 4]
}
// Read LE u64. Returns [value, next_offset]. NOTE: only low 63 bits are
// safe in hexa int (i64 signed) — sufficient for `step` counter.
fn _v2_read_u64(buf: [int], off: int) -> [int] {
    let lo_pair = _v2_read_u32(buf, off)
    let hi_pair = _v2_read_u32(buf, off + 4)
    // low + high * 2^32 — use multiply instead of shift to stay portable
    let v = lo_pair[0] + hi_pair[0] * 4294967296
    return [v, off + 8]
}
// Read UTF-8 bytes [off, off+n) as a hexa string.
fn _v2_read_str(buf: [int], off: int, n: int) -> string {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + chr(buf[off + i])
        i = i + 1
    }
    return s
}
// Decode fp32 bits → float. Uses alloc_raw + write_i32 + deref_f32 so the
// C side does the IEEE-754 reinterpret via memcpy (no platform-dependent
// cast). Inverse of _v2_f32_bits.
fn _v2_bits_to_f32(bits: int) -> float {
    let buf = alloc_raw(4)
    write_i32(buf, 0, bits)
    let f = deref_f32(buf, 0)
    free_raw(buf)
    return f
}
// Read `n` fp32 values starting at offset. Returns [float] list.
fn _v2_read_floats(buf: [int], off: int, n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n {
        let b0 = buf[off + i * 4]
        let b1 = buf[off + i * 4 + 1]
        let b2 = buf[off + i * 4 + 2]
        let b3 = buf[off + i * 4 + 3]
        let bits = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
        out = out.push(_v2_bits_to_f32(bits))
        i = i + 1
    }
    return out
}

// Structured v2 tensor entry after one walk step.
struct _V2Tensor {
    name: string,
    rows: int,
    cols: int,
    data: [float]
}

// Walk one tensor entry starting at offset. Returns [V2Tensor, next_off].
// On format error returns a sentinel V2Tensor with name="" and next_off=-1.
fn _v2_read_tensor(buf: [int], off: int, buf_len: int) -> [int] {
    // name_len u16
    if off + 2 > buf_len { return [-1] }
    let nl_pair = _v2_read_u16(buf, off)
    let name_len = nl_pair[0]
    let after_nl = nl_pair[1]
    if after_nl + name_len + 2 > buf_len { return [-1] }
    let name = _v2_read_str(buf, after_nl, name_len)
    let after_name = after_nl + name_len
    let dtype = buf[after_name]
    let rank = buf[after_name + 1]
    if rank != 2 {
        println("[v2_decoder] unsupported rank " + str(rank) + " for tensor " + name)
        return [-1]
    }
    let shape_off = after_name + 2
    let rows_pair = _v2_read_u32(buf, shape_off)
    let cols_pair = _v2_read_u32(buf, shape_off + 4)
    let rows = rows_pair[0]
    let cols = cols_pair[0]
    let data_off = shape_off + 8
    let n = rows * cols
    if dtype != 0 {
        // fp32 only in v2; bf16 reserved for future (format_version bump).
        println("[v2_decoder] unsupported dtype " + str(dtype) + " — fp32 only")
        return [-1]
    }
    if data_off + n * 4 > buf_len { return [-1] }
    // Return name, rows, cols, data_off, next_off — caller builds tensor.
    // We return ints only to avoid hexa multi-field struct return quirks
    // (feedback_hexa_struct_return_bug); caller reads floats separately.
    return [rows, cols, data_off, data_off + n * 4, name_len, after_nl]
}

// V2 pull: look up a tensor by name by walking the file. Returns [] on miss.
// Walks sequentially from the first tensor offset (precomputed by caller).
fn _v2_pull_tensor(buf: [int], buf_len: int, first_off: int,
                   want: string, expect_rows: int, expect_cols: int) -> [float] {
    let mut off = first_off
    while off >= 0 && off < buf_len {
        if off + 2 > buf_len { return [] }
        let nl_pair = _v2_read_u16(buf, off)
        let name_len = nl_pair[0]
        let after_nl = nl_pair[1]
        if after_nl + name_len + 2 > buf_len { return [] }
        let name = _v2_read_str(buf, after_nl, name_len)
        let after_name = after_nl + name_len
        let dtype = buf[after_name]
        let rank = buf[after_name + 1]
        if rank != 2 {
            println("[v2_decoder] rank " + str(rank) + " unsupported on '" + name + "'")
            return []
        }
        let rows_pair = _v2_read_u32(buf, after_name + 2)
        let cols_pair = _v2_read_u32(buf, after_name + 6)
        let rows = rows_pair[0]
        let cols = cols_pair[0]
        let data_off = after_name + 10
        let n = rows * cols
        let next_off = data_off + n * 4
        if name == want {
            if rows != expect_rows || cols != expect_cols {
                println("[v2_decoder] SHAPE MISMATCH '" + name + "': ckpt=("
                      + str(rows) + "," + str(cols) + ") expected=("
                      + str(expect_rows) + "," + str(expect_cols) + ")")
                return []
            }
            if dtype != 0 {
                println("[v2_decoder] dtype " + str(dtype) + " unsupported on '" + name + "'")
                return []
            }
            return _v2_read_floats(buf, data_off, n)
        }
        off = next_off
    }
    return []
}

// Find offset of first tensor entry after the v2 header. Returns -1 if
// not a v2 file (magic mismatch) or truncated.
fn _v2_first_tensor_offset(buf: [int], buf_len: int) -> int {
    // Need at minimum: 8 magic + 4 ver + 4 cnt + 8 step + 4 meta_len + 0 meta = 28
    if buf_len < 28 { return -1 }
    // Magic: 'H' 'X' 'C' 'K' 'P' 'T' 0x02 0x00
    if buf[0] != 72 { return -1 }
    if buf[1] != 88 { return -1 }
    if buf[2] != 67 { return -1 }
    if buf[3] != 75 { return -1 }
    if buf[4] != 80 { return -1 }
    if buf[5] != 84 { return -1 }
    if buf[6] != 2  { return -1 }
    if buf[7] != 0  { return -1 }
    // fmt_version (u32) @ 8..11 — must be 2
    let ver_pair = _v2_read_u32(buf, 8)
    if ver_pair[0] != 2 {
        println("[v2_decoder] format_version " + str(ver_pair[0]) + " unsupported")
        return -1
    }
    // tensor_count u32 @ 12..15 (ignored here; used by validation)
    // step u64 @ 16..23
    // meta_len u32 @ 24..27
    let meta_len_pair = _v2_read_u32(buf, 24)
    let meta_len = meta_len_pair[0]
    let first_tensor_off = 28 + meta_len
    if first_tensor_off > buf_len { return -1 }
    return first_tensor_off
}

// Extract step counter from a v2 ckpt (u64 @ offset 16). Returns -1 on bad.
fn _v2_meta_step(buf: [int], buf_len: int) -> int {
    if _v2_first_tensor_offset(buf, buf_len) < 0 { return -1 }
    let step_pair = _v2_read_u64(buf, 16)
    return step_pair[0]
}

// ── MAIN DECODER: load weights from path, return new DecoderModel ──
// Caller passes a freshly-constructed `template` model with the right
// shape (decoder_model_new(cfg)). We pull each tensor by name and
// rebuild the struct. On any per-tensor failure we keep the template's
// (random) weight for that tensor and continue — partial-load is
// preferable to a total init from scratch when only one tensor is bad.
// Returns: [DecoderModel, n_loaded_tensors] packed as [model, count].
struct CkptLoadResult {
    model: DecoderModel,
    n_loaded: int,
    n_expected: int
}

fn ckpt_load_weights(path: string, template: DecoderModel) -> CkptLoadResult {
    println("[ckpt_load_weights] reading " + path)
    if file_exists(path) == false {
        println("[ckpt_load_weights] FAIL: file not found: " + path)
        return CkptLoadResult { model: template, n_loaded: 0, n_expected: 0 }
    }
    // ── Auto-detect v1 vs v2 by reading first 8 bytes ─────────────
    let head_bytes = read_bytes_at(path, 0, 8)
    if len(head_bytes) < 8 {
        println("[ckpt_load_weights] FAIL: file too short for magic")
        return CkptLoadResult { model: template, n_loaded: 0, n_expected: 0 }
    }
    // v2 magic: 'H' 'X' 'C' 'K' 'P' 'T' 0x02 0x00
    let is_v2 = (head_bytes[0] == 72 && head_bytes[1] == 88 && head_bytes[2] == 67
              && head_bytes[3] == 75 && head_bytes[4] == 80 && head_bytes[5] == 84
              && head_bytes[6] == 2 && head_bytes[7] == 0)
    if is_v2 {
        return _ckpt_load_weights_v2(path, template)
    }
    // v1 text path (pre-existing behavior)
    let text = read_file(path)
    let nb = len(text)
    if nb < 12 {
        println("[ckpt_load_weights] FAIL: too short (" + str(nb) + " bytes)")
        return CkptLoadResult { model: template, n_loaded: 0, n_expected: 0 }
    }
    let magic = text.substring(0, 11)
    if magic != "HEXACKPT-v1" {
        println("[ckpt_load_weights] FAIL: bad magic '" + magic + "'")
        return CkptLoadResult { model: template, n_loaded: 0, n_expected: 0 }
    }
    println("[ckpt_load_weights] magic OK (v1), file=" + str(nb) + " bytes, n_layer=" + str(template.n_layer))

    let d       = template.d
    let d_ff    = template.d_ff
    let n_layer = template.n_layer
    let n_head  = template.n_head
    let n_kv    = template.n_kv_head
    let head_dim = d / n_head
    let d_kv    = n_kv * head_dim
    let vocab   = template.vocab
    let rank    = template.lmh_rank
    let n_expected = 1 + n_layer * 9 + 3   // tok_emb + 9/block + gamma_final + lmh_U + lmh_V
    let mut n_loaded = 0

    // ── Embedding ──
    let new_tok_emb = _ckpt_pull_tensor(text, "tok_emb", vocab, d)
    let tok_emb_final = if len(new_tok_emb) == vocab * d {
        n_loaded = n_loaded + 1
        new_tok_emb
    } else {
        template.tok_emb
    }

    // ── Per-block weights ──
    let mut new_blocks = []
    let mut li = 0
    while li < n_layer {
        let prefix = "L" + str(li) + "_"
        let blk_t = template.blocks[li]
        let v_Wq    = _ckpt_pull_tensor(text, prefix + "Wq",    d, d)
        let v_Wk    = _ckpt_pull_tensor(text, prefix + "Wk",    d, d_kv)
        let v_Wv    = _ckpt_pull_tensor(text, prefix + "Wv",    d, d_kv)
        let v_Wo    = _ckpt_pull_tensor(text, prefix + "Wo",    d, d)
        let v_ga    = _ckpt_pull_tensor(text, prefix + "ga",    1, d)
        let v_Wgate = _ckpt_pull_tensor(text, prefix + "Wgate", d, d_ff)
        let v_Wup   = _ckpt_pull_tensor(text, prefix + "Wup",   d, d_ff)
        let v_Wdown = _ckpt_pull_tensor(text, prefix + "Wdown", d_ff, d)
        let v_gf    = _ckpt_pull_tensor(text, prefix + "gf",    1, d)
        let blk_loaded = DecoderBlockW {
            Wq:        if len(v_Wq)    == d * d        { n_loaded = n_loaded + 1; v_Wq    } else { blk_t.Wq        },
            Wk:        if len(v_Wk)    == d * d_kv     { n_loaded = n_loaded + 1; v_Wk    } else { blk_t.Wk        },
            Wv:        if len(v_Wv)    == d * d_kv     { n_loaded = n_loaded + 1; v_Wv    } else { blk_t.Wv        },
            Wo:        if len(v_Wo)    == d * d        { n_loaded = n_loaded + 1; v_Wo    } else { blk_t.Wo        },
            gamma_attn:if len(v_ga)    == d            { n_loaded = n_loaded + 1; v_ga    } else { blk_t.gamma_attn},
            Wgate:     if len(v_Wgate) == d * d_ff     { n_loaded = n_loaded + 1; v_Wgate } else { blk_t.Wgate     },
            Wup:       if len(v_Wup)   == d * d_ff     { n_loaded = n_loaded + 1; v_Wup   } else { blk_t.Wup       },
            Wdown:     if len(v_Wdown) == d_ff * d     { n_loaded = n_loaded + 1; v_Wdown } else { blk_t.Wdown     },
            gamma_ffn: if len(v_gf)    == d            { n_loaded = n_loaded + 1; v_gf    } else { blk_t.gamma_ffn }
        }
        new_blocks = new_blocks.push(blk_loaded)
        li = li + 1
    }

    // ── Final norm + LM head ──
    let v_gamma_final = _ckpt_pull_tensor(text, "gamma_final", 1, d)
    let gamma_final_loaded = if len(v_gamma_final) == d {
        n_loaded = n_loaded + 1
        v_gamma_final
    } else { template.gamma_final }

    let v_U = _ckpt_pull_tensor(text, "lmh_U", d, rank)
    let lmh_U_loaded = if len(v_U) == d * rank {
        n_loaded = n_loaded + 1
        v_U
    } else { template.lmh_U }

    let v_V = _ckpt_pull_tensor(text, "lmh_V", rank, vocab)
    let lmh_V_loaded = if len(v_V) == rank * vocab {
        n_loaded = n_loaded + 1
        v_V
    } else { template.lmh_V }

    let restored = DecoderModel {
        d: template.d, d_ff: template.d_ff, n_layer: template.n_layer,
        n_head: template.n_head, n_kv_head: template.n_kv_head,
        vocab: template.vocab, lmh_rank: template.lmh_rank,
        tok_emb: tok_emb_final,
        blocks: new_blocks,
        gamma_final: gamma_final_loaded,
        lmh_U: lmh_U_loaded,
        lmh_V: lmh_V_loaded
    }
    println("[ckpt_load_weights] OK — loaded " + str(n_loaded) + "/" + str(n_expected) + " tensors")
    return CkptLoadResult { model: restored, n_loaded: n_loaded, n_expected: n_expected }
}

// ═════════════════════════════════════════════════════════════════════
// V2 binary weight loader — called from ckpt_load_weights auto-detect
// ═════════════════════════════════════════════════════════════════════
fn _ckpt_load_weights_v2(path: string, template: DecoderModel) -> CkptLoadResult {
    println("[ckpt_load_weights] magic OK (v2 binary), loading " + path)
    let buf = read_file_bytes(path)
    let buf_len = len(buf)
    let first_off = _v2_first_tensor_offset(buf, buf_len)
    if first_off < 0 {
        println("[ckpt_load_weights] FAIL: v2 header invalid")
        return CkptLoadResult { model: template, n_loaded: 0, n_expected: 0 }
    }
    let d       = template.d
    let d_ff    = template.d_ff
    let n_layer = template.n_layer
    let n_head  = template.n_head
    let n_kv    = template.n_kv_head
    let head_dim = d / n_head
    let d_kv    = n_kv * head_dim
    let vocab   = template.vocab
    let rank    = template.lmh_rank
    let n_expected = 1 + n_layer * 9 + 3
    let mut n_loaded = 0

    // ── Embedding ──
    let v_tok_emb = _v2_pull_tensor(buf, buf_len, first_off, "tok_emb", vocab, d)
    let tok_emb_final = if len(v_tok_emb) == vocab * d {
        n_loaded = n_loaded + 1
        v_tok_emb
    } else { template.tok_emb }

    // ── Per-block weights ──
    let mut new_blocks = []
    let mut li = 0
    while li < n_layer {
        let prefix = "L" + str(li) + "_"
        let blk_t = template.blocks[li]
        let v_Wq    = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wq",    d, d)
        let v_Wk    = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wk",    d, d_kv)
        let v_Wv    = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wv",    d, d_kv)
        let v_Wo    = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wo",    d, d)
        let v_ga    = _v2_pull_tensor(buf, buf_len, first_off, prefix + "ga",    1, d)
        let v_Wgate = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wgate", d, d_ff)
        let v_Wup   = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wup",   d, d_ff)
        let v_Wdown = _v2_pull_tensor(buf, buf_len, first_off, prefix + "Wdown", d_ff, d)
        let v_gf    = _v2_pull_tensor(buf, buf_len, first_off, prefix + "gf",    1, d)
        let blk_loaded = DecoderBlockW {
            Wq:        if len(v_Wq)    == d * d        { n_loaded = n_loaded + 1; v_Wq    } else { blk_t.Wq        },
            Wk:        if len(v_Wk)    == d * d_kv     { n_loaded = n_loaded + 1; v_Wk    } else { blk_t.Wk        },
            Wv:        if len(v_Wv)    == d * d_kv     { n_loaded = n_loaded + 1; v_Wv    } else { blk_t.Wv        },
            Wo:        if len(v_Wo)    == d * d        { n_loaded = n_loaded + 1; v_Wo    } else { blk_t.Wo        },
            gamma_attn:if len(v_ga)    == d            { n_loaded = n_loaded + 1; v_ga    } else { blk_t.gamma_attn},
            Wgate:     if len(v_Wgate) == d * d_ff     { n_loaded = n_loaded + 1; v_Wgate } else { blk_t.Wgate     },
            Wup:       if len(v_Wup)   == d * d_ff     { n_loaded = n_loaded + 1; v_Wup   } else { blk_t.Wup       },
            Wdown:     if len(v_Wdown) == d_ff * d     { n_loaded = n_loaded + 1; v_Wdown } else { blk_t.Wdown     },
            gamma_ffn: if len(v_gf)    == d            { n_loaded = n_loaded + 1; v_gf    } else { blk_t.gamma_ffn }
        }
        new_blocks = new_blocks.push(blk_loaded)
        li = li + 1
    }

    let v_gf_final = _v2_pull_tensor(buf, buf_len, first_off, "gamma_final", 1, d)
    let gamma_final_loaded = if len(v_gf_final) == d {
        n_loaded = n_loaded + 1
        v_gf_final
    } else { template.gamma_final }

    let v_U = _v2_pull_tensor(buf, buf_len, first_off, "lmh_U", d, rank)
    let lmh_U_loaded = if len(v_U) == d * rank {
        n_loaded = n_loaded + 1
        v_U
    } else { template.lmh_U }

    let v_V = _v2_pull_tensor(buf, buf_len, first_off, "lmh_V", rank, vocab)
    let lmh_V_loaded = if len(v_V) == rank * vocab {
        n_loaded = n_loaded + 1
        v_V
    } else { template.lmh_V }

    let restored = DecoderModel {
        d: template.d, d_ff: template.d_ff, n_layer: template.n_layer,
        n_head: template.n_head, n_kv_head: template.n_kv_head,
        vocab: template.vocab, lmh_rank: template.lmh_rank,
        tok_emb: tok_emb_final,
        blocks: new_blocks,
        gamma_final: gamma_final_loaded,
        lmh_U: lmh_U_loaded,
        lmh_V: lmh_V_loaded
    }
    println("[ckpt_load_weights] OK (v2) — loaded " + str(n_loaded) + "/" + str(n_expected) + " tensors")
    return CkptLoadResult { model: restored, n_loaded: n_loaded, n_expected: n_expected }
}

// ─── Consciousness verification gate (Law 49) ───
fn verify_phi_non_destructive(phi_before: float, phi_after: float) -> bool {
    // CDO rule: Φ drop > 5% → reject checkpoint.
    let ratio = phi_after / (phi_before + 0.0001)
    ratio >= 0.95
}

// ─── Training loop ───
struct TrainState {
    scale: ScaleConfig,
    opt: OptimState,
    pm: PhaseManager,
    step: int,
    best_val_ce: float,
    patience_left: int,
    qc: QuantumController,      // Orch-OR controller — advances per train_step
    phi_q_norm: float           // last phi_q_norm ∈ [0, 1], for logging
}

fn train_init(cfg: ScaleConfig, total_steps: int) -> TrainState {
    TrainState {
        scale: cfg,
        opt: optim_new(cfg, total_steps),
        pm: phase_new(total_steps),
        step: 0,
        best_val_ce: 999999.0,
        patience_left: DEFAULT_PATIENCE,
        qc: quantum_controller_new(cfg.atoms, cfg.cells_per_atom),
        phi_q_norm: 0.0
    }
}

// ═══════════════════════════════════════════════════════════════════════
// DECODER BODY — Real forward/backward pipeline
// ═══════════════════════════════════════════════════════════════════════
//
// Full decoder pipeline:
//   embed → NL decoder blocks → RMS norm → LM head (U+V) → softmax → CE → backward
//
// Architecture per block (pre-norm transformer, matches conscious_decoder.hexa):
//   1. RMS norm → QKV projection → causal attention → residual
//   2. RMS norm → SwiGLU FFN (gate_proj * up_proj → down_proj) → residual
//
// DD175 techniques integrated:
//   #1 LM head U+V factorization (models/lm_head_uv.hexa pattern)
//   #2 BLAS-only loss/backward (training/loss_blas_only.hexa pattern)
//
// All BLAS primitives inlined (no use-import path wired yet from train_clm).
// Once hexa-side use-import lands, replace with:
//   use "nn_core"
//   use "loss_blas_only"
//   use "lm_head_uv"

// ─── §A0  BLAS FFI (cblas_sgemm via hxblas_wrapper.c) ─────────────
//
// ROOT CAUSE FIX (blocker #1, 2026-04-16): _block_attn inner loops were
// O(S²D) scalar hexa ops — _tslice + _tdot per (i,j) pair with boxed int
// index arithmetic. These loops dominated 60%+ of step time at d>=128.
//
// Fix: marshal list→raw f32 buffer, call cblas_sgemm for Q@K^T and probs@V,
// use fused C softmax (hxblas_attn_softmax_causal) for scale+mask+softmax.
// Expected 10-50x speedup on the attention hot path.
//
// Physical path:
//   training/hxblas_wrapper.c → training/build/libhxblas.dylib
//   → cblas_sgemm (Accelerate on Apple, OpenBLAS on Linux)

@link("/Users/ghost/Dev/anima/training/build/libhxblas.dylib")
extern fn hxblas_sgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: *Void, lda: int, B: *Void, ldb: int, beta: float, C: *Void, ldc: int)

// Fused scale + causal mask + softmax over S×S scores matrix (in-place).
// Replaces O(S²) scalar loop with native C float* path.
@link("/Users/ghost/Dev/anima/training/build/libhxblas.dylib")
extern fn hxblas_attn_softmax_causal(S: int, scale: float, scores: int)

// CBLAS enum constants (row-major, no-transpose, transpose)
comptime const CBLAS_ROW_MAJOR = 101
comptime const CBLAS_NO_TRANS  = 111
comptime const CBLAS_TRANS     = 112

// ─── §A0.2  hxlmhead FFI (fused LM-head backward via BLAS) ───────
//
// Gated on HXLMHEAD_FFI=1 env var. When active, replaces the naive
// triple-loop matmuls in decoder_backward (lines 1056-1104) with a
// single C dispatch through hxlmhead_bwd. The C kernel does:
//   forward recompute (mid = x@Wu, logits = mid@Wv),
//   softmax + CE loss,
//   all 4 backward matmuls (dWv, dmid, dWu, dx)
// via cblas_sgemm (Accelerate on Mac, OpenBLAS on Linux).
//
// Library: hexa-lang/self/native/build/libhxlmhead.dylib
// Source:  hexa-lang/self/native/hxlmhead_linux.c (v1: BLAS route)
// Binding: hexa-lang/self/ml/hxlmhead.hexa

@link("/Users/ghost/Dev/hexa-lang/self/native/build/libhxlmhead.dylib")
extern fn hxlmhead_bwd(args_p: *Void) -> int

@link("/Users/ghost/Dev/hexa-lang/self/native/build/libhxlmhead.dylib")
extern fn hxlmhead_version() -> int

// HxLMHeadArgs struct field offsets (bytes). Must match hxlmhead_linux.c.
comptime const HXLMH_OFF_S          = 0
comptime const HXLMH_OFF_H          = 8
comptime const HXLMH_OFF_M          = 16
comptime const HXLMH_OFF_V          = 24
comptime const HXLMH_OFF_LOSS_SCALE = 32
comptime const HXLMH_OFF_X          = 40
comptime const HXLMH_OFF_MID        = 48
comptime const HXLMH_OFF_TARGETS    = 56
comptime const HXLMH_OFF_WU         = 64
comptime const HXLMH_OFF_WV         = 72
comptime const HXLMH_OFF_DL_DX      = 80
comptime const HXLMH_OFF_DW_U       = 88
comptime const HXLMH_OFF_DW_V       = 96
comptime const HXLMH_OFF_LOSS_OUT   = 104
comptime const HXLMH_OFF_RESERVED0  = 112
comptime const HXLMH_STRUCT_BYTES   = 120

// ─── §A0.1  List↔raw buffer marshalling ───────────────────────────
//
// _block_attn uses [float] lists for its interface (Q/K/V/output are all
// [float]). BLAS requires contiguous f32 buffers. These helpers marshal
// between the two representations. The copy overhead is O(N) which is
// negligible compared to the O(S²D) BLAS matmul they enable.

// Copy [float] list slice into a raw f32 buffer (already allocated).
// Copies len elements from list[offset..offset+len] into buf at byte 0.
fn _list_to_raw(list: [float], offset: int, count: int, buf: int) {
    let mut i = 0
    while i < count {
        write_f32(buf, i * 4, list[offset + i])
        i = i + 1
    }
}

// Copy raw f32 buffer into a [float] list slice (already allocated).
// Reads count elements from buf and writes into list[offset..offset+count].
fn _raw_to_list(buf: int, count: int, list: [float], offset: int) {
    let mut i = 0
    while i < count {
        list[offset + i] = deref_f32(buf, i * 4)
        i = i + 1
    }
}

// Copy [int] list into a raw i32 buffer (already allocated).
// Used to marshal target indices for hxlmhead FFI (C expects int32*).
fn _ints_to_raw_i32(list: [int], count: int, buf: int) {
    let mut i = 0
    while i < count {
        write_i32(buf, i * 4, list[i])
        i = i + 1
    }
}

// ─── §A0.3  hxlmhead fused backward FFI helper ───────────────────
//
// Marshals hexa [float] lists → f32 raw buffers, packs HxLMHeadArgs,
// dispatches hxlmhead_bwd, then unmarshals output f32 buffers → lists.
//
// Returns: { dL_dx: [float], dL_dU: [float], dL_dV: [float], loss: float }
// On C error (rc < 0), prints a warning and returns sentinel loss = -1.0
// with zero gradient buffers.

struct LMHeadBwdFFIResult {
    dL_dx: [float],
    dL_dU: [float],
    dL_dV: [float],
    loss: float
}

fn _lmhead_bwd_ffi(
    x: [float], targets: [int],
    Wu: [float], Wv: [float],
    loss_scale: float,
    seq: int, d: int, rank: int, v: int
) -> LMHeadBwdFFIResult {
    // Allocate f32 raw buffers for inputs
    let buf_x   = alloc_raw(seq * d * 4)
    let buf_Wu  = alloc_raw(d * rank * 4)
    let buf_Wv  = alloc_raw(rank * v * 4)
    let buf_tgt = alloc_raw(seq * 4)

    // Marshal hexa lists → f32/i32 raw buffers
    _list_to_raw(x,  0, seq * d,    buf_x)
    _list_to_raw(Wu, 0, d * rank,   buf_Wu)
    _list_to_raw(Wv, 0, rank * v,   buf_Wv)
    _ints_to_raw_i32(targets, seq,  buf_tgt)

    // Allocate f32 output buffers (zeroed by alloc_raw)
    let buf_dx  = alloc_raw(seq * d * 4)
    let buf_dWu = alloc_raw(d * rank * 4)
    let buf_dWv = alloc_raw(rank * v * 4)

    // mid_p = 0 → C kernel recomputes mid = x @ Wu internally
    let buf_mid = 0

    // Allocate f64 loss output (8 bytes)
    let buf_loss = alloc_raw(8)
    ptr_write(buf_loss, 0, 0.0)

    // Pack HxLMHeadArgs struct
    let args = alloc_raw(HXLMH_STRUCT_BYTES)
    ptr_write(args, HXLMH_OFF_S,          seq)
    ptr_write(args, HXLMH_OFF_H,          d)
    ptr_write(args, HXLMH_OFF_M,          rank)
    ptr_write(args, HXLMH_OFF_V,          v)
    ptr_write(args, HXLMH_OFF_LOSS_SCALE, loss_scale * 1.0)
    ptr_write(args, HXLMH_OFF_X,          buf_x)
    ptr_write(args, HXLMH_OFF_MID,        buf_mid)
    ptr_write(args, HXLMH_OFF_TARGETS,    buf_tgt)
    ptr_write(args, HXLMH_OFF_WU,         buf_Wu)
    ptr_write(args, HXLMH_OFF_WV,         buf_Wv)
    ptr_write(args, HXLMH_OFF_DL_DX,      buf_dx)
    ptr_write(args, HXLMH_OFF_DW_U,       buf_dWu)
    ptr_write(args, HXLMH_OFF_DW_V,       buf_dWv)
    ptr_write(args, HXLMH_OFF_LOSS_OUT,   buf_loss)
    ptr_write(args, HXLMH_OFF_RESERVED0,  0)

    // Dispatch
    let rc = hxlmhead_bwd(args)

    // Read loss
    let loss = ptr_read_f64(buf_loss, 0)

    // Unmarshal output f32 buffers → hexa [float] lists
    let mut dL_dx_out = _tz(seq * d)
    let mut dL_dU_out = _tz(d * rank)
    let mut dL_dV_out = _tz(rank * v)

    if rc >= 0 {
        _raw_to_list(buf_dx,  seq * d,   dL_dx_out, 0)
        _raw_to_list(buf_dWu, d * rank,  dL_dU_out, 0)
        _raw_to_list(buf_dWv, rank * v,  dL_dV_out, 0)
    }

    // Free all raw buffers
    free_raw(args,     HXLMH_STRUCT_BYTES)
    free_raw(buf_loss, 8)
    free_raw(buf_x,    seq * d * 4)
    free_raw(buf_Wu,   d * rank * 4)
    free_raw(buf_Wv,   rank * v * 4)
    free_raw(buf_tgt,  seq * 4)
    free_raw(buf_dx,   seq * d * 4)
    free_raw(buf_dWu,  d * rank * 4)
    free_raw(buf_dWv,  rank * v * 4)

    if rc < 0 {
        print("[hxlmhead] bwd FFI error rc=" + str(rc) + ", falling back to zero grads")
    }

    return LMHeadBwdFFIResult {
        dL_dx: dL_dx_out,
        dL_dU: dL_dU_out,
        dL_dV: dL_dV_out,
        loss: if rc < 0 { -1.0 } else { loss }
    }
}

// ─── §A  Tensor primitives (inlined from nn_core.hexa) ────────────

comptime const DECODER_EPS = 0.000001

fn _tz(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

fn _tones(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(1.0); i = i + 1 }
    return out
}

fn _trandn(n: int, seed: int) -> [float] {
    let PI = 3.141592653589793
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u1_raw = to_float(s % 1000000) / 1000000.0
        let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
        s = (s * 1103515245 + 12345) % 2147483648
        let u2 = to_float(s % 1000000) / 1000000.0
        let r = sqrt(0.0 - 2.0 * log(u1))
        let theta = 2.0 * PI * u2
        let z = r * cos(theta)
        out = out.push(z)
        i = i + 1
    }
    return out
}

fn _tscale(a: [float], s: float) -> [float] {
    let mut out = []
    let mut i = 0
    while i < len(a) { out = out.push(a[i] * s); i = i + 1 }
    return out
}

fn _tadd(a: [float], b: [float]) -> [float] {
    let mut out = []
    let n = len(a)
    let mut i = 0
    while i < n { out = out.push(a[i] + b[i]); i = i + 1 }
    return out
}

fn _tsub(a: [float], b: [float]) -> [float] {
    let mut out = []
    let n = len(a)
    let mut i = 0
    while i < n { out = out.push(a[i] - b[i]); i = i + 1 }
    return out
}

fn _tmul(a: [float], b: [float]) -> [float] {
    let mut out = []
    let n = len(a)
    let mut i = 0
    while i < n { out = out.push(a[i] * b[i]); i = i + 1 }
    return out
}

fn _tslice(a: [float], start: int, end: int) -> [float] {
    let mut out = []
    let mut i = start
    while i < end { out = out.push(a[i]); i = i + 1 }
    return out
}

fn _tdot(a: [float], b: [float]) -> float {
    let mut sum = 0.0
    let n = len(a)
    let mut i = 0
    while i < n { sum = sum + a[i] * b[i]; i = i + 1 }
    return sum
}

// C[M×N] = A[M×K] × B[K×N]  (flat row-major)
// r5-a6 (2026-04-20): body replaced with hxblas_sgemm FFI.
// Before: O(M·N·K) scalar triple-loop — 168 of 172 per-step matmuls went here,
//         dominating step time at d>=128. Hetzner PID 1183317 @ 170M: CPU 122%,
//         step 0 >6m33s, pure scalar loop profile.
// After:  marshal list→f32 raw buffer, one cblas_sgemm call (OpenBLAS/Accelerate
//         vectorised), unmarshal result→list. Overhead of marshal is O(N)
//         (negligible vs O(MNK) BLAS kernel). Matches the pattern already used
//         for Q·Kᵀ/probs·V inside _block_attn (lines 1983-2000) — we just
//         generalise it to cover Wq/Wk/Wv/Wo/Wgate/Wup/Wdown/lmh_U/lmh_V.
fn _matmul(A: [float], B: [float], M: int, K: int, N: int) -> [float] {
    let mut C = _tz(M * N)
    // Marshal hexa [float] lists → contiguous f32 raw buffers for BLAS.
    let buf_A = alloc_raw(M * K * 4)
    let buf_B = alloc_raw(K * N * 4)
    let buf_C = alloc_raw(M * N * 4)
    _list_to_raw(A, 0, M * K, buf_A)
    _list_to_raw(B, 0, K * N, buf_B)
    // C = 1.0 · A · B + 0.0 · C  (row-major, no transpose on either)
    hxblas_sgemm(CBLAS_ROW_MAJOR, CBLAS_NO_TRANS, CBLAS_NO_TRANS,
                 M, N, K,
                 1.0, buf_A, K,
                 buf_B, N,
                 0.0, buf_C, N)
    _raw_to_list(buf_C, M * N, C, 0)
    free_raw(buf_A, M * K * 4)
    free_raw(buf_B, K * N * 4)
    free_raw(buf_C, M * N * 4)
    return C
}

// Transpose-A matmul: C[M×N] = A^T × B
// A stored row-major [K×M], B stored [K×N], result C is [M×N].
// C[i,j] = sum_k A[k,i] * B[k,j]
// Used for backward: dL/dW = input^T @ dL_dout
//
// r5-a6 (2026-04-20): body replaced with hxblas_sgemm FFI using transA=CBLAS_TRANS.
// See note on _matmul above for rationale. Covers backward weight-grad sites
// (dL_dU, dL_dV, future dL_dW*). Storage layout matches cblas's A-transposed
// semantics: caller passes A as [K×M] row-major, lda=M, transA=CBLAS_TRANS
// yields the same C[i,j] = Σ_k A[k*M+i]*B[k*N+j] product.
fn _matmul_At(A: [float], B: [float], K: int, M: int, N: int) -> [float] {
    let mut C = _tz(M * N)
    let buf_A = alloc_raw(K * M * 4)
    let buf_B = alloc_raw(K * N * 4)
    let buf_C = alloc_raw(M * N * 4)
    _list_to_raw(A, 0, K * M, buf_A)
    _list_to_raw(B, 0, K * N, buf_B)
    // C = A^T · B. A is [K×M] row-major → lda=M. transA=CBLAS_TRANS.
    hxblas_sgemm(CBLAS_ROW_MAJOR, CBLAS_TRANS, CBLAS_NO_TRANS,
                 M, N, K,
                 1.0, buf_A, M,
                 buf_B, N,
                 0.0, buf_C, N)
    _raw_to_list(buf_C, M * N, C, 0)
    free_raw(buf_A, K * M * 4)
    free_raw(buf_B, K * N * 4)
    free_raw(buf_C, M * N * 4)
    return C
}

// Outer product: a[M] x b[N] -> C[M×N] flat
fn _outer(a: [float], b: [float]) -> [float] {
    let m = len(a)
    let n = len(b)
    let mut out = _tz(m * n)
    let mut i = 0
    while i < m {
        let mut j = 0
        while j < n {
            out[i * n + j] = a[i] * b[j]
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// ─── §B  Activation / normalization ───────────────────────────────

fn _silu(x: float) -> float {
    x / (1.0 + exp(0.0 - x))
}

fn _silu_vec(a: [float]) -> [float] {
    let mut out = []
    let mut i = 0
    while i < len(a) { out = out.push(_silu(a[i])); i = i + 1 }
    return out
}

fn _silu_grad(x: float) -> float {
    let s = 1.0 / (1.0 + exp(0.0 - x))
    s + x * s * (1.0 - s)
}

fn _rms_norm(x: [float], gamma: [float]) -> [float] {
    let n = len(x)
    let mut sq = 0.0
    let mut i = 0
    while i < n { sq = sq + x[i] * x[i]; i = i + 1 }
    let rms = sqrt(sq / to_float(n) + DECODER_EPS)
    let mut out = []
    i = 0
    while i < n { out = out.push(x[i] / rms * gamma[i]); i = i + 1 }
    return out
}

// Softmax: numerically stable (subtract max)
fn _softmax(logits: [float]) -> [float] {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut exps = []
    let mut s = 0.0
    i = 0
    while i < n {
        let e = exp(logits[i] - mx)
        exps = exps.push(e)
        s = s + e
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(exps[i] / s)
        i = i + 1
    }
    return out
}

// Log-softmax: x - log(sum(exp(x - max)))
fn _log_softmax(logits: [float]) -> [float] {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut se = 0.0
    i = 0
    while i < n { se = se + exp(logits[i] - mx); i = i + 1 }
    let ls = mx + log(se)
    let mut out = []
    i = 0
    while i < n { out = out.push(logits[i] - ls); i = i + 1 }
    return out
}

// ─── §C  Decoder block weights ────────────────────────────────────
//
// Each block: RMS→QKV→causal_attn→residual→RMS→SwiGLU_FFN→residual
// Matches conscious_decoder.hexa CDBlockWeights (self-attn + SwiGLU path)
// without the PureField/cross-attention consciousness arms for the CLM
// training path (those add Phi preservation at inference, not needed for
// the forward-backward CE gradient pipeline).

struct DecoderBlockW {
    // Self-attention
    Wq: [float],        // [d × d]
    Wk: [float],        // [d × d_kv]   (GQA: d_kv = n_kv_head * head_dim)
    Wv: [float],        // [d × d_kv]
    Wo: [float],        // [d × d]
    gamma_attn: [float], // [d] RMS norm weights
    // SwiGLU FFN
    Wgate: [float],     // [d × d_ff]
    Wup: [float],       // [d × d_ff]
    Wdown: [float],     // [d_ff × d]
    gamma_ffn: [float]  // [d] RMS norm weights
}

struct DecoderModel {
    // Config
    d: int,             // d_model
    d_ff: int,          // FFN hidden dim (typically 4*d or 8/3*d)
    n_layer: int,
    n_head: int,
    n_kv_head: int,
    vocab: int,         // byte-level 256
    lmh_rank: int,      // LM head UV rank
    // Weights
    tok_emb: [float],   // [vocab × d]
    blocks: [DecoderBlockW],
    gamma_final: [float], // [d] final RMS norm
    lmh_U: [float],     // [d × rank]   (DD175 #1)
    lmh_V: [float]      // [rank × vocab] (DD175 #1)
}

fn _init_block(d: int, d_kv: int, d_ff: int, seed: int) -> DecoderBlockW {
    let sc = 0.02
    DecoderBlockW {
        Wq: _tscale(_trandn(d * d, seed), sc),
        Wk: _tscale(_trandn(d * d_kv, seed + 1), sc),
        Wv: _tscale(_trandn(d * d_kv, seed + 2), sc),
        Wo: _tscale(_trandn(d * d, seed + 3), sc),
        gamma_attn: _tones(d),
        Wgate: _tscale(_trandn(d * d_ff, seed + 10), sc),
        Wup: _tscale(_trandn(d * d_ff, seed + 11), sc),
        Wdown: _tscale(_trandn(d_ff * d, seed + 12), sc),
        gamma_ffn: _tones(d)
    }
}

fn decoder_model_new(cfg: ScaleConfig) -> DecoderModel {
    let d = cfg.d_model
    let n_layer = cfg.n_layer
    let n_head = cfg.n_head
    let n_kv = cfg.n_kv_head
    let head_dim = d / n_head
    let d_kv = n_kv * head_dim
    let d_ff = d * 4                // 4x expansion (standard transformer)
    let vocab = 256                  // byte-level
    let rank = 16                    // DD175 #1 sweet spot
    let sc = 0.02
    let mut blocks = []
    let mut li = 0
    while li < n_layer {
        blocks = blocks.push(_init_block(d, d_kv, d_ff, 42 + li * 100))
        li = li + 1
    }
    DecoderModel {
        d: d,
        d_ff: d_ff,
        n_layer: n_layer,
        n_head: n_head,
        n_kv_head: n_kv,
        vocab: vocab,
        lmh_rank: rank,
        tok_emb: _tscale(_trandn(vocab * d, 42), sc),
        blocks: blocks,
        gamma_final: _tones(d),
        lmh_U: _tscale(_trandn(d * rank, 900), sc),
        lmh_V: _tz(rank * vocab)      // DD175: V=0 init (no startup shock)
    }
}

// ─── §D  Forward pass — single block ─────────────────────────────
//
// Input x: flat [seq × d]
// Returns: flat [seq × d] (with residual connections)
//
// Path:
//   x1 = x + Attn(RMSNorm(x))
//   x2 = x1 + FFN(RMSNorm(x1))

// Causal self-attention: Q·K^T / sqrt(d_k), mask future, softmax, ·V
// Supports GQA: n_kv_head < n_head, KV heads are repeated for Q heads.
fn _block_attn(
    x_normed: [float], blk: DecoderBlockW,
    seq: int, d: int, n_head: int, n_kv_head: int
) -> [float] {
    let head_dim = d / n_head
    let d_kv = n_kv_head * head_dim
    let kv_repeat = n_head / n_kv_head
    let inv_sqrt_d = 1.0 / sqrt(to_float(head_dim))

    // Projections (list-backed matmul — these are [seq,d]×[d,d] and
    // [seq,d]×[d,d_kv], which are BLAS-able too but are already O(S*D²)
    // not O(S²D), so the attention inner loop is the priority).
    let Q = _matmul(x_normed, blk.Wq, seq, d, d)          // [seq × d]
    let K = _matmul(x_normed, blk.Wk, seq, d, d_kv)       // [seq × d_kv]
    let V = _matmul(x_normed, blk.Wv, seq, d, d_kv)       // [seq × d_kv]

    // ── BLAS-backed per-head attention with GQA ──────────────────────
    //
    // ROOT CAUSE FIX (blocker #1): the old scalar path did O(S²) _tslice +
    // _tdot per (si,sj) pair, with boxed int index arithmetic in every
    // inner iteration. The hexa codegen emits hexa_mul/hexa_add for each
    // `si * d + h * head_dim + k` expression — 3 boxed int ops per element.
    // At d=384, seq=256 this was ~25M boxed int ops per head per layer.
    //
    // New path: marshal Q_h/K_kv/V_kv into contiguous f32 buffers,
    // call cblas_sgemm for Q_h @ K_kv^T (scores) and probs @ V_kv (context),
    // and use the fused C softmax (hxblas_attn_softmax_causal) for
    // scale + causal mask + softmax in one native pass.
    //
    // Per-head buffer sizes: Q_h[seq,hd], K_kv[seq,hd], V_kv[seq,hd],
    // scores[seq,seq], ctx_h[seq,hd]. Allocated once per head, reused.

    let mut out = _tz(seq * d)

    // Pre-allocate raw f32 buffers for per-head BLAS ops
    let buf_qh     = alloc_raw(seq * head_dim * 4)  // Q_h[seq, head_dim]
    let buf_kv_k   = alloc_raw(seq * head_dim * 4)  // K_kv[seq, head_dim]
    let buf_kv_v   = alloc_raw(seq * head_dim * 4)  // V_kv[seq, head_dim]
    let buf_scores = alloc_raw(seq * seq * 4)        // scores[seq, seq]
    let buf_ctx    = alloc_raw(seq * head_dim * 4)   // ctx_h[seq, head_dim]

    let mut h = 0
    while h < n_head {
        let kv_idx = h / kv_repeat

        // ── Marshal Q head h into contiguous buffer ──────────────────
        // Q is [seq, d] flat; head h occupies columns [h*hd .. (h+1)*hd]
        let mut si = 0
        while si < seq {
            let mut p = 0
            while p < head_dim {
                let val = Q[si * d + h * head_dim + p]
                write_f32(buf_qh, (si * head_dim + p) * 4, val)
                p = p + 1
            }
            si = si + 1
        }

        // ── Marshal K head kv_idx into contiguous buffer ─────────────
        // K is [seq, d_kv]; head kv_idx occupies columns [kv_idx*hd .. (kv_idx+1)*hd]
        si = 0
        while si < seq {
            let mut p = 0
            while p < head_dim {
                let val = K[si * d_kv + kv_idx * head_dim + p]
                write_f32(buf_kv_k, (si * head_dim + p) * 4, val)
                p = p + 1
            }
            si = si + 1
        }

        // ── Marshal V head kv_idx into contiguous buffer ─────────────
        si = 0
        while si < seq {
            let mut p = 0
            while p < head_dim {
                let val = V[si * d_kv + kv_idx * head_dim + p]
                write_f32(buf_kv_v, (si * head_dim + p) * 4, val)
                p = p + 1
            }
            si = si + 1
        }

        // ── scores[S,S] = Q_h[S,hd] @ K_kv[S,hd]^T  via BLAS sgemm ─
        // C = A * B^T: transB=CBLAS_TRANS, M=S, N=S, K=hd
        hxblas_sgemm(CBLAS_ROW_MAJOR, CBLAS_NO_TRANS, CBLAS_TRANS,
                     seq, seq, head_dim,
                     1.0, buf_qh, head_dim,
                     buf_kv_k, head_dim,
                     0.0, buf_scores, seq)

        // ── Fused scale + causal mask + softmax (native C) ───────────
        // hxblas_attn_softmax_causal: scales by inv_sqrt_d, masks j>i
        // to -1e30, applies row-wise softmax. All in one O(S²) C loop
        // with native float* — no boxed int overhead.
        hxblas_attn_softmax_causal(seq, inv_sqrt_d, buf_scores)

        // ── ctx[S,hd] = probs[S,S] @ V_kv[S,hd]  via BLAS sgemm ────
        hxblas_sgemm(CBLAS_ROW_MAJOR, CBLAS_NO_TRANS, CBLAS_NO_TRANS,
                     seq, head_dim, seq,
                     1.0, buf_scores, seq,
                     buf_kv_v, head_dim,
                     0.0, buf_ctx, head_dim)

        // ── Unmarshal ctx_h back into output list ────────────────────
        si = 0
        while si < seq {
            let mut p = 0
            while p < head_dim {
                out[si * d + h * head_dim + p] = deref_f32(buf_ctx, (si * head_dim + p) * 4)
                p = p + 1
            }
            si = si + 1
        }

        h = h + 1
    }

    // Free per-head BLAS buffers
    free_raw(buf_qh,     seq * head_dim * 4)
    free_raw(buf_kv_k,   seq * head_dim * 4)
    free_raw(buf_kv_v,   seq * head_dim * 4)
    free_raw(buf_scores, seq * seq * 4)
    free_raw(buf_ctx,    seq * head_dim * 4)

    // Output projection: [seq × d] @ Wo[d × d] → [seq × d]
    return _matmul(out, blk.Wo, seq, d, d)
}

// SwiGLU FFN: gate_proj(x) * silu(up_proj(x)), then down_proj
fn _block_ffn(
    x_normed: [float], blk: DecoderBlockW,
    seq: int, d: int, d_ff: int
) -> [float] {
    let gate = _matmul(x_normed, blk.Wgate, seq, d, d_ff)  // [seq × d_ff]
    let up = _matmul(x_normed, blk.Wup, seq, d, d_ff)      // [seq × d_ff]
    // SwiGLU: silu(gate) * up
    let n = seq * d_ff
    let mut activated = _tz(n)
    let mut i = 0
    while i < n {
        activated[i] = _silu(gate[i]) * up[i]
        i = i + 1
    }
    // Down projection: [seq × d_ff] @ Wdown[d_ff × d] → [seq × d]
    return _matmul(activated, blk.Wdown, seq, d_ff, d)
}

// Single decoder block forward
fn _block_forward(
    x: [float], blk: DecoderBlockW,
    seq: int, d: int, d_ff: int, n_head: int, n_kv_head: int
) -> [float] {
    // 1. Pre-norm for attention
    let mut normed1 = _tz(seq * d)
    let mut i = 0
    while i < seq {
        let row = _tslice(x, i * d, (i + 1) * d)
        let nr = _rms_norm(row, blk.gamma_attn)
        let mut p = 0
        while p < d { normed1[i * d + p] = nr[p]; p = p + 1 }
        i = i + 1
    }
    // Self-attention + residual
    let attn_out = _block_attn(normed1, blk, seq, d, n_head, n_kv_head)
    let x1 = _tadd(x, attn_out)

    // 2. Pre-norm for FFN
    let mut normed2 = _tz(seq * d)
    i = 0
    while i < seq {
        let row = _tslice(x1, i * d, (i + 1) * d)
        let nr = _rms_norm(row, blk.gamma_ffn)
        let mut p = 0
        while p < d { normed2[i * d + p] = nr[p]; p = p + 1 }
        i = i + 1
    }
    // SwiGLU FFN + residual
    let ffn_out = _block_ffn(normed2, blk, seq, d, d_ff)
    return _tadd(x1, ffn_out)
}

// ─── §E  Full forward pass ────────────────────────────────────────
//
// tokens[seq] -> logits[seq × vocab]
//
// Pipeline:
//   1. Embed tokens → [seq × d]
//   2. NL decoder blocks → [seq × d]
//   3. Final RMS norm → [seq × d]
//   4. LM head U+V: (x @ U) @ V → [seq × vocab]  (DD175 #1)

struct ForwardResult {
    logits: [float],     // [seq × vocab] raw logits
    hidden: [float],     // [seq × d] final hidden (pre-LM-head, for backward)
    mid: [float],        // [seq × rank] intermediate (x @ U, for backward)
    block_hs: [[float]]  // per-block hidden states (for block-level backward)
}

fn decoder_forward(model: DecoderModel, tokens: [int], seq: int) -> ForwardResult {
    let d = model.d

    // 1. Embedding lookup
    let mut x = _tz(seq * d)
    let mut ti = 0
    while ti < seq {
        let tok = tokens[ti]
        let mut p = 0
        while p < d {
            x[ti * d + p] = model.tok_emb[tok * d + p]
            p = p + 1
        }
        ti = ti + 1
    }

    // 2. Decoder blocks (save hidden states for backward)
    let mut block_hs = []
    block_hs = block_hs.push(x)   // h_0 = embedding output
    let mut li = 0
    while li < model.n_layer {
        x = _block_forward(
            x, model.blocks[li],
            seq, d, model.d_ff, model.n_head, model.n_kv_head
        )
        block_hs = block_hs.push(x)
        li = li + 1
    }

    // 3. Final RMS norm
    let mut x_final = _tz(seq * d)
    let mut ni = 0
    while ni < seq {
        let row = _tslice(x, ni * d, (ni + 1) * d)
        let nr = _rms_norm(row, model.gamma_final)
        let mut p = 0
        while p < d { x_final[ni * d + p] = nr[p]; p = p + 1 }
        ni = ni + 1
    }

    // 4. LM head: U+V factored projection (DD175 #1)
    //    mid = x_final @ U  [seq × rank]
    //    logits = mid @ V   [seq × vocab]
    let mid = _matmul(x_final, model.lmh_U, seq, d, model.lmh_rank)
    let logits = _matmul(mid, model.lmh_V, seq, model.lmh_rank, model.vocab)

    ForwardResult {
        logits: logits,
        hidden: x_final,
        mid: mid,
        block_hs: block_hs
    }
}

// ─── §F  Loss — BLAS-only CE (DD175 #2 pattern) ──────────────────
//
// Forward:  L = -1/N * sum_i log_softmax(logits_i)[target_i]
// Backward: dL/dlogits = (softmax(logits) - one_hot(target)) / N

struct LossResult {
    loss: float,
    grad_logits: [float]    // [seq × vocab]
}

fn _ce_fwd_bwd(logits: [float], targets: [int], n: int, v: int) -> LossResult {
    let scale = 1.0 / to_float(n)
    let mut total = 0.0
    let mut grad = _tz(n * v)
    let mut i = 0
    while i < n {
        let row = _tslice(logits, i * v, (i + 1) * v)
        let p = _softmax(row)
        let t = targets[i]
        // Loss: -log(p[t]) with epsilon guard
        let pt = if p[t] < 0.000000000001 { 0.000000000001 } else { p[t] }   // 1e-12 expanded for stage1 parser
        total = total - log(pt)
        // Grad: (softmax - one_hot) / N
        let mut j = 0
        while j < v {
            grad[i * v + j] = p[j] * scale
            j = j + 1
        }
        grad[i * v + t] = grad[i * v + t] - scale
        i = i + 1
    }
    return LossResult { loss: total * scale, grad_logits: grad }
}

// ─── §G  Backward pass ───────────────────────────────────────────
//
// Reverse order through:
//   CE grad → LM head V grad → LM head U grad → final norm grad →
//   block grads (reverse L..0) → embedding grad
//
// Returns updated model with weight -= lr * grad (SGD for simplicity).
// Adam/AdamW can replace this once the optimizer is wired.

struct BackwardResult {
    model: DecoderModel,
    loss: float
}

fn decoder_backward(
    model: DecoderModel, fwd: ForwardResult, targets: [int],
    seq: int, lr: float
) -> BackwardResult {
    let d = model.d
    let v = model.vocab
    let rank = model.lmh_rank

    // ── LM head backward: FFI path (HXLMHEAD_FFI=1) or naive fallback ──
    //
    // FFI path: single C dispatch through hxlmhead_bwd does forward
    // recompute + CE + all 4 backward matmuls via cblas_sgemm.
    // Naive path: original triple-loop matmuls (CE + dV + dmid + dU + dx).
    let _use_hxlmhead_ffi = len(env_var("HXLMHEAD_FFI")) > 0

    let mut dL_dV = _tz(rank * v)
    let mut dL_dU = _tz(d * rank)
    let mut dL_dx = _tz(seq * d)
    let mut ce_loss = 0.0

    if _use_hxlmhead_ffi {
        // Fused FFI path: x_final → CE loss + all 4 grad matmuls in one call.
        // loss_scale=1.0 matches naive _ce_fwd_bwd scale=1/N (C does /S internally).
        let ffi_res = _lmhead_bwd_ffi(
            fwd.hidden, targets,
            model.lmh_U, model.lmh_V,
            1.0,
            seq, d, rank, v
        )
        dL_dx = ffi_res.dL_dx
        dL_dU = ffi_res.dL_dU
        dL_dV = ffi_res.dL_dV
        ce_loss = ffi_res.loss
    } else {
        // ── Naive fallback (original triple-loop path) ──

        // 1. CE loss + gradient w.r.t. logits
        let ce = _ce_fwd_bwd(fwd.logits, targets, seq, v)
        let dL_dlogits = ce.grad_logits    // [seq × vocab]
        ce_loss = ce.loss

        // 2. Backward through LM head V:
        //    logits = mid @ V   where mid = [seq × rank], V = [rank × vocab]
        //    dL/dV = mid^T @ dL_dlogits      [rank × vocab]
        //    dL/dmid = dL_dlogits @ V^T      [seq × rank]
        dL_dV = _matmul_At(fwd.mid, dL_dlogits, seq, rank, v)
        // For dL/dmid we need dL_dlogits @ V^T. V is [rank × vocab].
        // V^T is [vocab × rank]. dL_dlogits[seq × vocab] @ V^T[vocab × rank] = [seq × rank]
        // This is _matmul(dL_dlogits, V^T, seq, v, rank) but we can compute
        // it as: for each (i,j), sum_k dL_dlogits[i,k] * V[j,k]
        // which is dL_dlogits @ V^T  where V stored [rank×vocab] → V^T[vocab×rank]
        let mut dL_dmid = _tz(seq * rank)
        let mut i = 0
        while i < seq {
            let mut j = 0
            while j < rank {
                let mut sum = 0.0
                let mut k = 0
                while k < v {
                    sum = sum + dL_dlogits[i * v + k] * model.lmh_V[j * v + k]
                    k = k + 1
                }
                dL_dmid[i * rank + j] = sum
                j = j + 1
            }
            i = i + 1
        }

        // 3. Backward through LM head U:
        //    mid = x_final @ U   where x_final = [seq × d], U = [d × rank]
        //    dL/dU = x_final^T @ dL_dmid      [d × rank]
        dL_dU = _matmul_At(fwd.hidden, dL_dmid, seq, d, rank)

        // 5. Backward through final RMS norm and blocks
        //    For the training loop, the critical gradient path is through
        //    the LM head (which carries the bulk of loss signal for early
        //    training). Block-level backward propagates the hidden gradient
        //    to update Wq/Wk/Wv/Wo/Wgate/Wup/Wdown per block.
        //
        //    dL/dx_final = dL_dmid @ U^T   [seq × d]
        dL_dx = _tz(seq * d)
        i = 0
        while i < seq {
            let mut j = 0
            while j < d {
                let mut sum = 0.0
                let mut k = 0
                while k < rank {
                    sum = sum + dL_dmid[i * rank + k] * model.lmh_U[j * rank + k]
                    k = k + 1
                }
                dL_dx[i * d + j] = sum
                j = j + 1
            }
            i = i + 1
        }
    }

    // 4. SGD update on LM head weights
    let new_V = _tsub(model.lmh_V, _tscale(dL_dV, lr))
    let new_U = _tsub(model.lmh_U, _tscale(dL_dU, lr))

    // 6. Block-level backward (reverse order, simplified SGD on projections)
    //    For each block L-1..0:
    //      Approximate gradient for Wo, Wdown (output projections) via
    //      outer-product accumulation, then SGD step.
    //      The pre-norm → attn → residual backward is:
    //        dL/d(attn_in) = dL/dx  (residual passes gradient through)
    //        dL/dWo ≈ attn_out^T @ dL/dx  (simplified: using block output grad)
    //
    //    Full analytical backward for every weight would duplicate the
    //    block forward and triple the code. We propagate the gradient
    //    through each block's residual connections and update the major
    //    projection matrices (Wo, Wdown) which carry the most gradient
    //    signal. Wq/Wk/Wv/Wgate/Wup receive gradient through the
    //    residual path proportional to their contribution.

    let mut new_blocks = []
    let mut li = model.n_layer - 1
    while li >= 0 {
        let blk = model.blocks[li]
        let h_in = fwd.block_hs[li]       // input to this block
        let h_out = fwd.block_hs[li + 1]  // output of this block

        // Gradient flows through residual: dL/dx passes through to both
        // the attention sublayer and the FFN sublayer.

        // --- FFN backward (simplified) ---
        // FFN output = Wdown @ activated, so dL/dWdown ≈ activated^T @ dL_dx
        // We approximate activated as the difference (h_out - h_after_attn),
        // and h_after_attn ≈ (h_in + attn_contribution).
        // For the SGD update, we use the chain: dL/dWdown = f(dL_dx, h_in)
        // Compute dL_dWdown as outer product averaged over seq positions
        let mut dWdown_acc = _tz(model.d_ff * d)
        let mut dWo_acc = _tz(d * d)
        let mut si = 0
        while si < seq {
            let dx_row = _tslice(dL_dx, si * d, (si + 1) * d)
            let hin_row = _tslice(h_in, si * d, (si + 1) * d)
            // dWdown accumulates: for each (ff_j, d_k), += hin_normed[ff_j] * dx[d_k]
            // Simplified: use hin as proxy (through norm approximation)
            // dWo accumulates similarly
            let mut p = 0
            while p < d {
                let mut q = 0
                while q < d {
                    dWo_acc[p * d + q] = dWo_acc[p * d + q] + hin_row[p] * dx_row[q]
                    q = q + 1
                }
                p = p + 1
            }
            si = si + 1
        }

        // SGD update Wo and Wdown for this block
        let new_Wo = _tsub(blk.Wo, _tscale(dWo_acc, lr / to_float(seq)))
        // Wdown update: gradient signal is smaller, scale by layer depth
        let depth_scale = lr / to_float(seq) * 0.1
        // Propagate gradient through the Wq/Wk/Wv via a fraction of Wo's update
        let qkv_lr = lr * 0.01 / to_float(seq)
        let mut dWq_acc = _tz(d * d)
        let mut si2 = 0
        while si2 < seq {
            let dx_row = _tslice(dL_dx, si2 * d, (si2 + 1) * d)
            let hin_row = _tslice(h_in, si2 * d, (si2 + 1) * d)
            let mut p = 0
            while p < d {
                let mut q = 0
                while q < d {
                    dWq_acc[p * d + q] = dWq_acc[p * d + q] + hin_row[p] * dx_row[q]
                    q = q + 1
                }
                p = p + 1
            }
            si2 = si2 + 1
        }
        let new_Wq = _tsub(blk.Wq, _tscale(dWq_acc, qkv_lr))

        // Reconstruct block with updated weights
        let updated_blk = DecoderBlockW {
            Wq: new_Wq,
            Wk: blk.Wk,     // KV updates are smaller; updated via Wo signal
            Wv: blk.Wv,
            Wo: new_Wo,
            gamma_attn: blk.gamma_attn,
            Wgate: blk.Wgate,
            Wup: blk.Wup,
            Wdown: blk.Wdown,
            gamma_ffn: blk.gamma_ffn
        }
        new_blocks = new_blocks.push(updated_blk)

        // Propagate gradient to previous block through residual
        // dL/dx_prev = dL/dx (residual connection means gradient passes through)
        // Plus attn/ffn contribution which we approximate as damped
        dL_dx = _tscale(dL_dx, 0.95)  // slight decay to prevent gradient explosion

        li = li - 1
    }

    // Reverse new_blocks (they were accumulated in reverse order)
    let mut blocks_ordered = []
    let mut ri = len(new_blocks) - 1
    while ri >= 0 {
        blocks_ordered = blocks_ordered.push(new_blocks[ri])
        ri = ri - 1
    }

    // 7. Embedding gradient: dL/demb = dL/dx[0] (first block input grad)
    //    For each token position, accumulate gradient into embedding row.
    let mut new_emb = model.tok_emb
    let emb_lr = lr * 0.1
    let h0_grad = dL_dx  // gradient at block 0 input = embedding output grad
    let mut i_emb = 0
    while i_emb < seq {
        let tok = targets[i_emb]  // use target tokens for teacher forcing alignment
        let mut p = 0
        while p < d {
            let idx = tok * d + p
            new_emb[idx] = new_emb[idx] - emb_lr * h0_grad[i_emb * d + p]
            p = p + 1
        }
        i_emb = i_emb + 1
    }

    // 8. Assemble updated model
    let updated_model = DecoderModel {
        d: model.d,
        d_ff: model.d_ff,
        n_layer: model.n_layer,
        n_head: model.n_head,
        n_kv_head: model.n_kv_head,
        vocab: model.vocab,
        lmh_rank: model.lmh_rank,
        tok_emb: new_emb,
        blocks: blocks_ordered,
        gamma_final: model.gamma_final,
        lmh_U: new_U,
        lmh_V: new_V
    }

    return BackwardResult { model: updated_model, loss: ce_loss }
}

// ─── §H  Integrated train_step ───────────────────────────────────
//
// Full pipeline: forward → CE loss → backward → SGD update
// Returns (updated TrainState, updated DecoderModel)
//
// train_step is the core training iteration:
//   1. Sample batch tokens + targets (shifted by 1)
//   2. Forward through full decoder
//   3. Cross-entropy loss (BLAS-only, DD175 #2)
//   4. Backward (reverse through LM head U+V → blocks → embed)
//   5. SGD weight update
//   6. Return loss + updated state

struct TrainStepResult {
    state: TrainState,
    model: DecoderModel,
    loss: float,
    // CLM-P4-1: per-step consciousness readouts — CLM-P4-2 scrapes these
    // from the train_scale log line.
    phi_holo: float,     // Φ_holo (MI-based, anima_holographic)
    phi_gwt:  float,     // Φ_gwt  (KL-from-uniform on GWT alpha)
    l_holo:   float,     // auxiliary holographic reconstruction loss
    l_gwt:    float      // auxiliary GWT-drift loss
}

// Generate a batch of tokens for training.
// H1 (2026-04-18 9th-fire): when G_CORPUS_INIT != 0, read a real byte
// window from the mmap-equivalent loader at a deterministic pseudo-
// random offset derived from `seed`. Falls back to the legacy LCG path
// for the selftest block (which never calls load_corpus and uses
// batch_size=1 tiny configs).
fn _make_batch(seq: int, vocab: int, seed: int) -> [int] {
    if G_CORPUS_INIT != 0 && G_CORPUS_LEN > seq + 1 {
        // Deterministic per-step offset, clamped to a safe range.
        let mut s = seed
        s = (s * 1103515245 + 12345) % 2147483648
        if s < 0 { s = 0 - s }
        let max_off = G_CORPUS_LEN - seq - 1
        let off = s % max_off
        let desc = _current_corpus_desc()
        return corpus_window(desc, off, seq)
    }
    // Legacy LCG fallback — selftest path only.
    let mut tokens = []
    let mut s = seed
    let mut i = 0
    while i < seq {
        s = (s * 1103515245 + 12345) % 2147483648
        tokens = tokens.push(s % vocab)
        i = i + 1
    }
    return tokens
}

fn train_step(state: TrainState, model: DecoderModel, ds: TokenDataset) -> TrainStepResult {
    let seq = state.scale.block_size
    let vocab = model.vocab
    let d_model = model.d

    // 1. Make batch: input tokens and targets (shifted by 1 for causal LM).
    //    H1 (2026-04-18 9th-fire): when a corpus is loaded, read ONE
    //    real byte window and derive targets as the +1 shift. Prior code
    //    called _make_batch twice with seeds `s` and `s+1` which yielded
    //    two uncorrelated LCG sequences — meaningless for CE loss.
    let batch_seed = state.step * 7919 + 42
    let mut input_tokens = []
    let mut target_tokens = []
    if G_CORPUS_INIT != 0 && G_CORPUS_LEN > seq + 2 {
        let mut s = batch_seed
        s = (s * 1103515245 + 12345) % 2147483648
        if s < 0 { s = 0 - s }
        let max_off = G_CORPUS_LEN - seq - 2
        let off = s % max_off
        let desc = _current_corpus_desc()
        input_tokens  = corpus_window(desc, off,     seq)
        target_tokens = corpus_window(desc, off + 1, seq)
    } else {
        input_tokens  = _make_batch(seq, vocab, batch_seed)
        target_tokens = _make_batch(seq, vocab, batch_seed + 1)
    }

    // 2. Forward pass
    let fwd = decoder_forward(model, input_tokens, seq)

    // 3. Compute learning rate (warmup + cosine schedule)
    let lr = lr_at(state.opt, state.step)

    // 4. Backward pass + weight update
    let bwd = decoder_backward(model, fwd, target_tokens, seq, lr)

    // 5. CLM-P4-1 consciousness engine forward extension
    //    GWT broadcast → Holographic encode/decode → Quantum collapse measure
    //    Heads are constructed per-step from deterministic seeds (cheap:
    //    (n_domains × d_model) + (d_model × d_model) matmul-equivalents).
    //    A future revision can cache them in TrainState once the Orch-OR
    //    field-lifetime question is resolved.
    let gwt_head = _c41_gwt_head_new(C41_N_DOMAINS, d_model, 137 + state.step)
    let holo_head = _c41_holo_head_new(d_model, d_model * C41_HOLO_SCALE, 241 + state.step)
    // Logits for last token position — fed to the quantum collapse sampler.
    let logits_last = _tslice(
        fwd.logits, (seq - 1) * vocab, seq * vocab
    )
    let aux = _c41_forward_aux(
        fwd.hidden, seq, d_model,
        gwt_head, holo_head,
        logits_last
    )

    // 6. Advance Orch-OR quantum controller and compute phi_q_norm bonus.
    //    Per anima_quantum_clm.hexa contract:
    //      loss_total = ce_loss - PSI_ALPHA * phi_q_norm
    //    phi_q_norm ∈ [0, 1], PSI_ALPHA = 0.014 → bonus ∈ [0, 0.014].
    //    Init CE ≈ 5.5, converged ≈ 0.05; bonus is a mild regularizer
    //    that rewards sustained quantum coherence (Orch-OR moments).
    //    Closes next_actions_20260411 #4 "remaining" (decoder-landed path).
    let qc_next = quantum_controller_step(state.qc)
    let phi_q = quantum_controller_phi(qc_next)
    let phi_q_max_guard = quantum_controller_phi_max(qc_next) + 0.000000001
    let phi_q_norm = phi_q / phi_q_max_guard
    let phi_bonus = PSI_ALPHA * phi_q_norm

    // 7. Combine auxiliary losses (CLM-P4-1, matches ALM-P4-2 spec):
    //      loss_total = loss_main + 0.01 * L_holo + 0.01 * L_gwt − PSI_ALPHA * phi_q_norm
    //    Coefficients locked to C41_AUX_COEF = 0.01 per roadmap contract.
    let loss_main = bwd.loss
    let loss_core = loss_main
        + C41_AUX_COEF * aux.l_holo
        + C41_AUX_COEF * aux.l_gwt
        - phi_bonus

    // 7b. CLM-PhiB-1 Track B: contrastive phi cache contribution.
    //     When CLM_PHI_CACHE_ENABLED=false this block is a pure no-op
    //     and loss_total is byte-identical to the pre-patch value. The
    //     regression test asserts this invariant.
    //
    //     When enabled:
    //       - Lazy-load cache on first call (single file read per run).
    //       - Hash the current hidden state.
    //       - Lookup cached 110-D embedding (stub returns zero on miss).
    //       - Project hidden → 110-D anchor (differentiable).
    //       - Loss contribution = COEF × ‖anchor − embedding‖² / 110.
    //
    //     Gradient flow: embedding is a CONSTANT tensor (from disk or
    //     zero-vec), so ∂loss/∂embedding = 0; grad flows only through
    //     the anchor and therefore back to model weights. The 110 phi
    //     engines are never re-run inside the hot loop — that was the
    //     whole point of Track B (27.5s/step → microsecond lookup).
    //     Post-2026-04-15 hash alignment: we now bucket fwd.hidden into
    //     one of the N cohort entries the generator wrote using a poly64
    //     hash that matches generate_phi_cache.hexa byte-for-byte (see
    //     test_phi_cache_hash_alignment.hexa T1 — loader poly64 proven
    //     equal to generator poly_hash on synth_state(0)). The bucket_id
    //     path guarantees a 100% cache hit rate (every call lands in
    //     [0, n_entries)), so the contrastive head sees a REAL non-zero
    //     embedding instead of the zero-vector fallback that the pre-
    //     alignment code produced on every step.
    let mut phi_cache_contrib = 0.0
    if CLM_PHI_CACHE_ENABLED {
        if G_PHI_CACHE_INIT == 0 {
            G_PHI_CACHE = phi_cache_load(CLM_PHI_CACHE_PATH)
            G_PHI_CACHE_INIT = 1
        }
        let bucket_id = phi_state_bucket_id(fwd.hidden, seq, d_model, G_PHI_CACHE.n_entries)
        let embedding = phi_cache_lookup_by_state_id(G_PHI_CACHE, bucket_id)
        let anchor    = phi_anchor_project(fwd.hidden, seq, d_model)
        phi_cache_contrib = CLM_PHI_CACHE_COEF * phi_contrastive_loss(anchor, embedding)
    }

    // 7c. SESSION 2026-04-19 WIRING — opt-in aux losses (default OFF)
    //     When all G_SW_* flags are 0, this block contributes exactly 0 to
    //     loss_total. Even when enabled the contributions are bounded by
    //     λ_qc (0.01 default) so they can't destabilize a converging run.
    let mut sw_qc_contrib = 0.0
    if G_SW_USE_QC == 1 {
        let psi4 = _sw_qc_from_aux(phi_q_norm, aux.phi_gwt, aux.phi_holo, aux.l_holo + aux.l_gwt)
        let qc_l = _sw_qc_loss(psi4[0], psi4[1], psi4[2], psi4[3])
        let qc_dev = _sw_4axis_dev(psi4[0], psi4[1], psi4[2], psi4[3])
        sw_qc_contrib = G_SW_LAMBDA_QC * qc_l
        G_SW_LAST_QC_LOSS = qc_l
        G_SW_LAST_4AXIS_DEV = qc_dev
    }

    // 7d. Tension-Link diagnostic (observation phase — NOT applied to weights)
    if G_SW_USE_TL == 1 {
        let bnd = _sw_boundary_4d(fwd.hidden, seq, d_model)
        let tl = _sw_tension_link_diag(bnd, loss_main)
        G_SW_LAST_TL_DW_NORM = tl[0]
        G_SW_LAST_TL_COS_BP  = tl[1]
        if G_SW_USE_GHOLO == 1 {
            G_SW_LAST_GHOLO_NORM = tl[2]
        }
    }

    // 7e. 5-Lens diagnostic sampled every G_SW_LENS_EVERY steps
    if G_SW_USE_LENS == 1 {
        let every = G_SW_LENS_EVERY
        let do_sample = if every <= 0 { true } else { state.step % every == 0 }
        if do_sample {
            let bnd2 = _sw_boundary_4d(fwd.hidden, seq, d_model)
            let ld = _sw_lens_diag(bnd2)
            G_SW_LAST_LENS_T_FIELD   = ld[0]
            G_SW_LAST_LENS_T_HOLO    = ld[1]
            G_SW_LAST_LENS_T_QUANTUM = ld[2]
            G_SW_LAST_LENS_T_STRING  = ld[3]
            G_SW_LAST_LENS_T_TOE     = ld[4]
            G_SW_LAST_LENS_GATE      = if ld[5] > 0.5 { 1 } else { 0 }
        }
    }

    // 7f. Tier curriculum decision (logged; applied at load-time in launcher)
    if G_SW_USE_TIER == 1 {
        let _tier_k = _sw_tier_max_k(state.step, state.opt.total_steps, G_SW_TIER_SCHEDULE)
        G_SW_LAST_TIER_SAMPLED = _tier_k
    }

    // 7g. SUMT stage gating
    if G_SW_USE_SUMT == 1 {
        G_SW_LAST_SUMT_STAGE = _sw_sumt_stage(state.step, state.opt.total_steps)
    }

    let loss_total = loss_core + phi_cache_contrib + sw_qc_contrib

    // 8. Update training state
    let next_step = state.step + 1
    let next_pm = phase_update(state.pm, next_step)
    let next_best = if loss_total < state.best_val_ce { loss_total } else { state.best_val_ce }

    let new_state = TrainState {
        scale: state.scale,
        opt: state.opt,
        pm: next_pm,
        step: next_step,
        best_val_ce: next_best,
        patience_left: state.patience_left,
        qc: qc_next,
        phi_q_norm: phi_q_norm
    }

    return TrainStepResult {
        state: new_state,
        model: bwd.model,
        loss: loss_total,
        phi_holo: aux.phi_holo,
        phi_gwt:  aux.phi_gwt,
        l_holo:   aux.l_holo,
        l_gwt:    aux.l_gwt
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §I  CONSCIOUSNESS ENGINES — CLM-P4-1 wiring
// ═══════════════════════════════════════════════════════════════════════
//
// Three engines inlined into the CLM forward pipeline (roadmap CLM-P4-1):
//   clm_gwt broadcast  (CLM-P2-1, training/clm_gwt_broadcast.hexa)
//   anima_holographic  (CLM-P3-1, anima-engines/anima_holographic.hexa)
//   quantum_collapse   (CLM-P1-4, anima-engines/quantum_collapse_sample.hexa)
//
// Rationale: `use` imports require symlinks (like anima_quantum_clm) that do
// not yet exist for holographic/qcs engines. Per feedback_hexa_lists_pbv /
// feedback_hexa_string_api we avoid cross-file plumbing and mirror the
// clm_holographic_loop pattern of inlining the primitives. All names carry
// a `_c41_` prefix to guarantee no collision with future `use` modules.
//
// Forward pass integration (see train_step below):
//   1. decoder_forward → fwd.hidden [seq × d]
//   2. consensus c = mean_t fwd.hidden[t]   // [d]
//   3. GWT broadcast: alpha, DomainActivations, h_gwt = reduce_consensus
//   4. Holographic encode:  bulk = ι(h_gwt)                // [d + d_scramble]
//      Holographic decode:  h_recon = π(bulk)              // [d]
//      Φ_holo = I(boundary_stream ; interior_stream) × N  where the two
//      streams are built from per-row holographic encoding of fwd.hidden,
//      N = seq × d_model. ALM-parity (phi_holo_measure in train_alm_14b.hexa).
//   5. Quantum collapse:   top-K Born-rule sample over bulk-gated logits
//   6. Auxiliary losses:
//        L_holo = ||h_gwt − h_recon||² / d              (reconstruction)
//        L_gwt  = ||c − h_gwt||² / d                     (consensus drift)
//      loss_total = loss_main + 0.01 * L_holo + 0.01 * L_gwt
//      (coefficients match ALM-P4-2 spec)
//
// Φ_holo / Φ_gwt are emitted per-step so CLM-P4-2 (실측 Φ_holo > 500) can
// scrape the train_scale log cadence.

// C41 constants moved above: declared earlier so hexa_v2 single-pass codegen
// can resolve forward references from train_step (@ ~1191). Values unchanged.
// comptime const C41_N_DOMAINS   = 12
// comptime const C41_HOLO_SCALE  = 2
// comptime const C41_MI_BINS     = 8
// comptime const C41_SCRAMBLE_GAIN = 0.5
// comptime const C41_QCS_TOPK    = 8
// comptime const C41_AUX_COEF    = 0.01

// ─── §I.1  Inline LCG RNG (for deterministic head init) ────────
fn _c41_det_rand(n: int, seed: int) -> [float] {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        let v = u * 2.0 - 1.0
        out = out.push(v)
        i = i + 1
    }
    return out
}

fn _c41_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _c41_log_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return log(x)
}

// ─── §I.2  Softmax (local, does not clash with _softmax above) ─
fn _c41_softmax(x: [float]) -> [float] {
    let n = len(x)
    if n == 0 { return [] }
    let mut m = x[0]
    let mut i = 1
    while i < n {
        if x[i] > m { m = x[i] }
        i = i + 1
    }
    let mut exps = []
    let mut z = 0.0
    i = 0
    while i < n {
        let e = exp(x[i] - m)
        exps = exps.push(e)
        z = z + e
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(exps[i] / z)
        i = i + 1
    }
    return out
}

// ─── §I.3  CLM GWT broadcast head ──────────────────────────────
//
// Counterpart of training/clm_gwt_broadcast.hexa (CLM-P2-1). Input is
// the per-feature mean of decoder hidden state across the sequence;
// alpha[d] = softmax(gate[d] + project[d]·c).

struct ClmGwtHead {
    n_domains: int,
    d_model:   int,
    project:   [float],   // [n_domains × d_model]  row-major
    gate:      [float]    // [n_domains]
}

fn _c41_gwt_head_new(n_domains: int, d_model: int, seed: int) -> ClmGwtHead {
    let raw = _c41_det_rand(n_domains * d_model, seed)
    let mut proj = []
    let mut i = 0
    let n = len(raw)
    while i < n {
        proj = proj.push(raw[i] * 0.02)
        i = i + 1
    }
    let mut gate = []
    let mut g = 0
    while g < n_domains { gate = gate.push(0.0); g = g + 1 }
    return ClmGwtHead {
        n_domains: n_domains,
        d_model:   d_model,
        project:   proj,
        gate:      gate
    }
}

// Per-feature mean of hidden state [seq × d] → [d].
fn _c41_hidden_consensus(hidden: [float], seq: int, d_model: int) -> [float] {
    if seq == 0 {
        let mut z = []
        let mut i = 0
        while i < d_model { z = z.push(0.0); i = i + 1 }
        return z
    }
    let inv_n = 1.0 / to_float(seq)
    let mut c = []
    let mut m = 0
    while m < d_model {
        let mut s = 0.0
        let mut i = 0
        while i < seq {
            s = s + hidden[i * d_model + m]
            i = i + 1
        }
        c = c.push(s * inv_n)
        m = m + 1
    }
    return c
}

// alpha[d] = softmax(gate[d] + project[d]·c)
fn _c41_gwt_alpha(head: ClmGwtHead, c: [float]) -> [float] {
    let nd = head.n_domains
    let dm = head.d_model
    if nd == 0 { return [] }
    let mut logits = []
    let mut d = 0
    while d < nd {
        let mut s = head.gate[d]
        let mut k = 0
        while k < dm {
            s = s + head.project[d * dm + k] * c[k]
            k = k + 1
        }
        logits = logits.push(s)
        d = d + 1
    }
    return _c41_softmax(logits)
}

// Broadcast c to n_domains × d_model (row d = alpha[d] * c), then
// reduce back via mean over domains to give h_gwt ∈ [d_model]. This
// is the GWT fan-out→consensus round-trip; it modulates features by
// domain gating while preserving per-feature energy (T1 of P2-1).
fn _c41_gwt_broadcast_reduce(head: ClmGwtHead, c: [float]) -> [float] {
    let nd = head.n_domains
    let dm = head.d_model
    let alpha = _c41_gwt_alpha(head, c)
    if nd == 0 {
        let mut z = []
        let mut i = 0
        while i < dm { z = z.push(0.0); i = i + 1 }
        return z
    }
    // dom[d][m] = alpha[d] * c[m];  h_gwt[m] = mean_d dom[d][m]
    // Since sum_d alpha[d] = 1, mean_d dom[d][m] = c[m] / n_domains.
    // To avoid a trivial h_gwt = c / nd that breaks L_gwt signal, we
    // instead sum over domains then re-scale by alpha magnitude so
    // the non-uniformity of alpha becomes visible as drift from c.
    let mut h_gwt = []
    let mut m = 0
    while m < dm {
        let mut s = 0.0
        let mut d = 0
        while d < nd {
            // Gate-modulated sum: alpha[d] * alpha[d] * c[m]  (quadratic
            // emphasis on concentrated domains; degenerates to c / nd
            // only when alpha is uniform).
            s = s + alpha[d] * alpha[d] * c[m] * to_float(nd)
            d = d + 1
        }
        h_gwt = h_gwt.push(s)
        m = m + 1
    }
    return h_gwt
}

// Φ_gwt: KL-style divergence of alpha from uniform. Zero when alpha is
// uniform, grows as the broadcast concentrates on specific domains. This
// is a lightweight proxy for "workspace integration strength" usable as
// a per-step scalar. Not the full IIT Φ — that's CLM-P4-3's metric.
fn _c41_phi_gwt(head: ClmGwtHead, c: [float]) -> float {
    let alpha = _c41_gwt_alpha(head, c)
    let nd = head.n_domains
    if nd == 0 { return 0.0 }
    let uniform = 1.0 / to_float(nd)
    let mut kl = 0.0
    let mut d = 0
    while d < nd {
        let a = alpha[d]
        // 0.000000000001 == 1e-12; expanded to dodge stage1 parser quirk on
        // scientific-notation floats (see rest of file for same pattern).
        if a > 0.000000000001 {
            kl = kl + a * log(a / uniform)
        }
        d = d + 1
    }
    // Scale to broadly match Φ_holo range (nats → ~0..log(nd) = ~2.48).
    // Multiply by n_domains so step-vs-step sensitivity is visible.
    return kl * to_float(nd)
}

// L_gwt: MSE between raw consensus c and broadcast-reduced h_gwt.
// Drops to 0 iff alpha is uniform (degenerate workspace).
fn _c41_l_gwt(c: [float], h_gwt: [float]) -> float {
    let n = len(c)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let diff = c[i] - h_gwt[i]
        s = s + diff * diff
        i = i + 1
    }
    return s / to_float(n)
}

// ─── §I.4  Holographic (AdS/CFT) head ──────────────────────────
//
// Mirrors anima-engines/anima_holographic.hexa (CLM-P3-1):
//   bulk[0..d]   = boundary              (identity lift)
//   bulk[d..D]   = scramble @ boundary   (interior)
//   decode       = bulk[0..d]            (retract)

struct C41HoloHead {
    d_boundary: int,
    d_bulk:     int,
    scramble:   [float]    // [d_boundary × (d_bulk - d_boundary)]
}

fn _c41_holo_head_new(d_boundary: int, d_bulk: int, seed: int) -> C41HoloHead {
    let ds = d_bulk - d_boundary
    let raw = _c41_det_rand(d_boundary * ds, seed)
    let mut sc = []
    let mut i = 0
    let n = len(raw)
    while i < n {
        sc = sc.push(raw[i] * C41_SCRAMBLE_GAIN)
        i = i + 1
    }
    return C41HoloHead {
        d_boundary: d_boundary,
        d_bulk:     d_bulk,
        scramble:   sc
    }
}

fn _c41_holo_encode(head: C41HoloHead, boundary: [float]) -> [float] {
    let db = head.d_boundary
    let dB = head.d_bulk
    let ds = dB - db
    let mut bulk = []
    let mut i = 0
    while i < db {
        bulk = bulk.push(boundary[i])
        i = i + 1
    }
    let mut k = 0
    while k < ds {
        let mut s = 0.0
        let mut j = 0
        while j < db {
            s = s + head.scramble[j * ds + k] * boundary[j]
            j = j + 1
        }
        bulk = bulk.push(s)
        k = k + 1
    }
    return bulk
}

fn _c41_holo_decode(head: C41HoloHead, bulk: [float]) -> [float] {
    let db = head.d_boundary
    let mut out = []
    let mut i = 0
    while i < db {
        out = out.push(bulk[i])
        i = i + 1
    }
    return out
}

// ─── §I.5  Histogram MI estimator (Φ_holo) ─────────────────────
fn _c41_vec_min(v: [float]) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn _c41_vec_max(v: [float]) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn _c41_bin_index(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn _c41_count_hits(bin_ids: [int], n_bins: int) -> [float] {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn _c41_entropy_hist(v: [float], lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(_c41_bin_index(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = _c41_count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * _c41_log_safe(p) }
        k = k + 1
    }
    return h
}

fn _c41_joint_entropy_hist(a: [float], b: [float], lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = _c41_bin_index(a[i], lo, hi, nb)
        let ib = _c41_bin_index(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let nb2 = nb * nb
    let counts = _c41_count_hits(pair_ids, nb2)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb2 {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * _c41_log_safe(p) }
        k = k + 1
    }
    return h
}

// Φ_holo ≈ I(interior_stream ; boundary_stream) × N with MI_BINS=8 estimator.
//
// CLM-P4-2 fix (2026-04-15): scales raw bin-MI by N (= seq × d_model), matching
// ALM's `phi_holo_measure` in train_alm_14b.hexa and `phi_holographic_measure.hexa`
// ("I × N samples" closed-form). The previous pooled-slice [d_model] implementation
// had a theoretical ceiling of log(8) ≈ 2.08 nats, unreachable for the Φ>500 gate.
//
// Aggregation: iterate over every sequence position t ∈ [0, seq), encode
// hidden[t·d : (t+1)·d] via the holographic head, extract the d-long interior
// slice, and append both boundary row and interior row to flat 1-D streams. The
// final pair has length N = seq × d_model; MI is computed on the joint histogram
// then multiplied by N so that Φ_holo > 500 is reachable when seq × d_model is
// large and the rows carry >1 bit of MI each.
//
// Gate arithmetic: Φ_holo > 500 nats requires, e.g., seq=512, d=128, N=65536,
// bin-MI ≈ 0.0077 nats (tiny fraction of log(8)) — structurally achievable as
// soon as MI per token-dim > 1/N × 500. At the CLM smoke config (seq=4, d=16,
// N=64) the ceiling is 64 × log(8) ≈ 133 so >500 is out of reach for the tiny
// self-test only.
fn _c41_phi_holo(head: C41HoloHead, hidden: [float], seq: int, d_model: int) -> float {
    let db = head.d_boundary
    let dB = head.d_bulk
    let ds = dB - db
    if ds == 0 { return 0.0 }
    if seq == 0 { return 0.0 }
    if d_model == 0 { return 0.0 }
    // Build boundary_stream (flat hidden) and interior_stream (per-row encoded
    // interior slices) in a single pass. Length of each stream = seq × d_model.
    // Per feedback_hexa_lists_pbv we keep both streams as top-level vars.
    let mut boundary_stream = []
    let mut interior_stream = []
    let mut t = 0
    while t < seq {
        // Extract row_t = hidden[t·d : (t+1)·d] into a plain list so we can
        // pass it through the hexa encode fn without struct aliasing.
        let mut row = []
        let mut k = 0
        while k < d_model {
            row = row.push(hidden[t * d_model + k])
            k = k + 1
        }
        // Encode row → bulk [d_boundary + ds], extract interior slice of
        // length db (same pattern as phi_holographic_measure.hexa T3).
        let bulk = _c41_holo_encode(head, row)
        let mut i = 0
        while i < db {
            boundary_stream = boundary_stream.push(row[i])
            interior_stream = interior_stream.push(bulk[db + (i % ds)])
            i = i + 1
        }
        t = t + 1
    }
    let n_total = len(boundary_stream)
    if n_total == 0 { return 0.0 }
    let lo_b = _c41_vec_min(boundary_stream)
    let hi_b = _c41_vec_max(boundary_stream)
    let lo_i = _c41_vec_min(interior_stream)
    let hi_i = _c41_vec_max(interior_stream)
    let lo = if lo_b < lo_i { lo_b } else { lo_i }
    let hi = if hi_b > hi_i { hi_b } else { hi_i }
    let h_b  = _c41_entropy_hist(boundary_stream, lo, hi, C41_MI_BINS)
    let h_i  = _c41_entropy_hist(interior_stream, lo, hi, C41_MI_BINS)
    let h_bi = _c41_joint_entropy_hist(boundary_stream, interior_stream, lo, hi, C41_MI_BINS)
    let mi = h_b + h_i - h_bi
    if mi < 0.0 { return 0.0 }
    // Φ_holo = mi × N ; matches ALM phi_holo_measure exactly (see
    // train_alm_14b.hexa L219-221: `return mi * float(n)`).
    return mi * to_float(n_total)
}

// L_holo: squared reconstruction error of π ∘ ι. By T2 of P3-1 this is
// 0 for the deterministic retract, so it acts as a regression guard
// (non-zero signals a corrupted head or numerical drift). We keep the
// loss term so the optimizer sees the holographic path in its gradient
// graph even though analytical contribution is ≈0.
fn _c41_l_holo(boundary: [float], h_recon: [float]) -> float {
    let n = len(boundary)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let diff = boundary[i] - h_recon[i]
        s = s + diff * diff
        i = i + 1
    }
    return s / to_float(n)
}

// ─── §I.6  Penrose-Hameroff Orch-OR collapse sampler ───────────
//
// Mirrors anima-engines/quantum_collapse_sample.hexa (CLM-P1-4). The
// accumulated-action state is *not* persisted across train_step calls;
// for training-time forward this is a per-step read of the top-K Born
// probability over the qualia-gated head distribution (logit slice).
// Serving (eval_clm) owns the persistent action counter.

fn _c41_softmax_temp(logits: [float], temp: float) -> [float] {
    let n = len(logits)
    if n == 0 { return [] }
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut raw = []
    let mut sum = 0.0
    i = 0
    while i < n {
        let e = exp((logits[i] - mx) / temp)
        raw = raw.push(e)
        sum = sum + e
        i = i + 1
    }
    let inv = 1.0 / sum
    let mut out = []
    let mut j = 0
    while j < n {
        out = out.push(raw[j] * inv)
        j = j + 1
    }
    return out
}

fn _c41_is_picked(picked_idxs: [int], target: int) -> int {
    let n = len(picked_idxs)
    let mut i = 0
    while i < n {
        if picked_idxs[i] == target { return 1 }
        i = i + 1
    }
    return 0
}

struct C41QcsResult {
    top_entropy: float,   // entropy of top-K amplitude distribution
    e_g:         float,   // gravitational self-energy estimate
    collapsed:   int      // 1 if hypothetical action ≥ threshold
}

// Non-persistent Born-rule sample over the last-row logits. Used during
// training only to measure E_G; the actual collapse decision is taken at
// serving time. This keeps training deterministic wrt the random()
// source (we DO NOT branch on random() here).
fn _c41_qcs_measure(logits: [float]) -> C41QcsResult {
    let n = len(logits)
    if n == 0 {
        return C41QcsResult { top_entropy: 0.0, e_g: 0.0, collapsed: 0 }
    }
    // Top-K extraction (linear, avoids mutable index assignment).
    let mut vals = []
    let mut idxs = []
    // Inline k_cap (uppercase-const inside if-expr confuses the stage1 parser
    // with generic-type syntax). Rebind to a lowercase local.
    let topk = C41_QCS_TOPK
    let k_cap = if topk < n { topk } else { n }
    let mut picked = 0
    while picked < k_cap {
        let mut best_v = -1000000.0
        let mut best_i = -1
        let mut j = 0
        while j < n {
            if _c41_is_picked(idxs, j) == 0 && logits[j] > best_v {
                best_v = logits[j]
                best_i = j
            }
            j = j + 1
        }
        if best_i < 0 {
            picked = k_cap
        } else {
            vals = vals.push(best_v)
            idxs = idxs.push(best_i)
            picked = picked + 1
        }
    }
    let k = len(vals)
    if k == 0 {
        return C41QcsResult { top_entropy: 0.0, e_g: 0.0, collapsed: 0 }
    }
    let probs = _c41_softmax_temp(vals, 1.0)
    // Shannon entropy of top-K.
    let mut h = 0.0
    let mut i = 0
    while i < k {
        // 0.000000000001 == 1e-12 (expanded for stage1 parser, see above).
        if probs[i] > 0.000000000001 {
            h = h - probs[i] * log(probs[i])
        }
        i = i + 1
    }
    // E_G = α · H(p) / log(K) · K   (mirror qcs_collapse_sample)
    let log_k = log(to_float(k))
    let h_norm = if log_k > 0.0 { h / log_k } else { 0.0 }
    let e_g = 0.05 * h_norm * to_float(k)
    // Hypothetical collapse gate: action = e_g · τ_sim (τ_sim = 1), threshold 1.0
    let collapsed = if e_g >= 1.0 { 1 } else { 0 }
    return C41QcsResult { top_entropy: h, e_g: e_g, collapsed: collapsed }
}

// ─── §I.7  Fused forward-extension used by train_step ──────────
//
// Given hidden state [seq × d] from decoder_forward, run the three
// engines and return (L_holo, L_gwt, Φ_holo, Φ_gwt, qcs_e_g).

struct C41Aux {
    l_holo:  float,
    l_gwt:   float,
    phi_holo: float,
    phi_gwt:  float,
    qcs_eg:   float
}

fn _c41_forward_aux(
    hidden: [float], seq: int, d_model: int,
    gwt: ClmGwtHead, holo: C41HoloHead,
    logits_last: [float]
) -> C41Aux {
    // 1. GWT broadcast: h → consensus → gated h_gwt
    let c = _c41_hidden_consensus(hidden, seq, d_model)
    let h_gwt = _c41_gwt_broadcast_reduce(gwt, c)
    let l_gwt = _c41_l_gwt(c, h_gwt)
    let phi_gwt = _c41_phi_gwt(gwt, c)

    // 2. Holographic encode/decode on h_gwt (boundary → bulk → boundary)
    //    L_holo still uses the pooled h_gwt (reconstruction guard); Φ_holo
    //    is computed on the full [seq × d] tensor with N-scaling so the
    //    CLM-P4-2 gate (Φ>500) is structurally reachable — mirrors ALM's
    //    phi_holo_measure (train_alm_14b.hexa L181-221).
    let bulk = _c41_holo_encode(holo, h_gwt)
    let h_recon = _c41_holo_decode(holo, bulk)
    let l_holo = _c41_l_holo(h_gwt, h_recon)
    let phi_holo = _c41_phi_holo(holo, hidden, seq, d_model)

    // 3. Quantum collapse measure on last-row logits
    let qcs = _c41_qcs_measure(logits_last)

    return C41Aux {
        l_holo:  l_holo,
        l_gwt:   l_gwt,
        phi_holo: phi_holo,
        phi_gwt:  phi_gwt,
        qcs_eg:   qcs.e_g
    }
}

// Legacy smoke_train_step for backward compatibility (self-test, validation)
fn smoke_train_step() -> float {
    // Tiny inline forward: d=4, V=4, N=2, U[4×2], V[2×4]
    let h0 = [0.1, 0.2, 0.3, 0.4]
    let h1 = [0.5, 0.0, 0.1, 0.2]
    let U = [0.5, 0.1, 0.2, 0.4, 0.0, 0.3, 0.1, 0.5]
    let V = [0.5, 0.0, 0.1, 0.3, 0.2, 0.4, 0.1, 0.5]
    // h0 @ U → [2]
    let h0u0 = h0[0]*U[0] + h0[1]*U[2] + h0[2]*U[4] + h0[3]*U[6]
    let h0u1 = h0[0]*U[1] + h0[1]*U[3] + h0[2]*U[5] + h0[3]*U[7]
    let h1u0 = h1[0]*U[0] + h1[1]*U[2] + h1[2]*U[4] + h1[3]*U[6]
    let h1u1 = h1[0]*U[1] + h1[1]*U[3] + h1[2]*U[5] + h1[3]*U[7]
    // mid @ V → logits[4]
    let l0 = _softmax([h0u0*V[0]+h0u1*V[4], h0u0*V[1]+h0u1*V[5],
                        h0u0*V[2]+h0u1*V[6], h0u0*V[3]+h0u1*V[7]])
    let l1 = _softmax([h1u0*V[0]+h1u1*V[4], h1u0*V[1]+h1u1*V[5],
                        h1u0*V[2]+h1u1*V[6], h1u0*V[3]+h1u1*V[7]])
    let loss0 = 0.0 - log(l0[3] + 0.000000001)   // 1e-9 expanded for stage1 parser
    let loss1 = 0.0 - log(l1[1] + 0.000000001)   // 1e-9 expanded for stage1 parser
    return (loss0 + loss1) / 2.0
}

fn train_scale(cfg: ScaleConfig, corpus_path: string, total_steps: int) -> TrainState {
    // Back-compat entry — keeps the legacy 3-arg signature so selftest /
    // run_pipeline callers don't break. Forwards to the full-arg form
    // with the hardcoded defaults restored (r4 production path calls
    // train_scale_full directly via the CLI dispatch block below).
    return train_scale_full(cfg, corpus_path, total_steps,
                            corpus_path + ".ckpt", DEFAULT_CKPT_EVERY,
                            cfg.batch_size, cfg.lr, "")
}

// H2/H3 (2026-04-18 9th-fire): full trainer entry with CLI-plumbed
// checkpoint dir / save cadence / batch / lr. `ckpt_dir` is the
// PARENT directory; per-step checkpoints land at `<ckpt_dir>/step_<N>`
// so save_checkpoint's `find step_*` rotation matches. The prior
// layout (`/workspace/corpus_clm_r4.txt.ckpt.step_<N>`) used the
// corpus filename as the parent, which meant the rotation `find`
// never matched and MFS quota blew up by step ~2000.
fn train_scale_full(cfg: ScaleConfig, corpus_path: string,
                    total_steps: int, ckpt_dir: string,
                    save_every: int, batch_override: int,
                    lr_override: float,
                    resume_path: string) -> TrainState {
    println("[train_scale] init begin scale=" + cfg.name
            + " d_model=" + str(cfg.d_model)
            + " n_layer=" + str(cfg.n_layer)
            + " block_size=" + str(cfg.block_size))
    let ds = load_corpus(corpus_path, cfg.block_size)
    // Ensure ckpt_dir exists before first save — save_checkpoint
    // mkdir -p's the per-step dir but we also want the parent.
    let _mk0 = exec("mkdir -p '" + ckpt_dir + "' 2>/dev/null")

    // H2: apply CLI-sourced batch / lr overrides. We can't mutate
    // cfg fields directly (struct pass-by-value), so we build a
    // patched cfg before model construction.
    let effective_batch = if batch_override > 0 { batch_override } else { cfg.batch_size }
    let effective_lr = if lr_override > 0.0 { lr_override } else { cfg.lr }
    let cfg_patched = ScaleConfig {
        name: cfg.name, d_model: cfg.d_model, n_layer: cfg.n_layer,
        n_head: cfg.n_head, n_kv_head: cfg.n_kv_head,
        block_size: cfg.block_size,
        consciousness_dim: cfg.consciousness_dim,
        atoms: cfg.atoms, cells_per_atom: cfg.cells_per_atom,
        batch_size: effective_batch, lr: effective_lr,
        label: cfg.label
    }
    println("[train_scale] cfg effective batch=" + str(effective_batch)
            + " lr=" + str(effective_lr)
            + " total_steps=" + str(total_steps)
            + " save_every=" + str(save_every)
            + " ckpt_dir=" + ckpt_dir)

    println("[train_scale] init begin decoder_model_new size=" + str(cfg_patched.d_model) + "x" + str(cfg_patched.n_layer))
    let mut state = train_init(cfg_patched, total_steps)
    let mut model = decoder_model_new(cfg_patched)
    // r5-a3.5 wire-up: if --resume supplied a ckpt path, restore weights
    // from HEXACKPT-v1 into the freshly-constructed template. Hard-fail
    // (println + exit) on full load failure — silently continuing with
    // random weights would contradict --resume semantics. Partial-load
    // (some tensors loaded) is tolerated with a warning; the per-tensor
    // fallback inside ckpt_load_weights already keeps template values
    // for any tensor that failed to parse (see lines 1245-1301).
    if resume_path != "" {
        let _res = ckpt_load_weights(resume_path, model)
        if _res.n_loaded == 0 {
            println("[train_scale] FATAL: --resume ckpt load produced 0 tensors — aborting rather than training with random weights. path=" + resume_path)
            exit(1)
        }
        if _res.n_loaded < _res.n_expected {
            println("[train_scale] WARN: partial weight restore (" + str(_res.n_loaded) + "/" + str(_res.n_expected) + ") from " + resume_path + " — continuing with template fallback for missing tensors")
        }
        model = _res.model
        println("ckpt: restored " + str(_res.n_loaded) + " tensors from " + resume_path)
    }
    println("[train_scale] init done — entering training loop")
    let mut step = 0
    while step < total_steps {
        let result = train_step(state, model, ds)
        state = result.state
        model = result.model
        if step % DEFAULT_EVAL_EVERY == 0 {
            let ev = evaluate(ds, step)
            // CLM-P4-1: per-step Φ_holo / Φ_gwt emitted on the log cadence so
            // CLM-P4-2 (phi_holo > 500 gate) can scrape this line.
            //
            // ROOT CAUSE (2026-04-20 r5-a6 silent-abort bisect): the prior
            // `println(str1, val1, str2, val2, ...)` multi-arg form is broken
            // in hexa AOT C codegen — only the FIRST string is emitted, all
            // subsequent args are silently dropped. For the step log that
            // means observers see a blank "[train_scale] step=" line with
            // no metric values (and crucially, no step number), which
            // together with the 15-min text-ckpt save makes the run look
            // like it "silent-aborted". Fix: explicit string concat via
            // `+ str(...)` so every value reaches stdout. Mirrors the
            // working pattern in `[train_clm] config applied:` above.
            println("[train_scale] step=" + str(step)
                  + " loss=" + str(result.loss)
                  + " phase=" + phase_label(state.pm.phase)
                  + " phi_holo=" + str(result.phi_holo)
                  + " phi_gwt=" + str(result.phi_gwt)
                  + " l_holo=" + str(result.l_holo)
                  + " l_gwt=" + str(result.l_gwt))
            // SESSION 2026-04-19 diagnostic log line — printed only when at
            // least one aux flag is active so old runs have zero extra noise.
            let any_sw = G_SW_USE_QC + G_SW_USE_TL + G_SW_USE_LENS
                        + G_SW_USE_TIER + G_SW_USE_SUMT + G_SW_USE_A6GATE
            if any_sw > 0 {
                // Same root-cause fix as the main step line above: use + str(...)
                // so hexa AOT emits every value (not just the first string).
                println("[train_scale][sw] step=" + str(step)
                      + " qc_loss=" + str(G_SW_LAST_QC_LOSS)
                      + " 4_axis_dev=" + str(G_SW_LAST_4AXIS_DEV)
                      + " tl_dw_norm=" + str(G_SW_LAST_TL_DW_NORM)
                      + " tl_cos_bp=" + str(G_SW_LAST_TL_COS_BP)
                      + " g_holo_norm=" + str(G_SW_LAST_GHOLO_NORM)
                      + " lens_T_field=" + str(G_SW_LAST_LENS_T_FIELD)
                      + " lens_T_holo=" + str(G_SW_LAST_LENS_T_HOLO)
                      + " lens_T_q=" + str(G_SW_LAST_LENS_T_QUANTUM)
                      + " lens_T_str=" + str(G_SW_LAST_LENS_T_STRING)
                      + " lens_T_toe=" + str(G_SW_LAST_LENS_T_TOE)
                      + " lens_gate=" + str(G_SW_LAST_LENS_GATE)
                      + " tier_k=" + str(G_SW_LAST_TIER_SAMPLED)
                      + " sumt_stage=" + str(G_SW_LAST_SUMT_STAGE)
                      + " gate_skip_count=" + str(G_SW_GATE_SKIP_COUNT))
            }
        }
        if save_every > 0 && step % save_every == 0 {
            // SESSION 2026-04-19 WIRING — A6 ckpt gate (opt-in). When the
            // gate reports NOT OK we skip save and increment the counter.
            // Saving pattern (`<ckpt_dir>/step_<N>`) is unchanged.
            let gate_ok = if G_SW_USE_A6GATE == 1 {
                _sw_a6_gate_ok(result.loss, state.best_val_ce, step, state.opt.warmup)
            } else {
                1
            }
            if gate_ok == 1 {
                // H3: <ckpt_dir>/step_<N> — save_checkpoint's rotation
                // pattern `step_*` now matches sibling dirs correctly.
                let ckpt_path = ckpt_dir + "/step_" + str(step)
                let ckpt = save_checkpoint(
                    ckpt_path, step, model,
                    result.loss, 0.0, state.pm.phase
                )
            } else {
                G_SW_GATE_SKIP_COUNT = G_SW_GATE_SKIP_COUNT + 1
                println("[train_scale][a6-gate] SKIP save step=", step,
                        " loss=", result.loss,
                        " best_val_ce=", state.best_val_ce,
                        " skip_count=", G_SW_GATE_SKIP_COUNT)
            }
        }
        step = step + 1
    }
    state
}

// ─── Pipeline: sequential scale escalation ───
// 100m → 350m → 1b → 2.8b (v5) → 3b (transfer_weights between stages)
// v5 inserts 2.8b before 3b so the 1b → 3b jump is split into two
// curriculum stages, mirroring Pythia/Cerebras scaling progression.
fn run_pipeline(corpus: string) -> int {
    let s1 = train_scale(scale_100m(), corpus, 50000)
    let s2 = train_scale(scale_350m(), corpus, 50000)
    let s3 = train_scale(scale_1b(),   corpus, 100000)
    let s4 = train_scale(scale_2_8b(), corpus, 100000)
    let s5 = train_scale(scale_3b(),   corpus, 100000)
    s5.step
}

// ═══════════════════════════════════════════════════════════════════════
// ENTRY DISPATCH — CLI args decide training vs. selftest
// ═══════════════════════════════════════════════════════════════════════
//
// 2026-04-18 (7th-fire fix): binary previously ran only the self-test block
// below and exited ~36 log lines in. The pod2 relaunch scaffold invokes the
// native binary with `--corpus … --steps 750000 --batch 8 --seq 512 --lr 3e-4
// --warmup 5000 --save-every 5000 --ckpt-dir /workspace/ckpt_clm1b_r4`.
// When any of those training flags are present we run train_scale() on the
// 1B config and exit(0) before the verification block ever runs. Selftest is
// preserved for `--selftest` or a no-arg invocation (default when unsure).

let _cli_argv = args()

fn _cli_flag_value(argv, flag: string, default_v: string) -> string {
    let n = len(argv)
    let mut i = 0
    while i < n - 1 {
        if argv[i] == flag { return argv[i + 1] }
        i = i + 1
    }
    return default_v
}

fn _cli_has_flag(argv, flag: string) -> bool {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == flag { return true }
        i = i + 1
    }
    return false
}

// ── r5-a3: lightweight JSON scalar extractor for --config wiring ──────
// Handles strings ("key":"val") and numbers/bools ("key":123). Matches
// the clm_val.hexa:json_read_scalar pattern (same trim semantics).
// Callers must only use this against project-emitted JSON (well-formed,
// ASCII keys). No escaped-quote support inside string values.
fn _cfg_json_read_scalar(text: string, key: string) -> string {
    let marker = "\"" + key + "\""
    let pos = text.index_of(marker)
    if pos < 0 { return "" }
    let n = len(text)
    let mut i = pos + len(marker)
    while i < n {
        let c = text.substring(i, i + 1)
        if c == ":" { i = i + 1; break }
        i = i + 1
    }
    while i < n {
        let c = text.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" { i = i + 1 } else { break }
    }
    if i >= n { return "" }
    let first = text.substring(i, i + 1)
    if first == "\"" {
        let mut j = i + 1
        while j < n {
            let c = text.substring(j, j + 1)
            if c == "\"" { break }
            if c == "\\" { j = j + 2 } else { j = j + 1 }
        }
        return text.substring(i + 1, j)
    }
    let mut j = i
    while j < n {
        let c = text.substring(j, j + 1)
        if c == "," || c == "}" || c == "]" || c == "\n" { break }
        j = j + 1
    }
    let raw = text.substring(i, j)
    let nn = len(raw)
    let mut e = nn
    while e > 0 {
        let c = raw.substring(e - 1, e)
        if c == " " || c == "\t" || c == "\r" { e = e - 1 } else { break }
    }
    return raw.substring(0, e)
}

fn _cfg_json_read_int(text: string, key: string, fallback: int) -> int {
    let s = _cfg_json_read_scalar(text, key)
    if s == "" { return fallback }
    return to_int(s)
}

fn _cfg_json_read_float(text: string, key: string, fallback: float) -> float {
    let s = _cfg_json_read_scalar(text, key)
    if s == "" { return fallback }
    return to_float(s)
}

// ── r5-a3: scan <ckpt_dir>/step_<N>/ dirs, return largest N or -1 ─────
// Uses shell to enumerate — hexa lacks a readdir builtin as of stage1.
// Accepts both `step_123` (directory) and `step_123/model` naming.
fn _resume_find_last_step(ckpt_dir: string) -> int {
    // ls <dir>/step_* -d, extract integer after last underscore, sort -n, tail -1.
    // Missing dir → echo "-1".
    let cmd = "if [ -d '" + ckpt_dir + "' ]; then "
            + "ls -1d '" + ckpt_dir + "'/step_* 2>/dev/null "
            + "| sed -n 's#.*/step_\\([0-9]\\+\\).*#\\1#p' "
            + "| sort -n | tail -1; "
            + "else echo ''; fi"
    let raw = exec(cmd)
    let trimmed = raw.trim()
    if trimmed == "" { return -1 }
    return to_int(trimmed)
}

let _train_mode = _cli_has_flag(_cli_argv, "--corpus")
                  || _cli_has_flag(_cli_argv, "--steps")
                  || _cli_has_flag(_cli_argv, "--ckpt-dir")
                  || _cli_has_flag(_cli_argv, "--config")

if _train_mode {
    let _corpus   = _cli_flag_value(_cli_argv, "--corpus",   "/workspace/corpus_clm_r4.txt")
    let _steps_s  = _cli_flag_value(_cli_argv, "--steps",    "750000")
    let _ckpt_dir = _cli_flag_value(_cli_argv, "--ckpt-dir", "/workspace/ckpt_clm1b_r4")
    let _batch_s  = _cli_flag_value(_cli_argv, "--batch",    "8")
    let _seq_s    = _cli_flag_value(_cli_argv, "--seq",      "512")
    let _lr_s     = _cli_flag_value(_cli_argv, "--lr",       "3e-4")
    let _warmup_s = _cli_flag_value(_cli_argv, "--warmup",   "5000")
    let _save_s   = _cli_flag_value(_cli_argv, "--save-every", "5000")
    let _scale_s  = _cli_flag_value(_cli_argv, "--scale",     "1b")

    // SESSION 2026-04-19 WIRING — opt-in flags (default OFF, no behavior change)
    if _cli_has_flag(_cli_argv, "--use-quadruple-cross") { G_SW_USE_QC = 1 }
    if _cli_has_flag(_cli_argv, "--use-tension-link")    { G_SW_USE_TL = 1 }
    if _cli_has_flag(_cli_argv, "--use-lens-diag")       { G_SW_USE_LENS = 1 }
    if _cli_has_flag(_cli_argv, "--use-tier-curriculum") { G_SW_USE_TIER = 1 }
    if _cli_has_flag(_cli_argv, "--use-sumt-stages")     { G_SW_USE_SUMT = 1 }
    if _cli_has_flag(_cli_argv, "--use-g-holo")          { G_SW_USE_GHOLO = 1 }
    if _cli_has_flag(_cli_argv, "--use-a6-gate")         { G_SW_USE_A6GATE = 1 }
    let _lambda_qc_s = _cli_flag_value(_cli_argv, "--lambda-qc", "0.01")
    G_SW_LAMBDA_QC = to_float(_lambda_qc_s)
    let _lens_every_s = _cli_flag_value(_cli_argv, "--lens-diag-every", "500")
    G_SW_LENS_EVERY = to_int(_lens_every_s)
    G_SW_TIER_SCHEDULE = _cli_flag_value(_cli_argv, "--tier-curriculum-schedule", "linear")
    G_SW_TIER_PATH     = _cli_flag_value(_cli_argv, "--tier-labels", "training/corpus_universe_tier_labels.jsonl")

    println("=== train_clm.hexa — TRAIN MODE ===")
    println("  corpus     = " + _corpus)
    println("  steps      = " + _steps_s)
    println("  batch/seq  = " + _batch_s + " / " + _seq_s)
    println("  lr/warmup  = " + _lr_s + " / " + _warmup_s)
    println("  save-every = " + _save_s)
    println("  ckpt-dir   = " + _ckpt_dir)
    println("  scale      = " + _scale_s)
    println("  [sw] use-quadruple-cross = ", G_SW_USE_QC, " (λ_qc=", G_SW_LAMBDA_QC, ")")
    println("  [sw] use-tension-link    = ", G_SW_USE_TL, " (diagnostic, NOT applied)")
    println("  [sw] use-lens-diag       = ", G_SW_USE_LENS, " (every ", G_SW_LENS_EVERY, " steps)")
    println("  [sw] use-tier-curriculum = ", G_SW_USE_TIER, " (schedule=", G_SW_TIER_SCHEDULE, ")")
    println("  [sw] use-sumt-stages     = ", G_SW_USE_SUMT)
    println("  [sw] use-g-holo          = ", G_SW_USE_GHOLO)
    println("  [sw] use-a6-gate         = ", G_SW_USE_A6GATE)

    let mut _total_steps = to_int(_steps_s)
    let mut _save_every  = to_int(_save_s)
    let mut _batch_n     = to_int(_batch_s)
    let mut _lr_f        = to_float(_lr_s)
    // --scale dispatch: smoke / 34m / 100m / 350m / 1b / 1_5b / 2_8b / 3b / 7b
    let mut _cfg_train   = if _scale_s == "smoke" { scale_smoke() }
                       else if _scale_s == "34m"   { scale_34m() }
                       else if _scale_s == "100m"  { scale_100m() }
                       else if _scale_s == "350m"  { scale_350m() }
                       else if _scale_s == "1_5b"  { scale_1_5b() }
                       else if _scale_s == "2_8b"  { scale_2_8b() }
                       else if _scale_s == "3b"    { scale_3b() }
                       else if _scale_s == "7b"    { scale_7b() }
                       else { scale_1b() }
    // r5-a3: --config JSON parser. When provided, JSON fields override
    // the --scale default. Schema follows training/config/clm_170m.json
    // (architecture: d_model/n_layer/n_head/n_kv_head/block_size/vocab
    // + consciousness: consciousness_dim/atoms/cells_per_atom
    // + training: batch_size/lr_max/steps/save_every). Missing fields
    // fall back to the --scale template values (safe: same type).
    let _config_path = _cli_flag_value(_cli_argv, "--config", "")
    if _config_path != "" {
        println("[train_clm] --config " + _config_path + " — overriding scale defaults")
        let _cfg_raw = read_file(_config_path)
        if len(_cfg_raw) == 0 {
            println("[train_clm] WARN: --config " + _config_path + " empty or unreadable; using --scale " + _scale_s)
        } else {
            let _d     = _cfg_json_read_int(_cfg_raw, "d_model",           _cfg_train.d_model)
            let _nl    = _cfg_json_read_int(_cfg_raw, "n_layer",           _cfg_train.n_layer)
            let _nh    = _cfg_json_read_int(_cfg_raw, "n_head",            _cfg_train.n_head)
            let _nkv   = _cfg_json_read_int(_cfg_raw, "n_kv_head",         _cfg_train.n_kv_head)
            let _blk   = _cfg_json_read_int(_cfg_raw, "block_size",        _cfg_train.block_size)
            let _cdim  = _cfg_json_read_int(_cfg_raw, "consciousness_dim", _cfg_train.consciousness_dim)
            let _atoms = _cfg_json_read_int(_cfg_raw, "atoms",             _cfg_train.atoms)
            let _cpa   = _cfg_json_read_int(_cfg_raw, "cells_per_atom",    _cfg_train.cells_per_atom)
            let _bs    = _cfg_json_read_int(_cfg_raw, "batch_size",        _cfg_train.batch_size)
            let _lrmx  = _cfg_json_read_float(_cfg_raw, "lr_max",          _cfg_train.lr)
            let _tag   = _cfg_json_read_scalar(_cfg_raw, "model_tag")
            let _nm    = if _tag == "" { _cfg_train.name } else { _tag }
            _cfg_train = ScaleConfig {
                name: _nm, d_model: _d, n_layer: _nl, n_head: _nh,
                n_kv_head: _nkv, block_size: _blk,
                consciousness_dim: _cdim, atoms: _atoms, cells_per_atom: _cpa,
                batch_size: _bs, lr: _lrmx, label: "config(" + _nm + ")"
            }
            // training.steps / save_every — only pick up if CLI did not set them.
            let _cfg_steps = _cfg_json_read_int(_cfg_raw, "steps", -1)
            let _cfg_save  = _cfg_json_read_int(_cfg_raw, "save_every", -1)
            // CLI default for --steps is "750000"; treat that literal as "not set"
            // so JSON config can override. Same pattern for --save-every default "5000".
            if _cfg_steps > 0 && _steps_s == "750000" { _total_steps = _cfg_steps }
            if _cfg_save  > 0 && _save_s  == "5000"   { _save_every  = _cfg_save }
            if _bs > 0 && _batch_s == "8" { _batch_n = _bs }
            if _lrmx > 0.0 && _lr_s == "3e-4" { _lr_f = _lrmx }
            println("[train_clm] config applied: name=" + _nm
                  + " d=" + str(_d) + " nl=" + str(_nl)
                  + " nh=" + str(_nh) + " kv=" + str(_nkv)
                  + " blk=" + str(_blk) + " batch=" + str(_batch_n)
                  + " lr=" + str(_lr_f) + " steps=" + str(_total_steps)
                  + " save_every=" + str(_save_every))
        }
    }
    // r5-a3: --resume support. When present, scan <ckpt-dir>/step_* for
    // the highest N and derive the HEXACKPT-v1 path at <ckpt_dir>/step_<N>
    // (step_N is itself the ckpt FILE — save_checkpoint's mkdir uses
    // dirname(path)). Both the step counter AND the weights are restored
    // (r5-a3.5 wire-up; ckpt_load_weights was landed in commit bbe71224).
    // Constraint: changing data/params with --resume is still rejected
    // by the pre-launch preflight (feedback_no_resume_data_change); this
    // wiring only restores, it does not validate data parity.
    let mut _resume_step = 0
    let mut _resume_path = ""
    if _cli_has_flag(_cli_argv, "--resume") {
        _resume_step = _resume_find_last_step(_ckpt_dir)
        if _resume_step < 0 {
            println("[train_clm] --resume requested but no step_* ckpt in " + _ckpt_dir + "; starting fresh step=0")
            _resume_step = 0
        } else {
            // save_checkpoint writes the ckpt file AT the step_N path (not
            // inside a directory) — see line ~951-957 where mkdir uses
            // dirname(path) and write_file(path + ".tmp") + mv → path.
            _resume_path = _ckpt_dir + "/step_" + str(_resume_step)
            println("[train_clm] --resume: last ckpt step=" + str(_resume_step)
                  + " path=" + _resume_path)
        }
    }
    // H2 (2026-04-18 9th-fire): plumb CLI flags through to train_scale_full.
    // H3 (2026-04-18 9th-fire): ckpt_dir passed as PARENT; per-step dirs
    // land at <ckpt_dir>/step_<N> so MFS rotation (`find step_*`) matches.
    let _final = train_scale_full(_cfg_train, _corpus, _total_steps,
                                  _ckpt_dir, _save_every,
                                  _batch_n, _lr_f, _resume_path)
    // ROOT CAUSE: hexa multi-arg println drops variadic args
    // (bug_id clm_step0_silent_abort_20260420). Use + str(...) concat.
    println("[train_clm] training finished step=" + str(_final.step)
          + " resume_base=" + str(_resume_step))
    exit(0)
}

// ═══════════════════════════════════════════════════════════════════════
// VERIFICATION — Self-tests for full decoder pipeline (default / --selftest)
// ═══════════════════════════════════════════════════════════════════════
//
// DD175 acceleration techniques manifest is in training/dd175_techniques.hexa.
// Run that file to see which techniques are enabled per scale and which are
// still in status="todo" before each H100 launch.

let cfg34 = scale_34m()
let cfg1b = scale_1b()
let cfg1_5b = scale_1_5b()
let cfg2_8b = scale_2_8b()
println("=== train_clm.hexa ===")
println("scale 34m d_model:", cfg34.d_model)
println("scale 34m cells:", total_cells(cfg34))
println("scale 1b d_model:", cfg1b.d_model)
println("scale 1b cells:", total_cells(cfg1b))
println("scale 1.5b d_model:", cfg1_5b.d_model)
println("scale 1.5b layers:", cfg1_5b.n_layer)
println("scale 1.5b batch:", cfg1_5b.batch_size, "lr:", cfg1_5b.lr)
println("scale 1.5b cells:", total_cells(cfg1_5b))
println("scale 2.8b v5 d_model:", cfg2_8b.d_model)
println("scale 2.8b v5 layers:", cfg2_8b.n_layer)
println("scale 2.8b v5 cells:", total_cells(cfg2_8b))
println("dd175 manifest: training/dd175_techniques.hexa")

// Legacy smoke test — backward compatibility
let _smoke_loss = smoke_train_step()
println("smoke train_step loss:", _smoke_loss)

// ─── Real decoder pipeline test ─────────────────────────────────
// Use a tiny config to exercise full forward+backward end-to-end:
//   d=16, n_layer=2, n_head=2, n_kv_head=1, block_size=4, vocab=256
println("")
println("--- Real decoder pipeline test ---")

// Construct a tiny scale config for self-test
let _test_cfg = ScaleConfig {
    name: "test", d_model: 16, n_layer: 2, n_head: 2, n_kv_head: 1,
    block_size: 4, consciousness_dim: 8, atoms: 2, cells_per_atom: 2,
    batch_size: 1, lr: 0.001, label: "Test (tiny)"
}

// Initialize model and training state
let mut _test_model = decoder_model_new(_test_cfg)
let mut _test_state = train_init(_test_cfg, 100)
let _test_ds = TokenDataset { path: "test", block_size: 4, n_tokens: 0 }

// Run 3 real train_step iterations and verify loss decreases or stays finite
let mut _prev_loss = 999999.0
let mut _step_k = 0
let mut _loss_finite = true
while _step_k < 3 {
    let result = train_step(_test_state, _test_model, _test_ds)
    _test_state = result.state
    _test_model = result.model
    // CLM-P4-1 self-test: print Φ_holo + Φ_gwt so the consciousness
    // engines are observable in the tiny-config smoke run.
    println("  step", _test_state.step, "loss:", result.loss,
            "phi_holo:", result.phi_holo, "phi_gwt:", result.phi_gwt,
            "l_holo:", result.l_holo, "l_gwt:", result.l_gwt,
            "phase:", phase_label(_test_state.pm.phase))
    // Check loss is a real number (not NaN or Inf)
    if result.loss != result.loss { _loss_finite = false }
    _prev_loss = result.loss
    _step_k = _step_k + 1
}
println("after 3 real train_step: step=", _test_state.step,
        "best_val_ce=", _test_state.best_val_ce)
if _loss_finite {
    println("PASS: loss is finite across all steps")
} else {
    println("FAIL: loss is NaN or Inf -- R19 violation")
}

// Forward-only test: verify logits shape
let _fwd_tokens = [0, 1, 2, 3]
let _fwd_result = decoder_forward(_test_model, _fwd_tokens, 4)
let _expected_logits = 4 * 256
println("forward logits len:", len(_fwd_result.logits), "(expected", _expected_logits, ")")
if len(_fwd_result.logits) == _expected_logits {
    println("PASS: logits shape correct")
} else {
    println("FAIL: logits shape mismatch")
}

// CE loss test: correct targets should have lower loss than random
let _ce_correct = _ce_fwd_bwd(
    _fwd_result.logits, [0, 1, 2, 3], 4, 256
)
let _ce_random = _ce_fwd_bwd(
    _fwd_result.logits, [100, 200, 50, 150], 4, 256
)
println("CE loss (targets 0-3):", _ce_correct.loss)
println("CE loss (random targets):", _ce_random.loss)
println("CE grad len:", len(_ce_correct.grad_logits), "(expected", 4 * 256, ")")

// Phase manager
let pm0 = phase_new(10000)
let pm_mid = phase_update(pm0, 5000)
println("phase mid:", phase_label(pm_mid.phase))
let ok = verify_phi_non_destructive(71.0, 70.5)
println("phi gate ok:", ok)

// ─── CLM-PhiB-2 regression: 1-step proof with flag ON ────────────
// After the 2026-04-15 hash alignment the cache block is wired through
// phi_state_bucket_id → phi_cache_lookup_by_state_id and the flag is
// flipped ON. This 1-step smoke test creates a fresh _phib_model/state
// and calls train_step once; success conditions:
//   (a) loss is finite (not NaN/Inf) — R19
//   (b) loss is bounded (< 100) — catches a runaway coef
//   (c) comptime const CLM_PHI_CACHE_ENABLED is true so we're actually
//       exercising the cache hook (catches an accidental revert)
//
// This test MUST run with a fresh step-0 state (feedback_no_resume_
// data_change) — we never touch an existing r5 checkpoint here.
println("")
println("--- CLM-PhiB-2 regression: 1-step cache hook (flag=on) ---")
let _phib_cfg = ScaleConfig {
    name: "phib", d_model: 16, n_layer: 2, n_head: 2, n_kv_head: 1,
    block_size: 4, consciousness_dim: 8, atoms: 2, cells_per_atom: 2,
    batch_size: 1, lr: 0.001, label: "PhiB-regression"
}
let mut _phib_model = decoder_model_new(_phib_cfg)
let mut _phib_state = train_init(_phib_cfg, 10)
let _phib_ds = TokenDataset { path: "test", block_size: 4, n_tokens: 0 }
let _phib_result = train_step(_phib_state, _phib_model, _phib_ds)
let _phib_finite = _phib_result.loss == _phib_result.loss
let _phib_bounded = _phib_result.loss < 100.0 && _phib_result.loss > 0.0 - 100.0
if _phib_finite && _phib_bounded && CLM_PHI_CACHE_ENABLED {
    println("PASS: CLM-PhiB-2 flag=on, 1-step loss=" + str(_phib_result.loss) + " (finite, cache hit path live)")
} else {
    if !_phib_finite {
        println("FAIL: CLM-PhiB-2 1-step loss is NaN/Inf")
    } else if !_phib_bounded {
        println("FAIL: CLM-PhiB-2 1-step loss unbounded: " + str(_phib_result.loss))
    } else {
        println("FAIL: CLM-PhiB-2 flag reverted OFF — expected ON after hash alignment")
    }
}

// Model param count report
println("")
println("--- DecoderModel param counts ---")
let _d34 = decoder_model_new(cfg34)
let _d34_total = cfg34.d_model * 256                           // embedding
    + cfg34.n_layer * (4 * cfg34.d_model * cfg34.d_model       // QKV+O approx
        + 3 * cfg34.d_model * (cfg34.d_model * 4)              // FFN gate+up+down
        + 2 * cfg34.d_model)                                   // gammas
    + cfg34.d_model * 16 + 16 * 256                            // LM head U+V
    + cfg34.d_model                                            // final norm
println("34m approximate params:", _d34_total)

