// training/train_clm.hexa — ConsciousLM training loop structural port
// Source: training/train_clm.py (2165 LOC)
// Phase 2c structural port; PyTorch ops → TODO comments.
// Covers: scale configs, phase manager, dataset, train loop, checkpoint, eval.
//
// Orch-OR quantum controller is resolved via symlinks in training/:
//   training/anima_quantum_clm.hexa -> ../anima-engines/anima_quantum_clm.hexa
//   training/anima_quantum.hexa     -> ../anima-engines/anima_quantum.hexa
//   training/quantum_types.hexa     -> ../../hexa-lang/self/quantum_types.hexa
// (hexa resolves `use` relative to the importing file's directory; cross-dir
//  import requires a symlink until module search path lands.)
// 2026-04-19: hexa 0.1.0-stage1 parser rejects `use "..."` string-literal form
// ("expected identifier, got StringLit"). Module resolution uses identifier
// form + the importing file's dir — see lines 6-11 above for symlink setup.
// 2026-04-19 (same day): BOTH `use anima_quantum_clm` and `use "anima_quantum_clm"`
// hit the same runtime-undefined-fn failure due to hexa silent-exit-on-imports
// (feedback_hexa_silent_exit_5_imports). Disabled; the needed symbols are
// inlined as SMOKE-SAFE STUBS below corpus helpers. Re-enable once the
// interpreter bug is fixed or we switch to a compiled hexa build that
// correctly links multi-file modules.
// use anima_quantum_clm
// Track B contrastive phi cache (CLM-PhiB-1). Imported for the off-by-
// default lookup path in train_step — see phi_cache_loader.hexa for the
// rationale and wire-format docs. Flag-off import has no runtime effect
// beyond the self-test prints at module load.
// use phi_cache_loader

// H1 (2026-04-18 9th-fire): INLINED mmap-equivalent byte-window corpus
// loader. Replaces the n_tokens=0 stub + LCG noise batch path.
//
// Not `use "clm_mmap_loader"` because the pod2 relaunch scaffold only
// transpiles a fixed DEP list and we cannot modify the scaffold per
// task scope. Functions are a strict subset of training/clm_mmap_loader
// .hexa — `corpus_open` + `corpus_window` (the hot path) — verified
// against that file's 14/14 self-test on 2026-04-16.
struct CorpusDesc {
    path: string
    len: int
}

fn corpus_open(path: string) -> CorpusDesc {
    // `wc -c` is POSIX-portable and faster than `stat -c/-f`.
    let raw = exec("wc -c < '" + path + "' 2>/dev/null")
    let trimmed = raw.trim()
    if trimmed == "" {
        println("[clm_mmap_loader] FAIL: cannot stat " + path)
        return CorpusDesc { path: path, len: 0 }
    }
    let n = to_int(trimmed)
    println("[clm_mmap_loader] opened " + path + " len=" + str(n) + " bytes (~" + str(n / 1048576) + " MiB)")
    return CorpusDesc { path: path, len: n }
}

fn corpus_window(desc: CorpusDesc, offset: int, n_bytes: int) -> [int] {
    if offset < 0 || n_bytes <= 0 {
        return []
    }
    let mut end = offset + n_bytes
    if end > desc.len {
        end = desc.len
    }
    let real_n = end - offset
    if real_n <= 0 {
        return []
    }
    let cmd = "dd if='" + desc.path + "' bs=1 skip=" + str(offset) + " count=" + str(real_n) + " status=none 2>/dev/null | od -An -vtu1"
    let raw = exec(cmd)
    let flat = raw.replace("\n", " ")
    let parts_raw = flat.split(" ")
    let np = len(parts_raw)
    let mut out = []
    let mut i = 0
    while i < np {
        let p = parts_raw[i].trim()
        if p != "" {
            out = out.push(to_int(p))
        }
        i = i + 1
    }
    return out
}

