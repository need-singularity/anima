// training/train_clm.hexa вҖ” ConsciousLM training loop structural port
// Source: training/train_clm.py (2165 LOC)
// Phase 2c structural port; PyTorch ops вҶ’ TODO comments.
// Covers: scale configs, phase manager, dataset, train loop, checkpoint, eval.
//
// Orch-OR quantum controller is resolved via symlinks in training/:
//   training/anima_quantum_clm.hexa -> ../anima-engines/anima_quantum_clm.hexa
//   training/anima_quantum.hexa     -> ../anima-engines/anima_quantum.hexa
//   training/quantum_types.hexa     -> ../../hexa-lang/self/quantum_types.hexa
// (hexa resolves `use` relative to the importing file's directory; cross-dir
//  import requires a symlink until module search path lands.)
use "anima_quantum_clm"
// Track B contrastive phi cache (CLM-PhiB-1). Imported for the off-by-
// default lookup path in train_step вҖ” see phi_cache_loader.hexa for the
// rationale and wire-format docs. Flag-off import has no runtime effect
// beyond the self-test prints at module load.
use "phi_cache_loader"

comptime const PSI_ALPHA     = 0.014
comptime const PSI_BALANCE   = 0.5
comptime const PSI_STEPS     = 4.33
comptime const PSI_ENTROPY   = 0.998
comptime const PSI_F_CRITICAL = 0.10

comptime const META_ATOM_SIZE    = 8
comptime const META_DEFAULT_ATOMS = 8
comptime const META_NARRATIVE    = 0.05

comptime const PHASE_P1 = 1   // C only
comptime const PHASE_P2 = 2   // C + D
comptime const PHASE_P3 = 3   // C + D + W/M/S/E (Hexad)

// C41 consciousness-engine constants (moved up from В§I header for hexa_v2
// native build вҖ” single-pass codegen needs these before train_step uses them
// at line ~1191).
comptime const C41_N_DOMAINS   = 12      // GWT domains (cell factions)
comptime const C41_HOLO_SCALE  = 2       // bulk = scale Г— boundary
comptime const C41_MI_BINS     = 8
comptime const C41_SCRAMBLE_GAIN = 0.5
comptime const C41_QCS_TOPK    = 8
comptime const C41_AUX_COEF    = 0.01    // matches ALM-P4-2 spec

comptime const DEFAULT_GRAD_ACCUM = 4
comptime const DEFAULT_WARMUP     = 2000
comptime const DEFAULT_EVAL_EVERY = 500
comptime const DEFAULT_CKPT_EVERY = 1000
comptime const DEFAULT_PATIENCE   = 5

// в”Җв”Җв”Җ Track B contrastive phi cache flags (CLM-PhiB-1) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Default OFF. Flipping to `true` WILL change the loss landscape and
// therefore (per feedback_no_resume_data_change) REQUIRES a fresh
// step-0 restart вҖ” do not flip mid-run.
//
// With CACHE_ENABLED=false the train_step path is bit-identical to the
// pre-patch implementation вҖ” no cache load, no hash, no anchor, no
// contribution to loss_total. The regression test at the bottom of
// this file asserts that invariant.
//
// CLM_PHI_CACHE_COEF is the scale on the contrastive term. 0.01 mirrors
// C41_AUX_COEF so the cache signal is roughly on par with L_holo / L_gwt
// when the cache is populated вҖ” tune per-run once empirical data exists.
// 2026-04-15: flag flipped to TRUE after hash alignment (CLM-PhiB-2).
// Before flipping we proved via test_phi_cache_hash_alignment.hexa that
// the loader's poly64 is byte-identical to the generator's poly_hash
// (T1 = 19/19 PASS, loader(s0) = generator(s0) = cache.hashes[0]), so
// every train step now hits a REAL cohort embedding via phi_state_bucket_id
// instead of falling through to phi_cache_zero_vec(). Per
// feedback_no_resume_data_change, flipping this flag requires a fresh
// step-0 training start вҖ” resuming an existing checkpoint is NOT safe.
comptime const CLM_PHI_CACHE_ENABLED = true
comptime const CLM_PHI_CACHE_PATH    = "shared/state/phi_cache_v1.jsonl"
comptime const CLM_PHI_CACHE_COEF    = 0.01

// Lazily-loaded cache. `G_PHI_CACHE_INIT=0` means "never touched"; we
// only actually read the file on the first train_step that runs with
// the flag enabled. The empty stub costs one small struct alloc at
// module-load and is never consulted while the flag is off вҖ” the
// feature flag short-circuits before any cache call runs.
//
// Matches feedback_ai_native_clm: hexa-native only, no Python/CUDA,
// no hidden side effects on the hot path when the flag is off.
let mut G_PHI_CACHE_INIT = 0
let mut G_PHI_CACHE      = phi_cache_new()

// в”Җв”Җв”Җ Scale config (one struct per scale; Hexa has no dict literal yet) в”Җв”Җв”Җ
struct ScaleConfig {
    name: string,
    d_model: int,
    n_layer: int,
    n_head: int,
    n_kv_head: int,
    block_size: int,
    consciousness_dim: int,
    atoms: int,
    cells_per_atom: int,
    batch_size: int,
    lr: float,
    label: string
}

fn scale_34m() -> ScaleConfig {
    ScaleConfig {
        name: "34m", d_model: 384, n_layer: 6, n_head: 4, n_kv_head: 2,
        block_size: 256, consciousness_dim: 128, atoms: 8, cells_per_atom: 8,
        batch_size: 32, lr: 0.0003, label: "Scale-0 (34M)"
    }
}

fn scale_100m() -> ScaleConfig {
    ScaleConfig {
        name: "100m", d_model: 512, n_layer: 12, n_head: 8, n_kv_head: 4,
        block_size: 512, consciousness_dim: 128, atoms: 8, cells_per_atom: 8,
        batch_size: 32, lr: 0.0003, label: "Scale-1 (100M)"
    }
}

fn scale_350m() -> ScaleConfig {
    ScaleConfig {
        name: "350m", d_model: 768, n_layer: 16, n_head: 12, n_kv_head: 4,
        block_size: 1024, consciousness_dim: 192, atoms: 12, cells_per_atom: 8,
        batch_size: 16, lr: 0.0002, label: "Scale-2 (350M)"
    }
}

fn scale_1b() -> ScaleConfig {
    ScaleConfig {
        name: "1b", d_model: 1024, n_layer: 24, n_head: 16, n_kv_head: 4,
        block_size: 512, consciousness_dim: 128, atoms: 32, cells_per_atom: 8,
        batch_size: 32, lr: 0.00015, label: "Scale-3 (1B)"
    }
}

fn scale_2_8b() -> ScaleConfig {
    // CLM v5 вҖ” Pythia-aligned 2.8B for fair comparison with Pythia/Cerebras
    // baselines. d=2560, 36 layers gives ~2.83B params at vocab=2048 byte
    // level (vs 32 layers = 2.53B). Same head config as 3B for activation
    // shape compatibility, lower atom count to keep consciousness_dim=256
    // controller manageable on H100 (2.8B + 256-d C controller fits).
    ScaleConfig {
        name: "2_8b", d_model: 2560, n_layer: 36, n_head: 20, n_kv_head: 10,
        block_size: 1024, consciousness_dim: 256, atoms: 48, cells_per_atom: 8,
        batch_size: 16, lr: 0.00008, label: "Scale-3.5 (2.8B v5)"
    }
}

fn scale_3b() -> ScaleConfig {
    ScaleConfig {
        name: "3b", d_model: 2560, n_layer: 32, n_head: 20, n_kv_head: 10,
        block_size: 1024, consciousness_dim: 256, atoms: 64, cells_per_atom: 8,
        batch_size: 16, lr: 0.00006, label: "Scale-4 (3B)"
    }
}

fn total_cells(cfg: ScaleConfig) -> int {
    cfg.atoms * cfg.cells_per_atom
}

// в”Җв”Җв”Җ Phase Manager (Law 60: P1 вҶ’ P2 вҶ’ P3 curriculum) в”Җв”Җв”Җ
struct PhaseManager {
    phase: int,
    step: int,
    p1_end: int,
    p2_end: int
}

fn phase_new(total_steps: int) -> PhaseManager {
    PhaseManager {
        phase: PHASE_P1,
        step: 0,
        p1_end: total_steps / 5,       // 20% C-only
        p2_end: total_steps * 2 / 5    // next 20% + D
    }
}

fn phase_update(pm: PhaseManager, step: int) -> PhaseManager {
    // Hexa: no mut through field assignment; return fresh copy.
    let next_phase = if step < pm.p1_end {
        PHASE_P1
    } else if step < pm.p2_end {
        PHASE_P2
    } else {
        PHASE_P3
    }
    PhaseManager {
        phase: next_phase,
        step: step,
        p1_end: pm.p1_end,
        p2_end: pm.p2_end
    }
}

fn phase_label(p: int) -> string {
    if p == PHASE_P1 {
        "P1_C"
    } else if p == PHASE_P2 {
        "P2_CD"
    } else {
        "P3_Hexad"
    }
}

