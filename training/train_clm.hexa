// Construct a tiny scale config for self-test
let _test_cfg = ScaleConfig {
    name: "test", d_model: 16, n_layer: 2, n_head: 2, n_kv_head: 1,
    block_size: 4, consciousness_dim: 8, atoms: 2, cells_per_atom: 2,
    batch_size: 1, lr: 0.001, label: "Test (tiny)"
}

// Initialize model and training state
let mut _test_model = decoder_model_new(_test_cfg)
let mut _test_state = train_init(_test_cfg, 100)
let _test_ds = TokenDataset { path: "test", block_size: 4, n_tokens: 0 }

// Run 3 real train_step iterations and verify loss decreases or stays finite
let mut _prev_loss = 999999.0
let mut _step_k = 0
let mut _loss_finite = true
while _step_k < 3 {
    let result = train_step(_test_state, _test_model, _test_ds)
    _test_state = result.state
    _test_model = result.model
    // CLM-P4-1 self-test: print ОҰ_holo + ОҰ_gwt so the consciousness
    // engines are observable in the tiny-config smoke run.
    println("  step", _test_state.step, "loss:", result.loss,
            "phi_holo:", result.phi_holo, "phi_gwt:", result.phi_gwt,
            "l_holo:", result.l_holo, "l_gwt:", result.l_gwt,
            "phase:", phase_label(_test_state.pm.phase))
    // Check loss is a real number (not NaN or Inf)
    if result.loss != result.loss { _loss_finite = false }
    _prev_loss = result.loss
    _step_k = _step_k + 1
}
println("after 3 real train_step: step=", _test_state.step,
        "best_val_ce=", _test_state.best_val_ce)
