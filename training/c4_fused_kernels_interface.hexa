}

// fused_qkv_projection_fwd
//   Fuses:  norm1 → mm(norm1, Wq) + mm(norm1, Wk) + mm(norm1, Wv)
//   by packing [Wq | Wk | Wv] into one [D, 3·D_head·H] matrix (shared A).
//   Launch reduction: 3 → 1  (shared input row, 3x bandwidth recovery)
//   bf16 TC:          YES
//   Body: TODO C2-LANDING.
fn fused_qkv_projection_fwd(norm_dev, Wqkv_dev,
                            Q_dev, K_dev, V_dev,
                            M, K_in, D_head, H) -> int {
    return C4_ERR_C2_NOT_LANDED
}

// fused_attn_score_softmax_fwd
//   Fuses:  mm(Q, K^T) / sqrt(d) → causal mask → softmax
//   Already partially fused in cuda_kernels.hexa (K_FUSED_ATTN_POST_FWD
//   does scale + softmax together); this adds the GEMM into the same
//   launch by using a streaming online-softmax on the score tile —
//   this is the FlashAttention path applied per-layer.
//   Launch reduction: 2 → 1
//   bf16 TC:          YES (score GEMM uses WMMA)
//   Body: TODO C2-LANDING.
fn fused_attn_score_softmax_fwd(Q_dev, K_dev, probs_dev,
                                B, H, S, D_head, causal_int) -> int {
    return C4_ERR_C2_NOT_LANDED
}

// fused_ffn_swiglu_fwd
//   Fuses:  rms_norm(mid) → mm(norm, W_up) → mm(norm, W_gate) → swiglu(up, gate) → mm(act, W_down)
//   Launch reduction: 5 → 1 (with two GEMMs folded via WMMA tile fusion)
//   bf16 TC:          YES
//   Body: TODO C2-LANDING.
