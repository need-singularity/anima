// ── §1  Constants ────────────────────────────────────────────

// WMMA tile shape — m16n16k16 is the native H100 (sm_90) bf16 shape.
// Matches hexa-lang/self/native/hxcuda_fused.cu WMMA_M / WMMA_N / WMMA_K.
let C4_WMMA_M = 16
let C4_WMMA_N = 16
let C4_WMMA_K = 16

// Warp size (threads per warp on NVIDIA).
let C4_WARP = 32

// Max dynamic shared memory per block on sm_90 (bytes). Used for
// register-pressure checks inside launchers.
let C4_SM90_SHMEM_MAX = 228 * 1024

// Fusion status token — returned by stubs until C2 lands.
let C4_ERR_C2_NOT_LANDED = -1001

// ── §2  Fused forward kernel stubs ──────────────────────────

