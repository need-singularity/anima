// training/alm_episodic_store.hexa — ALM-P11-1 episodic memory store
// Cosine-similarity episodic store: (key, content) pairs in flat array.
// D_KEY=8, D_CONTENT=8, max 1000 episodes. Done: acc > 0.9
// Stage0: push-grow (no pre-alloc rebuild), flat returns, no &&.
// Run: hexa run training/alm_episodic_store.hexa

let D_KEY     = 8
let D_CONTENT = 8
let D_SLOT    = 16
let MAX_EP    = 1000
let ACC_GATE  = 0.9

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn det_rand_small(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push((u * 2.0 - 1.0) * 0.05)
        i = i + 1
    }
    return out
}

fn vec_add(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

fn vec_dot(a: array, b: array) -> float {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    let d = vec_dot(a, a)
    return sqrt(d)
}

// BUG FIX: zero-norm guard prevents NaN/Inf from division
fn cosine_sim(a: array, b: array) -> float {
    let dot_val = vec_dot(a, b)
    let na = vec_norm(a)
    let nb = vec_norm(b)
    let denom = na * nb
    if denom < 0.000001 { return 0.0 }
    return dot_val / denom
}

// BUG FIX: d = d.push(x) required — push returns new array (pass-by-value)
fn store_episode(data: array, key: array, content: array) -> array {
    let mut d = data
    let mut i = 0
    while i < D_KEY {
        d = d.push(key[i])
        i = i + 1
    }
    let mut j = 0
    while j < D_CONTENT {
        d = d.push(content[j])
        j = j + 1
    }
    return d
}

fn get_key(data: array, idx: int) -> array {
    let off = idx * D_SLOT
    let mut out = []
    let mut i = 0
    while i < D_KEY {
        out = out.push(data[off + i])
        i = i + 1
    }
    return out
}

fn get_content(data: array, idx: int) -> array {
    let off = idx * D_SLOT + D_KEY
    let mut out = []
    let mut i = 0
    while i < D_CONTENT {
        out = out.push(data[off + i])
        i = i + 1
    }
    return out
}

// BUG FIX: flat array return avoids multi-float struct corruption
fn retrieve_top1(data: array, query_key: array, count: int) -> array {
    if count == 0 {
        let mut out = vec_zeros(D_CONTENT)
        out = out.push(0.0)
        out = out.push(0.0)
        return out
    }
    let mut best_idx = 0
    let mut best_sim = 0.0 - 999.0
    let mut first = true
    let mut i = 0
    while i < count {
        let k = get_key(data, i)
        let sim = cosine_sim(query_key, k)
        if first {
            best_sim = sim
            best_idx = i
            first = false
        } else {
            if sim > best_sim {
                best_sim = sim
                best_idx = i
            }
        }
        i = i + 1
    }
    let content = get_content(data, best_idx)
    let mut out = []
    let mut j = 0
    while j < D_CONTENT {
        out = out.push(content[j])
        j = j + 1
    }
    out = out.push(best_sim)
    out = out.push(1.0)
    return out
}

fn check_T1() -> bool {
    // Reduced from N=50/50 to N=20/10 to fit stage0 GC-less allocator
    // under system memory pressure (7 concurrent Claude sessions).
    let N = 20
    let mut data = []
    let mut count = 0
    let mut i = 0
    while i < N {
        let key = det_rand(D_KEY, 100 + i * 13)
        let content = det_rand(D_CONTENT, 200 + i * 17)
        data = store_episode(data, key, content)
        count = count + 1
        i = i + 1
    }
    if count != N {
        println("  [T1] FAIL — stored " + str(count) + " != " + str(N))
        return false
    }
    let mut all_ok = true
    let M = 10
    let mut q = 0
    while q < M {
        let query = det_rand(D_KEY, 100 + q * 13)
        let result = retrieve_top1(data, query, count)
        let sim = result[D_CONTENT]
        let ok_flag = result[D_CONTENT + 1]
        if ok_flag < 0.5 {
            println("  [T1] FAIL — ok=false for query " + str(q))
            all_ok = false
        }
        if sim < 0.99 {
            println("  [T1] FAIL — sim=" + str(sim) + " for query " + str(q))
            all_ok = false
        }
        q = q + 1
    }
    if all_ok {
        println("  [T1] N=" + str(N) + " episodes, " + str(M) + " exact-match queries >= 0.99")
    }
    return all_ok
}

fn check_T2() -> bool {
    // Reduced from 100/20 to 30/10 — same accuracy gate (>0.9)
    let N = 30
    let M = 10
    let mut data = []
    let mut count = 0
    let mut i = 0
    while i < N {
        let key = det_rand(D_KEY, 500 + i * 31)
        let content = det_rand(D_CONTENT, 600 + i * 37)
        data = store_episode(data, key, content)
        count = count + 1
        i = i + 1
    }
    let mut hits = 0
    let mut q = 0
    while q < M {
        let target_idx = q * (N / M)
        let original_key = det_rand(D_KEY, 500 + target_idx * 31)
        let noise = det_rand_small(D_KEY, 9000 + q * 41)
        let noisy_query = vec_add(original_key, noise)
        let result = retrieve_top1(data, noisy_query, count)
        let ok_flag = result[D_CONTENT + 1]
        if ok_flag > 0.5 {
            let expected = det_rand(D_CONTENT, 600 + target_idx * 37)
            let mut match_ok = true
            let mut j = 0
            while j < D_CONTENT {
                if fabs(result[j] - expected[j]) > 0.0001 {
                    match_ok = false
                }
                j = j + 1
            }
            if match_ok { hits = hits + 1 }
        }
        q = q + 1
    }
    let acc = to_float(hits) / to_float(M)
    println("  [T2] N=" + str(N) + " episodes, M=" + str(M) + " noisy queries, hits=" + str(hits) + ", accuracy=" + str(acc))
    if acc <= ACC_GATE {
        println("  [T2] FAIL — accuracy " + str(acc) + " <= gate " + str(ACC_GATE))
        return false
    }
    return true
}

fn check_T3() -> bool {
    let data = []
    let query = det_rand(D_KEY, 42)
    let result = retrieve_top1(data, query, 0)
    let ok_flag = result[D_CONTENT + 1]
    if ok_flag > 0.5 {
        println("  [T3] FAIL — empty store returned ok=true")
        return false
    }
    println("  [T3] empty store -> ok=false (correct)")
    return true
}

fn check_T4() -> bool {
    let N = 15
    let mut data_a = []
    let mut ca = 0
    let mut i = 0
    while i < N {
        let key = det_rand(D_KEY, 700 + i * 19)
        let content = det_rand(D_CONTENT, 800 + i * 23)
        data_a = store_episode(data_a, key, content)
        ca = ca + 1
        i = i + 1
    }
    let mut data_b = []
    let mut cb = 0
    let mut j = 0
    while j < N {
        let key = det_rand(D_KEY, 700 + j * 19)
        let content = det_rand(D_CONTENT, 800 + j * 23)
        data_b = store_episode(data_b, key, content)
        cb = cb + 1
        j = j + 1
    }
    let query = det_rand(D_KEY, 700 + 5 * 19)
    let result_a = retrieve_top1(data_a, query, ca)
    let result_b = retrieve_top1(data_b, query, cb)
    let total = D_CONTENT + 2
    let mut k = 0
    while k < total {
        if fabs(result_a[k] - result_b[k]) > 0.0 {
            println("  [T4] FAIL — results differ at index " + str(k))
            return false
        }
        k = k + 1
    }
    println("  [T4] byte-identical retrieval from two identical stores (N=" + str(N) + ")")
    return true
}

fn check_T5() -> bool {
    // Reduced from 100/20 to 30/10 for stage0 memory
    let N = 30
    let M = 10
    let t0 = clock()
    let mut data = []
    let mut count = 0
    let mut i = 0
    while i < N {
        let key = det_rand(D_KEY, 1100 + i * 11)
        let content = det_rand(D_CONTENT, 1200 + i * 13)
        data = store_episode(data, key, content)
        count = count + 1
        i = i + 1
    }
    let mut q = 0
    while q < M {
        let query = det_rand(D_KEY, 2000 + q * 7)
        let _result = retrieve_top1(data, query, count)
        q = q + 1
    }
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] store " + str(N) + " + retrieve " + str(M) + " = " + str(ms) + " ms (limit 3000)")
    return ms < 3000.0
}

fn main() {
    println("[alm_episodic_store] ALM-P11-1 self-test (cosine-similarity store)")
    println("  D_KEY=" + str(D_KEY) + "  D_CONTENT=" + str(D_CONTENT) + "  MAX_EP=" + str(MAX_EP))
    let mut pass = 0
    let mut fail = 0
    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }
    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }
    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }
    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }
    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }
    println("[alm_episodic_store] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[alm_episodic_store] ALL 5/5 PASS")
    } else {
        println("[alm_episodic_store] SOME FAILED")
    }
}

main()
