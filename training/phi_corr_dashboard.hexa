// ═══════════════════════════════════════════════════════════════
//  training/phi_corr_dashboard.hexa — P25 ASCII renderer
//
//  Calls the same summary logic as phi_corr_history_reader.hexa but
//  prints a fixed-width table for humans / CI logs. By duplicating
//  (not importing) the parser we avoid the 3+ import silent-exit trap
//  documented in feedback_hexa_silent_exit_5_imports.
//
//  Schema of each stdout row:
//      +------------------+-------+------+---------+-----------+
//      | dim              | runs  | |r|  | weight  | status    |
//      +------------------+-------+------+---------+-----------+
//      | phi_holo         |  12   | 0.90 | 0.900   | STABLE    |
//      | phi_unity        |  12   | 0.15 | 0.150   | PRUNE     |
//
//  Usage:
//      hexa run training/phi_corr_dashboard.hexa                 # reads SSOT
//      hexa run training/phi_corr_dashboard.hexa --path <jsonl>
//      hexa run training/phi_corr_dashboard.hexa --self-test
//
//  STATUS classes (same as reader):
//      STABLE | WEAK | DECAY | PRUNE | NULL | NODATA
// ═══════════════════════════════════════════════════════════════

let HISTORY_PATH_DEFAULT = "shared/state/phi_corr_history.jsonl"
let WEAK_GATE            = 0.2
let SIG_GATE             = 0.5
let PRUNE_CONSECUTIVE_N  = 3
let DECAY_RATIO          = 0.70

// ─── fmt helpers ───────────────────────────────────────────────────

fn d_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn d_fmt2(x: float) -> string {
    let neg = x < 0.0
    let ax = if neg { 0.0 - x } else { x }
    let scaled = ax * 100.0 + 0.5
    let k = to_int(scaled)
    let whole = k / 100
    let frac  = k - whole * 100
    let mut frac_s = str(frac)
    if len(frac_s) < 2 { frac_s = "0" + frac_s }
    let body = str(whole) + "." + frac_s
    if neg { return "-" + body }
    return body
}

fn d_fmt3(x: float) -> string {
    let neg = x < 0.0
    let ax = if neg { 0.0 - x } else { x }
    let scaled = ax * 1000.0 + 0.5
    let k = to_int(scaled)
    let whole = k / 1000
    let frac  = k - whole * 1000
    let mut frac_s = str(frac)
    while len(frac_s) < 3 { frac_s = "0" + frac_s }
    let body = str(whole) + "." + frac_s
    if neg { return "-" + body }
    return body
}

fn d_pad_r(s: string, w: int) -> string {
    let n = len(s)
    if n >= w { return s }
    let mut out = s
    let mut i = 0
    while i < w - n {
        out = out + " "
        i = i + 1
    }
    return out
}

fn d_pad_l(s: string, w: int) -> string {
    let n = len(s)
    if n >= w { return s }
    let mut out = ""
    let mut i = 0
    while i < w - n {
        out = out + " "
        i = i + 1
    }
    return out + s
}

fn d_pad_c(s: string, w: int) -> string {
    let n = len(s)
    if n >= w { return s }
    let total = w - n
    let left = total / 2
    let right = total - left
    let mut out = ""
    let mut i = 0
    while i < left { out = out + " "; i = i + 1 }
    out = out + s
    let mut j = 0
    while j < right { out = out + " "; j = j + 1 }
    return out
}

// ─── JSON mini-parser (duplicated from reader on purpose) ──────────

fn dj_scalar(blob: string, key: string) -> string {
    let probe = "\"" + key + "\""
    let k = blob.index_of(probe)
    if k < 0 { return "" }
    let n = len(blob)
    let mut i = k + len(probe)
    while i < n && blob.substring(i, i + 1) != ":" { i = i + 1 }
    if i >= n { return "" }
    i = i + 1
    while i < n {
        let c = blob.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" { i = i + 1 } else { break }
    }
    let mut j = i
    let mut in_str = false
    while j < n {
        let c = blob.substring(j, j + 1)
        if c == "\"" { in_str = !in_str }
        if !in_str {
            if c == "," || c == "}" || c == "]" { break }
        }
        j = j + 1
    }
    let raw = blob.substring(i, j)
    let mut a = 0
    let mut b = len(raw)
    while a < b {
        let c = raw.substring(a, a + 1)
        if c == " " || c == "\t" || c == "\"" { a = a + 1 } else { break }
    }
    while b > a {
        let c = raw.substring(b - 1, b)
        if c == " " || c == "\t" || c == "\"" { b = b - 1 } else { break }
    }
    return raw.substring(a, b)
}

fn dj_f(s: string) -> float {
    if len(s) == 0 { return 0.0 }
    return to_float(s)
}

fn dj_i(s: string) -> int {
    if len(s) == 0 { return 0 }
    return to_int(s)
}

fn dsplit_dim_objects(blob: string) -> array {
    let mut out = []
    let k = blob.index_of("\"dims\"")
    if k < 0 { return out }
    let n = len(blob)
    let mut lb = k
    while lb < n && blob.substring(lb, lb + 1) != "[" { lb = lb + 1 }
    if lb >= n { return out }
    let mut rb = lb + 1
    let mut depth = 1
    while rb < n && depth > 0 {
        let c = blob.substring(rb, rb + 1)
        if c == "[" { depth = depth + 1 }
        if c == "]" { depth = depth - 1 }
        if depth == 0 { break }
        rb = rb + 1
    }
    if rb <= lb { return out }
    let inner = blob.substring(lb + 1, rb)
    let m = len(inner)
    let mut i = 0
    while i < m {
        let c = inner.substring(i, i + 1)
        if c == "{" {
            let mut d = 1
            let mut j = i + 1
            while j < m && d > 0 {
                let cc = inner.substring(j, j + 1)
                if cc == "{" { d = d + 1 }
                if cc == "}" { d = d - 1 }
                if d == 0 { break }
                j = j + 1
            }
            if j < m {
                out = out.push(inner.substring(i, j + 1))
                i = j + 1
            } else {
                i = m
            }
        } else {
            i = i + 1
        }
    }
    return out
}

fn parse_run_line(line: string) -> array {
    let objs = dsplit_dim_objects(line)
    let nd = len(objs)
    let mut names = []
    let mut rs = []
    let mut ws = []
    let mut i = 0
    while i < nd {
        let o = objs[i]
        names = names.push(dj_scalar(o, "name"))
        let mut rs_s = dj_scalar(o, "r_pearson_acc")
        if len(rs_s) == 0 { rs_s = dj_scalar(o, "r_pearson") }
        rs = rs.push(dj_f(rs_s))
        ws = ws.push(dj_f(dj_scalar(o, "weight")))
        i = i + 1
    }
    let mut out = []
    out = out.push(dj_scalar(line, "run_ts"))
    out = out.push(dj_i(dj_scalar(line, "step")))
    out = out.push(names)
    out = out.push(rs)
    out = out.push(ws)
    return out
}

fn read_runs(path: string) -> array {
    let mut runs = []
    if !file_exists(path) { return runs }
    let blob = read_file(path)
    let lines = blob.split("\n")
    let n = len(lines)
    let mut i = 0
    while i < n {
        let ln = lines[i]
        if len(ln) > 0 && ln.index_of("\"dims\"") >= 0 {
            runs = runs.push(parse_run_line(ln))
        }
        i = i + 1
    }
    return runs
}

// ─── per-dim reduction ─────────────────────────────────────────────

fn find_idx(nm_list: array, target: string) -> int {
    let n = len(nm_list)
    let mut i = 0
    while i < n {
        if nm_list[i] == target { return i }
        i = i + 1
    }
    return -1
}

fn collect_rs(runs: array, dim: string) -> array {
    let n = len(runs)
    let mut out = []
    let mut i = 0
    while i < n {
        let r = runs[i]
        let idx = find_idx(r[2], dim)
        if idx >= 0 { out = out.push(r[3][idx]) }
        i = i + 1
    }
    return out
}

fn collect_ws(runs: array, dim: string) -> array {
    let n = len(runs)
    let mut out = []
    let mut i = 0
    while i < n {
        let r = runs[i]
        let idx = find_idx(r[2], dim)
        if idx >= 0 { out = out.push(r[4][idx]) }
        i = i + 1
    }
    return out
}

fn trailing_weak(rs: array) -> int {
    let n = len(rs)
    let mut i = n - 1
    let mut c = 0
    while i >= 0 {
        if d_fabs(rs[i]) < WEAK_GATE { c = c + 1 } else { break }
        i = i - 1
    }
    return c
}

fn peak_w(ws: array) -> float {
    let n = len(ws)
    let mut p = 0.0
    let mut i = 0
    while i < n { if ws[i] > p { p = ws[i] } ; i = i + 1 }
    return p
}

fn last_v(xs: array) -> float {
    let n = len(xs)
    if n == 0 { return 0.0 }
    return xs[n - 1]
}

fn classify(rs: array, ws: array) -> string {
    if len(rs) == 0 { return "NODATA" }
    if trailing_weak(rs) >= PRUNE_CONSECUTIVE_N { return "PRUNE" }
    let peak = peak_w(ws)
    let cur  = last_v(ws)
    if peak > 0.0 && cur < peak * DECAY_RATIO { return "DECAY" }
    let last_r = d_fabs(last_v(rs))
    if last_r >= SIG_GATE  { return "STABLE" }
    if last_r >= WEAK_GATE { return "WEAK" }
    return "NULL"
}

fn union_names(runs: array) -> array {
    let mut out = []
    let n = len(runs)
    let mut i = 0
    while i < n {
        let names = runs[i][2]
        let m = len(names)
        let mut j = 0
        while j < m {
            let nm = names[j]
            let mut seen = false
            let mut k = 0
            while k < len(out) {
                if out[k] == nm { seen = true; break }
                k = k + 1
            }
            if !seen { out = out.push(nm) }
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// ─── renderer ──────────────────────────────────────────────────────
//
// Widths (content, not counting the two-space padding each side):
//   dim=16  runs=5  |r|=4  weight=7  status=9
// The total cell width = content + 2 (one space each side).

let W_DIM = 16
let W_RUNS = 5
let W_R = 4
let W_W = 7
let W_ST = 9

fn border() -> string {
    // +----+----+----+----+----+
    let mut s = "+"
    // dim
    s = s + make_dashes(W_DIM + 2) + "+"
    s = s + make_dashes(W_RUNS + 2) + "+"
    s = s + make_dashes(W_R + 2) + "+"
    s = s + make_dashes(W_W + 2) + "+"
    s = s + make_dashes(W_ST + 2) + "+"
    return s
}

fn make_dashes(n: int) -> string {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + "-"
        i = i + 1
    }
    return s
}

fn header() -> string {
    let mut s = "|"
    s = s + " " + d_pad_r("dim",     W_DIM)  + " |"
    s = s + " " + d_pad_c("runs",    W_RUNS) + " |"
    s = s + " " + d_pad_c("|r|",     W_R)    + " |"
    s = s + " " + d_pad_c("weight",  W_W)    + " |"
    s = s + " " + d_pad_c("status",  W_ST)   + " |"
    return s
}

fn render_row(nm: string, runs_c: int, ar: float, w: float, st: string) -> string {
    let mut s = "|"
    s = s + " " + d_pad_r(nm, W_DIM) + " |"
    s = s + " " + d_pad_c(str(runs_c), W_RUNS) + " |"
    s = s + " " + d_pad_l(d_fmt2(ar), W_R) + " |"
    s = s + " " + d_pad_l(d_fmt3(w),  W_W) + " |"
    s = s + " " + d_pad_r(st, W_ST) + " |"
    return s
}

fn render_table(runs: array) -> array {
    let mut lines = []
    lines = lines.push(border())
    lines = lines.push(header())
    lines = lines.push(border())
    let dims = union_names(runs)
    let m = len(dims)
    let mut i = 0
    while i < m {
        let nm = dims[i]
        let rs = collect_rs(runs, nm)
        let ws = collect_ws(runs, nm)
        let rc = len(rs)
        let ar = d_fabs(last_v(rs))
        let w  = last_v(ws)
        let st = classify(rs, ws)
        lines = lines.push(render_row(nm, rc, ar, w, st))
        i = i + 1
    }
    lines = lines.push(border())
    return lines
}

fn count_st(runs: array, target: string) -> int {
    let dims = union_names(runs)
    let m = len(dims)
    let mut c = 0
    let mut i = 0
    while i < m {
        let nm = dims[i]
        let rs = collect_rs(runs, nm)
        let ws = collect_ws(runs, nm)
        let st = classify(rs, ws)
        if st == target { c = c + 1 }
        i = i + 1
    }
    return c
}

// ─── self-test (uses same synth writer as reader, inlined) ─────────

fn synth_line(
    run_ts: string, step: int,
    rh: float, wh: float,
    rd_: float, wd: float,
    rp: float, wp: float,
    rw: float, ww: float
) -> string {
    let mut s = "{"
    s = s + "\"run_ts\":\"" + run_ts + "\","
    s = s + "\"step\":" + str(step) + ","
    s = s + "\"model_tag\":\"alm14b\","
    s = s + "\"round\":4,"
    s = s + "\"n_checkpoints\":5,"
    s = s + "\"dims\":["
    s = s + "{\"name\":\"phi_holo\",\"r_pearson_acc\":" + d_fmt3(rh) + ",\"weight\":" + d_fmt3(wh) + ",\"flag\":\"SIG \"},"
    s = s + "{\"name\":\"phi_decay\",\"r_pearson_acc\":" + d_fmt3(rd_) + ",\"weight\":" + d_fmt3(wd) + ",\"flag\":\"WEAK\"},"
    s = s + "{\"name\":\"phi_prune\",\"r_pearson_acc\":" + d_fmt3(rp) + ",\"weight\":" + d_fmt3(wp) + ",\"flag\":\"NULL\"},"
    s = s + "{\"name\":\"phi_weak\",\"r_pearson_acc\":" + d_fmt3(rw) + ",\"weight\":" + d_fmt3(ww) + ",\"flag\":\"WEAK\"}"
    s = s + "]}"
    return s
}

fn write_synth(path: string) {
    let mut blob = ""
    blob = blob + synth_line("2026-04-14T00:00:00Z",  500, 0.88, 0.88, 0.70, 0.70, 0.30, 0.30, 0.30, 0.30) + "\n"
    blob = blob + synth_line("2026-04-15T00:00:00Z", 1000, 0.91, 0.91, 0.85, 0.85, 0.25, 0.25, 0.32, 0.32) + "\n"
    blob = blob + synth_line("2026-04-16T00:00:00Z", 1500, 0.90, 0.90, 0.60, 0.60, 0.15, 0.15, 0.28, 0.28) + "\n"
    blob = blob + synth_line("2026-04-17T00:00:00Z", 2000, 0.92, 0.92, 0.40, 0.40, 0.10, 0.10, 0.31, 0.31) + "\n"
    blob = blob + synth_line("2026-04-18T00:00:00Z", 2500, 0.90, 0.90, 0.20, 0.20, 0.08, 0.08, 0.29, 0.29) + "\n"
    write_file(path, blob)
}

fn arg_path(argv: array) -> string {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == "--path" && i + 1 < n { return argv[i + 1] }
        i = i + 1
    }
    return ""
}

fn has_self_test(argv: array) -> bool {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == "--self-test" { return true }
        i = i + 1
    }
    return false
}

fn main() {
    let argv = args()
    let mut path = arg_path(argv)
    let selftest = has_self_test(argv)
    if selftest {
        path = "/tmp/phi_corr_history_test.jsonl"
        write_synth(path)
    }
    if len(path) == 0 { path = HISTORY_PATH_DEFAULT }

    let runs = read_runs(path)
    let n_runs = len(runs)

    println("[phi_corr_dashboard] path: " + path)
    println("  n_runs: " + str(n_runs))
    println("")

    if n_runs == 0 {
        println("  (empty history — A1 producer has not emitted yet)")
        println("pass=1")
        return
    }

    let lines = render_table(runs)
    let nl = len(lines)
    let mut i = 0
    while i < nl {
        println(lines[i])
        i = i + 1
    }

    println("")
    println("  SUMMARY: "
          + "STABLE=" + str(count_st(runs, "STABLE"))
          + " WEAK="  + str(count_st(runs, "WEAK"))
          + " DECAY=" + str(count_st(runs, "DECAY"))
          + " PRUNE=" + str(count_st(runs, "PRUNE"))
          + " NULL="  + str(count_st(runs, "NULL")))

    if selftest {
        // Expect 1/1/1/1 across STABLE/WEAK/DECAY/PRUNE with 4 synth dims.
        let s1 = count_st(runs, "STABLE")
        let s2 = count_st(runs, "DECAY")
        let s3 = count_st(runs, "PRUNE")
        let s4 = count_st(runs, "WEAK")
        if s1 == 1 && s2 == 1 && s3 == 1 && s4 == 1 {
            println("[phi_corr_dashboard] VERDICT PASS — synthetic history classified correctly")
            println("pass=1")
        } else {
            println("[phi_corr_dashboard] VERDICT FAIL — synthetic classification off")
            println("pass=0")
        }
    } else {
        println("pass=1")
    }
}

main()
