// ─── Stats primitives (Pearson + Spearman) ──────────────────────

fn corr_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn corr_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

// Newton sqrt — well behaved for positive x
fn corr_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    let mut k = 0
    while k < 30 {
        g = 0.5 * (g + x / g)
        k = k + 1
    }
    return g
}

fn corr_pearson(xs: array, ys: array) -> float {
    let n = len(xs)
    if n != len(ys) { return 0.0 }
    if n < 2 { return 0.0 }
    let mx = corr_mean(xs)
    let my = corr_mean(ys)
    let mut num = 0.0
    let mut dx2 = 0.0
    let mut dy2 = 0.0
    let mut i = 0
    while i < n {
        let dx = xs[i] - mx
        let dy = ys[i] - my
        num = num + dx * dy
        dx2 = dx2 + dx * dx
        dy2 = dy2 + dy * dy
        i = i + 1
    }
    if dx2 <= 0.0 { return 0.0 }
    if dy2 <= 0.0 { return 0.0 }
    let denom = corr_sqrt(dx2 * dy2)
    if denom <= 0.0 { return 0.0 }
    return num / denom
}

fn corr_ranks(v: array) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        let mut rk = 1
        let mut j = 0
        while j < n {
            if v[j] < v[i] { rk = rk + 1 }
            j = j + 1
        }
        out = out.push(to_float(rk))
        i = i + 1
    }
    return out
}

fn corr_spearman(xs: array, ys: array) -> float {
    let rx = corr_ranks(xs)
    let ry = corr_ranks(ys)
    return corr_pearson(rx, ry)
}

// ─── Vector extraction from registry ────────────────────────────
//
// rows[i] layout:  [step, task_acc, ce, phi0, phi1, ..., phi15]
//                   idx:  0     1      2   3    4         18
// so phi_k is at column 3 + k.

fn extract_task_acc(rows: array) -> array {
    let n = len(rows)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(rows[i][1])
        i = i + 1
    }
    return out
}

fn extract_ce(rows: array) -> array {
    let n = len(rows)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(rows[i][2])
        i = i + 1
    }
    return out
}

fn extract_phi_dim(rows: array, dim: int) -> array {
    let n = len(rows)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(rows[i][3 + dim])
        i = i + 1
    }
    return out
}

// ─── Weight proposal from correlation ───────────────────────────
//
// Proposed weight in composite Φ-AGI scalar:
//   w_i = |r_pearson(phi_i, task_acc)|   clipped to [0, 1]
// Dims with |r| < 0.2 get w=0 (pruned). Dims with |r| >= 0.5 are
// highlighted as "CONFIRMED". This is the same gate shape the P24-2
// scalar version used.

fn weight_for(r_pearson: float) -> float {
    let ar = corr_fabs(r_pearson)
    if ar < WEAK_GATE { return 0.0 }
    if ar > 1.0 { return 1.0 }
    return ar
}

fn flag_for(r_pearson: float, r_spearman: float) -> string {
    let ap = corr_fabs(r_pearson)
    let as_ = corr_fabs(r_spearman)
    if ap >= CORR_GATE || as_ >= CORR_GATE {
        return "SIG "
    }
    if ap < WEAK_GATE && as_ < WEAK_GATE {
        return "NULL"
    }
    return "WEAK"
}

// ─── Arg parsing ────────────────────────────────────────────────

fn is_full(argv: array) -> bool {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == "--full" { return true }
        i = i + 1
    }
    return false
}

// get_manifest_path — return path string after "--manifest", else "".
fn get_manifest_path(argv: array) -> string {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == "--manifest" && i + 1 < n {
            return argv[i + 1]
        }
        i = i + 1
    }
    return ""
}

// ─── W1 manifest loader (phi_eval_hook_spec.md, Consumer Hook) ──
//
// Reads <ckpt_root>/phi_runs.json, then for each step loads:
//   <ckpt_root>/step_<N>/phi_vec.json  → 16 dim floats (spec order)
//   <ckpt_root>/step_<N>/ce.json       → train_ce/val_ce
// Assembles rows in the smoke_row shape so the downstream loop
// (corr_pearson/extract_phi_dim) works unchanged.
//
// Missing files fall back to zeros — rows are still counted so
// broken runs are visibly NULL-correlated instead of silently dropped.

// Minimal JSON scalar extractor: finds "<key>":, skips whitespace,
// reads until , } ] end-of-string. Returns "" when key absent.
// Good enough for flat scalar values produced by our writer.
fn json_read_scalar(blob: string, key: string) -> string {
    let probe = "\"" + key + "\""
    let k = blob.index_of(probe)
    if k < 0 { return "" }
    let rest_start = k + len(probe)
    let n = len(blob)
    // find ':' after key
    let mut i = rest_start
    while i < n && blob.substring(i, i + 1) != ":" { i = i + 1 }
    if i >= n { return "" }
    i = i + 1
    // skip whitespace
    while i < n {
        let c = blob.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" { i = i + 1 } else { break }
    }
    // read until delimiter
    let mut j = i
    let mut in_str = false
    while j < n {
        let c = blob.substring(j, j + 1)
        if c == "\"" { in_str = !in_str }
        if !in_str {
            if c == "," || c == "}" || c == "]" || c == "\n" { break }
        }
        j = j + 1
    }
    let raw = blob.substring(i, j)
    // trim quotes + spaces
    let mut a = 0
    let mut b = len(raw)
    while a < b {
        let c = raw.substring(a, a + 1)
        if c == " " || c == "\t" || c == "\"" { a = a + 1 } else { break }
    }
    while b > a {
        let c = raw.substring(b - 1, b)
        if c == " " || c == "\t" || c == "\"" { b = b - 1 } else { break }
    }
    return raw.substring(a, b)
}

fn safe_to_float(s: string) -> float {
    if len(s) == 0 { return 0.0 }
    return to_float(s)
}

fn safe_to_int(s: string) -> int {
    if len(s) == 0 { return 0 }
    return to_int(s)
}

// Parse the "steps": [...] integer list out of phi_runs.json.
fn manifest_parse_steps(blob: string) -> array {
    let mut out = []
    let k = blob.index_of("\"steps\"")
    if k < 0 { return out }
    let n = len(blob)
    // find '[' after key
    let mut lb = k
    while lb < n && blob.substring(lb, lb + 1) != "[" { lb = lb + 1 }
    if lb >= n { return out }
    let mut rb = lb
    while rb < n && blob.substring(rb, rb + 1) != "]" { rb = rb + 1 }
    if rb <= lb { return out }
    let inner = blob.substring(lb + 1, rb)
    let parts = inner.split(",")
    let mut i = 0
    while i < len(parts) {
        let p = parts[i]
        let m = len(p)
        let mut a = 0
        let mut b = m
        while a < b {
            let c = p.substring(a, a + 1)
            if c == " " || c == "\t" || c == "\n" || c == "\r" { a = a + 1 } else { break }
        }
        while b > a {
            let c = p.substring(b - 1, b)
            if c == " " || c == "\t" || c == "\n" || c == "\r" { b = b - 1 } else { break }
        }
        let t = p.substring(a, b)
        if len(t) > 0 {
            out = out.push(to_int(t))
        }
        i = i + 1
    }
    return out
}

// Dir of manifest path = ckpt_root fallback if manifest lacks the key.
fn dirname_of(path: string) -> string {
    let n = len(path)
    let mut i = n - 1
    while i >= 0 {
        let c = path.substring(i, i + 1)
        if c == "/" { return path.substring(0, i) }
        i = i - 1
    }
    return "."
}

fn load_registry_from_manifest(manifest_path: string) -> array {
    let mut rows = []
    if !file_exists(manifest_path) {
        println("[eval_phi_corr] ERR manifest not found: " + manifest_path)
        return rows
    }
    let blob = read_file(manifest_path)
    let steps = manifest_parse_steps(blob)
    let n_steps = len(steps)
    if n_steps == 0 {
        println("[eval_phi_corr] WARN manifest has no steps: " + manifest_path)
        return rows
    }
    // Determine ckpt_root: prefer manifest key, else dir of manifest.
    let root_from_json = json_read_scalar(blob, "ckpt_root")
    let ckpt_root = if len(root_from_json) > 0 { root_from_json } else { dirname_of(manifest_path) }
    let names = phi_dim_names()
    println("[eval_phi_corr] manifest: " + manifest_path)
    println("  ckpt_root: " + ckpt_root)
    println("  steps    : " + str(n_steps))
    let mut i = 0
    while i < n_steps {
        let step = steps[i]
        let step_dir = ckpt_root + "/step_" + str(step)
        let vec_path = step_dir + "/phi_vec.json"
        let ce_path  = step_dir + "/ce.json"
        // Load phi dims (16 floats) — zero-fallback for missing
        let mut dims = []
        if file_exists(vec_path) {
            let vblob = read_file(vec_path)
            let mut d = 0
            while d < PHI_DIM_COUNT {
                let val_s = json_read_scalar(vblob, names[d])
                dims = dims.push(safe_to_float(val_s))
                d = d + 1
            }
        } else {
            let mut d = 0
            while d < PHI_DIM_COUNT {
                dims = dims.push(0.0)
                d = d + 1
            }
        }
        // Load CE (val_ce preferred for correlation, train_ce fallback)
        let mut val_ce = 0.0
        if file_exists(ce_path) {
            let cblob = read_file(ce_path)
            let v_s = json_read_scalar(cblob, "val_ce")
            if len(v_s) > 0 { val_ce = safe_to_float(v_s) } else {
                val_ce = safe_to_float(json_read_scalar(cblob, "train_ce"))
            }
        }
        // task_acc is not available from hook artifacts — proxy to
        // exp(-val_ce) so the pipeline still produces a correlation.
        // Bounded to [0, 1]. Real task_acc comes from bench.json when
        // that writer is wired.
        let task_acc_proxy = if val_ce > 0.0 { 1.0 / (1.0 + val_ce) } else { 0.0 }
        // Assemble row: [step, task_acc, ce, phi0..phi15]
        let mut row = []
        row = row.push(step)
        row = row.push(task_acc_proxy)
        row = row.push(val_ce)
        let mut d = 0
        while d < PHI_DIM_COUNT {
            row = row.push(dims[d])
            d = d + 1
        }
        rows = rows.push(row)
        i = i + 1
    }
    return rows
}

// ─── Float → short string (trim to 4 decimals) ──────────────────

fn fmt4(x: float) -> string {
    // scale by 10000, round, emit as "int.dddd"
    let neg = x < 0.0
    let ax = if neg { 0.0 - x } else { x }
    let scaled = ax * 10000.0 + 0.5
    let k = to_int(scaled)
    let whole = k / 10000
    let frac  = k - whole * 10000
    let mut frac_s = str(frac)
    // left-pad frac_s to 4 chars
    let pad_n = 4 - len(frac_s)
    let mut pad = ""
    let mut i = 0
    while i < pad_n {
        pad = pad + "0"
        i = i + 1
    }
    let body = str(whole) + "." + pad + frac_s
    if neg { return "-" + body }
    return body
}

// ─── JSON emit (flat shape) ─────────────────────────────────────

fn emit_json(
    names: array,
    r_acc: array, s_acc: array,
    r_ce:  array, s_ce:  array,
    weights: array,
    n_rows: int
) {
    let mut out = "{\n"
    out = out + "  \"n_checkpoints\": " + str(n_rows) + ",\n"
    out = out + "  \"dim_count\": " + str(PHI_DIM_COUNT) + ",\n"
    out = out + "  \"dims\": [\n"
    let n = len(names)
    let mut i = 0
    while i < n {
        let sep = if i + 1 < n { "," } else { "" }
        out = out + "    {"
        out = out + " \"name\": \"" + names[i] + "\","
        out = out + " \"r_pearson_acc\": "  + fmt4(r_acc[i])   + ","
        out = out + " \"r_spearman_acc\": " + fmt4(s_acc[i])   + ","
        out = out + " \"r_pearson_ce\": "   + fmt4(r_ce[i])    + ","
        out = out + " \"r_spearman_ce\": "  + fmt4(s_ce[i])    + ","
        out = out + " \"weight\": "         + fmt4(weights[i]) + " }" + sep + "\n"
        i = i + 1
    }
    out = out + "  ]\n"
    out = out + "}\n"
    write_file(OUT_JSON_PATH, out)
    println("  wrote " + OUT_JSON_PATH)
}

// ─── Main ───────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let full = is_full(argv)
    let manifest = get_manifest_path(argv)

    let rows = if len(manifest) > 0 {
        load_registry_from_manifest(manifest)
    } else {
        if full { make_full_registry() } else { make_smoke_registry() }
    }
    let n_rows = len(rows)
    let names = phi_dim_names()

    let mode_label = if len(manifest) > 0 {
        "manifest (" + str(n_rows) + " ckpts)"
    } else {
        if full { "full (5 ckpts)" } else { "smoke (3 ckpts)" }
    }

    println("[eval_phi_corr] 16D Φ ↔ benchmark correlation")
    println("  mode         : " + mode_label)
    println("  dims         : " + str(PHI_DIM_COUNT))
    println("  n_checkpoints: " + str(n_rows))
    println("")

    if n_rows == 0 {
        println("[eval_phi_corr] VERDICT FAIL — no rows loaded (empty manifest?)")
        println("pass=0")
        return
    }

    let task_acc = extract_task_acc(rows)
    let ce       = extract_ce(rows)

    // Per-dim correlation sweeps
    let mut r_acc = []
    let mut s_acc = []
    let mut r_ce  = []
    let mut s_ce  = []
    let mut weights = []
    let mut sig_count = 0
    let mut null_count = 0

    println("  dim                  r(acc)    ρ(acc)    r(CE)     ρ(CE)     weight  flag")
    println("  ----                 -------   -------   -------   -------   ------  ----")

    let mut d = 0
    while d < PHI_DIM_COUNT {
        let xs = extract_phi_dim(rows, d)
        let rp_a = corr_pearson(xs, task_acc)
        let rs_a = corr_spearman(xs, task_acc)
        let rp_c = corr_pearson(xs, ce)
        let rs_c = corr_spearman(xs, ce)
        let w    = weight_for(rp_a)
        let flag = flag_for(rp_a, rs_a)

        r_acc = r_acc.push(rp_a)
        s_acc = s_acc.push(rs_a)
        r_ce  = r_ce.push(rp_c)
        s_ce  = s_ce.push(rs_c)
        weights = weights.push(w)

        if flag == "SIG " { sig_count = sig_count + 1 }
        if flag == "NULL" { null_count = null_count + 1 }

        // Pad name to width 20
        let nm = names[d]
        let pad_n = 20 - len(nm)
        let mut pad = ""
        let mut pp = 0
        while pp < pad_n {
            pad = pad + " "
            pp = pp + 1
        }
        println("  " + nm + pad
              + " " + fmt4(rp_a) + "   "
              + fmt4(rs_a) + "   "
              + fmt4(rp_c) + "   "
              + fmt4(rs_c) + "   "
              + fmt4(w)    + "  "
              + flag)
        d = d + 1
    }

    println("")
    println("  SIGNIFICANT dims (|r| >= 0.5): " + str(sig_count) + " / " + str(PHI_DIM_COUNT))
    println("  NULL dims (|r| <  0.2):        " + str(null_count) + " / " + str(PHI_DIM_COUNT))

    emit_json(names, r_acc, s_acc, r_ce, s_ce, weights, n_rows)

    // Health criteria for the pipeline itself:
    //   - all 16 dims produced a finite r
    //   - at least 1 dim significant (otherwise the whole probe is suspect)
    //   - sum of weights > 0
    let mut w_sum = 0.0
    let mut k = 0
    while k < PHI_DIM_COUNT {
        w_sum = w_sum + weights[k]
        k = k + 1
    }
    let healthy = (sig_count >= 1) && (w_sum > 0.0)

    println("")
    if healthy {
        println("[eval_phi_corr] VERDICT PASS — pipeline healthy, " + str(sig_count)
              + " significant dim(s), Σw=" + fmt4(w_sum))
    } else {
        println("[eval_phi_corr] VERDICT FAIL — no significant correlation found")
    }
    println("pass=" + (if healthy { "1" } else { "0" }))
}

main()
