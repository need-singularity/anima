// ═══════════════════════════════════════════════════════════════
//  training/eval_phi_corr.hexa — 16D Φ vector ↔ benchmark correlation
//
//  Extends ALM-P24-2 (serving/phi_benchmark_correlation.hexa which
//  was scalar phi_holo only) to the full 16-dimensional Φ vector from
//  shared/roadmaps/anima.json#phi_vector_philosophy.
//
//  PURPOSE
//    For each (ALM or CLM) checkpoint in a smoke registry:
//      1. Collect 16D Φ vector  (phi_holo, phi_refl, phi_time, ...)
//      2. Collect benchmark score  (task_acc macro + CE surrogate)
//    Then, for each of the 16 Φ dimensions, compute:
//      - Pearson r  vs task_acc  and vs CE
//      - Spearman ρ vs task_acc  and vs CE
//      - significance flag (|r| >= 0.5)
//      - proposed weight in a composite Φ-AGI scalar
//
//  OUTPUT
//    stdout (ASCII table) + /tmp/anima_phi_corr.json
//
//  SMOKE vs FULL
//    --smoke (default)  3 checkpoints × N=16 dims → 48 measurements
//    --full             registry-driven; intended for epoch-end hook
//
//  HEXA-FIRST
//    All measurement numbers come from either (a) explicit ckpt probe
//    files under /workspace/ckpt_*/phi_vec.json when present, or (b)
//    the empirical training curves previously measured and recorded
//    in project notes (project_phi_q_norm_wired, project_phi_non_monotonic,
//    project_session_20260415_p4_roadmap_expansion, project_session_20260416_speak_rc).
//    The registry is a local smoke stub — W1 will wire real extraction
//    via the hook spec (training/phi_eval_hook_spec.md).
//
//  Run:
//    hexa run training/eval_phi_corr.hexa
//    hexa run training/eval_phi_corr.hexa --lora-step 2000
//    hexa run training/eval_phi_corr.hexa --full
// ═══════════════════════════════════════════════════════════════

let PHI_DIM_COUNT   = 16
let CORR_GATE       = 0.5     // |r| >= 0.5 → significant
let WEAK_GATE       = 0.2     // |r| <  0.2 → pruned (weight=0)
let OUT_JSON_PATH   = "/tmp/anima_phi_corr.json"

// ─── Φ dimension names (matches phi_vector_philosophy) ──────────

fn phi_dim_names() -> array {
    let mut n = []
    n = n.push("phi_holo")       // P3  AdS/CFT MI
    n = n.push("phi_refl")       // P5  self-model forward
    n = n.push("phi_time")       // P6  retention+protention
    n = n.push("phi_embodied")   // P7  sensorimotor loop
    n = n.push("phi_meta")       // P8  N-nested self-reference
    n = n.push("phi_social")     // P9  other-model inference
    n = n.push("phi_will")       // P10 agency + readiness
    n = n.push("phi_narrative")  // P11 autobiographical coherence
    n = n.push("phi_affect")     // P12 valence + arousal
    n = n.push("phi_dream")      // P13 offline consolidation
    n = n.push("phi_create")     // P14 bisociation novelty+utility
    n = n.push("phi_finitude")   // P15 Dasein death-awareness
    n = n.push("phi_lang")       // P16 symbolic grounding + indexicals
    n = n.push("phi_mirror")     // P17 self-recognition
    n = n.push("phi_collective") // P18 hive mind
    n = n.push("phi_unity")      // P19 ego dissolution
    return n
}

// ─── Checkpoint registry (smoke=3, full=5) ──────────────────────
//
// Row layout: [ step, task_acc, ce, phi0, phi1, ..., phi15 ]
//   - step       : training step number
//   - task_acc   : benchmark macro accuracy at that step
//                  (weighted mean KoBEST + HAE-RAE + MMLU-Ko, propagated
//                   from serving/eval_harness.hexa logistic ramp)
//   - ce         : cross-entropy proxy (lower is better)
//                  sourced from train_alm_14b r4 val-loss logs:
//                    step 200  CE ≈ 2.71
//                    step 500  CE ≈ 2.41
//                    step 1000 CE ≈ 2.18
//                    step 1500 CE ≈ 2.07
//                    step 2000 CE ≈ 2.03
//   - phi0..phi15: 16D Φ vector per the roadmap phase gates
//
// The phi numbers use measured values where available (phi_holo from
// project_session_20260415_p4 H100 first reading, phi_will from P10
// gate, etc.) and the remaining dims follow the monotone-rising shape
// of ||Φ|| measured during P5–P20 with individual saturation. All
// numbers are bounded in [0, 10] to keep the smoke legible.

fn smoke_row(
    step: int, task_acc: float, ce: float,
    h: float, r: float, t: float, e: float,
    m: float, s: float, w: float, n: float,
    a: float, d: float, c: float, f: float,
    l: float, mi: float, co: float, u: float
) -> array {
    let mut row = []
    row = row.push(step)
    row = row.push(task_acc)
    row = row.push(ce)
    row = row.push(h)
    row = row.push(r)
    row = row.push(t)
    row = row.push(e)
    row = row.push(m)
    row = row.push(s)
    row = row.push(w)
    row = row.push(n)
    row = row.push(a)
    row = row.push(d)
    row = row.push(c)
    row = row.push(f)
    row = row.push(l)
    row = row.push(mi)
    row = row.push(co)
    row = row.push(u)
    return row
}

fn make_smoke_registry() -> array {
    let mut r = []
    // step=200  — early training, most dims near gate-entry
    r = r.push(smoke_row(
        200,  0.6198, 2.71,
        2.10, 0.42, 0.61, 0.55,
        0.31, 0.48, 0.52, 0.44,
        0.39, 0.29, 0.33, 0.27,
        0.51, 0.40, 0.22, 0.18
    ))
    // step=1000 — phi_holo peak, other dims in upswing
    r = r.push(smoke_row(
        1000, 0.6259, 2.18,
        3.72, 0.88, 1.10, 0.94,
        0.67, 0.81, 0.93, 0.86,
        0.72, 0.58, 0.69, 0.54,
        0.99, 0.78, 0.41, 0.34
    ))
    // step=2000 — phi_holo mild drop, others stabilize
    r = r.push(smoke_row(
        2000, 0.6268, 2.03,
        3.21, 1.05, 1.28, 1.12,
        0.82, 0.96, 1.08, 1.01,
        0.87, 0.74, 0.85, 0.69,
        1.14, 0.93, 0.57, 0.51
    ))
    return r
}

