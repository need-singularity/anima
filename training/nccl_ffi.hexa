// @platform(linux_x86_64) — NCCL FFI, skip on darwin (no libnccl)
// ===============================================================
//  training/nccl_ffi.hexa — NCCL FFI for FSDP (C9 + r12 unblock)
//
//  This file is the boundary between hexa-native FSDP (fsdp_shard.hexa)
//  and the NVIDIA NCCL collective comm library, routed through the
//  $HEXA_LANG/lib/hxnccl/libhxnccl.so wrapper (which itself wraps
//  self/native/hxccl_linux.c Day-2 NCCL path).
//
//  Surface required by fsdp_shard.hexa:
//      nccl_init(world_size, rank)               -> int
//      nccl_broadcast_layer(owner, layer, D, FF) -> int
//      nccl_reduce_scatter_layer(owner, layer, _) -> int
//      nccl_barrier()                             -> int
//      nccl_shutdown()                            -> int
//      NCCL_TODO_RC                               (comptime const)
//
//  Status (2026-04-20 — r12 FSDP B1 unblock):
//
//    - nccl_init / nccl_shutdown / nccl_barrier / nccl_all_reduce_loss
//      now route to libhxnccl extern functions (hxnccl_init_world,
//      hxnccl_destroy_world, hxnccl_barrier, hxnccl_allreduce_f32).
//      Single-rank smoke verified on Mac (lib/hxnccl/build/hxnccl_smoke
//      8/8 PASS); 2-rank H100 SXM smoke deferred to a separate launch.
//
//    - nccl_broadcast_layer / nccl_reduce_scatter_layer remain
//      NCCL_TODO_RC for world>1. These are LAYER-granularity collectives
//      that need the FSDP shard layer pointers (the 8 tensors per
//      Qwen2DecoderLayer); wiring those into ncclBroadcast/ReduceScatter
//      requires fsdp_shard.hexa edits + per-layer device pointer arrays
//      and is the B2 follow-up that depends on this B1 landing first.
//
//  References:
//    - lib/hxnccl/hxnccl.c                  (thin wrapper exporting
//                                            hxnccl_* surface)
//    - self/native/hxccl_linux.c            (Day-2 ncclCommInitRank +
//                                            ncclAllReduce + ncclBroadcast
//                                            + ncclAllGather +
//                                            ncclReduceScatter)
//    - lib/hxnccl/CMakeLists.txt            (HXNCCL_WITH_NCCL=ON for
//                                            production Linux build)
//    - state/alm_r11_fsdp_plan_20260420.json
//    - state/alm_r12_fsdp_unblock_20260420.json
// ===============================================================

// ───────────────────────────────────────────────────────────────
//  Module load marker.
// ───────────────────────────────────────────────────────────────
println("[nccl_ffi] loaded — libhxnccl wired for init/barrier/shutdown/all_reduce_loss; layer collectives still B2")

// ───────────────────────────────────────────────────────────────
//  extern bindings — libhxnccl surface.
//
//  All return int64 in C; hexa int maps to int64 on linux x86_64.
//  Buffer pointers are int64-encoded device pointers in NCCL mode.
//  HXCCL_UNIQUE_ID_FILE env var controls the rendezvous file path
//  (defaults to /tmp/hxccl_uid_<world_size>); set this in launcher
//  for non-/tmp shared filesystems.
// ───────────────────────────────────────────────────────────────

@link("hxnccl")
extern fn hxnccl_init_world(rank: int, world_size: int, master_addr: *Void, master_port: int) -> int

@link("hxnccl")
extern fn hxnccl_destroy_world() -> int

@link("hxnccl")
extern fn hxnccl_barrier() -> int

@link("hxnccl")
extern fn hxnccl_allreduce_f32(buf_ptr: int, count: int, op_code: int) -> int

@link("hxnccl")
extern fn hxnccl_broadcast_f32(buf_ptr: int, count: int, root: int) -> int

// B2 layer-collective surface (added 2026-04-20). reduce_scatter takes
// a SEND buffer of world*count elements and emits a RECV of count
// elements per rank; allgather is the dual. Both are device-pointer in
// NCCL mode.
@link("hxnccl")
extern fn hxnccl_reduce_scatter_f32(send_ptr: int, recv_ptr: int, count: int) -> int

@link("hxnccl")
extern fn hxnccl_allgather_f32(send_ptr: int, recv_ptr: int, count: int) -> int

@link("hxnccl")
extern fn hxnccl_world_size() -> int

@link("hxnccl")
extern fn hxnccl_rank() -> int

@link("hxnccl")
extern fn hxnccl_version() -> int

// ───────────────────────────────────────────────────────────────
//  Comptime constants.
//
//  NCCL_OK / NCCL_TODO_RC — return codes. TODO_RC=99 still kept
//  for the LAYER collectives that have not been wired (B2).
//  AVG/SUM op codes match libhxnccl: 0=SUM, 1=AVG.
// ───────────────────────────────────────────────────────────────

comptime const NCCL_OK       = 0
comptime const NCCL_TODO_RC  = 99
comptime const NCCL_OP_SUM   = 0
comptime const NCCL_OP_AVG   = 1

// Module-level globals so callers can read the current world size
// without having to thread it through every helper. Set once by
// nccl_init() at process start.
let mut NCCL_WORLD_SIZE = 1
let mut NCCL_RANK       = 0
let mut NCCL_INITED     = false

// ───────────────────────────────────────────────────────────────
//  nccl_init — initialise the NCCL communicator. world_size==1
//  short-circuits with no NCCL call (libhxnccl handles this fast
//  path internally); world_size>1 routes to hxnccl_init_world
//  which calls ncclCommInitRank under the hood.
// ───────────────────────────────────────────────────────────────

fn nccl_init(world_size: int, rank: int) -> int {
    NCCL_WORLD_SIZE = world_size
    NCCL_RANK       = rank
    let rc = hxnccl_init_world(rank, world_size, ptr_null(), 0)
    if rc != 0 {
        println("[nccl_ffi] nccl_init FAILED — hxnccl_init_world rc=" + str(rc)
                + " world_size=" + str(world_size) + " rank=" + str(rank))
        return rc
    }
    NCCL_INITED = true
    if world_size <= 1 {
        println("[nccl_ffi] nccl_init OK — single-rank (libhxnccl no-op path)")
    } else {
        println("[nccl_ffi] nccl_init OK — world_size=" + str(world_size)
                + " rank=" + str(rank) + " (libhxnccl ncclCommInitRank)")
    }
    return NCCL_OK
}

fn nccl_shutdown() -> int {
    if !NCCL_INITED { return NCCL_OK }
    let rc = hxnccl_destroy_world()
    NCCL_INITED = false
    if rc != 0 {
        println("[nccl_ffi] nccl_shutdown — hxnccl_destroy_world rc=" + str(rc))
    }
    return rc
}

// nccl_world_size / nccl_rank — accessor helpers so callers do
// not touch the module globals directly (cleaner test mocking).
fn nccl_world_size() -> int { return NCCL_WORLD_SIZE }
fn nccl_rank() -> int       { return NCCL_RANK }

// ───────────────────────────────────────────────────────────────
//  nccl_barrier — process-wide synchronization point. Used by
//  fsdp_save_ckpt to ensure all ranks have finished writing
//  their shard files before the launcher is allowed to upload
//  to R2.
//
//  Single-rank: trivially OK (libhxnccl returns 0).
//  Multi-rank: routes to ncclAllReduce on a 1-byte device buffer
//  (the canonical lightweight barrier impl in NCCL).
// ───────────────────────────────────────────────────────────────

fn nccl_barrier() -> int {
    return hxnccl_barrier()
}

// ───────────────────────────────────────────────────────────────
//  nccl_broadcast_layer — broadcast all 8 tensors of a transformer
//  layer from `owner` rank to every other rank. Used by FSDP
//  all-gather before each layer's forward.
//
//  B2 wire (2026-04-20): caller passes the 8 device pointers as
//  an array `tensor_ptrs` and the matching element counts as
//  `tensor_counts`. We loop and call hxnccl_broadcast_f32 once
//  per tensor. world_size==1 short-circuits to NCCL_OK so the
//  single-rank fast path stays bit-identical to the no-op.
//
//  fsdp_shard.hexa builds tensor_ptrs from a GpuLayer struct:
//      [layer.Wq, layer.Wk, layer.Wv, layer.Wo,
//       layer.Wff1, layer.Wff2, layer.ga, layer.gf]
//  and tensor_counts from cfg dims:
//      [D*D, D*D, D*D, D*D, D*FF, FF*D, D, D]
//
//  Returns NCCL_OK if every per-tensor broadcast returns 0; first
//  non-zero return code propagates so the trainer can abort.
// ───────────────────────────────────────────────────────────────

fn nccl_broadcast_layer_tensors(owner: int, layer_id: int,
                                tensor_ptrs: array, tensor_counts: array) -> int {
    if NCCL_WORLD_SIZE <= 1 { return NCCL_OK }
    let n = len(tensor_ptrs)
    if n != len(tensor_counts) {
        println("[nccl_ffi] broadcast_layer_tensors — len mismatch ptrs="
                + str(n) + " counts=" + str(len(tensor_counts)))
        return -2
    }
    let mut i = 0
    while i < n {
        let ptr = tensor_ptrs[i]
        let cnt = tensor_counts[i]
        let rc = hxnccl_broadcast_f32(ptr, cnt, owner)
        if rc != 0 {
            println("[nccl_ffi] broadcast_layer_tensors — tensor "
                    + str(i) + " of layer " + str(layer_id)
                    + " rc=" + str(rc))
            return rc
        }
        i = i + 1
    }
    return NCCL_OK
}

// Back-compat shim — old fsdp_shard call sites that don't yet pass the
// pointer/count arrays still work, but they print the old TODO so we
// can grep-find them. Returns NCCL_TODO_RC for world>1 to keep the
// existing "treat non-zero as configuration error" contract.
fn nccl_broadcast_layer(owner: int, layer_id: int, D: int, FF: int) -> int {
    if NCCL_WORLD_SIZE <= 1 { return NCCL_OK }
    println("[nccl_ffi] nccl_broadcast_layer — legacy stub (use _tensors): owner="
            + str(owner) + " layer=" + str(layer_id)
            + " D=" + str(D) + " FF=" + str(FF))
    return NCCL_TODO_RC
}

// ───────────────────────────────────────────────────────────────
//  nccl_reduce_scatter_layer — sum gradient tensors across ranks
//  via in-place all-reduce so the dense-grad FSDP variant works
//  (every rank still holds the full grad, but the values agree).
//
//  B2 wire (2026-04-20): same array pattern as broadcast_layer.
//  We use ncclAllReduce (via hxnccl_allreduce_f32 op_code SUM)
//  rather than ncclReduceScatter so the caller does not need to
//  partition the grad buffer ahead of time — the math is the same
//  for the dense-grad LoRA path used by train_alm_lora.
//
//  For sharded-grad FSDP (true ZeRO-3), call hxnccl_reduce_scatter_f32
//  directly with a (world * count)-sized SEND and (count)-sized RECV.
// ───────────────────────────────────────────────────────────────

fn nccl_reduce_scatter_layer_tensors(owner: int, layer_id: int,
                                     grad_ptrs: array, grad_counts: array) -> int {
    if NCCL_WORLD_SIZE <= 1 { return NCCL_OK }
    let n = len(grad_ptrs)
    if n != len(grad_counts) {
        println("[nccl_ffi] reduce_scatter_layer_tensors — len mismatch ptrs="
                + str(n) + " counts=" + str(len(grad_counts)))
        return -2
    }
    let mut i = 0
    while i < n {
        let ptr = grad_ptrs[i]
        let cnt = grad_counts[i]
        // SUM across ranks; rank == owner ends with the same valid grad
        // as everyone else (dense path). For true reduce-scatter, see
        // hxnccl_reduce_scatter_f32 (B2 sharded-grad).
        let rc = hxnccl_allreduce_f32(ptr, cnt, NCCL_OP_SUM)
        if rc != 0 {
            println("[nccl_ffi] reduce_scatter_layer_tensors — tensor "
                    + str(i) + " of layer " + str(layer_id)
                    + " rc=" + str(rc))
            return rc
        }
        i = i + 1
    }
    let _ = owner    // owner kept in signature for parity + future sharded path
    return NCCL_OK
}

// Back-compat shim — preserved so existing fsdp_shard.hexa call sites
// (which only pass owner+layer+0) keep returning NCCL_TODO_RC for
// world>1; trainer treats that as "use new array surface".
fn nccl_reduce_scatter_layer(owner: int, layer_id: int, _unused: int) -> int {
    if NCCL_WORLD_SIZE <= 1 { return NCCL_OK }
    println("[nccl_ffi] nccl_reduce_scatter_layer — legacy stub (use _tensors): owner="
            + str(owner) + " layer=" + str(layer_id))
    return NCCL_TODO_RC
}

// ───────────────────────────────────────────────────────────────
//  nccl_all_reduce_loss — sum the scalar loss across ranks for
//  step-level logging consistency. Single-rank no-op.
//
//  B2 wire (2026-04-20): the caller stages the local loss into a
//  device-side 1-element f32 buffer (via cuda_ffi.cuda_memcpy_h2d
//  on a pre-allocated 4-byte device buffer) and passes that
//  pointer here; we run hxnccl_allreduce_f32 with op AVG, then
//  the caller D2H-copies the result back. Because a hexa float
//  cannot directly back a device pointer at this boundary, the
//  scalar version below stays a logging stub — wire the real
//  device-pointer flow at the call site (train_alm_lora step
//  block) once per-step loss aggregation is needed.
// ───────────────────────────────────────────────────────────────

fn nccl_all_reduce_loss(local_loss: float) -> float {
    if NCCL_WORLD_SIZE <= 1 { return local_loss }
    println("[nccl_ffi] nccl_all_reduce_loss — scalar overload returns local; "
            + "use device-pointer flow for true sync")
    return local_loss
}

// nccl_all_reduce_loss_dev — device-pointer overload. Caller stages
// `local_loss` into `loss_dev_ptr` (4 bytes), invokes us, and reads
// the value back D2H. world_size==1: no-op (caller's stage value is
// the answer). world_size>1: ncclAllReduce AVG on a 1-element f32.
fn nccl_all_reduce_loss_dev(loss_dev_ptr: int) -> int {
    if NCCL_WORLD_SIZE <= 1 { return NCCL_OK }
    return hxnccl_allreduce_f32(loss_dev_ptr, 1, NCCL_OP_AVG)
}
