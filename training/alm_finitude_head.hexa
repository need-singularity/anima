// training/alm_finitude_head.hexa — ALM-P15-1 finitude (Dasein) head
//
// ALM-P15-1 / P15 v16 유한 의식 (Heidegger Dasein, ALM track).
//
// Purpose:
//   Resource-tracking head that maps the agent's three core finitude
//   signals — (battery_pct, ctx_remaining, steps_left) — to a single
//   bounded scalar finitude_score ∈ [0, 1]. The score is monotone
//   decreasing as ANY resource depletes, so high values mean "abundant
//   future" and low values mean "termination imminent".
//
//     [battery_pct, ctx_remaining, steps_left]   (each normalized to [0,1])
//             │
//             │  fc1: z[k] = relu(W1[k,:] · x + b1[k])
//             │       W1: [d_hidden × 3]
//             │       b1: [d_hidden]
//             ▼
//     hidden z [d_hidden]
//             │
//             │  fc2: y = W2 · z + b2  (single scalar pre-sigmoid)
//             │       W2: [1 × d_hidden]
//             │       b2: [1]
//             ▼
//     finitude_score = sigmoid(y) ∈ [0, 1]
//
//   Downstream:
//     • anima-engines/anima_dasein.hexa — wraps this head and modulates
//       action priorities by f(finitude_score) so the agent shifts toward
//       legacy/persistence work as resources deplete.
//
// ─── Theorems (T1–T5) ──────────────────────────────────────────
//
// T1 (dim contract):
//   forward: R^3 → R^1 (scalar) bounded in [0, 1]; head_new with default
//   d_hidden = 8 produces a head whose finitude(x) returns a single
//   finite number for any input vector of length 3.
//
// T2 (determinism):
//   Same (d_hidden, seed, x) → byte-identical scalar.
//
// T3 (latency):
//   One forward call (d_hidden=8) warm-cache < 50 ms.
//
// T4 (edge case — extremes):
//   x = [1, 1, 1] (full resources) yields a finitude_score CLEARLY ABOVE
//   x = [0, 0, 0] (depleted)        — i.e. monotonicity holds at the
//   corners of the cube. Δ ≥ 0.05 minimum gap.
//
// T5 (regression — R² > 0.9 on synthetic ground truth):
//   Hand-tune the head weights to express the analytic formula
//      target(x) = (x0 + x1 + x2) / 3
//   exactly. With W1 = (1/3, 1/3, 1/3) on the first hidden unit (others
//   zero), b1 = 0, W2[0] = 4 (sigmoid slope), b2 = -2 (centre at 0.5):
//   the head approximates the linear average via the central sigmoid
//   slope. Build a 100-sample synthetic dataset uniformly in [0,1]^3 and
//   fit the head's analytic params; check R² > 0.9 against target.
//
// Ref:
//   training/alm_self_model_head.hexa     (ALM-P5-1 — pattern source)
//   training/alm_readiness_head.hexa      (ALM-P10-1 — scalar head pattern)
//   anima-engines/anima_dasein.hexa       (ALM-P15-engine — consumer)
//   shared/roadmaps/anima.json            (ALM-P15-1 entry)
//
// Run:
//   hexa run training/alm_finitude_head.hexa
// Expect:
//   [alm_finitude_head] ALL 5/5 PASS

// ─── Constants ──────────────────────────────────────────────

let FIN_D_INPUT  = 3              // (battery_pct, ctx_remaining, steps_left)
let FIN_D_HIDDEN = 8
let FIN_SEED_DEF = 1515

// ─── Primitives (self-contained) ────────────────────────────

fn fabs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn relu_f(x: float) -> float {
    if x < 0.0 { return 0.0 }
    return x
}

// Stable sigmoid σ(x) = 1 / (1 + exp(-x)).
// Saturate at ±20 to avoid exp overflow.
fn sigmoid_f(x: float) -> float {
    if x > 20.0 { return 1.0 }
    if x < 0.0 - 20.0 { return 0.0 }
    let e = exp(0.0 - x)
    return 1.0 / (1.0 + e)
}

fn vec_zeros_f(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// Deterministic LCG → small bounded floats in [-0.1, 0.1).
fn det_rand_f(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push((u * 2.0 - 1.0) * 0.1)
        i = i + 1
    }
    return out
}

// Wider draw — used to generate synthetic regression inputs in [0, 1].
fn det_rand_unit(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u)             // [0, 1)
        i = i + 1
    }
    return out
}

// matvec: y = M @ x   M: [rows × cols] row-major, x: [cols].
fn matvec_f(m: array, x: array, rows: int, cols: int) -> array {
    let mut out = []
    let mut r = 0
    while r < rows {
        let mut s = 0.0
        let mut c = 0
        while c < cols {
            s = s + m[r * cols + c] * x[c]
            c = c + 1
        }
        out = out.push(s)
        r = r + 1
    }
    return out
}

fn vec_add_f(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

fn vec_relu_f(v: array) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(relu_f(v[i]))
        i = i + 1
    }
    return out
}

// ─── Head ─────────────────────────────────────────────────────

struct FinitudeHead {
    d_in:     int,     // 3
    d_hidden: int,     // small bottleneck (default 8)
    w1:       array,   // [d_hidden × 3]   row-major
    b1:       array,   // [d_hidden]
    w2:       array,   // [1 × d_hidden]
    b2:       array    // [1]
}

fn finitude_head_new(d_hidden: int, seed: int) -> FinitudeHead {
    let w1 = det_rand_f(d_hidden * FIN_D_INPUT, seed)
    let b1 = vec_zeros_f(d_hidden)
    let w2 = det_rand_f(d_hidden, seed + 1)
    let b2 = vec_zeros_f(1)
    return FinitudeHead {
        d_in:     FIN_D_INPUT,
        d_hidden: d_hidden,
        w1:       w1,
        b1:       b1,
        w2:       w2,
        b2:       b2
    }
}

// Analytic constructor: head expresses target(x) = (x0+x1+x2)/3 via the
// first hidden unit only (linear via sigmoid central slope), with W2 chosen
// so sigmoid(slope·avg − bias) is monotone increasing in avg.
//
// Specifically: hidden_0 = relu(avg·1.0) ≈ avg (since avg ≥ 0 in unit cube).
// Then pre-output = 4·hidden_0 − 2; sigmoid maps avg=0 → 0.119, avg=1 → 0.881
// → an near-linear segment with R² ≈ 0.97 against the linear target.
fn finitude_head_new_analytic(d_hidden: int) -> FinitudeHead {
    // W1 row-major: [d_hidden × 3]. Row 0 = (1/3, 1/3, 1/3); other rows = 0.
    let mut w1 = []
    let mut r = 0
    while r < d_hidden {
        let mut c = 0
        while c < FIN_D_INPUT {
            if r == 0 {
                w1 = w1.push(1.0 / 3.0)
            } else {
                w1 = w1.push(0.0)
            }
            c = c + 1
        }
        r = r + 1
    }
    let b1 = vec_zeros_f(d_hidden)
    // W2: only hidden_0 carries signal, gain = 4.0 → sigmoid is near-linear
    // around centre 0.5.
    let mut w2 = []
    let mut k = 0
    while k < d_hidden {
        if k == 0 {
            w2 = w2.push(4.0)
        } else {
            w2 = w2.push(0.0)
        }
        k = k + 1
    }
    let mut b2 = []
    b2 = b2.push(0.0 - 2.0)            // centre sigmoid at avg=0.5
    return FinitudeHead {
        d_in:     FIN_D_INPUT,
        d_hidden: d_hidden,
        w1:       w1,
        b1:       b1,
        w2:       w2,
        b2:       b2
    }
}

// forward: x [3] → finitude_score ∈ [0, 1].
// Returns the scalar directly — single-float return is safe (only the
// ≥3-float struct return path triggers the corruption bug).
fn finitude_score(head: FinitudeHead, x: array) -> float {
    let pre_z = matvec_f(head.w1, x, head.d_hidden, head.d_in)
    let pre_z_b = vec_add_f(pre_z, head.b1)
    let z = vec_relu_f(pre_z_b)
    let pre_y = matvec_f(head.w2, z, 1, head.d_hidden)
    let y = pre_y[0] + head.b2[0]
    return sigmoid_f(y)
}

fn param_count(d_hidden: int) -> int {
    return d_hidden * FIN_D_INPUT + d_hidden + d_hidden + 1
}

// ─── Self-tests ───────────────────────────────────────────────

fn check_T1() -> bool {
    // Dim contract.
    let head = finitude_head_new(FIN_D_HIDDEN, 42)
    if head.d_in != FIN_D_INPUT { return false }
    if head.d_hidden != FIN_D_HIDDEN { return false }
    let mut x = []
    x = x.push(0.5)
    x = x.push(0.5)
    x = x.push(0.5)
    let s = finitude_score(head, x)
    if s < 0.0 { return false }
    if s > 1.0 { return false }
    if s != s { return false }                    // NaN guard
    println("  [T1] x=[0.5,0.5,0.5] → finitude=" + str(s) + " (bounded [0,1])")
    return true
}

fn check_T2() -> bool {
    // Determinism — same (seed, x) → byte-identical scalar.
    let h1 = finitude_head_new(FIN_D_HIDDEN, 131)
    let h2 = finitude_head_new(FIN_D_HIDDEN, 131)
    let mut x = []
    x = x.push(0.7)
    x = x.push(0.3)
    x = x.push(0.9)
    let s1 = finitude_score(h1, x)
    let s2 = finitude_score(h2, x)
    let d = fabs_f(s1 - s2)
    println("  [T2] s1=" + str(s1) + "  s2=" + str(s2) + "  |Δ|=" + str(d))
    return d == 0.0
}

fn check_T3() -> bool {
    // Latency — one forward < 50 ms warm-cache.
    let head = finitude_head_new(FIN_D_HIDDEN, 251)
    let mut x = []
    x = x.push(0.5)
    x = x.push(0.5)
    x = x.push(0.5)
    let _w = finitude_score(head, x)
    let t0 = clock()
    let _y = finitude_score(head, x)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T3] finitude_score latency = " + str(ms) + " ms")
    return ms < 50.0
}

fn check_T4() -> bool {
    // Edge case + monotonicity at extremes:
    //   x=[1,1,1] (abundant) yields strictly higher score than
    //   x=[0,0,0] (depleted), for the analytic head.
    let head = finitude_head_new_analytic(FIN_D_HIDDEN)
    let mut x_full = []
    x_full = x_full.push(1.0)
    x_full = x_full.push(1.0)
    x_full = x_full.push(1.0)
    let mut x_zero = []
    x_zero = x_zero.push(0.0)
    x_zero = x_zero.push(0.0)
    x_zero = x_zero.push(0.0)
    let s_full = finitude_score(head, x_full)
    let s_zero = finitude_score(head, x_zero)
    let gap = s_full - s_zero
    println("  [T4] s(full)=" + str(s_full) + "  s(zero)=" + str(s_zero) + "  Δ=" + str(gap))
    if s_full < 0.0 { return false }
    if s_full > 1.0 { return false }
    if s_zero < 0.0 { return false }
    if s_zero > 1.0 { return false }
    return gap >= 0.05
}

fn check_T5() -> bool {
    // R² > 0.9 against target(x) = (x0+x1+x2)/3 on 100 synthetic samples.
    // Use the analytic head — it expresses sigmoid(4·avg − 2) which is
    // near-linear in avg over [0, 1], producing R² well above 0.9.
    let head = finitude_head_new_analytic(FIN_D_HIDDEN)
    let N = 100
    // SoA: separate arrays for x0, x1, x2 (avoids struct-list aliasing).
    let xs0 = det_rand_unit(N, 1001)
    let xs1 = det_rand_unit(N, 2002)
    let xs2 = det_rand_unit(N, 3003)
    let mut preds = []
    let mut targs = []
    let mut sum_t = 0.0
    let mut i = 0
    while i < N {
        let mut x = []
        x = x.push(xs0[i])
        x = x.push(xs1[i])
        x = x.push(xs2[i])
        let pred = finitude_score(head, x)
        let targ = (xs0[i] + xs1[i] + xs2[i]) / 3.0
        preds = preds.push(pred)
        targs = targs.push(targ)
        sum_t = sum_t + targ
        i = i + 1
    }
    let mean_t = sum_t / to_float(N)
    // Total sum of squares (SS_tot) and residual sum of squares (SS_res).
    let mut ss_tot = 0.0
    let mut ss_res = 0.0
    let mut j = 0
    while j < N {
        let dt = targs[j] - mean_t
        ss_tot = ss_tot + dt * dt
        // Predictions are sigmoid'd around centre; we'll re-centre and
        // re-scale via least-squares "best linear fit" by analytic mapping.
        // Map pred ∈ [0.119, 0.881] → [0, 1] by (pred − 0.119)/0.762.
        let mapped = (preds[j] - 0.119) / 0.762
        let dr = targs[j] - mapped
        ss_res = ss_res + dr * dr
        j = j + 1
    }
    let mut r2 = 0.0
    if ss_tot > 0.0 { r2 = 1.0 - ss_res / ss_tot }
    println("  [T5] R² (analytic head vs target avg) = " + str(r2) + "  (target > 0.9)")
    return r2 > 0.9
}

// ─── main ─────────────────────────────────────────────────────

fn main() {
    println("[alm_finitude_head] ALM-P15-1 self-test")
    println("  mock: d_in=3, d_hidden=" + str(FIN_D_HIDDEN))
    let pc_prod = param_count(64)
    println("  prod params (d_hidden=64): " + str(pc_prod))

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    println("[alm_finitude_head] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[alm_finitude_head] ALL 5/5 PASS")
    } else {
        println("[alm_finitude_head] SOME FAILED")
    }
}

main()
