// training/corpus_kowiki_extract.hexa — CLM 7B kowiki XML → plain text (hexa native)
//
// Plan SSOT: state/corpus_140gb_plan.json
// Progress:  state/corpus_7b_progress_20260416.json
//
// Purpose:
//   Decompress kowiki XML bz2 dump and emit one line per article to a
//   UTF-8 plain-text file, suitable for feeding into training/corpus_filter.hexa.
//
//   wikiextractor (Python) is BANNED (Total .py ban, feedback_py_ban_total).
//   We use a hexa orchestrator that shells out to `bzcat | awk | sed`. The
//   heavy-lifting bytewise parsing stays in the battle-tested Unix tools,
//   while the hexa file is the canonical invocation contract + self-test.
//
// Pipeline (exec-delegated):
//   bzcat INPUT
//     | awk (extract <text> bodies where <ns>=0, skip Wikipedia:/Help:/etc)
//     | sed (strip markup: [[link|text]] -> text, {{template}} -> '')
//     | sed (strip residual <tags>)
//     > OUTPUT (one article per line, space-collapsed)
//
// Input:  data/corpus_v2_raw/kowiki-latest-pages-articles-multistream.xml.bz2
// Output: data/corpus_v2_clean/kowiki.txt
//
// Self-tests (T1..T5):
//   T1 tiny mock XML 1-page parse correctness (hangul text survives)
//   T2 markup stripping: [[link|alias]] -> alias, {{template}} -> ''
//   T3 namespace filter: Wikipedia:Policy (ns=4) skipped
//   T4 empty <text> skipped
//   T5 latency: 10MB mock repeat finishes under 5s
//
// Stage0 constraints honored:
//   - exec() returns stdout string; trim() available
//   - no early-return inside while (feedback interpreter bug)
//   - no nested fn-call-inside-substring loops with bool breaks
//   - import count: 0 (well under silent-exit threshold of 5)
//
// Run:
//   hexa run training/corpus_kowiki_extract.hexa                 # self-test 5/5
//   hexa run training/corpus_kowiki_extract.hexa --extract       # extract real dump

// =====================================================================
// Constants
// =====================================================================

let INPUT_PATH  = "data/corpus_v2_raw/kowiki-latest-pages-articles-multistream.xml.bz2"
let OUTPUT_PATH = "data/corpus_v2_clean/kowiki.txt"
let TMP_DIR     = "data/corpus_v2_clean/tmp_kowiki"
let MOCK_XML    = "data/corpus_v2_clean/tmp_kowiki/_mock.xml"
let MOCK_OUT    = "data/corpus_v2_clean/tmp_kowiki/_mock_out.txt"
let MIN_TEXT_LEN = 10

// =====================================================================
// AWK program — extracts <text> bodies for ns=0 pages.
// Written as a hexa string literal so the shell gets it verbatim.
//
// State machine:
//   on <title>X</title> -> title=X
//   on <ns>N</ns>       -> ns=N
//   on <text ...>       -> in_text=1, begin capturing
//   on </text>          -> in_text=0, mark emit
//   after emit          -> if ns==0 and length>MIN, print text
//
// NOTE: We use printf from hexa to write the program to a file and
// invoke awk -f, avoiding shell quoting nightmares with embedded
// single/double quotes.
// =====================================================================

fn awk_program() -> string {
    let p = "BEGIN { in_text=0; emit=0; title=\"\"; ns=\"\"; text=\"\" }\n"
    let p1 = p + "/<title>/ { line=$0; sub(/.*<title>/, \"\", line); sub(/<\\/title>.*/, \"\", line); title=line; next }\n"
    let p2 = p1 + "/<ns>/ { line=$0; sub(/.*<ns>/, \"\", line); sub(/<\\/ns>.*/, \"\", line); ns=line; next }\n"
    let p3 = p2 + "/<text/ && in_text==0 { line=$0; sub(/.*<text[^>]*>/, \"\", line); text=line; in_text=1; if (match(line, /<\\/text>/)) { sub(/<\\/text>.*/, \"\", text); in_text=0; emit=1 }; next }\n"
    let p4 = p3 + "in_text==1 && /<\\/text>/ { line=$0; sub(/<\\/text>.*/, \"\", line); text=text \" \" line; in_text=0; emit=1; next }\n"
    let p5 = p4 + "in_text==1 { text=text \" \" $0; next }\n"
    let p6 = p5 + "emit==1 { emit=0; if (ns==\"0\" && length(text)>" + str(MIN_TEXT_LEN) + ") print text; text=\"\"; ns=\"\"; title=\"\" }\n"
    return p6
}

// =====================================================================
// Build the full shell pipeline: decompress | awk | strip_markup
// =====================================================================

fn build_pipeline(input_path: string, output_path: string, decompress_cmd: string, awk_prog_path: string) -> string {
    // decompress_cmd: "bzcat" for .bz2, "cat" for plain xml (mock tests)
    let cmd = decompress_cmd + " '" + input_path + "' " +
              " | awk -f '" + awk_prog_path + "' " +
              " | sed -E 's/\\{\\{[^}]*\\}\\}//g' " +
              " | sed -E 's/\\[\\[([^]|]+)\\|([^]]+)\\]\\]/\\2/g' " +
              " | sed -E 's/\\[\\[([^]]+)\\]\\]/\\1/g' " +
              " | sed -E 's/<[^>]+>//g' " +
              " | awk 'NF>0' " +
              " > '" + output_path + "'"
    return cmd
}

// =====================================================================
// Extract — run the full pipeline on the real kowiki dump
// =====================================================================

fn extract(input: string, output: string) -> int {
    exec("mkdir -p '" + TMP_DIR + "'")
    exec("mkdir -p data/corpus_v2_clean")

    let prog = awk_program()
    let prog_path = TMP_DIR + "/_kowiki_extract.awk"
    write_file(prog_path, prog)

    let cmd = build_pipeline(input, output, "bzcat", prog_path)
    println("[extract] cmd: " + cmd)
    let _r = exec(cmd)

    // Count lines in output
    let wc_out = exec("wc -l < '" + output + "' 2>/dev/null").trim()
    if wc_out == "" {
        println("[extract] output file empty or missing: " + output)
        return -1
    }
    let size_out = exec("wc -c < '" + output + "' 2>/dev/null").trim()
    println("[extract] lines=" + wc_out + " bytes=" + size_out + " -> " + output)
    return to_int(wc_out)
}

// =====================================================================
// Self-test fixtures
// =====================================================================

fn mock_xml() -> string {
    let s1 = "<mediawiki>\n"
    let s2 = s1 + "<page>\n<title>안녕</title>\n<ns>0</ns>\n<revision>\n<text>한국어 위키 첫 번째 문서입니다. [[링크]]를 포함합니다. {{템플릿}}</text>\n</revision>\n</page>\n"
    let s3 = s2 + "<page>\n<title>Wikipedia:Policy</title>\n<ns>4</ns>\n<revision>\n<text>This is a policy page with [[link]].</text>\n</revision>\n</page>\n"
    let s4 = s3 + "<page>\n<title>Hello</title>\n<ns>0</ns>\n<revision>\n<text>Second article [[link|alias]] here.</text>\n</revision>\n</page>\n"
    let s5 = s4 + "<page>\n<title>Empty</title>\n<ns>0</ns>\n<revision>\n<text></text>\n</revision>\n</page>\n"
    let s6 = s5 + "</mediawiki>\n"
    return s6
}

fn run_mock_extract() -> int {
    exec("mkdir -p '" + TMP_DIR + "'")
    write_file(MOCK_XML, mock_xml())
    let prog_path = TMP_DIR + "/_mock_kowiki.awk"
    write_file(prog_path, awk_program())
    let cmd = build_pipeline(MOCK_XML, MOCK_OUT, "cat", prog_path)
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + MOCK_OUT + "' 2>/dev/null").trim()
    if wc == "" { return -1 }
    return to_int(wc)
}

// =====================================================================
// T1 — mock XML 1-page parse: Hangul text survives decode + strip
// =====================================================================

fn check_T1_mock_parse() -> bool {
    let lines_written = run_mock_extract()
    // Expected: 2 ns=0 non-empty articles (안녕, Hello). Empty text skipped.
    let ok_count = lines_written == 2
    let content = read_file(MOCK_OUT)
    let ok_hangul = content.contains("한국어 위키")
    let ok_hello = content.contains("Second article")
    let mut ok = false
    if ok_count {
        if ok_hangul {
            if ok_hello {
                ok = true
            }
        }
    }
    println("  [T1] mock extract: lines=" + str(lines_written) + " hangul=" + str(ok_hangul) + " hello=" + str(ok_hello))
    return ok
}

// =====================================================================
// T2 — markup stripping: [[link|alias]] -> alias, {{template}} removed
// =====================================================================

fn check_T2_markup_strip() -> bool {
    let content = read_file(MOCK_OUT)
    // After strip: "Second article alias here." present (not "[[link|alias]]")
    let ok_alias = content.contains("Second article alias here.")
    let ok_no_brackets = content.contains("[[") == false
    let ok_no_templ = content.contains("{{") == false
    // Link-only [[링크]] -> 링크
    let ok_plain_link = content.contains("링크를")
    let mut ok = false
    if ok_alias {
        if ok_no_brackets {
            if ok_no_templ {
                if ok_plain_link {
                    ok = true
                }
            }
        }
    }
    println("  [T2] markup: alias=" + str(ok_alias) + " no_brackets=" + str(ok_no_brackets) + " no_templ=" + str(ok_no_templ) + " plain_link=" + str(ok_plain_link))
    return ok
}

// =====================================================================
// T3 — namespace filter: Wikipedia: prefix skipped (ns=4)
// =====================================================================

fn check_T3_namespace_filter() -> bool {
    let content = read_file(MOCK_OUT)
    let ok = content.contains("policy page") == false
    println("  [T3] ns filter: policy-page-absent=" + str(ok))
    return ok
}

// =====================================================================
// T4 — empty <text></text> skipped
// =====================================================================

fn check_T4_empty_skip() -> bool {
    // "Empty" page's article has empty <text></text>. Mock output should
    // have exactly 2 lines (안녕 + Hello), not 3.
    let wc = exec("wc -l < '" + MOCK_OUT + "' 2>/dev/null").trim()
    let n = to_int(wc)
    let ok = n == 2
    println("  [T4] empty_skip: lines=" + str(n) + " (expect 2)")
    return ok
}

// =====================================================================
// T5 — latency: 10MB mock repeat under 5s
// =====================================================================

fn check_T5_latency() -> bool {
    exec("mkdir -p '" + TMP_DIR + "'")
    // Build ~10MB input by repeating the small mock ~4000x (single mock ~2.5KB)
    let mock = mock_xml()
    // Use a shell-side expansion for bulk to avoid hexa O(n²) string concat
    write_file(TMP_DIR + "/_one.xml", mock)
    let _r0 = exec("for i in $(seq 1 4000); do cat '" + TMP_DIR + "/_one.xml'; done > '" + TMP_DIR + "/_big.xml'")
    let sz = exec("wc -c < '" + TMP_DIR + "/_big.xml'").trim()
    let prog_path = TMP_DIR + "/_big_kowiki.awk"
    write_file(prog_path, awk_program())
    let big_out = TMP_DIR + "/_big_out.txt"
    // Compute elapsed time shell-side (hexa int is 32-bit, unix epoch overflows;
    // to_int("0") also returns void in current stage0 — avoid both)
    let t_start = exec("date +%s").trim()
    let cmd = build_pipeline(TMP_DIR + "/_big.xml", big_out, "cat", prog_path)
    let _r = exec(cmd)
    // Shell-side: compute dt and emit "OK" if <5s, "SLOW" otherwise.
    // Stage0 quirk: substring on small exec outputs can crash; use contains().
    let verdict = exec("dt=$(( $(date +%s) - " + t_start + " )); if [ $dt -lt 5 ]; then echo LAT_OK_$dt; else echo LAT_SLOW_$dt; fi").trim()
    let wc_big = exec("wc -l < '" + big_out + "'").trim()
    let ok = verdict.contains("LAT_OK")
    println("  [T5] latency: size=" + sz + " lines=" + wc_big + " verdict=" + verdict)
    return ok
}

// =====================================================================
// Main
// =====================================================================

fn test() {
    println("[training/corpus_kowiki_extract] CLM 7B kowiki XML -> plain text")
    println("  input:    " + INPUT_PATH)
    println("  output:   " + OUTPUT_PATH)
    println("  min_len:  " + str(MIN_TEXT_LEN))
    println("")

    let t1 = check_T1_mock_parse()
    if t1 { println("T1 PASS - mock XML parses + hangul survives") } else { println("T1 FAIL") }

    let t2 = check_T2_markup_strip()
    if t2 { println("T2 PASS - markup stripped (links/templates)") } else { println("T2 FAIL") }

    let t3 = check_T3_namespace_filter()
    if t3 { println("T3 PASS - namespace filter (Wikipedia: skipped)") } else { println("T3 FAIL") }

    let t4 = check_T4_empty_skip()
    if t4 { println("T4 PASS - empty <text> skipped") } else { println("T4 FAIL") }

    let t5 = check_T5_latency()
    if t5 { println("T5 PASS - 10MB mock < 5s") } else { println("T5 FAIL") }

    println("")
    // Stage0 quirk: `let mut pc = 0; pc = pc + 1` produces void in current hexa.
    // Use list-length accumulator instead (verified working 2026-04-17).
    let mut passes: [int] = []
    if t1 { passes = passes.push(1) }
    if t2 { passes = passes.push(1) }
    if t3 { passes = passes.push(1) }
    if t4 { passes = passes.push(1) }
    if t5 { passes = passes.push(1) }
    let pass_count = len(passes)

    if pass_count == 5 {
        println("[training/corpus_kowiki_extract] 5/5 PASS - ready for real extraction")
        println("")
        println("Real extraction:")
        println("  hexa run training/corpus_kowiki_extract.hexa --extract")
        println("  (will invoke bzcat on " + INPUT_PATH + " -> " + OUTPUT_PATH + ")")
    } else {
        println("[training/corpus_kowiki_extract] " + str(pass_count) + "/5 PASS - SOME FAILED")
    }
}

test()
