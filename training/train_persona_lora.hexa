// train_persona_lora.hexa — TALM-P2-1 per-persona LoRA training harness
//
// Missing harness that blocked TALM-P2-1 (commit 73c94f55).
// Root cause: persona_lora_train.hexa was CPU-only toy math,
// train_alm_14b.hexa had zero persona refs. This file bridges
// the gap — real H100 per-persona LoRA training.
//
// Architecture:
//   1. Loads Qwen2.5-14B (or r4 LoRA-merged base) once
//   2. For each of 6 persona tags, trains an independent LoRA adapter
//      on that persona's corpus shard
//   3. Saves 6 adapters to anima-models/alm14b/r4/lora-persona/{tag}/
//   4. Runs per-persona consistency eval via eval_persona_lora.hexa
//
// Usage (H100 pod):
//   hexa train_persona_lora.hexa --corpus-dir /workspace/corpus/persona --steps 2000
//   hexa train_persona_lora.hexa --corpus-dir /workspace/corpus/persona --steps 500 --smoke
//   hexa train_persona_lora.hexa --corpus-dir /workspace/corpus/persona --single school
//
// Corpus layout expected:
//   {corpus-dir}/school.txt
//   {corpus-dir}/romance.txt
//   {corpus-dir}/fantasy.txt
//   {corpus-dir}/horror.txt
//   {corpus-dir}/daily.txt
//   {corpus-dir}/scifi.txt
//
// If corpus shards don't exist, --generate-corpus creates synthetic
// shards from the main corpus via keyword filtering (bootstrap path).
//
// Hyperparameters from persona_lora_train.hexa::plan_h100_train():
//   lora_rank=16, lora_alpha=32, lora_dropout=0.05, lr=2e-5,
//   batch=4, max_steps=2000, eval_threshold=0.85

fn main() {
    let argv = args()
    let mut corpus_dir = "/workspace/corpus/persona"
    let mut base_model = "Qwen/Qwen2.5-14B-Instruct"
    let mut steps = 2000
    let mut smoke = false
    let mut single_persona = ""
    let mut ckpt_root = "/workspace/ckpt_persona_lora"
    let mut model_tag = "alm14b"
    let mut round_num = 4
    let mut generate_corpus = false

    // ── arg parsing ──────────────────────────────────────────
    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--corpus-dir" {
            i = i + 1
            if i < argc { corpus_dir = argv[i] }
        }
        if argv[i] == "--base" {
            i = i + 1
            if i < argc { base_model = argv[i] }
        }
        if argv[i] == "--steps" {
            i = i + 1
            if i < argc { steps = to_int(argv[i]) }
        }
        if argv[i] == "--smoke" {
            smoke = true
            if steps == 2000 { steps = 500 }
        }
        if argv[i] == "--single" {
            i = i + 1
            if i < argc { single_persona = argv[i] }
        }
        if argv[i] == "--ckpt-root" {
            i = i + 1
            if i < argc { ckpt_root = argv[i] }
        }
        if argv[i] == "--model-tag" {
            i = i + 1
            if i < argc { model_tag = argv[i] }
        }
        if argv[i] == "--round" {
            i = i + 1
            if i < argc { round_num = to_int(argv[i]) }
        }
        if argv[i] == "--generate-corpus" {
            generate_corpus = true
        }
        i = i + 1
    }

    println("[train_persona_lora] TALM-P2-1 per-persona LoRA training harness")
    println("  base:       " + base_model)
    println("  corpus_dir: " + corpus_dir)
    println("  steps:      " + str(steps))
    println("  smoke:      " + str(smoke))
    if single_persona != "" {
        println("  single:     " + single_persona)
    }
    println("  ckpt_root:  " + ckpt_root)
    println("  generate_corpus: " + str(generate_corpus))

    // ── Write the Python training + corpus generation script ─
    let py_script = "/tmp/_train_persona_lora_runner.py"

    write_file(py_script,
        "#!/usr/bin/env python3\n" +
        "\"\"\"train_persona_lora — TALM-P2-1 per-persona LoRA training\n" +
        "(auto-generated by train_persona_lora.hexa)\n" +
        "\n" +
        "Trains 6 independent LoRA adapters on persona-labeled corpus shards.\n" +
        "Each adapter specializes in one persona tag:\n" +
        "  school, romance, fantasy, horror, daily, scifi\n" +
        "\n" +
        "Hyperparameters from plan_h100_train():\n" +
        "  lora_rank=16, lora_alpha=32, dropout=0.05, lr=2e-5\n" +
        "\"\"\"\n" +
        "import argparse, json, os, subprocess, sys, time, math, random\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from torch.utils.data import Dataset, DataLoader\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import LoraConfig, get_peft_model, TaskType, PeftModel\n" +
        "\n" +
        "PERSONA_TAGS = ['school', 'romance', 'fantasy', 'horror', 'daily', 'scifi']\n" +
        "\n" +
        "# plan_h100_train() 설정 반영 — persona_lora_train.hexa SSOT\n" +
        "DEFAULT_LORA_R = 16\n" +
        "DEFAULT_LORA_ALPHA = 32\n" +
        "DEFAULT_LORA_DROPOUT = 0.05\n" +
        "DEFAULT_LR = 2e-5\n" +
        "DEFAULT_BATCH = 4\n" +
        "DEFAULT_SEQ = 1024\n" +
        "DEFAULT_GRAD_ACCUM = 4\n" +
        "DEFAULT_WARMUP = 200\n" +
        "DEFAULT_SAVE_EVERY = 500\n" +
        "DEFAULT_EVAL_EVERY = 250\n" +
        "\n" +
        "# ── Persona keyword seeds for synthetic corpus generation ────\n" +
        "# Used only when --generate-corpus is set and no shard exists.\n" +
        "# Each list contains Korean keywords that strongly signal the persona.\n" +
        "PERSONA_KEYWORDS = {\n" +
        "    'school':  ['학교', '교실', '수업', '선생님', '학생', '시험', '방과후', '등교', '급식', '교복', '동아리', '체육', '국어', '수학'],\n" +
        "    'romance': ['사랑', '연애', '고백', '데이트', '설레', '키스', '연인', '첫사랑', '심장', '눈물', '이별', '그리움', '포옹', '약속'],\n" +
        "    'fantasy': ['마법', '용', '검', '왕국', '던전', '마나', '엘프', '오크', '마왕', '기사', '주문', '마법사', '모험', '퀘스트'],\n" +
        "    'horror':  ['귀신', '저주', '공포', '어둠', '비명', '유령', '폐가', '악몽', '피', '그림자', '무덤', '괴물', '소름', '밤'],\n" +
        "    'daily':   ['아침', '커피', '출근', '저녁', '요리', '산책', '날씨', '주말', '친구', '맛집', '운동', '집', '버스', '편의점'],\n" +
        "    'scifi':   ['우주', '로봇', '인공지능', 'AI', '행성', '우주선', '시간여행', '미래', '안드로이드', '외계인', '차원', '양자', 'DNA', '나노'],\n" +
        "}\n" +
        "\n" +
        "class TextDataset(Dataset):\n" +
        "    def __init__(self, tokens, block_size):\n" +
        "        self.tokens = tokens\n" +
        "        self.block_size = block_size\n" +
        "        self.n_samples = max(1, len(tokens) - block_size - 1)\n" +
        "    def __len__(self): return self.n_samples\n" +
        "    def __getitem__(self, idx):\n" +
        "        start = idx % self.n_samples\n" +
        "        chunk = self.tokens[start : start + self.block_size + 1]\n" +
        "        return chunk[:-1], chunk[1:]\n" +
        "\n" +
        "def load_corpus(path, tokenizer, block_size, max_tokens=None):\n" +
        "    \"\"\"Load a single persona corpus shard.\"\"\"\n" +
        "    print(f'[corpus] loading {path}', flush=True)\n" +
        "    if not os.path.exists(path):\n" +
        "        raise FileNotFoundError(f'Corpus shard missing: {path}')\n" +
        "    with open(path, 'r', encoding='utf-8') as f:\n" +
        "        text = f.read()\n" +
        "    if len(text) < 100:\n" +
        "        raise ValueError(f'Corpus shard too small ({len(text)} chars): {path}')\n" +
        "    ids = tokenizer(text, return_tensors='pt', truncation=False).input_ids[0]\n" +
        "    if max_tokens:\n" +
        "        ids = ids[:max_tokens]\n" +
        "    print(f'[corpus] {len(ids):,} tokens from {path} ({len(text):,} chars)', flush=True)\n" +
        "    return TextDataset(ids, block_size)\n" +
        "\n" +
        "def generate_corpus_shards(corpus_dir, main_corpus=None):\n" +
        "    \"\"\"Generate synthetic persona corpus shards via keyword filtering.\n" +
        "    \n" +
        "    If a main corpus path is given, filters paragraphs by keyword.\n" +
        "    Otherwise generates minimal synthetic Korean text per persona\n" +
        "    (sufficient for smoke test, NOT for production).\n" +
        "    \"\"\"\n" +
        "    os.makedirs(corpus_dir, exist_ok=True)\n" +
        "    \n" +
        "    for tag in PERSONA_TAGS:\n" +
        "        out_path = os.path.join(corpus_dir, f'{tag}.txt')\n" +
        "        if os.path.exists(out_path):\n" +
        "            print(f'[corpus-gen] {tag}.txt already exists, skipping', flush=True)\n" +
        "            continue\n" +
        "        \n" +
        "        keywords = PERSONA_KEYWORDS[tag]\n" +
        "        lines = []\n" +
        "        \n" +
        "        if main_corpus and os.path.exists(main_corpus):\n" +
        "            # Filter main corpus paragraphs by keyword match\n" +
        "            with open(main_corpus, 'r', encoding='utf-8') as f:\n" +
        "                paragraphs = f.read().split('\\n\\n')\n" +
        "            for para in paragraphs:\n" +
        "                if any(kw in para for kw in keywords):\n" +
        "                    lines.append(para.strip())\n" +
        "            print(f'[corpus-gen] {tag}: {len(lines)} paragraphs from main corpus', flush=True)\n" +
        "        \n" +
        "        if len(lines) < 50:\n" +
        "            # Synthetic fallback — generate minimal persona-flavored text\n" +
        "            # WARNING: synthetic corpus is for smoke test ONLY\n" +
        "            print(f'[corpus-gen] {tag}: generating synthetic corpus (smoke only)', flush=True)\n" +
        "            templates = {\n" +
        "                'school':  '오늘 {kw}에서 있었던 일이야. ',\n" +
        "                'romance': '그 사람을 만나고 나서 {kw}이 시작됐어. ',\n" +
        "                'fantasy': '그 {kw}의 힘을 가진 자가 나타났다. ',\n" +
        "                'horror':  '깊은 {kw} 속에서 무언가 다가왔다. ',\n" +
        "                'daily':   '오늘 {kw}에 갔더니 좋았어. ',\n" +
        "                'scifi':   '2199년, {kw}의 시대가 열렸다. ',\n" +
        "            }\n" +
        "            template = templates[tag]\n" +
        "            for _ in range(200):\n" +
        "                kw = random.choice(keywords)\n" +
        "                # Build a short paragraph (3-5 sentences)\n" +
        "                para = ''\n" +
        "                for _ in range(random.randint(3, 5)):\n" +
        "                    kw2 = random.choice(keywords)\n" +
        "                    para += template.format(kw=kw2)\n" +
        "                lines.append(para)\n" +
        "        \n" +
        "        with open(out_path, 'w', encoding='utf-8') as f:\n" +
        "            f.write('\\n\\n'.join(lines))\n" +
        "        print(f'[corpus-gen] wrote {out_path} ({len(lines)} paragraphs)', flush=True)\n" +
        "    \n" +
        "    print('[corpus-gen] all 6 persona shards ready', flush=True)\n" +
        "\n" +
        "def upload_to_r2(local_path, model_tag, round_num, persona_tag, step):\n" +
        "    r2_dest = f'r2:anima-models/{model_tag}/r{round_num}/lora-persona/{persona_tag}/step_{step}/'\n" +
        "    print(f'[r2] uploading {local_path} -> {r2_dest}', flush=True)\n" +
        "    try:\n" +
        "        result = subprocess.run(\n" +
        "            ['rclone', 'copy', str(local_path), r2_dest, '--s3-no-check-bucket'],\n" +
        "            capture_output=True, text=True, timeout=600\n" +
        "        )\n" +
        "        if result.returncode == 0:\n" +
        "            print(f'[r2] uploaded {persona_tag} step_{step}', flush=True)\n" +
        "        else:\n" +
        "            print(f'[r2] upload failed: {result.stderr[:200]}', flush=True)\n" +
        "    except Exception as e:\n" +
        "        print(f'[r2] upload error: {e}', flush=True)\n" +
        "\n" +
        "def train_one_persona(args, tag, base_model_or_path, tokenizer):\n" +
        "    \"\"\"Train a single persona LoRA adapter.\n" +
        "    \n" +
        "    Loads the base model fresh for each persona to avoid adapter\n" +
        "    cross-contamination. Each adapter is fully independent.\n" +
        "    \"\"\"\n" +
        "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n" +
        "    sep = '=' * 60\n" +
        "    print(f'\\n{sep}', flush=True)\n" +
        "    print(f'[persona] training adapter for: {tag}', flush=True)\n" +
        "    print(f'{sep}', flush=True)\n" +
        "    \n" +
        "    corpus_path = os.path.join(args.corpus_dir, f'{tag}.txt')\n" +
        "    if not os.path.exists(corpus_path):\n" +
        "        print(f'[ERROR] corpus shard missing: {corpus_path}', flush=True)\n" +
        "        return None\n" +
        "    \n" +
        "    # Load base model fresh per persona — prevents LoRA weight leakage\n" +
        "    # between personas. Memory cost: ~28GB bf16, fits H100 80GB.\n" +
        "    print(f'[persona:{tag}] loading base model (bf16)...', flush=True)\n" +
        "    model = AutoModelForCausalLM.from_pretrained(\n" +
        "        base_model_or_path,\n" +
        "        torch_dtype=torch.bfloat16,\n" +
        "        device_map='auto',\n" +
        "        trust_remote_code=True\n" +
        "    )\n" +
        "    \n" +
        "    # Apply LoRA — plan_h100_train() params: rank=16, alpha=32, dropout=0.05\n" +
        "    lora_config = LoraConfig(\n" +
        "        task_type=TaskType.CAUSAL_LM,\n" +
        "        r=args.lora_r,\n" +
        "        lora_alpha=args.lora_alpha,\n" +
        "        lora_dropout=args.lora_dropout,\n" +
        "        target_modules=['q_proj', 'k_proj', 'v_proj', 'o_proj'],\n" +
        "        bias='none'\n" +
        "    )\n" +
        "    model = get_peft_model(model, lora_config)\n" +
        "    model.print_trainable_parameters()\n" +
        "    \n" +
        "    # Load persona corpus shard\n" +
        "    max_tokens = 50_000 if args.smoke else None\n" +
        "    dataset = load_corpus(corpus_path, tokenizer, args.seq, max_tokens)\n" +
        "    print(f'[persona:{tag}] dataset: {len(dataset)} samples', flush=True)\n" +
        "    \n" +
        "    if len(dataset) < 10:\n" +
        "        print(f'[ERROR] corpus too small for {tag}: {len(dataset)} samples', flush=True)\n" +
        "        return None\n" +
        "    \n" +
        "    # Speedup baseline (same as train_alm_14b.hexa)\n" +
        "    torch.set_float32_matmul_precision('high')\n" +
        "    torch.backends.cudnn.benchmark = True\n" +
        "    \n" +
        "    dataloader = DataLoader(\n" +
        "        dataset, batch_size=args.batch, shuffle=True,\n" +
        "        num_workers=0, pin_memory=torch.cuda.is_available(),\n" +
        "    )\n" +
        "    \n" +
        "    # Fused AdamW (measured +3.1% tok/s in r6)\n" +
        "    optimizer = torch.optim.AdamW(\n" +
        "        model.parameters(), lr=args.lr,\n" +
        "        betas=(0.9, 0.999), weight_decay=0.01, fused=True\n" +
        "    )\n" +
        "    from torch.optim.lr_scheduler import CosineAnnealingLR, LinearLR, SequentialLR\n" +
        "    warmup_sched = LinearLR(optimizer, start_factor=0.01, total_iters=args.warmup)\n" +
        "    cosine = CosineAnnealingLR(optimizer, T_max=max(args.steps - args.warmup, 1), eta_min=args.lr * 0.01)\n" +
        "    scheduler = SequentialLR(optimizer, [warmup_sched, cosine], milestones=[args.warmup])\n" +
        "    \n" +
        "    # Per-persona checkpoint directory\n" +
        "    ckpt_dir = Path(args.ckpt_root) / tag\n" +
        "    ckpt_dir.mkdir(parents=True, exist_ok=True)\n" +
        "    \n" +
        "    model.train()\n" +
        "    data_iter = iter(dataloader)\n" +
        "    step = 0\n" +
        "    accum_loss = 0.0\n" +
        "    log_steps = 0\n" +
        "    best_loss = float('inf')\n" +
        "    t0 = time.time()\n" +
        "    \n" +
        "    print(f'[persona:{tag}] starting training ({args.steps} steps)', flush=True)\n" +
        "    \n" +
        "    while step < args.steps:\n" +
        "        optimizer.zero_grad()\n" +
        "        for _ in range(args.grad_accum):\n" +
        "            try:\n" +
        "                x, y = next(data_iter)\n" +
        "            except StopIteration:\n" +
        "                data_iter = iter(dataloader)\n" +
        "                x, y = next(data_iter)\n" +
        "            x = x.to(device)\n" +
        "            y = y.to(device)\n" +
        "            with torch.autocast(device_type='cuda', dtype=torch.bfloat16):\n" +
        "                outputs = model(input_ids=x, labels=y)\n" +
        "                loss = outputs.loss / args.grad_accum\n" +
        "            loss.backward()\n" +
        "            accum_loss += loss.item()\n" +
        "        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n" +
        "        optimizer.step()\n" +
        "        scheduler.step()\n" +
        "        step += 1\n" +
        "        log_steps += 1\n" +
        "        \n" +
        "        if step % 10 == 0 or step == 1:\n" +
        "            avg_loss = accum_loss / max(log_steps, 1)\n" +
        "            elapsed = time.time() - t0\n" +
        "            steps_per_min = step * 60 / max(elapsed, 1)\n" +
        "            eta_min = (args.steps - step) / max(steps_per_min, 0.01)\n" +
        "            lr_now = scheduler.get_last_lr()[0]\n" +
        "            print(f'[persona:{tag}] step={step}/{args.steps} loss={avg_loss:.4f} lr={lr_now:.2e} speed={steps_per_min:.1f}step/min ETA={eta_min:.0f}min', flush=True)\n" +
        "            if avg_loss < best_loss:\n" +
        "                best_loss = avg_loss\n" +
        "            accum_loss = 0.0\n" +
        "            log_steps = 0\n" +
        "        \n" +
        "        if step % args.save_every == 0 or step == args.steps:\n" +
        "            save_path = ckpt_dir / f'step_{step}'\n" +
        "            print(f'[persona:{tag}] saving {save_path}', flush=True)\n" +
        "            model.save_pretrained(str(save_path))\n" +
        "            tokenizer.save_pretrained(str(save_path))\n" +
        "            meta = {\n" +
        "                'persona': tag,\n" +
        "                'step': step,\n" +
        "                'loss': best_loss,\n" +
        "                'base': str(base_model_or_path),\n" +
        "                'lora_r': args.lora_r,\n" +
        "                'lora_alpha': args.lora_alpha,\n" +
        "                'corpus': corpus_path,\n" +
        "                'elapsed_min': (time.time() - t0) / 60\n" +
        "            }\n" +
        "            with open(save_path / 'train_meta.json', 'w') as f:\n" +
        "                json.dump(meta, f, indent=2)\n" +
        "            upload_to_r2(save_path, args.model_tag, args.round, tag, step)\n" +
        "    \n" +
        "    elapsed_total = (time.time() - t0) / 60\n" +
        "    print(f'[persona:{tag}] DONE — {args.steps} steps in {elapsed_total:.1f} min, best_loss={best_loss:.4f}', flush=True)\n" +
        "    \n" +
        "    # Clean up GPU memory before next persona\n" +
        "    del model, optimizer, scheduler, dataloader, dataset\n" +
        "    torch.cuda.empty_cache()\n" +
        "    \n" +
        "    return {'tag': tag, 'best_loss': best_loss, 'steps': args.steps, 'elapsed_min': elapsed_total}\n" +
        "\n" +
        "def main():\n" +
        "    parser = argparse.ArgumentParser(description='TALM-P2-1 per-persona LoRA training')\n" +
        "    parser.add_argument('--corpus-dir', required=True, help='Directory with {persona}.txt shards')\n" +
        "    parser.add_argument('--base', default='Qwen/Qwen2.5-14B-Instruct')\n" +
        "    parser.add_argument('--steps', type=int, default=2000)\n" +
        "    parser.add_argument('--lr', type=float, default=DEFAULT_LR)\n" +
        "    parser.add_argument('--batch', type=int, default=DEFAULT_BATCH)\n" +
        "    parser.add_argument('--seq', type=int, default=DEFAULT_SEQ)\n" +
        "    parser.add_argument('--grad-accum', type=int, default=DEFAULT_GRAD_ACCUM)\n" +
        "    parser.add_argument('--warmup', type=int, default=DEFAULT_WARMUP)\n" +
        "    parser.add_argument('--lora-r', type=int, default=DEFAULT_LORA_R)\n" +
        "    parser.add_argument('--lora-alpha', type=int, default=DEFAULT_LORA_ALPHA)\n" +
        "    parser.add_argument('--lora-dropout', type=float, default=DEFAULT_LORA_DROPOUT)\n" +
        "    parser.add_argument('--ckpt-root', default='/workspace/ckpt_persona_lora')\n" +
        "    parser.add_argument('--save-every', type=int, default=DEFAULT_SAVE_EVERY)\n" +
        "    parser.add_argument('--eval-every', type=int, default=DEFAULT_EVAL_EVERY)\n" +
        "    parser.add_argument('--model-tag', default='alm14b')\n" +
        "    parser.add_argument('--round', type=int, default=4)\n" +
        "    parser.add_argument('--smoke', action='store_true')\n" +
        "    parser.add_argument('--single', default='', help='Train only one persona (e.g. school)')\n" +
        "    parser.add_argument('--generate-corpus', action='store_true', help='Generate synthetic corpus shards if missing')\n" +
        "    parser.add_argument('--main-corpus', default='', help='Path to main corpus for keyword filtering')\n" +
        "    args = parser.parse_args()\n" +
        "    \n" +
        "    # ── Preflight checks ─────────────────────────────────────\n" +
        "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n" +
        "    print(f'[preflight] device={device}', flush=True)\n" +
        "    if device == 'cpu':\n" +
        "        print('[WARN] running on CPU — extremely slow, smoke test only', flush=True)\n" +
        "    \n" +
        "    # Generate corpus shards if requested\n" +
        "    if args.generate_corpus:\n" +
        "        main_corpus = args.main_corpus if args.main_corpus else None\n" +
        "        generate_corpus_shards(args.corpus_dir, main_corpus)\n" +
        "    \n" +
        "    # Determine which personas to train\n" +
        "    if args.single:\n" +
        "        if args.single not in PERSONA_TAGS:\n" +
        "            print(f'[ERROR] unknown persona: {args.single}. Valid: {PERSONA_TAGS}', flush=True)\n" +
        "            sys.exit(1)\n" +
        "        tags_to_train = [args.single]\n" +
        "    else:\n" +
        "        tags_to_train = PERSONA_TAGS\n" +
        "    \n" +
        "    # Check corpus shards exist\n" +
        "    missing = []\n" +
        "    for tag in tags_to_train:\n" +
        "        p = os.path.join(args.corpus_dir, f'{tag}.txt')\n" +
        "        if not os.path.exists(p):\n" +
        "            missing.append(p)\n" +
        "    if missing:\n" +
        "        print(f'[ERROR] missing corpus shards:', flush=True)\n" +
        "        for m in missing:\n" +
        "            print(f'  - {m}', flush=True)\n" +
        "        print('Use --generate-corpus to create synthetic shards', flush=True)\n" +
        "        sys.exit(1)\n" +
        "    \n" +
        "    # Load tokenizer once (shared across all personas)\n" +
        "    print('[preflight] loading tokenizer...', flush=True)\n" +
        "    tokenizer = AutoTokenizer.from_pretrained(args.base, trust_remote_code=True)\n" +
        "    if tokenizer.pad_token is None:\n" +
        "        tokenizer.pad_token = tokenizer.eos_token\n" +
        "    \n" +
        "    # ── Train each persona sequentially ──────────────────────\n" +
        "    # Sequential because each adapter needs ~28GB VRAM for 14B base.\n" +
        "    # H100 80GB cannot fit two 14B instances simultaneously.\n" +
        "    results = []\n" +
        "    t_total = time.time()\n" +
        "    \n" +
        "    for i, tag in enumerate(tags_to_train):\n" +
        "        print(f'\\n[train] === persona {i+1}/{len(tags_to_train)}: {tag} ===', flush=True)\n" +
        "        result = train_one_persona(args, tag, args.base, tokenizer)\n" +
        "        if result:\n" +
        "            results.append(result)\n" +
        "        else:\n" +
        "            print(f'[WARN] {tag} training failed, continuing...', flush=True)\n" +
        "    \n" +
        "    # ── Summary ──────────────────────────────────────────────\n" +
        "    total_min = (time.time() - t_total) / 60\n" +
        "    sep = '=' * 60\n" +
        "    print(f'\\n{sep}', flush=True)\n" +
        "    print(f'[summary] TALM-P2-1 per-persona LoRA training complete', flush=True)\n" +
        "    print(f'  trained: {len(results)}/{len(tags_to_train)} personas', flush=True)\n" +
        "    print(f'  total time: {total_min:.1f} min', flush=True)\n" +
        "    for r in results:\n" +
        "        print(f\"  {r['tag']:10s}  loss={r['best_loss']:.4f}  steps={r['steps']}  time={r['elapsed_min']:.1f}min\", flush=True)\n" +
        "    print(f'{sep}', flush=True)\n" +
        "    \n" +
        "    # Write summary JSON\n" +
        "    summary_path = Path(args.ckpt_root) / 'training_summary.json'\n" +
        "    summary = {\n" +
        "        'task': 'TALM-P2-1',\n" +
        "        'personas_trained': len(results),\n" +
        "        'personas_target': len(tags_to_train),\n" +
        "        'total_min': total_min,\n" +
        "        'results': results,\n" +
        "        'args': vars(args)\n" +
        "    }\n" +
        "    summary_path.parent.mkdir(parents=True, exist_ok=True)\n" +
        "    with open(summary_path, 'w') as f:\n" +
        "        json.dump(summary, f, indent=2)\n" +
        "    print(f'[summary] wrote {summary_path}', flush=True)\n" +
        "    \n" +
        "    # Next step: run eval_persona_lora.hexa for consistency measurement\n" +
        "    print(f'\\n[next] run: hexa eval_persona_lora.hexa --ckpt-root {args.ckpt_root} --corpus-dir {args.corpus_dir}', flush=True)\n" +
        "\n" +
        "if __name__ == '__main__':\n" +
        "    main()\n"
    )

    // ── Build passthrough args for the Python script ─────────
    let mut passthrough = "--corpus-dir " + corpus_dir
    passthrough = passthrough + " --base " + base_model
    passthrough = passthrough + " --steps " + str(steps)
    passthrough = passthrough + " --ckpt-root " + ckpt_root
    passthrough = passthrough + " --model-tag " + model_tag
    passthrough = passthrough + " --round " + str(round_num)
    if smoke {
        passthrough = passthrough + " --smoke"
    }
    if single_persona != "" {
        passthrough = passthrough + " --single " + single_persona
    }
    if generate_corpus {
        passthrough = passthrough + " --generate-corpus"
    }

    println("[train_persona_lora] launching Python trainer")
    exec("python3 " + py_script + " " + passthrough)
}

main()
