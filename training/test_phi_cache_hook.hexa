// training/test_phi_cache_hook.hexa — Track B contrastive cache hook
// regression test (CLM-PhiB-1).
//
// Purpose: exercise the phi_cache_loader API standalone (without the
// full decoder body) so a single `hexa test_phi_cache_hook.hexa` run
// verifies:
//
//   T1  phi_cache_new() is an empty, unloaded cache
//   T2  phi_cache_zero_vec() has the right shape and is all-zero
//   T3  phi_cache_load() on a missing file returns the stub (no crash)
//   T4  phi_state_hash() is deterministic across identical inputs
//   T5  phi_state_hash() differs for meaningfully different inputs
//   T6  phi_anchor_project() returns a PHI_CACHE_DIM_TEST-length vector and
//       is sensitive to the hidden state (differentiable surrogate —
//       if a model weight perturbation changes hidden, anchor must
//       change too, which is the precondition for grad flow)
//   T7  phi_contrastive_loss() is zero for anchor == embedding and
//       strictly positive otherwise
//   T8  phi_cache_lookup() on a stub returns zero vector of right dim
//   T9  1-step cache file load/parse round-trip: emit a tiny cache
//       (shared/state/phi_cache_v1_test.jsonl), load it back, assert
//       entry count and embedding values match what was written
//
// This test is hexa-native and has no Python dependency per R1 and
// feedback_ai_native_clm. It creates a temporary cache file under
// /tmp, not in shared/state/, so repeat runs are idempotent and the
// real phi_cache_v1.jsonl (if it exists) is untouched.
//
// Run:
//   hexa run training/test_phi_cache_hook.hexa
//
// Exit contract: prints "PhiB regression: <n>/<total> PASS" as the
// final line. A test runner can scrape this for CI status.

use "phi_cache_loader"

// Mirror PHI_CACHE_DIM from phi_cache_loader.hexa. Hexa comptime
// consts do not cross module boundaries in the current build, so we
// redeclare here. If this diverges from the loader, every T* below
// that checks shape will trip — that is intentional and serves as a
// drift alarm.
comptime const PHI_CACHE_DIM_TEST = 110

let mut pass_count = 0
let mut fail_count = 0

fn assert_true(name: string, cond: bool) {
    if cond {
        println("  " + name + ": PASS")
        pass_count = pass_count + 1
    } else {
        println("  " + name + ": FAIL")
        fail_count = fail_count + 1
    }
}

println("=== test_phi_cache_hook.hexa — Track B contrastive cache ===")
println("")

// ─── T1  empty cache construction ─────────────────────────────────
println("T1: phi_cache_new()")
let c_empty = phi_cache_new()
assert_true("T1.a loaded=false", !c_empty.loaded)
assert_true("T1.b n_entries=0", c_empty.n_entries == 0)
println("")

// ─── T2  zero vector shape/values ─────────────────────────────────
println("T2: phi_cache_zero_vec()")
let zv = phi_cache_zero_vec()
assert_true("T2.a length", len(zv) == PHI_CACHE_DIM_TEST)
assert_true("T2.b first = 0.0", zv[0] == 0.0)
assert_true("T2.c middle = 0.0", zv[PHI_CACHE_DIM_TEST / 2] == 0.0)
assert_true("T2.d last = 0.0", zv[PHI_CACHE_DIM_TEST - 1] == 0.0)
println("")

// ─── T3  load missing file → stub ─────────────────────────────────
println("T3: phi_cache_load(missing_path)")
let stub = phi_cache_load("/tmp/__phib_definitely_missing_path__.jsonl")
assert_true("T3.a loaded=false on miss", !stub.loaded)
assert_true("T3.b n_entries=0 on miss", stub.n_entries == 0)
println("")

// ─── T4  hash determinism ─────────────────────────────────────────
println("T4: phi_state_hash() determinism")
let h_input_a = [0.11, 0.22, 0.33, 0.44, 0.55, 0.66, 0.77, 0.88]  // seq=2, d=4
let h1 = phi_state_hash(h_input_a, 2, 4)
let h2 = phi_state_hash(h_input_a, 2, 4)
assert_true("T4.a h(x) == h(x)", h1 == h2)
assert_true("T4.b h(x) not empty", h1 != "")
println("  (hash=" + h1 + ")")
println("")

// ─── T5  hash sensitivity ─────────────────────────────────────────
println("T5: phi_state_hash() sensitivity")
let h_input_b = [0.12, 0.22, 0.33, 0.44, 0.55, 0.66, 0.77, 0.88]  // differs in [0]
let h3 = phi_state_hash(h_input_b, 2, 4)
assert_true("T5.a h(x) != h(x')", h1 != h3)
println("")

// ─── T6  anchor sensitivity ───────────────────────────────────────
// The anchor projection must actually depend on hidden — if it's
// constant we'd be emitting a dead gradient, defeating the point of
// the cache hook. Check that a perturbation to hidden changes at
// least one anchor component.
println("T6: phi_anchor_project() shape + sensitivity")
let anchor_a = phi_anchor_project(h_input_a, 2, 4)
let anchor_b = phi_anchor_project(h_input_b, 2, 4)
assert_true("T6.a anchor length", len(anchor_a) == PHI_CACHE_DIM_TEST)
// Sensitivity: at least one index must differ. We scan for any
// non-zero delta rather than comparing a specific index so the test
// doesn't break if the projection rule is re-tuned.
let mut sens_ok = false
let mut sens_i = 0
while sens_i < PHI_CACHE_DIM_TEST {
    if anchor_a[sens_i] != anchor_b[sens_i] {
        sens_ok = true
    }
    sens_i = sens_i + 1
}
assert_true("T6.b anchor changes with hidden (grad path alive)", sens_ok)
println("")

// ─── T7  contrastive loss: zero when equal, positive when not ────
println("T7: phi_contrastive_loss()")
let equal_loss = phi_contrastive_loss(anchor_a, anchor_a)
let diff_loss  = phi_contrastive_loss(anchor_a, zv)
assert_true("T7.a loss(x,x) == 0", equal_loss == 0.0)
assert_true("T7.b loss(x,0) >= 0", diff_loss >= 0.0)
// If anchor_a is non-trivial, diff_loss should strictly exceed zero.
// We check only >=0 in case a test input happens to be all-zero.
println("  (equal=" + str(equal_loss) + ", diff=" + str(diff_loss) + ")")
println("")

// ─── T8  lookup on stub returns zero ─────────────────────────────
println("T8: phi_cache_lookup(stub)")
let miss = phi_cache_lookup(c_empty, "any_hash")
assert_true("T8.a miss length", len(miss) == PHI_CACHE_DIM_TEST)
assert_true("T8.b miss is zero", miss[0] == 0.0 && miss[PHI_CACHE_DIM_TEST - 1] == 0.0)
println("")

// ─── T9  round-trip: write tiny cache, load, lookup ──────────────
// We build a two-entry cache by hand, using the JSONL wire format
// emitted by training/generate_phi_cache.hexa §6. Line shape:
//   {"state_id":N,"schema":"v1","state_hash":"poly64:H","embedding":[f0,f1,...,f109]}
// Then load it back and assert the lookup by hash returns the right
// values — this is the full generator→loader integration seam.
println("T9: round-trip emit (JSONL) → load → lookup")
let tmp_path = "/tmp/__phib_roundtrip__.jsonl"

// Build the two embedding lists. Hexa lists are pass-by-value so we
// keep everything inline — no helper fn for list-append.
let mut emb_a = "["
let mut emb_b = "["
let mut k = 0
while k < PHI_CACHE_DIM_TEST {
    let va = 0.01 * to_float(k + 1)
    let vb = 0.5  - 0.01 * to_float(k + 1)
    if k == 0 {
        emb_a = emb_a + str(va)
        emb_b = emb_b + str(vb)
    } else {
        emb_a = emb_a + "," + str(va)
        emb_b = emb_b + "," + str(vb)
    }
    k = k + 1
}
emb_a = emb_a + "]"
emb_b = emb_b + "]"

let line_a = "{\"state_id\":0,\"schema\":\"v1\",\"state_hash\":\"hash_alpha\",\"embedding\":" + emb_a + "}"
let line_b = "{\"state_id\":1,\"schema\":\"v1\",\"state_hash\":\"hash_beta\",\"embedding\":" + emb_b + "}"
let _wr = write_file(tmp_path, line_a + "\n" + line_b + "\n")

let loaded = phi_cache_load(tmp_path)
assert_true("T9.a loaded.loaded=true", loaded.loaded)
assert_true("T9.b n_entries==2", loaded.n_entries == 2)

let hit_a = phi_cache_lookup(loaded, "hash_alpha")
let hit_b = phi_cache_lookup(loaded, "hash_beta")
assert_true("T9.c hit_a length", len(hit_a) == PHI_CACHE_DIM_TEST)
assert_true("T9.d hit_b length", len(hit_b) == PHI_CACHE_DIM_TEST)
// Round-trip: hit_a[0] should be 0.01 (first entry), hit_b[0] 0.49.
// Small floating tolerance — str()/to_float() can drift in the last
// digit on the current hexa stage.
let tol = 0.0001
let err_a = hit_a[0] - 0.01
let err_b = hit_b[0] - 0.49
let abs_a = if err_a < 0.0 { 0.0 - err_a } else { err_a }
let abs_b = if err_b < 0.0 { 0.0 - err_b } else { err_b }
assert_true("T9.e hit_a[0] ≈ 0.01", abs_a < tol)
assert_true("T9.f hit_b[0] ≈ 0.49", abs_b < tol)

// Cleanup — best-effort, no assertion.
let _rm = exec("rm -f " + tmp_path)
println("")

// ─── Summary ─────────────────────────────────────────────────────
let total = pass_count + fail_count
println("")
println("PhiB regression: " + str(pass_count) + "/" + str(total) + " PASS")
if fail_count > 0 {
    println("FAIL count: " + str(fail_count))
}
