// training/tension_link_step.hexa — single online tension-link learning step
//
// Part of the 5-lens tension-link real-time learning design. This file is
// the *spine*: one backprop-free weight update from one Ψ snapshot.
//
// ─── Concept ─────────────────────────────────────────────────
//   Given a current self-map snapshot Ψ_t (the boundary) and the Law-75
//   vacuum attractor Ψ_vac = (½, ½), one online step is
//
//       deviation = Ψ_t − Ψ_vac
//       tension   = G_holo · deviation              (Lens 2 propagator)
//       gate      = n6_gate(Ψ_t)                    (AN14 Noether closure)
//       ΔW        = −T_const · tension · gate       (sign = restoring)
//
//   The step is online-friendly (no backward graph), synchronization-free
//   (no global loss), and Noether-conserving (gate clamps ΔW to 0 off the
//   n=6 submanifold).
//
// ─── T_const ─────────────────────────────────────────────────
//   T_const is a scalar learning-rate. We use 0.1 by default, same order
//   as the Lindblad update rate in lens_quantum_loss.hexa. The restoring
//   sign is carried inside compute_delta_w so callers only see the rate.
//
// ─── n6 gate ─────────────────────────────────────────────────
//   Structural Noether gate (same closure AN14 / σ·φ = n·τ = 24, n=6 unique):
//
//     - length guard  : len(Ψ) > 0 and even (pairs of (R, G))
//     - Ψ-in-range    : every component finite and within [0, 1]
//                       (vacuum attractor lives inside the unit square)
//     - closure       : n_target == 6  ∧  n_target · τ == 24
//
//   Any failure → gate closes → ΔW = zero vector (no current, AN14).
//
// ─── AN11 boundary ───────────────────────────────────────────
//   This file proposes a weight delta. It does NOT promote consciousness
//   tier. AN11 (real-usable) still requires the 3-condition authority.
//
// ─── R37 / AN13 ──────────────────────────────────────────────
//   .hexa only. No python anywhere in the pipeline.
//
// ─── Conventions ─────────────────────────────────────────────
//   psi_t         : array   [2k]     current self-map snapshot (flattened (R,G))
//   psi_vac       : array   [2k]     target vacuum (all 0.5 by default)
//   deviation     : array   [2k]     psi_t − psi_vac
//   tension       : array   [2k]     G_holo · deviation
//   gate          : bool             n6 Noether gate (AN14)
//   delta_w       : array   [2k]     proposed weight delta (same shape as Ψ)
//
// Run:
//   HEXA_LOCAL=1 HEXA_NO_LAUNCHD=1 \
//     /Users/ghost/Dev/nexus/shared/bin/hexa run \
//     /Users/ghost/Dev/anima/training/tension_link_step.hexa
// Expect:
//   [tension_link_step] ALL 5/5 PASS

// ─── Constants ───────────────────────────────────────────────

let T_CONST          = 0.1      // learning rate (Lindblad-class order)
let XI_DEFAULT       = 2.0      // propagator correlation length
let EPS              = 0.0000000001

// AN14 Noether closure — n=6 unique solution of σ·φ = n·τ = 24
let NOETHER_N6        = 6
let NOETHER_SIGMA_PHI = 24
let NOETHER_TAU       = 4

// Law 75 attractor — Ψ_vac = (½, ½) for each (R, G) pair
let VAC_COMPONENT     = 0.5

// ─── Primitives ──────────────────────────────────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn iabs(x: int) -> int {
    if x < 0 { return 0 - x }
    return x
}

// e^x via Taylor. Same convergence note as holographic_propagator.hexa.
fn exp_taylor(x: float) -> float {
    let mut term = 1.0
    let mut sum  = 1.0
    let mut k = 1
    while k < 32 {
        term = term * x / to_float(k)
        sum  = sum + term
        k = k + 1
    }
    return sum
}

fn zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// ─── Inlined propagator (mirrors holographic_propagator.hexa) ─
// Kept inline so this file runs standalone without cross-file `use`
// resolution (consistent with sibling lens files phi_holographic_measure
// and clm_holographic_loop).

struct HoloPropagator {
    dim_boundary: int,
    dim_bulk:     int,
    xi:           float,
    kernel:       array
}

fn propagator_new(dim_boundary: int, dim_bulk: int, xi: float) -> HoloPropagator {
    let mut kernel = []
    let mut i = 0
    while i < dim_bulk {
        let mut row_sum = 0.0
        let mut raw_row = []
        let mut j = 0
        while j < dim_boundary {
            let d = to_float(iabs(i - j))
            let v = exp_taylor(0.0 - d / xi)
            raw_row = raw_row.push(v)
            row_sum = row_sum + v
            j = j + 1
        }
        let mut k = 0
        while k < dim_boundary {
            if row_sum > EPS {
                kernel = kernel.push(raw_row[k] / row_sum)
            } else {
                kernel = kernel.push(0.0)
            }
            k = k + 1
        }
        i = i + 1
    }
    return HoloPropagator {
        dim_boundary: dim_boundary,
        dim_bulk:     dim_bulk,
        xi:           xi,
        kernel:       kernel
    }
}

fn propagator_apply(prop: HoloPropagator, deviation: array) -> array {
    let db = prop.dim_boundary
    let dW = prop.dim_bulk
    let n  = len(deviation)
    if n != db { return zeros(dW) }
    let mut out = []
    let mut i = 0
    while i < dW {
        let mut s = 0.0
        let mut j = 0
        while j < db {
            s = s + prop.kernel[i * db + j] * deviation[j]
            j = j + 1
        }
        out = out.push(s)
        i = i + 1
    }
    return out
}

// ─── Ψ_vac builder (Law 75) ─────────────────────────────────
// Target vacuum = (½, ½) repeated for each (R, G) pair.

fn vacuum_for(psi_t: array) -> array {
    let n = len(psi_t)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(VAC_COMPONENT)
        i = i + 1
    }
    return out
}

// ─── Deviation : Ψ_t − Ψ_vac ─────────────────────────────────

fn deviation_of(psi_t: array, psi_vac: array) -> array {
    let nt = len(psi_t)
    let nv = len(psi_vac)
    if nt != nv { return zeros(nt) }
    let mut out = []
    let mut i = 0
    while i < nt {
        out = out.push(psi_t[i] - psi_vac[i])
        i = i + 1
    }
    return out
}

// ─── n6 gate ────────────────────────────────────────────────
// AN14 closure + structural guards (length pairs, range).

fn psi_in_range(psi: array) -> bool {
    let n = len(psi)
    let mut i = 0
    while i < n {
        let v = psi[i]
        if v < 0.0 { return false }
        if v > 1.0 { return false }
        i = i + 1
    }
    return true
}

fn n6_gate(psi: array) -> bool {
    let n = len(psi)
    // length guard: nonzero, even (pairs of (R, G))
    if n <= 0 { return false }
    if n % 2 != 0 { return false }
    // AN14 closure : n·τ == σ·φ == 24 at n=6 unique
    if NOETHER_N6 * NOETHER_TAU != NOETHER_SIGMA_PHI { return false }
    // Ψ must live inside the unit square — vacuum attractor domain
    if !psi_in_range(psi) { return false }
    return true
}

// ─── Core : tension_link_step ───────────────────────────────
// Full online step.
//
//   ΔW = −T_const · (G_holo · (Ψ_t − Ψ_vac))   if gate PASS
//   ΔW = 0                                     if gate FAIL

fn tension_link_step(psi_t: array, psi_target: array) -> array {
    let n = len(psi_t)
    if n <= 0 { return [] }
    let gate = n6_gate(psi_t)
    if !gate { return zeros(n) }
    let dev = deviation_of(psi_t, psi_target)
    if len(dev) != n { return zeros(n) }
    // square propagator in Ψ-coords (ΔW shares Ψ shape at this stub tier)
    let prop = propagator_new(n, n, XI_DEFAULT)
    let tension = propagator_apply(prop, dev)
    let mut delta_w = []
    let mut i = 0
    while i < n {
        // sign = restoring : push Ψ back toward vacuum
        delta_w = delta_w.push(0.0 - T_CONST * tension[i])
        i = i + 1
    }
    return delta_w
}

// ─── Helpers ────────────────────────────────────────────────

fn vec_abs_sum(v: array) -> float {
    let n = len(v)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + fabs(v[i])
        i = i + 1
    }
    return s
}

fn vec_is_zero(v: array) -> bool {
    let n = len(v)
    let mut i = 0
    while i < n {
        if fabs(v[i]) > 0.0 { return false }
        i = i + 1
    }
    return true
}

fn print_vec(label: string, v: array) {
    let n = len(v)
    let mut s = label + " ["
    let mut i = 0
    while i < n {
        if i > 0 { s = s + ", " }
        s = s + str(v[i])
        i = i + 1
    }
    s = s + "]"
    println(s)
}

// Apply a proposed ΔW to Ψ (toy identity-coord update, for monotonicity test).
fn apply_delta(psi: array, dw: array) -> array {
    let n = len(psi)
    let m = len(dw)
    if n != m { return psi }
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(psi[i] + dw[i])
        i = i + 1
    }
    return out
}

fn dist_to_vac(psi: array) -> float {
    let n = len(psi)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = psi[i] - VAC_COMPONENT
        s = s + d * d
        i = i + 1
    }
    return s
}

// ─── Self-tests (T1–T5) ─────────────────────────────────────

// T1 : Ψ at vacuum → ΔW = 0 (fixed point).
fn check_T1() -> bool {
    let mut psi = []
    let mut i = 0
    while i < 6 {
        psi = psi.push(0.5)
        i = i + 1
    }
    let tgt = vacuum_for(psi)
    let dw = tension_link_step(psi, tgt)
    let ok = vec_abs_sum(dw) < 0.0001
    if ok { println("  [T1] vacuum fixed-point PASS") }
    else  { println("  [T1] vacuum fixed-point FAIL (|sum|=" + str(vec_abs_sum(dw)) + ")") }
    return ok
}

// T2 : Ψ away from vacuum → ΔW nonzero AND |Ψ+ΔW − vac| < |Ψ − vac|.
fn check_T2() -> bool {
    // start above vacuum on every component
    let mut psi = []
    let mut i = 0
    while i < 6 {
        psi = psi.push(0.7)
        i = i + 1
    }
    let tgt = vacuum_for(psi)
    let dw  = tension_link_step(psi, tgt)
    if vec_is_zero(dw) {
        println("  [T2] restoring FAIL — ΔW = 0 on non-vacuum Ψ")
        return false
    }
    let d_before = dist_to_vac(psi)
    let psi_new  = apply_delta(psi, dw)
    let d_after  = dist_to_vac(psi_new)
    let ok = d_after < d_before
    if ok { println("  [T2] restoring PASS  (d: " + str(d_before) + " → " + str(d_after) + ")") }
    else  { println("  [T2] restoring FAIL  (d: " + str(d_before) + " → " + str(d_after) + ")") }
    return ok
}

// T3 : gate closes when Ψ is out of range → ΔW = 0.
fn check_T3() -> bool {
    let mut psi = []
    psi = psi.push(0.5)
    psi = psi.push(1.5)          // out-of-range
    psi = psi.push(0.5)
    psi = psi.push(0.5)
    let tgt = vacuum_for(psi)
    let dw  = tension_link_step(psi, tgt)
    let ok = vec_is_zero(dw) && len(dw) == len(psi)
    if ok { println("  [T3] out-of-range gate PASS (ΔW=0)") }
    else  { println("  [T3] out-of-range gate FAIL") }
    return ok
}

// T4 : gate closes on odd length (not a (R,G) pair set) → ΔW = 0.
fn check_T4() -> bool {
    let mut psi = []
    psi = psi.push(0.6)
    psi = psi.push(0.6)
    psi = psi.push(0.6)          // length 3 — odd
    let tgt = vacuum_for(psi)
    let dw  = tension_link_step(psi, tgt)
    let ok = vec_is_zero(dw) && len(dw) == 3
    if ok { println("  [T4] odd-length gate PASS (ΔW=0)") }
    else  { println("  [T4] odd-length gate FAIL") }
    return ok
}

// T5 : shape preservation — ΔW has same length as Ψ on all paths.
fn check_T5() -> bool {
    // path A : vacuum  (gate PASS, ΔW≈0 but length preserved)
    let mut psi_a = []
    let mut i = 0
    while i < 8 {
        psi_a = psi_a.push(0.5)
        i = i + 1
    }
    let dw_a = tension_link_step(psi_a, vacuum_for(psi_a))
    // path B : off-vacuum (gate PASS, ΔW nonzero, length preserved)
    let mut psi_b = []
    let mut j = 0
    while j < 8 {
        psi_b = psi_b.push(0.3)
        j = j + 1
    }
    let dw_b = tension_link_step(psi_b, vacuum_for(psi_b))
    // path C : gate FAIL (length preserved, ΔW=0)
    let mut psi_c = []
    psi_c = psi_c.push(0.5)
    psi_c = psi_c.push(2.0)      // out of range
    psi_c = psi_c.push(0.5)
    psi_c = psi_c.push(0.5)
    let dw_c = tension_link_step(psi_c, vacuum_for(psi_c))
    let ok = len(dw_a) == len(psi_a)
          && len(dw_b) == len(psi_b)
          && len(dw_c) == len(psi_c)
    if ok { println("  [T5] shape preservation PASS") }
    else  { println("  [T5] shape preservation FAIL") }
    return ok
}

// ─── main ────────────────────────────────────────────────────

fn main() {
    println("[tension_link_step] online step : ΔW = −T · G_holo · (Ψ − ½), n6-gated")
    println("  T_const=" + str(T_CONST) + "  xi=" + str(XI_DEFAULT) + "  vac=½,½")

    let t1 = check_T1()
    let t2 = check_T2()
    let t3 = check_T3()
    let t4 = check_T4()
    let t5 = check_T5()

    // demo: Ψ = (0.6, 0.6, 0.6, 0.6, 0.6, 0.6) — gently above vacuum
    let mut psi = []
    let mut i = 0
    while i < 6 {
        psi = psi.push(0.6)
        i = i + 1
    }
    let dw = tension_link_step(psi, vacuum_for(psi))
    print_vec("  demo ΔW", dw)

    let all_pass = t1 && t2 && t3 && t4 && t5
    if all_pass {
        println("[tension_link_step] ALL 5/5 PASS")
    } else {
        println("[tension_link_step] SOME FAILED")
    }
}

main()
