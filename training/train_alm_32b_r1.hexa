println("eta h opt    :", r1.eta.eta_hours_optimistic)
println("--- trigger gate ---")
println("marker       :", r1.gate.marker_path)
println("required r4  :", r1.gate.required_r4_best_eval)
println("current  r4  :", r1.gate.current_r4_best_eval)

theorem alm_32b_r1_invariants {
    // r4 parity — alpha:r must stay 2:1
    assert R1_LORA_ALPHA == R1_LORA_R * 2

    // ALM-P4-4: effective batch = BATCH × NGPU × GRAD_ACCUM = 2 × 2 × 4 = 16
    // Single-GPU r4/old-plan was 8; doubled for faster 32B convergence.
    assert R1_BATCH * R1_NGPU * R1_GRAD_ACCUM == 16

    // ALM-P4-4: FSDP 2× H100 plan
    assert R1_NGPU == 2

    // ALM-P4-4: 3000 steps (down from 10000 in pre-accel plan)
    assert R1_STEPS == 3000

    // ALM-P4-4: save/eval cadence scaled down to match 3000-step run
    assert R1_SAVE_EVERY == 500
    assert R1_EVAL_EVERY == 200

    // 6 saves and 15 evals across the full run
    assert R1_STEPS / R1_SAVE_EVERY == 6
    assert R1_STEPS / R1_EVAL_EVERY == 15

    // Warmup scaled proportionally: 500/10000 = 200/3000 within tolerance
    // (exact: 0.05 vs 0.067, both well below 10% of total steps)
    assert R1_WARMUP == 200

    // Module count matches r4 (4 attn + 3 MLP = 7)
    assert 4 + 3 == 7

    // Round = 1 (fresh lineage)
    assert R1_ROUND == 1

    // Bf16 master rule
    assert 1 == 1   // placeholder for opt.bf16 == true (no bool theorem lhs)

    // PSI constants unchanged
    assert PSI_ALPHA == 0.014
}

// ═══════════════════════════════════════════════════════════════════════════
// PYTHON DEPLOYMENT NOTE — ALM-P4-4 FSDP 2× H100
// ═══════════════════════════════════════════════════════════════════════════
// hexa-lang has no native CUDA bindings yet (stdlib/nn.hexa is CPU-only) so
// the actual forward/backward kernel path still routes through
// training/train_alm_14b.py on the pod. This .hexa file is the authoritative
// config + dry-run validation; launch_alm_32b_r1.sh reads these constants
// and wraps the Python trainer in torchrun with FSDP:
//
//   torchrun --nproc_per_node=2 --nnodes=1 --standalone \
//     /workspace/train_alm_14b.py \
//     --base Qwen/Qwen2.5-32B-Instruct \
//     --corpus /workspace/anima/training/corpus_large.txt \
//     --steps 3000 --lr 5e-6 --batch 2 --grad-accum 4 --seq 1024 \
//     --warmup 200 \
//     --lora-r 32 --lora-alpha 64 --lora-dropout 0.05 \
//     --target-modules q_proj k_proj v_proj o_proj gate_proj up_proj down_proj \
//     --ckpt-dir /workspace/ckpt_alm_32b_r1 \
//     --save-every 500 --eval-every 200 \
//     --model-tag alm32b --round 1 \
//     --fsdp --fsdp-wrap-cls Qwen2DecoderLayer
//
// Trainer additions for FSDP:
//   - torch.distributed.init_process_group("nccl") gated on LOCAL_RANK env
//   - device_map removed (FSDP handles placement); .to(local_rank) after wrap
//   - FSDP(model, auto_wrap_policy=transformer_auto_wrap_policy({Qwen2DecoderLayer}),
//     sharding_strategy=FULL_SHARD, mixed_precision=MixedPrecision(...bf16...))
//   - save_pretrained uses FullStateDictConfig(offload_to_cpu=True, rank0_only=True)
//
// When hexa-lang ships native cuBLAS/NCCL bindings (see AN3), this file will
// absorb the full train loop and the Python trainer will be archived.
// ═══════════════════════════════════════════════════════════════════════════
