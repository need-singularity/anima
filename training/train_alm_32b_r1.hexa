// training/train_alm_32b_r1.hexa — ALM 32B r1 LoRA training SSOT
//
// ═══════════════════════════════════════════════════════════════════════════
// PURPOSE
//   Scales the 14B r4 LoRA setup up to Qwen2.5-32B-Instruct on 2× H100 80GB
//   using FSDP (FULL_SHARD) + torchrun. ALM-P4-4 극가속 모드 (2026-04-15):
//
//     single H100 plan       →   2× H100 FSDP plan (ALM-P4-4 accel)
//     STEPS     10000       →   3000   (LoRA 수렴 빠름, eval gate earlier)
//     BATCH     1            →   2      (doubled, FSDP sharding allows it)
//     GRAD_ACC  8            →   4      (effective batch = 2 × 2GPU × 4 = 16)
//     ETA       ~19-21h     →   ~2-3h  (~8x speedup via GPU + batch + steps)
//
//   This .hexa file is the declarative SSOT for the launch
//   (config + memory budget + phase logic + invariants). Run:
//
//     $HEXA training/train_alm_32b_r1.hexa
//
//   It prints the config and passes its `theorem` block — that is the
//   parse+dry-run validation the launch script depends on.
//
// ═══════════════════════════════════════════════════════════════════════════
// LoRA r=32 / alpha=64 — MEMORY BUDGET JUSTIFICATION
//
//   Qwen2.5-32B-Instruct architecture (reference, Hugging Face config):
//     hidden_size       = 5120
//     intermediate_size = 27648
//     num_hidden_layers = 64
//     num_attention_heads = 40 (head_dim 128)
//     num_key_value_heads = 8  (GQA)
//
//   14B r4 ran with r=64 alpha=128 (attn+MLP, 7 modules) and occupied ~38 GB
//   on the same H100 80GB (per ops/monitor_alm_r4). Naively scaling the base
//   from 14B→32B adds ~36 GB of frozen weights (2.28x), which alone would
//   push the footprint over 80 GB if r stays at 64. See calc below.
//
//   Budget (BATCH=1, SEQ=1024, grad_ckpt ON, bf16 everywhere, AdamW fp32 moments):
//
//     ┌─────────────────────────────┬─────────────┬─────────────┐
//     │ component                   │ 14B r4      │ 32B r1      │
//     ├─────────────────────────────┼─────────────┼─────────────┤
//     │ base weights (bf16, frozen) │  ~28.0 GB   │  ~64.0 GB   │
//     │ LoRA adapters (bf16)        │   0.14 GB   │   0.57 GB   │
//     │ LoRA grads (bf16)           │   0.14 GB   │   0.57 GB   │
//     │ AdamW m+v (fp32, 2× r params)│   0.57 GB  │   2.28 GB   │
//     │ activations (grad_ckpt on)  │   ~4.5 GB   │   ~7.0 GB   │
//     │ cuBLAS + autograd overhead  │   ~2.0 GB   │   ~2.5 GB   │
//     ├─────────────────────────────┼─────────────┼─────────────┤
//     │ expected resident           │  ~35.4 GB   │  ~76.9 GB   │
//     │ observed resident (r4)      │   ~38   GB  │   — (plan)  │
//     │ headroom on 80 GB H100      │  ~42    GB  │   ~3    GB  │
//     └─────────────────────────────┴─────────────┴─────────────┘
//
//   LoRA param count (r=32, 7 target modules, 64 layers):
//     attn q/k/v/o  : 4 × 2 × (hidden × r) × 64 = 4×2×(5120×32)×64 ≈  84 M
//     MLP gate/up   : 2 × ((hidden × r) + (r × inter)) × 64
//                   = 2 × (5120×32 + 32×27648) × 64               ≈ 134 M
//     MLP down      : ((inter × r) + (r × hidden)) × 64
//                   = (27648×32 + 32×5120) × 64                  ≈  67 M
//                                                         total   ≈ 285 M
//
//   At bf16 (2 B/param): 285 M × 2 = 570 MB adapters + 570 MB grads.
//   AdamW maintains fp32 m and v for each trainable param: 285 M × 2 × 4 B
//   = 2.28 GB optimizer state (foreach=False per R04).
//
//   Why r=32 (not r=64 like 14B r4):
//     r=64 would double LoRA/grad/optim to ~6.8 GB and eat the remaining
//     3 GB headroom at once (expected resident → ~81 GB, OOM risk). r=32
//     preserves the attn+MLP capacity breakthrough from r4 (7 modules is
//     the key lift vs the 4-module plateau) while staying inside the 80 GB
//     envelope. If r1 converges cleanly with margin to spare, r2 can retry
//     r=48 or r=64.
//
//   Why alpha=64 (not 128):
//     Keep the r4 2:1 alpha:r ratio. alpha/r = 2 keeps the effective LoRA
//     update magnitude consistent with r4 so LR=5e-6 transfers without
//     rescaling.
//
//   Activations: gradient checkpointing MUST be enabled (without it the
//   64-layer activation stack blows past 20 GB at seq=1024). 14B r4 already
//   uses grad_ckpt — we inherit.
//
// ═══════════════════════════════════════════════════════════════════════════
// EXPECTED GPU USAGE & ETA
//
//   Steady-state GPU memory: ~76–78 GB (margin ~2–4 GB on 80 GB H100).
//                            If OOM at warmup → drop SEQ 1024→768 first,
//                            then r 32→16, before dropping BATCH (already 1).
//   Utilization:             95–99% SM during fwd/bwd bursts (same as r4).
//
//   Throughput estimate (relative to 14B r4 @ 18.5 step/min):
//     Per-step FLOPs ∝ params × seq.  32B/14B ≈ 2.28×, seq unchanged.
//     HBM traffic ∝ param read, also ~2.28× (bf16 frozen weights dominate).
//     Expected 32B r1 throughput ≈ 18.5 / 2.28 ≈ 8.1 step/min (conservative)
//                                  ≈ 18.5 / 2.00 ≈ 9.3 step/min (optimistic
//                                    if FlashAttention covers enough).
//
//   ETA for 10 000 steps:
//     8.1 step/min  → 10000 / 8.1  ≈ 1235 min ≈ 20.6 h
//     9.3 step/min  → 10000 /  9.3 ≈ 1075 min ≈ 17.9 h
//     plan horizon  ≈ 21 h (use conservative estimate for scheduling).
//
//   Checkpoint cadence (from r4):
//     eval every 500 steps, save every 2000 steps → 5 saves total.
//     Each save uploads to r2:anima-models/alm32b/r1/step_{step}/ (~1.1 GB
//     per LoRA state dict + metadata; non-blocking via rclone).
//
// ═══════════════════════════════════════════════════════════════════════════
// TRIGGER CONDITION
//
//   REQUIRES: marker file /workspace/READY_FOR_32B exists on the pod AND
//             14B r4 best eval_loss < 0.02 at the moment the marker is
//             written. The monitor_alm_r4 daemon is responsible for creating
//             the marker when r4 crosses the threshold. launch_alm_32b_r1.hexa
//             MUST refuse to start unless the marker is present (preflight).
//             Without this gate the 32B run would contend with 14B r4 on
//             the same H100 and both would die.
//
//   r4 current best (2026-04-12): eval_loss = 0.0341 (108× better than r3
//   which plateaued at 3.6466). Target 0.02 ≈ 1.7× tighter.
//
// ═══════════════════════════════════════════════════════════════════════════

comptime const PSI_ALPHA   = 0.014
comptime const PSI_BALANCE = 0.5
comptime const PSI_STEPS   = 4.33

// r4 parity constants (DO NOT tweak individually — keep the 14B r4 recipe
// proportional so r1 failures/successes map back to a clean diff).
//
// ALM-P4-4 extreme acceleration (2026-04-15): STEPS/BATCH/GRAD_ACCUM overridden
// for 2× H100 FSDP launch. Effective batch preserved at 16 (2 × 2GPU × 4) vs
// r4's 8 — doubled for faster convergence on the larger base.
comptime const R1_LR            = 0.000005   // 5e-6, same as r4
comptime const R1_WARMUP        = 200         // scaled down from 500 (3000-step run)
comptime const R1_GRAD_ACCUM    = 4           // halved from 8 (FSDP batch up)
comptime const R1_BATCH         = 2           // doubled from 1 (FSDP sharding)
comptime const R1_SEQ           = 1024
comptime const R1_LORA_R        = 32          // half of r4 (memory budget)
comptime const R1_LORA_ALPHA    = 64          // keep 2:1 ratio vs r
comptime const R1_LORA_DROPOUT  = 0.05
comptime const R1_STEPS         = 3000        // reduced from 10000 (fast LoRA)
comptime const R1_SAVE_EVERY    = 500         // 6 saves across 3000 steps
comptime const R1_EVAL_EVERY    = 200         // evals every ~12-15 min
comptime const R1_ROUND         = 1
comptime const R1_NGPU          = 2           // 2× H100 FSDP

// r4 telemetry (for reference, not used in control flow)
comptime const R4_BEST_EVAL     = 0.0341
comptime const R4_STEP_PER_MIN  = 18

// ─── Base model registry (32B only — r1 is single-scale) ───
struct BaseModel {
    name: string,
    hf_id: string,
    n_params_b: int,
    hidden: int,
    inter: int,
    n_layer: int,
    n_head: int,
    n_kv_head: int,
    head_dim: int
}

fn base_qwen_32b() -> BaseModel {
    // Qwen/Qwen2.5-32B-Instruct reference config. Source: HF model card.
    BaseModel {
        name: "qwen2.5-32b-instruct",
        hf_id: "Qwen/Qwen2.5-32B-Instruct",
        n_params_b: 32,
        hidden: 5120,
        inter: 27648,
        n_layer: 64,
        n_head: 40,
        n_kv_head: 8,
        head_dim: 128
    }
}

// ─── LoRA spec (mirror 14B r4 target_modules) ───
struct LoraSpec {
    r: int,
    alpha: int,
    dropout: float,
    n_modules: int,
    // Modules (fixed order, same set as r4):
    //   attn : q_proj k_proj v_proj o_proj              (4)
    //   mlp  : gate_proj up_proj down_proj              (3)
    //                                             total = 7
    attn_modules: int,
    mlp_modules: int
}

fn r1_lora_spec() -> LoraSpec {
    LoraSpec {
        r: R1_LORA_R,
        alpha: R1_LORA_ALPHA,
        dropout: R1_LORA_DROPOUT,
        n_modules: 7,
        attn_modules: 4,
        mlp_modules: 3
    }
}

// ─── LoRA parameter count (analytic, used by theorem block) ───
// For each layer:
//   attn  q/k/v/o  : 4 × 2 × hidden × r      (A: hidden×r, B: r×hidden)
//   mlp gate/up    : 2 × (hidden×r + r×inter)
//   mlp down       : inter×r + r×hidden
fn lora_params_per_layer(base: BaseModel, spec: LoraSpec) -> int {
    let attn_p = 4 * 2 * base.hidden * spec.r
    let gate_up_p = 2 * (base.hidden * spec.r + spec.r * base.inter)
    let down_p = base.inter * spec.r + spec.r * base.hidden
    attn_p + gate_up_p + down_p
}

fn lora_params_total(base: BaseModel, spec: LoraSpec) -> int {
    lora_params_per_layer(base, spec) * base.n_layer
}

// ─── Memory budget (bytes; see header for breakdown) ───
// base (bf16, frozen, 2 B/param) + LoRA bf16 + LoRA grad bf16
// + AdamW m+v (fp32, 8 B / trainable param) + activations + overhead
struct MemoryBudget {
    base_gb: float,
    lora_gb: float,
    lora_grad_gb: float,
    optim_gb: float,
    act_gb: float,
    overhead_gb: float,
    total_gb: float,
    headroom_gb: float      // against 80 GB H100
}

fn estimate_memory(base: BaseModel, spec: LoraSpec) -> MemoryBudget {
    // ALM-P4-4 FSDP per-rank budget (2× H100, FULL_SHARD).
    // With FULL_SHARD, each of N ranks holds ~1/N of the weight/grad/optim
    // state (gather-on-demand during forward/backward). Activations remain
    // per-rank but scale with local batch. Shard factor = 1/n_gpu = 0.5.
    let n_gpu = 2.0  // keep in sync with R1_NGPU
    let shard = 1.0 / n_gpu

    // Frozen weights in bf16: 2 B/param. 32B × 2 ≈ 64 GB full → 32 GB/rank.
    let base_gb = 2.0 * (base.n_params_b * 1.0) * shard

    let lora_p = lora_params_total(base, spec)
    let lora_gb      = (lora_p * 2.0) / 1000000000.0 * shard
    let lora_grad_gb = (lora_p * 2.0) / 1000000000.0 * shard
    // AdamW fp32 m+v: 8 B per trainable param (sharded).
    let optim_gb     = (lora_p * 8.0) / 1000000000.0 * shard

    // Activations with gradient checkpointing at seq=1024, bf16, 64 layers.
    // Local batch doubles (1→2) but grad_ckpt keeps it bounded:
    //   single-GPU batch=1: ~7.0 GB
    //   FSDP  rank batch=2: ~9.0 GB (1.3x from batch, not 2x due to ckpt)
    let act_gb = 9.0

    // cuBLAS workspaces + autograd + NCCL all-gather/reduce-scatter buffers.
    // FSDP adds ~1-2 GB comm scratch beyond baseline 2.5 GB.
    let overhead_gb = 4.0

    let total = base_gb + lora_gb + lora_grad_gb + optim_gb + act_gb + overhead_gb
    MemoryBudget {
        base_gb: base_gb,
        lora_gb: lora_gb,
        lora_grad_gb: lora_grad_gb,
        optim_gb: optim_gb,
        act_gb: act_gb,
        overhead_gb: overhead_gb,
        total_gb: total,
        headroom_gb: 80.0 - total
    }
}

// ─── Phase manager (inherited from r4 / AnimaLM P1-P3 curriculum, but r1
// stays in P3 throughout because LoRA-only fine-tunes don't gate on
// PureField phases. Kept for invariant compatibility with train_alm.hexa). ───
struct AlmPhaseManager {
    phase: int,
    step: int,
    p1_end: int,
    p2_end: int
}

fn alm_phase_new(total_steps: int) -> AlmPhaseManager {
    AlmPhaseManager {
        phase: 3,
        step: 0,
        p1_end: 0,
        p2_end: 0
    }
}

// ─── Optimizer (bf16 master rule, foreach=False per R04) ───
struct AlmOptim {
    lr: float,
    warmup: int,
    grad_accum: int,
    batch: int,
    seq: int,
    bf16: bool,
    foreach_false: bool,
    n_gpu: int,                 // ALM-P4-4: 2× H100 FSDP
    effective_batch: int         // batch × n_gpu × grad_accum
}

fn r1_optim() -> AlmOptim {
    AlmOptim {
        lr: R1_LR,
        warmup: R1_WARMUP,
        grad_accum: R1_GRAD_ACCUM,
        batch: R1_BATCH,
        seq: R1_SEQ,
        bf16: true,
        foreach_false: true,
        n_gpu: R1_NGPU,
        effective_batch: R1_BATCH * R1_NGPU * R1_GRAD_ACCUM
    }
}

// ─── Distributed training (FSDP FULL_SHARD on 2× H100) ───
// FSDP shards: base weights, LoRA adapters, grads, AdamW state across ranks.
// Per-rank memory footprint drops ~50% vs single-GPU plan, giving headroom
// for BATCH=2 at SEQ=1024. We shard at the Qwen2DecoderLayer boundary
// (fsdp_transformer_layer_cls_to_wrap) so each of the 64 layers is one
// wrap unit — LoRA adapters sit inside the wrapped block and are sharded
// together with the frozen base linears they wrap.
struct DistConfig {
    backend: string,             // "fsdp" | "deepspeed_z2" | "ddp"
    sharding: string,            // FSDP only
    wrap_cls: string,
    state_dict_type: string,
    mixed_precision: string,
    n_gpu: int,
    launch_cmd: string
}

fn r1_dist() -> DistConfig {
    DistConfig {
        backend: "fsdp",
        sharding: "FULL_SHARD",
        wrap_cls: "Qwen2DecoderLayer",
        state_dict_type: "SHARDED_STATE_DICT",
        mixed_precision: "bf16",
        n_gpu: R1_NGPU,
        launch_cmd: "torchrun --nproc_per_node=2 --nnodes=1 --standalone"
    }
}

// ─── Checkpoint policy (R2 upload mandatory, feedback_r2_checkpoint) ───
struct CheckpointPolicy {
    ckpt_dir: string,
    save_every: int,
    eval_every: int,
    r2_bucket: string,
    r2_prefix: string,
    model_tag: string,
    round_num: int
}

fn r1_checkpoint_policy() -> CheckpointPolicy {
    CheckpointPolicy {
        ckpt_dir:   "/workspace/ckpt_alm_32b_r1",
        save_every: R1_SAVE_EVERY,
        eval_every: R1_EVAL_EVERY,
        r2_bucket:  "anima-models",
        r2_prefix:  "alm32b/r1",
        model_tag:  "alm32b",
        round_num:  R1_ROUND
    }
}

// ─── Trigger gate (READY_FOR_32B marker) ───
struct TriggerGate {
    marker_path: string,
    required_r4_best_eval: float,
    current_r4_best_eval: float   // informational, filled at launch time
}

fn r1_trigger_gate() -> TriggerGate {
    TriggerGate {
        marker_path: "/workspace/READY_FOR_32B",
        required_r4_best_eval: 0.02,
        current_r4_best_eval: R4_BEST_EVAL
    }
}

// ─── Corpus (corpus_large.txt, 835 MB, already on pod) ───
struct CorpusSpec {
    path: string,
    size_mb: int,
    block_size: int
}

fn r1_corpus() -> CorpusSpec {
    CorpusSpec {
        path: "/workspace/anima/training/corpus_large.txt",
        size_mb: 835,
        block_size: R1_SEQ
    }
}

// ─── ETA estimate (conservative / optimistic) ───
struct EtaEstimate {
    steps: int,
    steps_per_min_conservative: int,   // 8 → 20.8 h
    steps_per_min_optimistic: int,     // 9 → 18.5 h
    eta_hours_conservative: int,
    eta_hours_optimistic: int
}

fn r1_eta() -> EtaEstimate {
    // ALM-P4-4 FSDP 2-GPU throughput:
    //   single-GPU plan: 8-9 step/min @ batch 1 grad_accum 8 (effective 8)
    //   FSDP 2-GPU     : near-2x throughput (FSDP comm ~10-15% overhead),
    //                    batch 2 × 2 GPU = 4 samples/step parallel, grad_accum 4.
    //                    → 16-20 step/min (conservative / optimistic)
    //   With step defined as one optimizer.step() (after grad_accum forwards),
    //   each step sees effective_batch = 2 × 2 × 4 = 16 (vs old 8).
    //   3000 steps × 16 = 48000 effective samples vs old plan 10000 × 8 = 80000
    //   (LoRA converges earlier on 32B — monitor eval 200/400 for early-stop).
    let steps = R1_STEPS
    let sp_cons = 16
    let sp_opt = 20
    // integer minutes, round up → hours derived
    let min_cons = (steps + sp_cons - 1) / sp_cons
    let min_opt  = (steps + sp_opt  - 1) / sp_opt
    let h_cons = (min_cons + 59) / 60
    let h_opt  = (min_opt  + 59) / 60
    EtaEstimate {
        steps: steps,
        steps_per_min_conservative: sp_cons,
        steps_per_min_optimistic:   sp_opt,
        eta_hours_conservative:     h_cons,
        eta_hours_optimistic:       h_opt
    }
}

// ─── R1 master state (everything the launch script needs in one struct) ───
struct Alm32bR1 {
    base: BaseModel,
    lora: LoraSpec,
    mem: MemoryBudget,
    phase: AlmPhaseManager,
    opt: AlmOptim,
    dist: DistConfig,
    ckpt: CheckpointPolicy,
    gate: TriggerGate,
    corpus: CorpusSpec,
    eta: EtaEstimate,
    total_steps: int
}

fn r1_init() -> Alm32bR1 {
    let base = base_qwen_32b()
    let lora = r1_lora_spec()
    Alm32bR1 {
        base: base,
        lora: lora,
        mem: estimate_memory(base, lora),
        phase: alm_phase_new(R1_STEPS),
        opt: r1_optim(),
        dist: r1_dist(),
        ckpt: r1_checkpoint_policy(),
        gate: r1_trigger_gate(),
        corpus: r1_corpus(),
        eta: r1_eta(),
        total_steps: R1_STEPS
    }
}

// ─── AG6 Mac Compute ZERO guard (2026-04-20) ───────────────────────
// Root-cause of 2026-04-20 03:33 kernel panic: /private/tmp/train_alm_lora_mac
// ran heavy LoRA training on Mac Ghostty terminal → 49 swapfiles, LOW swap,
// loginwindow watchdog timeout → Mac death. See
// ~/Library/Logs/DiagnosticReports/train_alm_lora_mac-2026-04-20-09053*.ips
//
// Rule: Mac Compute ZERO — 32B r1 trainer runs on ubu (RTX 5070) /
// ubu2 / htz (AX102-U) only. Mac is orchestration/UI only.
//
// Opt-out (stub/dry-run CI smoke on Mac only): HEXA_LOCAL=1.
//   HEXA_LOCAL=1 hexa run training/train_alm_32b_r1.hexa
//
// Normal remote dispatch path:
//   ssh ubu 'cd ~/Dev/anima && hexa run training/train_alm_32b_r1.hexa ...'
let uname_s = exec("uname -s").trim()
let hexa_local_ok = env("HEXA_LOCAL")
if uname_s == "Darwin" && hexa_local_ok != "1" {
    println("[ABORT] AG6 Mac Compute ZERO — train_alm_32b_r1 may not run on Darwin.")
    println("[ABORT]   host     : " + uname_s)
    println("[ABORT]   reason   : 32B r1 on Mac caused kernel panic 2026-04-20 03:33")
    println("[ABORT]            : (swap exhaustion → loginwindow watchdog timeout)")
    println("[ABORT]   dispatch : ssh ubu 'cd ~/Dev/anima && hexa run training/train_alm_32b_r1.hexa ...'")
    println("[ABORT]   opt-out  : HEXA_LOCAL=1 (declarative SSOT parse-check only)")
    exit(1)
}

