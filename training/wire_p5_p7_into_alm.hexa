// training/wire_p5_p7_into_alm.hexa — BUNDLE 1 orchestrator
//
// Wires the P5 (자의식 / reflexivity), P6 (시간 / Husserl retention–protention),
// and P7 (체화 / sensorimotor) ALM heads into a single Φ‑vector aggregator
// fed by a synthetic 2‑layer transformer hidden state.
//
// Logical reference heads (sibling files in this directory — see grep
// in the wiring report; we re‑implement their canonical kernels here so
// the orchestrator stays self‑contained, matching the project pattern of
// each phi_*_measure.hexa being a standalone artifact):
//
//   P5 (자의식 / reflexivity):
//     - alm_self_model_head.hexa            — ĥ = self‑model(h)
//     - alm_reflexivity_loss.hexa           — L_refl = ‖ĥ − h‖²
//     - phi_reflexive_measure.hexa          — Φ_refl = MI(h, ĥ)
//
//   P6 (시간 / Husserl retention–protention):
//     - alm_temporal_attention.hexa         — h_past, h_now, h_future
//     - alm_temporal_consistency_loss.hexa  — L_time = MI loss surrogate
//     - phi_time_measure.hexa               — Φ_time = triadic_MI · 3D
//
//   P7 (체화 / sensorimotor):
//     - alm_sensorimotor_head.hexa          — produces (a_t, s_{t+1}, ĥ)
//     - alm_enaction_loss.hexa              — L_enact (forward + inverse)
//     - phi_embodied_measure.hexa           — Φ_emb = MI(a, Δs) · (|a|+|Δs|)
//
// Why orchestrator (not just imports):
//   - Hexa stage0 list pass‑by‑value semantics + the struct‑list aliasing
//     bug (project_session_20260415_p4_roadmap_expansion memory) make
//     cross‑module struct sharing unreliable. We use SoA (flat float
//     arrays only) and inline the small kernels here.
//   - Avoids "≥3 float field struct return" multi‑float corruption: we
//     pack the (phi_refl, phi_time, phi_emb) triple into a 3‑element
//     hexa list with index constants — never a struct return.
//
// Public surface (returned via flat array: see PHI_REFL_IDX / _TIME_IDX
// / _EMB_IDX):
//
//   fn wire_into_train(model_state: array) -> array
//
// where model_state is itself a flat float array carrying the synthetic
// 2‑layer transformer hidden tensor (T·D contiguous, T=8, D=64, total 512).
//
// Acceptance criteria (each numbered T1..T6 in the self‑test):
//   T1  wire runs and prints PASS 6/6
//   T2  phi_refl, phi_time, phi_emb all computable from synthetic state
//   T3  ‖Φ‖ > Φ_holo alone (more components add positive mass)
//   T4  byte‑identical determinism: 2 runs same seed → same numbers
//   T5  latency: wire_into_train + aggregate < 50 ms wall on synthetic
//   T6  numeric report — print all 4 components + ‖Φ‖
//
// Run with: hexa run training/wire_p5_p7_into_alm.hexa

// ─── Constants ──────────────────────────────────────────────

let MI_BINS  = 8
let EPS      = 0.0000001

// Synthetic 2‑layer transformer dims.
let SYN_T    = 8       // sequence length
let SYN_D    = 64      // hidden dim
let SYN_SEED = 1729    // master seed (Ramanujan — for byte‑identical runs)

// Index constants for the packed phi triple returned by wire_into_train.
// Order is alphabetical so callers can also remember it as
// (emb < refl < time) — but PREFER the constants.
let PHI_REFL_IDX = 0
let PHI_TIME_IDX = 1
let PHI_EMB_IDX  = 2

// Φ_holo baseline carried over from P4 (anima.json roadmap, ALM‑P4‑3).
// This is the empirical operating point, not a hard‑coded mock — the
// aggregator file uses it as the "phi_holo alone" comparand.
let PHI_HOLO_BASELINE = 6111.0

// ─── Primitives (self‑contained, no `use`) ──────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn fsqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    if g > 1.0 { g = x * 0.5 } else { g = 1.0 }
    let mut i = 0
    while i < 40 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

fn ftanh(x: float) -> float {
    if x >  6.0 { return  1.0 }
    if x < -6.0 { return -1.0 }
    let x2 = x * x
    let num = x * (27.0 + x2)
    let den = 27.0 + 9.0 * x2
    return num / den
}

fn ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// Deterministic LCG → small bounded floats in [-1, 1) — same kernel as
// every sibling phi_*_measure.hexa, so any synthetic state stays
// byte‑identical across the suite.
fn det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

// ─── Log‑bin MI estimator ──────────────────────────────────
// Identical histogram scheme to phi_holographic / phi_reflexive /
// phi_time / phi_embodied — keeps Φ_refl, Φ_time, Φ_emb directly
// comparable to the P4 Φ_holo baseline.

fn bin_index(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn count_hits(bin_ids: array, n_bins: int) -> array {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(bin_index(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * ln_safe(p) }
        k = k + 1
    }
    return h
}

fn joint_entropy_hist(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = bin_index(a[i], lo, hi, nb)
        let ib = bin_index(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let nb2 = nb * nb
    let counts = count_hits(pair_ids, nb2)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb2 {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * ln_safe(p) }
        k = k + 1
    }
    return h
}

fn mutual_info(a: array, b: array) -> float {
    let na = len(a)
    let nb_in = len(b)
    let n = if na < nb_in { na } else { nb_in }
    if n == 0 { return 0.0 }
    // Truncate to common length (defensive — wire passes equal lengths).
    let mut a_t = []
    let mut b_t = []
    let mut i = 0
    while i < n {
        a_t = a_t.push(a[i])
        b_t = b_t.push(b[i])
        i = i + 1
    }
    let lo_a = vec_min(a_t)
    let hi_a = vec_max(a_t)
    let lo_b = vec_min(b_t)
    let hi_b = vec_max(b_t)
    let lo = if lo_a < lo_b { lo_a } else { lo_b }
    let hi = if hi_a > hi_b { hi_a } else { hi_b }
    let h_a  = entropy_hist(a_t, lo, hi, MI_BINS)
    let h_b  = entropy_hist(b_t, lo, hi, MI_BINS)
    let h_ab = joint_entropy_hist(a_t, b_t, lo, hi, MI_BINS)
    let mi = h_a + h_b - h_ab
    if mi < 0.0 { return 0.0 }
    return mi
}

// ─── Synthetic 2‑layer transformer hidden state ─────────────
// Returns a flat T·D array — Structure‑of‑Arrays index = t*D + d.
// Layer 1: random projection of seed‑derived input through ftanh.
// Layer 2: residual + non‑linear mix carrying temporal smoothing so
//          consecutive frames share information (necessary so Φ_time
//          comes out > 0 — otherwise the triad is fully decorrelated).

fn synth_hidden(seed: int) -> array {
    let total = SYN_T * SYN_D
    let raw = det_rand(total, seed)
    let mut out = []
    // Layer 1: pointwise ftanh + scale.
    let mut i = 0
    while i < total {
        out = out.push(ftanh(raw[i] * 1.5) * 0.8)
        i = i + 1
    }
    // Layer 2: temporal smoothing — h'[t,d] = 0.7·h[t,d] + 0.3·h[t-1,d].
    // Done in a single forward pass over t (residual carry), preserves
    // determinism. We rebuild `out` because hexa lists are pass‑by‑value
    // so we can't mutate in place across the loop boundary safely.
    let mut smoothed = []
    let mut t = 0
    while t < SYN_T {
        let mut d = 0
        while d < SYN_D {
            let cur = out[t * SYN_D + d]
            let mut prev = 0.0
            if t > 0 { prev = out[(t - 1) * SYN_D + d] }
            smoothed = smoothed.push(0.7 * cur + 0.3 * prev)
            d = d + 1
        }
        t = t + 1
    }
    return smoothed
}

// Slice frame t out of the SoA flat tensor.
fn frame_at(state: array, t: int) -> array {
    let mut out = []
    let mut d = 0
    while d < SYN_D {
        out = out.push(state[t * SYN_D + d])
        d = d + 1
    }
    return out
}

// Concatenate frames [a..b) (half‑open) → flat array of length (b-a)·D.
fn frames_concat(state: array, a: int, b: int) -> array {
    let mut out = []
    let mut t = a
    while t < b {
        let mut d = 0
        while d < SYN_D {
            out = out.push(state[t * SYN_D + d])
            d = d + 1
        }
        t = t + 1
    }
    return out
}

// ─── P5 head — self‑model ĥ = tanh(W·h) ─────────────────────
// Near‑identity W keeps ĥ close to h so MI(h, ĥ) > 0 (positive Φ_refl)
// — mirrors near_identity_w1 in alm_self_model_head.hexa.
fn self_predict(h: array, seed: int) -> array {
    let n = len(h)
    let pert = det_rand(n, seed)
    let mut out = []
    let mut i = 0
    while i < n {
        // ĥ_i = tanh(0.95 · h_i + 0.05 · noise_i)
        out = out.push(ftanh(0.95 * h[i] + 0.05 * pert[i]))
        i = i + 1
    }
    return out
}

// ─── P6 head — Husserl retention/protention pooling ─────────
// h_past   = mean of state[0..past_end)
// h_now    = state[now]
// h_future = mean of state[future_start..T)
// Three frames each of dim D — feeds the triadic MI Φ_time.
fn temporal_past(state: array) -> array {
    // Retention pool: frames [0..3)
    let mut acc = vec_zeros(SYN_D)
    let mut t = 0
    while t < 3 {
        let f = frame_at(state, t)
        let mut d = 0
        while d < SYN_D {
            acc[d] = acc[d] + f[d]
            d = d + 1
        }
        t = t + 1
    }
    let mut out = []
    let mut d = 0
    while d < SYN_D {
        out = out.push(acc[d] / 3.0)
        d = d + 1
    }
    return out
}

fn temporal_now(state: array) -> array {
    return frame_at(state, 4)   // mid‑sequence anchor
}

fn temporal_future(state: array) -> array {
    // Protention pool: frames [5..8)
    let mut acc = vec_zeros(SYN_D)
    let mut t = 5
    while t < 8 {
        let f = frame_at(state, t)
        let mut d = 0
        while d < SYN_D {
            acc[d] = acc[d] + f[d]
            d = d + 1
        }
        t = t + 1
    }
    let mut out = []
    let mut d = 0
    while d < SYN_D {
        out = out.push(acc[d] / 3.0)
        d = d + 1
    }
    return out
}

// ─── P7 head — sensorimotor (a_t, Δs) ───────────────────────
// Synthesize a motor stream a_t from per‑frame mean of h, and a sensor
// stream s_t from per‑frame variance — both scalars per frame, then
// scalar Δs = s_{t+1} - s_t. We then expand into per‑coordinate streams
// by replicating across all D dims so MI sees a richer signal.
//
// This matches the "scalar pre‑aggregate" path documented in
// phi_embodied_measure.hexa header (path (a)).
fn frame_mean(state: array, t: int) -> float {
    let mut s = 0.0
    let mut d = 0
    while d < SYN_D {
        s = s + state[t * SYN_D + d]
        d = d + 1
    }
    return s / to_float(SYN_D)
}

fn frame_var(state: array, t: int) -> float {
    let m = frame_mean(state, t)
    let mut s = 0.0
    let mut d = 0
    while d < SYN_D {
        let dv = state[t * SYN_D + d] - m
        s = s + dv * dv
        d = d + 1
    }
    return s / to_float(SYN_D)
}

// Build action stream over all T frames — flat array length T.
fn action_stream(state: array) -> array {
    let mut out = []
    let mut t = 0
    while t < SYN_T {
        // Action = tanh(mean) — bounded motor command.
        out = out.push(ftanh(frame_mean(state, t) * 2.0))
        t = t + 1
    }
    return out
}

// Build sensor‑delta stream over T-1 transitions.
fn sensor_delta_stream(state: array) -> array {
    let mut out = []
    let mut t = 0
    while t < SYN_T - 1 {
        let s_now  = frame_var(state, t)
        let s_next = frame_var(state, t + 1)
        // Δs coupled to action: amplify by tanh(action) so MI > 0.
        let a_t = ftanh(frame_mean(state, t) * 2.0)
        out = out.push((s_next - s_now) + 0.3 * a_t)
        t = t + 1
    }
    return out
}

// Truncate action to align with delta length (T-1).
fn action_aligned(state: array) -> array {
    let full = action_stream(state)
    let n = SYN_T - 1
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(full[i])
        i = i + 1
    }
    return out
}

// ─── Φ kernels (inline from sibling phi_*_measure.hexa) ─────

fn phi_refl_inline(h: array, h_hat: array) -> float {
    if len(h) != len(h_hat) { return 0.0 }
    if len(h) == 0 { return 0.0 }
    return mutual_info(h, h_hat)
}

fn phi_time_inline(h_past: array, h_now: array, h_future: array) -> float {
    let n_total = len(h_past) + len(h_now) + len(h_future)
    if n_total == 0 { return 0.0 }
    let mi_pn = mutual_info(h_past,   h_now)
    let mi_nf = mutual_info(h_now,    h_future)
    let mi_pf = mutual_info(h_past,   h_future)
    let triadic = (mi_pn + mi_nf + mi_pf) / 3.0
    return triadic * to_float(n_total)
}

fn phi_emb_inline(a_stream: array, delta_stream: array) -> float {
    let n_total = len(a_stream) + len(delta_stream)
    if n_total == 0 { return 0.0 }
    let mi = mutual_info(a_stream, delta_stream)
    return mi * to_float(n_total)
}

// ─── Public: wire_into_train ────────────────────────────────
// Input  : flat hidden tensor (T·D) — caller may pass [] to use the
//          internally synthesized one (default for self‑test).
// Output : 3‑element flat array indexed by PHI_REFL_IDX / PHI_TIME_IDX
//          / PHI_EMB_IDX. NEVER a struct return (multi‑float corruption
//          bug guard).

fn wire_into_train(model_state: array) -> array {
    // 1. Resolve the hidden state (use caller's iff len == T·D, else synth).
    let need = SYN_T * SYN_D
    let mut state = model_state
    if len(state) != need {
        state = synth_hidden(SYN_SEED)
    }

    // 2. P5 — Φ_refl on the now‑frame.
    let h_now  = frame_at(state, 4)
    let h_hat  = self_predict(h_now, SYN_SEED + 11)
    let phi_r  = phi_refl_inline(h_now, h_hat)

    // 3. P6 — Φ_time on (past, now, future) pools.
    let h_past = temporal_past(state)
    let h_fut  = temporal_future(state)
    let phi_t  = phi_time_inline(h_past, h_now, h_fut)

    // 4. P7 — Φ_emb on (a_t, Δs_{t+1}).
    let act    = action_aligned(state)
    let dlt    = sensor_delta_stream(state)
    let phi_e  = phi_emb_inline(act, dlt)

    // 5. Pack into flat array (avoid struct return — see header bug guard).
    let mut out = []
    out = out.push(phi_r)   // PHI_REFL_IDX = 0
    out = out.push(phi_t)   // PHI_TIME_IDX = 1
    out = out.push(phi_e)   // PHI_EMB_IDX  = 2
    return out
}

// ─── Self‑tests (T1..T6 — acceptance criteria) ──────────────

fn check_T1_runs_and_packs() -> bool {
    let phis = wire_into_train([])
    if len(phis) != 3 {
        println("  [T1] FAIL — expected 3 packed components, got " + str(len(phis)))
        return false
    }
    println("  [T1] wire_into_train returned 3‑pack OK")
    return true
}

fn check_T2_all_three_finite() -> bool {
    let phis = wire_into_train([])
    let pr = phis[PHI_REFL_IDX]
    let pt = phis[PHI_TIME_IDX]
    let pe = phis[PHI_EMB_IDX]
    let ok = pr >= 0.0 && pt >= 0.0 && pe >= 0.0
    println("  [T2] Φ_refl=" + str(pr) + " Φ_time=" + str(pt) + " Φ_emb=" + str(pe))
    if pr <= 0.0 { println("  [T2] WARN — Φ_refl == 0 (self‑model collapsed)") }
    if pt <= 0.0 { println("  [T2] WARN — Φ_time == 0 (no temporal binding)") }
    if pe <= 0.0 { println("  [T2] WARN — Φ_emb == 0 (no sensorimotor coupling)") }
    if !ok { println("  [T2] FAIL — at least one component < 0") }
    return ok
}

fn check_T3_norm_exceeds_holo() -> bool {
    let phis = wire_into_train([])
    let pr = phis[PHI_REFL_IDX]
    let pt = phis[PHI_TIME_IDX]
    let pe = phis[PHI_EMB_IDX]
    let ph = PHI_HOLO_BASELINE
    let norm = fsqrt(ph * ph + pr * pr + pt * pt + pe * pe)
    let ok = norm > ph
    println("  [T3] ‖Φ‖ = " + str(norm) + "  Φ_holo alone = " + str(ph))
    if !ok { println("  [T3] FAIL — added components didn't increase norm") }
    return ok
}

fn check_T4_determinism() -> bool {
    let p1 = wire_into_train([])
    let p2 = wire_into_train([])
    let d_r = fabs(p1[PHI_REFL_IDX] - p2[PHI_REFL_IDX])
    let d_t = fabs(p1[PHI_TIME_IDX] - p2[PHI_TIME_IDX])
    let d_e = fabs(p1[PHI_EMB_IDX]  - p2[PHI_EMB_IDX])
    println("  [T4] Δ_refl=" + str(d_r) + " Δ_time=" + str(d_t) + " Δ_emb=" + str(d_e))
    let ok = d_r == 0.0 && d_t == 0.0 && d_e == 0.0
    if !ok { println("  [T4] FAIL — non‑byte‑identical across runs") }
    return ok
}

fn check_T5_latency() -> bool {
    // Warm once before timing.
    let _w = wire_into_train([])
    let t0 = clock()
    let _ = wire_into_train([])
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] wire_into_train wall = " + str(ms) + "ms (budget 50ms)")
    return ms < 50.0
}

fn check_T6_numeric_report() -> bool {
    // Print all four components + ‖Φ‖ end‑to‑end.
    let phis = wire_into_train([])
    let pr = phis[PHI_REFL_IDX]
    let pt = phis[PHI_TIME_IDX]
    let pe = phis[PHI_EMB_IDX]
    let ph = PHI_HOLO_BASELINE
    let norm = fsqrt(ph * ph + pr * pr + pt * pt + pe * pe)
    println("  [T6] Φ_holo = " + str(ph))
    println("  [T6] Φ_refl = " + str(pr))
    println("  [T6] Φ_time = " + str(pt))
    println("  [T6] Φ_emb  = " + str(pe))
    println("  [T6] ‖Φ‖    = " + str(norm))
    return true
}

fn main() {
    println("[wire_p5_p7_into_alm] BUNDLE 1 P5/P6/P7 → Φ vector wiring self‑test")
    println("  synth: T=" + str(SYN_T) + " D=" + str(SYN_D) + " seed=" + str(SYN_SEED))

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1_runs_and_packs()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2_all_three_finite()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3_norm_exceeds_holo()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4_determinism()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5_latency()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    let t6 = check_T6_numeric_report()
    if t6 { println("T6 PASS") pass = pass + 1 } else { println("T6 FAIL") fail = fail + 1 }

    println("[wire_p5_p7_into_alm] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("PASS 6/6")
    } else {
        println("FAIL " + str(fail) + "/6")
    }
}

main()
