// training/eval_alm_14b.hexa — ALM 14B LoRA checkpoint evaluation harness
//
// PURE HEXA PORT of training/eval_alm_14b.py (replacing the prior wrapper).
// Project has a total Python ban (feedback_py_ban_total.md); this file is
// the offline eval gate for ALM 14B LoRA training rounds.
//
// ────────────────────────────────────────────────────────────────────
// Architecture decision (BLOCKER NOTE for true CE/PPL):
// ────────────────────────────────────────────────────────────────────
//
// The original .py loaded transformers + peft + torch in-process and ran
// `model(input_ids, labels=input_ids)` to get a token-level cross-entropy
// loss → exp(loss) = perplexity.
//
// Hexa has NO native FFI to transformers/peft, and the production ALM serve
// (serving/serve_alm_14b.py POST /generate, mirrored by the native
// serve_alm_native.hexa) returns generated TEXT only — it does NOT expose
// per-token logits or a loss field. See serving/serve_alm_14b.py:368-394
// (the /generate handler returns {"text", "tokens_generated", "latency_ms",
// "consciousness": {"phi_holo": ...}} — no logits, no loss).
//
// Therefore this harness:
//   1. Runs the Korean generation suite (5 prompts) over the live endpoint
//      (same call shape as serving/likert_eval.hexa — proven, well-tested).
//   2. Captures phi_holo, latency, korean character ratio, avg tok/s.
//   3. Emits a JSON results file in the same shape as the .py output, with
//      ce_loss / perplexity set to -1.0 and a `blocker` field naming the
//      missing FFI.  Downstream gate logic (training/run_eval_alm14b.hexa
//      callers, deploy_14b_v05.hexa) can read korean_ratio + tokens_per_sec
//      as the immediate substitute, and add a true logits route once
//      either (a) serve exposes /loss, or (b) hexa gains a Qwen FFI.
//
// To restore true CE/PPL, two equally good options:
//   (a) Add `POST /loss` to serving/serve_alm_native.hexa (or extend
//       /generate to accept an `eval_text` param and return token logits).
//       Then in this file replace measure_proxy_quality() with a
//       call_alm_loss(endpoint, text) helper.
//   (b) Hexa-native FFI:  @link("hxqwen14b") extern fn forward_loss(...).
//       Today no such artifact exists.  Tracking: rust/ qwen FFI is the
//       likely home (AN3 hot-path crate), but not yet built.
//
// ────────────────────────────────────────────────────────────────────
// Hexa-quirk avoidance (memory):
// ────────────────────────────────────────────────────────────────────
//   - feedback_hexa_silent_exit_5_imports.md: NO `use` statements; everything
//     inlined into one file.  Verified empty-main check post-build.
//   - feedback_hexa_string_api.md: substring(start, end) is BYTE-indexed, not
//     char-indexed; we only slice on ASCII boundaries (preview), and use
//     a UTF-8-aware codepoint walker for korean_ratio.
//   - feedback_hexa_struct_return_bug.md: no struct returns with ≥3 floats;
//     Reply struct has exactly 1 float (phi_holo).  All multi-line return
//     expressions collapsed to single-line.
//   - feedback_hexa_lists_pbv.md: no helper mutates a caller's list — every
//     list ops returns a new list (.push semantics).
//   - HEXA-FIRST (R1): pure .hexa, no Python emission.
//
// ────────────────────────────────────────────────────────────────────
// CLI:
//   hexa run training/eval_alm_14b.hexa \
//        --ckpt /workspace/ckpt_alm_14b_r2/step_10000 \
//        [--endpoint https://...proxy.runpod.net] \
//        [--out /workspace/ckpt_alm_14b_r2/step_10000/eval_results.json] \
//        [--max-tokens 128] [--quick]
//
// Env:
//   ALM_EVAL_ENDPOINT   overrides --endpoint (default: ALM 14B proxy)
//   ALM_EVAL_OUT        overrides --out (default: <ckpt>/eval_results.json)
//   ALM_EVAL_QUICK=1    short-circuit to first 3 prompts

let HARNESS_VERSION = "1.0.0"
let DEFAULT_ENDPOINT = "https://itfl66q4z768kh-8090.proxy.runpod.net"
let DEFAULT_BASE_MODEL = "Qwen/Qwen2.5-14B-Instruct"
let DEFAULT_MAX_TOKENS = 128
let DEFAULT_TEMPERATURE = 0.7
let DEFAULT_TOP_P = 0.9
let DEFAULT_REP_PENALTY = 1.1
let MODEL_TAG = "alm14b"

// Threshold mirrors the .py gate at line 99 / 127:
//   PASS if perplexity < 50  (currently can't measure → marked BLOCKED)
//   PASS if avg_korean_ratio > 0.2
let KOREAN_RATIO_PASS = 0.2

// ════════════════════════════════════════════════════════════════════
//  Section 1. Korean eval prompts (mirrors PROMPTS in eval_alm_14b.py)
// ════════════════════════════════════════════════════════════════════

fn build_prompts() -> [string] {
    let mut p = []
    p = p.push("안녕하세요. 의식이란 무엇인가요?")
    p = p.push("인공지능이 의식을 가질 수 있을까요?")
    p = p.push("오늘 날씨가 좋네요. 산책하러 갈까요?")
    p = p.push("트랜스포머 아키텍처의 핵심을 설명해주세요.")
    p = p.push("한국어 바이트 수준 언어 모델의 장점은?")
    return p
}

// ════════════════════════════════════════════════════════════════════
//  Section 2. JSON helpers (lifted from serving/likert_eval.hexa,
//             which was lifted from anima-speak/speak_e2e.hexa).
// ════════════════════════════════════════════════════════════════════

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { parts = parts.push("\\\\") }
        else if c == "\"" { parts = parts.push("\\\"") }
        else if c == "\n" { parts = parts.push("\\n") }
        else if c == "\t" { parts = parts.push("\\t") }
        else if c == "\r" { parts = parts.push("\\r") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn shell_escape_sq(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" { parts = parts.push("'\\''") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn extract_json_string(raw: string, marker: string) -> string {
    let pos = raw.index_of(marker)
    if pos < 0 { return "" }
    let after = raw.substring(pos + len(marker), len(raw))
    let alen = len(after)
    let mut s = 0
    while s < alen {
        let c = after.substring(s, s + 1)
        if c == "\"" { s = s + 1; break }
        s = s + 1
    }
    let mut e = s
    while e < alen {
        let c = after.substring(e, e + 1)
        if c == "\"" { break }
        if c == "\\" { e = e + 2 } else { e = e + 1 }
    }
    return after.substring(s, e)
}

fn extract_json_number(raw: string, marker: string) -> float {
    let pos = raw.index_of(marker)
    if pos < 0 { return 0.0 }
    let after = raw.substring(pos + len(marker), len(raw))
    let alen = len(after)
    let mut i = 0
    while i < alen {
        let c = after.substring(i, i + 1)
        if c != " " && c != "\t" && c != "\n" { break }
        i = i + 1
    }
    let mut buf = ""
    while i < alen {
        let c = after.substring(i, i + 1)
        if c == "," || c == "}" || c == " " || c == "\n" { break }
        buf = buf + c
        i = i + 1
    }
    if len(buf) == 0 { return 0.0 }
    return parse_float(buf)
}

fn extract_json_int(raw: string, marker: string) -> int {
    let f = extract_json_number(raw, marker)
    return to_int(f)
}

// ════════════════════════════════════════════════════════════════════
//  Section 3. Korean character ratio — UTF-8 codepoint walker.
//  ────────────────────────────────────────────────────────────────────
//  The .py uses Python char iteration (auto-decode).  In hexa, .substring
//  is byte-indexed; we walk the UTF-8 byte stream, decode each codepoint,
//  and count those in Hangul ranges:
//    Syllables : U+AC00..U+D7A3   →  3-byte UTF-8 lead 0xEA-0xED
//    Jamo      : U+3131..U+318E   →  3-byte UTF-8 lead 0xE3
//  We use a precise codepoint decoder (not a sloppy lead-byte heuristic) to
//  avoid false positives on CJK punctuation that share lead bytes.
// ════════════════════════════════════════════════════════════════════

fn byte_at(s: string, i: int) -> int {
    // .substring returns the raw byte; convert via to_int on its char-code.
    // Hexa: we use char_code_at if available; otherwise pull byte via slice.
    let c = s.substring(i, i + 1)
    return char_code(c)
}

fn is_hangul_codepoint(cp: int) -> bool {
    if cp >= 0xAC00 && cp <= 0xD7A3 { return true }
    if cp >= 0x3131 && cp <= 0x318E { return true }
    return false
}

fn korean_ratio(text: string) -> float {
    let n = len(text)
    if n == 0 { return 0.0 }
    let mut hangul_chars = 0
    let mut total_chars = 0
    let mut i = 0
    while i < n {
        let b0 = byte_at(text, i)
        let mut cp = 0
        let mut step = 1
        if b0 < 0x80 {
            cp = b0
            step = 1
        } else if b0 < 0xC0 {
            // Stray continuation byte; skip without counting (malformed).
            i = i + 1
            continue
        } else if b0 < 0xE0 {
            // 2-byte sequence: 110xxxxx 10xxxxxx
            if i + 1 >= n { break }
            let b1 = byte_at(text, i + 1)
            cp = ((b0 - 0xC0) * 64) + (b1 - 0x80)
            step = 2
        } else if b0 < 0xF0 {
            // 3-byte sequence: 1110xxxx 10xxxxxx 10xxxxxx
            if i + 2 >= n { break }
            let b1 = byte_at(text, i + 1)
            let b2 = byte_at(text, i + 2)
            cp = ((b0 - 0xE0) * 4096) + ((b1 - 0x80) * 64) + (b2 - 0x80)
            step = 3
        } else {
            // 4-byte sequence: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
            if i + 3 >= n { break }
            let b1 = byte_at(text, i + 1)
            let b2 = byte_at(text, i + 2)
            let b3 = byte_at(text, i + 3)
            cp = ((b0 - 0xF0) * 262144) + ((b1 - 0x80) * 4096) + ((b2 - 0x80) * 64) + (b3 - 0x80)
            step = 4
        }
        total_chars = total_chars + 1
        if is_hangul_codepoint(cp) { hangul_chars = hangul_chars + 1 }
        i = i + step
    }
    if total_chars == 0 { return 0.0 }
    return to_float(hangul_chars) / to_float(total_chars)
}

// ════════════════════════════════════════════════════════════════════
//  Section 4. ALM /generate round-trip via curl exec().
//             Reply struct has 1 float (phi_holo) — well under the
//             ≥3 float corruption threshold.
// ════════════════════════════════════════════════════════════════════

struct Reply {
    text: string,
    phi_holo: float,
    lat_ms: int,
    tokens_generated: int,
    ok: bool,
    error: string
}

fn call_alm(endpoint: string, prompt: string, max_tokens: int, temperature: float) -> Reply {
    let body = "{\"prompt\":\"" + json_escape(prompt)
             + "\",\"max_tokens\":" + to_string(max_tokens)
             + ",\"temperature\":" + to_string(temperature)
             + ",\"top_p\":" + to_string(DEFAULT_TOP_P)
             + ",\"repetition_penalty\":" + to_string(DEFAULT_REP_PENALTY) + "}"
    let body_sh = shell_escape_sq(body)
    let cmd = "curl -sX POST " + endpoint + "/generate"
            + " -H 'Content-Type: application/json'"
            + " -d '" + body_sh + "'"
            + " -w '\\n__LATENCY__%{time_total}\\n'"
            + " --connect-timeout 15 --max-time 120 2>/dev/null"
    let raw = exec(cmd)
    if len(raw) == 0 {
        return Reply { text: "", phi_holo: 0.0, lat_ms: 0, tokens_generated: 0, ok: false, error: "empty_response" }
    }
    let text = extract_json_string(raw, "\"text\":")
    if len(text) == 0 {
        return Reply { text: "", phi_holo: 0.0, lat_ms: 0, tokens_generated: 0, ok: false, error: "no_text_field" }
    }
    let phi = extract_json_number(raw, "\"phi_holo\":")
    let n_tok = extract_json_int(raw, "\"tokens_generated\":")
    let secs = extract_json_number(raw, "__LATENCY__")
    let lat = to_int(secs * 1000.0)
    return Reply { text: text, phi_holo: phi, lat_ms: lat, tokens_generated: n_tok, ok: true, error: "" }
}

// ════════════════════════════════════════════════════════════════════
//  Section 5. Per-prompt JSON sample emitter.
//  ────────────────────────────────────────────────────────────────────
//  Single-pass string concat per sample; outer driver joins with ",\n".
//  We never store samples in a struct array (avoids the struct-list
//  aliasing bug).
// ════════════════════════════════════════════════════════════════════

fn sample_json(prompt: string, reply: Reply, kr: float, idx: int, total: int) -> string {
    let comma = if idx + 1 < total { "," } else { "" }
    let ok_lit = if reply.ok { "true" } else { "false" }
    return "    {\n"
         + "      \"idx\":           " + to_string(idx) + ",\n"
         + "      \"prompt\":        \"" + json_escape(prompt) + "\",\n"
         + "      \"response\":      \"" + json_escape(reply.text) + "\",\n"
         + "      \"phi_holo\":      " + to_string(reply.phi_holo) + ",\n"
         + "      \"korean_ratio\":  " + to_string(kr) + ",\n"
         + "      \"tokens\":        " + to_string(reply.tokens_generated) + ",\n"
         + "      \"lat_ms\":        " + to_string(reply.lat_ms) + ",\n"
         + "      \"ok\":            " + ok_lit + ",\n"
         + "      \"error\":         \"" + json_escape(reply.error) + "\"\n"
         + "    }" + comma
}

// ════════════════════════════════════════════════════════════════════
//  Section 6. Output JSON assembler — same shape as the .py output,
//             with ce_loss / perplexity / blocker fields.
// ════════════════════════════════════════════════════════════════════

// NB: linter wants to dangle the `)` on its own line; hexa parser rejects
// trailing commas in fn param lists, so keep the closing paren glued to the
// last param.
fn assemble_output_json(ckpt: string, base: string, endpoint: string, timestamp: string, n_prompts: int, samples_body: string, avg_kr: float, tokens_per_sec: float, max_tokens: int, temperature: float, blocker: string, kr_verdict: string) -> string {
    return "{\n"
         + "  \"harness\":          \"eval_alm_14b.hexa\",\n"
         + "  \"harness_version\":  \"" + HARNESS_VERSION + "\",\n"
         + "  \"ckpt\":             \"" + ckpt + "\",\n"
         + "  \"base\":             \"" + base + "\",\n"
         + "  \"model\":            \"" + MODEL_TAG + "\",\n"
         + "  \"endpoint\":         \"" + endpoint + "\",\n"
         + "  \"timestamp\":        \"" + timestamp + "\",\n"
         + "  \"n_prompts\":        " + to_string(n_prompts) + ",\n"
         + "  \"max_tokens\":       " + to_string(max_tokens) + ",\n"
         + "  \"temperature\":      " + to_string(temperature) + ",\n"
         + "  \"ce_loss\":          -1.0,\n"
         + "  \"perplexity\":       -1.0,\n"
         + "  \"perplexity_pass\":  null,\n"
         + "  \"avg_korean_ratio\": " + to_string(avg_kr) + ",\n"
         + "  \"korean_ratio_pass\": " + kr_verdict + ",\n"
         + "  \"tokens_per_sec\":   " + to_string(tokens_per_sec) + ",\n"
         + "  \"blocker\":          \"" + json_escape(blocker) + "\",\n"
         + "  \"generations\": [\n"
         + samples_body
         + "\n  ]\n"
         + "}\n"
}

// ════════════════════════════════════════════════════════════════════
//  Section 7. Driver — iterate prompts, emit JSON.
// ════════════════════════════════════════════════════════════════════

fn run_eval(ckpt: string, base: string, endpoint: string, out_path: string, max_tokens: int, quick: bool) -> int {
    let all_prompts = build_prompts()
    let total_avail = len(all_prompts)
    let mut total = total_avail
    if quick && 3 < total_avail { total = 3 }

    let timestamp = exec("date '+%Y-%m-%d %H:%M:%S' | tr -d '\\n'")

    println("============================================================")
    println("[eval_alm_14b] " + HARNESS_VERSION + " (pure-hexa)")
    println("============================================================")
    println("[eval_alm_14b] ckpt:       " + ckpt)
    println("[eval_alm_14b] base:       " + base)
    println("[eval_alm_14b] endpoint:   " + endpoint)
    println("[eval_alm_14b] out:        " + out_path)
    println("[eval_alm_14b] n_prompts:  " + to_string(total) + " of " + to_string(total_avail))
    println("[eval_alm_14b] max_tokens: " + to_string(max_tokens))
    println("[eval_alm_14b] quick:      " + to_string(quick))
    println("")

    println("[eval_alm_14b] === PERPLEXITY ===")
    println("  ce_loss:    BLOCKED (no logits route — see file header)")
    println("  perplexity: BLOCKED")
    println("")

    println("[eval_alm_14b] === KOREAN GENERATION ===")
    let mut samples_body = ""
    let mut ok_count = 0
    let mut total_tokens = 0
    let mut total_lat_ms = 0
    let mut sum_kr = 0.0
    let mut i = 0
    while i < total {
        let prompt = all_prompts[i]
        println("")
        println("  Q[" + to_string(i + 1) + "/" + to_string(total) + "]: " + prompt)
        let r = call_alm(endpoint, prompt, max_tokens, DEFAULT_TEMPERATURE)
        let kr = if r.ok { korean_ratio(r.text) } else { 0.0 }
        if r.ok {
            ok_count = ok_count + 1
            total_tokens = total_tokens + r.tokens_generated
            total_lat_ms = total_lat_ms + r.lat_ms
            sum_kr = sum_kr + kr
            // Preview: first 80 BYTES — multibyte chars may clip mid-codepoint;
            // OK for log readability (don't write back into JSON).
            let preview_len = if len(r.text) < 80 { len(r.text) } else { 80 }
            let preview = r.text.substring(0, preview_len)
            let suffix = if len(r.text) > 80 { "..." } else { "" }
            println("  A: " + preview + suffix)
            println("     korean=" + to_string(kr)
                  + " tokens=" + to_string(r.tokens_generated)
                  + " lat=" + to_string(r.lat_ms) + "ms"
                  + " phi=" + to_string(r.phi_holo))
        } else {
            println("  !! ERROR: " + r.error)
        }
        let chunk = sample_json(prompt, r, kr, i, total)
        samples_body = samples_body + chunk + (if i + 1 < total { "\n" } else { "" })
        i = i + 1
    }

    let avg_kr = if ok_count > 0 { sum_kr / to_float(ok_count) } else { 0.0 }
    let total_lat_s = to_float(total_lat_ms) / 1000.0
    let tps_denom = if total_lat_s < 0.01 { 0.01 } else { total_lat_s }
    let tokens_per_sec = to_float(total_tokens) / tps_denom

    let kr_verdict = if avg_kr > KOREAN_RATIO_PASS { "true" } else { "false" }
    let kr_label = if avg_kr > KOREAN_RATIO_PASS { "PASS" } else { "FAIL" }

    let blocker = "ce_loss/perplexity NOT measured: serve_alm_14b /generate returns text-only (no logits/loss). Add POST /loss to serve or hxqwen14b FFI to restore."

    // NB: linter wants to add a trailing comma — keep the closing paren on
    // the same line as the last arg to defeat that, since hexa parser
    // rejects trailing commas in call arg lists.
    let body = assemble_output_json(ckpt, base, endpoint, timestamp, total, samples_body, avg_kr, tokens_per_sec, max_tokens, DEFAULT_TEMPERATURE, blocker, kr_verdict)
    write_file(out_path, body)

    println("")
    println("============================================================")
    println("[eval_alm_14b] RESULTS SUMMARY")
    println("============================================================")
    println("  Perplexity:    BLOCKED (see blocker field in output JSON)")
    println("  Korean ratio:  " + to_string(avg_kr) + " (" + kr_label + ")")
    println("  Speed:         " + to_string(tokens_per_sec) + " tok/s")
    println("  OK count:      " + to_string(ok_count) + " / " + to_string(total))
    println("============================================================")
    println("[eval_alm_14b] saved -> " + out_path)

    if ok_count == total { return 0 } else { return 1 }
}

// ════════════════════════════════════════════════════════════════════
//  Section 8. CLI entrypoint.
// ════════════════════════════════════════════════════════════════════

fn print_usage() {
    println("usage: hexa run training/eval_alm_14b.hexa --ckpt <path>")
    println("       [--base <model>] [--endpoint <url>] [--out <path>]")
    println("       [--max-tokens N] [--quick]")
    println("")
    println("env vars:")
    println("  ALM_EVAL_ENDPOINT   overrides --endpoint")
    println("  ALM_EVAL_OUT        overrides --out (default <ckpt>/eval_results.json)")
    println("  ALM_EVAL_QUICK=1    short-circuit to first 3 prompts")
}

fn main() -> int {
    let av = args()
    let mut ckpt = ""
    let mut base = DEFAULT_BASE_MODEL
    let mut endpoint = env_var("ALM_EVAL_ENDPOINT")
    if endpoint == "" { endpoint = DEFAULT_ENDPOINT }
    let mut out_path = env_var("ALM_EVAL_OUT")
    let mut max_tokens = DEFAULT_MAX_TOKENS
    let mut quick = false
    if env_var("ALM_EVAL_QUICK") == "1" { quick = true }

    let mut i = 2
    let argc = len(av)
    while i < argc {
        let a = av[i]
        if a == "--ckpt" {
            if i + 1 < argc { ckpt = av[i + 1] }
            i = i + 2
        } else if a == "--base" {
            if i + 1 < argc { base = av[i + 1] }
            i = i + 2
        } else if a == "--endpoint" {
            if i + 1 < argc { endpoint = av[i + 1] }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < argc { out_path = av[i + 1] }
            i = i + 2
        } else if a == "--max-tokens" {
            if i + 1 < argc { max_tokens = parse_int(av[i + 1]) }
            i = i + 2
        } else if a == "--quick" {
            quick = true
            i = i + 1
        } else if a == "--help" {
            print_usage()
            return 0
        } else {
            i = i + 1
        }
    }

    if ckpt == "" {
        println("[eval_alm_14b] ERROR: --ckpt is required")
        print_usage()
        return 2
    }
    if out_path == "" { out_path = ckpt + "/eval_results.json" }

    return run_eval(ckpt, base, endpoint, out_path, max_tokens, quick)
}

