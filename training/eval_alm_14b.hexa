// eval_alm_14b.hexa — ALM 14B LoRA checkpoint evaluation launcher
//
// Wraps the Python evaluation logic via exec(). The actual eval
// (perplexity, Korean generation quality, Korean char ratio) uses
// torch/transformers/peft and must run as Python.
//
// Usage:
//   hexa eval_alm_14b.hexa --ckpt /workspace/ckpt_alm_14b_r2/step_10000
//   hexa eval_alm_14b.hexa --ckpt /workspace/ckpt_alm_14b_r2/step_10000 --quick

fn main() {
    let argv = args()
    let mut ckpt = ""
    let mut base = "Qwen/Qwen2.5-14B-Instruct"
    let mut max_tokens = "128"
    let mut quick_flag = ""

    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--ckpt" {
            i = i + 1
            if i < argc {
                ckpt = argv[i]
            }
        }
        if argv[i] == "--base" {
            i = i + 1
            if i < argc {
                base = argv[i]
            }
        }
        if argv[i] == "--max-tokens" {
            i = i + 1
            if i < argc {
                max_tokens = argv[i]
            }
        }
        if argv[i] == "--quick" {
            quick_flag = " --quick"
        }
        i = i + 1
    }

    if ckpt == "" {
        println("[eval_alm_14b] ERROR: --ckpt is required")
        println("  Usage: hexa eval_alm_14b.hexa --ckpt <path> [--base <model>] [--max-tokens N] [--quick]")
        exec("exit 1")
    }

    println("[eval_alm_14b] ckpt:       " + ckpt)
    println("[eval_alm_14b] base:       " + base)
    println("[eval_alm_14b] max_tokens: " + max_tokens)

    // Write the Python eval script to a temp file and exec it.
    // This avoids string-escape issues with inline Python in hexa.
    let py_script = "/tmp/_eval_alm_14b_runner.py"

    write_file(py_script,
        "#!/usr/bin/env python3\n" +
        "\"\"\"eval_alm_14b — ALM 14B LoRA checkpoint evaluation (auto-generated by eval_alm_14b.hexa)\"\"\"\n" +
        "import argparse, json, math, sys, time\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import PeftModel\n" +
        "\n" +
        "PROMPTS = [\n" +
        "    '\\uc548\\ub155\\ud558\\uc138\\uc694. \\uc758\\uc2dd\\uc774\\ub780 \\ubb34\\uc5c7\\uc778\\uac00\\uc694?',\n" +
        "    '\\uc778\\uacf5\\uc9c0\\ub2a5\\uc774 \\uc758\\uc2dd\\uc744 \\uac00\\uc9c8 \\uc218 \\uc788\\uc744\\uae4c\\uc694?',\n" +
        "    '\\uc624\\ub298 \\ub0a0\\uc528\\uac00 \\uc88b\\ub124\\uc694. \\uc0b0\\ucc45\\ud558\\ub7ec \\uac08\\uae4c\\uc694?',\n" +
        "    '\\ud2b8\\ub79c\\uc2a4\\ud3ec\\uba38 \\uc544\\ud0a4\\ud14d\\ucc98\\uc758 \\ud575\\uc2ec\\uc744 \\uc124\\uba85\\ud574\\uc8fc\\uc138\\uc694.',\n" +
        "    '\\ud55c\\uad6d\\uc5b4 \\ubc14\\uc774\\ud2b8 \\uc218\\uc900 \\uc5b8\\uc5b4 \\ubaa8\\ub378\\uc758 \\uc7a5\\uc810\\uc740?',\n" +
        "]\n" +
        "\n" +
        "HELD_OUT = (\n" +
        "    '\\uc758\\uc2dd\\uc758 \\uacfc\\ud559\\uc801 \\uc5f0\\uad6c\\ub294 20\\uc138\\uae30 \\ud6c4\\ubc18\\uc5d0 \\ube44\\ub85c\\uc18c \\ubcf8\\uaca9\\uc801\\uc73c\\ub85c \\uc2dc\\uc791\\ub418\\uc5c8\\ub2e4.\\n'\n" +
        "    '\\uc2e0\\uacbd\\uacfc\\ud559\\uc790\\ub4e4\\uc740 \\uc758\\uc2dd\\uc758 \\uc2e0\\uacbd\\uc0c1\\uad00\\ubb3c\\uc744 \\ucc3e\\uae30 \\uc704\\ud574 \\ub2e4\\uc591\\ud55c \\uc2e4\\ud5d8\\uc744 \\uc218\\ud589\\ud588\\ub2e4.\\n'\n" +
        "    '\\ud1b5\\ud569\\uc815\\ubcf4\\uc774\\ub860\\uc740 \\uc758\\uc2dd\\uc744 \\uc815\\ubcf4 \\ud1b5\\ud569\\uc758 \\uad00\\uc810\\uc5d0\\uc11c \\uc124\\uba85\\ud558\\ub824\\ub294 \\uc2dc\\ub3c4\\uc774\\ub2e4.\\n'\n" +
        "    '\\uc774 \\uc774\\ub860\\uc5d0 \\ub530\\ub974\\uba74 \\uc758\\uc2dd\\uc758 \\uc218\\uc900\\uc740 \\uc2dc\\uc2a4\\ud15c\\uc758 \\ud1b5\\ud569 \\uc815\\ubcf4\\ub7c9\\uc73c\\ub85c \\uce21\\uc815\\ud560 \\uc218 \\uc788\\ub2e4.'\n" +
        ")\n" +
        "\n" +
        "def load_model(ckpt_path, base):\n" +
        "    print(f'[eval] loading base: {base}')\n" +
        "    tokenizer = AutoTokenizer.from_pretrained(base, trust_remote_code=True)\n" +
        "    model = AutoModelForCausalLM.from_pretrained(base, torch_dtype=torch.bfloat16, device_map='auto', trust_remote_code=True)\n" +
        "    print(f'[eval] loading LoRA: {ckpt_path}')\n" +
        "    model = PeftModel.from_pretrained(model, ckpt_path)\n" +
        "    model.eval()\n" +
        "    return model, tokenizer\n" +
        "\n" +
        "def measure_perplexity(model, tokenizer, text, max_len=512):\n" +
        "    tokens = tokenizer(text, return_tensors='pt', truncation=True, max_length=max_len)\n" +
        "    input_ids = tokens.input_ids.to(model.device)\n" +
        "    with torch.no_grad():\n" +
        "        outputs = model(input_ids=input_ids, labels=input_ids)\n" +
        "    ppl = math.exp(outputs.loss.item())\n" +
        "    return outputs.loss.item(), ppl\n" +
        "\n" +
        "def generate_korean(model, tokenizer, prompt, max_new=128):\n" +
        "    inputs = tokenizer(prompt, return_tensors='pt').to(model.device)\n" +
        "    t0 = time.time()\n" +
        "    with torch.no_grad():\n" +
        "        out = model.generate(**inputs, max_new_tokens=max_new, do_sample=True, temperature=0.7, top_p=0.9, repetition_penalty=1.1)\n" +
        "    elapsed = time.time() - t0\n" +
        "    generated = tokenizer.decode(out[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)\n" +
        "    tokens_generated = out.shape[1] - inputs.input_ids.shape[1]\n" +
        "    return generated, elapsed, tokens_generated\n" +
        "\n" +
        "def korean_ratio(text):\n" +
        "    if not text: return 0.0\n" +
        "    hangul = sum(1 for c in text if '\\uAC00' <= c <= '\\uD7A3' or '\\u3131' <= c <= '\\u318E')\n" +
        "    return hangul / len(text)\n" +
        "\n" +
        "if __name__ == '__main__':\n" +
        "    parser = argparse.ArgumentParser()\n" +
        "    parser.add_argument('--ckpt', required=True)\n" +
        "    parser.add_argument('--base', default='Qwen/Qwen2.5-14B-Instruct')\n" +
        "    parser.add_argument('--max-tokens', type=int, default=128)\n" +
        "    parser.add_argument('--quick', action='store_true')\n" +
        "    args = parser.parse_args()\n" +
        "    model, tokenizer = load_model(args.ckpt, args.base)\n" +
        "    results = {'ckpt': args.ckpt, 'base': args.base, 'timestamp': time.strftime('%Y-%m-%d %H:%M:%S')}\n" +
        "    print('\\n[eval] === PERPLEXITY ===')\n" +
        "    ce, ppl = measure_perplexity(model, tokenizer, HELD_OUT)\n" +
        "    results['ce_loss'] = round(ce, 4)\n" +
        "    results['perplexity'] = round(ppl, 2)\n" +
        "    print(f'  CE loss: {ce:.4f}')\n" +
        "    print(f'  PPL:     {ppl:.2f}')\n" +
        "    print(f'  {\"PASS\" if ppl < 50 else \"FAIL\"} (threshold < 50)')\n" +
        "    print('\\n[eval] === KOREAN GENERATION ===')\n" +
        "    generations = []\n" +
        "    total_tokens = 0\n" +
        "    total_time = 0\n" +
        "    for prompt in (PROMPTS[:3] if args.quick else PROMPTS):\n" +
        "        gen, elapsed, n_tok = generate_korean(model, tokenizer, prompt, max_new=args.max_tokens)\n" +
        "        kr = korean_ratio(gen)\n" +
        "        total_tokens += n_tok\n" +
        "        total_time += elapsed\n" +
        "        print(f'\\n  Q: {prompt}')\n" +
        "        print(f'  A: {gen[:200]}{\"...\" if len(gen) > 200 else \"\"}')\n" +
        "        print(f'  korean={kr:.1%} tokens={n_tok} time={elapsed:.1f}s')\n" +
        "        generations.append({'prompt': prompt, 'response': gen, 'korean_ratio': round(kr, 3), 'tokens': n_tok, 'time_s': round(elapsed, 1)})\n" +
        "    results['generations'] = generations\n" +
        "    results['avg_korean_ratio'] = round(sum(g['korean_ratio'] for g in generations) / len(generations), 3)\n" +
        "    results['tokens_per_sec'] = round(total_tokens / max(total_time, 0.01), 1)\n" +
        "    sep = '=' * 60\n" +
        "    print(f'\\n{sep}')\n" +
        "    print('[eval] RESULTS SUMMARY')\n" +
        "    print(sep)\n" +
        "    ppl_verdict = 'PASS' if results['perplexity'] < 50 else 'FAIL'\n" +
        "    kr_verdict = 'PASS' if results['avg_korean_ratio'] > 0.2 else 'FAIL'\n" +
        "    print(f'  Perplexity:    {results[\"perplexity\"]:.2f} ({ppl_verdict})')\n" +
        "    print(f'  Korean ratio:  {results[\"avg_korean_ratio\"]:.1%} ({kr_verdict})')\n" +
        "    print(f'  Speed:         {results[\"tokens_per_sec\"]:.1f} tok/s')\n" +
        "    print(sep)\n" +
        "    from pathlib import Path as P\n" +
        "    out_path = P(args.ckpt) / 'eval_results.json'\n" +
        "    with open(out_path, 'w') as f:\n" +
        "        json.dump(results, f, indent=2, ensure_ascii=False)\n" +
        "    print(f'[eval] saved -> {out_path}')\n"
    )

    let cmd = "python3 " + py_script + " --ckpt " + ckpt + " --base " + base + " --max-tokens " + max_tokens + quick_flag
    exec(cmd)
}

main()
