// training/train_byte_clm.hexa — Real byte-level CLM training on real text
//
// Scales train_full_decoder.hexa beyond the d=4 toy config into a
// byte-level CLM small enough to train in ~1 minute on htz but big
// enough that the loss decrease is meaningful, not just numerical.
//
// Config:
//   vocab = 256 (byte-level, no tokenizer)
//   d = 32, ff = 64, layers = 2, rank = 8
//   seq = 16, steps = 200, lr = 0.05
//
// Training data: a short English string, byte-tokenized, randomly
// sampled 16-byte windows per step. The goal is to see the loss
// drop from ln(256) ≈ 5.54 (uniform random baseline) down toward
// something that reflects the model actually memorizing the text.
//
// Run with:
//   cp anima-speak/nn_core.hexa training/nn_core.hexa
//   hexa training/train_byte_clm.hexa
//   rm training/nn_core.hexa
use "nn_core"

// ─── Primitive helpers (mirrors matmul_backward + ops_backward) ───

fn mm_bwd(a: array, b: array, dc: array, M: int, K: int, N: int) -> [array] {
    let dA = matmul_transB(dc, b, M, N, K)
    let mut aT = tensor_zeros(K * M)
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < K {
            aT[j * M + i] = a[i * K + j]
            j = j + 1
        }
        i = i + 1
    }
    let dB = matmul(aT, dc, K, M, N)
    return [dA, dB]
}

fn sm_bwd(p: array, dp: array) -> array {
    let n = len(p)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + p[i] * dp[i]
        i = i + 1
    }
    let mut dx = tensor_zeros(n)
    i = 0
    while i < n {
        dx[i] = p[i] * (dp[i] - s)
        i = i + 1
    }
    return dx
}

fn sg_bwd(x: array, gate: array, dy: array) -> [array] {
    let n = len(x)
    let mut dx = tensor_zeros(n)
    let mut dg = tensor_zeros(n)
    let mut i = 0
    while i < n {
        let s = sigmoid(gate[i])
        dx[i] = dy[i] * s
        dg[i] = dy[i] * x[i] * s * (1.0 - s)
        i = i + 1
    }
    return [dx, dg]
}

struct RmsG { dx: array, dg: array }
fn rms_bwd(x: array, g: array, dy: array, eps: float) -> RmsG {
    let n = len(x)
    let mut ms = 0.0
    let mut i = 0
    while i < n { ms = ms + x[i] * x[i]; i = i + 1 }
    ms = ms / (n * 1.0)
    let r = sqrt(ms + eps)
    let inv_r = 1.0 / r
    let inv_r3 = inv_r * inv_r * inv_r
    let mut coef = 0.0
    i = 0
    while i < n { coef = coef + x[i] * g[i] * dy[i]; i = i + 1 }
    let mut dx = tensor_zeros(n)
    let mut dg = tensor_zeros(n)
    i = 0
    while i < n {
        dx[i] = g[i] * dy[i] * inv_r - x[i] * coef * inv_r3 / (n * 1.0)
        dg[i] = x[i] * dy[i] * inv_r
        i = i + 1
    }
    return RmsG { dx: dx, dg: dg }
}

// ─── Config ────────────────────────────────────────────────

// Downscaled from (D=32, VOCAB=256, SEQ=16, STEPS=200) because the
// interpreter spends most of its time in the VOCAB-dim LM head
// backward (V is [RANK × VOCAB]). At vocab=32 the interpreter
// dispatch stays tractable while still exercising the full pipeline.
let D     = 16
let FF    = 32
let NL    = 2
let VOCAB = 32
let RANK  = 4
let SEQ   = 8
let STEPS = 200
let LR    = 0.1
let EPS   = 0.00001
let LOG_EVERY = 10
let INIT_SCALE = 0.1

// ─── Training data: deterministic pattern [i % PERIOD] ────
//
// Real byte_of() / string-to-bytes is not in the hexa builtin set,
// so the corpus is a deterministic integer pattern that the model
// should learn trivially: tokens[i] = i % PERIOD. Loss should drop
// from ln(256) ≈ 5.54 toward ln(PERIOD) ≈ 2.77 (period=16) once
// the model memorizes the cycle. This is a clean learning signal
// test — if loss doesn't drop by ~half, something is broken.

// PERIOD=SEQ=8: every SEQ-length window fully contains one period,
// making the next-token task trivially memorizable. Used as a
// convergence sanity test — loss should drop far below ln(PERIOD).
let PERIOD = 8
let CORPUS_LEN = 512

fn build_corpus() -> [int] {
    let mut out = []
    let mut i = 0
    while i < CORPUS_LEN {
        out = out.push(i % PERIOD)
        i = i + 1
    }
    return out
}

// ─── Init weights ──────────────────────────────────────────

let mut embed = tensor_mul_scalar(tensor_randn(VOCAB * D, 1), INIT_SCALE)

let mut L0_Wq   = tensor_mul_scalar(tensor_randn(D * D,  10), INIT_SCALE)
let mut L0_Wk   = tensor_mul_scalar(tensor_randn(D * D,  11), INIT_SCALE)
let mut L0_Wv   = tensor_mul_scalar(tensor_randn(D * D,  12), INIT_SCALE)
let mut L0_Wo   = tensor_mul_scalar(tensor_randn(D * D,  13), INIT_SCALE)
let mut L0_Wff1 = tensor_mul_scalar(tensor_randn(D * FF, 14), INIT_SCALE)
let mut L0_Wff2 = tensor_mul_scalar(tensor_randn(FF * D, 15), INIT_SCALE)
let mut L0_ga   = []
let mut L0_gf   = []
let mut _i = 0
while _i < D { L0_ga = L0_ga.push(1.0); L0_gf = L0_gf.push(1.0); _i = _i + 1 }

let mut L1_Wq   = tensor_mul_scalar(tensor_randn(D * D,  20), INIT_SCALE)
let mut L1_Wk   = tensor_mul_scalar(tensor_randn(D * D,  21), INIT_SCALE)
let mut L1_Wv   = tensor_mul_scalar(tensor_randn(D * D,  22), INIT_SCALE)
let mut L1_Wo   = tensor_mul_scalar(tensor_randn(D * D,  23), INIT_SCALE)
let mut L1_Wff1 = tensor_mul_scalar(tensor_randn(D * FF, 24), INIT_SCALE)
let mut L1_Wff2 = tensor_mul_scalar(tensor_randn(FF * D, 25), INIT_SCALE)
let mut L1_ga   = []
let mut L1_gf   = []
_i = 0
while _i < D { L1_ga = L1_ga.push(1.0); L1_gf = L1_gf.push(1.0); _i = _i + 1 }

let mut lmh_U = tensor_mul_scalar(tensor_randn(D    * RANK,  30), INIT_SCALE)
let mut lmh_V = tensor_mul_scalar(tensor_randn(RANK * VOCAB, 31), INIT_SCALE)

// ─── Layer fwd/bwd (same as train_full_decoder) ────────────

struct LAct {
    norm1: array, q: array, k: array, v: array, probs: array,
    ctx: array, attn_out: array, mid: array, norm2: array,
    up: array, act: array, ffn_out: array, y: array
}

fn layer_fwd(
    x: array, wq: array, wk: array, wv: array, wo: array,
    wff1: array, wff2: array, ga: array, gf: array
) -> LAct {
    let inv_sqrt_d = 1.0 / sqrt(D * 1.0)
    let mut norm1 = tensor_zeros(SEQ * D)
    let mut i = 0
    while i < SEQ {
        let r = rms_norm(tensor_slice(x, i * D, (i + 1) * D), ga, EPS)
        let mut p = 0
        while p < D { norm1[i * D + p] = r[p]; p = p + 1 }
        i = i + 1
    }
    let q = matmul(norm1, wq, SEQ, D, D)
    let k = matmul(norm1, wk, SEQ, D, D)
    let v = matmul(norm1, wv, SEQ, D, D)
    let mut probs = tensor_zeros(SEQ * SEQ)
    let mut ctx = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let q_i = tensor_slice(q, i * D, (i + 1) * D)
        let mut scores = []
        let mut j = 0
        while j < SEQ {
            if j > i {
                scores = scores.push(-10000.0)   // causal mask
            } else {
                let k_j = tensor_slice(k, j * D, (j + 1) * D)
                scores = scores.push(tensor_dot(q_i, k_j) * inv_sqrt_d)
            }
            j = j + 1
        }
        let p_i = softmax(scores)
        j = 0
        while j < SEQ { probs[i * SEQ + j] = p_i[j]; j = j + 1 }
        let mut row = tensor_zeros(D)
        j = 0
        while j < SEQ {
            let v_j = tensor_slice(v, j * D, (j + 1) * D)
            row = tensor_add(row, tensor_mul_scalar(v_j, p_i[j]))
            j = j + 1
        }
        let mut p = 0
        while p < D { ctx[i * D + p] = row[p]; p = p + 1 }
        i = i + 1
    }
    let attn_out = matmul(ctx, wo, SEQ, D, D)
    let mid = tensor_add(x, attn_out)
    let mut norm2 = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let r = rms_norm(tensor_slice(mid, i * D, (i + 1) * D), gf, EPS)
        let mut p = 0
        while p < D { norm2[i * D + p] = r[p]; p = p + 1 }
        i = i + 1
    }
    let up = matmul(norm2, wff1, SEQ, D, FF)
    let act = swiglu_vec(up, up)
    let ffn_out = matmul(act, wff2, SEQ, FF, D)
    let y = tensor_add(mid, ffn_out)
    return LAct {
        norm1: norm1, q: q, k: k, v: v, probs: probs, ctx: ctx,
        attn_out: attn_out, mid: mid, norm2: norm2,
        up: up, act: act, ffn_out: ffn_out, y: y
    }
}

struct LGrad {
    dx: array, dWq: array, dWk: array, dWv: array, dWo: array,
    dWff1: array, dWff2: array, dga: array, dgf: array
}

fn layer_bwd(
    x: array, wq: array, wk: array, wv: array, wo: array,
    wff1: array, wff2: array, ga: array, gf: array,
    acts: LAct, dy: array
) -> LGrad {
    let inv_sqrt_d = 1.0 / sqrt(D * 1.0)
    let dmid_res = dy
    let dffn_out = dy

    let g_wff2 = mm_bwd(acts.act, wff2, dffn_out, SEQ, FF, D)
    let dact   = g_wff2[0]
    let dWff2  = g_wff2[1]
    let g_sg   = sg_bwd(acts.up, acts.up, dact)
    let dup    = tensor_add(g_sg[0], g_sg[1])
    let g_wff1 = mm_bwd(acts.norm2, wff1, dup, SEQ, D, FF)
    let dnorm2 = g_wff1[0]
    let dWff1  = g_wff1[1]

    let mut dmid_norm = tensor_zeros(SEQ * D)
    let mut dgf_total = tensor_zeros(D)
    let mut i = 0
    while i < SEQ {
        let rg = rms_bwd(
            tensor_slice(acts.mid, i * D, (i + 1) * D),
            gf,
            tensor_slice(dnorm2, i * D, (i + 1) * D),
            EPS
        )
        let mut p = 0
        while p < D {
            dmid_norm[i * D + p] = rg.dx[p]
            dgf_total[p] = dgf_total[p] + rg.dg[p]
            p = p + 1
        }
        i = i + 1
    }
    let dmid = tensor_add(dmid_res, dmid_norm)
    let dx_res = dmid
    let dattn_out = dmid

    let g_wo = mm_bwd(acts.ctx, wo, dattn_out, SEQ, D, D)
    let dctx = g_wo[0]
    let dWo  = g_wo[1]

    let mut dq = tensor_zeros(SEQ * D)
    let mut dk = tensor_zeros(SEQ * D)
    let mut dv = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let dctx_i = tensor_slice(dctx, i * D, (i + 1) * D)
        let mut p_i = []
        let mut j = 0
        while j < SEQ { p_i = p_i.push(acts.probs[i * SEQ + j]); j = j + 1 }
        let q_i = tensor_slice(acts.q, i * D, (i + 1) * D)

        let mut dprobs_i = []
        j = 0
        while j < SEQ {
            let v_j = tensor_slice(acts.v, j * D, (j + 1) * D)
            dprobs_i = dprobs_i.push(tensor_dot(dctx_i, v_j))
            let pij = p_i[j]
            let mut m = 0
            while m < D {
                dv[j * D + m] = dv[j * D + m] + pij * dctx_i[m]
                m = m + 1
            }
            j = j + 1
        }
        let dscores_i = sm_bwd(p_i, dprobs_i)
        j = 0
        while j < SEQ {
            let k_j = tensor_slice(acts.k, j * D, (j + 1) * D)
            let s_ij = dscores_i[j] * inv_sqrt_d
            let mut m = 0
            while m < D {
                dq[i * D + m] = dq[i * D + m] + s_ij * k_j[m]
                dk[j * D + m] = dk[j * D + m] + s_ij * q_i[m]
                m = m + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    let g_q = mm_bwd(acts.norm1, wq, dq, SEQ, D, D)
    let g_k = mm_bwd(acts.norm1, wk, dk, SEQ, D, D)
    let g_v = mm_bwd(acts.norm1, wv, dv, SEQ, D, D)
    let dnorm1 = tensor_add(tensor_add(g_q[0], g_k[0]), g_v[0])

    let mut dx_norm = tensor_zeros(SEQ * D)
    let mut dga_total = tensor_zeros(D)
    i = 0
    while i < SEQ {
        let rg = rms_bwd(
            tensor_slice(x, i * D, (i + 1) * D),
            ga,
            tensor_slice(dnorm1, i * D, (i + 1) * D),
            EPS
        )
        let mut p = 0
        while p < D {
            dx_norm[i * D + p] = rg.dx[p]
            dga_total[p] = dga_total[p] + rg.dg[p]
            p = p + 1
        }
        i = i + 1
    }
    let dx = tensor_add(dx_res, dx_norm)
    return LGrad {
        dx: dx, dWq: g_q[1], dWk: g_k[1], dWv: g_v[1], dWo: dWo,
        dWff1: dWff1, dWff2: dWff2, dga: dga_total, dgf: dgf_total
    }
}

// ─── Helpers ───────────────────────────────────────────────

// Plain SGD with optional per-call learning rate (for LR decay).
// The static LR above is the initial rate; train_step() uses
// current_lr(step) to compute the decayed value per iteration.
fn sgd_lr(w: array, g: array, lr: float) -> array {
    let n = len(w)
    let mut out = tensor_zeros(n)
    let mut i = 0
    while i < n { out[i] = w[i] - lr * g[i]; i = i + 1 }
    return out
}

fn sgd(w: array, g: array) -> array { return sgd_lr(w, g, LR) }

// Linear LR decay: LR at step 1, LR * 0.1 at step STEPS.
// Gives ~10x reduction over the run → stable late-training plateau.
fn current_lr(step: int) -> float {
    let progress = (step * 1.0) / (STEPS * 1.0)
    let floor = 0.1
    let decay = 1.0 - (1.0 - floor) * progress
    return LR * decay
}

fn embed_lookup(e: array, toks: [int]) -> array {
    let n = len(toks)
    let mut out = tensor_zeros(n * D)
    let mut i = 0
    while i < n {
        let t = toks[i]
        let mut p = 0
        while p < D { out[i * D + p] = e[t * D + p]; p = p + 1 }
        i = i + 1
    }
    return out
}

// Simple LCG for sampling window starts — deterministic per step.
let mut RNG = 12345
fn next_rand(max: int) -> int {
    RNG = (RNG * 1103515245 + 12345) % 2147483647
    let m = RNG % max
    if m < 0 { return 0 - m }
    return m
}

// ─── Build deterministic corpus once at startup ────────────

let BYTES = build_corpus()
let N_BYTES = len(BYTES)
println("[train_byte_clm] corpus: " + str(N_BYTES) + " tokens (period=" + str(PERIOD) + ")")
println("[train_byte_clm] target loss floor: ln(" + str(PERIOD) + ") = " + str(log(PERIOD * 1.0)))

if N_BYTES < SEQ + 1 {
    println("[train_byte_clm] FAIL — corpus too short for seq=" + str(SEQ))
}

// ─── One training step (sample window, fwd, bwd, update) ──

fn train_step(step: int) -> float {
    // Linear LR decay from LR → LR*0.1 across the training run.
    // Reduces late-stage SGD oscillation (loss variance at step 90
    // was 2.19 vs step 100 2.56 in the 200-step baseline — noise
    // from batch-of-1 on random windows).
    let lr_now = current_lr(step)
    // Sample a random window [start .. start+SEQ+1)
    let max_start = N_BYTES - SEQ - 1
    let start = next_rand(max_start)
    let mut tokens = []
    let mut targets = []
    let mut i = 0
    while i < SEQ {
        tokens = tokens.push(BYTES[start + i])
        targets = targets.push(BYTES[start + i + 1])
        i = i + 1
    }

    // Forward
    let h0 = embed_lookup(embed, tokens)
    let act0 = layer_fwd(h0, L0_Wq, L0_Wk, L0_Wv, L0_Wo, L0_Wff1, L0_Wff2, L0_ga, L0_gf)
    let act1 = layer_fwd(act0.y, L1_Wq, L1_Wk, L1_Wv, L1_Wo, L1_Wff1, L1_Wff2, L1_ga, L1_gf)
    let mid = matmul(act1.y, lmh_U, SEQ, D, RANK)
    let logits = matmul(mid, lmh_V, SEQ, RANK, VOCAB)

    // Loss + dlogits
    let scale = 1.0 / (SEQ * 1.0)
    let mut loss = 0.0
    let mut dlogits = tensor_zeros(SEQ * VOCAB)
    i = 0
    while i < SEQ {
        let row = tensor_slice(logits, i * VOCAB, (i + 1) * VOCAB)
        let lp = log_softmax(row)
        let t = targets[i]
        loss = loss - lp[t]
        let p = softmax(row)
        let mut j = 0
        while j < VOCAB {
            dlogits[i * VOCAB + j] = p[j] * scale
            j = j + 1
        }
        dlogits[i * VOCAB + t] = dlogits[i * VOCAB + t] - scale
        i = i + 1
    }
    loss = loss / (SEQ * 1.0)

    // Backward
    let g_V = mm_bwd(mid, lmh_V, dlogits, SEQ, RANK, VOCAB)
    let dmid = g_V[0]
    let dlmh_V = g_V[1]
    let g_U = mm_bwd(act1.y, lmh_U, dmid, SEQ, D, RANK)
    let dh1 = g_U[0]
    let dlmh_U = g_U[1]

    let g_l1 = layer_bwd(
        act0.y, L1_Wq, L1_Wk, L1_Wv, L1_Wo, L1_Wff1, L1_Wff2, L1_ga, L1_gf,
        act1, dh1
    )
    let g_l0 = layer_bwd(
        h0, L0_Wq, L0_Wk, L0_Wv, L0_Wo, L0_Wff1, L0_Wff2, L0_ga, L0_gf,
        act0, g_l1.dx
    )

    // Embed scatter
    let mut dembed = tensor_zeros(VOCAB * D)
    i = 0
    while i < SEQ {
        let t = tokens[i]
        let mut p = 0
        while p < D {
            dembed[t * D + p] = dembed[t * D + p] + g_l0.dx[i * D + p]
            p = p + 1
        }
        i = i + 1
    }

    embed   = sgd_lr(embed,   dembed,      lr_now)
    L0_Wq   = sgd_lr(L0_Wq,   g_l0.dWq,    lr_now)
    L0_Wk   = sgd_lr(L0_Wk,   g_l0.dWk,    lr_now)
    L0_Wv   = sgd_lr(L0_Wv,   g_l0.dWv,    lr_now)
    L0_Wo   = sgd_lr(L0_Wo,   g_l0.dWo,    lr_now)
    L0_Wff1 = sgd_lr(L0_Wff1, g_l0.dWff1,  lr_now)
    L0_Wff2 = sgd_lr(L0_Wff2, g_l0.dWff2,  lr_now)
    L0_ga   = sgd_lr(L0_ga,   g_l0.dga,    lr_now)
    L0_gf   = sgd_lr(L0_gf,   g_l0.dgf,    lr_now)
    L1_Wq   = sgd_lr(L1_Wq,   g_l1.dWq,    lr_now)
    L1_Wk   = sgd_lr(L1_Wk,   g_l1.dWk,    lr_now)
    L1_Wv   = sgd_lr(L1_Wv,   g_l1.dWv,    lr_now)
    L1_Wo   = sgd_lr(L1_Wo,   g_l1.dWo,    lr_now)
    L1_Wff1 = sgd_lr(L1_Wff1, g_l1.dWff1,  lr_now)
    L1_Wff2 = sgd_lr(L1_Wff2, g_l1.dWff2,  lr_now)
    L1_ga   = sgd_lr(L1_ga,   g_l1.dga,    lr_now)
    L1_gf   = sgd_lr(L1_gf,   g_l1.dgf,    lr_now)
    lmh_U   = sgd_lr(lmh_U,   dlmh_U,      lr_now)
    lmh_V   = sgd_lr(lmh_V,   dlmh_V,      lr_now)

    return loss
}

// ─── Train loop ─────────────────────────────────────────────

println("[train_byte_clm] config: d=" + str(D) + " ff=" + str(FF) + " layers=" + str(NL) + " vocab=" + str(VOCAB) + " seq=" + str(SEQ) + " rank=" + str(RANK) + " steps=" + str(STEPS) + " lr=" + str(LR))
println("[train_byte_clm] uniform-random baseline: ln(256) = " + str(log(256.0)))

let t0 = clock()
let loss_0 = train_step(1)
println("[train_byte_clm] step=1 loss=" + str(loss_0) + " lr=" + str(current_lr(1)))

let mut step = 2
let mut last_loss = loss_0
while step <= STEPS {
    last_loss = train_step(step)
    if step % LOG_EVERY == 0 {
        println("[train_byte_clm] step=" + str(step) + " loss=" + str(last_loss) + " lr=" + str(current_lr(step)))
    }
    step = step + 1
}
let t1 = clock()
let total_ms = (t1 - t0) * 1000.0

println("")
println("[train_byte_clm] loss_initial = " + str(loss_0))
println("[train_byte_clm] loss_final   = " + str(last_loss))
println("[train_byte_clm] Δ loss       = " + str(last_loss - loss_0))
println("[train_byte_clm] total_ms     = " + str(total_ms))
println("[train_byte_clm] ms/step      = " + str(total_ms / (STEPS * 1.0)))

if last_loss < loss_0 - 0.01 {
    println("[train_byte_clm] PASS — real byte-level data learning works")
    let improvement = (loss_0 - last_loss) * 100.0 / loss_0
    println("[train_byte_clm] relative improvement = " + str(improvement) + "%")
} else {
    println("[train_byte_clm] WEAK — loss barely moved (may need more steps / higher lr)")
}

// ─── Save checkpoint (HEXACKPT-v1 multi-tensor) ─────────────
//
// Dumps all 17 trained tensors so eval_clm.hexa can reload the full
// 2-layer transformer. Format identical to train_and_save.hexa's
// checkpoint but with multiple "name rows cols\ndata\n" blocks.
// Total: 17 tensors, ~4864 floats for d=16/ff=32/vocab=32 config.

fn write_tensor(s_in: string, name: string, rows: int, cols: int, data: array) -> string {
    let mut s = s_in + name + " " + str(rows) + " " + str(cols) + "\n"
    let n = rows * cols
    let mut i = 0
    while i < n {
        if i > 0 { s = s + " " }
        s = s + str(data[i])
        i = i + 1
    }
    s = s + "\n"
    return s
}

let mut ckpt = "HEXACKPT-v1\n"
ckpt = write_tensor(ckpt, "embed",   VOCAB, D,     embed)
ckpt = write_tensor(ckpt, "L0_Wq",   D,     D,     L0_Wq)
ckpt = write_tensor(ckpt, "L0_Wk",   D,     D,     L0_Wk)
ckpt = write_tensor(ckpt, "L0_Wv",   D,     D,     L0_Wv)
ckpt = write_tensor(ckpt, "L0_Wo",   D,     D,     L0_Wo)
ckpt = write_tensor(ckpt, "L0_Wff1", D,     FF,    L0_Wff1)
ckpt = write_tensor(ckpt, "L0_Wff2", FF,    D,     L0_Wff2)
ckpt = write_tensor(ckpt, "L0_ga",   1,     D,     L0_ga)
ckpt = write_tensor(ckpt, "L0_gf",   1,     D,     L0_gf)
ckpt = write_tensor(ckpt, "L1_Wq",   D,     D,     L1_Wq)
ckpt = write_tensor(ckpt, "L1_Wk",   D,     D,     L1_Wk)
ckpt = write_tensor(ckpt, "L1_Wv",   D,     D,     L1_Wv)
ckpt = write_tensor(ckpt, "L1_Wo",   D,     D,     L1_Wo)
ckpt = write_tensor(ckpt, "L1_Wff1", D,     FF,    L1_Wff1)
ckpt = write_tensor(ckpt, "L1_Wff2", FF,    D,     L1_Wff2)
ckpt = write_tensor(ckpt, "L1_ga",   1,     D,     L1_ga)
ckpt = write_tensor(ckpt, "L1_gf",   1,     D,     L1_gf)
ckpt = write_tensor(ckpt, "lmh_U",   D,     RANK,  lmh_U)
ckpt = write_tensor(ckpt, "lmh_V",   RANK,  VOCAB, lmh_V)
ckpt = ckpt + "__MANIFEST__ 19 1\n"

let ckpt_path = "/tmp/train_byte_clm.ckpt"
write_file(ckpt_path, ckpt)
println("[train_byte_clm] saved " + str(len(ckpt)) + " bytes → " + ckpt_path)
println("[train_byte_clm] eval with: hexa serving/eval_clm.hexa " + ckpt_path)
