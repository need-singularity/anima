// ─── Pipeline (Roadmap C extreme acceleration) ───
fn run_alm_pipeline() -> int {
    // Phase 1: 7B (in parallel with serving + agent)
    let s7b = alm_init(base_mistral_7b(), 10000)
    // Phase 2: 14B after 7B eval passes
    let s14b = alm_init(base_qwen_14b(), 10000)
    // Phase 3 (optional): 70B if 14B insufficient
    let s72b = alm_init(base_qwen_72b(), 10000)
    s7b.step + s14b.step + s72b.step
}

// ─── CLI dispatch (ENTRY) ─────────────────────────────────────────
// Parses the same SESSION 2026-04-19 opt-in flags as train_clm.hexa so the
// launcher can pass identical --use-* flags to both binaries. Any flag
// absent → default OFF. Must run at module load so alm_step / alm_save
// observe the globals.

fn _alm_cli_flag_value(argv, flag: string, default_v: string) -> string {
    let n = len(argv)
    let mut i = 0
    while i < n - 1 {
        if argv[i] == flag { return argv[i + 1] }
        i = i + 1
    }
    return default_v
}

fn _alm_cli_has_flag(argv, flag: string) -> bool {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == flag { return true }
        i = i + 1
    }
    return false
}

let _alm_argv = args()
if _alm_cli_has_flag(_alm_argv, "--use-quadruple-cross") { G_SW_USE_QC = 1 }
if _alm_cli_has_flag(_alm_argv, "--use-tension-link")    { G_SW_USE_TL = 1 }
if _alm_cli_has_flag(_alm_argv, "--use-lens-diag")       { G_SW_USE_LENS = 1 }
if _alm_cli_has_flag(_alm_argv, "--use-tier-curriculum") { G_SW_USE_TIER = 1 }
if _alm_cli_has_flag(_alm_argv, "--use-sumt-stages")     { G_SW_USE_SUMT = 1 }
if _alm_cli_has_flag(_alm_argv, "--use-g-holo")          { G_SW_USE_GHOLO = 1 }
if _alm_cli_has_flag(_alm_argv, "--use-a6-gate")         { G_SW_USE_A6GATE = 1 }
G_SW_LAMBDA_QC     = to_float(_alm_cli_flag_value(_alm_argv, "--lambda-qc", "0.01"))
G_SW_LENS_EVERY    = to_int(_alm_cli_flag_value(_alm_argv, "--lens-diag-every", "500"))
G_SW_TIER_SCHEDULE = _alm_cli_flag_value(_alm_argv, "--tier-curriculum-schedule", "linear")
G_SW_TIER_PATH     = _alm_cli_flag_value(_alm_argv, "--tier-labels", "training/corpus_universe_tier_labels.jsonl")

