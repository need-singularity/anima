// training/train_alm.hexa — AnimaLM training loop structural port
// Source: train_anima_lm.py (Mistral 7B / Qwen2.5 base + PureField transform)
// Phase 2c structural port; PyTorch + transformers ops → TODO comments.
//
// Pipeline: base LM (frozen) ⊕ PureField FFN injection ⊕ tension bridge.
// Goal: independent AGI without external API. Roadmap C: 7B → 14B → 70B.

comptime const PSI_ALPHA   = 0.014
comptime const PSI_BALANCE = 0.5
comptime const PSI_STEPS   = 4.33

// ═════════════════════════════════════════════════════════════════════════
// SESSION 2026-04-19 WIRING — opt-in aux losses / diagnostics / curriculum
// ═════════════════════════════════════════════════════════════════════════
//
// Default OFF. When all flags are 0 the structural port is byte-identical
// to the pre-wiring path (ALM r10 baseline). Flags flip to 1 from the
// ENTRY DISPATCH block at the bottom when matching CLI flags are present.
// Aux module references (READ-ONLY — do not edit):
//   training/quadruple_cross_loss.hexa    (QC loss)
//   training/tension_link_step.hexa       (TL diagnostic)
//   training/holographic_propagator.hexa  (G_holo inside TL)
//   training/lens_{field,holographic,quantum,string,toe}_loss.hexa
//   training/corpus_universe_tier_labels.jsonl
//   training/sumt_bigbang_atom.hexa
//   training/ckpt_gate_a6.hexa
//
// Hexa quirks dodged (per feedback_hexa_*):
//   - Deep import silent-exit  → no `use`; inline primitives below.
//   - Pass-by-value list semantics → no list mutation via helpers.
//   - ≥3-float struct return bug  → flat-array returns.

let mut G_SW_USE_QC     = 0
let mut G_SW_USE_TL     = 0
let mut G_SW_USE_LENS   = 0
let mut G_SW_USE_TIER   = 0
let mut G_SW_USE_SUMT   = 0
let mut G_SW_USE_GHOLO  = 0
let mut G_SW_USE_A6GATE = 0

let mut G_SW_LAMBDA_QC     = 0.01
let mut G_SW_LENS_EVERY    = 500
let mut G_SW_TIER_SCHEDULE = "linear"
let mut G_SW_TIER_PATH     = "training/corpus_universe_tier_labels.jsonl"

let mut G_SW_LAST_QC_LOSS     = 0.0
let mut G_SW_LAST_4AXIS_DEV   = 0.0
let mut G_SW_LAST_TL_DW_NORM  = 0.0
let mut G_SW_LAST_TL_COS_BP   = 0.0
let mut G_SW_LAST_GHOLO_NORM  = 0.0
let mut G_SW_LAST_LENS_T_FIELD   = 0.0
let mut G_SW_LAST_LENS_T_HOLO    = 0.0
let mut G_SW_LAST_LENS_T_QUANTUM = 0.0
let mut G_SW_LAST_LENS_T_STRING  = 0.0
let mut G_SW_LAST_LENS_T_TOE     = 0.0
let mut G_SW_LAST_LENS_GATE      = 0
let mut G_SW_LAST_TIER_SAMPLED   = 0
let mut G_SW_LAST_SUMT_STAGE     = 0
let mut G_SW_GATE_SKIP_COUNT     = 0

fn _sw_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _sw_sq(x: float) -> float { return x * x }

fn _sw_sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut r = x
    let mut i = 0
    while i < 16 {
        let r2 = (r + x / r) * 0.5
        r = r2
        i = i + 1
    }
    return r
}

// Quadruple-cross loss (inline mirror of quadruple_cross_loss.hexa::loss_*_*
// with α=β=γ=δ=1.0 defaults). Opt-in aux contributes λ_qc · qc_loss.
fn _sw_qc_loss(psi_res: float, psi_gate: float, route: float, n_eff: float) -> float {
    return _sw_sq(psi_res) + _sw_sq(psi_gate - 0.5)
         + _sw_sq(route - 1.0) + _sw_sq(n_eff - 6.0)
}

fn _sw_4axis_dev(psi_res: float, psi_gate: float, route: float, n_eff: float) -> float {
    return _sw_fabs(psi_res) + _sw_fabs(psi_gate - 0.5)
         + _sw_fabs(route - 1.0) + _sw_fabs(n_eff - 6.0)
}

// SUMT stage: 1..4 (A1 probe → B1 anchor → B2 map-Δ → B4 self-pred)
fn _sw_sumt_stage(step: int, total_steps: int) -> int {
    if total_steps <= 0 { return 1 }
    let pct10 = total_steps / 10
    let pct30 = (total_steps * 3) / 10
    let pct60 = (total_steps * 6) / 10
    if step <= pct10 { return 1 }
    if step <= pct30 { return 2 }
    if step <= pct60 { return 3 }
    return 4
}

// Tier-curriculum max_k on a 1..70 scale
fn _sw_tier_max_k(step: int, total_steps: int, sched: string) -> int {
    if total_steps <= 0 { return 1 }
    let frac_num = step * 1000 / total_steps
    if sched == "exp" {
        let f2 = (frac_num * frac_num) / 1000
        let k = 1 + (69 * f2) / 1000
        if k < 1 { return 1 }
        if k > 70 { return 70 }
        return k
    }
    let k_lin = 1 + (69 * frac_num) / 1000
    if k_lin < 1 { return 1 }
    if k_lin > 70 { return 70 }
    return k_lin
}

// A6 gate: CV<3% vs best_ce outside warmup, else PASS. Returns 1/0.
fn _sw_a6_gate_ok(loss: float, best_ce: float, step: int, warmup: int) -> int {
    if step < warmup { return 1 }
    let denom = _sw_fabs(best_ce) + 0.000000001
    let cv = _sw_fabs(loss - best_ce) / denom
    if cv < 0.03 { return 1 }
    return 0
}

// Minimal lens surrogate tuple (flat array, 6 floats: field/holo/q/str/toe/gate)
// Inputs: scalar loss proxy + scalar tension proxy (ALM uses phase_manager T).
fn _sw_lens_tuple(loss_main: float, tension: float) -> [float] {
    let t_field   = _sw_fabs(loss_main)
    let t_holo    = _sw_sq(tension)
    let t_quantum = _sw_fabs(tension) * 0.5
    let t_string  = _sw_sqrt_safe(t_holo) * 0.1591549
    let t_toe     = (t_field + t_holo + t_quantum + t_string) * 0.25
    let mut gate = 1.0
    if t_field > 100.0 { gate = 0.0 }
    if t_holo > 100.0 { gate = 0.0 }
    return [t_field, t_holo, t_quantum, t_string, t_toe, gate]
}

comptime const ALM_PHASE_P1 = 1   // PureField only
comptime const ALM_PHASE_P2 = 2   // PureField + tension
comptime const ALM_PHASE_P3 = 3   // Full Hexad coupling

comptime const DEFAULT_LR        = 0.00002
comptime const DEFAULT_WARMUP    = 200
comptime const DEFAULT_GRAD_ACCUM = 8
comptime const DEFAULT_BATCH     = 2

// ─── Base model registry ───
struct BaseModel {
    name: string,
    hf_id: string,
    n_params_b: int,    // billions
    d_model: int,
    n_layer: int,
    pf_params_m: int,   // PureField transform params (millions)
    cost_usd: int
}

fn base_mistral_7b() -> BaseModel {
    BaseModel {
        name: "mistral-7b",
        hf_id: "mistralai/Mistral-7B-Instruct-v0.2",
        n_params_b: 7, d_model: 4096, n_layer: 32,
        pf_params_m: 56, cost_usd: 8
    }
}

fn base_qwen_14b() -> BaseModel {
    BaseModel {
        name: "qwen2.5-14b",
        hf_id: "Qwen/Qwen2.5-14B-Instruct",
        n_params_b: 14, d_model: 5120, n_layer: 48,
        pf_params_m: 120, cost_usd: 6
    }
}

fn base_qwen_72b() -> BaseModel {
    BaseModel {
        name: "qwen2.5-72b",
        hf_id: "Qwen/Qwen2.5-72B-Instruct",
        n_params_b: 72, d_model: 8192, n_layer: 80,
        pf_params_m: 380, cost_usd: 65
    }
}

// ─── PureField transform spec (injected per layer) ───
struct PureFieldSpec {
    d_model: int,
    rank: int,        // low-rank factorization
    dropout: float,
    alpha: float      // tension coupling
}

fn pf_spec_for(base: BaseModel) -> PureFieldSpec {
    PureFieldSpec {
        d_model: base.d_model,
        rank: base.d_model / 32,
        dropout: 0.37,
        alpha: PSI_ALPHA
    }
}

// ─── ALM phase manager ───
struct AlmPhaseManager {
    phase: int,
    step: int,
    p1_end: int,
    p2_end: int
}

fn alm_phase_new(total_steps: int) -> AlmPhaseManager {
    AlmPhaseManager {
        phase: ALM_PHASE_P1,
        step: 0,
        p1_end: total_steps / 4,
        p2_end: total_steps / 2
    }
}

fn alm_phase_update(pm: AlmPhaseManager, step: int) -> AlmPhaseManager {
    let next = if step < pm.p1_end {
        ALM_PHASE_P1
    } else if step < pm.p2_end {
        ALM_PHASE_P2
    } else {
        ALM_PHASE_P3
    }
    AlmPhaseManager {
        phase: next, step: step,
        p1_end: pm.p1_end, p2_end: pm.p2_end
    }
}

// ─── Optimizer (bf16 master rule) ───
struct AlmOptim {
    lr: float,
    warmup: int,
    grad_accum: int,
    batch: int,
    bf16: bool
}

fn alm_optim_default() -> AlmOptim {
    AlmOptim {
        lr: DEFAULT_LR,
        warmup: DEFAULT_WARMUP,
        grad_accum: DEFAULT_GRAD_ACCUM,
        batch: DEFAULT_BATCH,
        bf16: true
    }
}

// ─── Training step ───
struct AlmState {
    base: BaseModel,
    pf: PureFieldSpec,
    pm: AlmPhaseManager,
    opt: AlmOptim,
    step: int,
    best_ce: float
}

fn alm_init(base: BaseModel, total_steps: int) -> AlmState {
    AlmState {
        base: base,
        pf: pf_spec_for(base),
        pm: alm_phase_new(total_steps),
        opt: alm_optim_default(),
        step: 0,
        best_ce: 999999.0
    }
}

fn alm_step(state: AlmState) -> AlmState {
    // TODO[pytorch + transformers]:
    //   model = AutoModelForCausalLM.from_pretrained(base.hf_id,
    //                                                 torch_dtype=torch.bfloat16,
    //                                                 device_map='cuda')
    //   freeze_all_params(model)
    //   inject_purefield(model, pf_spec)         // only PF params trainable
    //   for micro in range(grad_accum):
    //       batch = next(loader)
    //       with autocast(bf16):
    //           out = model(batch.input_ids, labels=batch.labels)
    //           ce = out.loss
    //           tension = compute_tension(model.pf_states)
    //           loss = (ce - PSI_ALPHA * tension) / grad_accum
    //       loss.backward()
    //   optim.step(); sched.step(); optim.zero_grad()
    let next_step = state.step + 1
    let next_pm = alm_phase_update(state.pm, next_step)

    // SESSION 2026-04-19 WIRING — opt-in aux diagnostics (default OFF).
    // Because this is a structural port (actual ce/tension computed by the
    // PyTorch side on H100 per TODO above), we use proxy inputs here: the
    // phase index and the current ce proxy (best_ce fallback). When the
    // real PyTorch side runs, it should read these same globals from the
    // scaffold and feed real tensors; this block guarantees the flags are
    // observable from the `alm_step` path and the launcher can scrape them.
    let loss_proxy = if state.best_ce < 999999.0 { state.best_ce } else { 5.5 }
    let tension_proxy = state.pf.alpha * (1.0 + next_pm.phase + 0.0)
    if G_SW_USE_QC == 1 {
        let psi_res  = loss_proxy * 0.1
        let psi_gate = 0.5
        let route    = 1.0
        let n_eff    = 6.0
        let qc_l = _sw_qc_loss(psi_res, psi_gate, route, n_eff)
        G_SW_LAST_QC_LOSS   = qc_l
        G_SW_LAST_4AXIS_DEV = _sw_4axis_dev(psi_res, psi_gate, route, n_eff)
    }
    if G_SW_USE_TL == 1 {
        // Diagnostic only — ΔW_tl not applied to weights this phase.
        G_SW_LAST_TL_DW_NORM = _sw_fabs(tension_proxy) * 0.1
        G_SW_LAST_TL_COS_BP  = 1.0
        if G_SW_USE_GHOLO == 1 {
            G_SW_LAST_GHOLO_NORM = _sw_sqrt_safe(G_SW_LAST_TL_DW_NORM) * 0.5
        }
    }
    if G_SW_USE_LENS == 1 {
        let every = G_SW_LENS_EVERY
        let do_sample = if every <= 0 { true } else { next_step % every == 0 }
        if do_sample {
            let ld = _sw_lens_tuple(loss_proxy, tension_proxy)
            G_SW_LAST_LENS_T_FIELD   = ld[0]
            G_SW_LAST_LENS_T_HOLO    = ld[1]
            G_SW_LAST_LENS_T_QUANTUM = ld[2]
            G_SW_LAST_LENS_T_STRING  = ld[3]
            G_SW_LAST_LENS_T_TOE     = ld[4]
            G_SW_LAST_LENS_GATE      = if ld[5] > 0.5 { 1 } else { 0 }
        }
    }
    if G_SW_USE_TIER == 1 {
        // total_steps proxy: phase manager p2_end * 2 (≈ total_steps used at init)
        let total_proxy = state.pm.p2_end * 2
        G_SW_LAST_TIER_SAMPLED = _sw_tier_max_k(next_step, total_proxy, G_SW_TIER_SCHEDULE)
    }
    if G_SW_USE_SUMT == 1 {
        let total_proxy2 = state.pm.p2_end * 2
        G_SW_LAST_SUMT_STAGE = _sw_sumt_stage(next_step, total_proxy2)
    }

    AlmState {
        base: state.base,
        pf: state.pf,
        pm: next_pm,
        opt: state.opt,
        step: next_step,
        best_ce: state.best_ce
    }
}

// ─── Eval (5 metrics) ───
struct AlmEval {
    perplexity: float,
    gen_quality: float,
    consciousness_t: float,
    korean_ratio: float,
    instr_follow: int
}

fn alm_eval(state: AlmState) -> AlmEval {
    // TODO[pytorch]: run eval_animalm.py: PPL, gen quality, T, KR, IF
    AlmEval {
        perplexity: 0.0,
        gen_quality: 0.0,
        consciousness_t: 0.0,
        korean_ratio: 0.0,
        instr_follow: 0
    }
}

fn alm_eval_passes(e: AlmEval) -> bool {
    // 5/5 threshold per CLAUDE.md extreme accel report
    e.perplexity > 0.0 && e.gen_quality >= 0.6 && e.consciousness_t > 0.0 && e.korean_ratio >= 0.3 && e.instr_follow >= 4
}

// ─── Checkpoint (R2 backup mandatory per feedback_r2_checkpoint) ───
struct AlmCheckpoint {
    path: string,
    step: int,
    ce: float,
    r2_uploaded: bool
}

fn alm_save(path: string, step: int, ce: float) -> AlmCheckpoint {
    // TODO:
    //   atomic_save(state, path + '.tmp'); rename(.tmp, path)
    //   subprocess: rclone copy path r2:anima-models/
    // SESSION 2026-04-19 WIRING — A6 gate (opt-in). When enabled and
    // gate_ok==0, SKIP the save and log it. best_ce tracked via ce arg
    // (caller passes state.best_ce before update, matching convention).
    if G_SW_USE_A6GATE == 1 {
        let gate_ok = _sw_a6_gate_ok(ce, ce, step, DEFAULT_WARMUP)
        if gate_ok == 0 {
            G_SW_GATE_SKIP_COUNT = G_SW_GATE_SKIP_COUNT + 1
            println("[alm][a6-gate] SKIP save step=", step, " ce=", ce,
                    " skip_count=", G_SW_GATE_SKIP_COUNT)
            return AlmCheckpoint { path: path, step: step, ce: ce, r2_uploaded: false }
        }
    }
    AlmCheckpoint { path: path, step: step, ce: ce, r2_uploaded: true }
}

