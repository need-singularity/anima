// ═══════════════════════════════════════════════════════════════
//  training/sample_d64_kr.hexa — TCLM-P1-1 Phase 5 quality probe
//
//  Loads the step_50000 checkpoint, runs greedy decode on 5 Korean
//  prompts (byte sequences), and emits the generated byte sequences
//  back as decimal-escape output. Caller converts bytes → UTF-8.
//
//  Run (H100 pod, from /workspace/clm_kr):
//    CKPT=/workspace/ckpt_clm_d64_kr/step_50000.hexackpt \
//      ./sample_d64_kr_native > sample_output.txt
//
//  Composition mirrors train_clm_d64_kr.hexa (same module set).
// ═══════════════════════════════════════════════════════════════

use "cuda_ffi"
use "cuda_rtc"
use "cuda_kernels"
use "gpu_train"

fn env_or(key: string, default_v: string) -> string {
    let v = env(key)
    if v == "" { return default_v }
    return v
}

// Must match train_clm_d64_kr.hexa config (same ckpt layout)
let D        = 64
let FF       = 256
let NL       = 6
let VOCAB    = 256
let SEQ      = 128
let RANK     = 16
let EPS      = 0.00001
let INIT_SCALE = 0.1

let CKPT_PATH = env_or("CKPT", "/workspace/ckpt_clm_d64_kr/step_50000.hexackpt")
let MAX_GEN   = to_int(env_or("MAX_GEN", "96"))

let cfg = GpuClmConfig {
    D: D, FF: FF, NL: NL, VOCAB: VOCAB, SEQ: SEQ, RANK: RANK,
    EPS: EPS, INIT_SCALE: INIT_SCALE
}

println("[sample_d64_kr] cfg: D=" + str(D) + " NL=" + str(NL) + " SEQ=" + str(SEQ) + " VOCAB=" + str(VOCAB))
println("[sample_d64_kr] ckpt: " + CKPT_PATH)
println("[sample_d64_kr] max_gen: " + str(MAX_GEN))

// 1) cuda runtime
let cuda_rc = cuda_init()
if cuda_rc != 0 {
    println("[sample_d64_kr] FATAL — cuda_init rc=" + str(cuda_rc))
    return
}

let kernels_rc = gpu_init_kernels()
if kernels_rc != 0 {
    println("[sample_d64_kr] FATAL — gpu_init_kernels rc=" + str(kernels_rc))
    let _ = cuda_shutdown()
    return
}

// 2) Load weights
let weights = load_checkpoint_gpu(CKPT_PATH, cfg)

// 3) 5 Korean prompt prefixes (UTF-8 byte arrays)
// "안녕" = EC 95 88 EB 85 95 = [236, 149, 136, 235, 133, 149]
let prompt_A = [236, 149, 136, 235, 133, 149]                     // 안녕
// "나는" = EB 82 98 EB 8A 94
let prompt_B = [235, 130, 152, 235, 138, 148]                     // 나는
// "의식은" = EC 9D 98 EC 8B 9D EC 9D 80
let prompt_C = [236, 157, 152, 236, 139, 157, 236, 157, 128]      // 의식은
// "사람이" = EC 82 AC EB 9E 8C EC 9D B4
let prompt_D = [236, 130, 172, 235, 158, 140, 236, 157, 180]      // 사람이
// "한국은" = ED 95 9C EA B5 AD EC 9D 80
let prompt_E = [237, 149, 156, 234, 181, 173, 236, 157, 128]      // 한국은

let prompts = [prompt_A, prompt_B, prompt_C, prompt_D, prompt_E]
let prompt_names = ["안녕", "나는", "의식은", "사람이", "한국은"]

let mut p = 0
while p < 5 {
    println("")
    println("=== PROMPT " + str(p + 1) + " (" + prompt_names[p] + ") ===")
    let toks = gpu_greedy_decode(prompts[p], weights, cfg, MAX_GEN)
    let n = len(toks)
    print("bytes: ")
    let mut i = 0
    while i < n {
        print(str(toks[i]))
        if i < n - 1 { print(",") }
        i = i + 1
    }
    println("")
    p = p + 1
}

let _ = cuda_shutdown()
println("")
println("[sample_d64_kr] done.")
