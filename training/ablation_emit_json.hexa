// training/ablation_emit_json.hexa — D2 CPU precompute 71-row JSON emitter
//
// PURPOSE:
//   Emits the full 71-engine leave-one-out CPU precompute as JSON to stdout.
//   Deterministic, reproducible from engine_ablation.hexa's surrogate formulas.
//
// OUTPUT (stdout, parsable JSON):
//   { "_meta": {...},
//     "rows": [ {"idx":N, "name":"...", "family":F, "family_tag":"...",
//                 "gain":G, "ce_delta":X, "phi_delta":Y,
//                 "combined_score":S, "verdict":"KEEP|REVIEW|DROP"}, ... ],
//     "distribution": {"KEEP":K, "REVIEW":R, "DROP":D},
//     "top10": [...], "bottom10": [...]
//   }
//
// Verdict thresholds (SSOT with task spec — NOT run_ablation.hexa's looser ones):
//   KEEP   : |CE_Δ| >= 1e-3 AND |phi_Δ| >= 5e-4
//   DROP   : |CE_Δ| < 1e-4 AND |phi_Δ| < 1e-5
//   REVIEW : otherwise
//
// Combined score for ranking: |CE_Δ|*1000 + |phi_Δ|*10000
//
// Run:
//   HEXA_LOCAL=1 hexa run training/ablation_emit_json.hexa > out.json
// (or through wrapper; stderr is ignored by JSON consumers)

let EJ_N_ENGINES = 71

// ─── Helpers ─────────────────────────────────────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_sum(v: array) -> float {
    let mut s = 0.0; let mut i = 0; let n = len(v)
    while i < n { s = s + v[i]; i = i + 1 }
    return s
}

fn vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    return vec_sum(v) / (n * 1.0)
}

fn vec_var(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let m = vec_mean(v)
    let mut s = 0.0; let mut i = 0
    while i < n { let d = v[i] - m; s = s + d * d; i = i + 1 }
    return s / (n * 1.0)
}

