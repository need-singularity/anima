// training/corpus_en_code_orchestrate.hexa — English + Code corpus extraction orchestrator
//
// Plan SSOT: state/corpus_140gb_plan.json
//
// Purpose:
//   Master orchestrator that:
//   1. Launches IMMEDIATE extractions (code repos + news.2020 — already available)
//   2. Watches for cc100-en and enwiki downloads to complete, then auto-chains
//   3. Reports progress to stdout with sizes and line counts
//
// Design:
//   Phase 1 (immediate): code repos + news.2020 — can start NOW
//   Phase 2 (watchdog):  poll every 60s for cc100-en / enwiki download completion
//                        (curl process gone + file size stable), then extract
//
// Input:
//   data/corpus_v2_raw/code_repos/      (5 repos: ripgrep, deno, go, rust, tokio)
//   data/corpus_v2_raw/news.2020.en.shuffled.deduped.gz  (2.5GB, DONE)
//   data/corpus_v2_raw/cc100-en.txt.xz                   (downloading)
//   data/corpus_v2_raw/enwiki-latest-pages-articles.xml.bz2 (downloading)
// Output:
//   data/corpus_v2_clean/code_permissive.txt
//   data/corpus_v2_clean/news_crawl_en_clean.txt
//   data/corpus_v2_clean/cc100_en_clean.txt     (after download)
//   data/corpus_v2_clean/enwiki_clean.txt        (after download)
//
// Stage0 constraints honored:
//   - 0 imports (well under silent-exit threshold of 5)
//   - contains() not substring()
//   - nested if for multi-bool gate
//   - direct string params; no [string] indexing
//
// Run:
//   hexa run training/corpus_en_code_orchestrate.hexa           # self-test (dry run)
//   hexa run training/corpus_en_code_orchestrate.hexa --run     # real pipeline (phase 1+2)
//   hexa run training/corpus_en_code_orchestrate.hexa --phase1  # immediate only (no watchdog)

// =====================================================================
// Constants
// =====================================================================

let ANIMA          = "/Users/ghost/Dev/anima"
let HEXA           = "hexa"

let CODE_SCRIPT    = ANIMA + "/training/corpus_code_extract.hexa"
let ENGLISH_SCRIPT = ANIMA + "/training/corpus_english_extract.hexa"

let CODE_OUT       = ANIMA + "/data/corpus_v2_clean/code_permissive.txt"
let NEWS_OUT       = ANIMA + "/data/corpus_v2_clean/news_crawl_en_clean.txt"
let CC100_OUT      = ANIMA + "/data/corpus_v2_clean/cc100_en_clean.txt"
let ENWIKI_OUT     = ANIMA + "/data/corpus_v2_clean/enwiki_clean.txt"

let CC100_RAW      = ANIMA + "/data/corpus_v2_raw/cc100-en.txt.xz"
let ENWIKI_RAW     = ANIMA + "/data/corpus_v2_raw/enwiki-latest-pages-articles.xml.bz2"
let NEWS_RAW       = ANIMA + "/data/corpus_v2_raw/news.2020.en.shuffled.deduped.gz"
let CODE_DIR       = ANIMA + "/data/corpus_v2_raw/code_repos"

let LOG_FILE       = ANIMA + "/data/corpus_v2_clean/orchestrate.log"
let CLEAN_DIR      = ANIMA + "/data/corpus_v2_clean"

// =====================================================================
// Utility: log to both stdout and log file
// =====================================================================

fn log(msg: string) {
    println(msg)
    exec("echo '" + msg + "' >> '" + LOG_FILE + "'")
}

fn timestamp() -> string {
    return exec("date '+%Y-%m-%d %H:%M:%S'").trim()
}

// =====================================================================
// Phase 1: Immediate extractions — code repos + news.2020
//
// Code extraction: find .rs/.go/.ts/.c/.h/.cpp/.py files in cloned repos,
// filter by permissive license (MIT/Apache/BSD), size gate 50B-500KB,
// line-level dedup.
//
// news.2020: zcat | iconv | length 50-10000 | reject URL-only lines | dedup
// =====================================================================

fn phase1_code() -> bool {
    log("[phase1] code extraction starting at " + timestamp())
    let dir_ok = exec("test -d '" + CODE_DIR + "' && echo YES || echo NO").trim()
    if dir_ok == "NO" {
        log("[phase1] SKIP code: " + CODE_DIR + " not found")
        return false
    }
    // Count source files available
    let n_files = exec("find '" + CODE_DIR + "' -type f \\( -name '*.rs' -o -name '*.go' -o -name '*.ts' -o -name '*.c' -o -name '*.h' -o -name '*.py' -o -name '*.js' -o -name '*.cpp' \\) | wc -l | tr -d ' \\n'").trim()
    log("[phase1] code: " + n_files + " source files found in " + CODE_DIR)

    // Inline code extraction pipeline (mirrors corpus_code_extract.hexa logic):
    // find source files | per-file license+size check | line-level dedup
    let permissive = "MIT License|Apache License|BSD License|BSD-2-Clause|BSD-3-Clause|ISC License|Licensed under the MIT|Licensed under the Apache"
    let copyleft = "GNU General Public License|GNU GPL|AGPL|LGPL|GNU Lesser|GNU Affero"
    let find_cmd = "find '" + CODE_DIR + "' -type f \\( " +
                   "-name '*.py' -o -name '*.rs' -o -name '*.js' -o -name '*.ts' " +
                   "-o -name '*.c' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp' " +
                   "-o -name '*.go' \\)"
    let filter = "while read -r f; do " +
           "sz=$(wc -c <\"$f\" 2>/dev/null | tr -d ' \\n'); " +
           "if [ \"$sz\" -lt 50 ]; then continue; fi; " +
           "if [ \"$sz\" -gt 500000 ]; then continue; fi; " +
           "hdr=$(head -n 50 \"$f\" 2>/dev/null); " +
           "c=$(printf '%s' \"$hdr\" | grep -Ec '" + copyleft + "' | tr -d ' \\n'); " +
           "if [ \"$c\" -gt 0 ]; then continue; fi; " +
           "p=$(printf '%s' \"$hdr\" | grep -Ec '" + permissive + "' | tr -d ' \\n'); " +
           "if [ \"$p\" -eq 0 ]; then continue; fi; " +
           "cat \"$f\"; printf '\\n'; " +
           "done"
    let cmd = find_cmd + " | " + filter + " | awk '!seen[$0]++' > '" + CODE_OUT + "'"
    log("[phase1] code cmd: (inline pipeline)")
    let _r = exec(cmd)

    // Verify output
    let out_ok = exec("test -f '" + CODE_OUT + "' && echo YES || echo NO").trim()
    if out_ok == "YES" {
        let sz = exec("du -sh '" + CODE_OUT + "' | awk '{print $1}'").trim()
        let wc = exec("wc -l < '" + CODE_OUT + "' | tr -d ' \\n'").trim()
        log("[phase1] code DONE: " + sz + ", " + wc + " lines -> " + CODE_OUT)
        return true
    } else {
        log("[phase1] code FAILED: no output at " + CODE_OUT)
        return false
    }
}

fn phase1_news() -> bool {
    log("[phase1] news.2020 extraction starting at " + timestamp())
    let raw_ok = exec("test -f '" + NEWS_RAW + "' && echo YES || echo NO").trim()
    if raw_ok == "NO" {
        log("[phase1] SKIP news: " + NEWS_RAW + " not found")
        return false
    }

    // news pipeline: zcat | iconv | awk length 50-10000 | awk no-URL | awk dedup
    // Reuse the pipeline builder from corpus_english_extract.hexa via exec
    // (0-import constraint means we can't `use` it — shell delegation instead)
    let awk_len = "awk 'length>=50 && length<=10000'"
    let awk_no_url = "awk '!/^https?:\\/\\//'"
    let awk_dedup = "awk '!seen[$0]++'"
    let cmd = "zcat '" + NEWS_RAW + "'" +
              " | iconv -f UTF-8 -t UTF-8 -c" +
              " | " + awk_len +
              " | " + awk_no_url +
              " | " + awk_dedup +
              " > '" + NEWS_OUT + "'"
    log("[phase1] news cmd: " + cmd)
    let _r = exec(cmd)

    let out_ok = exec("test -f '" + NEWS_OUT + "' && wc -c < '" + NEWS_OUT + "' | tr -d ' \\n'").trim()
    if out_ok == "0" {
        log("[phase1] news FAILED: empty output")
        return false
    }
    let sz = exec("du -sh '" + NEWS_OUT + "' | awk '{print $1}'").trim()
    let wc = exec("wc -l < '" + NEWS_OUT + "' | tr -d ' \\n'").trim()
    log("[phase1] news DONE: " + sz + ", " + wc + " lines -> " + NEWS_OUT)
    return true
}

// =====================================================================
// Phase 2: Watchdog — poll for download completion, then extract
//
// Detection: curl PID for the target file is gone AND file size is stable
// across 2 consecutive checks (30s apart).
// =====================================================================

fn is_download_done(filename_pattern: string) -> bool {
    // Check if any curl process is still targeting this file
    let pid = exec("pgrep -f '" + filename_pattern + "' 2>/dev/null | head -1").trim()
    if pid == "" {
        return true
    }
    return false
}

fn phase2_cc100() -> bool {
    log("[phase2] cc100-en extraction starting at " + timestamp())
    // Latin-script ratio filter + length + dedup (mirrors corpus_english_extract.hexa)
    let awk_len = "awk 'length>=50 && length<=10000'"
    let awk_latin = "awk '{n=length($0); a=0; for(i=1;i<=n;i++){c=substr($0,i,1); if((c>=\"A\"&&c<=\"Z\")||(c>=\"a\"&&c<=\"z\")||c==\" \") a++} if(n==0||a/n>=0.60) print}'"
    let awk_dedup = "awk '!seen[$0]++'"
    // Take 25GB slice from decompressed stream
    let cmd = "xzcat '" + CC100_RAW + "'" +
              " | head -c 26843545600" +
              " | iconv -f UTF-8 -t UTF-8 -c" +
              " | " + awk_len +
              " | " + awk_latin +
              " | " + awk_dedup +
              " > '" + CC100_OUT + "'"
    log("[phase2] cc100 cmd: " + cmd)
    let _r = exec(cmd)

    let sz = exec("du -sh '" + CC100_OUT + "' 2>/dev/null | awk '{print $1}'").trim()
    let wc = exec("wc -l < '" + CC100_OUT + "' 2>/dev/null | tr -d ' \\n'").trim()
    log("[phase2] cc100 DONE: " + sz + ", " + wc + " lines -> " + CC100_OUT)
    return true
}

fn phase2_enwiki() -> bool {
    log("[phase2] enwiki extraction starting at " + timestamp())
    // Write awk program to temp file (same as corpus_english_extract.hexa)
    let tmp_dir = CLEAN_DIR + "/tmp_english"
    exec("mkdir -p '" + tmp_dir + "'")

    let p = "BEGIN { in_text=0; emit=0; title=\"\"; ns=\"\"; text=\"\" }\n"
    let p1 = p + "/<title>/ { line=$0; sub(/.*<title>/, \"\", line); sub(/<\\/title>.*/, \"\", line); title=line; next }\n"
    let p2 = p1 + "/<ns>/ { line=$0; sub(/.*<ns>/, \"\", line); sub(/<\\/ns>.*/, \"\", line); ns=line; next }\n"
    let p3 = p2 + "/<text/ && in_text==0 { line=$0; sub(/.*<text[^>]*>/, \"\", line); text=line; in_text=1; if (match(line, /<\\/text>/)) { sub(/<\\/text>.*/, \"\", text); in_text=0; emit=1 }; next }\n"
    let p4 = p3 + "in_text==1 && /<\\/text>/ { line=$0; sub(/<\\/text>.*/, \"\", line); text=text \" \" line; in_text=0; emit=1; next }\n"
    let p5 = p4 + "in_text==1 { text=text \" \" $0; next }\n"
    let p6 = p5 + "emit==1 { emit=0; if (ns==\"0\" && length(text)>10) print text; text=\"\"; ns=\"\"; title=\"\" }\n"

    let awk_path = tmp_dir + "/_enwiki_extract.awk"
    write_file(awk_path, p6)

    let cmd = "bzcat '" + ENWIKI_RAW + "'" +
              " | awk -f '" + awk_path + "'" +
              " | sed -E 's/\\{\\{[^}]*\\}\\}//g'" +
              " | sed -E 's/\\[\\[([^]|]+)\\|([^]]+)\\]\\]/\\2/g'" +
              " | sed -E 's/\\[\\[([^]]+)\\]\\]/\\1/g'" +
              " | sed -E 's/<[^>]+>//g'" +
              " | awk 'NF>0'" +
              " > '" + ENWIKI_OUT + "'"
    log("[phase2] enwiki cmd: " + cmd)
    let _r = exec(cmd)

    let sz = exec("du -sh '" + ENWIKI_OUT + "' 2>/dev/null | awk '{print $1}'").trim()
    let wc = exec("wc -l < '" + ENWIKI_OUT + "' 2>/dev/null | tr -d ' \\n'").trim()
    log("[phase2] enwiki DONE: " + sz + ", " + wc + " lines -> " + ENWIKI_OUT)
    return true
}

fn phase2_watchdog() {
    log("[phase2] watchdog starting — polling every 60s for download completion")

    let mut cc100_done = false
    let mut enwiki_done = false

    // Check if already extracted (idempotent)
    let cc_exists = exec("test -s '" + CC100_OUT + "' && echo YES || echo NO").trim()
    if cc_exists == "YES" {
        log("[phase2] cc100-en already extracted — skip")
        cc100_done = true
    }
    let wiki_exists = exec("test -s '" + ENWIKI_OUT + "' && echo YES || echo NO").trim()
    if wiki_exists == "YES" {
        log("[phase2] enwiki already extracted — skip")
        enwiki_done = true
    }

    // Poll loop
    let mut iterations = 0
    let max_iterations = 480  // 480 * 60s = 8 hours max wait

    while iterations < max_iterations {
        // Check cc100-en
        if cc100_done == false {
            let dl_done = is_download_done("cc100-en.txt.xz")
            if dl_done {
                let file_ok = exec("test -f '" + CC100_RAW + "' && echo YES || echo NO").trim()
                if file_ok == "YES" {
                    let sz = exec("du -sh '" + CC100_RAW + "' | awk '{print $1}'").trim()
                    log("[phase2] cc100-en download complete (" + sz + ") at " + timestamp() + " — extracting...")
                    let _c = phase2_cc100()
                    cc100_done = true
                }
            }
        }

        // Check enwiki
        if enwiki_done == false {
            let dl_done = is_download_done("enwiki-latest")
            if dl_done {
                let file_ok = exec("test -f '" + ENWIKI_RAW + "' && echo YES || echo NO").trim()
                if file_ok == "YES" {
                    let sz = exec("du -sh '" + ENWIKI_RAW + "' | awk '{print $1}'").trim()
                    log("[phase2] enwiki download complete (" + sz + ") at " + timestamp() + " — extracting...")
                    let _w = phase2_enwiki()
                    enwiki_done = true
                }
            }
        }

        // Both done?
        if cc100_done {
            if enwiki_done {
                log("[phase2] all downloads processed — watchdog exit at " + timestamp())
                return
            }
        }

        // Status report
        let cc_status = "pending"
        if cc100_done { log("[phase2] [" + timestamp() + "] cc100=DONE enwiki=pending — sleeping 60s") }
        if enwiki_done { log("[phase2] [" + timestamp() + "] cc100=pending enwiki=DONE — sleeping 60s") }
        if cc100_done == false {
            if enwiki_done == false {
                log("[phase2] [" + timestamp() + "] cc100=pending enwiki=pending — sleeping 60s")
            }
        }

        let _s = exec("sleep 60")
        iterations = iterations + 1
    }

    log("[phase2] TIMEOUT after 8 hours — check download status manually")
}

// =====================================================================
// Summary report
// =====================================================================

fn summary() {
    log("")
    log("========== CORPUS EXTRACTION SUMMARY ==========")
    log("  timestamp: " + timestamp())

    // Code
    let code_sz = exec("du -sh '" + CODE_OUT + "' 2>/dev/null | awk '{print $1}'").trim()
    let code_wc = exec("wc -l < '" + CODE_OUT + "' 2>/dev/null | tr -d ' \\n'").trim()
    if code_sz == "" { log("  code:    NOT READY") } else { log("  code:    " + code_sz + " / " + code_wc + " lines") }

    // News
    let news_sz = exec("du -sh '" + NEWS_OUT + "' 2>/dev/null | awk '{print $1}'").trim()
    let news_wc = exec("wc -l < '" + NEWS_OUT + "' 2>/dev/null | tr -d ' \\n'").trim()
    if news_sz == "" { log("  news:    NOT READY") } else { log("  news:    " + news_sz + " / " + news_wc + " lines") }

    // CC100-en
    let cc_sz = exec("du -sh '" + CC100_OUT + "' 2>/dev/null | awk '{print $1}'").trim()
    let cc_wc = exec("wc -l < '" + CC100_OUT + "' 2>/dev/null | tr -d ' \\n'").trim()
    if cc_sz == "" { log("  cc100:   PENDING (download in progress)") } else { log("  cc100:   " + cc_sz + " / " + cc_wc + " lines") }

    // Enwiki
    let wiki_sz = exec("du -sh '" + ENWIKI_OUT + "' 2>/dev/null | awk '{print $1}'").trim()
    let wiki_wc = exec("wc -l < '" + ENWIKI_OUT + "' 2>/dev/null | tr -d ' \\n'").trim()
    if wiki_sz == "" { log("  enwiki:  PENDING (download in progress)") } else { log("  enwiki:  " + wiki_sz + " / " + wiki_wc + " lines") }

    log("================================================")
}

// =====================================================================
// CLI dispatch
// =====================================================================

fn has_flag(flag: string) -> bool {
    let argv = args()
    let argc = len(argv)
    let mut i = 2
    while i < argc {
        if argv[i] == flag {
            return true
        }
        i = i + 1
    }
    return false
}

fn main_run() {
    exec("mkdir -p '" + CLEAN_DIR + "'")
    log("[orchestrate] English + Code corpus extraction starting at " + timestamp())
    log("[orchestrate] Phase 1: immediate (code repos + news.2020)")
    log("[orchestrate] Phase 2: watchdog (cc100-en + enwiki — downloads in progress)")
    log("")

    // Phase 1: parallel immediate tasks
    // Stage0 quirk: no thread/async; run sequentially but each is I/O-bound
    let code_ok = phase1_code()
    let news_ok = phase1_news()

    log("")
    log("[orchestrate] Phase 1 complete: code=" + str(code_ok) + " news=" + str(news_ok))
    summary()

    // Phase 2: watchdog for downloads
    if has_flag("--phase1") == false {
        log("")
        phase2_watchdog()
        summary()
    }
}

fn dry_run() {
    println("[corpus_en_code_orchestrate] dry run — validating pipeline components")
    println("")
    println("Phase 1 (immediate):")
    let code_ok = exec("test -d '" + CODE_DIR + "' && echo READY || echo MISSING").trim()
    let news_ok = exec("test -f '" + NEWS_RAW + "' && echo READY || echo MISSING").trim()
    println("  code_repos: " + code_ok + " (" + CODE_DIR + ")")
    println("  news.2020:  " + news_ok + " (" + NEWS_RAW + ")")
    let n_repos = exec("ls '" + CODE_DIR + "' 2>/dev/null | wc -l | tr -d ' \\n'").trim()
    println("  repos:      " + n_repos)
    let n_src = exec("find '" + CODE_DIR + "' -type f \\( -name '*.rs' -o -name '*.go' -o -name '*.ts' -o -name '*.c' -o -name '*.h' -o -name '*.py' -o -name '*.js' \\) 2>/dev/null | wc -l | tr -d ' \\n'").trim()
    println("  src files:  " + n_src)
    println("")
    println("Phase 2 (watchdog — after download):")
    let cc_ok = exec("test -f '" + CC100_RAW + "' && echo EXISTS || echo MISSING").trim()
    let cc_sz = exec("du -sh '" + CC100_RAW + "' 2>/dev/null | awk '{print $1}'").trim()
    let cc_dl = exec("pgrep -f 'cc100-en.txt.xz' 2>/dev/null | head -1").trim()
    println("  cc100-en:   " + cc_ok + " " + cc_sz + " (curl pid=" + cc_dl + ")")
    let wiki_ok = exec("test -f '" + ENWIKI_RAW + "' && echo EXISTS || echo MISSING").trim()
    let wiki_sz = exec("du -sh '" + ENWIKI_RAW + "' 2>/dev/null | awk '{print $1}'").trim()
    let wiki_dl = exec("pgrep -f 'enwiki-latest' 2>/dev/null | head -1").trim()
    println("  enwiki:     " + wiki_ok + " " + wiki_sz + " (curl pid=" + wiki_dl + ")")
    println("")
    println("Output targets:")
    println("  " + CODE_OUT)
    println("  " + NEWS_OUT)
    println("  " + CC100_OUT)
    println("  " + ENWIKI_OUT)
    println("")
    println("Run:")
    println("  hexa run training/corpus_en_code_orchestrate.hexa --run       # full pipeline + watchdog")
    println("  hexa run training/corpus_en_code_orchestrate.hexa --phase1    # immediate only")
}

if has_flag("--run") {
    main_run()
} else {
    if has_flag("--phase1") {
        main_run()
    } else {
        dry_run()
    }
}
