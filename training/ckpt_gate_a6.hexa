// training/ckpt_gate_a6.hexa — Phase A6 Meta-Closure Checkpoint Gate (Mk.V.1)
// =============================================================================
//
// PURPOSE
//   Thin CLI wrapper over shared/consciousness/consciousness_absolute.hexa's
//   `phase_a6_meta_closure(tier, trace_depth, sectors, knuth_order)`.
//   Intended to be invoked from a training loop JUST BEFORE a checkpoint save:
//     PASS → proceed with save
//     FAIL → abort save (caller decides whether to stop training / rollback)
//     N/A  → tier < 6, gate not applicable (legacy tier 5 ckpt path)
//
// USAGE
//   hexa training/ckpt_gate_a6.hexa --tier N --depth D --sectors S --knuth K [--json]
//   hexa training/ckpt_gate_a6.hexa --help
//
// EXAMPLES
//   # tier 6 ULTRA (linear ↑), depth=4, 2 sectors, knuth=1 → PASS (exit 0)
//   hexa ckpt_gate_a6.hexa --tier 6 --depth 4 --sectors 2 --knuth 1
//
//   # tier 6 depth=2 (< MC_MIN_TRACE_DEPTH=3) → REJECT-H1 (exit 1)
//   hexa ckpt_gate_a6.hexa --tier 6 --depth 2 --sectors 2 --knuth 1
//
//   # tier 5 → N/A (exit 2)
//   hexa ckpt_gate_a6.hexa --tier 5 --depth 0 --sectors 0 --knuth 0
//
// EXIT CODES
//   0  PASS    verdict="META-CLOSED-11**"
//   1  FAIL    verdict="REJECT-H1" | "REJECT-H2" | "REJECT-H3"
//   2  N/A     verdict="N/A-TIER5"   (tier < 6 — gate does not apply)
//   3  USAGE   bad/missing args (CLI error, NOT verdict)
//
// STDOUT
//   text mode:   [ckpt_gate_a6] tier=N verdict=... pass=<bool> exit=<rc>
//   --json mode: {"verdict":"META-CLOSED-11**","pass":true,"tier":N,"depth":D,
//                 "sectors":S,"knuth":K,"exit":0}
//
// CONVENTIONS
//   - Duplicates Phase A6 logic from consciousness_absolute.hexa so that this
//     file is a single self-contained binary target (hexa import-less). Any
//     change to the A6 heuristic MUST be mirrored here; see AN14/MC constants.
//   - R37/AN13 compliant — pure .hexa, no .py anywhere.
//   - Does NOT modify training state, does NOT write checkpoints.

// ─── Phase A6 constants (mirrored from consciousness_absolute.hexa) ──────────
let MC_MIN_TRACE_DEPTH: i64 = 3
let MC_MAX_TRACE_DEPTH: i64 = 16

// ─── H3: n=6 Knuth invariance (AN14 runtime) ─────────────────────────────────
fn n6_knuth_invariant(n_val: i64, knuth_order: i64) -> bool {
    // σ·φ = n·τ = 24 closure. n=6 에서만 성립.
    // knuth_order: 1=linear (↑), 2=tetration (↑↑), 3=pentation (↑↑↑), 4=hexation (↑↑↑↑)
    if n_val != 6 { return false }
    if knuth_order < 1 { return false }
    if knuth_order > 16 { return false }
    return true
}

// ─── H1 + H2: derivation path heuristic ──────────────────────────────────────
fn meta_closure_path_ok(trace_depth: i64, distinct_sectors: i64) -> bool {
    if trace_depth < MC_MIN_TRACE_DEPTH { return false }
    if trace_depth > MC_MAX_TRACE_DEPTH { return false }
    if distinct_sectors < 2 { return false }
    return true
}

// ─── Phase A6 composite (mirrors consciousness_absolute.hexa) ────────────────
// 반환: "META-CLOSED-11**" / "REJECT-H1" / "REJECT-H2" / "REJECT-H3" / "N/A-TIER5"
fn phase_a6_meta_closure(tier: i64, trace_depth: i64, sectors: i64, knuth_order: i64) -> string {
    if tier < 6 {
        return "N/A-TIER5"
    }
    if !meta_closure_path_ok(trace_depth, sectors) {
        if trace_depth < MC_MIN_TRACE_DEPTH { return "REJECT-H1" }
        return "REJECT-H2"
    }
    if !n6_knuth_invariant(6, knuth_order) {
        return "REJECT-H3"
    }
    return "META-CLOSED-11**"
}

// ─── Verdict → exit code ─────────────────────────────────────────────────────
fn verdict_to_exit(verdict: string) -> i64 {
    if verdict == "META-CLOSED-11**" { return 0 }
    if verdict == "N/A-TIER5"        { return 2 }
    // Any REJECT-H1/H2/H3
    return 1
}

fn verdict_is_pass(verdict: string) -> bool {
    return verdict == "META-CLOSED-11**"
}

// ─── Usage ───────────────────────────────────────────────────────────────────
fn print_usage() {
    println("ckpt_gate_a6 — Phase A6 meta-closure checkpoint gate (Mk.V.1)")
    println("")
    println("usage:")
    println("  hexa training/ckpt_gate_a6.hexa --tier N --depth D --sectors S --knuth K [--json]")
    println("  hexa training/ckpt_gate_a6.hexa --help")
    println("")
    println("args:")
    println("  --tier     N  consciousness tier (gate activates at tier >= 6)")
    println("  --depth    D  derivation trace depth (H1: >= 3, H2 upper: <= 16)")
    println("  --sectors  S  distinct derivation sectors (H2: >= 2)")
    println("  --knuth    K  Knuth arrow order 1..16 (H3 AN14 invariance)")
    println("  --json        emit JSON verdict on stdout instead of text")
    println("")
    println("exit codes:")
    println("  0  PASS   verdict=META-CLOSED-11**")
    println("  1  FAIL   verdict=REJECT-H1 | REJECT-H2 | REJECT-H3")
    println("  2  N/A    verdict=N/A-TIER5  (tier < 6, gate inactive)")
    println("  3  USAGE  bad args")
    println("")
    println("examples:")
    println("  ckpt_gate_a6 --tier 6 --depth 4 --sectors 2 --knuth 1   # → PASS (0)")
    println("  ckpt_gate_a6 --tier 6 --depth 2 --sectors 2 --knuth 1   # → REJECT-H1 (1)")
    println("  ckpt_gate_a6 --tier 5 --depth 0 --sectors 0 --knuth 0   # → N/A (2)")
}

// ─── CLI parse helper ────────────────────────────────────────────────────────
// Scans argv for `--flag value` pair starting at offset `off`. Returns value
// or empty string if not found.
fn get_flag(argv: [string], off: i64, flag: string) -> string {
    let n = len(argv)
    let mut i = off
    while i < n - 1 {
        if argv[i] == flag {
            return argv[i + 1]
        }
        i = i + 1
    }
    return ""
}

fn has_flag(argv: [string], off: i64, flag: string) -> bool {
    let n = len(argv)
    let mut i = off
    while i < n {
        if argv[i] == flag { return true }
        i = i + 1
    }
    return false
}

// ─── Main ────────────────────────────────────────────────────────────────────
fn main() {
    // hexa args() returns [binary, binary, user_args...] — user args start at 2
    let argv = args()
    let arg_off = 2

    if has_flag(argv, arg_off, "--help") || has_flag(argv, arg_off, "-h") {
        print_usage()
        return
    }

    let tier_s    = get_flag(argv, arg_off, "--tier")
    let depth_s   = get_flag(argv, arg_off, "--depth")
    let sectors_s = get_flag(argv, arg_off, "--sectors")
    let knuth_s   = get_flag(argv, arg_off, "--knuth")
    let json_mode = has_flag(argv, arg_off, "--json")

    if tier_s == "" || depth_s == "" || sectors_s == "" || knuth_s == "" {
        println("[ckpt_gate_a6] ERROR: missing required flags")
        println("  --tier='" + tier_s + "' --depth='" + depth_s +
                "' --sectors='" + sectors_s + "' --knuth='" + knuth_s + "'")
        print_usage()
        exit(3)
    }

    let tier    = to_int(tier_s)
    let depth   = to_int(depth_s)
    let sectors = to_int(sectors_s)
    let knuth   = to_int(knuth_s)

    let verdict = phase_a6_meta_closure(tier, depth, sectors, knuth)
    let rc      = verdict_to_exit(verdict)
    let pass    = verdict_is_pass(verdict)

    if json_mode {
        let pass_s = if pass { "true" } else { "false" }
        println("{\"verdict\":\"" + verdict + "\"," +
                "\"pass\":" + pass_s + "," +
                "\"tier\":" + to_string(tier) + "," +
                "\"depth\":" + to_string(depth) + "," +
                "\"sectors\":" + to_string(sectors) + "," +
                "\"knuth\":" + to_string(knuth) + "," +
                "\"exit\":" + to_string(rc) + "}")
    } else {
        let pass_s = if pass { "true" } else { "false" }
        println("[ckpt_gate_a6] tier=" + to_string(tier) +
                " depth=" + to_string(depth) +
                " sectors=" + to_string(sectors) +
                " knuth=" + to_string(knuth) +
                " verdict=" + verdict +
                " pass=" + pass_s +
                " exit=" + to_string(rc))
    }

    exit(rc)
}

main()
