// build_libhxblas_cuda.hexa — build libhxblas_cuda.so on a CUDA-capable host
//
// What this does:
//   Wraps the gcc build of training/hxblas_cuda_shim.c into a hexa-executable
//   so the build provenance lives inside the repo's hexa-native tooling
//   surface (R37-friendly — no .sh). Runs gcc via `exec` plugin; gcc is the
//   standard system C compiler and needs no Python/Rust/shell in the loop.
//
// Usage (run on ubu or H100 pod with CUDA toolkit installed):
//   hexa training/build/build_libhxblas_cuda.hexa
//
// Host requirements:
//   - gcc ≥ 11
//   - libopenblas-dev (cblas.h + libopenblas.so)
//   - CUDA toolkit ≥ 12.0 (cublas_v2.h + libcublas.so + libcudart.so)
//
// Output:
//   training/build/libhxblas_cuda.so
//
// Re-smoke-test after build:
//   HXBLAS_CUDA=1 training/build/hxblas_cuda_smoke

use plugins/exec

fn main() {
    let src = "training/hxblas_cuda_shim.c"
    let out = "training/build/libhxblas_cuda.so"

    // Header / lib paths — tuned for ubuntu 24.04 + CUDA 12.8 layout.
    // Override by editing; H100 pod uses /usr/local/cuda same layout.
    let cblas_inc = "/usr/include/x86_64-linux-gnu"
    let cuda_inc  = "/usr/local/cuda/include"
    let cuda_lib  = "/usr/local/cuda/lib64"

    let cmd = "gcc -O3 -fPIC -shared -fopenmp"
        + " -DHXBLAS_ENABLE_CUDA=1"
        + " -I" + cuda_inc + " -I" + cblas_inc
        + " -L" + cuda_lib + " -Wl,-rpath," + cuda_lib
        + " " + src
        + " -o " + out
        + " -lopenblas -lcublas -lcudart -lm"

    println("[build_libhxblas_cuda] cmd: " + cmd)
    let rc = exec_system(cmd)
    if rc != 0 {
        println("[build_libhxblas_cuda] FAILED rc=" + rc.to_string())
        return
    }
    println("[build_libhxblas_cuda] libhxblas_cuda.so built at " + out)
    println("[build_libhxblas_cuda] Next: HXBLAS_CUDA=1 training/build/hxblas_cuda_smoke")
}
