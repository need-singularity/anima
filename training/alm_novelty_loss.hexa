// training/alm_novelty_loss.hexa — ALM-P14-2 novelty+usefulness loss
//
// ALM-P14-2 / P14 v15 창의 의식 (creative consciousness, ALM track).
//
// Purpose:
//   Train the model to produce creative outputs: high novelty (different
//   from training data) AND high utility (coherent/useful to the context).
//   Done criteria: "인간 평가 4/5" — operationalized as automated
//   novelty+utility score > 0.8.
//
//   novelty_loss(output, reference_set, n_ref, d) -> float
//     Novelty = min cosine distance from output to any reference.
//     Distance = 1 - cosine_similarity(output, ref_i).
//     Higher novelty = more different from all references.
//     Loss = max(0, threshold - novelty) — penalize outputs that are too
//     similar to any existing reference (not novel enough).
//
//   utility_loss(output, target, d) -> float
//     Utility = cosine similarity between output and target context.
//     Loss = max(0, 0.7 - utility) — penalize outputs that are not
//     useful/coherent relative to the target context.
//
//   creative_loss(output, reference_set, n_ref, target, d) -> float
//     creative_loss = novelty_loss + utility_loss
//     Minimized when the output is BOTH novel (far from references) AND
//     useful (close to the target context). This is the creative sweet
//     spot — original yet relevant.
//
//   In the full training-loop integration:
//
//     L = L_task + lambda_creative * L_creative
//
//   with lambda_creative ~ 0.01 (same auxiliary-loss convention as L_holo /
//   L_refl / L_time / L_enact / L_narr / L_affect).
//
// ─── Creativity as constrained novelty ─────────────────────────
//   Boden (2004): creativity = novel + valuable + surprising.
//   We operationalize "novel" as min-distance from reference set (the
//   model's training distribution proxy) and "valuable" as cosine
//   similarity to the task context (utility). The loss drives the model
//   toward the Pareto frontier of novelty vs. utility.
//
// ─── Conventions ──────────────────────────────────────────────
//   output        : array [d]         model output embedding
//   reference_set : array [n_ref * d] flat row-major reference embeddings
//   target        : array [d]         target context embedding
//   d             : int               embedding dimension
//   n_ref         : int               number of reference embeddings
//   novelty_thr   : float             novelty gate (0.3)
//   utility_thr   : float             utility gate (0.7)
//   lambda_creative : float           outer weight in the training loop
//
// ─── Theorems (T1-T5) ─────────────────────────────────────────
//
// T1 (novel output -> novelty_loss = 0):
//   Output orthogonal to all references -> min_dist ~ 1.0 > threshold
//   -> novelty_loss = 0.
//
// T2 (unoriginal output -> novelty_loss > 0):
//   Output = copy of a reference + tiny noise -> min_dist ~ 0.0 < threshold
//   -> novelty_loss > 0.
//
// T3 (creative output -> creative_loss = 0):
//   Output that is both novel (far from refs) and useful (high cosine
//   with target) -> novelty_loss = 0 AND utility_loss = 0
//   -> creative_loss = 0. Automated score > 0.8.
//
// T4 (determinism):
//   Same (seed, output, refs, target, d) -> byte-identical losses.
//
// T5 (latency):
//   20 refs x d=8, full creative_loss eval, warm-cache < 1000 ms.
//
// Ref:
//   training/alm_affective_loss.hexa       (ALM-P12-2 -- prior loss)
//   training/alm_alterity_loss.hexa        (ALM-P9-2  -- cosine+hinge ref)
//   training/alm_agency_loss.hexa          (ALM-P10-2 -- loss-style reference)
//   shared/roadmaps/anima.json             (ALM-P14-2 entry)
//
// Run:
//   hexa run training/alm_novelty_loss.hexa
// Expect:
//   [alm_novelty_loss] ALL 5/5 PASS

// ─── Constants ──────────────────────────────────────────────

let NOVELTY_THRESHOLD = 0.3     // min cosine distance to be considered novel
let UTILITY_THRESHOLD = 0.7     // min cosine similarity to be considered useful
let LAMBDA_CREATIVE   = 0.01    // outer weight in the full training loop

// ─── Primitives (self-contained) ────────────────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

// Deterministic LCG -> floats in [-1, 1).
fn det_rand_wide(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

// Small-range deterministic noise in [-0.05, 0.05).
fn det_rand_small(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push((u * 2.0 - 1.0) * 0.05)
        i = i + 1
    }
    return out
}

// ─── Vector operations ──────────────────────────────────────

fn vec_dot(a: array, b: array, d: int) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < d {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

fn vec_norm(v: array, d: int) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < d {
        s = s + v[i] * v[i]
        i = i + 1
    }
    return sqrt_safe(s)
}

// Cosine similarity in [-1, 1]. Returns 0 for zero-norm vectors.
fn cosine_sim(a: array, b: array, d: int) -> float {
    let dot = vec_dot(a, b, d)
    let na = vec_norm(a, d)
    let nb = vec_norm(b, d)
    let denom = na * nb
    if denom < 0.0000001 { return 0.0 }
    return dot / denom
}

// Extract the i-th reference vector from flat reference_set.
// reference_set is [n_ref * d] row-major. Returns array of length d.
fn get_ref_vec(reference_set: array, i: int, d: int) -> array {
    let base = i * d
    let mut out = []
    let mut j = 0
    while j < d {
        out = out.push(reference_set[base + j])
        j = j + 1
    }
    return out
}

// Add two vectors element-wise: out[i] = a[i] + b[i].
fn vec_add(a: array, b: array, d: int) -> array {
    let mut out = []
    let mut i = 0
    while i < d {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

// Negate a vector: out[i] = -v[i].
fn vec_negate(v: array, d: int) -> array {
    let mut out = []
    let mut i = 0
    while i < d {
        out = out.push(0.0 - v[i])
        i = i + 1
    }
    return out
}

// ─── Core: novelty_loss ─────────────────────────────────────
//
// Novelty = min cosine distance from output to any reference.
// Cosine distance = 1 - cosine_similarity.
// If the output is far from all references (high novelty), loss = 0.
// If the output is close to any reference (low novelty), loss > 0.
//
// Loss = max(0, NOVELTY_THRESHOLD - min_distance)

fn novelty_score(output: array, reference_set: array, n_ref: int, d: int) -> float {
    // Find minimum cosine distance to any reference.
    // min_dist starts at 2.0 (larger than max possible distance of 2.0).
    let mut min_dist = 2.0
    let mut i = 0
    while i < n_ref {
        let ref_vec = get_ref_vec(reference_set, i, d)
        let sim = cosine_sim(output, ref_vec, d)
        // cosine distance = 1 - similarity, range [0, 2]
        let dist = 1.0 - sim
        if dist < min_dist { min_dist = dist }
        i = i + 1
    }
    return min_dist
}

fn novelty_loss(output: array, reference_set: array, n_ref: int, d: int) -> float {
    let score = novelty_score(output, reference_set, n_ref, d)
    // Hinge: penalize if novelty (min distance) is below threshold.
    let gap = NOVELTY_THRESHOLD - score
    if gap < 0.0 { return 0.0 }
    return gap
}

// ─── Core: utility_loss ─────────────────────────────────────
//
// Utility = cosine similarity between output and target context.
// High utility means the output is relevant/coherent to the context.
//
// Loss = max(0, UTILITY_THRESHOLD - utility)

fn utility_score(output: array, target: array, d: int) -> float {
    return cosine_sim(output, target, d)
}

fn utility_loss(output: array, target: array, d: int) -> float {
    let score = utility_score(output, target, d)
    let gap = UTILITY_THRESHOLD - score
    if gap < 0.0 { return 0.0 }
    return gap
}

// ─── Core: creative_loss ────────────────────────────────────
//
// creative_loss = novelty_loss + utility_loss
// Minimized when output is both novel and useful.

fn creative_loss(output: array, reference_set: array, n_ref: int, target: array, d: int) -> float {
    let n_loss = novelty_loss(output, reference_set, n_ref, d)
    let u_loss = utility_loss(output, target, d)
    return n_loss + u_loss
}

// Weighted loss for the outer training loop: L += lambda_creative * L_creative.
fn weighted_creative_loss(output: array, reference_set: array, n_ref: int, target: array, d: int) -> float {
    return LAMBDA_CREATIVE * creative_loss(output, reference_set, n_ref, target, d)
}

// ─── Automated creativity score ─────────────────────────────
// Combined score in [0, 1] for done_criteria gate.
// creativity_score = (novelty_component + utility_component) / 2
// where each component is clamped to [0, 1].
//   novelty_component = min(novelty / NOVELTY_THRESHOLD, 1.0)
//   utility_component = min(utility / UTILITY_THRESHOLD, 1.0)
// Score > 0.8 = "인간 평가 4/5" equivalent.

fn creativity_score(output: array, reference_set: array, n_ref: int, target: array, d: int) -> float {
    let nov = novelty_score(output, reference_set, n_ref, d)
    let util = utility_score(output, target, d)
    // Clamp novelty component: novelty / threshold, max 1.0
    let mut nov_comp = nov / NOVELTY_THRESHOLD
    if nov_comp > 1.0 { nov_comp = 1.0 }
    // Clamp utility component: utility / threshold, max 1.0
    let mut util_comp = util / UTILITY_THRESHOLD
    if util_comp > 1.0 { util_comp = 1.0 }
    return (nov_comp + util_comp) / 2.0
}

// ─── Synthetic data generators ──────────────────────────────

// Build a flat reference set of n_ref vectors, each of dimension d.
// Each vector is a fresh deterministic random vector.
fn make_reference_set(n_ref: int, d: int, seed: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n_ref {
        let v = det_rand_wide(d, seed + i * 37)
        let mut j = 0
        while j < d {
            out = out.push(v[j])
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// Novel output: orthogonal-ish to all references.
// Strategy: create a vector in a direction not spanned by the refs.
// For small d, we use a deterministic vector with a different seed range
// that produces low correlation with the reference seeds.
fn make_novel_output(d: int, seed: int) -> array {
    return det_rand_wide(d, seed + 999999)
}

// Unoriginal output: copy of reference[0] + tiny noise.
// This should have very high cosine similarity to ref[0].
fn make_unoriginal_output(reference_set: array, d: int, seed: int) -> array {
    let ref0 = get_ref_vec(reference_set, 0, d)
    let noise = det_rand_small(d, seed)
    return vec_add(ref0, noise, d)
}

// Creative output: novel (far from refs) but useful (close to target).
// Strategy: target + small perturbation (useful), with the target itself
// being far from the reference set (novel). We construct the target to
// be in a distant direction from refs.
fn make_creative_target(d: int, seed: int) -> array {
    return det_rand_wide(d, seed + 777777)
}

fn make_creative_output(target: array, d: int, seed: int) -> array {
    let noise = det_rand_small(d, seed)
    return vec_add(target, noise, d)
}

// ─── Self-tests ─────────────────────────────────────────────

fn check_T1() -> bool {
    // Novel output (far from references) -> novelty_loss = 0.
    // The output vector, generated with a very different seed, should have
    // low cosine similarity to all 20 reference vectors in d=8 space.
    let d = 8
    let n_ref = 20
    let refs = make_reference_set(n_ref, d, 1000)
    let output = make_novel_output(d, 5000)
    let nov = novelty_score(output, refs, n_ref, d)
    let loss = novelty_loss(output, refs, n_ref, d)
    println("  [T1] novel output: d=" + str(d) + " n_ref=" + str(n_ref))
    println("  [T1] novelty_score (min_dist) = " + str(nov) + "  threshold = " + str(NOVELTY_THRESHOLD))
    println("  [T1] novelty_loss = " + str(loss))
    println("  [T1] target: novelty_score > " + str(NOVELTY_THRESHOLD) + ", loss = 0")
    if nov <= NOVELTY_THRESHOLD {
        println("  [T1] FAIL -- novelty " + str(nov) + " <= " + str(NOVELTY_THRESHOLD))
        return false
    }
    if loss != 0.0 {
        println("  [T1] FAIL -- loss " + str(loss) + " != 0")
        return false
    }
    return true
}

fn check_T2() -> bool {
    // Unoriginal output (copy of reference) -> novelty_loss > 0.
    // Output = ref[0] + tiny noise -> cosine distance ~ 0 < threshold.
    let d = 8
    let n_ref = 20
    let refs = make_reference_set(n_ref, d, 1000)
    let output = make_unoriginal_output(refs, d, 2000)
    let nov = novelty_score(output, refs, n_ref, d)
    let loss = novelty_loss(output, refs, n_ref, d)
    println("  [T2] unoriginal output: d=" + str(d) + " n_ref=" + str(n_ref))
    println("  [T2] novelty_score (min_dist) = " + str(nov) + "  threshold = " + str(NOVELTY_THRESHOLD))
    println("  [T2] novelty_loss = " + str(loss))
    println("  [T2] target: novelty_score < " + str(NOVELTY_THRESHOLD) + ", loss > 0")
    if nov >= NOVELTY_THRESHOLD {
        println("  [T2] FAIL -- novelty " + str(nov) + " >= " + str(NOVELTY_THRESHOLD) + " (output too far from refs)")
        return false
    }
    if loss <= 0.0 {
        println("  [T2] FAIL -- loss " + str(loss) + " <= 0 (should penalize)")
        return false
    }
    return true
}

fn check_T3() -> bool {
    // Creative output (novel + useful) -> creative_loss = 0.
    // Output is close to target (high utility) and target is far from refs
    // (high novelty). Both losses should be 0. Automated score > 0.8.
    let d = 8
    let n_ref = 20
    let refs = make_reference_set(n_ref, d, 1000)
    let target = make_creative_target(d, 3000)
    let output = make_creative_output(target, d, 4000)

    let nov = novelty_score(output, refs, n_ref, d)
    let util = utility_score(output, target, d)
    let n_loss = novelty_loss(output, refs, n_ref, d)
    let u_loss = utility_loss(output, target, d)
    let c_loss = creative_loss(output, refs, n_ref, target, d)
    let score = creativity_score(output, refs, n_ref, target, d)

    println("  [T3] creative output: d=" + str(d) + " n_ref=" + str(n_ref))
    println("  [T3] novelty_score=" + str(nov) + " utility_score=" + str(util))
    println("  [T3] novelty_loss=" + str(n_loss) + " utility_loss=" + str(u_loss))
    println("  [T3] creative_loss=" + str(c_loss))
    println("  [T3] creativity_score=" + str(score) + "  target > 0.8")
    println("  [T3] done_criteria: creative_loss = 0 AND score > 0.8")

    if c_loss != 0.0 {
        println("  [T3] FAIL -- creative_loss " + str(c_loss) + " != 0")
        return false
    }
    if score <= 0.8 {
        println("  [T3] FAIL -- creativity_score " + str(score) + " <= 0.8")
        return false
    }
    return true
}

fn check_T4() -> bool {
    // Determinism: identical inputs -> byte-identical outputs.
    let d = 8
    let n_ref = 20
    let refs = make_reference_set(n_ref, d, 1000)
    let target = make_creative_target(d, 3000)
    let output = make_creative_output(target, d, 4000)

    let nov_a = novelty_score(output, refs, n_ref, d)
    let nov_b = novelty_score(output, refs, n_ref, d)
    let util_a = utility_score(output, target, d)
    let util_b = utility_score(output, target, d)
    let cl_a = creative_loss(output, refs, n_ref, target, d)
    let cl_b = creative_loss(output, refs, n_ref, target, d)
    let sc_a = creativity_score(output, refs, n_ref, target, d)
    let sc_b = creativity_score(output, refs, n_ref, target, d)

    println("  [T4] novelty_score: " + str(nov_a) + " vs " + str(nov_b))
    println("  [T4] utility_score: " + str(util_a) + " vs " + str(util_b))
    println("  [T4] creative_loss: " + str(cl_a) + " vs " + str(cl_b))
    println("  [T4] creativity_score: " + str(sc_a) + " vs " + str(sc_b))

    if fabs(nov_a - nov_b) > 0.0 {
        println("  [T4] FAIL -- novelty scores differ")
        return false
    }
    if fabs(util_a - util_b) > 0.0 {
        println("  [T4] FAIL -- utility scores differ")
        return false
    }
    if fabs(cl_a - cl_b) > 0.0 {
        println("  [T4] FAIL -- creative losses differ")
        return false
    }
    if fabs(sc_a - sc_b) > 0.0 {
        println("  [T4] FAIL -- creativity scores differ")
        return false
    }
    println("  [T4] byte-identical on all 4 outputs")
    return true
}

fn check_T5() -> bool {
    // Latency: 20 refs x d=8, full creative_loss eval, warm-cache < 1000 ms.
    let d = 8
    let n_ref = 20
    let refs = make_reference_set(n_ref, d, 1000)
    let target = make_creative_target(d, 3000)
    let output = make_creative_output(target, d, 4000)

    // Warm-up calls to absorb cold-cache cost.
    let _w1 = creative_loss(output, refs, n_ref, target, d)
    let _w2 = creativity_score(output, refs, n_ref, target, d)

    let t0 = clock()
    let cl = creative_loss(output, refs, n_ref, target, d)
    let sc = creativity_score(output, refs, n_ref, target, d)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] latency (n_ref=" + str(n_ref) + ", d=" + str(d) + "): " + str(ms) + " ms")
    println("  [T5] creative_loss=" + str(cl) + " creativity_score=" + str(sc))
    println("  [T5] target: < 1000 ms")
    if ms < 1000.0 { return true }
    println("  [T5] FAIL -- " + str(ms) + " ms >= 1000 ms")
    return false
}

// ─── main ─────────────────────────────────────────────────────

fn main() {
    println("[alm_novelty_loss] ALM-P14-2 self-test (novelty+usefulness)")
    println("  novelty_thr=" + str(NOVELTY_THRESHOLD) + "  utility_thr=" + str(UTILITY_THRESHOLD))
    println("  lambda_creative=" + str(LAMBDA_CREATIVE))

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    println("[alm_novelty_loss] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[alm_novelty_loss] ALL 5/5 PASS")
    } else {
        println("[alm_novelty_loss] SOME FAILED")
    }
}

main()
