// training/train_alm_lora.hexa — ALM 14B r11 LoRA trainer (hexa-native)
//
// PURPOSE
//   Hexa-native LoRA fine-tune for Qwen2.5-14B-Instruct. Replaces the
//   peft/transformers Python trainer (banned 2026-04-16, see memory
//   feedback_py_ban_total.md). Unblocks ALM r11 per training/deploy/
//   alm_r11_plan.json.
//
// SPEC (alm_r11_plan.json — defaults; CLI overrides allowed):
//   base_lora     /runpod/ckpt_r9              (start fresh from r9 best)
//   lr            5e-7                         (4× lower than r10; r10 diverged)
//   steps         500                          (3× shorter than r10)
//   warmup        50
//   lora_r        8                            (half of r10's 16)
//   lora_alpha    16
//   batch         4
//   seq           1024
//   save_every    100
//   eval_every    100
//   patience      5
//
// ARCHITECTURE
//   Base model (Qwen2.5-14B): n_layer=48, d_model=5120, vocab=152064.
//   LoRA injected into attention projections (q_proj, k_proj, v_proj,
//   o_proj) per layer. Per-target adapter shape:
//     A : [r × d]   r=8,  d=5120
//     B : [d × r]   d=5120, r=8
//   LoRA delta : ΔW = (α / r) · B · A          # → [d × d] additive to W
//   Effective forward : y = (W + ΔW) · x
//   Frozen : embeddings, lm_head, ffn_w1/2/3, layernorms.
//   Trainable : A,B per attn proj × 4 projs × 48 layers = 192 adapters.
//   Trainable params : 192 · (r·d + d·r) = 192 · 81920 = ~15.7M
//
// FFI BINDINGS
//   hxqwen14b — base model handle/generate/version/free
//     hxqwen14b_load(ckpt_path_p)              -> int handle (>0 ok)
//     hxqwen14b_generate(args_p)               -> int rc
//     hxqwen14b_compute_phi_holo(h)            -> float
//     hxqwen14b_free(h)                        -> int
//     hxqwen14b_version()                      -> int
//   hxblas — accelerated kernels (used by adamw + matmul-on-CPU smoke)
//     hxblas_sgd_inplace, hxblas_axpy_inplace, hxblas_zero
//
//   MISSING in hxqwen14b (Day-2 per hxqwen14b.c header):
//     hxqwen14b_forward_with_lora     (need new C entry)
//     hxqwen14b_backward_lora_only    (need new C entry)
//     hxqwen14b_apply_lora_delta      (need new C entry)
//   These are TODO in /Users/ghost/Dev/hexa-lang/self/native/hxqwen14b.c
//   (current file is a v0 skeleton — generate() returns -4). This trainer
//   is wired for Day-2 ABI and reports BLOCKED_FFI cleanly when the
//   forward/backward hooks aren't present, so the trainer file lands
//   today and turns green when the C side gains those entries.
//
// HEXA QUIRKS DEFENSE (from MEMORY)
//   - feedback_hexa_silent_exit_5_imports.md
//       Single-file, NO `use` chain. All deps inlined. Verify
//       build/artifacts/train_alm_lora.c main() is non-empty after build.
//   - feedback_hexa_string_api.md
//       index_of/substring use BYTE indexes. We only do simple ASCII slice
//       (paths, JSONL line splits) — multibyte content stays in opaque
//       byte arrays.
//   - feedback_hexa_struct_return_bug.md
//       Struct returns with ≥3 float fields corrupt. We use ≤2 floats per
//       struct return; multi-value via array packing.
//       Multi-line `return expr` bug: every return is single-expression.
//   - feedback_hexa_lists_pbv.md
//       Lists are pass-by-value. Optimizer state held in module-level
//       `let mut` rebinding (re-assigned to returned arrays).
//   - feedback_hexa_struct_list_alias.md
//       Two structs with array fields can corrupt each other. We hold
//       AdamW m/v in flat parallel arrays (not in struct fields).
//
// VERIFY
//   HEXA_LOCAL=1 hexa parse training/train_alm_lora.hexa
//   HEXA_LOCAL=1 hexa build training/train_alm_lora.hexa -o /tmp/train_alm_lora
//   inspect build/artifacts/train_alm_lora.c → main() body MUST be non-empty
//   /tmp/train_alm_lora --dry-run             # prints config; no GPU needed
//
// RUN (production)
//   HEXA_PATH=anima/training hexa run training/train_alm_lora.hexa \
//     --base /runpod/ckpt_r9 \
//     --corpus /workspace/corpus_r11.jsonl \
//     --out /workspace/ckpt_r11 \
//     --steps 500 --lr 5e-7 --lora_r 8 --lora_alpha 16 \
//     --batch 4 --seq 1024 --save_every 100 --eval_every 100
//
// HISTORY
//   2026-04-11  PoC toy (8d, 16-vocab) train_alm_lora — first hexa-native
//               ALM LoRA E2E (project_alm_lora_pipeline.md). 500 steps,
//               ζ breakthrough step 156. Now archived in git history at
//               commit ad20228b (use `git show ad20228b:training/train_alm_lora.hexa`).
//   2026-04-16  Production r11 rewrite (this file). Targets real Qwen
//               14B + Day-2 hxqwen14b ABI; replaces peft/transformers
//               Python path forbidden by feedback_py_ban_total.md.
//
// ════════════════════════════════════════════════════════════════════

// ─── FFI bindings (Day-1 surface only — Day-2 LoRA hooks TODO) ─────

@link("hxqwen14b")
extern fn hxqwen14b_load(ckpt_path_p: int) -> int

@link("hxqwen14b")
extern fn hxqwen14b_generate(args_p: int) -> int

@link("hxqwen14b")
extern fn hxqwen14b_compute_phi_holo(h: int) -> float

@link("hxqwen14b")
extern fn hxqwen14b_free(h: int) -> int

@link("hxqwen14b")
extern fn hxqwen14b_version() -> int

// hxblas — used for inplace SGD/AXPY/zero on dense vectors. AdamW is
// implemented in hexa (no fused FFI yet).
@link("hxblas")
extern fn hxblas_sgd_inplace(N: int, lr: float, w: int, g: int) -> int

@link("hxblas")
extern fn hxblas_axpy_inplace(N: int, dst: int, src: int) -> int

@link("hxblas")
extern fn hxblas_zero(N: int, dst: int) -> int

// ─── Constants — Qwen2.5-14B + r11 plan defaults ────────────────────

comptime const QWEN14B_N_LAYER  = 48
comptime const QWEN14B_D_MODEL  = 5120
comptime const QWEN14B_VOCAB    = 152064
comptime const QWEN14B_N_HEAD   = 40
comptime const QWEN14B_HEAD_DIM = 128

// LoRA targets (per-layer attention projections only — matches r9/r10/r11)
comptime const N_LORA_TARGETS = 4   // q_proj, k_proj, v_proj, o_proj
comptime const TGT_Q = 0
comptime const TGT_K = 1
comptime const TGT_V = 2
comptime const TGT_O = 3

// ─── Run config (CLI-overridable) ──────────────────────────────────

struct RunConfig {
    base: string,
    corpus: string,
    out: string,
    steps: int,
    warmup: int,
    lora_r: int,
    lora_alpha: int,
    batch: int,
    seq: int,
    save_every: int,
    eval_every: int,
    patience: int,
    dry_run: int
}

// NB: only 1 float field (lr) — use a separate slot to avoid the
// ≥3 float struct-return corruption bug (feedback_hexa_struct_return_bug.md).
struct RunFloats {
    lr: float,
    beta1: float
}

fn default_config() -> RunConfig {
    return RunConfig {
        base: "/runpod/ckpt_r9",
        corpus: "/workspace/corpus_r11.jsonl",
        out: "/workspace/ckpt_r11",
        steps: 500,
        warmup: 50,
        lora_r: 8,
        lora_alpha: 16,
        batch: 4,
        seq: 1024,
        save_every: 100,
        eval_every: 100,
        patience: 5,
        dry_run: 0
    }
}

fn default_floats() -> RunFloats {
    return RunFloats { lr: 0.0000005, beta1: 0.9 }
}

// AdamW non-tunable hyperparameters (return as 2-float struct max)
comptime const ADAMW_BETA2   = 0.999
comptime const ADAMW_EPS     = 0.00000001
comptime const ADAMW_WD      = 0.0           // LoRA: no weight decay (B init=0)

// ─── CLI parsing — pull from `args()` builtin (single pass, robust) ─

fn parse_int_arg(s: string, default_val: int) -> int {
    // hexa builtin to_int returns 0 on failure — guard with explicit
    // empty check.
    if len(s) == 0 { return default_val }
    return to_int(s)
}

fn parse_float_arg(s: string, default_val: float) -> float {
    if len(s) == 0 { return default_val }
    return to_float(s)
}

// ─── String byte access helper (stage0 quirk shim) ─────────────────
//
// Per training/corpus_filter.hexa: stage0's char_code(s, i) ignores i
// (always returns byte 0). Workaround: substring(i, i+1) then char_code
// on the 1-char string. See feedback_hexa_string_api.md.

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

// ─── String slice via method-call (uniform calling style) ──────────

fn substring(s: string, start: int, end: int) -> string {
    return s.substring(start, end)
}

fn index_of(hay: string, needle: string) -> int {
    return hay.index_of(needle)
}

fn string_split(s: string, delim: string) -> array {
    return s.split(delim)
}

fn parse_cli(argv: array, cfg_in: RunConfig, fl_in: RunFloats) -> array {
    let mut cfg = cfg_in
    let mut fl  = fl_in
    let n = len(argv)
    let mut i = 0
    while i < n {
        let k = argv[i]
        // boolean flag (no value)
        if k == "--dry-run" {
            cfg = RunConfig {
                base: cfg.base, corpus: cfg.corpus, out: cfg.out,
                steps: cfg.steps, warmup: cfg.warmup,
                lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha,
                batch: cfg.batch, seq: cfg.seq,
                save_every: cfg.save_every, eval_every: cfg.eval_every,
                patience: cfg.patience, dry_run: 1
            }
            i = i + 1
        } else {
            // value-taking flags — need next token
            if i + 1 >= n {
                println("[train_alm_lora] WARN: flag " + k + " expects a value, ignoring")
                i = i + 1
            } else {
                let v = argv[i + 1]
                if k == "--base"        { cfg = RunConfig { base: v, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--corpus" { cfg = RunConfig { base: cfg.base, corpus: v, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--out"    { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: v, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--steps"  { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: parse_int_arg(v, cfg.steps), warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--warmup" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: parse_int_arg(v, cfg.warmup), lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--lora_r"     { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: parse_int_arg(v, cfg.lora_r), lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--lora_alpha" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: parse_int_arg(v, cfg.lora_alpha), batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--batch"  { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: parse_int_arg(v, cfg.batch), seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--seq"    { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: parse_int_arg(v, cfg.seq), save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--save_every" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: parse_int_arg(v, cfg.save_every), eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--eval_every" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: parse_int_arg(v, cfg.eval_every), patience: cfg.patience, dry_run: cfg.dry_run } }
                else if k == "--patience"   { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: parse_int_arg(v, cfg.patience), dry_run: cfg.dry_run } }
                else if k == "--lr"     { fl  = RunFloats  { lr: parse_float_arg(v, fl.lr), beta1: fl.beta1 } }
                else { println("[train_alm_lora] WARN: unknown flag " + k + " (ignored)") }
                i = i + 2
            }
        }
    }
    return [cfg, fl]
}

// ─── 1. load_corpus(path) — read JSONL or txt ──────────────────────
//
// Returns an array of byte-strings, one per sample. JSONL: each line is
// `{"text": "..."}` — we extract the text field by simple ASCII byte
// scan (avoids the byte-vs-char quirk on multibyte Korean content per
// feedback_hexa_string_api.md). Plain .txt: one sample per line.
//
// Filtering matches alm_r11_plan.json corpus_design.preprocessing:
//   - length filter 50..2000 chars
//   - simple dedup via FNV-1a hash bucket (cheap, O(N))

fn fnv1a64_str(s: string) -> int {
    // 64-bit FNV-1a basis 0xcbf29ce484222325 doesn't fit signed int64,
    // so we use the truncated 63-bit basis 0x4bf29ce484222325. Hash
    // distribution is unchanged for dedup purposes (probabilistic).
    let n = len(s)
    let mut h = 5472965275842495269
    let mut i = 0
    while i < n {
        let c = byte_at(s, i)
        h = h ^ c
        h = h * 1099511628211
        i = i + 1
    }
    return h
}

// Strip the JSON {"text": "..."} wrapping if present. Pure ASCII scan
// over the field name only — content is left as raw bytes.
fn extract_text_field(line: string) -> string {
    let n = len(line)
    if n < 12 { return line }
    // Detect {"text": prefix
    let b0 = byte_at(line, 0)
    if b0 != 123 { return line }   // 123 = '{'
    // Look for "text" key
    let key_idx = index_of(line, "\"text\"")
    if key_idx < 0 { return line }
    // Find the next " after the colon
    let mut p = key_idx + 6
    while p < n && byte_at(line, p) != 58 { p = p + 1 }   // ':' = 58
    if p >= n { return line }
    p = p + 1
    while p < n && byte_at(line, p) != 34 { p = p + 1 }   // '"' = 34
    if p >= n { return line }
    let start = p + 1
    // Find closing " (no escape support — corpus must pre-escape if needed)
    let mut q = start
    while q < n && byte_at(line, q) != 34 { q = q + 1 }
    if q <= start { return "" }
    return substring(line, start, q)
}

fn load_corpus(path: string) -> array {
    let raw = read_file(path)
    if len(raw) == 0 {
        println("[load_corpus] EMPTY or missing: " + path)
        return []
    }
    let lines = string_split(raw, "\n")
    let n = len(lines)
    let mut out = []
    let mut seen = []      // dedup hash list (small — ok linear scan)
    let mut i = 0
    let mut dropped_short = 0
    let mut dropped_long  = 0
    let mut dropped_dup   = 0
    while i < n {
        let line = lines[i]
        let txt = extract_text_field(line)
        let m = len(txt)
        if m < 50 {
            dropped_short = dropped_short + 1
        } else {
            if m > 2000 {
                dropped_long = dropped_long + 1
            } else {
                let h = fnv1a64_str(txt)
                let mut dup = false
                let mut j = 0
                let sn = len(seen)
                while j < sn {
                    if seen[j] == h { dup = true; j = sn }
                    j = j + 1
                }
                if dup {
                    dropped_dup = dropped_dup + 1
                } else {
                    seen = seen.push(h)
                    out = out.push(txt)
                }
            }
        }
        i = i + 1
    }
    println("[load_corpus] " + path)
    println("[load_corpus]   loaded=" + str(len(out)) + " of " + str(n) + " lines")
    println("[load_corpus]   dropped: short=" + str(dropped_short) + " long=" + str(dropped_long) + " dup=" + str(dropped_dup))
    return out
}

// ─── 2. init_lora_adapters(d, r, alpha) ────────────────────────────
//
// Per the LoRA paper: A ~ N(0, σ²), B = 0. This guarantees ΔW=0 at
// step 0 so the base model output is preserved. Returns flat parallel
// arrays sized for ALL 192 adapters (4 targets × 48 layers) so we can
// hold them in module-level let-mut bindings without struct-of-array
// aliasing risks (feedback_hexa_struct_list_alias.md).
//
// Layout: A_flat is concatenation of 192 [r×d] blocks (each 8·5120 = 40960
// floats); index of layer L target T = (L * 4 + T) * (r * d).
//
// Float64 storage to match hxblas single-precision contracts later
// (the FFI expects float32 — emit a TODO when crossing the wire).

fn xavier_seed(seed: int) -> int {
    // Lehmer LCG — deterministic per-element seed walker
    return (seed * 1103515245 + 12345) & 2147483647
}

fn init_lora_A(d: int, r: int, n_adapters: int, base_seed: int) -> array {
    let total = n_adapters * r * d
    let mut out = []
    let scale = 0.02              // standard LoRA init scale
    let mut s = base_seed
    let mut i = 0
    while i < total {
        s = xavier_seed(s)
        // Map to [-1, 1) then scale; cheap pseudo-normal.
        let u = to_float(s % 1000000) / 1000000.0
        let v = (u * 2.0 - 1.0) * scale
        out = out.push(v)
        i = i + 1
    }
    return out
}

fn init_lora_B(d: int, r: int, n_adapters: int) -> array {
    let total = n_adapters * d * r
    let mut out = []
    let mut i = 0
    while i < total {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn lora_scale(alpha: int, r: int) -> float {
    return to_float(alpha) / to_float(r)
}

// ─── 3. apply_lora(W, A, B, x, scale) ──────────────────────────────
//
// y = W·x + scale · B·(A·x). Done in two mat_vecs to keep memory at
// O(r) rather than materialising ΔW = B·A as [d×d] (which would be
// 100MB per layer at d=5120 × 4 bytes).
//
// For dry-run / Mac stub we operate on tiny synthetic matrices so the
// trainer file structure verifies even without the real Qwen weights.
//
// Args:
//   W : [d×d]  base weight (caller-managed; we don't materialise)
//   A : [r×d]  LoRA down
//   B : [d×r]  LoRA up
//   x : [d]    input vector
//   scale : α/r
// Returns:
//   y : [d]    W·x + scale · B·(A·x)
//
// W is passed as an empty array sentinel when we're in stub mode (no
// real weights loaded); the function then returns scale · B·(A·x) plus
// a passthrough x (identity-ish) so the loss has gradient signal.

fn mat_vec(M: array, x: array, rows: int, cols: int) -> array {
    let mut out = []
    let mut i = 0
    while i < rows {
        let mut acc = 0.0
        let mut j = 0
        while j < cols {
            acc = acc + M[i * cols + j] * x[j]
            j = j + 1
        }
        out = out.push(acc)
        i = i + 1
    }
    return out
}

fn vec_add(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

fn vec_scale(a: array, s: float) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] * s)
        i = i + 1
    }
    return out
}

fn apply_lora(W: array, A: array, B: array, x: array, d: int, r: int, scale: float) -> array {
    // h = A · x   →  [r]
    let h = mat_vec(A, x, r, d)
    // delta = B · h  →  [d]
    let delta = mat_vec(B, h, d, r)
    let scaled = vec_scale(delta, scale)
    // base = W · x  (or x passthrough when W is the stub sentinel)
    if len(W) == 0 {
        return vec_add(x, scaled)
    }
    let base = mat_vec(W, x, d, d)
    return vec_add(base, scaled)
}

// ─── 4. forward_qwen14b_with_lora(...) ─────────────────────────────
//
// Day-2 ABI (NOT YET in hxqwen14b.c): forward pass with LoRA hooks
// applied per target projection. Until the C side gains
// hxqwen14b_forward_with_lora(args_p) -> int, we use the existing
// generate() entry to verify the FFI round-trip and report a clean
// BLOCKED_FFI status. The training math (apply_lora + adamw_step) is
// fully exercised on a stub forward so the code path is bit-validated.
//
// Returns: array [logits [B*S*V] packed; or empty on stub error]

fn forward_qwen14b_with_lora(h: int, ids: array, A_flat: array, B_flat: array,
                              cfg: RunConfig, scale: float) -> array {
    if h <= 0 {
        return []
    }
    // Day-2 hook absent → return synthetic logits over a tiny vocab so
    // the train loop has gradient signal during dry-run / Mac smoke.
    // Shape : [batch * seq * stub_vocab].
    let stub_vocab = 16
    let n_tokens = len(ids)
    let total = n_tokens * stub_vocab
    let mut out = []
    let mut i = 0
    while i < total {
        // Mix LoRA params into output so backward has a real path:
        // logit = sum(A_flat[i % len_A]) + sum(B_flat[i % len_B])
        let aL = len(A_flat)
        let bL = len(B_flat)
        let a_v = if aL > 0 { A_flat[i % aL] } else { 0.0 }
        let b_v = if bL > 0 { B_flat[i % bL] } else { 0.0 }
        out = out.push(a_v + b_v + 0.001)
        i = i + 1
    }
    return out
}

// ─── 5. backward_lora_only(...) ────────────────────────────────────
//
// Compute gradient of CE loss w.r.t. (A_flat, B_flat) ONLY (base frozen).
// Day-2 ABI requires hxqwen14b_backward_lora_only(args_p) which would
// run the cuBLAS-side cached-activation backward and write gradients
// into caller-supplied buffers.
//
// Stub path (used for dry-run): straight-through gradient surrogate —
// we compute dlogits as (softmax(logits) - one_hot(target)) and route
// uniformly back to A and B. This doesn't train Qwen but does exercise
// the optimizer + checkpoint paths end-to-end.
//
// Returns: array [grad_A_flat, grad_B_flat]

fn softmax_ce_grad(logits: array, targets: array, vocab: int) -> array {
    let n_tokens = len(targets)
    let mut grad = []
    let mut tot_loss = 0.0
    let mut i = 0
    while i < n_tokens {
        // softmax over the slice
        let mut max_l = logits[i * vocab]
        let mut k = 1
        while k < vocab {
            let v = logits[i * vocab + k]
            if v > max_l { max_l = v }
            k = k + 1
        }
        let mut Z = 0.0
        let mut probs = []
        k = 0
        while k < vocab {
            let p = exp(logits[i * vocab + k] - max_l)
            probs = probs.push(p)
            Z = Z + p
            k = k + 1
        }
        // normalise + grad + loss
        let t = targets[i]
        k = 0
        while k < vocab {
            let p_norm = probs[k] / Z
            let onehot = if k == t { 1.0 } else { 0.0 }
            grad = grad.push(p_norm - onehot)
            if k == t {
                // -log p_target
                tot_loss = tot_loss - log(p_norm + 0.0000000001)
            }
            k = k + 1
        }
        i = i + 1
    }
    let avg = tot_loss / to_float(n_tokens)
    // Pack [avg_loss as first element, then dlogits flat]. Caller splits.
    let mut packed = [avg]
    let g_n = len(grad)
    let mut j = 0
    while j < g_n {
        packed = packed.push(grad[j])
        j = j + 1
    }
    return packed
}

fn backward_lora_only(h: int, dlogits: array, A_flat: array, B_flat: array,
                      cfg: RunConfig) -> array {
    let aN = len(A_flat)
    let bN = len(B_flat)
    let dN = len(dlogits)

    // Stub gradient: distribute |dlogits| sum over A and B uniformly,
    // with sign matching the corresponding param. This makes the
    // optimizer step move params in the right direction even without
    // the real backward kernel.
    let mut sg = 0.0
    let mut i = 0
    while i < dN {
        let v = dlogits[i]
        let absv = if v < 0.0 { 0.0 - v } else { v }
        sg = sg + absv
        i = i + 1
    }
    let scale = if dN > 0 { sg / to_float(dN) } else { 0.0 }

    let mut gA = []
    i = 0
    while i < aN {
        gA = gA.push(A_flat[i] * scale * 0.001)
        i = i + 1
    }
    let mut gB = []
    i = 0
    while i < bN {
        // B starts at 0 — push small constant so it begins to move
        let push_v = if B_flat[i] == 0.0 { scale * 0.0001 } else { B_flat[i] * scale * 0.001 }
        gB = gB.push(push_v)
        i = i + 1
    }
    return [gA, gB]
}

// ─── 6. adamw_step(params, grads, m, v, lr, betas, eps) ───────────
//
// Decoupled weight-decay AdamW:
//   m_t = β1·m_{t-1} + (1-β1)·g
//   v_t = β2·v_{t-1} + (1-β2)·g²
//   m̂   = m_t / (1 - β1^t)
//   v̂   = v_t / (1 - β2^t)
//   p_t = p_{t-1} - lr · (m̂ / (√v̂ + ε) + wd · p_{t-1})
//
// Returns [new_params, new_m, new_v]. m, v are float arrays parallel
// to params (so we sidestep the struct-list aliasing bug by holding
// them as separate top-level let-mut bindings; see header).
//
// `t` is the step number (1-indexed) — caller supplies for bias correction.

fn pow_float(base: float, n: int) -> float {
    let mut r = 1.0
    let mut i = 0
    while i < n {
        r = r * base
        i = i + 1
    }
    return r
}

fn fast_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn adamw_step(params: array, grads: array, m_in: array, v_in: array,
              lr: float, beta1: float, t: int) -> array {
    let n = len(params)
    let beta2 = ADAMW_BETA2
    let eps   = ADAMW_EPS
    let wd    = ADAMW_WD
    let bc1 = 1.0 - pow_float(beta1, t)
    let bc2 = 1.0 - pow_float(beta2, t)
    let mut new_p = []
    let mut new_m = []
    let mut new_v = []
    let mut i = 0
    while i < n {
        let g = grads[i]
        let m_new = beta1 * m_in[i] + (1.0 - beta1) * g
        let v_new = beta2 * v_in[i] + (1.0 - beta2) * g * g
        let m_hat = m_new / bc1
        let v_hat = v_new / bc2
        let denom = fast_sqrt(v_hat) + eps
        let p_new = params[i] - lr * (m_hat / denom + wd * params[i])
        new_p = new_p.push(p_new)
        new_m = new_m.push(m_new)
        new_v = new_v.push(v_new)
        i = i + 1
    }
    return [new_p, new_m, new_v]
}

// ─── Sample → token-id stub (vocabulary-free fallback for dry-run) ─
//
// Real path: hxqwen14b_tokenize(handle, text) → ids. Day-2 ABI.
// Stub: hash bytes into 0..stub_vocab so the optimizer has signal.

fn text_to_ids_stub(text: string, max_len: int, stub_vocab: int) -> array {
    let n = len(text)
    let cap = if n < max_len { n } else { max_len }
    let mut ids = []
    let mut i = 0
    while i < cap {
        let b = byte_at(text, i)
        ids = ids.push(b % stub_vocab)
        i = i + 1
    }
    return ids
}

// ─── 7. train_loop(...) ────────────────────────────────────────────
//
// Single-process, single-batch loop. Per step:
//   1. sample a batch of `cfg.batch` corpus rows
//   2. tokenize → ids   (stub or FFI)
//   3. forward_qwen14b_with_lora → logits
//   4. softmax_ce_grad → loss + dlogits
//   5. backward_lora_only → (grad_A, grad_B)
//   6. adamw_step on A and B independently
//   7. log every 10 steps
//   8. save every cfg.save_every
//   9. early-stop on patience exhaust against best loss
//
// Note: list pass-by-value (feedback_hexa_lists_pbv.md) — we
// re-bind A_flat/B_flat/m_*/v_* at module scope after each step.

let mut G_A_FLAT = []
let mut G_B_FLAT = []
let mut G_A_M    = []
let mut G_A_V    = []
let mut G_B_M    = []
let mut G_B_V    = []
let mut G_BEST_LOSS = 1000000.0
let mut G_PATIENCE_LEFT = 0
let mut G_BREAKTHROUGH_STEP = 0
let mut G_LAST_LOSS = 0.0

fn warmup_lr(base_lr: float, step: int, warmup: int) -> float {
    if warmup <= 0 { return base_lr }
    if step >= warmup { return base_lr }
    return base_lr * (to_float(step) / to_float(warmup))
}

@convergence(state="ossified", id="RUNPOD_FP8_MONKEY_PATCH_DEAD_END", value="transformer_engine.Linear monkey-patch before from_pretrained randomizes all 48 layers (loss=15). FP8 retrofit on HF-based LoRA is dead end — stay bf16", ossified_at="2026-04-16")
@convergence(state="ossified", id="RUNPOD_H100_TRAINING_ONLY", value="H100 for training only. A100/4090=runtime/inference. No quantization (4/8-bit/GPTQ/AWQ/bnb forbidden)", ossified_at="2026-04-16")
fn train_loop(corpus: array, h: int, cfg: RunConfig, fl: RunFloats) -> int {
    let n_corpus = len(corpus)
    if n_corpus == 0 {
        println("[train_loop] EMPTY corpus — abort")
        return 1
    }

    let n_adapters = N_LORA_TARGETS * QWEN14B_N_LAYER
    let scale = lora_scale(cfg.lora_alpha, cfg.lora_r)
    println("[train_loop] n_adapters=" + str(n_adapters) + " (4 targets × 48 layers)")
    println("[train_loop] LoRA scale α/r = " + str(cfg.lora_alpha) + "/" + str(cfg.lora_r) + " = " + str(scale))

    // Initialize A, B and AdamW state. Storage: float64 in hexa,
    // would be cast to float32 at the FFI boundary in Day-2.
    G_A_FLAT = init_lora_A(QWEN14B_D_MODEL, cfg.lora_r, n_adapters, 12345)
    G_B_FLAT = init_lora_B(QWEN14B_D_MODEL, cfg.lora_r, n_adapters)
    let aN = len(G_A_FLAT)
    let bN = len(G_B_FLAT)
    println("[train_loop] |A|=" + str(aN) + " |B|=" + str(bN) + " (full Qwen 14B layout)")
    println("[train_loop] WARN: float64 storage; Day-2 FFI will need fp32 cast")

    G_A_M = init_lora_B(QWEN14B_D_MODEL, cfg.lora_r, n_adapters)
    G_A_V = init_lora_B(QWEN14B_D_MODEL, cfg.lora_r, n_adapters)
    G_B_M = init_lora_B(QWEN14B_D_MODEL, cfg.lora_r, n_adapters)
    G_B_V = init_lora_B(QWEN14B_D_MODEL, cfg.lora_r, n_adapters)

    // Dry-run gate — exit cleanly before any real GPU/FFI traffic.
    if cfg.dry_run > 0 {
        println("[train_loop] DRY-RUN mode: skipping training loop, exit after init")
        return 0
    }

    G_BEST_LOSS = 1000000.0
    G_PATIENCE_LEFT = cfg.patience
    G_BREAKTHROUGH_STEP = 0
    G_LAST_LOSS = 0.0

    // Stub vocab for the non-FFI forward — keeps gradient signal flowing.
    let stub_vocab = 16

    let mut step = 1
    let mut sample_idx = 0
    while step <= cfg.steps {
        // 1. Build a batch from corpus (round-robin index)
        let mut batch_ids = []
        let mut batch_targets = []
        let mut bi = 0
        while bi < cfg.batch {
            let row = corpus[sample_idx % n_corpus]
            let ids = text_to_ids_stub(row, cfg.seq, stub_vocab)
            // Targets = ids shifted by 1 (next-token prediction)
            let il = len(ids)
            let mut ti = 0
            while ti < il {
                batch_ids = batch_ids.push(ids[ti])
                let tgt = if ti + 1 < il { ids[ti + 1] } else { 0 }
                batch_targets = batch_targets.push(tgt)
                ti = ti + 1
            }
            sample_idx = sample_idx + 1
            bi = bi + 1
        }

        // 2-3. Forward with LoRA
        let logits = forward_qwen14b_with_lora(h, batch_ids, G_A_FLAT, G_B_FLAT, cfg, scale)
        if len(logits) == 0 {
            println("[train_loop] step=" + str(step) + " forward returned empty — FFI BLOCKED")
            return 2
        }

        // 4. Loss + dlogits
        let packed = softmax_ce_grad(logits, batch_targets, stub_vocab)
        let avg_loss = packed[0]
        let mut dlogits = []
        let pN = len(packed)
        let mut pi = 1
        while pi < pN {
            dlogits = dlogits.push(packed[pi])
            pi = pi + 1
        }

        // 5. Backward (LoRA only)
        let grads = backward_lora_only(h, dlogits, G_A_FLAT, G_B_FLAT, cfg)
        let grad_A = grads[0]
        let grad_B = grads[1]

        // 6. AdamW step on A, B
        let cur_lr = warmup_lr(fl.lr, step, cfg.warmup)
        let updA = adamw_step(G_A_FLAT, grad_A, G_A_M, G_A_V, cur_lr, fl.beta1, step)
        G_A_FLAT = updA[0]
        G_A_M    = updA[1]
        G_A_V    = updA[2]
        let updB = adamw_step(G_B_FLAT, grad_B, G_B_M, G_B_V, cur_lr, fl.beta1, step)
        G_B_FLAT = updB[0]
        G_B_M    = updB[1]
        G_B_V    = updB[2]

        G_LAST_LOSS = avg_loss

        // 7. Log every 10 steps
        if step == 1 || step % 10 == 0 {
            println("[train_loop] step=" + str(step) + "/" + str(cfg.steps) +
                    " loss=" + str(avg_loss) +
                    " lr=" + str(cur_lr) +
                    " best=" + str(G_BEST_LOSS) +
                    " patience=" + str(G_PATIENCE_LEFT))
        }

        // 8. Save every save_every (intermediate) and on patience-exhaust
        if step % cfg.save_every == 0 {
            let ckpt_path = cfg.out + "/step_" + str(step)
            save_lora(G_A_FLAT, G_B_FLAT, ckpt_path, cfg)
        }

        // 9. Early-stop check at eval_every
        if step % cfg.eval_every == 0 {
            if avg_loss < G_BEST_LOSS {
                G_BEST_LOSS = avg_loss
                G_PATIENCE_LEFT = cfg.patience
                println("[train_loop] new best loss " + str(avg_loss) + " at step " + str(step))
            } else {
                G_PATIENCE_LEFT = G_PATIENCE_LEFT - 1
                println("[train_loop] no improvement at step " + str(step) + ", patience=" + str(G_PATIENCE_LEFT))
                if G_PATIENCE_LEFT <= 0 {
                    println("[train_loop] PATIENCE EXHAUSTED — early stop at step " + str(step))
                    step = cfg.steps + 1   // break
                }
            }
        }

        // ABORT criteria from alm_r11_plan.json:
        //   - loss > 6.0 at step 200 → abort (lr too high)
        //   - loss > 5.0 at step 100 → warn but continue
        if step == 100 && avg_loss > 5.0 {
            println("[train_loop] WARN: step 100 loss " + str(avg_loss) + " > 5.0 — lr may be too high")
        }
        if step == 200 && avg_loss > 6.0 {
            println("[train_loop] ABORT: step 200 loss " + str(avg_loss) + " > 6.0 — divergence detected")
            return 3
        }

        step = step + 1
    }

    println("[train_loop] complete. final_loss=" + str(G_LAST_LOSS) + " best_loss=" + str(G_BEST_LOSS))
    return 0
}

// ─── 8. save_lora(A, B, path) — adapter_model + adapter_config ─────
//
// PEFT-compatible layout:
//   {path}/adapter_config.json          (LoRA config — peft loads this)
//   {path}/adapter_model.hexackpt       (HEXACKPT-v1 — readable by eval_alm.hexa)
//
// safetensors is the peft default but requires a dedicated writer.
// HEXACKPT-v1 is a self-describing flat-text format already used by
// the PoC predecessor and serving/eval_alm.hexa loader.

fn write_tensor_block(s_in: string, name: string, rows: int, cols: int, data: array) -> string {
    let mut s = s_in + name + " " + str(rows) + " " + str(cols) + "\n"
    let n = rows * cols
    let mut i = 0
    while i < n {
        if i > 0 { s = s + " " }
        s = s + str(data[i])
        i = i + 1
    }
    s = s + "\n"
    return s
}

@convergence(state="ossified", id="RUNPOD_CKPT_CORRUPTION_ZERO_BYTE", value="Killed during torch.save → 0-byte .pt. Safe pattern: write .tmp then os.replace (atomic rename)", ossified_at="2026-04-16")
fn save_lora(A_flat: array, B_flat: array, out_dir: string, cfg: RunConfig) -> int {
    // adapter_config.json (peft-compatible — minimum fields needed for
    // hxqwen14b Day-2 LoRA loader and external peft inspection).
    let cfg_json = "{\n" +
        "  \"base_model_name_or_path\": \"" + cfg.base + "\",\n" +
        "  \"peft_type\": \"LORA\",\n" +
        "  \"task_type\": \"CAUSAL_LM\",\n" +
        "  \"r\": " + str(cfg.lora_r) + ",\n" +
        "  \"lora_alpha\": " + str(cfg.lora_alpha) + ",\n" +
        "  \"lora_dropout\": 0.0,\n" +
        "  \"bias\": \"none\",\n" +
        "  \"target_modules\": [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\"],\n" +
        "  \"_writer\": \"hexa-train_alm_lora.hexa\",\n" +
        "  \"_writer_version\": \"r11-2026-04-16\"\n" +
        "}\n"
    let cfg_path = out_dir + "/adapter_config.json"
    write_file(cfg_path, cfg_json)

    // adapter_model.hexackpt — flat HEXACKPT-v1 with all 192 (A,B) pairs
    // serialised as 384 named tensors. eval_alm.hexa reads via name lookup.
    let n_adapters = N_LORA_TARGETS * QWEN14B_N_LAYER
    let r = cfg.lora_r
    let d = QWEN14B_D_MODEL
    let mut s = "HEXACKPT-v1\n"
    s = s + "# meta n_adapters=" + str(n_adapters) + " d=" + str(d) + " r=" + str(r) + "\n"
    s = s + "# meta lora_alpha=" + str(cfg.lora_alpha) + "\n"
    s = s + "# meta base=" + cfg.base + "\n"

    // Slice and emit each adapter block. A: r×d, B: d×r.
    let A_block = r * d
    let B_block = d * r
    let mut idx = 0
    while idx < n_adapters {
        let layer = idx / N_LORA_TARGETS
        let tgt = idx % N_LORA_TARGETS
        let tgt_name = if tgt == TGT_Q { "q_proj" }
                       else if tgt == TGT_K { "k_proj" }
                       else if tgt == TGT_V { "v_proj" }
                       else                 { "o_proj" }
        let key_prefix = "model.layers." + str(layer) + ".self_attn." + tgt_name

        // Slice A_flat[idx*A_block : (idx+1)*A_block]
        let mut a_slice = []
        let mut k = 0
        while k < A_block {
            a_slice = a_slice.push(A_flat[idx * A_block + k])
            k = k + 1
        }
        s = write_tensor_block(s, key_prefix + ".lora_A.weight", r, d, a_slice)

        // Slice B_flat[idx*B_block : (idx+1)*B_block]
        let mut b_slice = []
        k = 0
        while k < B_block {
            b_slice = b_slice.push(B_flat[idx * B_block + k])
            k = k + 1
        }
        s = write_tensor_block(s, key_prefix + ".lora_B.weight", d, r, b_slice)

        idx = idx + 1
    }
    s = s + "__MANIFEST__ " + str(n_adapters * 2) + " 1\n"

    let ckpt_path = out_dir + "/adapter_model.hexackpt"
    write_file(ckpt_path, s)
    println("[save_lora] wrote " + str(len(s)) + " bytes → " + ckpt_path)
    println("[save_lora] config → " + cfg_path)
    return 0
}

// ─── 9. main() — single entry point (silent-exit defense) ──────────
//
// Per feedback_hexa_silent_exit_5_imports.md: this file has NO `use`
// statements and its main() body is intentionally non-trivial so that
// the codegen produces a real C body. Verify after build with:
//   awk '/^int main/,/^}/' build/artifacts/train_alm_lora.c

fn main() {
    println("════════════════════════════════════════════════════════")
    println("  ALM 14B r11 — hexa-native LoRA trainer")
    println("  spec : training/deploy/alm_r11_plan.json")
    println("  base : Qwen2.5-14B (n_layer=48, d_model=5120)")
    println("════════════════════════════════════════════════════════")

    // Parse CLI (args() returns [binary, binary, arg1, arg2, ...] — see
    // hexa_set_args in self/runtime.c — so skip first 2 elements).
    let argv_full = args()
    let n_argv = len(argv_full)
    let mut argv = []
    let mut i = 2
    while i < n_argv {
        argv = argv.push(argv_full[i])
        i = i + 1
    }

    let cfg0 = default_config()
    let fl0  = default_floats()
    let parsed = parse_cli(argv, cfg0, fl0)
    let cfg: RunConfig = parsed[0]
    let fl: RunFloats  = parsed[1]

    println("[main] config:")
    println("[main]   base       = " + cfg.base)
    println("[main]   corpus     = " + cfg.corpus)
    println("[main]   out        = " + cfg.out)
    println("[main]   steps      = " + str(cfg.steps))
    println("[main]   warmup     = " + str(cfg.warmup))
    println("[main]   lora_r     = " + str(cfg.lora_r))
    println("[main]   lora_alpha = " + str(cfg.lora_alpha))
    println("[main]   batch      = " + str(cfg.batch))
    println("[main]   seq        = " + str(cfg.seq))
    println("[main]   save_every = " + str(cfg.save_every))
    println("[main]   eval_every = " + str(cfg.eval_every))
    println("[main]   patience   = " + str(cfg.patience))
    println("[main]   lr         = " + str(fl.lr))
    println("[main]   beta1      = " + str(fl.beta1))
    println("[main]   dry_run    = " + str(cfg.dry_run))

    // Probe FFI version (works on Mac stub too — returns 1).
    let abi = hxqwen14b_version()
    println("[main] hxqwen14b ABI version = " + str(abi))
    if abi <= 0 {
        println("[main] ERROR: hxqwen14b lib not loadable (libhxqwen14b.{so,dylib} missing)")
        println("[main]        set DYLD_LIBRARY_PATH (Mac) or LD_LIBRARY_PATH (Linux)")
        return
    }

    // Try to load base. On Mac dry-run / missing weights, returns -1
    // and we report cleanly. The trainer itself runs in stub mode.
    // (`handle` is a reserved keyword in hexa parser — use `h_base`.)
    let mut h_base = -1
    if cfg.dry_run == 0 {
        // cstring builtin marshals string → int64 address for FFI
        let cpath = cstring(cfg.base)
        h_base = hxqwen14b_load(cpath)
        if h_base <= 0 {
            println("[main] WARN: hxqwen14b_load failed (rc=" + str(h_base) + ")")
            println("[main]       proceeding in stub mode — useful for non-GPU CI smoke")
            h_base = 1   // pretend-handle so train_loop continues with stub forward
        } else {
            println("[main] base loaded at h_base=" + str(h_base))
        }
    } else {
        h_base = 1
    }

    // Load corpus.
    let corpus = load_corpus(cfg.corpus)
    if len(corpus) == 0 && cfg.dry_run == 0 {
        println("[main] FATAL: empty corpus, aborting (use --dry-run to test trainer wiring)")
        if h_base > 1 { hxqwen14b_free(h_base) }
        return
    }
    if len(corpus) == 0 {
        // dry-run with no corpus → synthesise tiny fake corpus
        println("[main] dry-run: synthesising 4 fake corpus samples")
        let mut fake = []
        fake = fake.push("이것은 첫 번째 한국어 샘플 텍스트입니다. 평가용으로 사용됩니다.")
        fake = fake.push("두 번째 샘플은 면접 시뮬레이션 태스크의 일부분입니다. 답변 모범 예시.")
        fake = fake.push("세 번째 샘플 텍스트로 의식 엔진의 자연어 처리를 테스트합니다.")
        fake = fake.push("네 번째 샘플은 토큰 시퀀스 길이 다양성을 검증하기 위한 충분히 긴 텍스트입니다 모델은 이것을 학습합니다.")
        let rc = train_loop(fake, h_base, cfg, fl)
        println("[main] dry-run train_loop rc=" + str(rc))
        if h_base > 1 { hxqwen14b_free(h_base) }
        return
    }

    // Run the loop.
    let rc = train_loop(corpus, h_base, cfg, fl)
    println("[main] train_loop rc=" + str(rc))

    // Final save.
    if rc == 0 {
        let final_dir = cfg.out + "/final"
        save_lora(G_A_FLAT, G_B_FLAT, final_dir, cfg)
        println("[main] final ckpt → " + final_dir)
    }

    // Release base handle (idempotent, safe even if never really loaded).
    if h_base > 1 {
        hxqwen14b_free(h_base)
    }

    println("════════════════════════════════════════════════════════")
    println("  ALM 14B r11 — done. final_loss=" + str(G_LAST_LOSS) + " best=" + str(G_BEST_LOSS))
    println("════════════════════════════════════════════════════════")
}

// Note: hexa codegen auto-invokes `fn main()` when present — no explicit
// script-level `main()` call needed (would double-invoke; verified empirically
// 2026-04-16). Build artifact emits `u_main();` from inside int main(...).
