// On-device fused AdamW. Walks all 384 LoRA buffers (192 adapters × A,B)
// internally — single host call applies the full optimizer step.
@link("hxqwen14b")
extern fn hxqwen14b_v565_lora_adamw_step(
    lora_ptrs_p: int, grad_ptrs_p: int, m_ptrs_p: int, v_ptrs_p: int,
    r: int, step: int,
    lr: float, beta1: float, beta2: float, eps: float, wd: float) -> int

// v5.6.6 — global L2 grad-norm clip across all 384 LoRA grad buffers.
//   Computes ||g||_2, then if > max_norm scales every grad in-place by
//   max_norm / ||g||_2. Returns measured pre-clip norm via out_norm_p
//   (host fp64 ptr), 1/0 clipped flag via out_clipped_p (host int64 ptr).
//   r12 NaN root-cause fix (2026-04-20): without grad-clip, M=512 real
//   corpus blows to NaN by step 10. With max_norm=1.0 default, training
//   stays bounded.
@link("hxqwen14b")
extern fn hxqwen14b_v566_lora_grad_clip(
    grad_ptrs_p: int, r: int,
    max_norm: float,
    out_norm_p: int, out_clipped_p: int) -> int

// v5.6.6 ABI version probe — used by trainer to verify grad-clip surface
// is live before launch (≥ 566 means clip is wired).
@link("hxqwen14b")
extern fn hxqwen14b_version_v566() -> int

