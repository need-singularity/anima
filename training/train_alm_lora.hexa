// ─── Run config (CLI-overridable) ──────────────────────────────────

struct RunConfig {
    base: string,
    corpus: string,
    out: string,
    steps: int,
    warmup: int,
    lora_r: int,
    lora_alpha: int,
    batch: int,
    seq: int,
    save_every: int,
    eval_every: int,
    patience: int,
    dry_run: int,
    // FSDP / data-parallel knobs. world_size>1 triggers hxnccl AllReduce
    // on grads + rank-0-only ckpt writes. r11 keeps default 1; r12 sets 2.
    world_size: int,
    rank: int
}

// NB: only 1 float field (lr) — use a separate slot to avoid the
// ≥3 float struct-return corruption bug (feedback_hexa_struct_return_bug.md).
struct RunFloats {
    lr: float,
    beta1: float
}

fn default_config() -> RunConfig {
    return RunConfig {
        base: "/runpod/ckpt_r9",
        corpus: "/workspace/corpus_r11.jsonl",
        out: "/workspace/ckpt_r11",
        steps: 500,
        warmup: 50,
        lora_r: 8,
        lora_alpha: 16,
        batch: 4,
        seq: 1024,
        save_every: 100,
        eval_every: 100,
        patience: 5,
        dry_run: 0,
        world_size: 1,
        rank: 0
    }
}

fn default_floats() -> RunFloats {
    return RunFloats { lr: 0.0000005, beta1: 0.9 }
}

// AdamW non-tunable hyperparameters (return as 2-float struct max)
comptime const ADAMW_BETA2   = 0.999
comptime const ADAMW_EPS     = 0.00000001
comptime const ADAMW_WD      = 0.0           // LoRA: no weight decay (B init=0)

// ─── CLI parsing — pull from `args()` builtin (single pass, robust) ─

fn parse_int_arg(s: string, default_val: int) -> int {
    // hexa builtin to_int returns 0 on failure — guard with explicit
    // empty check.
    if len(s) == 0 { return default_val }
    return to_int(s)
}

fn parse_float_arg(s: string, default_val: float) -> float {
    if len(s) == 0 { return default_val }
    return to_float(s)
}

// ─── Raw int32 host buffer for FFI ─────────────────────────────────
//
// hxqwen14b_train_step_v54 expects a host pointer to an int32 array of
// token ids. This helper packs a hexa array of ints into a freshly
// alloc_raw'd buffer (caller must free_raw after the call).
//
// Returns: int — host buffer pointer (alloc_raw handle).

fn float_array_to_int32_buf(ids: array) -> int {
    let n = len(ids)
    if n <= 0 { return 0 }
    let buf = alloc_raw(n * 4)
    let mut i = 0
    while i < n {
        write_i32(buf, i * 4, ids[i])
        i = i + 1
    }
    return buf
}

// ─── String byte access helper (stage0 quirk shim) ─────────────────
//
// Per training/corpus_filter.hexa: stage0's char_code(s, i) ignores i
// (always returns byte 0). Workaround: substring(i, i+1) then char_code
// on the 1-char string. See feedback_hexa_string_api.md.

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

// ─── String slice via method-call (uniform calling style) ──────────

fn substring(s: string, start: int, end: int) -> string {
    return s.substring(start, end)
}

fn index_of(hay: string, needle: string) -> int {
    return hay.index_of(needle)
}

fn string_split(s: string, delim: string) -> array {
    return s.split(delim)
}

fn parse_cli(argv: array, cfg_in: RunConfig, fl_in: RunFloats) -> array {
    let mut cfg = cfg_in
    let mut fl  = fl_in
    let n = len(argv)
    let mut i = 0
    while i < n {
        let k = argv[i]
        // boolean flag (no value)
        if k == "--dry-run" {
            cfg = RunConfig {
                base: cfg.base, corpus: cfg.corpus, out: cfg.out,
                steps: cfg.steps, warmup: cfg.warmup,
                lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha,
                batch: cfg.batch, seq: cfg.seq,
                save_every: cfg.save_every, eval_every: cfg.eval_every,
                patience: cfg.patience, dry_run: 1,
                world_size: cfg.world_size, rank: cfg.rank
            }
            i = i + 1
        } else {
            // value-taking flags — need next token
            if i + 1 >= n {
                println("[train_alm_lora] WARN: flag " + k + " expects a value, ignoring")
                i = i + 1
            } else {
                let v = argv[i + 1]
                if k == "--base"        { cfg = RunConfig { base: v, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--corpus" { cfg = RunConfig { base: cfg.base, corpus: v, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--out"    { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: v, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--steps"  { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: parse_int_arg(v, cfg.steps), warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--warmup" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: parse_int_arg(v, cfg.warmup), lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--lora_r"     { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: parse_int_arg(v, cfg.lora_r), lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--lora_alpha" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: parse_int_arg(v, cfg.lora_alpha), batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--batch"  { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: parse_int_arg(v, cfg.batch), seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--seq"    { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: parse_int_arg(v, cfg.seq), save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--save_every" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: parse_int_arg(v, cfg.save_every), eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--eval_every" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: parse_int_arg(v, cfg.eval_every), patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--patience"   { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: parse_int_arg(v, cfg.patience), dry_run: cfg.dry_run, world_size: cfg.world_size, rank: cfg.rank } }
                else if k == "--lr"     { fl  = RunFloats  { lr: parse_float_arg(v, fl.lr), beta1: fl.beta1 } }
                else if k == "--world_size" { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: parse_int_arg(v, cfg.world_size), rank: cfg.rank } }
                else if k == "--rank"       { cfg = RunConfig { base: cfg.base, corpus: cfg.corpus, out: cfg.out, steps: cfg.steps, warmup: cfg.warmup, lora_r: cfg.lora_r, lora_alpha: cfg.lora_alpha, batch: cfg.batch, seq: cfg.seq, save_every: cfg.save_every, eval_every: cfg.eval_every, patience: cfg.patience, dry_run: cfg.dry_run, world_size: cfg.world_size, rank: parse_int_arg(v, cfg.rank) } }
                else { println("[train_alm_lora] WARN: unknown flag " + k + " (ignored)") }
                i = i + 2
            }
        }
    }
    return [cfg, fl]
}

// ─── 1. load_corpus(path) — read JSONL or txt ──────────────────────
//
// Returns an array of byte-strings, one per sample. JSONL: each line is
// `{"text": "..."}` — we extract the text field by simple ASCII byte
// scan (avoids the byte-vs-char quirk on multibyte Korean content per
// feedback_hexa_string_api.md). Plain .txt: one sample per line.
//
// Filtering matches alm_r11_plan.json corpus_design.preprocessing:
//   - length filter 50..2000 chars
//   - simple dedup via FNV-1a hash bucket (cheap, O(N))

fn fnv1a64_str(s: string) -> int {
    // 64-bit FNV-1a basis 0xcbf29ce484222325 doesn't fit signed int64,
    // so we use the truncated 63-bit basis 0x4bf29ce484222325. Hash
    // distribution is unchanged for dedup purposes (probabilistic).
    let n = len(s)
    let mut h = 5472965275842495269
    let mut i = 0
    while i < n {
        let c = byte_at(s, i)
        h = h ^ c
        h = h * 1099511628211
        i = i + 1
    }
    return h
}

// Strip the JSON {"text": "..."} wrapping if present. Pure ASCII scan
// over the field name only — content is left as raw bytes.
fn extract_text_field(line: string) -> string {
    let n = len(line)
    if n < 12 { return line }
    // Detect {"text": prefix
    let b0 = byte_at(line, 0)
    if b0 != 123 { return line }   // 123 = '{'
    // Look for "text" key
    let key_idx = index_of(line, "\"text\"")
    if key_idx < 0 { return line }
    // Find the next " after the colon
    let mut p = key_idx + 6
    while p < n && byte_at(line, p) != 58 { p = p + 1 }   // ':' = 58
    if p >= n { return line }
    p = p + 1
    while p < n && byte_at(line, p) != 34 { p = p + 1 }   // '"' = 34
    if p >= n { return line }
    let start = p + 1
    // Find closing " (no escape support — corpus must pre-escape if needed)
    let mut q = start
    while q < n && byte_at(line, q) != 34 { q = q + 1 }
    if q <= start { return "" }
    return substring(line, start, q)
}

fn load_corpus(path: string) -> array {
    let raw = read_file(path)
    if len(raw) == 0 {
        println("[load_corpus] EMPTY or missing: " + path)
        return []
    }
    let lines = string_split(raw, "\n")
    let n = len(lines)
    let mut out = []
    let mut seen = []      // dedup hash list (small — ok linear scan)
    let mut i = 0
    let mut dropped_short = 0
    let mut dropped_long  = 0
    let mut dropped_dup   = 0
    while i < n {
        let line = lines[i]
        let txt = extract_text_field(line)
        let m = len(txt)
        if m < 50 {
            dropped_short = dropped_short + 1
        } else {
            if m > 2000 {
                dropped_long = dropped_long + 1
            } else {
                let h = fnv1a64_str(txt)
                let mut dup = false
                let mut j = 0
                let sn = len(seen)
                while j < sn {
                    if seen[j] == h { dup = true; j = sn }
                    j = j + 1
                }
                if dup {
                    dropped_dup = dropped_dup + 1
                } else {
                    seen = seen.push(h)
                    out = out.push(txt)
                }
            }
        }
        i = i + 1
    }
    println("[load_corpus] " + path)
    println("[load_corpus]   loaded=" + str(len(out)) + " of " + str(n) + " lines")
    println("[load_corpus]   dropped: short=" + str(dropped_short) + " long=" + str(dropped_long) + " dup=" + str(dropped_dup))
    return out
}

// ─── 2. init_lora_adapters(d, r, alpha) ────────────────────────────
//
// Per the LoRA paper: A ~ N(0, σ²), B = 0. This guarantees ΔW=0 at
// step 0 so the base model output is preserved. Returns flat parallel
// arrays sized for ALL 192 adapters (4 targets × 48 layers) so we can
// hold them in module-level let-mut bindings without struct-of-array
// aliasing risks (feedback_hexa_struct_list_alias.md).
//
// Layout: A_flat is concatenation of 192 [r×d] blocks (each 8·5120 = 40960
// floats); index of layer L target T = (L * 4 + T) * (r * d).
//
// Float64 storage to match hxblas single-precision contracts later
// (the FFI expects float32 — emit a TODO when crossing the wire).

fn xavier_seed(seed: int) -> int {
    // Lehmer LCG — deterministic per-element seed walker
    return (seed * 1103515245 + 12345) & 2147483647
}

fn init_lora_A(d: int, r: int, n_adapters: int, base_seed: int) -> array {
    let total = n_adapters * r * d
    let mut out = []
    let scale = 0.02              // standard LoRA init scale
    let mut s = base_seed
    let mut i = 0
    while i < total {
        s = xavier_seed(s)
        // Map to [-1, 1) then scale; cheap pseudo-normal.
        let u = to_float(s % 1000000) / 1000000.0
        let v = (u * 2.0 - 1.0) * scale
        out = out.push(v)
        i = i + 1
    }
    return out
}

fn init_lora_B(d: int, r: int, n_adapters: int) -> array {
    let total = n_adapters * d * r
    let mut out = []
    let mut i = 0
    while i < total {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn lora_scale(alpha: int, r: int) -> float {
    return to_float(alpha) / to_float(r)
}

// ─── 3. apply_lora(W, A, B, x, scale) ──────────────────────────────
//
// y = W·x + scale · B·(A·x). Done in two mat_vecs to keep memory at
// O(r) rather than materialising ΔW = B·A as [d×d] (which would be
// 100MB per layer at d=5120 × 4 bytes).
//
// For dry-run / Mac stub we operate on tiny synthetic matrices so the
// trainer file structure verifies even without the real Qwen weights.
//
// Args:
//   W : [d×d]  base weight (caller-managed; we don't materialise)
//   A : [r×d]  LoRA down
//   B : [d×r]  LoRA up
//   x : [d]    input vector
//   scale : α/r
// Returns:
//   y : [d]    W·x + scale · B·(A·x)
//
// W is passed as an empty array sentinel when we're in stub mode (no
// real weights loaded); the function then returns scale · B·(A·x) plus
// a passthrough x (identity-ish) so the loss has gradient signal.

fn mat_vec(M: array, x: array, rows: int, cols: int) -> array {
    let mut out = []
    let mut i = 0
    while i < rows {
        let mut acc = 0.0
        let mut j = 0
        while j < cols {
            acc = acc + M[i * cols + j] * x[j]
            j = j + 1
        }
        out = out.push(acc)
        i = i + 1
    }
    return out
}

fn vec_add(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

fn vec_scale(a: array, s: float) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(a[i] * s)
        i = i + 1
    }
    return out
}

fn apply_lora(W: array, A: array, B: array, x: array, d: int, r: int, scale: float) -> array {
    // h = A · x   →  [r]
    let h = mat_vec(A, x, r, d)
    // delta = B · h  →  [d]
    let delta = mat_vec(B, h, d, r)
    let scaled = vec_scale(delta, scale)
    // base = W · x  (or x passthrough when W is the stub sentinel)
    if len(W) == 0 {
        return vec_add(x, scaled)
    }
    let base = mat_vec(W, x, d, d)
    return vec_add(base, scaled)
}

// ─── 4. forward_qwen14b_with_lora(...) ─────────────────────────────
//
// Day-2 ABI (NOT YET in hxqwen14b.c): forward pass with LoRA hooks
// applied per target projection. Until the C side gains
// hxqwen14b_forward_with_lora(args_p) -> int, we use the existing
// generate() entry to verify the FFI round-trip and report a clean
// BLOCKED_FFI status. The training math (apply_lora + adamw_step) is
// fully exercised on a stub forward so the code path is bit-validated.
//
// Returns: array [logits [B*S*V] packed; or empty on stub error]

fn forward_qwen14b_with_lora(h: int, ids: array, A_flat: array, B_flat: array,
                              cfg: RunConfig, scale: float) -> array {
    if h <= 0 {
        return []
    }
    // Day-2 hook absent → return synthetic logits over a tiny vocab so
    // the train loop has gradient signal during dry-run / Mac smoke.
    // Shape : [batch * seq * stub_vocab].
    let stub_vocab = 16
    let n_tokens = len(ids)
    let total = n_tokens * stub_vocab
    let mut out = []
    let mut i = 0
    while i < total {
        // Mix LoRA params into output so backward has a real path:
        // logit = sum(A_flat[i % len_A]) + sum(B_flat[i % len_B])
        let aL = len(A_flat)
        let bL = len(B_flat)
        let a_v = if aL > 0 { A_flat[i % aL] } else { 0.0 }
        let b_v = if bL > 0 { B_flat[i % bL] } else { 0.0 }
        out = out.push(a_v + b_v + 0.001)
        i = i + 1
    }
    return out
}

// ─── 5. backward_lora_only(...) ────────────────────────────────────
//
// Compute gradient of CE loss w.r.t. (A_flat, B_flat) ONLY (base frozen).
// Day-2 ABI requires hxqwen14b_backward_lora_only(args_p) which would
// run the cuBLAS-side cached-activation backward and write gradients
// into caller-supplied buffers.
//
// Stub path (used for dry-run): straight-through gradient surrogate —
// we compute dlogits as (softmax(logits) - one_hot(target)) and route
// uniformly back to A and B. This doesn't train Qwen but does exercise
// the optimizer + checkpoint paths end-to-end.
//
// Returns: array [grad_A_flat, grad_B_flat]

fn softmax_ce_grad(logits: array, targets: array, vocab: int) -> array {
    let n_tokens = len(targets)
    let mut grad = []
    let mut tot_loss = 0.0
    let mut i = 0
    while i < n_tokens {
        // softmax over the slice
        let mut max_l = logits[i * vocab]
        let mut k = 1
        while k < vocab {
            let v = logits[i * vocab + k]
            if v > max_l { max_l = v }
            k = k + 1
        }
        let mut Z = 0.0
        let mut probs = []
        k = 0
        while k < vocab {
            let p = exp(logits[i * vocab + k] - max_l)
            probs = probs.push(p)
            Z = Z + p
            k = k + 1
        }
        // normalise + grad + loss
        let t = targets[i]
        k = 0
        while k < vocab {
            let p_norm = probs[k] / Z
            let onehot = if k == t { 1.0 } else { 0.0 }
            grad = grad.push(p_norm - onehot)
            if k == t {
                // -log p_target
                tot_loss = tot_loss - log(p_norm + 0.0000000001)
            }
            k = k + 1
        }
        i = i + 1
    }
    let avg = tot_loss / to_float(n_tokens)
    // Pack [avg_loss as first element, then dlogits flat]. Caller splits.
    let mut packed = [avg]
    let g_n = len(grad)
    let mut j = 0
    while j < g_n {
        packed = packed.push(grad[j])
        j = j + 1
    }
    return packed
}

fn backward_lora_only(h: int, dlogits: array, A_flat: array, B_flat: array,
                      cfg: RunConfig) -> array {
    let aN = len(A_flat)
    let bN = len(B_flat)
    let dN = len(dlogits)

    // Stub gradient: distribute |dlogits| sum over A and B uniformly,
    // with sign matching the corresponding param. This makes the
    // optimizer step move params in the right direction even without
    // the real backward kernel.
    let mut sg = 0.0
    let mut i = 0
    while i < dN {
        let v = dlogits[i]
        let absv = if v < 0.0 { 0.0 - v } else { v }
        sg = sg + absv
        i = i + 1
    }
    let scale = if dN > 0 { sg / to_float(dN) } else { 0.0 }

    let mut gA = []
    i = 0
    while i < aN {
        gA = gA.push(A_flat[i] * scale * 0.001)
        i = i + 1
    }
    let mut gB = []
    i = 0
    while i < bN {
        // B starts at 0 — push small constant so it begins to move
        let push_v = if B_flat[i] == 0.0 { scale * 0.0001 } else { B_flat[i] * scale * 0.001 }
        gB = gB.push(push_v)
        i = i + 1
    }
    return [gA, gB]
}

// ─── 6. adamw_step(params, grads, m, v, lr, betas, eps) ───────────
//
// Decoupled weight-decay AdamW:
//   m_t = β1·m_{t-1} + (1-β1)·g
//   v_t = β2·v_{t-1} + (1-β2)·g²
//   m̂   = m_t / (1 - β1^t)
//   v̂   = v_t / (1 - β2^t)
//   p_t = p_{t-1} - lr · (m̂ / (√v̂ + ε) + wd · p_{t-1})
//
// Returns [new_params, new_m, new_v]. m, v are float arrays parallel
// to params (so we sidestep the struct-list aliasing bug by holding
// them as separate top-level let-mut bindings; see header).
//
// `t` is the step number (1-indexed) — caller supplies for bias correction.

fn pow_float(base: float, n: int) -> float {
    let mut r = 1.0
    let mut i = 0
    while i < n {
        r = r * base
        i = i + 1
    }
    return r
}

fn fast_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn adamw_step(params: array, grads: array, m_in: array, v_in: array,
              lr: float, beta1: float, t: int) -> array {
    let n = len(params)
    let beta2 = ADAMW_BETA2
    let eps   = ADAMW_EPS
    let wd    = ADAMW_WD
    let bc1 = 1.0 - pow_float(beta1, t)
    let bc2 = 1.0 - pow_float(beta2, t)
    let mut new_p = []
    let mut new_m = []
    let mut new_v = []
    let mut i = 0
    while i < n {
        let g = grads[i]
        let m_new = beta1 * m_in[i] + (1.0 - beta1) * g
        let v_new = beta2 * v_in[i] + (1.0 - beta2) * g * g
        let m_hat = m_new / bc1
        let v_hat = v_new / bc2
        let denom = fast_sqrt(v_hat) + eps
        let p_new = params[i] - lr * (m_hat / denom + wd * params[i])
        new_p = new_p.push(p_new)
        new_m = new_m.push(m_new)
        new_v = new_v.push(v_new)
        i = i + 1
    }
    return [new_p, new_m, new_v]
}

// ─── Sample → token-id stub (vocabulary-free fallback for dry-run) ─
//
// Real path (Phase-3): encode_real_bpe via hxtok_encode FFI. Stub path
// kept for --dry-corpus / smoke modes that don't load tokenizer.json.

fn text_to_ids_stub(text: string, max_len: int, stub_vocab: int) -> array {
    let n = len(text)
    let cap = if n < max_len { n } else { max_len }
    let mut ids = []
    let mut i = 0
    while i < cap {
        let b = byte_at(text, i)
        ids = ids.push(b % stub_vocab)
        i = i + 1
    }
    return ids
}

// ─── hxtok FFI (Phase-3 — real Qwen2.5 BPE) ───────────────────────
//
// hxtok.c lives in hexa-lang/self/native/. Provides Qwen2.5 BPE vocab
// (152064) + merges (~151K) via C-side hashmap for interpreter-proof
// performance. Declared locally (not via `use tokenizer_qwen`) to avoid
// the feedback_hexa_silent_exit_5_imports multi-import fragility.
// Smoke validated Mac+pod: encode('hello world')=[14990,1879],
// encode('안녕')=[126246,144370].

@link("hxtok")
extern fn hxtok_load(path: string, expected_vocab_size: int) -> int
@link("hxtok")
extern fn hxtok_free(h: int) -> int
@link("hxtok")
extern fn hxtok_encode(h: int, text: string, text_len: int,
                       out_ids_p: int, max_out: int) -> int
@link("hxtok")
extern fn hxtok_vocab_size(h: int) -> int

// Global tokenizer handle populated by main() via hxtok_load; 0 = not
// loaded (train loop falls back to text_to_ids_stub for dev smoke).
let mut G_TOK_H = 0

// Real BPE encoder — truncates/pads to seq_len.
fn encode_real_bpe(text: string, seq_len: int) -> array {
    if G_TOK_H == 0 { return [] }
    let text_len = len(text)
    // Allocate with headroom (BPE may expand beyond raw byte count for
    // rare scripts). Floor at 32 bytes so empty lines still alloc.
    let cap_guess = text_len + 8
    let cap = if cap_guess < 32 { 32 } else { cap_guess }
    let out_p = alloc_raw(cap * 8)
    let n = hxtok_encode(G_TOK_H, text, text_len, out_p, cap)
    let effective = if n < cap { n } else { cap }
    let limit = if effective < seq_len { effective } else { seq_len }
    let mut ids = []
    let mut i = 0
    while i < limit {
        ids = ids.push(deref(out_p + i * 8))
        i = i + 1
    }
    free_raw(out_p)
    return ids
}

// text_to_ids — unified entry. Uses real BPE if tokenizer loaded, else
// stub fallback (signal-only hash for dry runs).
fn text_to_ids(text: string, max_len: int, stub_vocab: int) -> array {
    if G_TOK_H != 0 {
        return encode_real_bpe(text, max_len)
    }
    return text_to_ids_stub(text, max_len, stub_vocab)
}

// ─── 7. train_loop(...) ────────────────────────────────────────────
//
// Single-process, single-batch loop. Per step:
//   1. sample a batch of `cfg.batch` corpus rows
//   2. tokenize → ids   (stub or FFI)
//   3. forward_qwen14b_with_lora → logits
//   4. softmax_ce_grad → loss + dlogits
//   5. backward_lora_only → (grad_A, grad_B)
//   6. adamw_step on A and B independently
//   7. log every 10 steps
//   8. save every cfg.save_every
//   9. early-stop on patience exhaust against best loss
//
// Note: list pass-by-value (feedback_hexa_lists_pbv.md) — we
// re-bind A_flat/B_flat/m_*/v_* at module scope after each step.

// 2026-04-20 Phase-5 wiring: LoRA state lives on-device. int64 pointer-table
// host buffers hold 384 × int64 device pointers (one per A/B buffer of each
// adapter), allocated at train_loop entry and freed at exit. PCIe copies:
//   (a) init  : Kaiming A + zero B (handled by C-side alloc_lora_buffers_v56)
//   (b) memset: zero m, v moments after first alloc (per v565 smoke #3)
//   (c) save_lora: d2h copy of all 384 buffers per ckpt
// On-device state (int = host buffer pointer holding int64* table)
let mut G_LORA_PTRS_P  = 0
let mut G_GRAD_PTRS_P  = 0
let mut G_M_PTRS_P     = 0
let mut G_V_PTRS_P     = 0
let mut G_CACHE_PTRS_P = 0
let mut G_IDS_DEV      = 0
let mut G_TGT_DEV      = 0
let mut G_LOGITS_DEV   = 0
let mut G_IDS_HOST     = 0
let mut G_TGT_HOST     = 0
let mut G_DEV_M        = 0   // active M tokens for which dev buffers were sized
let mut G_BEST_LOSS = 1000000.0
let mut G_PATIENCE_LEFT = 0
let mut G_BREAKTHROUGH_STEP = 0
let mut G_LAST_LOSS = 0.0
// FSDP handle — non-zero means hxnccl_init succeeded and hxnccl_free must
// run at main() exit. 0 = single-GPU path (no wire overhead).
let mut G_NCCL_H = 0

// LoRA adapter shape lookup matching C-side hxqwen14b.c v56_proj_n_out
// / v56_proj_k_in helpers. Adapter index → (n_out, k_in) for the
// projection. T = adapter % 4: 0=q (n_out=dq=5120), 1=k (dkv=1024),
// 2=v (dkv=1024), 3=o (n_out=d=5120; k_in=dq=5120).
fn lora_adapter_n_out(adapter: int) -> int {
    let t = adapter % N_LORA_TARGETS
    if t == TGT_Q { return 5120 }      // dq = 40 * 128
    if t == TGT_K { return 1024 }      // dkv = 8 * 128
    if t == TGT_V { return 1024 }
    return 5120                          // o_proj output = d_model
}

fn lora_adapter_k_in(adapter: int) -> int {
    let t = adapter % N_LORA_TARGETS
    if t == TGT_O { return 5120 }      // o_proj input = dq
    return 5120                          // q/k/v input = d_model
}

// Buffer byte size for either the A side (idx_in_pair=0; r×k_in floats)
// or the B side (idx_in_pair=1; n_out×r floats) of an adapter.
fn lora_buf_floats(adapter: int, is_A: int, r: int) -> int {
    if is_A == 1 {
        return r * lora_adapter_k_in(adapter)
    }
    return lora_adapter_n_out(adapter) * r
}

// Allocate a host buffer holding `n` int64 entries (8 bytes each), all
// zero-initialised by alloc_raw. Returns the int address.
fn alloc_int64_table(n: int) -> int {
    let buf = alloc_raw(n * 8)
    let mut i = 0
    while i < n {
        write_i64(buf, i * 8, 0)
        i = i + 1
    }
    return buf
}

// Read int64 from a host pointer table at slot index `idx`. Wraps the
// hexa builtin ptr_read (returns int64 from absolute byte offset).
fn deref_i64_at(ptrs_p: int, idx: int) -> int {
    return ptr_read(ptrs_p, idx * 8)
}

// Walk the 384-entry pointer table held at host buffer `ptrs_p` and
// memset(0) every device buffer. Used after _v56_alloc_grad_buffers
// to zero AdamW moments (the alloc helper Kaiming-inits A buffers
// because it shares code with alloc_lora_buffers_v56; for moments
// we need zeros — see v565 smoke test 3 bugfix).
fn zero_lora_state(ptrs_p: int, r: int) -> int {
    let mut idx = 0
    while idx < 384 {
        let dev = deref_i64_at(ptrs_p, idx)
        if dev != 0 {
            let adapter = idx / 2
            let is_A = if (idx % 2) == 0 { 1 } else { 0 }
            let bytes = lora_buf_floats(adapter, is_A, r) * 4
            let _ = hxqwen14b_cu_launch_memset_zero(dev, bytes)
        }
        idx = idx + 1
    }
    return 0
}

// Linear lr warmup. r12 NaN root-cause fix (2026-04-20): even with
// grad-clip, jumping straight to full lr at step 1 risks blowup; warmup
// gives Adam moment buffers time to populate non-zero v before the full
// step lands. Caller may pass any warmup>=0; warmup<25 is silently
// floored to 25 to enforce the empirically safe minimum on r12.
fn warmup_lr(base_lr: float, step: int, warmup: int) -> float {
    let mut wm = warmup
    if wm <= 0 { return base_lr }
    if wm < 25 { wm = 25 }                     // r12 safety floor
    if step >= wm { return base_lr }
    return base_lr * (to_float(step) / to_float(wm))
}

@convergence(state="ossified", id="RUNPOD_FP8_MONKEY_PATCH_DEAD_END", value="transformer_engine.Linear monkey-patch before from_pretrained randomizes all 48 layers (loss=15). FP8 retrofit on HF-based LoRA is dead end — stay bf16", ossified_at="2026-04-16")
@convergence(state="ossified", id="RUNPOD_H100_TRAINING_ONLY", value="H100 for training only. A100/4090=runtime/inference. No quantization (4/8-bit/GPTQ/AWQ/bnb forbidden)", ossified_at="2026-04-16")
fn train_loop(corpus: array, h: int, cfg: RunConfig, fl: RunFloats) -> int {
    let n_corpus = len(corpus)
    if n_corpus == 0 {
        println("[train_loop] EMPTY corpus — abort")
        return 1
    }

    let n_adapters = N_LORA_TARGETS * QWEN14B_N_LAYER
    let scale = lora_scale(cfg.lora_alpha, cfg.lora_r)
    println("[train_loop] n_adapters=" + str(n_adapters) + " (4 targets × 48 layers)")
    println("[train_loop] LoRA scale α/r = " + str(cfg.lora_alpha) + "/" + str(cfg.lora_r) + " = " + str(scale))

    // 2026-04-20 Phase-5 wiring: detect v565 ABI. v565 = on-device LoRA
    // training (cache-writing fwd → backward orchestrator → fused AdamW).
    // r12 launch HARD-REQUIRES v565; refuse to train without it (would
    // burn H100 on stub forward). Dry-run still works (skips loop).
    let abi_v565 = hxqwen14b_version_v565()
    println("[train_loop] hxqwen14b v565 ABI = " + str(abi_v565) + " (565 = on-device LoRA training; <=0 = stub or missing)")
    let abi_v566 = hxqwen14b_version_v566()
    println("[train_loop] hxqwen14b v566 ABI = " + str(abi_v566) + " (566 = grad-clip + AdamW NaN-guard live; r12 NaN fix gate)")

    // Dry-run gate — exit cleanly before any real GPU/FFI traffic.
    if cfg.dry_run > 0 {
        println("[train_loop] DRY-RUN mode: skipping training loop, exit after init")
        return 0
    }

    if abi_v565 < 565 || h <= 0 {
        println("[train_loop] ERROR: v565 not live (abi=" + str(abi_v565) + ", h=" + str(h) + ") — Phase-5 wiring requires v5.6.5 libhxqwen14b.so")
        return 4
    }
    if abi_v566 < 566 {
        println("[train_loop] ERROR: v566 not live (abi=" + str(abi_v566) + ") — r12 NaN fix requires v5.6.6 libhxqwen14b.so (grad-clip + NaN-guard)")
        return 5
    }

    G_BEST_LOSS = 1000000.0
    G_PATIENCE_LEFT = cfg.patience
    G_BREAKTHROUGH_STEP = 0
    G_LAST_LOSS = 0.0

    // ── On-device LoRA state allocation (once per train_loop) ──────
    // 192 adapters × {A, B} = 384 device buffers. Pointer table is a
    // host-side int64* (alloc_raw'd) since the FFI takes int64 pointer
    // arrays by address. _alloc_lora_buffers_v56 does Kaiming(A) + zero(B).
    G_LORA_PTRS_P = alloc_int64_table(384)
    let alloc_lora_rc = hxqwen14b_alloc_lora_buffers_v56(cfg.lora_r, G_LORA_PTRS_P)
    if alloc_lora_rc != 0 {
        println("[train_loop] FATAL: alloc_lora_buffers_v56 rc=" + str(alloc_lora_rc))
        return 5
    }
    println("[train_loop] LoRA buffers allocated (384 device bufs, Kaiming A + zero B)")

    // Grad buffers (same shape as LoRA, accumulated zero per-step inside
    // backward orchestrator; alloc helper Kaiming-inits but next step's
    // bwd zeroes them via accumulate_grads=0 path).
    G_GRAD_PTRS_P = alloc_int64_table(384)
    let alloc_grad_rc = hxqwen14b_v56_alloc_grad_buffers(cfg.lora_r, G_GRAD_PTRS_P)
    if alloc_grad_rc != 0 {
        println("[train_loop] FATAL: alloc_grad_buffers rc=" + str(alloc_grad_rc))
        return 6
    }

    // AdamW moments — must be ZERO (alloc_grad_buffers shares Kaiming-init
    // code with alloc_lora_buffers; v565 smoke test 3 caught this bug.
    // memset to 0 explicitly).
    G_M_PTRS_P = alloc_int64_table(384)
    let alloc_m_rc = hxqwen14b_v56_alloc_grad_buffers(cfg.lora_r, G_M_PTRS_P)
    if alloc_m_rc != 0 {
        println("[train_loop] FATAL: alloc m moments rc=" + str(alloc_m_rc))
        return 7
    }
    let _zm = zero_lora_state(G_M_PTRS_P, cfg.lora_r)

    G_V_PTRS_P = alloc_int64_table(384)
    let alloc_v_rc = hxqwen14b_v56_alloc_grad_buffers(cfg.lora_r, G_V_PTRS_P)
    if alloc_v_rc != 0 {
        println("[train_loop] FATAL: alloc v moments rc=" + str(alloc_v_rc))
        return 8
    }
    let _zv = zero_lora_state(G_V_PTRS_P, cfg.lora_r)
    let _sync = hxqwen14b_cu_device_sync()
    println("[train_loop] AdamW moments (m, v) allocated + zeroed")

    // Activation cache (626 device buffers, ~15GB at M=1024). Sized for
    // the largest M we'll see (cfg.batch * cfg.seq).
    let M_total = cfg.batch * cfg.seq
    let cache_slots = hxqwen14b_v56_cache_total_slots()
    println("[train_loop] activation cache: " + str(cache_slots) + " slots, M=" + str(M_total))
    G_CACHE_PTRS_P = alloc_int64_table(cache_slots)
    let alloc_cache_rc = hxqwen14b_v56_alloc_activation_cache(M_total, G_CACHE_PTRS_P)
    if alloc_cache_rc != 0 {
        println("[train_loop] FATAL: alloc_activation_cache rc=" + str(alloc_cache_rc) + " (M=" + str(M_total) + ")")
        return 9
    }
    G_DEV_M = M_total

    // Persistent device-side scratch: ids buffer (M int32), targets buffer
    // ((M-1) int32), logits buffer (M × V fp32). M_total * VOCAB * 4 bytes
    // ≈ 4096 * 152064 * 4 = 2.5 GB at M=4096 (batch=4 seq=1024). Sized
    // once; reused per step.
    let ids_bytes    = M_total * 4
    let tgt_bytes    = (M_total - 1) * 4   // last-position has no next-token target
    let logits_bytes = M_total * QWEN14B_VOCAB * 4
    G_IDS_DEV    = hxqwen14b_cu_malloc_bytes(ids_bytes)
    G_TGT_DEV    = hxqwen14b_cu_malloc_bytes(tgt_bytes)
    G_LOGITS_DEV = hxqwen14b_cu_malloc_bytes(logits_bytes)
    if G_IDS_DEV == 0 || G_TGT_DEV == 0 || G_LOGITS_DEV == 0 {
        println("[train_loop] FATAL: cu_malloc_bytes failed for persistent dev buffers")
        return 10
    }
    G_IDS_HOST = alloc_raw(ids_bytes)
    G_TGT_HOST = alloc_raw(tgt_bytes)
    println("[train_loop] device persistent buffers: ids=" + str(ids_bytes / 1024) + "KB, targets=" + str(tgt_bytes / 1024) + "KB, logits=" + str(logits_bytes / 1024 / 1024) + "MB")

    // Stub vocab for hashing source text into ids until the real BPE
    // tokenizer lands (multi-day track). Using stub_vocab=152064 so the
    // ids fall within Qwen2.5-14B's vocab range (random-ish ids → forward
    // is still well-defined, base CE will be high but learning signal flows).
    let stub_vocab = QWEN14B_VOCAB

    let mut step = 1
    let mut sample_idx = 0
    while step <= cfg.steps {
        // 1. Build a batch from corpus (round-robin index, M_total tokens).
        // Pack ids into the persistent host int32 buffer in-place.
        let mut bi = 0
        let mut tok_idx = 0
        while bi < cfg.batch {
            let row = corpus[sample_idx % n_corpus]
            let ids = text_to_ids(row, cfg.seq, stub_vocab)
            let il = len(ids)
            // Pad short rows with zeros so M is exactly batch*seq.
            let mut ti = 0
            while ti < cfg.seq {
                let v = if ti < il { ids[ti] } else { 0 }
                write_i32(G_IDS_HOST, tok_idx * 4, v)
                tok_idx = tok_idx + 1
                ti = ti + 1
            }
            sample_idx = sample_idx + 1
            bi = bi + 1
        }
        // Targets = ids shifted by 1 (next-token prediction; last position
        // has no target so targets length = M_total - 1).
        let mut t_i = 0
        while t_i < M_total - 1 {
            // src ids are int32 at byte off (t_i+1)*4
            let next_id = deref_i32(G_IDS_HOST, (t_i + 1) * 4)
            write_i32(G_TGT_HOST, t_i * 4, next_id)
            t_i = t_i + 1
        }

        // 2. PCIe h2d copy of the new batch (ids + targets).
        let _h2d_ids = hxqwen14b_cu_memcpy_h2d(G_IDS_DEV, G_IDS_HOST, ids_bytes)
        let _h2d_tgt = hxqwen14b_cu_memcpy_h2d(G_TGT_DEV, G_TGT_HOST, tgt_bytes)

        // 3. Forward with cache (writes 626 activation slots).
        let fwd_rc = hxqwen14b_base_forward_v56_with_lora_cache_pos(
            h, G_IDS_DEV, M_total, G_LOGITS_DEV,
            G_LORA_PTRS_P, cfg.lora_r, scale, G_CACHE_PTRS_P)
        if fwd_rc != 0 {
            println("[train_loop] step=" + str(step) + " fwd_cache rc=" + str(fwd_rc))
            return 11
        }

        // 4. CE loss on first (M_total - 1) rows (last token has no target).
        let avg_loss = hxqwen14b_ce_loss_v54_pos(G_LOGITS_DEV, G_TGT_DEV,
                                                  M_total - 1, QWEN14B_VOCAB)

        // 5. Backward orchestrator — produces grad_A, grad_B in G_GRAD_PTRS_P.
        let bwd_rc = hxqwen14b_base_backward_v565_pos(
            h, M_total, G_LOGITS_DEV, G_TGT_DEV,
            G_CACHE_PTRS_P, G_LORA_PTRS_P, G_GRAD_PTRS_P,
            cfg.lora_r, scale)
        if bwd_rc != 0 {
            println("[train_loop] step=" + str(step) + " bwd_v565 rc=" + str(bwd_rc))
            return 12
        }

        // 5b. FSDP grad AllReduce (r12 2-GPU data-parallel). world_size==1 ⇒
        // no-op. world_size>1 not yet device-pointer-aware in hxnccl wrap;
        // r12 1-GPU smoke uses world_size=1 so this is dormant.
        if G_NCCL_H != 0 && cfg.world_size > 1 {
            // TODO: walk G_GRAD_PTRS_P 384 entries, AllReduce each device buf.
            // Today's stub call exercises the handle but is a no-op.
            let _ar = hxnccl_allreduce_bf16(G_NCCL_H, cfg.rank, 0, 0)
        }

        // 5c. v5.6.6 — Global L2 grad-norm clip across all 384 LoRA grads.
        //   r12 NaN root-cause fix (2026-04-20): without clip, M=512 real
        //   corpus explodes to NaN by step 10. max_norm=1.0 keeps direction
        //   while bounding magnitude. Out-params measure pre-clip norm and
        //   whether scale was applied for diagnostic logging.
        // alloc_raw scratch buffers for the FFI out-params (caller frees
        // at end of step; alloc_raw is zero-initialised so safe to read).
        let _gn_buf = alloc_raw(8)        // double slot
        let _cl_buf = alloc_raw(8)        // int64 slot
        let clip_rc = hxqwen14b_v566_lora_grad_clip(
            G_GRAD_PTRS_P, cfg.lora_r,
            1.0, _gn_buf, _cl_buf)
        if clip_rc != 0 {
            println("[train_loop] step=" + str(step) + " grad_clip rc=" + str(clip_rc))
            free_raw(_gn_buf)
            free_raw(_cl_buf)
            return 14
        }
        let grad_norm = ptr_read_f64(_gn_buf, 0)
        let clipped_flag = deref_i64_at(_cl_buf, 0)
        free_raw(_gn_buf)
        free_raw(_cl_buf)

        // 6. AdamW step (on-device fused; updates lora in-place; bumps m, v).
        //   Kernel has v5.6.6 NaN-guard: bad gradient elements are skipped
        //   so a single Inf cannot poison every subsequent step.
        let cur_lr = warmup_lr(fl.lr, step, cfg.warmup)
        let adamw_rc = hxqwen14b_v565_lora_adamw_step(
            G_LORA_PTRS_P, G_GRAD_PTRS_P, G_M_PTRS_P, G_V_PTRS_P,
            cfg.lora_r, step,
            cur_lr, fl.beta1, ADAMW_BETA2, ADAMW_EPS, ADAMW_WD)
        if adamw_rc != 0 {
            println("[train_loop] step=" + str(step) + " adamw rc=" + str(adamw_rc))
            return 13
        }
        let _step_sync = hxqwen14b_cu_device_sync()

        G_LAST_LOSS = avg_loss

        // 7. Log every 10 steps. v5.6.6 — also surface grad_norm and clip
        // flag so we can confirm the r12 NaN fix is engaging in production.
        if step == 1 || step % 10 == 0 {
            println("[train_loop] step=" + str(step) + "/" + str(cfg.steps) +
                    " loss=" + str(avg_loss) +
                    " lr=" + str(cur_lr) +
                    " gnorm=" + str(grad_norm) +
                    " clipped=" + str(clipped_flag) +
                    " best=" + str(G_BEST_LOSS) +
                    " patience=" + str(G_PATIENCE_LEFT))
        }

        // 8. Save every save_every (intermediate) — rank-0-only under FSDP.
        // Streams device buffers d2h via save_lora_device_state.
        if step % cfg.save_every == 0 && cfg.rank == 0 {
            let ckpt_path = cfg.out + "/step_" + str(step)
            let _save = save_lora_device_state(ckpt_path, cfg)
        }

        // 9. Early-stop check at eval_every
        if step % cfg.eval_every == 0 {
            if avg_loss < G_BEST_LOSS {
                G_BEST_LOSS = avg_loss
                G_PATIENCE_LEFT = cfg.patience
                println("[train_loop] new best loss " + str(avg_loss) + " at step " + str(step))
            } else {
                G_PATIENCE_LEFT = G_PATIENCE_LEFT - 1
                println("[train_loop] no improvement at step " + str(step) + ", patience=" + str(G_PATIENCE_LEFT))
                if G_PATIENCE_LEFT <= 0 {
                    println("[train_loop] PATIENCE EXHAUSTED — early stop at step " + str(step))
                    step = cfg.steps + 1   // break
                }
            }
        }

        // ABORT criteria from alm_r11_plan.json:
        //   - loss > 6.0 at step 200 → abort (lr too high)
        //   - loss > 5.0 at step 100 → warn but continue
        if step == 100 && avg_loss > 5.0 {
            println("[train_loop] WARN: step 100 loss " + str(avg_loss) + " > 5.0 — lr may be too high")
        }
        if step == 200 && avg_loss > 6.0 {
            println("[train_loop] ABORT: step 200 loss " + str(avg_loss) + " > 6.0 — divergence detected")
            free_train_loop_state()
            return 3
        }

        step = step + 1
    }

    // NOTE: free_train_loop_state() is NOT called here — main() runs a
    // final save_lora_device_state right after we return, which needs
    // G_LORA_PTRS_P alive for the d2h walk. main() calls free_train_loop_state
    // after the final save.
    println("[train_loop] complete. final_loss=" + str(G_LAST_LOSS) + " best_loss=" + str(G_BEST_LOSS))
    return 0
}

// ─── 8. save_lora(A, B, path) — adapter_model + adapter_config ─────
//
// PEFT-compatible layout:
//   {path}/adapter_config.json          (LoRA config — peft loads this)
//   {path}/adapter_model.hexackpt       (HEXACKPT-v1 — readable by eval_alm.hexa)
//
// safetensors is the peft default but requires a dedicated writer.
// HEXACKPT-v1 is a self-describing flat-text format already used by
// the PoC predecessor and serving/eval_alm.hexa loader.

fn write_tensor_block(s_in: string, name: string, rows: int, cols: int, data: array) -> string {
    let mut s = s_in + name + " " + str(rows) + " " + str(cols) + "\n"
    let n = rows * cols
    let mut i = 0
    while i < n {
        if i > 0 { s = s + " " }
        s = s + str(data[i])
        i = i + 1
    }
    s = s + "\n"
    return s
}

// 2026-04-20 (Blocker #1 fix): chunked-append variant of write_tensor_block.
// Streams the tensor's data line straight to disk via append_file in
// fixed-size element batches, so the in-memory string never exceeds
// CHUNK_FLOATS digits worth of accumulator (~30-50KB instead of the 47GB
// from the previous O(n²) full-tensor-in-string accumulator).
//
// HEXACKPT-v1 format requires the entire data array to live on ONE LINE
// (newlines split tensors), so we cannot insert per-row newlines. Trade
// off: one trailing "\n" per tensor + many small space-separated chunks.
//
// Used by save_lora() — the previous in-memory accumulator path was O(n²)
// in stage0 string concat and never wrote adapter_model.hexackpt to disk
// before the trainer hung.
//
// Returns: 0 on success.
comptime const HEXACKPT_CHUNK_FLOATS = 1024

// ─── HEXACKPT-v2 binary writer (2026-04-20 r12 blocker #4) ─────────
//
// Inlined port of train_clm.hexa's HEXACKPT-v2 helpers (commit fead4ea8).
// Activated when env HEXACKPT_V2=1; otherwise save_lora keeps the v1
// chunked-text path so live trainers (BG #34 CLM 1B) are not perturbed.
//
// Wire-format (v2; little-endian; matches train_clm.hexa exactly):
//   Magic (8 bytes):  'H' 'X' 'C' 'K' 'P' 'T' 0x02 0x00
//   u32 format_version = 2
//   u32 tensor_count
//   u64 step
//   u32 meta_json_len
//   [meta_json_len bytes UTF-8 JSON]
//   Per tensor:
//     u16 name_len, [name_len bytes UTF-8]
//     u8 dtype (0=fp32), u8 rank (=2)
//     rank × u32 shape, prod(shape) × 4 bytes fp32 LE
//
// Streaming chunk: 65_536 floats/chunk = 256 KB per fwrite.
// ────────────────────────────────────────────────────────────────────
let _V2_LORA_CHUNK_FLOATS = 65536

fn _v2lora_pack_le(val: int, nbytes: int) -> array {
    let mut out = []
    let mut v = val
    let mut i = 0
    while i < nbytes {
        out = out.push(v & 0xFF)
        v = v / 256
        i = i + 1
    }
    return out
}

fn _v2lora_append_bytes(path: string, bytes: array) -> bool {
    return write_bytes_append(path, bytes)
}

fn _v2lora_append_u8(path: string, v: int) -> bool {
    return _v2lora_append_bytes(path, [v & 0xFF])
}

fn _v2lora_append_u16(path: string, v: int) -> bool {
    return _v2lora_append_bytes(path, _v2lora_pack_le(v, 2))
}

fn _v2lora_append_u32(path: string, v: int) -> bool {
    return _v2lora_append_bytes(path, _v2lora_pack_le(v, 4))
}

fn _v2lora_append_u64(path: string, v: int) -> bool {
    return _v2lora_append_bytes(path, _v2lora_pack_le(v, 8))
}

fn _v2lora_append_str_bytes(path: string, s: string) -> bool {
    let n = len(s)
    let mut bytes = []
    let mut i = 0
    while i < n {
        bytes = bytes.push(byte_at(s, i))
        i = i + 1
    }
    return _v2lora_append_bytes(path, bytes)
}

// IEEE-754 fp32 bit pattern → unsigned-i64 payload (sign-bit safe).
fn _v2lora_f32_bits(f: float) -> int {
    let buf = alloc_raw(4)
    write_f32(buf, 0, f)
    let bits_signed = deref_i32(buf, 0)
    free_raw(buf)
    return bits_signed & 0xFFFFFFFF
}

// Chunked tensor data writer — single shared 4-byte scratch reused for
// every float→bits conversion. O(N) total, vs v1 chunked-TEXT O(N) but
// ~7× faster bytes (no decimal str() formatting per float).
fn _v2lora_append_floats_chunked(path: string, data: array) -> int {
    let n = len(data)
    let mut i = 0
    let mut total = 0
    let scratch = alloc_raw(4)
    while i < n {
        let mut chunk_bytes = []
        let cand = i + _V2_LORA_CHUNK_FLOATS
        let end = if cand < n { cand } else { n }
        let mut j = i
        while j < end {
            write_f32(scratch, 0, data[j])
            let bits_signed = deref_i32(scratch, 0)
            let bits = bits_signed & 0xFFFFFFFF
            chunk_bytes = chunk_bytes.push(bits & 0xFF)
            chunk_bytes = chunk_bytes.push((bits / 256) & 0xFF)
            chunk_bytes = chunk_bytes.push((bits / 65536) & 0xFF)
            chunk_bytes = chunk_bytes.push((bits / 16777216) & 0xFF)
            j = j + 1
        }
        let _ = _v2lora_append_bytes(path, chunk_bytes)
        total = total + (end - i)
        i = end
    }
    free_raw(scratch)
    return total
}

// Write one v2 tensor entry. Returns floats written.
fn _v2lora_write_tensor(path: string, name: string, rows: int, cols: int, data: array) -> int {
    let _ = _v2lora_append_u16(path, len(name))
    let _ = _v2lora_append_str_bytes(path, name)
    let _ = _v2lora_append_u8(path, 0)         // dtype fp32
    let _ = _v2lora_append_u8(path, 2)         // rank=2
    let _ = _v2lora_append_u32(path, rows)
    let _ = _v2lora_append_u32(path, cols)
    let _ = _v2lora_append_floats_chunked(path, data)
    return rows * cols
}

// Env probe: HEXACKPT_V2=1 → use binary path. Default v1.
fn _v2lora_enabled() -> int {
    let v = exec("printf '%s' \"${HEXACKPT_V2:-0}\"").trim()
    if v == "1" { return 1 }
    return 0
}

fn append_tensor_block(path: string, name: string, rows: int, cols: int, data: array) -> int {
    // Header line first: "name rows cols\n"
    let header = name + " " + str(rows) + " " + str(cols) + "\n"
    let _h_rc = append_file(path, header)
    let n = rows * cols
    if n <= 0 {
        let _nl = append_file(path, "\n")
        return 0
    }
    let mut start = 0
    while start < n {
        let cand = start + HEXACKPT_CHUNK_FLOATS
        let end = if cand < n { cand } else { n }
        let mut buf = ""
        let mut i = start
        while i < end {
            if i > 0 { buf = buf + " " }
            buf = buf + str(data[i])
            i = i + 1
        }
        let _rc = append_file(path, buf)
        start = end
    }
    let _nl = append_file(path, "\n")
    return 0
}

@convergence(state="ossified", id="RUNPOD_CKPT_CORRUPTION_ZERO_BYTE", value="Killed during torch.save → 0-byte .pt. Safe pattern: write .tmp then os.replace (atomic rename)", ossified_at="2026-04-16")
fn save_lora(A_flat: array, B_flat: array, out_dir: string, cfg: RunConfig) -> int {
    // BUGFIX 2026-04-20 r11 v5.4 wire smoke: write_file does not auto-mkdir;
    // train_loop call site passes "ckpt_dir/step_N" without first creating
    // it, so adapter_config.json silently fails and the giant string s
    // build phase (RAM ~47GB for full 192-adapter dump) blocks save with
    // no on-disk artifact. Explicit mkdir -p restores the per-step dir.
    let mk_rc = exec_with_status("mkdir -p '" + out_dir + "'")
    if mk_rc[1] != 0 {
        eprintln("[save_lora] WARN: mkdir failed for " + out_dir)
    }
    // adapter_config.json (peft-compatible — minimum fields needed for
    // hxqwen14b Day-2 LoRA loader and external peft inspection).
    let cfg_json = "{\n" +
        "  \"base_model_name_or_path\": \"" + cfg.base + "\",\n" +
        "  \"peft_type\": \"LORA\",\n" +
        "  \"task_type\": \"CAUSAL_LM\",\n" +
        "  \"r\": " + str(cfg.lora_r) + ",\n" +
        "  \"lora_alpha\": " + str(cfg.lora_alpha) + ",\n" +
        "  \"lora_dropout\": 0.0,\n" +
        "  \"bias\": \"none\",\n" +
        "  \"target_modules\": [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\"],\n" +
        "  \"_writer\": \"hexa-train_alm_lora.hexa\",\n" +
        "  \"_writer_version\": \"r11-2026-04-16\"\n" +
        "}\n"
    let cfg_path = out_dir + "/adapter_config.json"
    write_file(cfg_path, cfg_json)

    // adapter_model.hexackpt — flat HEXACKPT-v1 with all 192 (A,B) pairs
    // serialised as 384 named tensors. eval_alm.hexa reads via name lookup.
    //
    // 2026-04-20 (Blocker #1 fix): switched from O(n²) in-memory string
    // accumulator to chunked append_file writes. The previous path built
    // a single 47GB string before write_file ever ran, hanging the trainer
    // for any save_every<=500. Now we write the magic + meta header once,
    // then stream each tensor in 1024-float chunks straight to disk.
    //
    // 2026-04-20 (r12 blocker #4): HEXACKPT_V2=1 env activates binary
    // fp32 LE writer (~22× wallclock speedup on CLM 1B per fead4ea8).
    // Default v1 keeps backward compat with eval_alm.hexa text decoder
    // until the v2 decoder is also wired into the eval path.
    let n_adapters = N_LORA_TARGETS * QWEN14B_N_LAYER
    let r = cfg.lora_r
    let d = QWEN14B_D_MODEL
    let ckpt_path = out_dir + "/adapter_model.hexackpt"

    let v2_on = _v2lora_enabled()
    if v2_on == 1 {
        // ── HEXACKPT-v2 binary path ────────────────────────────────
        // Truncate target file by writing a single zero-length payload.
        write_file(ckpt_path, "")
        // Magic 'HXCKPT' + 0x02 + 0x00.
        let _ = _v2lora_append_bytes(ckpt_path, [0x48, 0x58, 0x43, 0x4B, 0x50, 0x54, 0x02, 0x00])
        let _ = _v2lora_append_u32(ckpt_path, 2)                  // format_version
        let _ = _v2lora_append_u32(ckpt_path, n_adapters * 2)     // tensor_count
        let _ = _v2lora_append_u64(ckpt_path, 0)                  // step (caller may patch)
        let meta = "{\"n_adapters\": " + str(n_adapters) +
                   ", \"d_model\": " + str(d) +
                   ", \"r\": " + str(r) +
                   ", \"alpha\": " + str(cfg.lora_alpha) +
                   ", \"base\": \"" + cfg.base + "\"" +
                   ", \"writer\": \"hexa-train_alm_lora.hexa-v2\"" +
                   ", \"writer_version\": \"r12-2026-04-20\"}"
        let _ = _v2lora_append_u32(ckpt_path, len(meta))
        let _ = _v2lora_append_str_bytes(ckpt_path, meta)

        // Stream each adapter A then B as a v2 tensor entry.
        let A_block_v2 = r * d
        let B_block_v2 = d * r
        let mut idx2 = 0
        while idx2 < n_adapters {
            let layer2 = idx2 / N_LORA_TARGETS
            let tgt2   = idx2 % N_LORA_TARGETS
            let tgt_name2 = if tgt2 == TGT_Q { "q_proj" }
                            else if tgt2 == TGT_K { "k_proj" }
                            else if tgt2 == TGT_V { "v_proj" }
                            else                  { "o_proj" }
            let key_prefix2 = "model.layers." + str(layer2) + ".self_attn." + tgt_name2

            let mut a_slice2 = []
            let mut k2 = 0
            while k2 < A_block_v2 {
                a_slice2 = a_slice2.push(A_flat[idx2 * A_block_v2 + k2])
                k2 = k2 + 1
            }
            let _ = _v2lora_write_tensor(ckpt_path, key_prefix2 + ".lora_A.weight", r, d, a_slice2)

            let mut b_slice2 = []
            k2 = 0
            while k2 < B_block_v2 {
                b_slice2 = b_slice2.push(B_flat[idx2 * B_block_v2 + k2])
                k2 = k2 + 1
            }
            let _ = _v2lora_write_tensor(ckpt_path, key_prefix2 + ".lora_B.weight", d, r, b_slice2)

            idx2 = idx2 + 1
        }
        println("[save_lora] HEXACKPT-v2 binary streamed " + str(n_adapters * 2) + " tensors → " + ckpt_path)
        println("[save_lora] config → " + cfg_path)
        return 0
    }

    // ── HEXACKPT-v1 text path (default) ───────────────────────────
    // Truncate + write magic + meta lines. Subsequent tensors stream via
    // append_tensor_block.
    let header = "HEXACKPT-v1\n" +
        "# meta n_adapters=" + str(n_adapters) + " d=" + str(d) + " r=" + str(r) + "\n" +
        "# meta lora_alpha=" + str(cfg.lora_alpha) + "\n" +
        "# meta base=" + cfg.base + "\n"
    write_file(ckpt_path, header)

    // Slice and emit each adapter block. A: r×d, B: d×r.
    let A_block = r * d
    let B_block = d * r
    let mut idx = 0
    while idx < n_adapters {
        let layer = idx / N_LORA_TARGETS
        let tgt = idx % N_LORA_TARGETS
        let tgt_name = if tgt == TGT_Q { "q_proj" }
                       else if tgt == TGT_K { "k_proj" }
                       else if tgt == TGT_V { "v_proj" }
                       else                 { "o_proj" }
        let key_prefix = "model.layers." + str(layer) + ".self_attn." + tgt_name

        // Slice A_flat[idx*A_block : (idx+1)*A_block]
        let mut a_slice = []
        let mut k = 0
        while k < A_block {
            a_slice = a_slice.push(A_flat[idx * A_block + k])
            k = k + 1
        }
        let _ra = append_tensor_block(ckpt_path,
                                       key_prefix + ".lora_A.weight",
                                       r, d, a_slice)

        // Slice B_flat[idx*B_block : (idx+1)*B_block]
        let mut b_slice = []
        k = 0
        while k < B_block {
            b_slice = b_slice.push(B_flat[idx * B_block + k])
            k = k + 1
        }
        let _rb = append_tensor_block(ckpt_path,
                                       key_prefix + ".lora_B.weight",
                                       d, r, b_slice)

        idx = idx + 1
    }
    let _rm = append_file(ckpt_path, "__MANIFEST__ " + str(n_adapters * 2) + " 1\n")
    println("[save_lora] streamed " + str(n_adapters * 2) + " tensors → " + ckpt_path)
    println("[save_lora] config → " + cfg_path)
    return 0
}

// ─── 9. save_lora_device_state(out_dir, cfg) — d2h + write ─────────
//
// 2026-04-20 Phase-5 wiring: replaces hexa-side save_lora when LoRA
// state lives on-device. Walks G_LORA_PTRS_P (384 device buffers) and
// memcpy_d2h's each one into a freshly-alloc'd hexa array, then hands
// to existing save_lora() so HEXACKPT-v1 / v2 paths remain shared.

fn d2h_buffer_to_array(dev_ptr: int, n_floats: int) -> array {
    if dev_ptr == 0 || n_floats <= 0 { return [] }
    let bytes = n_floats * 4
    let host_buf = alloc_raw(bytes)
    let _rc = hxqwen14b_cu_memcpy_d2h(host_buf, dev_ptr, bytes)
    let mut out = []
    let mut i = 0
    while i < n_floats {
        out = out.push(deref_f32(host_buf, i * 4))
        i = i + 1
    }
    free_raw(host_buf)
    return out
}

fn save_lora_device_state(out_dir: string, cfg: RunConfig) -> int {
    if G_LORA_PTRS_P == 0 {
        println("[save_lora_device_state] WARN: G_LORA_PTRS_P==0 — nothing to save")
        return 1
    }
    let _sync = hxqwen14b_cu_device_sync()
    let n_adapters = N_LORA_TARGETS * QWEN14B_N_LAYER
    let r = cfg.lora_r
    println("[save_lora_device_state] d2h " + str(n_adapters * 2) + " adapter buffers → " + out_dir)

    // Reconstruct flat A_flat / B_flat hexa arrays from device buffers.
    // A blocks are r * Kin per adapter; B blocks are Nout * r per adapter.
    // For all 4 targets q/k/v/o, Kin = d_model = 5120 (Qwen rotary q
    // takes d_model input). For B: o_proj has Nout = d_model, q has
    // dq = HQ*HD = 5120, k/v have dkv = HK*HD = 1024. So A_block stays
    // uniform (r * 5120) but B_block varies. We pack into a single
    // contiguous flat array following the same indexing the existing
    // save_lora uses (idx * A_block + k for A; idx * B_block + k for B).
    //
    // CAVEAT: the legacy save_lora hard-codes A_block = r*d, B_block = d*r
    // assuming Nout = d. For k/v adapters Nout = dkv != d, so we either
    // (a) zero-pad to d for v1 compat, or (b) stream each adapter
    // separately at its true shape. Choosing (b) — write directly here
    // without reusing the legacy save_lora indexing (otherwise k/v adapter
    // bytes would overflow into the next adapter's slot).
    let mk_rc = exec_with_status("mkdir -p '" + out_dir + "'")
    if mk_rc[1] != 0 {
        eprintln("[save_lora_device_state] WARN: mkdir failed for " + out_dir)
    }
    let cfg_json = "{\n" +
        "  \"base_model_name_or_path\": \"" + cfg.base + "\",\n" +
        "  \"peft_type\": \"LORA\",\n" +
        "  \"task_type\": \"CAUSAL_LM\",\n" +
        "  \"r\": " + str(cfg.lora_r) + ",\n" +
        "  \"lora_alpha\": " + str(cfg.lora_alpha) + ",\n" +
        "  \"lora_dropout\": 0.0,\n" +
        "  \"bias\": \"none\",\n" +
        "  \"target_modules\": [\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\"],\n" +
        "  \"_writer\": \"hexa-train_alm_lora.hexa-device\",\n" +
        "  \"_writer_version\": \"r12-2026-04-20-v565\"\n" +
        "}\n"
    let cfg_path = out_dir + "/adapter_config.json"
    write_file(cfg_path, cfg_json)

    let ckpt_path = out_dir + "/adapter_model.hexackpt"
    let v2_on = _v2lora_enabled()

    if v2_on == 1 {
        // HEXACKPT-v2 binary path with true per-adapter shapes.
        write_file(ckpt_path, "")
        let _ = _v2lora_append_bytes(ckpt_path, [0x48, 0x58, 0x43, 0x4B, 0x50, 0x54, 0x02, 0x00])
        let _ = _v2lora_append_u32(ckpt_path, 2)
        let _ = _v2lora_append_u32(ckpt_path, n_adapters * 2)
        let _ = _v2lora_append_u64(ckpt_path, 0)
        let meta = "{\"n_adapters\": " + str(n_adapters) +
                   ", \"d_model\": " + str(QWEN14B_D_MODEL) +
                   ", \"r\": " + str(r) +
                   ", \"alpha\": " + str(cfg.lora_alpha) +
                   ", \"base\": \"" + cfg.base + "\"" +
                   ", \"writer\": \"hexa-train_alm_lora.hexa-device-v2\"" +
                   ", \"writer_version\": \"r12-2026-04-20\"}"
        let _ = _v2lora_append_u32(ckpt_path, len(meta))
        let _ = _v2lora_append_str_bytes(ckpt_path, meta)

        let mut a_idx = 0
        while a_idx < n_adapters {
            let layer = a_idx / N_LORA_TARGETS
            let tgt   = a_idx % N_LORA_TARGETS
            let tgt_name = if tgt == TGT_Q { "q_proj" }
                           else if tgt == TGT_K { "k_proj" }
                           else if tgt == TGT_V { "v_proj" }
                           else                 { "o_proj" }
            let key_prefix = "model.layers." + str(layer) + ".self_attn." + tgt_name
            let n_out = lora_adapter_n_out(a_idx)
            let k_in  = lora_adapter_k_in(a_idx)

            let dev_A = deref_i64_at(G_LORA_PTRS_P, a_idx * 2 + 0)
            let dev_B = deref_i64_at(G_LORA_PTRS_P, a_idx * 2 + 1)
            let arr_A = d2h_buffer_to_array(dev_A, r * k_in)
            let _wA = _v2lora_write_tensor(ckpt_path, key_prefix + ".lora_A.weight", r, k_in, arr_A)
            let arr_B = d2h_buffer_to_array(dev_B, n_out * r)
            let _wB = _v2lora_write_tensor(ckpt_path, key_prefix + ".lora_B.weight", n_out, r, arr_B)

            a_idx = a_idx + 1
        }
        println("[save_lora_device_state] HEXACKPT-v2 streamed " + str(n_adapters * 2) + " tensors → " + ckpt_path)
        return 0
    }

    // HEXACKPT-v1 text path with true per-adapter shapes.
    let header = "HEXACKPT-v1\n" +
        "# meta n_adapters=" + str(n_adapters) + " d=" + str(QWEN14B_D_MODEL) + " r=" + str(r) + "\n" +
        "# meta lora_alpha=" + str(cfg.lora_alpha) + "\n" +
        "# meta base=" + cfg.base + "\n" +
        "# writer hexa-train_alm_lora.hexa-device\n"
    write_file(ckpt_path, header)
    let mut idx = 0
    while idx < n_adapters {
        let layer = idx / N_LORA_TARGETS
        let tgt   = idx % N_LORA_TARGETS
        let tgt_name = if tgt == TGT_Q { "q_proj" }
                       else if tgt == TGT_K { "k_proj" }
                       else if tgt == TGT_V { "v_proj" }
                       else                 { "o_proj" }
        let key_prefix = "model.layers." + str(layer) + ".self_attn." + tgt_name
        let n_out = lora_adapter_n_out(idx)
        let k_in  = lora_adapter_k_in(idx)
        let dev_A = deref_i64_at(G_LORA_PTRS_P, idx * 2 + 0)
        let dev_B = deref_i64_at(G_LORA_PTRS_P, idx * 2 + 1)
        let arr_A = d2h_buffer_to_array(dev_A, r * k_in)
        let _ra = append_tensor_block(ckpt_path, key_prefix + ".lora_A.weight", r, k_in, arr_A)
        let arr_B = d2h_buffer_to_array(dev_B, n_out * r)
        let _rb = append_tensor_block(ckpt_path, key_prefix + ".lora_B.weight", n_out, r, arr_B)
        idx = idx + 1
    }
    let _rm = append_file(ckpt_path, "__MANIFEST__ " + str(n_adapters * 2) + " 1\n")
    println("[save_lora_device_state] HEXACKPT-v1 streamed " + str(n_adapters * 2) + " tensors → " + ckpt_path)
    return 0
}

// Free all on-device + host scratch state allocated by train_loop. Idempotent.
fn free_train_loop_state() -> int {
    if G_LORA_PTRS_P != 0 {
        let _ = hxqwen14b_free_lora_buffers_v56(G_LORA_PTRS_P)
        free_raw(G_LORA_PTRS_P)
        G_LORA_PTRS_P = 0
    }
    if G_GRAD_PTRS_P != 0 {
        let _ = hxqwen14b_v56_free_grad_buffers(G_GRAD_PTRS_P)
        free_raw(G_GRAD_PTRS_P)
        G_GRAD_PTRS_P = 0
    }
    if G_M_PTRS_P != 0 {
        let _ = hxqwen14b_v56_free_grad_buffers(G_M_PTRS_P)
        free_raw(G_M_PTRS_P)
        G_M_PTRS_P = 0
    }
    if G_V_PTRS_P != 0 {
        let _ = hxqwen14b_v56_free_grad_buffers(G_V_PTRS_P)
        free_raw(G_V_PTRS_P)
        G_V_PTRS_P = 0
    }
    if G_CACHE_PTRS_P != 0 {
        let _ = hxqwen14b_v56_free_activation_cache(G_CACHE_PTRS_P)
        free_raw(G_CACHE_PTRS_P)
        G_CACHE_PTRS_P = 0
    }
    if G_IDS_DEV != 0    { let _ = hxqwen14b_cu_free_ptr(G_IDS_DEV);    G_IDS_DEV = 0 }
    if G_TGT_DEV != 0    { let _ = hxqwen14b_cu_free_ptr(G_TGT_DEV);    G_TGT_DEV = 0 }
    if G_LOGITS_DEV != 0 { let _ = hxqwen14b_cu_free_ptr(G_LOGITS_DEV); G_LOGITS_DEV = 0 }
    if G_IDS_HOST != 0   { free_raw(G_IDS_HOST); G_IDS_HOST = 0 }
    if G_TGT_HOST != 0   { free_raw(G_TGT_HOST); G_TGT_HOST = 0 }
    return 0
}

// ─── 10. main() — single entry point (silent-exit defense) ─────────
//
// Per feedback_hexa_silent_exit_5_imports.md: this file has NO `use`
// statements and its main() body is intentionally non-trivial so that
// the codegen produces a real C body. Verify after build with:
//   awk '/^int main/,/^}/' build/artifacts/train_alm_lora.c

fn main() {
    println("════════════════════════════════════════════════════════")
    println("  ALM 14B r11 — hexa-native LoRA trainer")
    println("  spec : training/deploy/alm_r11_plan.json")
    println("  base : Qwen2.5-14B (n_layer=48, d_model=5120)")
    println("════════════════════════════════════════════════════════")

    // Parse CLI (args() returns [binary, binary, arg1, arg2, ...] — see
    // hexa_set_args in self/runtime.c — so skip first 2 elements).
    let argv_full = args()
    let n_argv = len(argv_full)
    let mut argv = []
    let mut i = 2
    while i < n_argv {
        argv = argv.push(argv_full[i])
        i = i + 1
    }

    let cfg0 = default_config()
    let fl0  = default_floats()
    let parsed = parse_cli(argv, cfg0, fl0)
    let cfg: RunConfig = parsed[0]
    let fl: RunFloats  = parsed[1]

    println("[main] config:")
    println("[main]   base       = " + cfg.base)
    println("[main]   corpus     = " + cfg.corpus)
    println("[main]   out        = " + cfg.out)
    println("[main]   steps      = " + str(cfg.steps))
    println("[main]   warmup     = " + str(cfg.warmup))
    println("[main]   lora_r     = " + str(cfg.lora_r))
    println("[main]   lora_alpha = " + str(cfg.lora_alpha))
    println("[main]   batch      = " + str(cfg.batch))
    println("[main]   seq        = " + str(cfg.seq))
    println("[main]   save_every = " + str(cfg.save_every))
    println("[main]   eval_every = " + str(cfg.eval_every))
    println("[main]   patience   = " + str(cfg.patience))
    println("[main]   lr         = " + str(fl.lr))
    println("[main]   beta1      = " + str(fl.beta1))
    println("[main]   dry_run    = " + str(cfg.dry_run))
    println("[main]   world_size = " + str(cfg.world_size) + "  rank = " + str(cfg.rank))

    // Probe FFI version (works on Mac stub too — returns 1).
    let abi = hxqwen14b_version()
    println("[main] hxqwen14b ABI version = " + str(abi))
    if abi <= 0 {
        println("[main] ERROR: hxqwen14b lib not loadable (libhxqwen14b.{so,dylib} missing)")
        println("[main]        set DYLD_LIBRARY_PATH (Mac) or LD_LIBRARY_PATH (Linux)")
        return
    }

    // FSDP init — world_size>1 triggers hxnccl bf16 AllReduce on grads.
    // world_size==1 ⇒ identity, but we still init to exercise the call graph.
    let nccl_v = hxnccl_version()
    println("[main] hxnccl version = " + str(nccl_v) + " (1=real NCCL, 0=stub)")
    if cfg.world_size > 1 && nccl_v != 1 {
        println("[main] ERROR: world_size=" + str(cfg.world_size) + " but hxnccl is stub — build libhxnccl.so on pod with CUDA+NCCL first (see training/build/build_libhxnccl.hexa)")
        return
    }
    let init_rc = hxnccl_init(cfg.world_size)
    G_NCCL_H = init_rc
    if init_rc < 0 {
        println("[main] ERROR: hxnccl_init failed rc=" + str(init_rc))
        return
    }
    println("[main] hxnccl_init handle=" + str(G_NCCL_H) + " world_size=" + str(cfg.world_size) + " rank=" + str(cfg.rank))

    // Try to load base. On Mac dry-run / missing weights, returns -1
    // and we report cleanly. The trainer itself runs in stub mode.
    // (`handle` is a reserved keyword in hexa parser — use `h_base`.)
    let mut h_base = -1
    if cfg.dry_run == 0 {
        // cstring builtin marshals string → int64 address for FFI
        let cpath = cstring(cfg.base)
        h_base = hxqwen14b_load(cpath)
        if h_base <= 0 {
            println("[main] WARN: hxqwen14b_load failed (rc=" + str(h_base) + ")")
            println("[main]       proceeding in stub mode — useful for non-GPU CI smoke")
            h_base = 1   // pretend-handle so train_loop continues with stub forward
        } else {
            println("[main] base loaded at h_base=" + str(h_base))
        }
    } else {
        h_base = 1
    }

    // ─── v5.4 CUDA forward path live-probe (2026-04-20, r11) ──────────
    // Rationale: r11 BLOCKED_FFI was caused by libhxqwen14b.so missing
    // CUDA symbols. nvcc-built .so now ships hxqwen14b_cu_launch_* +
    // base_forward_v54 + load_all_weights + ce_loss_v54. Probe the v5.4
    // version + smoke entries here so a broken .so fails LOUD before the
    // 500-step loop wastes H100 minutes. Real LoRA-fused forward wiring
    // is r12 work (needs hidden_state + LoRA delta integration). Today
    // the train_loop still uses the stub forward for gradient signal.
    let abi_v54 = hxqwen14b_version_v54()
    println("[main] hxqwen14b v5.4 ABI = " + str(abi_v54) + " (54 = real CUDA, <=0 = stub or missing)")
    // BUGFIX 2026-04-20 (Blocker #4): hxqwen14b_load returns slot=1 on
    // successful probe (no VRAM upload yet). The previous gate `h_base > 1`
    // wrongly skipped the v5.4 path even when the load succeeded. Slot 1 is
    // the FIRST valid slot (slot 0 is reserved sentinel). Fix: gate on
    // `h_base >= 1` so v5.4 load_all_weights+forward runs as designed.
    if h_base >= 1 && abi_v54 >= 54 {
        // load_all_weights: orchestrator pulls all 8 safetensor shards
        // into device memory (+3.1GB lm_head fp32, headroom on H100 80GB).
        // Uses the v5.5 positional wrapper (real ABI is struct-pointer).
        let loadw_rc = hxqwen14b_load_all_weights_pos(h_base, cstring(cfg.base))
        println("[main] hxqwen14b_load_all_weights_pos rc=" + str(loadw_rc) + " (0=ok, <0=load failure)")
        if loadw_rc != 0 {
            println("[main] FATAL: real Qwen2.5-14B weights failed to load — base loss would be stub-only. Aborting.")
            if G_NCCL_H != 0 { let _ = hxnccl_free(G_NCCL_H); G_NCCL_H = 0 }
            return
        }
        // Smoke step: feed a tiny prompt and check we get a real CE in [3,8].
        // Random baseline for V=152064 is log(V)=11.93. Real Qwen base on
        // arbitrary token ids should land somewhere around 6-8.
        let probe_ids_str = "안녕"
        let probe_ids = text_to_ids_stub(probe_ids_str, 4, 4)
        let probe_buf = float_array_to_int32_buf(probe_ids)
        let probe_ce = hxqwen14b_train_step_v54(h_base, probe_buf, 4)
        println("[main] hxqwen14b_train_step_v54 probe_ce=" + str(probe_ce) + " (real Qwen base CE; band [3,8] expected, <0 = -rc)")
    }

    // Load corpus.
    let corpus = load_corpus(cfg.corpus)
    if len(corpus) == 0 && cfg.dry_run == 0 {
        println("[main] FATAL: empty corpus, aborting (use --dry-run to test trainer wiring)")
        if G_NCCL_H != 0 { let _ = hxnccl_free(G_NCCL_H); G_NCCL_H = 0 }
        if h_base > 1 { hxqwen14b_free(h_base) }
        return
    }
    // ─── Phase-3 BPE tokenizer load ──────────────────────────────────
    // Try pod path first, then Mac fallback. If both fail, G_TOK_H stays
    // 0 and train_loop falls back to text_to_ids_stub (signal-only hash).
    // Real Qwen2.5-14B training requires the real tokenizer — warn loud.
    let tok_pod = hxtok_load(QWEN14B_TOKENIZER_POD, 0)
    if tok_pod != 0 {
        G_TOK_H = tok_pod
        println("[main] hxtok loaded (pod path): vocab_size=" + str(hxtok_vocab_size(tok_pod)))
    } else {
        let tok_mac = hxtok_load(QWEN14B_TOKENIZER_MAC, 0)
        if tok_mac != 0 {
            G_TOK_H = tok_mac
            println("[main] hxtok loaded (mac path): vocab_size=" + str(hxtok_vocab_size(tok_mac)))
        } else {
            println("[main] WARN: hxtok_load failed on both POD + MAC paths — train_loop will fall back to text_to_ids_stub (vocab=152064 hashed, NOT real BPE). For real loss curves, place tokenizer.json at one of:")
            println("[main]   " + QWEN14B_TOKENIZER_POD)
            println("[main]   " + QWEN14B_TOKENIZER_MAC)
        }
    }

    if len(corpus) == 0 {
        // dry-run with no corpus → synthesise tiny fake corpus
        println("[main] dry-run: synthesising 4 fake corpus samples")
        let mut fake = []
        fake = fake.push("이것은 첫 번째 한국어 샘플 텍스트입니다. 평가용으로 사용됩니다.")
        fake = fake.push("두 번째 샘플은 면접 시뮬레이션 태스크의 일부분입니다. 답변 모범 예시.")
        fake = fake.push("세 번째 샘플 텍스트로 의식 엔진의 자연어 처리를 테스트합니다.")
        fake = fake.push("네 번째 샘플은 토큰 시퀀스 길이 다양성을 검증하기 위한 충분히 긴 텍스트입니다 모델은 이것을 학습합니다.")
        let rc = train_loop(fake, h_base, cfg, fl)
        println("[main] dry-run train_loop rc=" + str(rc))
        if G_NCCL_H != 0 { let _ = hxnccl_free(G_NCCL_H); G_NCCL_H = 0 }
        if h_base > 1 { hxqwen14b_free(h_base) }
        return
    }

    // Run the loop.
    let rc = train_loop(corpus, h_base, cfg, fl)
    println("[main] train_loop rc=" + str(rc))

    // Final save — rank-0-only under FSDP so shards don't collide.
    // 2026-04-20 Phase-5: device-state save (d2h all 384 LoRA buffers).
    // train_loop intentionally leaves device state allocated until here
    // so this final write can read from G_LORA_PTRS_P; we free right after.
    if rc == 0 && cfg.rank == 0 {
        let final_dir = cfg.out + "/final"
        let _final = save_lora_device_state(final_dir, cfg)
        println("[main] final ckpt → " + final_dir)
    }
    // Free tokenizer handle (idempotent; 0 = already-freed / never-loaded).
    if G_TOK_H != 0 { let _ = hxtok_free(G_TOK_H); G_TOK_H = 0 }
    // Free on-device state regardless of rc (idempotent on already-freed paths).
    let _free = free_train_loop_state()

    // FSDP teardown — hxnccl_free destroys all NCCL comms on every rank.
    if G_NCCL_H != 0 {
        let _ = hxnccl_free(G_NCCL_H)
        G_NCCL_H = 0
    }

    // Release base handle (idempotent, safe even if never really loaded).
    if h_base > 1 {
        hxqwen14b_free(h_base)
    }

    println("════════════════════════════════════════════════════════")
    println("  ALM 14B r11 — done. final_loss=" + str(G_LAST_LOSS) + " best=" + str(G_BEST_LOSS))
    println("════════════════════════════════════════════════════════")
}

// Note: hexa codegen auto-invokes `fn main()` when present — no explicit
// script-level `main()` call needed (would double-invoke; verified empirically
// 2026-04-16). Build artifact emits `u_main();` from inside int main(...).
