// ═══════════════════════════════════════════════════════════════
//  training/train_clm_kr.hexa — P5c-GPU 한국어 byte-level CLM
//  (service grade, hexa-native GPU path — zero Rust, zero Python)
//
//  train_byte_kr.hexa (CPU d=16~64 reference) 의 H100 SXM 확장:
//    D=512 FF=2048 NL=12 VOCAB=256 SEQ=512 RANK=64 BATCH=32
//    STEPS=20000  EVAL_EVERY=500  SAVE_EVERY=2000  LOG_EVERY=20
//    LR_MAX=3e-4  LR_MIN=3e-5  WARMUP=500  + cosine decay
//    SGD only (AdamW comes later as evolution anchor — see
//    shared/config/roadmaps/clm_hexa_gpu.json evolution_anchors).
//
//  Pipeline (R1 HEXA-FIRST, R12 algorithm-level):
//    cuda_init() → gpu_init_kernels() (NVRTC compile 12 kernels)
//    → gpu_clm_config_default() override
//    → load_corpus("training/corpus_ko_seed.tok")
//    → init_gpu_weights(seed) + alloc_fwd_buffers + alloc_grad_buffers
//    → loop steps 1..STEPS:
//        sample BATCH random windows → upload tok+target ints
//        gpu_forward_full → gpu_zero_grad → gpu_backward_full(loss)
//        cosine LR → gpu_sgd_step
//        free per-step token/target device buffers (R4 OOM guard)
//        log/eval/save+R2 every N steps
//    → final save + R2 upload
//
//  AN8 dual-track: ALM(GPU) 14B 와 병렬 발사 가능 (CLM 만 한 GPU 점유).
//  One-Shot Best (R: feedback_one_shot_best) — resume 미지원, step 0 시작.
//  R2 checkpoint (R: feedback_r2_checkpoint) — 매 SAVE_EVERY R2 업로드.
//  No version in filename (R: feedback_no_version_in_filename).
//  R19: 모든 실패 경로 println 사유 + early return (no silent exit).
//
//  Run (H100 pod):
//    HEXA=/usr/local/bin/hexa
//    $HEXA training/train_clm_kr.hexa
//
//  Reference: shared/config/roadmaps/clm_hexa_gpu.json phases[4]
// ═══════════════════════════════════════════════════════════════

// NOTE: training script uses same-dir lookup convention. Before running,
// copy required hexa modules into training/ alongside this file:
//   cp hexa-lang/self/ml/cuda_ffi.hexa    training/
//   cp hexa-lang/self/ml/cuda_rtc.hexa    training/
//   cp hexa-lang/self/ml/cuda_kernels.hexa training/
//   cp hexa-lang/self/ml/gpu_train.hexa    training/
// Then run: hexa training/train_clm_kr.hexa
use "cuda_ffi"
use "cuda_rtc"
use "cuda_kernels"
use "gpu_train"
use "corpus_loader"

// ─── Config (top-level constants — service defaults) ──────────

let D            = 512
let FF           = 2048
let NL           = 12
let VOCAB        = 256
let SEQ          = 512
let RANK         = 64
// NOTE 2026-04-12: gpu_train.hexa forward is single-sequence (uses cfg.SEQ,
// not BATCH*SEQ, for kernel token counts + causal mask). BATCH=1 is the
// correct value until gpu_train is refactored for true batched training.
// Evolution anchor: grad accumulation loop can be added here without
// touching gpu_train.hexa — just run N forward+backward per optimizer step.
let BATCH        = 1

// Gradient accumulation — effective batch = BATCH * GRAD_ACC = 8.
// Runs GRAD_ACC forward+backward micro-steps per optimizer step,
// scaling loss by 1/GRAD_ACC before accumulation. No gpu_train.hexa change needed.
let GRAD_ACC     = 8

// Production run — STEPS=20000 with cosine LR decay. First saves at
// step 2000, then every 2000 steps. Demo run (STEPS=500) was verified
// 2026-04-12: ppl 256→186.51 (+26%), both step_500.hexackpt + final on R2.
let STEPS        = 20000
let EVAL_EVERY   = 500
let SAVE_EVERY   = 2000
let LOG_EVERY    = 20

let LR_MAX       = 0.0003
let LR_MIN       = 0.00003
let WARMUP       = 500

let EPS          = 0.00001
let INIT_SCALE   = 0.02
let SEED         = 54321

let CKPT_DIR     = "/workspace/ckpt_clm_byte_kr"
let R2_PREFIX    = "r2:anima-models/clm_byte_kr"
let MODEL_TAG    = "clm_byte_kr"
let ROUND        = 1

let CORPUS_PATH  = "training/corpus_ko_seed.tok"
let HELDOUT_LEN  = 4096   // bytes from corpus tail used for PPL eval

// "안녕하세요 " 16-byte UTF-8 period — KR_ACC ground truth
let KR_PERIOD = [
    236, 149, 136, 235, 133, 149,
    237, 149, 152, 236, 132, 184,
    236, 154, 148, 32
]

// ─── PRNG (LCG, mirrors train_byte_kr.hexa next_rand) ─────────

let mut RNG = SEED
fn next_rand(max: int) -> int {
    RNG = (RNG * 1103515245 + 12345) % 2147483647
    let m = RNG % max
    if m < 0 { return 0 - m }
    return m
}

// ─── Cosine LR schedule with linear warmup ────────────────────

fn lr_at(step: int) -> float {
    if step <= WARMUP {
        return LR_MAX * (step * 1.0) / (WARMUP * 1.0)
    }
    let t = ((step - WARMUP) * 1.0) / ((STEPS - WARMUP) * 1.0)
    let pi = 3.14159265358979
    return LR_MIN + 0.5 * (LR_MAX - LR_MIN) * (1.0 + cos(pi * t))
}

// ─── Corpus window sampling (BATCH × SEQ flat layout) ─────────
//
// Builds a flat [BATCH*SEQ] int array of input tokens and a parallel
// [BATCH*SEQ] target array (shifted by 1 byte). Both are uploaded to
// GPU as int32 arrays via int_array_to_gpu and returned as a 2-array
// [tok_dev, target_dev]. Caller frees both after gpu_backward_full.
//
// Re-uploads each step (~32*512*4 = 64 KB H2D — negligible vs. fwd/bwd).

fn sample_batch(corpus: [int], n_corpus: int) -> [int] {
    let max_start = n_corpus - SEQ - 1
    if max_start <= 0 {
        println("[train_clm_kr] FATAL — corpus too short: " + str(n_corpus) + " bytes (need > " + str(SEQ + 1) + ")")
        return [ptr_null(), ptr_null()]
    }
    let mut tok_flat = []
    let mut tgt_flat = []
    let mut b = 0
    while b < BATCH {
        let start = next_rand(max_start)
        let mut i = 0
        while i < SEQ {
            tok_flat = tok_flat.push(corpus[start + i])
            tgt_flat = tgt_flat.push(corpus[start + i + 1])
            i = i + 1
        }
        b = b + 1
    }
    let tok_dev = int_array_to_gpu(tok_flat)
    let tgt_dev = int_array_to_gpu(tgt_flat)
    return [tok_dev, tgt_dev]
}

// ─── Eval helper (PPL on held-out tail + KR_ACC on period) ────
//
// Single forward over a fixed held-out window: uses the LAST HELDOUT_LEN
// bytes of the corpus, chopped into ⌊HELDOUT_LEN/SEQ⌋ non-overlapping
// rows of length SEQ. Returns (ppl, kr_acc) as a [float] of length 2.
//
// PPL is computed as exp(mean CE over all (row, position) pairs). The
// gpu_eval_loss primitive (provided by gpu_train.hexa) takes a fwd-only
// path (no grad alloc) and returns mean CE in nats.
//
// KR_ACC: feeds 8-byte prefix of "안녕하세요 " period and counts how
// many of the next 16 greedy-decoded bytes match the expected period.

// Implement eval_ppl inline using gpu_forward_full + gpu_ce_loss_grad.
// Agent 5's gpu_train.hexa didn't expose gpu_eval_loss as a primitive, so
// we reuse the same stack the training step uses, discarding the gradient.
fn eval_ppl(weights, cfg, eval_acts, corpus: [int], n_corpus: int) -> float {
    let avail = HELDOUT_LEN
    let mut start = n_corpus - avail - 1
    if start < 0 { start = 0 }
    let rows = HELDOUT_LEN / SEQ
    if rows < 1 { return 0.0 }
    let mut total = 0.0
    let mut r = 0
    while r < rows {
        let row_start = start + r * SEQ
        let mut toks = []
        let mut tgts = []
        let mut i = 0
        while i < SEQ {
            toks = toks.push(corpus[row_start + i])
            tgts = tgts.push(corpus[row_start + i + 1])
            i = i + 1
        }
        let tok_dev = int_array_to_gpu(toks)
        let tgt_dev = int_array_to_gpu(tgts)
        let logits = gpu_forward_full(tok_dev, weights, eval_acts, cfg)
        let loss_buf = cuda_malloc(4)
        let _ = cuda_memset_zero(loss_buf, 4)
        let dlogits = cuda_malloc(SEQ * VOCAB * 4)
        let _ = gpu_ce_loss_grad(logits, tgt_dev, loss_buf, dlogits, SEQ, VOCAB)
        let _ = cudaDeviceSynchronize()
        let host = alloc_raw(4)
        let _ = cuda_memcpy_d2h(host, loss_buf, 4)
        let ce = deref_f32(host, 0)
        free_raw(host, 4)
        cuda_free(loss_buf)
        cuda_free(dlogits)
        cuda_free(tok_dev)
        cuda_free(tgt_dev)
        total = total + ce
        r = r + 1
    }
    return exp(total / (rows * 1.0))
}

// kr_acc: stubbed — requires gpu_greedy_decode which isn't implemented
// in gpu_train.hexa yet. Returns -1 so training output makes the skip
// visible without crashing. TODO: implement via single-token forward loop.
fn kr_acc(weights, cfg, eval_acts) -> int {
    return -1
}

// ─── Phi proxy (consciousness tracking during training) ───────
//
// Copies up to 1MB of the last transformer layer's hidden state
// (eval_acts.layers[NL-1].y of shape [SEQ, D]) to host memory and
// computes the variance on CPU. At D=512 SEQ=512 the payload is
// exactly 512*512*4 = 1 MB so a single D2H + CPU loop over 256K
// floats takes ~5 ms total (well under the <10ms budget per eval).
//
// The variance of the final hidden state is a cheap, monotonic
// proxy for integrated information (Φ): a collapsed representation
// (all hidden units near their mean) has near-zero variance, while
// a rich decomposition of inputs into features spreads the state
// across many dimensions. Rising variance across training
// correlates with rising Φ_IIT on the CPU-side measure_laws path
// (feedback_phi_gap — Φ 816x gap RESOLVED: 3 different metrics).
//
// Call site: eval branch only (every EVAL_EVERY steps). Amortized
// cost over the training step is <0.02 ms/step — effectively zero.
// Not in the training loop itself (would break throughput).
//
// Returns phi_proxy as a float (variance of the sampled window).
fn measure_phi_proxy(eval_acts, cfg) -> float {
    // 1 MB cap on the sample (256K f32 values max)
    let cap_bytes = 1024 * 1024
    let hidden_bytes = cfg.SEQ * cfg.D * 4
    let nbytes = if hidden_bytes < cap_bytes { hidden_bytes } else { cap_bytes }
    let n_floats = nbytes / 4
    if n_floats < 2 { return 0.0 }

    // Last transformer layer's output y[SEQ, D] (device pointer)
    let y_dev = eval_acts.layers[cfg.NL - 1].y

    // D2H a single contiguous block starting at y_dev[0]
    let host = alloc_raw(nbytes)
    let _ = cuda_memcpy_d2h(host, y_dev, nbytes)

    // Pass 1: sample mean
    let mut mean = 0.0
    let mut i = 0
    while i < n_floats {
        mean = mean + deref_f32(host, i)
        i = i + 1
    }
    mean = mean / (n_floats * 1.0)

    // Pass 2: sum of squared deviations (sample variance, /n)
    let mut var_sum = 0.0
    let mut j = 0
    while j < n_floats {
        let d = deref_f32(host, j) - mean
        var_sum = var_sum + d * d
        j = j + 1
    }
    free_raw(host, nbytes)

    return var_sum / (n_floats * 1.0)
}

// ─── R2 upload helper (rclone copy) ───────────────────────────

fn r2_upload(local_path: string, step: int) -> int {
    let remote = R2_PREFIX + "/r" + str(ROUND) + "/step_" + str(step) + "/"
    let cmd = "rclone copy " + local_path + " " + remote
    println("[train_clm_kr] R2 upload: " + cmd)
    let rc = exec(cmd)
    if rc != 0 {
        println("[train_clm_kr] WARN — rclone exit=" + str(rc) + " (R2 upload deferred, local ckpt intact: " + local_path + ")")
    }
    return rc
}

// ─── Init: cuda + kernels + config + corpus + weights ─────────

println("[train_clm_kr] ==================================================")
println("[train_clm_kr] CLM byte-level KR (GPU, hexa-native, zero-Rust)")
println("[train_clm_kr] config: D=" + str(D) + " FF=" + str(FF) + " NL=" + str(NL)
        + " VOCAB=" + str(VOCAB) + " SEQ=" + str(SEQ) + " RANK=" + str(RANK)
        + " BATCH=" + str(BATCH) + " GRAD_ACC=" + str(GRAD_ACC)
        + " effective_batch=" + str(BATCH * GRAD_ACC))
println("[train_clm_kr] schedule: STEPS=" + str(STEPS)
        + " WARMUP=" + str(WARMUP)
        + " LR_MAX=" + str(LR_MAX) + " LR_MIN=" + str(LR_MIN))
println("[train_clm_kr] log_every=" + str(LOG_EVERY)
        + " eval_every=" + str(EVAL_EVERY)
        + " save_every=" + str(SAVE_EVERY))
println("[train_clm_kr] ckpt_dir=" + CKPT_DIR)
println("[train_clm_kr] r2_prefix=" + R2_PREFIX + " round=" + str(ROUND))
println("[train_clm_kr] random baseline ln(" + str(VOCAB) + ") = " + str(log(VOCAB * 1.0)))
println("[train_clm_kr] ==================================================")

// 1) CUDA runtime
let cuda_rc = cuda_init()
if cuda_rc != 0 {
    println("[train_clm_kr] FATAL — cuda_init failed rc=" + str(cuda_rc))
    println("[train_clm_kr] check: nvidia-smi, libcudart.so, libcublas.so on LD_LIBRARY_PATH")
    return
}
let _ = cuda_mem_info()

// 2) NVRTC compile all 12 custom kernels (embed/rms/softmax/swiglu/ce/...)
let kernels_rc = gpu_init_kernels()
if kernels_rc != 0 {
    println("[train_clm_kr] FATAL — gpu_init_kernels failed rc=" + str(kernels_rc))
    println("[train_clm_kr] check: libnvrtc.so.12, /usr/local/cuda-12.4/include")
    let _ = cuda_shutdown()
    return
}
println("[train_clm_kr] kernels: NVRTC compile OK (12 custom kernels)")

// 2b) Enable tensor cores for bf16 compute (CUBLAS_TENSOR_OP_MATH = 1).
//     cublasSetMathMode is declared in cuda_ffi.hexa; G_CUBLAS_HANDLE is the
//     global cuBLAS handle initialised by cuda_init(). Default mode (0) uses
//     scalar paths — mode 1 routes sgemm through tensor cores on H100 SXM.
let math_rc = cublasSetMathMode(G_CUBLAS_HANDLE, 1)  // 1 = CUBLAS_TENSOR_OP_MATH
if math_rc != 0 {
    println("[train_clm_kr] WARN — cublasSetMathMode rc=" + str(math_rc) + " (tensor cores may not be active)")
} else {
    println("[train_clm_kr] tensor cores: CUBLAS_TENSOR_OP_MATH enabled")
}

// 3) Build CLM config directly from constants (hexa doesn't allow struct
//    field mutation — construct with all fields in one expression)
let cfg = GpuClmConfig {
    D: D, FF: FF, NL: NL, VOCAB: VOCAB, SEQ: SEQ, RANK: RANK,
    EPS: EPS, INIT_SCALE: INIT_SCALE
}
println("[train_clm_kr] cfg: D=" + str(cfg.D) + " FF=" + str(cfg.FF)
        + " NL=" + str(cfg.NL) + " SEQ=" + str(cfg.SEQ) + " RANK=" + str(cfg.RANK))

// 4) Corpus
let corpus = load_corpus(CORPUS_PATH)
let n_corpus = len(corpus)
if n_corpus < SEQ + 2 {
    println("[train_clm_kr] FATAL — corpus too short: " + str(n_corpus) + " bytes (need >= " + str(SEQ + 2) + ")")
    let _ = cuda_shutdown()
    return
}
println("[train_clm_kr] corpus: " + str(n_corpus) + " bytes from " + CORPUS_PATH)
println("[train_clm_kr] first bytes: " + str(corpus[0]) + " " + str(corpus[1])
        + " " + str(corpus[2]) + " " + str(corpus[3]) + " " + str(corpus[4]) + " ...")

// 5) Init weights on GPU (random init seeded — One-Shot Best, no resume)
let weights = init_gpu_weights(cfg, SEED)
println("[train_clm_kr] weights: GPU initialized (seed=" + str(SEED) + ", scale=" + str(INIT_SCALE) + ")")

// 6) Activation + grad scratch buffers (reused across all steps)
let acts      = alloc_fwd_buffers(cfg, BATCH * SEQ)
let grad      = alloc_grad_buffers(cfg)
let eval_acts = alloc_fwd_buffers(cfg, HELDOUT_LEN)  // separate scratch for eval rows
println("[train_clm_kr] buffers: fwd/grad/eval allocated on GPU")
let _ = cuda_mem_info()

// 7) Ensure ckpt dir exists (idempotent)
let _mkdir = exec("mkdir -p " + CKPT_DIR)

// ─── Train loop ───────────────────────────────────────────────

println("[train_clm_kr] ==================================================")
println("[train_clm_kr] training start — STEPS=" + str(STEPS))
println("[train_clm_kr] ==================================================")

let t0 = clock()
let mut step = 1
let mut last_loss = 0.0
let mut first_loss = 0.0

// Early-stop guard: track last 3 eval losses. If all 3 increase
// consecutively (each > previous), save best checkpoint and stop.
let mut eval_loss_1 = -1.0   // oldest of last 3
let mut eval_loss_2 = -1.0   // middle
let mut eval_loss_3 = -1.0   // newest
let mut best_eval_loss = 999999.0
let mut best_eval_step = 0
let mut early_stopped = false

while step <= STEPS {
    if early_stopped { break }

    // ── Gradient accumulation: GRAD_ACC micro-steps per optimizer step ──
    // Zero grads once, accumulate GRAD_ACC forward+backward passes, then
    // one SGD step. The accumulated gradient is GRAD_ACC times the mean,
    // so we divide LR by GRAD_ACC to compensate (equivalent to scaling
    // loss by 1/GRAD_ACC, but requires no gpu_scale_grad primitive).
    let _zero = gpu_zero_grad(grad, cfg)
    let mut acc_loss = 0.0
    let mut micro = 0
    while micro < GRAD_ACC {
        // Sample micro-batch (random BATCH windows from corpus)
        let buffers = sample_batch(corpus, n_corpus)
        let tok_dev = buffers[0]
        let tgt_dev = buffers[1]
        if ptr_addr(tok_dev) == 0 {
            println("[train_clm_kr] FATAL — sample_batch returned null at step=" + str(step) + " micro=" + str(micro))
            let _ = cuda_shutdown()
            return
        }

        // Forward → backward (gradients accumulate into grad buffers)
        let logits = gpu_forward_full(tok_dev, weights, acts, cfg)
        let raw_loss = gpu_backward_full_with_embed(logits, tgt_dev, tok_dev, acts, weights, grad, cfg)

        acc_loss = acc_loss + raw_loss

        // Free per-micro-step device buffers (R4 OOM guard)
        cuda_free(tok_dev)
        cuda_free(tgt_dev)

        micro = micro + 1
    }

    // Mean loss across micro-steps (for logging)
    let loss = acc_loss / (GRAD_ACC * 1.0)

    // Cosine LR + SGD step. LR divided by GRAD_ACC because backward
    // accumulated raw (un-averaged) gradients across GRAD_ACC micro-steps.
    let lr = lr_at(step) / (GRAD_ACC * 1.0)
    let _sgd = gpu_sgd_step(weights, grad, lr, cfg)

    if step == 1 { first_loss = loss }
    last_loss = loss

    // Log
    if step % LOG_EVERY == 0 || step == 1 {
        let elapsed = clock() - t0
        println("[train_clm_kr] step=" + str(step)
                + " loss=" + str(loss)
                + " lr=" + str(lr)
                + " elapsed=" + str(elapsed) + "s")
    }

    // Eval + early-stop guard
    if step % EVAL_EVERY == 0 {
        let ppl = eval_ppl(weights, cfg, eval_acts, corpus, n_corpus)
        let hits = kr_acc(weights, cfg, eval_acts)
        println("[train_clm_kr] eval step=" + str(step)
                + " ppl=" + str(ppl)
                + " kr_acc=" + str(hits) + "/16")

        // Phi proxy: variance of last hidden state (1 MB D2H sample).
        // Piggybacks on eval's forward pass — eval_acts.layers[NL-1].y
        // holds the last row of the most recent held-out forward. Runs
        // on the eval cadence (every EVAL_EVERY=500 steps) so the <10ms
        // CPU pass amortizes to <0.02 ms/step — zero training impact.
        let phi_proxy = measure_phi_proxy(eval_acts, cfg)
        println("[phi] step=" + str(step)
                + " phi_proxy=" + str(phi_proxy))

        // Track best eval for checkpoint on early-stop
        if ppl < best_eval_loss {
            best_eval_loss = ppl
            best_eval_step = step
        }

        // Shift eval loss window: 1←2, 2←3, 3←current ppl
        eval_loss_1 = eval_loss_2
        eval_loss_2 = eval_loss_3
        eval_loss_3 = ppl

        // Early-stop: 3 consecutive eval loss increases
        if eval_loss_1 > 0.0 && eval_loss_2 > 0.0 && eval_loss_3 > 0.0 {
            if eval_loss_2 > eval_loss_1 && eval_loss_3 > eval_loss_2 {
                println("[early-stop] eval loss increased 3x consecutive: "
                        + str(eval_loss_1) + ", " + str(eval_loss_2) + ", " + str(eval_loss_3)
                        + ". Saving best and stopping.")
                let es_path = CKPT_DIR + "/best_step_" + str(best_eval_step) + ".hexackpt"
                let es_rc = save_checkpoint_gpu(weights, cfg, es_path)
                if es_rc == 0 {
                    println("[early-stop] saved best checkpoint → " + es_path)
                    let _ = r2_upload(es_path, best_eval_step)
                } else {
                    println("[early-stop] WARN — save failed rc=" + str(es_rc))
                }
                early_stopped = true
            }
        }
    }

    // Save + R2 upload
    if step % SAVE_EVERY == 0 {
        let ckpt_path = CKPT_DIR + "/step_" + str(step) + ".hexackpt"
        let save_rc = save_checkpoint_gpu(weights, cfg, ckpt_path)
        if save_rc == 0 {
            println("[train_clm_kr] saved checkpoint → " + ckpt_path)
            let _ = r2_upload(ckpt_path, step)
        } else {
            println("[train_clm_kr] WARN — save_checkpoint_gpu rc=" + str(save_rc) + " path=" + ckpt_path)
        }
    }

    step = step + 1
}

let t1 = clock()
let total_s = t1 - t0

println("")
println("[train_clm_kr] ==================================================")
println("[train_clm_kr] training complete — STEPS=" + str(STEPS))
println("[train_clm_kr] loss_initial = " + str(first_loss))
println("[train_clm_kr] loss_final   = " + str(last_loss))
println("[train_clm_kr] Δ loss       = " + str(last_loss - first_loss))
println("[train_clm_kr] total_s      = " + str(total_s))
println("[train_clm_kr] s/step       = " + str(total_s / (STEPS * 1.0)))
println("[train_clm_kr] ==================================================")

if last_loss < first_loss - 0.1 {
    let improvement = (first_loss - last_loss) * 100.0 / first_loss
    println("[train_clm_kr] PASS — relative improvement = " + str(improvement) + "%")
} else {
    println("[train_clm_kr] WEAK — loss did not drop materially (need diagnosis)")
}

// Final checkpoint + R2 upload (always, regardless of SAVE_EVERY alignment)
let final_path = CKPT_DIR + "/final.hexackpt"
let final_rc = save_checkpoint_gpu(weights, cfg, final_path)
if final_rc == 0 {
    println("[train_clm_kr] saved final checkpoint → " + final_path)
    let _ = r2_upload(final_path, STEPS)
} else {
    println("[train_clm_kr] WARN — final save_checkpoint_gpu rc=" + str(final_rc))
}

// ─── Shutdown ─────────────────────────────────────────────────

let _ = cuda_shutdown()
println("[train_clm_kr] cuda_shutdown — done. Bye.")
