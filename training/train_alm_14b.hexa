//   TODO[pytorch] (1) model.save_pretrained(path) + tokenizer.save_pretrained(path)
//                     + train_meta.json (effa4707:225-237)
//                 (2) FFI needed: raw file_write for .bin tensor dump.
//                     Partial impl in train_alm_lora.hexa::save_lora line 925
//                     (JSONL text format + write_f32_buf TODO).
//                 (3) CLM xref: train_clm.hexa ckpt writer same pattern.
fn alm14b_save(state: Alm14bState, out_dir: string) -> int {
    if G_SW_USE_A6GATE == 1 {
        let ok = _a6_gate_ok(state.best_ce, state.best_ce, state.step, DEFAULT_WARMUP)
        if ok == 0 {
            G_SW_GATE_SKIP_COUNT = G_SW_GATE_SKIP_COUNT + 1
            println("[alm14b][a6-gate] SKIP save step=" + str(state.step) +
                    " skip_count=" + str(G_SW_GATE_SKIP_COUNT))
            return 0
        }
    }
    // TODO: write params + meta.json. Delegate to train_alm_lora.hexa at
    // real-run landing. Return 0 = no-op success for selftest.
    return 0
}

