// ═══════════════════════════════════════════════════════════════════════
// §2  STRUCTS — Alm14bConfig / Alm14bState / Alm14bModel / LoraAdapter
// ═══════════════════════════════════════════════════════════════════════
//
// Struct layout follows train_alm_lora.hexa::RunConfig exactly (verified to
// parse under hexa 0.1.0-stage1). Float fields kept out of struct bodies
// where possible (held in RunFloats companion) to dodge multi-float return
// corruption. Array fields NEVER paired with other array fields in the same
// struct (dodges struct-list-alias bug).

struct Alm14bConfig {
    round: string,      // "r5" | "r9" | "r10" | "r10b" | "r10c" | "r10d" | "r11"
    base: string,       // HF id: "Qwen/Qwen2.5-14B-Instruct" or local ckpt path
    corpus: string,     // JSONL path
    out: string,        // checkpoint dir
    steps: int,
    warmup: int,
    batch: int,
    seq: int,
    grad_accum: int,
    lora_r: int,
    lora_alpha: int,
    save_every: int,
    eval_every: int,
    patience: int,
    dry_run: int        // 1 = skip FFI base load, use stub forward
}

// Scalar floats companion — returning >=3 floats in one struct corrupts
// under hexa 0.1.0-stage1 (see feedback_hexa_struct_return_bug.md).
struct Alm14bFloats {
    lr: float,
    beta1: float,
    beta2: float,
    eps: float
}

// Runtime training state. Step/loss metrics only — no array fields in this
// struct (dodges struct-list-alias; big buffers live in module-level `let mut`).
struct Alm14bState {
    step: int,
    phase: int,
    best_ce: float,
    patience_left: int
}

// Base model handle + pointer — opaque to hexa, sized by hxqwen14b C lib.
// Held as int (C returns int64 address). No payload hexa-side.
// NOTE: `handle` is a reserved keyword in hexa 0.1.0-stage1 (same quirk
// as train_alm_lora.hexa:1054 comment) — use `h` for the handle field.
struct Alm14bModel {
    h: int,             // hxqwen14b_load() return value (>0 ok, <=0 err)
    abi_version: int    // hxqwen14b_version() snapshot
}

// LoRA adapter spec — per-projection shape. Real A/B weight buffers live
// in module-level `let mut G_A_FLAT / G_B_FLAT` (see train_alm_lora.hexa
// line 734 for the rationale — list-aliasing bug prevents per-struct arrays).
struct LoraAdapter {
    rank: int,
    alpha: int,
    n_adapters: int,    // 4 targets × 48 layers = 192
    d_model: int
}

// ═══════════════════════════════════════════════════════════════════════
// §3  DEFAULT CONSTRUCTORS
// ═══════════════════════════════════════════════════════════════════════

fn default_config() -> Alm14bConfig {
    Alm14bConfig {
        round: "r11",
        base: "Qwen/Qwen2.5-14B-Instruct",
        corpus: "/workspace/corpus.txt",
        out: "/workspace/ckpt_alm_14b",
        steps: DEFAULT_STEPS,
        warmup: DEFAULT_WARMUP,
        batch: DEFAULT_BATCH,
        seq: DEFAULT_SEQ,
        grad_accum: DEFAULT_GRAD_ACCUM,
        lora_r: DEFAULT_LORA_R,
        lora_alpha: DEFAULT_LORA_ALPHA,
        save_every: DEFAULT_SAVE_EVERY,
        eval_every: DEFAULT_EVAL_EVERY,
        patience: DEFAULT_PATIENCE,
        dry_run: 0
    }
}

fn default_floats() -> Alm14bFloats {
    Alm14bFloats {
        lr: DEFAULT_LR,
        beta1: ADAMW_BETA1,
        beta2: ADAMW_BETA2,
        eps: ADAMW_EPS
    }
}

fn default_lora(d_model: int) -> LoraAdapter {
    LoraAdapter {
        rank: DEFAULT_LORA_R,
        alpha: DEFAULT_LORA_ALPHA,
        n_adapters: N_LORA_TARGETS * QWEN14B_N_LAYER,
        d_model: d_model
    }
}

fn state_init() -> Alm14bState {
    Alm14bState {
        step: 0,
        phase: ALM_PHASE_P1,
        best_ce: 999999.0,
        patience_left: DEFAULT_PATIENCE
    }
}

fn model_init_stub() -> Alm14bModel {
    Alm14bModel {
        h: 0,
        abi_version: 0
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §4  CLI HELPERS (inlined — no imports)
// ═══════════════════════════════════════════════════════════════════════

fn _cli_has_flag(argv, flag: string) -> bool {
    let n = len(argv)
    let mut i = 0
    while i < n {
        if argv[i] == flag { return true }
        i = i + 1
    }
    return false
}

fn _cli_flag_value(argv, flag: string, default_v: string) -> string {
    let n = len(argv)
    let mut i = 0
    while i < n - 1 {
        if argv[i] == flag { return argv[i + 1] }
        i = i + 1
    }
    return default_v
}

// ═══════════════════════════════════════════════════════════════════════
// §5  MATH PRIMITIVES (inlined — for aux loss + scheduler)
// ═══════════════════════════════════════════════════════════════════════

fn _fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _sq(x: float) -> float { return x * x }

fn _sqrt_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut r = x
    let mut i = 0
    while i < 16 {
        r = (r + x / r) * 0.5
        i = i + 1
    }
    return r
}

// Quadruple-cross loss mirror (α=β=γ=δ=1.0).
// Same formula as train_alm.hexa::_sw_qc_loss for launcher compatibility.
fn _qc_loss(psi_res: float, psi_gate: float, route: float, n_eff: float) -> float {
    return _sq(psi_res) + _sq(psi_gate - 0.5)
         + _sq(route - 1.0) + _sq(n_eff - 6.0)
}

// Linear-warmup then constant. Cosine decay TODO
//   TODO[pytorch] (1) torch.optim.lr_scheduler.{LinearLR, CosineAnnealingLR,
//                     SequentialLR} replaced the inline cosine here.
//                 (2) No FFI needed — this is pure scalar math, just needs
//                     a hexa cosine() fn (not yet in stage1 stdlib).
//                 (3) train_clm.hexa `lr_for_step` already does warmup+cosine
//                     using a Taylor-series cosine approx; copy that when
//                     a real run needs it.
fn warmup_lr(base_lr: float, step: int, warmup: int) -> float {
    if warmup <= 0 { return base_lr }
    if step >= warmup { return base_lr }
    let frac = step * 10000 / warmup
    return base_lr * (frac + 1) * 0.0001
}

// A6 save-gate (CV < 3% vs best_ce). Returns 1=save, 0=skip.
fn _a6_gate_ok(loss: float, best_ce: float, step: int, warmup: int) -> int {
    if step < warmup { return 1 }
    let denom = _fabs(best_ce) + 0.000000001
    let cv = _fabs(loss - best_ce) / denom
    if cv < 0.03 { return 1 }
    return 0
}

// SUMT stage schedule (A1 → B1 → B2 → B4).
fn _sumt_stage(step: int, total: int) -> int {
    if total <= 0 { return 1 }
    let p10 = total / 10
    let p30 = (total * 3) / 10
    let p60 = (total * 6) / 10
    if step <= p10 { return 1 }
    if step <= p30 { return 2 }
    if step <= p60 { return 3 }
    return 4
}

// Tier max_k on 1..70 linear schedule.
fn _tier_max_k(step: int, total: int) -> int {
    if total <= 0 { return 1 }
    let frac_num = step * 1000 / total
    let k = 1 + (69 * frac_num) / 1000
    if k < 1 { return 1 }
    if k > 70 { return 70 }
    return k
}

// ═══════════════════════════════════════════════════════════════════════
// §6  PHASE 3 REAL SLICE — AdamW optimizer step (pure hexa)
// ═══════════════════════════════════════════════════════════════════════
//
// Slice picked per plan §"Phase 3 candidate slices": AdamW is the cleanest
// standalone unit (no FFI dependency) and has an existing self-test shape
// in train_alm_lora.hexa:672-704 which this mirrors.
//
// Replaces:
//   (1) torch.optim.AdamW(params, lr=lr, betas=(β1,β2), eps=ε, weight_decay=wd)
//       + optimizer.step() in train_alm_14b.py:142-148 and .py:201
//   (2) FFI needed: none — pure scalar math. Future speedup: route to
//       hxblas_axpy_inplace already available in train_alm_lora.hexa FFI.
//   (3) CLM xref: train_clm.hexa has an analogous inline AdamW but coupled
//       to its own optim_state struct; we decouple here for LoRA-only params.

fn pow_float(base: float, n: int) -> float {
    let mut r = 1.0
    let mut i = 0
    while i < n {
        r = r * base
        i = i + 1
    }
    return r
}

// AdamW single step. Returns updated `params` (pass-by-value → rebind at
// caller). m_in/v_in are the first/second moment buffers — also rebound.
// All four output arrays are returned as a single [array] to dodge the
// struct-return ≥3-field corruption bug (they are arrays not floats, but
// the same bug reproduces for ≥3 list fields per feedback_hexa_struct_list
// _alias.md — safer to pack).
fn adamw_step(params: array, grads: array, m_in: array, v_in: array,
              step: int, lr: float, beta1: float, beta2: float,
              eps: float, wd: float) -> array {
    let n = len(params)
    let mut p_out = params
    let mut m_out = m_in
    let mut v_out = v_in
    let b1p = 1.0 - pow_float(beta1, step)
    let b2p = 1.0 - pow_float(beta2, step)
    let lr_corr = if b1p > 0.0 { lr / b1p } else { lr }

    let mut i = 0
    while i < n {
        let g = grads[i]
        let m_new = beta1 * m_out[i] + (1.0 - beta1) * g
        let v_new = beta2 * v_out[i] + (1.0 - beta2) * (g * g)
        m_out[i] = m_new
        v_out[i] = v_new
        let v_hat = v_new / (if b2p > 0.0 { b2p } else { 1.0 })
        let denom = _sqrt_safe(v_hat) + eps
        let p_new = p_out[i] - lr_corr * (m_new / denom + wd * p_out[i])
        p_out[i] = p_new
        i = i + 1
    }

    let mut packed = []
    packed = packed.push(p_out)
    packed = packed.push(m_out)
    packed = packed.push(v_out)
    return packed
}

