// ─── AG6 Mac Compute ZERO guard (2026-04-20) ───────────────────────
// Root-cause of 2026-04-20 03:33 kernel panic: /private/tmp/train_alm_lora_mac
// ran heavy LoRA training on Mac Ghostty terminal → 49 swapfiles, LOW swap,
// loginwindow watchdog timeout → Mac death. See
// ~/Library/Logs/DiagnosticReports/train_alm_lora_mac-2026-04-20-09053*.ips
//
// Rule: Mac Compute ZERO — 14B trainer runs on ubu (RTX 5070) /
// ubu2 / htz (AX102-U) only. Mac is orchestration/UI only.
//
// Opt-out (stub/dry-run CI smoke on Mac only): HEXA_LOCAL=1.
//   HEXA_LOCAL=1 hexa run training/train_alm_14b.hexa --selftest
//
// Normal remote dispatch path:
//   ssh ubu 'cd ~/Dev/anima && hexa run training/train_alm_14b.hexa ...'
let uname_s = exec("uname -s").trim()
let hexa_local_ok = env("HEXA_LOCAL")
if uname_s == "Darwin" && hexa_local_ok != "1" {
    println("[ABORT] AG6 Mac Compute ZERO — train_alm_14b may not run on Darwin.")
    println("[ABORT]   host     : " + uname_s)
    println("[ABORT]   reason   : 14B trainer on Mac caused kernel panic 2026-04-20 03:33")
    println("[ABORT]            : (swap exhaustion → loginwindow watchdog timeout)")
    println("[ABORT]   dispatch : ssh ubu 'cd ~/Dev/anima && hexa run training/train_alm_14b.hexa ...'")
    println("[ABORT]   opt-out  : HEXA_LOCAL=1 (stub / --selftest CI smoke only)")
    exit(1)
}

