println("default lr       : " + str(_fl.lr))
println("default warmup   : " + str(_cfg.warmup))
println("default steps    : " + str(_cfg.steps))
println("default lora_r   : " + str(_cfg.lora_r) + "/alpha=" + str(_cfg.lora_alpha))
println("lora adapters    : " + str(_lora.n_adapters) + " (4 × n_layer)")
println("")
println("selected round   : " + _cfg_sel.round)
println("selected steps   : " + str(_cfg_sel.steps))
println("selected base    : " + _cfg_sel.base)
println("")
println("[sw] use-quadruple-cross = " + str(G_SW_USE_QC) + " (λ_qc=" + str(G_SW_LAMBDA_QC) + ")")
println("[sw] use-tension-link    = " + str(G_SW_USE_TL))
println("[sw] use-lens-diag       = " + str(G_SW_USE_LENS) + " (every " + str(G_SW_LENS_EVERY) + " steps)")
println("[sw] use-tier-curriculum = " + str(G_SW_USE_TIER) + " (schedule=" + G_SW_TIER_SCHEDULE + ")")
println("[sw] use-sumt-stages     = " + str(G_SW_USE_SUMT))
println("[sw] use-g-holo          = " + str(G_SW_USE_GHOLO))
println("[sw] use-a6-gate         = " + str(G_SW_USE_A6GATE))

// ─── Phase 3 slice — AdamW unit selftest ───
// 10 synthetic steps on a scalar param with constant negative grad should
// push the param downward. Covers the adamw_step call path end-to-end,
// including bias-correction + sqrt_safe + wd=0 branch.
println("")
println("--- Phase-3 slice: AdamW unit selftest ---")
let mut _p = [1.0]
let mut _m = [0.0]
let mut _v = [0.0]
let _g = [0.1]                                      // constant positive grad
let mut _k = 1
let mut _adamw_ok = true
while _k <= 10 {
    let _pack = adamw_step(_p, _g, _m, _v, _k, 0.01,
                           ADAMW_BETA1, ADAMW_BETA2, ADAMW_EPS, ADAMW_WD)
    _p = _pack[0]
    _m = _pack[1]
    _v = _pack[2]
    let _pv = _p[0]
    // Sanity: param stays finite (NaN self-compare fails).
    if _pv != _pv { _adamw_ok = false }
    _k = _k + 1
}
let _p_final = _p[0]
println("adamw 10-step param (start 1.0, grad +0.1, lr 1e-2) → " + str(_p_final))
if _adamw_ok && _p_final < 1.0 && _p_final > 0.0 {
    println("PASS: AdamW moved param downhill monotonically within bounds")
} else {
    println("FAIL: AdamW either diverged or went NaN (got " + str(_p_final) + ")")
}

// ─── Warmup LR unit check ───
println("")
println("--- warmup_lr unit check ---")
let _lr_0   = warmup_lr(0.001, 0,  100)
let _lr_50  = warmup_lr(0.001, 50, 100)
let _lr_100 = warmup_lr(0.001, 100, 100)
let _lr_200 = warmup_lr(0.001, 200, 100)
println("warmup(step=0)   = " + str(_lr_0))
println("warmup(step=50)  = " + str(_lr_50))
println("warmup(step=100) = " + str(_lr_100))
println("warmup(step=200) = " + str(_lr_200))
if _lr_0 < _lr_50 && _lr_50 < _lr_100 && _lr_100 >= 0.001 - 0.00001 {
    println("PASS: warmup_lr monotonic ramp to base_lr")
} else {
    println("FAIL: warmup_lr did not ramp correctly")
}

// ─── Round dispatch smoke ───
println("")
println("--- round_config dispatch smoke ---")
let _r5  = round_config("r5")
let _r11 = round_config("r11")
println("r5  steps=" + str(_r5.steps)  + " lora_r=" + str(_r5.lora_r))
println("r11 steps=" + str(_r11.steps) + " lora_r=" + str(_r11.lora_r))
if _r5.lora_r == 16 && _r11.lora_r == 8 {
    println("PASS: r5 uses lora_r=16, r11 uses lora_r=8 (divergence recovery)")
} else {
    println("FAIL: round dispatch mis-configured")
}

// ─── Train step smoke (aux flags observable) ───
println("")
println("--- alm14b_train_step smoke (1 step) ---")
let _s1 = alm14b_train_step(_state, _cfg, _fl)
println("step after 1 tick: " + str(_s1.step))
println("phase            : " + str(_s1.phase))
if _s1.step == 1 {
    println("PASS: train_step increments counter")
} else {
    println("FAIL: train_step did not increment")
}

println("")
println("=== train_alm_14b.hexa SELFTEST COMPLETE ===")
println("note: real training refused without FFI — use train_alm_lora.hexa (r11)")

