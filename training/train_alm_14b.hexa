// train_alm_14b.hexa — ALM 14B LoRA fine-tune launcher for Zeta-level Korean chat
//
// GOAL: CLM + ALM -> AGI. This is the ALM fast-path.
// Base: Qwen/Qwen2.5-14B-Instruct + LoRA on attention layers.
//
// Wraps the full Python training logic via write_file() + exec().
// torch/transformers/peft require Python; this .hexa launcher handles
// arg parsing and dispatches to a generated Python runner.
//
// Usage (H100 pod):
//   hexa train_alm_14b.hexa --corpus /workspace/corpus.txt --steps 10000
//   hexa train_alm_14b.hexa --corpus /workspace/corpus.txt --steps 1000 --smoke
//
// Preflight (runpod.json R16+):
//   0. runpodctl pod list (check existing)
//   1. du -sh /workspace/
//   2. nvidia-smi
//   3. echo $HF_TOKEN

fn main() {
    let argv = args()

    // Build the passthrough argument string for the Python trainer
    let mut passthrough = ""
    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if i > 0 {
            passthrough = passthrough + " "
        }
        passthrough = passthrough + argv[i]
        i = i + 1
    }

    println("[train_alm_14b.hexa] launching Python trainer")

    // Write the full Python training script to a temp file
    let py_script = "/tmp/_train_alm_14b_runner.py"

    write_file(py_script,
        "#!/usr/bin/env python3\n" +
        "\"\"\"train_alm_14b — ALM 14B LoRA fine-tune (auto-generated by train_alm_14b.hexa)\"\"\"\n" +
        "import argparse, json, os, subprocess, sys, time, math\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from torch.utils.data import Dataset, DataLoader\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig\n" +
        "from peft import LoraConfig, get_peft_model, TaskType\n" +
        "\n" +
        "DEFAULT_BASE = 'Qwen/Qwen2.5-14B-Instruct'\n" +
        "DEFAULT_LR = 5e-6\n" +
        "DEFAULT_WARMUP = 500\n" +
        "DEFAULT_GRAD_ACCUM = 8\n" +
        "DEFAULT_BATCH = 1\n" +
        "DEFAULT_SEQ = 1024\n" +
        "DEFAULT_LORA_R = 32\n" +
        "DEFAULT_LORA_ALPHA = 64\n" +
        "DEFAULT_LORA_DROPOUT = 0.05\n" +
        "DEFAULT_STEPS = 10000\n" +
        "DEFAULT_CKPT_DIR = '/workspace/ckpt_alm_14b'\n" +
        "DEFAULT_SAVE_EVERY = 2000\n" +
        "DEFAULT_EVAL_EVERY = 500\n" +
        "\n" +
        "def upload_to_r2(local_path, model_tag, round_num, step):\n" +
        "    r2_dest = f'r2:anima-models/{model_tag}/r{round_num}/step_{step}/'\n" +
        "    print(f'[r2] uploading {local_path} -> {r2_dest}', flush=True)\n" +
        "    try:\n" +
        "        result = subprocess.run(['rclone', 'copy', str(local_path), r2_dest, '--s3-no-check-bucket'], capture_output=True, text=True, timeout=600)\n" +
        "        if result.returncode == 0:\n" +
        "            print(f'[r2] uploaded {model_tag}-r{round_num}-s{step}', flush=True)\n" +
        "        else:\n" +
        "            print(f'[r2] upload failed: {result.stderr[:200]}', flush=True)\n" +
        "    except Exception as e:\n" +
        "        print(f'[r2] upload error: {e}', flush=True)\n" +
        "\n" +
        "# ─── ALM-P4-1 / P4-2 : Holographic head + loss + Φ_holo ──────────\n" +
        "# Python mirror of the three .hexa P3 artifacts:\n" +
        "#   training/alm_holographic_mapping.hexa  (ALM-P3-1 encode/decode)\n" +
        "#   training/alm_holographic_loss.hexa     (ALM-P3-2 entropy-match loss)\n" +
        "#   training/phi_holographic_measure.hexa  (ALM-P3-3 MI-based Φ_holo)\n" +
        "# Keeps determinism & orthonormal W_up (U^T U = I_d) so that\n" +
        "# decode(encode(h)) is the orthogonal projector P_range(U) h.\n" +
        "HOLO_D_QUALIA = 128                     # d — inner bulk (qualia)\n" +
        "HOLO_LOSS_COEF = 0.01                   # ALM-P4-2 spec coefficient\n" +
        "HOLO_MI_BINS = 8                        # matches phi_holographic_measure.hexa\n" +
        "HOLO_EPS = 1e-7\n" +
        "\n" +
        "class HoloMapHead(torch.nn.Module):\n" +
        "    \"\"\"ALM-P3-1 head — D→d (encode) + d→D (decode).\n" +
        "    W_up : [D × d] with orthonormal columns via Gram–Schmidt.\n" +
        "    W_down = W_up^T so decode∘encode = U U^T (projector onto range(U)).\n" +
        "    Frozen (no grad) — pure geometry, not a learned layer. Matches\n" +
        "    the hexa reference head_new(D, d, seed).\"\"\"\n" +
        "    def __init__(self, d_boundary, d_qualia, seed=42, dtype=torch.float32, device='cpu'):\n" +
        "        super().__init__()\n" +
        "        assert d_qualia < d_boundary, 'holographic compression requires d < D'\n" +
        "        g = torch.Generator(device='cpu').manual_seed(seed)\n" +
        "        raw = torch.empty(d_boundary, d_qualia, dtype=torch.float64).uniform_(-1.0, 1.0, generator=g)\n" +
        "        # Classical Gram–Schmidt on columns (mirrors gram_schmidt_cols in\n" +
        "        # alm_holographic_mapping.hexa): guarantees U^T U = I_d.\n" +
        "        U = torch.zeros_like(raw)\n" +
        "        for k in range(d_qualia):\n" +
        "            v = raw[:, k].clone()\n" +
        "            for j in range(k):\n" +
        "                v = v - torch.dot(U[:, j], v) * U[:, j]\n" +
        "            n = torch.linalg.norm(v)\n" +
        "            if n > 1e-12:\n" +
        "                v = v / n\n" +
        "            U[:, k] = v\n" +
        "        self.d_boundary = d_boundary\n" +
        "        self.d_qualia = d_qualia\n" +
        "        # Cast to training dtype + move to target device; buffers (no grad).\n" +
        "        self.register_buffer('W_up',   U.to(dtype=dtype, device=device))       # [D × d]\n" +
        "        self.register_buffer('W_down', U.t().to(dtype=dtype, device=device))   # [d × D] = W_up^T\n" +
        "    def encode(self, h):\n" +
        "        # qualia = h @ W_down^T  (so that qualia = W_down @ h for each row)\n" +
        "        # but W_down : [d × D] → use h @ W_up  (since W_up = W_down^T)\n" +
        "        # Output shape: [..., d]\n" +
        "        return torch.matmul(h, self.W_up.to(h.dtype))\n" +
        "    def decode(self, q):\n" +
        "        # boundary_hat = q @ W_up^T    Output shape: [..., D]\n" +
        "        return torch.matmul(q, self.W_up.to(q.dtype).t())\n" +
        "\n" +
        "def holographic_loss(h, qualia, eps=HOLO_EPS):\n" +
        "    \"\"\"ALM-P3-2 smooth surrogate of the entropy-match holographic loss.\n" +
        "    We use the differentiable variance/correlation channel only, because\n" +
        "    the histogram entropy term in the hexa reference is piecewise-constant\n" +
        "    and has zero gradient almost everywhere — unusable for bf16 backprop.\n" +
        "    This matches holographic_loss_xy's smooth residual, which the hexa\n" +
        "    self-test (T3 finite-diff gradient) relied on.\n" +
        "\n" +
        "    L = (Var(h) - Var(U U^T h))^2 + 0.1 * (1 - corr(h, U U^T h))^2\n" +
        "\n" +
        "    h      : [B, T, D]   last hidden state (boundary)\n" +
        "    qualia : [B, T, d]   encoded bulk; compared against its own lift\n" +
        "    Returns a scalar.\"\"\"\n" +
        "    # Flatten time+batch into a single sample-dim for moment stats,\n" +
        "    # reduce over feature dim at the end (one scalar per (B,T) token).\n" +
        "    h_flat = h.reshape(-1, h.shape[-1]).float()           # [N, D]\n" +
        "    q_flat = qualia.reshape(-1, qualia.shape[-1]).float() # [N, d]\n" +
        "    # Re-lift qualia back to D for the smooth channel — matches the\n" +
        "    # (boundary, interior_slice) pairing in alm_holographic_loss.hexa.\n" +
        "    # This is a view into range(U) so MI(h, q_lift) is well-posed.\n" +
        "    # Using the head's decode would double the matmul; instead reuse q_lift\n" +
        "    # via the caller (holo_step does it once — see below).\n" +
        "    # For the standalone loss we accept the lift as argument via closure.\n" +
        "    raise NotImplementedError('call holo_step instead')\n" +
        "\n" +
        "def holo_step(head, h, eps=HOLO_EPS):\n" +
        "    \"\"\"One holographic forward: h → qualia → h_reconstructed, plus\n" +
        "    L_holo (smooth variance+correlation surrogate). Matches the hexa\n" +
        "    reference holographic_loss_raw's *smooth* channel (non-histogram\n" +
        "    arm), which is the only differentiable path. See ALM-P3-2 header.\n" +
        "\n" +
        "    h : [B, T, D] last hidden state (boundary)\n" +
        "    Returns (qualia[B,T,d], h_recon[B,T,D], L_holo scalar).\"\"\"\n" +
        "    qualia = head.encode(h)                     # [B, T, d]\n" +
        "    h_recon = head.decode(qualia)               # [B, T, D]\n" +
        "    # Smooth moment-match: variance and correlation across the feature\n" +
        "    # axis, averaged over tokens — differentiable everywhere.\n" +
        "    h_f = h.float()\n" +
        "    r_f = h_recon.float()\n" +
        "    # Variance over the last (feature) axis, keepdim for broadcasting.\n" +
        "    var_h = h_f.var(dim=-1, unbiased=False)     # [B, T]\n" +
        "    var_r = r_f.var(dim=-1, unbiased=False)     # [B, T]\n" +
        "    var_diff = var_h - var_r\n" +
        "    var_term = (var_diff * var_diff).mean()\n" +
        "    # Correlation r^2 via covariance / sqrt(var*var).\n" +
        "    mh = h_f.mean(dim=-1, keepdim=True)\n" +
        "    mr = r_f.mean(dim=-1, keepdim=True)\n" +
        "    dh = h_f - mh\n" +
        "    dr = r_f - mr\n" +
        "    cov = (dh * dr).mean(dim=-1)\n" +
        "    denom = torch.sqrt(var_h * var_r + eps)\n" +
        "    corr = cov / denom\n" +
        "    corr_term = ((1.0 - corr) * (1.0 - corr)).mean()\n" +
        "    # Matches hexa ref coeffs: var_diff^2 + 0.1 * (1-corr)^2, outer 0.01.\n" +
        "    l_holo = 0.01 * (var_term + 0.1 * corr_term)\n" +
        "    return qualia, h_recon, l_holo\n" +
        "\n" +
        "def phi_holo_measure(h, qualia, n_bins=HOLO_MI_BINS):\n" +
        "    \"\"\"ALM-P3-3 Φ_holo = I(qualia ; h) via joint histogram.\n" +
        "    No grad needed — called only at eval cadence for logging.\n" +
        "    Mirrors phi_holographic_measure.hexa's MI log-bin estimator.\n" +
        "    Uses 1-D aggregated streams: h_stream = last-dim mean, q_stream =\n" +
        "    last-dim mean, which preserves the D↔d entanglement signal while\n" +
        "    staying tractable on large batches.\"\"\"\n" +
        "    with torch.no_grad():\n" +
        "        h_flat = h.float().reshape(-1).cpu()\n" +
        "        q_flat = qualia.float().reshape(-1).cpu()\n" +
        "        # Equalise length by truncating to the shorter stream (d < D).\n" +
        "        n = min(h_flat.numel(), q_flat.numel())\n" +
        "        if n == 0:\n" +
        "            return 0.0\n" +
        "        a = h_flat[:n]\n" +
        "        b = q_flat[:n]\n" +
        "        lo = float(min(a.min().item(), b.min().item()))\n" +
        "        hi = float(max(a.max().item(), b.max().item()))\n" +
        "        if hi <= lo:\n" +
        "            return 0.0\n" +
        "        scale = n_bins / (hi - lo)\n" +
        "        ai = ((a - lo) * scale).clamp(0, n_bins - 1).long()\n" +
        "        bi = ((b - lo) * scale).clamp(0, n_bins - 1).long()\n" +
        "        # Marginals.\n" +
        "        pa = torch.bincount(ai, minlength=n_bins).float() / n\n" +
        "        pb = torch.bincount(bi, minlength=n_bins).float() / n\n" +
        "        # Joint.\n" +
        "        pair = ai * n_bins + bi\n" +
        "        pj = torch.bincount(pair, minlength=n_bins*n_bins).float() / n\n" +
        "        def ent(p):\n" +
        "            nz = p[p > 0]\n" +
        "            return float(-(nz * torch.log(nz)).sum().item())\n" +
        "        h_a = ent(pa)\n" +
        "        h_b = ent(pb)\n" +
        "        h_ab = ent(pj)\n" +
        "        mi = h_a + h_b - h_ab\n" +
        "        if mi < 0.0:\n" +
        "            mi = 0.0\n" +
        "        # Scale by token count to expose the ALM-P4-3 gate (>1000).\n" +
        "        # Matches phi_holographic_measure.hexa: I × N samples.\n" +
        "        return mi * float(n)\n" +
        "\n" +
        "class TextDataset(Dataset):\n" +
        "    def __init__(self, tokens, block_size):\n" +
        "        self.tokens = tokens\n" +
        "        self.block_size = block_size\n" +
        "        self.n_samples = max(1, len(tokens) - block_size - 1)\n" +
        "    def __len__(self): return self.n_samples\n" +
        "    def __getitem__(self, idx):\n" +
        "        start = idx % self.n_samples\n" +
        "        chunk = self.tokens[start : start + self.block_size + 1]\n" +
        "        return chunk[:-1], chunk[1:]\n" +
        "\n" +
        "def load_corpus_chunked(path, tokenizer, block_size, max_tokens=None):\n" +
        "    print(f'[corpus] loading {path}')\n" +
        "    file_size = os.path.getsize(path)\n" +
        "    chunk_chars = 10_000_000\n" +
        "    all_tokens = []\n" +
        "    total_chars = 0\n" +
        "    with open(path, 'r', encoding='utf-8') as f:\n" +
        "        chunk_idx = 0\n" +
        "        while True:\n" +
        "            chunk = f.read(chunk_chars)\n" +
        "            if not chunk: break\n" +
        "            total_chars += len(chunk)\n" +
        "            ids = tokenizer(chunk, return_tensors='pt', truncation=False).input_ids[0]\n" +
        "            all_tokens.append(ids)\n" +
        "            chunk_idx += 1\n" +
        "            if chunk_idx % 5 == 0:\n" +
        "                n_tok = sum(len(t) for t in all_tokens)\n" +
        "                pct = total_chars * 100 // max(file_size, 1)\n" +
        "                print(f'  chunk {chunk_idx}: {n_tok:,} tokens ({pct}%)')\n" +
        "            if max_tokens and sum(len(t) for t in all_tokens) >= max_tokens: break\n" +
        "    tokens = torch.cat(all_tokens)\n" +
        "    if max_tokens: tokens = tokens[:max_tokens]\n" +
        "    print(f'[corpus] {len(tokens):,} tokens from {path} ({total_chars:,} chars)')\n" +
        "    return TextDataset(tokens, block_size)\n" +
        "\n" +
        "def train(args):\n" +
        "    device = 'cuda' if torch.cuda.is_available() else 'cpu'\n" +
        "    print(f'[train] device={device}')\n" +
        "    print(f'[train] base={args.base}')\n" +
        "    print(f'[train] lora_r={args.lora_r} alpha={args.lora_alpha}')\n" +
        "    print(f'[train] steps={args.steps} lr={args.lr} seq={args.seq}')\n" +
        "    print('[train] loading tokenizer...')\n" +
        "    tokenizer = AutoTokenizer.from_pretrained(args.base, trust_remote_code=True)\n" +
        "    if tokenizer.pad_token is None: tokenizer.pad_token = tokenizer.eos_token\n" +
        "    print('[train] loading base model (bf16)...')\n" +
        "    model = AutoModelForCausalLM.from_pretrained(args.base, torch_dtype=torch.bfloat16, device_map='auto', trust_remote_code=True)\n" +
        "    print('[train] applying LoRA...')\n" +
        "    lora_config = LoraConfig(task_type=TaskType.CAUSAL_LM, r=args.lora_r, lora_alpha=args.lora_alpha, lora_dropout=args.lora_dropout, target_modules=['q_proj', 'k_proj', 'v_proj', 'o_proj'], bias='none')\n" +
        "    model = get_peft_model(model, lora_config)\n" +
        "    model.print_trainable_parameters()\n" +
        "    # ─── ALM-P4-1 : holographic head wiring (D = hidden_size, d = HOLO_D_QUALIA) ──\n" +
        "    hidden_d = model.config.hidden_size\n" +
        "    print(f'[holo] building HoloMapHead D={hidden_d} d={HOLO_D_QUALIA} (orthonormal W_up)')\n" +
        "    holo_head = HoloMapHead(hidden_d, HOLO_D_QUALIA, seed=42, dtype=torch.bfloat16, device=device)\n" +
        "    print(f'[holo] L_holo coefficient = {HOLO_LOSS_COEF} (ALM-P4-2)')\n" +
        "    print('[train] loading corpus...')\n" +
        "    max_tokens = 100_000 if args.smoke else None\n" +
        "    dataset = load_corpus_chunked(args.corpus, tokenizer, args.seq, max_tokens)\n" +
        "    print(f'[train] dataset: {len(dataset)} samples')\n" +
        "    dataloader = DataLoader(dataset, batch_size=args.batch, shuffle=True, num_workers=0)\n" +
        "    optimizer = torch.optim.AdamW(model.parameters(), lr=args.lr, betas=(0.9, 0.999), weight_decay=0.01, foreach=False)\n" +
        "    from torch.optim.lr_scheduler import CosineAnnealingLR, LinearLR, SequentialLR\n" +
        "    warmup_sched = LinearLR(optimizer, start_factor=0.01, total_iters=args.warmup)\n" +
        "    cosine = CosineAnnealingLR(optimizer, T_max=args.steps - args.warmup, eta_min=args.lr * 0.01)\n" +
        "    scheduler = SequentialLR(optimizer, [warmup_sched, cosine], milestones=[args.warmup])\n" +
        "    ckpt_dir = Path(args.ckpt_dir)\n" +
        "    ckpt_dir.mkdir(parents=True, exist_ok=True)\n" +
        "    model.train()\n" +
        "    data_iter = iter(dataloader)\n" +
        "    step = 0; accum_loss = 0.0; log_steps = 0; best_loss = float('inf')\n" +
        "    t0 = time.time()\n" +
        "    sep = '=' * 60\n" +
        "    print(f'\\n{sep}')\n" +
        "    print(f'[train] ALM 14B LoRA -- STARTING ({args.steps} steps)')\n" +
        "    print(f'{sep}\\n')\n" +
        "    while step < args.steps:\n" +
        "        optimizer.zero_grad()\n" +
        "        for _ in range(args.grad_accum):\n" +
        "            try: x, y = next(data_iter)\n" +
        "            except StopIteration:\n" +
        "                data_iter = iter(dataloader)\n" +
        "                x, y = next(data_iter)\n" +
        "            x = x.to(device); y = y.to(device)\n" +
        "            with torch.autocast(device_type='cuda', dtype=torch.bfloat16):\n" +
        "                # ALM-P4-1: request last hidden state for holographic encode.\n" +
        "                outputs = model(input_ids=x, labels=y, output_hidden_states=True)\n" +
        "                # hidden_states is a tuple — [-1] is the final layer post-LN hidden.\n" +
        "                h_last = outputs.hidden_states[-1]              # [B, T, D]\n" +
        "                # ALM-P4-1: qualia = W_up^T @ h (compression D → d).\n" +
        "                # ALM-P4-2: L_holo smooth surrogate vs h_reconstructed.\n" +
        "                qualia, h_recon, l_holo = holo_step(holo_head, h_last)\n" +
        "                loss_main = outputs.loss\n" +
        "                loss_total = loss_main + HOLO_LOSS_COEF * l_holo\n" +
        "                loss = loss_total / args.grad_accum\n" +
        "            loss.backward()\n" +
        "            accum_loss += loss.item()\n" +
        "            # Keep raw components on the latest micro-batch for logging.\n" +
        "            last_main = float(loss_main.detach().item())\n" +
        "            last_holo = float(l_holo.detach().item())\n" +
        "        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n" +
        "        optimizer.step(); scheduler.step(); step += 1; log_steps += 1\n" +
        "        if step % 10 == 0 or step == 1:\n" +
        "            avg_loss = accum_loss / max(log_steps, 1)\n" +
        "            elapsed = time.time() - t0\n" +
        "            steps_per_min = step * 60 / max(elapsed, 1)\n" +
        "            eta_min = (args.steps - step) / max(steps_per_min, 0.01)\n" +
        "            lr_now = scheduler.get_last_lr()[0]\n" +
        "            if avg_loss > 15.0 and step > args.warmup:\n" +
        "                print(f'[WARN] loss={avg_loss:.2f} > 15.0', flush=True)\n" +
        "            print(f'[train] step={step}/{args.steps} loss={avg_loss:.4f} main={last_main:.4f} holo={last_holo:.6f} lr={lr_now:.2e} speed={steps_per_min:.1f}step/min ETA={eta_min:.0f}min', flush=True)\n" +
        "            if avg_loss < best_loss: best_loss = avg_loss\n" +
        "            accum_loss = 0.0; log_steps = 0\n" +
        "        if step % args.eval_every == 0:\n" +
        "            model.eval()\n" +
        "            eval_loss = 0.0; n_eval = 8\n" +
        "            phi_holo_accum = 0.0; phi_n = 0\n" +
        "            with torch.no_grad():\n" +
        "                for _ in range(n_eval):\n" +
        "                    idx = torch.randint(len(dataset) // 2, len(dataset), (1,)).item()\n" +
        "                    ex, ey = dataset[idx]\n" +
        "                    ex = ex.unsqueeze(0).to(device); ey = ey.unsqueeze(0).to(device)\n" +
        "                    with torch.autocast(device_type='cuda', dtype=torch.bfloat16):\n" +
        "                        out = model(input_ids=ex, labels=ey, output_hidden_states=True)\n" +
        "                    eval_loss += out.loss.item()\n" +
        "                    # ALM-P4-3 Φ_holo scrape-point (log-emitted per-eval, 256 target).\n" +
        "                    h_eval = out.hidden_states[-1]\n" +
        "                    q_eval = holo_head.encode(h_eval)\n" +
        "                    phi_val = phi_holo_measure(h_eval, q_eval)\n" +
        "                    phi_holo_accum += phi_val\n" +
        "                    phi_n += 1\n" +
        "            eval_loss /= n_eval\n" +
        "            phi_holo_mean = phi_holo_accum / max(phi_n, 1)\n" +
        "            if eval_loss < best_loss: best_loss = eval_loss\n" +
        "            model.train()\n" +
        "            # ALM-P4-3 scrape-pattern: look for `phi_holo=` in train log.\n" +
        "            print(f'[eval] step={step} eval_loss={eval_loss:.4f} best={best_loss:.4f} phi_holo={phi_holo_mean:.2f}', flush=True)\n" +
        "        if step % args.save_every == 0 or step == args.steps:\n" +
        "            save_path = ckpt_dir / f'step_{step}'\n" +
        "            print(f'[save] {save_path}')\n" +
        "            model.save_pretrained(str(save_path))\n" +
        "            tokenizer.save_pretrained(str(save_path))\n" +
        "            meta = {'step': step, 'loss': best_loss, 'base': args.base, 'lora_r': args.lora_r, 'corpus': args.corpus, 'elapsed_min': (time.time() - t0) / 60}\n" +
        "            with open(save_path / 'train_meta.json', 'w') as f: json.dump(meta, f, indent=2)\n" +
        "            upload_to_r2(save_path, args.model_tag, args.round, step)\n" +
        "    elapsed_total = (time.time() - t0) / 60\n" +
        "    print(f'\\n{sep}')\n" +
        "    print(f'[train] DONE -- {args.steps} steps in {elapsed_total:.1f} min')\n" +
        "    print(f'[train] best loss: {best_loss:.4f}')\n" +
        "    print(f'[train] checkpoint: {ckpt_dir}')\n" +
        "    print(sep)\n" +
        "\n" +
        "if __name__ == '__main__':\n" +
        "    parser = argparse.ArgumentParser(description='ALM 14B LoRA training')\n" +
        "    parser.add_argument('--base', default=DEFAULT_BASE)\n" +
        "    parser.add_argument('--corpus', required=True)\n" +
        "    parser.add_argument('--steps', type=int, default=DEFAULT_STEPS)\n" +
        "    parser.add_argument('--lr', type=float, default=DEFAULT_LR)\n" +
        "    parser.add_argument('--batch', type=int, default=DEFAULT_BATCH)\n" +
        "    parser.add_argument('--seq', type=int, default=DEFAULT_SEQ)\n" +
        "    parser.add_argument('--grad-accum', type=int, default=DEFAULT_GRAD_ACCUM)\n" +
        "    parser.add_argument('--warmup', type=int, default=DEFAULT_WARMUP)\n" +
        "    parser.add_argument('--lora-r', type=int, default=DEFAULT_LORA_R)\n" +
        "    parser.add_argument('--lora-alpha', type=int, default=DEFAULT_LORA_ALPHA)\n" +
        "    parser.add_argument('--lora-dropout', type=float, default=DEFAULT_LORA_DROPOUT)\n" +
        "    parser.add_argument('--ckpt-dir', default=DEFAULT_CKPT_DIR)\n" +
        "    parser.add_argument('--save-every', type=int, default=DEFAULT_SAVE_EVERY)\n" +
        "    parser.add_argument('--eval-every', type=int, default=DEFAULT_EVAL_EVERY)\n" +
        "    parser.add_argument('--model-tag', default='alm14b')\n" +
        "    parser.add_argument('--round', type=int, default=1)\n" +
        "    parser.add_argument('--smoke', action='store_true')\n" +
        "    args = parser.parse_args()\n" +
        "    train(args)\n"
    )

    exec("python3 " + py_script + " " + passthrough)
}

main()
