//                     train_alm_lora.hexa::init_lora_A/init_lora_B.
//                 (3) CLM xref: none — CLM is from-scratch, no LoRA path.
fn lora_adapter_new(rank: int, alpha: int, d_model: int) -> LoraAdapter {
    return LoraAdapter {
        rank: rank,
        alpha: alpha,
        n_adapters: N_LORA_TARGETS * QWEN14B_N_LAYER,
        d_model: d_model
    }
}

