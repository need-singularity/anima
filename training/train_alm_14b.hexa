// ═══════════════════════════════════════════════════════════════════════
// §10  EVAL (5 metrics stub)
// ═══════════════════════════════════════════════════════════════════════

// Evaluation returning 5 metrics. Pack as [float] array (dodges >=3-float
// struct-return corruption).
//   TODO[pytorch] (1) eval_animalm.py: PPL, gen_quality, consciousness_T,
//                     korean_ratio, instr_follow
//                 (2) FFI needed: hxqwen14b_eval_ppl(h, ids) for PPL; pure
//                     hexa char-class counting for korean_ratio; judge
//                     rubric (hire_sim pattern) for instr_follow — hexa ok
//                     once corpus reader lands.
//                 (3) CLM xref: train_clm.hexa has eval_step but only CE/PPL;
//                     ALM's 5-metric gate is ALM-specific.
fn alm14b_eval(model: Alm14bModel, adapter: LoraAdapter) -> array {
    // Return [ppl, gen_q, T, kr, if]. Sentinel zeros — real impl TODO.
    let mut out = []
    out = out.push(0.0)    // perplexity
    out = out.push(0.0)    // gen_quality
    out = out.push(0.0)    // consciousness_T
    out = out.push(0.0)    // korean_ratio
    out = out.push(0.0)    // instr_follow (0..5)
    return out
}

fn alm14b_eval_pass(ev: array) -> bool {
    let ppl  = ev[0]
    let gen  = ev[1]
    let kr   = ev[3]
    let iflw = ev[4]
    // 5/5 threshold per CLAUDE.md extreme accel — currently all zeros, never passes.
    return ppl > 0.0 && gen >= 0.6 && kr >= 0.3 && iflw >= 4.0
}

// ═══════════════════════════════════════════════════════════════════════
// §11  TRAIN STEP (stub with aux wiring)
// ═══════════════════════════════════════════════════════════════════════

fn alm14b_train_step(state: Alm14bState, cfg: Alm14bConfig,
                     fl: Alm14bFloats) -> Alm14bState {
    let next_step = state.step + 1

    // Phase manager — linear quartile schedule like train_alm.hexa.
    let p1_end = cfg.steps / 4
    let p2_end = cfg.steps / 2
    let next_phase = if next_step < p1_end { ALM_PHASE_P1 }
                     else if next_step < p2_end { ALM_PHASE_P2 }
                     else { ALM_PHASE_P3 }

    // Aux diagnostics — observable to launcher even without real compute.
    // Use best_ce as loss proxy; scales with training progress.
    let loss_proxy = if state.best_ce < 999999.0 { state.best_ce } else { 5.5 }
    let tension_proxy = PSI_ALPHA * (1.0 + next_phase + 0.0)

    if G_SW_USE_QC == 1 {
        let psi_res  = loss_proxy * 0.1
        G_SW_LAST_QC_LOSS   = _qc_loss(psi_res, 0.5, 1.0, 6.0)
        G_SW_LAST_4AXIS_DEV = _fabs(psi_res) + 0.0
    }
    if G_SW_USE_TL == 1 {
        G_SW_LAST_TL_DW_NORM = _fabs(tension_proxy) * 0.1
        if G_SW_USE_GHOLO == 1 {
            G_SW_LAST_GHOLO_NORM = _sqrt_safe(G_SW_LAST_TL_DW_NORM) * 0.5
        }
    }
    if G_SW_USE_LENS == 1 {
        let every = G_SW_LENS_EVERY
        let sample = if every <= 0 { true } else { next_step % every == 0 }
        if sample {
            G_SW_LAST_LENS_GATE = if loss_proxy < 100.0 { 1 } else { 0 }
        }
    }
    if G_SW_USE_TIER == 1 {
        G_SW_LAST_TIER_MAX_K = _tier_max_k(next_step, cfg.steps)
    }
    if G_SW_USE_SUMT == 1 {
        G_SW_LAST_SUMT_STAGE = _sumt_stage(next_step, cfg.steps)
    }

    // TODO[FFI forward + backward + adamw_step] — real body here on Day-2.
    // For selftest / dry-run, advance step counters only.
    return Alm14bState {
        step: next_step,
        phase: next_phase,
        best_ce: state.best_ce,
        patience_left: state.patience_left
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §12  ROUND DISPATCH — r5 / r9 / r10[bcd] / r11 historical selection
// ═══════════════════════════════════════════════════════════════════════
//
// Each round has its own (base_ckpt, lr, steps, lora_r, lora_alpha) tuple
// encoded here so one binary can replace all the stubbed launch_*.hexa.
// Real execution still delegates to train_alm_lora.hexa (r11) or FFI (future
// r-series). This fn only emits the intended config so it's observable.

fn round_config(round: string) -> Alm14bConfig {
    let mut cfg = default_config()
    if round == "r5" {
        // r5 from-scratch LoRA r=16 on Qwen base.
        cfg = Alm14bConfig {
            round: "r5", base: cfg.base, corpus: cfg.corpus, out: cfg.out,
            steps: 10000, warmup: 200, batch: 1, seq: 1024, grad_accum: 8,
            lora_r: 16, lora_alpha: 32, save_every: 2000, eval_every: 500,
            patience: 5, dry_run: cfg.dry_run
        }
    } else if round == "r9" {
        // r9 — a2_tool_mixed base (mode collapse per project_r9_mode_collapse).
        cfg = Alm14bConfig {
            round: "r9", base: "/runpod/ckpt_a2_tool_mixed",
            corpus: cfg.corpus, out: "/workspace/ckpt_r9",
            steps: 2000, warmup: 100, batch: 2, seq: 1024, grad_accum: 8,
            lora_r: 16, lora_alpha: 32, save_every: 500, eval_every: 250,
            patience: 5, dry_run: cfg.dry_run
        }
    } else if round == "r10" || round == "r10b" || round == "r10c" || round == "r10d" {
        // r10-series — r9 base, divergence recovery attempts.
        cfg = Alm14bConfig {
            round: round, base: "/runpod/ckpt_r9",
            corpus: cfg.corpus, out: "/workspace/ckpt_" + round,
            steps: 1500, warmup: 100, batch: 2, seq: 1024, grad_accum: 8,
            lora_r: 16, lora_alpha: 32, save_every: 300, eval_every: 150,
            patience: 5, dry_run: cfg.dry_run
        }
    }
    // Default = r11 (plan defaults already in default_config()).
    return cfg
}

// ═══════════════════════════════════════════════════════════════════════
// §13  CLI PARSING (module-scope)
// ═══════════════════════════════════════════════════════════════════════

let _argv_full = args()
let _argv_n = len(_argv_full)
let mut _argv = []
let mut _argv_i = 2                                 // skip binary + self-ref
while _argv_i < _argv_n {
    _argv = _argv.push(_argv_full[_argv_i])
    _argv_i = _argv_i + 1
}

// Aux flag wiring — matches train_alm.hexa:479-490 and train_clm.hexa:3115-3128.
if _cli_has_flag(_argv, "--use-quadruple-cross") { G_SW_USE_QC = 1 }
if _cli_has_flag(_argv, "--use-tension-link")    { G_SW_USE_TL = 1 }
if _cli_has_flag(_argv, "--use-lens-diag")       { G_SW_USE_LENS = 1 }
if _cli_has_flag(_argv, "--use-tier-curriculum") { G_SW_USE_TIER = 1 }
if _cli_has_flag(_argv, "--use-sumt-stages")     { G_SW_USE_SUMT = 1 }
if _cli_has_flag(_argv, "--use-g-holo")          { G_SW_USE_GHOLO = 1 }
if _cli_has_flag(_argv, "--use-a6-gate")         { G_SW_USE_A6GATE = 1 }

G_SW_LAMBDA_QC     = to_float(_cli_flag_value(_argv, "--lambda-qc", "0.01"))
G_SW_LENS_EVERY    = to_int(_cli_flag_value(_argv, "--lens-diag-every", "500"))
G_SW_TIER_SCHEDULE = _cli_flag_value(_argv, "--tier-curriculum-schedule", "linear")
G_SW_TIER_PATH     = _cli_flag_value(_argv, "--tier-labels", "training/corpus_universe_tier_labels.jsonl")

// Round selector + training-mode trigger.
let _round_arg    = _cli_flag_value(_argv, "--round", "r11")
let _selftest     = _cli_has_flag(_argv, "--selftest")
let _train_mode   = _cli_has_flag(_argv, "--corpus")
                    || _cli_has_flag(_argv, "--steps")
                    || _cli_has_flag(_argv, "--ckpt-dir")

let _cfg_sel = round_config(_round_arg)

