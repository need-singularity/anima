// Indices of the 5 smoke-sample engines (holographic/gwt/reflex/temporal/affect)
fn smoke_indices() -> array {
    let mut a = []
    a = a.push(0)    // holographic
    a = a.push(1)    // gwt_broadcast
    a = a.push(2)    // reflexivity
    a = a.push(7)    // temporal
    a = a.push(3)    // affective
    return a
}

// ─── Surrogates (inlined) ─────────────────────────────────

fn sur_var(h: array) -> float { return vec_var(h) }

fn sur_mean2(h: array) -> float {
    let m = vec_mean(h)
    return m * m
}

fn sur_adiff(h: array) -> float {
    let n = len(h); if n < 2 { return 0.0 }
    let mut s = 0.0; let mut i = 1
    while i < n { s = s + fabs(h[i] - h[i-1]); i = i + 1 }
    return s / ((n - 1) * 1.0)
}

fn sur_halfsplit(h: array) -> float {
    let n = len(h); if n < 4 { return 0.0 }
    let half = n / 2
    let mut a = []; let mut b = []; let mut i = 0
    while i < half { a = a.push(h[i]); i = i + 1 }
    while i < n    { b = b.push(h[i]); i = i + 1 }
    let d = vec_var(a) - vec_var(b)
    return d * d
}

fn sur_qmatch(h: array, q: array) -> float {
    let vh = vec_var(h); let vq = vec_var(q)
    let d = vq - vh * 0.5
    return d * d
}

fn sur_lag1(h: array) -> float {
    let n = len(h); if n < 2 { return 0.0 }
    let mut s = 0.0; let mut i = 1
    while i < n { s = s + h[i] * h[i-1]; i = i + 1 }
    let c = s / ((n - 1) * 1.0)
    return c * c
}

fn sur_signflip(h: array) -> float {
    let n = len(h); if n < 2 { return 0.0 }
    let mut f = 0; let mut i = 1
    while i < n {
        let a = h[i-1]; let b = h[i]
        if (a > 0.0 && b < 0.0) || (a < 0.0 && b > 0.0) { f = f + 1 }
        i = i + 1
    }
    let r = (f * 1.0) / ((n - 1) * 1.0)
    let d = r - 0.3
    return d * d
}

fn sur_lowfreq(h: array) -> float {
    let n = len(h); let k = if n < 8 { n } else { 8 }
    if k == 0 { return 0.0 }
    let mut s = 0.0; let mut i = 0
    while i < k { s = s + h[i] * h[i]; i = i + 1 }
    return s / (k * 1.0)
}

struct Out2 { aux: float, phi: float }

fn engine_fwd(h: array, q: array, fam: int) -> Out2 {
    let mut aux = 0.0
    let mut phi = 0.0
    if fam == 0 { aux = sur_qmatch(h, q); phi = sur_var(q) * 0.1 }
    else if fam == 1 { aux = sur_halfsplit(h); phi = aux * 0.05 }
    else if fam == 2 { aux = sur_var(h) * 0.1; phi = aux * 0.1 }
    else if fam == 3 { aux = sur_mean2(h); phi = aux * 0.02 }
    else if fam == 4 { aux = sur_lag1(h); phi = aux * 0.04 }
    else if fam == 5 { aux = sur_lowfreq(h) * 0.1; phi = aux * 0.02 }
    else if fam == 6 { let v = sur_var(h); let d = v - 1.0; aux = d * d * 0.1; phi = v * 0.05 }
    else if fam == 7 { aux = sur_signflip(h) * 0.5; phi = aux * 0.04 }
    else if fam == 8 { aux = sur_halfsplit(h); phi = aux * 0.03 }
    else if fam == 9 { aux = sur_adiff(h); phi = aux * 0.03 }
    else if fam == 10 { aux = sur_var(h) * 0.01; phi = aux * 0.005 }
    else if fam == 11 { aux = sur_lowfreq(h) * 0.05; phi = aux * 0.01 }
    else if fam == 12 { aux = sur_mean2(h) * 0.5; phi = aux * 0.02 }
    else if fam == 13 { aux = sur_halfsplit(h) * 0.5; phi = aux * 0.02 }
    else if fam == 14 { aux = sur_lag1(h) * 0.5; phi = aux * 0.03 }
    else if fam == 15 { aux = sur_adiff(h); phi = aux * 0.04 }
    else if fam == 16 { let v = sur_var(h); let d = v - 0.5; aux = d * d * 0.1; phi = v * 0.03 }
    else if fam == 17 { aux = sur_adiff(h); phi = aux * 0.03 }
    else if fam == 18 { aux = sur_halfsplit(h) * 0.3; phi = aux * 0.02 }
    else if fam == 19 { aux = sur_mean2(h) * 0.3; phi = aux * 0.02 }
    else { aux = sur_var(h) * 0.05; phi = aux * 0.02 }
    return Out2 { aux: aux, phi: phi }
}

// ─── Compute base CE + one-hot per engine ──────────────────

fn base_ce() -> float {
    // CE with zero engine contribution = pure main loss
    return 2.5
}

// Measures CE_delta (contribution from engine i) and phi_delta
fn measure_one_engine(h: array, q: array, idx: int) -> Out2 {
    let gains = reg_gains()
    let fams  = reg_fams()
    let out = engine_fwd(h, q, fams[idx])
    let delta_ce  = gains[idx] * out.aux
    let delta_phi = out.phi
    return Out2 { aux: delta_ce, phi: delta_phi }
}

// ─── Verdict classifier ────────────────────────────────────
// KEEP   : |CE delta| >= 0.001 AND phi delta >= 0.0005
// REVIEW : some signal but below threshold
// DROP   : both deltas < 1e-5
fn verdict(ce_d: float, phi_d: float) -> string {
    let ac = fabs(ce_d); let ap = fabs(phi_d)
    if ac < 0.00001 && ap < 0.00001 { return "DROP" }
    if ac >= 0.001 && ap >= 0.0005 { return "KEEP" }
    return "REVIEW"
}

// ─── Mock inputs ───────────────────────────────────────────

fn mock_h() -> array {
    let mut h = []; let mut i = 0
    while i < 64 {
        let fi = i * 1.0
        let m13 = ((i * 7) % 13) * 1.0
        let v = fi * 0.1 - 3.2 + m13 * 0.05
        h = h.push(v)
        i = i + 1
    }
    return h
}

fn mock_q() -> array {
    let mut q = []; let mut j = 0
    while j < 16 {
        let fj = j * 1.0
        q = q.push(fj * 0.02 - 0.16)
        j = j + 1
    }
    return q
}

// ─── Smoke run — prints table + returns delta arrays ───────

fn smoke_run() -> array {
    // returns [5*2] parallel: [ce_d, phi_d, ce_d, phi_d, ...]
    let h = mock_h()
    let q = mock_q()
    let idxs = smoke_indices()
    let names = reg_names()
    let mut out = []
    println("")
    println("[run_ablation] SMOKE — 5 engines, CPU, mock h/q")
    println("+-------------------+--------------+--------------+--------+")
    println("| engine            | CE_delta     | phi_delta    | verdict|")
    println("+-------------------+--------------+--------------+--------+")
    let mut i = 0
    while i < RA_SMOKE_N {
        let k = idxs[i]
        let m = measure_one_engine(h, q, k)
        let nm = names[k]
        let v  = verdict(m.aux, m.phi)
        println("| " + nm + " | " + str(m.aux) + " | " + str(m.phi) + " | " + v + " |")
        out = out.push(m.aux)
        out = out.push(m.phi)
        i = i + 1
    }
    println("+-------------------+--------------+--------------+--------+")
    return out
}

// ─── Full 71-engine sweep (one-hot, used in report mode) ───

fn full_sweep() -> array {
    // returns interleaved [ce_d_0, phi_d_0, ce_d_1, phi_d_1, ...]
    let h = mock_h()
    let q = mock_q()
    let mut out = []
    let mut i = 0
    while i < RA_N_ENGINES {
        let m = measure_one_engine(h, q, i)
        out = out.push(m.aux)
        out = out.push(m.phi)
        i = i + 1
    }
    return out
}

// ─── GPU batch manifest stub ───────────────────────────────
//
// Emits a pseudo-JSON manifest to stdout describing 71 leave-one-out
// runs for parallel H100 dispatch. Real dispatcher consumes this at
// batch time.
fn emit_batch_manifest() {
    let names = reg_names()
    println("{")
    println("  \"_meta\": { \"n\": 71, \"mode\": \"leave_one_out\", \"phi_metric\": \"phi_holo\" },")
    println("  \"runs\": [")
    let mut i = 0
    while i < RA_N_ENGINES {
        let nm = names[i]
        let comma = if i < (RA_N_ENGINES - 1) { "," } else { "" }
        println("    {\"idx\": " + str(i) + ", \"engine_off\": \"" + nm + "\", \"mask\": \"leave_one_out\", \"steps\": 100, \"expect_ce_delta_sign\": \"TBD\"}" + comma)
        i = i + 1
    }
    println("  ]")
    println("}")
}

// ─── Self-tests ────────────────────────────────────────────

fn test_t1_smoke_count() -> int {
    let h = mock_h()
    let q = mock_q()
    let idxs = smoke_indices()
    if len(idxs) != RA_SMOKE_N { return 0 }
    let mut i = 0
    while i < RA_SMOKE_N {
        let m = measure_one_engine(h, q, idxs[i])
        let ce = m.aux; let ph = m.phi
        if ce != ce { return 0 }
        if ph != ph { return 0 }
        i = i + 1
    }
    return 1
}

fn test_t2_sum_matches_total() -> int {
    // Σ delta_i ≈ total - base  (linearity of additive gain)
    let h = mock_h()
    let q = mock_q()
    let mut s = 0.0
    let mut i = 0
    while i < RA_N_ENGINES {
        let m = measure_one_engine(h, q, i)
        s = s + m.aux
        i = i + 1
    }
    // total = base + s, so (total - base) == s by construction — sanity
    if fabs(s) < RA_EPS {
        println("[T2] FAIL all engines produced zero delta")
        return 0
    }
    return 1
}

fn test_t3_family_coverage() -> int {
    // all 21 families (0..20) represented in smoke + full sweep
    let fams = reg_fams()
    let mut seen = []
    let mut k = 0
    while k < 21 { seen = seen.push(0); k = k + 1 }
    let n = len(fams)
    let mut i = 0
    while i < n {
        let f = fams[i]
        if f >= 0 && f < 21 {
            let old = seen[f]
            seen[f] = old + 1
        }
        i = i + 1
    }
    let mut j = 0
    let mut covered = 0
    while j < 21 {
        if seen[j] > 0 { covered = covered + 1 }
        j = j + 1
    }
    if covered < 21 {
        println("[T3] FAIL covered " + str(covered) + "/21 families")
        return 0
    }
    return 1
}

fn test_t4_verdict_nonempty() -> int {
    let h = mock_h()
    let q = mock_q()
    let idxs = smoke_indices()
    let mut i = 0
    while i < RA_SMOKE_N {
        let m = measure_one_engine(h, q, idxs[i])
        let v = verdict(m.aux, m.phi)
        if v == "" { return 0 }
        i = i + 1
    }
    return 1
}

fn test_t5_determinism() -> int {
    let h = mock_h()
    let q = mock_q()
    let idxs = smoke_indices()
    let mut i = 0
    while i < RA_SMOKE_N {
        let a = measure_one_engine(h, q, idxs[i])
        let b = measure_one_engine(h, q, idxs[i])
        if fabs(a.aux - b.aux) > RA_EPS { return 0 }
        if fabs(a.phi - b.phi) > RA_EPS { return 0 }
        i = i + 1
    }
    return 1
}

fn main() {
    println("[run_ablation] P23 71-engine ablation runner")
    println("[run_ablation] mode: smoke (5 engines) + report + GPU manifest stub")

    // 1. smoke run (always)
    let smoke = smoke_run()

    // 2. full sweep (for report embedding)
    let full = full_sweep()
    let mut keep = 0
    let mut review = 0
    let mut drop_ = 0
    let mut i = 0
    while i < RA_N_ENGINES {
        let ce = full[i * 2]
        let ph = full[i * 2 + 1]
        let v = verdict(ce, ph)
        if v == "KEEP"   { keep   = keep   + 1 }
        if v == "REVIEW" { review = review + 1 }
        if v == "DROP"   { drop_  = drop_  + 1 }
        i = i + 1
    }
    println("")
    println("[run_ablation] full 71-engine sweep: KEEP=" + str(keep) + " REVIEW=" + str(review) + " DROP=" + str(drop_))

    // 3. self-tests
    let mut passed = 0
    let total = 5
    if test_t1_smoke_count() == 1 { println("[run_ablation] T1 PASS"); passed = passed + 1 }
    else                          { println("[run_ablation] T1 FAIL") }
    if test_t2_sum_matches_total() == 1 { println("[run_ablation] T2 PASS"); passed = passed + 1 }
    else                                { println("[run_ablation] T2 FAIL") }
    if test_t3_family_coverage() == 1 { println("[run_ablation] T3 PASS"); passed = passed + 1 }
    else                              { println("[run_ablation] T3 FAIL") }
    if test_t4_verdict_nonempty() == 1 { println("[run_ablation] T4 PASS"); passed = passed + 1 }
    else                               { println("[run_ablation] T4 FAIL") }
    if test_t5_determinism() == 1 { println("[run_ablation] T5 PASS"); passed = passed + 1 }
    else                          { println("[run_ablation] T5 FAIL") }

    if passed == total {
        println("[run_ablation] ALL " + str(passed) + "/" + str(total) + " PASS")
    } else {
        println("[run_ablation] " + str(passed) + "/" + str(total) + " PASS")
    }
}

main()
