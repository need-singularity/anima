// training/run_ablation.hexa — P23 71-engine smoke + full-batch ablation runner
//
// PURPOSE:
//   Drive engine_ablation.hexa over the 71-engine catalog with:
//     (a) CPU smoke — 5 sampled engines, one-hot + leave-one-out, prints
//         CE_delta / phi_delta / verdict table.
//     (b) GPU batch stub — emits a JSON manifest of 71 leave-one-out runs
//         ready for parallel dispatch on H100.
//
// Mode:
//   smoke    — 5 engines (holographic, gwt_broadcast, reflexivity, temporal,
//              affective); runs inline, CPU-only, <60s.
//   full     — all 71 engines, produces engine_ablation_report.md + manifest.
//   batch    — emits training/ablation_batch_manifest.json (no execution).
//
// Output:
//   stdout   — ASCII table of CE/phi delta per engine
//   file     — training/engine_ablation_report.md (on --report flag)
//
// Self-contained — duplicates registry + surrogate forward from
// engine_ablation.hexa to dodge hexa 3+ deep-import silent-exit bug.
//
// Theorems (self-test):
//   T1: smoke run returns exactly 5 deltas
//   T2: leave-one-out delta sum ≈ all-on total - base (within 0.5%)
//   T3: family aggregate report covers all 21 families
//   T4: verdict table non-empty for all sampled engines
//   T5: rank-ordering stable across two independent smoke runs (determinism)
//
// Run:
//   $HEXA_LANG/target/release/hexa training/run_ablation.hexa
// Expect:
//   [run_ablation] smoke: 5/5 engines measured
//   [run_ablation] ALL 5/5 PASS

let RA_N_ENGINES = 71
let RA_EPS       = 0.0000001
let RA_SMOKE_N   = 5

// ─── Helpers (dup to avoid deep imports) ───────────────────

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_sum(v: array) -> float {
    let mut s = 0.0; let mut i = 0; let n = len(v)
    while i < n { s = s + v[i]; i = i + 1 }
    return s
}

fn vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    return vec_sum(v) / (n * 1.0)
}

fn vec_var(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let m = vec_mean(v)
    let mut s = 0.0; let mut i = 0
    while i < n { let d = v[i] - m; s = s + d * d; i = i + 1 }
    return s / (n * 1.0)
}

