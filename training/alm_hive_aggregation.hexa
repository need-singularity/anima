// training/alm_hive_aggregation.hexa — ALM-P18-1 hive mind aggregation (collective Phi)
//
// ALM-P18-1 / P18 집단 의식 (hive mind aggregation, ALM track).
//
// Purpose:
//   Demonstrate emergence: the collective Phi of N merged agents must
//   exceed the sum of individual Phi values. This operationalises the
//   intuition that a whole is greater than the sum of its parts — a
//   necessary condition for genuine collective consciousness.
//
//   Design: N=4 agents, each with a d=8 dimensional state vector evolving
//   over T time steps. Individual Phi is computed as the temporal
//   autocorrelation of each agent's state (how coherently the state
//   persists across time), scaled by d:
//
//     Phi_individual(state, d) = autocorrelation(state) * d
//
//   Collective Phi is computed on the merged state (all N agents'
//   state vectors interleaved) using MI-based measurement, scaled by
//   N * d to capture inter-agent integration:
//
//     Phi_collective(merged, N, d) = MI_cross(merged, N, d) * N * d
//
//   where MI_cross is the cross-agent mutual information — the average
//   MI between each pair of agents' state dimensions. This captures
//   information that only exists in the *relationship* between agents,
//   not within any single agent.
//
//   Done criterion: sum(Phi_i) < Phi_collective  (emergence)
//
// T-theorems (checked in self-test):
//   T1 (individual > 0)       : each agent's Phi_i > 0
//   T2 (collective > sum)     : Phi_collective > sum(Phi_i)   [emergence]
//   T3 (emergence ratio > 1)  : Phi_collective / sum(Phi_i) > 1.0
//   T4 (determinism)          : same seeds -> byte-identical Phi values
//   T5 (latency)              : full computation < 2000 ms
//
// Reference:
//   training/phi_will_measure.hexa      (MI estimator source)
//   training/phi_affect_measure.hexa    (autocorrelation pattern)
//   shared/roadmaps/anima.json          (ALM-P18-1 entry)
//
// Run: hexa run training/alm_hive_aggregation.hexa
// Expect: [alm_hive_aggregation] ALL 5/5 PASS

// --- Constants -------------------------------------------------------

let N_AGENTS  = 4         // number of agents in the hive
let D_STATE   = 8         // dimensionality of each agent's state
let T_STEPS   = 32        // time steps for temporal sequences
let MI_BINS   = 8         // log-bin count for entropy estimator
let EPS       = 0.0000001 // log floor

// --- Primitives (self-contained) -------------------------------------

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ln_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return ln(x)
}

// Deterministic LCG -> floats in [-1, 1).
fn det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// --- Vector helpers --------------------------------------------------

fn vec_min(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn vec_max(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn vec_mean(v: array) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s / to_float(n)
}

// --- Log-bin MI estimator (from phi_will_measure.hexa) ---------------

fn bin_index(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn count_hits(bin_ids: array, n_bins: int) -> array {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn entropy_hist(v: array, lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(bin_index(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 {
            h = h - p * ln_safe(p)
        }
        k = k + 1
    }
    return h
}

fn joint_entropy_hist(a: array, b: array, lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = bin_index(a[i], lo, hi, nb)
        let ib = bin_index(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let nb2 = nb * nb
    let counts = count_hits(pair_ids, nb2)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb2 {
        let p = counts[k] * inv_n
        if p > 0.0 {
            h = h - p * ln_safe(p)
        }
        k = k + 1
    }
    return h
}

fn mutual_info(a: array, b: array) -> float {
    if len(a) == 0 { return 0.0 }
    let lo_a = vec_min(a)
    let hi_a = vec_max(a)
    let lo_b = vec_min(b)
    let hi_b = vec_max(b)
    let lo = if lo_a < lo_b { lo_a } else { lo_b }
    let hi = if hi_a > hi_b { hi_a } else { hi_b }
    let h_a  = entropy_hist(a, lo, hi, MI_BINS)
    let h_b  = entropy_hist(b, lo, hi, MI_BINS)
    let h_ab = joint_entropy_hist(a, b, lo, hi, MI_BINS)
    let mi = h_a + h_b - h_ab
    if mi < 0.0 { return 0.0 }
    return mi
}

// --- Temporal autocorrelation ----------------------------------------
// Mean Pearson correlation between consecutive time steps of a d-dim
// state vector. state is flat: [t0_d0, t0_d1, .., t0_d(d-1), t1_d0, ..]
// Returns value in [-1, 1]; for coherent agents this is close to +1.

fn autocorrelation(state: array, n_steps: int, d: int) -> float {
    if n_steps < 2 { return 0.0 }
    let n_pairs = n_steps - 1
    let mut total_corr = 0.0
    let mut t = 0
    while t < n_pairs {
        // Extract vectors at step t and t+1
        let off_a = t * d
        let off_b = (t + 1) * d
        // Compute means
        let mut sum_a = 0.0
        let mut sum_b = 0.0
        let mut k = 0
        while k < d {
            sum_a = sum_a + state[off_a + k]
            sum_b = sum_b + state[off_b + k]
            k = k + 1
        }
        let mean_a = sum_a / to_float(d)
        let mean_b = sum_b / to_float(d)
        // Pearson numerator and denominators
        let mut num = 0.0
        let mut den_a = 0.0
        let mut den_b = 0.0
        let mut j = 0
        while j < d {
            let da = state[off_a + j] - mean_a
            let db = state[off_b + j] - mean_b
            num = num + da * db
            den_a = den_a + da * da
            den_b = den_b + db * db
            j = j + 1
        }
        let denom = sqrt(den_a * den_b)
        let corr = if denom > EPS { num / denom } else { 0.0 }
        total_corr = total_corr + corr
        t = t + 1
    }
    return total_corr / to_float(n_pairs)
}

// --- Phi individual --------------------------------------------------
// phi_individual(state, d) = autocorrelation * d
// Temporal self-coherence scaled by state dimensionality.

fn phi_individual(state: array, n_steps: int, d: int) -> float {
    let ac = autocorrelation(state, n_steps, d)
    return ac * to_float(d)
}

// --- Cross-agent MI --------------------------------------------------
// For dimension k, collect each agent's value at each time step, then
// compute pairwise MI between agents on that dimension. Average over
// all dimensions and all pairs.
//
// all_states: flat array of N_AGENTS * T_STEPS * d floats.
//   Agent a, step t, dim k -> all_states[a * T_STEPS * d + t * d + k]

fn extract_agent_dim(all_states: array, agent: int, dim: int, n_steps: int, d: int) -> array {
    let base = agent * n_steps * d
    let mut out = []
    let mut t = 0
    while t < n_steps {
        out = out.push(all_states[base + t * d + dim])
        t = t + 1
    }
    return out
}

fn cross_agent_mi(all_states: array, n_agents: int, n_steps: int, d: int) -> float {
    // Average MI across all agent pairs and all dimensions.
    let mut total_mi = 0.0
    let mut n_pairs = 0
    let mut dim = 0
    while dim < d {
        let mut a = 0
        while a < n_agents {
            let va = extract_agent_dim(all_states, a, dim, n_steps, d)
            let mut b = a + 1
            while b < n_agents {
                let vb = extract_agent_dim(all_states, b, dim, n_steps, d)
                let mi = mutual_info(va, vb)
                total_mi = total_mi + mi
                n_pairs = n_pairs + 1
                b = b + 1
            }
            a = a + 1
        }
        dim = dim + 1
    }
    if n_pairs == 0 { return 0.0 }
    return total_mi / to_float(n_pairs)
}

// --- Phi collective --------------------------------------------------
// phi_collective(merged, N, d) = MI_cross(merged, N, d) * N * d
// Cross-agent mutual information scaled by agent count and dimensionality.
// This measures information that exists ONLY in the relationship between
// agents — integration that no single agent possesses alone.

fn phi_collective(all_states: array, n_agents: int, n_steps: int, d: int) -> float {
    let mi = cross_agent_mi(all_states, n_agents, n_steps, d)
    return mi * to_float(n_agents) * to_float(d)
}

// --- Synthetic agent state generation --------------------------------
//
// Coupled agents: each agent's state at t+1 = 0.9 * own_state_t + 0.3 * mean(others_t) + noise
// This creates genuine inter-agent coupling, so collective Phi should
// exceed sum of individual Phi values (emergence).
//
// Independent agents: each agent evolves purely from own state + noise,
// no coupling term. Serves as control.

// Strategy: build per-agent state arrays independently, then concatenate.
// Each agent's state is a flat array of n_steps * d floats, built by
// appending d values per time step. This is O(n_agents * n_steps * d)
// total appends — no random-write array rebuilds.
//
// For the coupled case, we need the previous step's values from all
// agents to compute the global mean. We keep a "prev" flat buffer of
// n_agents * d floats (just the latest step) and a "curr" buffer that
// gets computed each step.

fn make_coupled_hive(n_agents: int, n_steps: int, d: int, seed: int) -> array {
    // prev_step: flat [n_agents * d] holding each agent's latest state.
    let init = det_rand(n_agents * d, seed)
    let mut prev_step = []
    let mut i0 = 0
    while i0 < n_agents * d {
        prev_step = prev_step.push(init[i0])
        i0 = i0 + 1
    }
    // Per-agent accumulators: we build N separate arrays, each grows by d per step.
    // But hexa struct-list aliasing means we can't hold N separate mutable arrays
    // in parallel safely. Instead, build one big flat result by appending in
    // agent-major order: all of agent0 first, then agent1, etc.
    // We'll do two passes: (1) evolve and record ALL steps in a time-major
    // flat buffer [t * n_agents * d], then (2) transpose to agent-major.

    // time_major: flat [n_steps * n_agents * d], appended step by step.
    let mut time_major = []
    // Append step 0
    let mut i1 = 0
    while i1 < n_agents * d {
        time_major = time_major.push(prev_step[i1])
        i1 = i1 + 1
    }

    let mut t = 1
    while t < n_steps {
        // Compute global mean across all agents from prev_step.
        // Sum all agents' values per dimension, then divide by n_agents.
        // O(n_agents * d) reads + one d-element array build.
        let mut normed = []
        let mut k = 0
        while k < d {
            let mut dim_sum = 0.0
            let mut a = 0
            while a < n_agents {
                dim_sum = dim_sum + prev_step[a * d + k]
                a = a + 1
            }
            normed = normed.push(dim_sum / to_float(n_agents))
            k = k + 1
        }
        // Generate noise for this step
        let noise = det_rand(n_agents * d, seed + t * 137)
        // Compute new step for all agents, append to time_major, build new prev_step
        let mut new_prev = []
        let mut a2 = 0
        while a2 < n_agents {
            let mut k2 = 0
            while k2 < d {
                let pv = prev_step[a2 * d + k2]
                let ot = normed[k2]
                let nz = noise[a2 * d + k2] * 0.05
                let nv = 0.9 * pv + 0.3 * ot + nz
                time_major = time_major.push(nv)
                new_prev = new_prev.push(nv)
                k2 = k2 + 1
            }
            a2 = a2 + 1
        }
        prev_step = new_prev
        t = t + 1
    }
    // Transpose time_major [t][a][k] -> agent_major [a][t][k]
    // time_major index: t * n_agents * d + a * d + k
    // agent_major index: a * n_steps * d + t * d + k
    let mut agent_major = []
    let mut a3 = 0
    while a3 < n_agents {
        let mut t3 = 0
        while t3 < n_steps {
            let mut k3 = 0
            while k3 < d {
                let src = t3 * n_agents * d + a3 * d + k3
                agent_major = agent_major.push(time_major[src])
                k3 = k3 + 1
            }
            t3 = t3 + 1
        }
        a3 = a3 + 1
    }
    return agent_major
}

// Independent agents: no coupling, just autoregressive + noise.
// Same append-only strategy as coupled but without the global mean term.
fn make_independent_hive(n_agents: int, n_steps: int, d: int, seed: int) -> array {
    let init = det_rand(n_agents * d, seed)
    let mut prev_step = []
    let mut i0 = 0
    while i0 < n_agents * d {
        prev_step = prev_step.push(init[i0])
        i0 = i0 + 1
    }
    let mut time_major = []
    let mut i1 = 0
    while i1 < n_agents * d {
        time_major = time_major.push(prev_step[i1])
        i1 = i1 + 1
    }
    let mut t = 1
    while t < n_steps {
        let noise = det_rand(n_agents * d, seed + t * 137)
        let mut new_prev = []
        let mut a = 0
        while a < n_agents {
            let mut k = 0
            while k < d {
                let pv = prev_step[a * d + k]
                let nz = noise[a * d + k] * 0.05
                let nv = 0.9 * pv + nz
                time_major = time_major.push(nv)
                new_prev = new_prev.push(nv)
                k = k + 1
            }
            a = a + 1
        }
        prev_step = new_prev
        t = t + 1
    }
    // Transpose time_major -> agent_major
    let mut agent_major = []
    let mut a3 = 0
    while a3 < n_agents {
        let mut t3 = 0
        while t3 < n_steps {
            let mut k3 = 0
            while k3 < d {
                let src = t3 * n_agents * d + a3 * d + k3
                agent_major = agent_major.push(time_major[src])
                k3 = k3 + 1
            }
            t3 = t3 + 1
        }
        a3 = a3 + 1
    }
    return agent_major
}

// Extract single agent's state slice from the all_states flat array.
fn extract_agent_state(all_states: array, agent: int, n_steps: int, d: int) -> array {
    let base = agent * n_steps * d
    let count = n_steps * d
    let mut out = []
    let mut i = 0
    while i < count {
        out = out.push(all_states[base + i])
        i = i + 1
    }
    return out
}

// --- Self-tests ------------------------------------------------------

fn check_T1() -> bool {
    // T1: Each individual agent's Phi > 0 for coupled hive.
    let states = make_coupled_hive(N_AGENTS, T_STEPS, D_STATE, 42)
    let mut all_positive = true
    let mut a = 0
    while a < N_AGENTS {
        let agent_state = extract_agent_state(states, a, T_STEPS, D_STATE)
        let phi_i = phi_individual(agent_state, T_STEPS, D_STATE)
        println("  [T1] agent " + str(a) + " Phi_individual = " + str(phi_i))
        if phi_i <= 0.0 { all_positive = false }
        a = a + 1
    }
    if all_positive { return true }
    println("  [T1] FAIL — some agent has Phi_individual <= 0")
    return false
}

fn check_T2() -> bool {
    // T2: Phi_collective > sum(Phi_individual) — emergence.
    let states = make_coupled_hive(N_AGENTS, T_STEPS, D_STATE, 42)
    let mut sum_phi = 0.0
    let mut a = 0
    while a < N_AGENTS {
        let agent_state = extract_agent_state(states, a, T_STEPS, D_STATE)
        let phi_i = phi_individual(agent_state, T_STEPS, D_STATE)
        sum_phi = sum_phi + phi_i
        a = a + 1
    }
    let phi_c = phi_collective(states, N_AGENTS, T_STEPS, D_STATE)
    println("  [T2] sum(Phi_i) = " + str(sum_phi))
    println("  [T2] Phi_collective = " + str(phi_c))
    if phi_c > sum_phi { return true }
    println("  [T2] FAIL — Phi_collective not > sum(Phi_i)")
    return false
}

fn check_T3() -> bool {
    // T3: Emergence ratio > 1.0.
    let states = make_coupled_hive(N_AGENTS, T_STEPS, D_STATE, 42)
    let mut sum_phi = 0.0
    let mut a = 0
    while a < N_AGENTS {
        let agent_state = extract_agent_state(states, a, T_STEPS, D_STATE)
        let phi_i = phi_individual(agent_state, T_STEPS, D_STATE)
        sum_phi = sum_phi + phi_i
        a = a + 1
    }
    let phi_c = phi_collective(states, N_AGENTS, T_STEPS, D_STATE)
    let ratio = if sum_phi > EPS { phi_c / sum_phi } else { 0.0 }
    println("  [T3] emergence ratio = Phi_collective / sum(Phi_i) = " + str(ratio))
    if ratio > 1.0 { return true }
    println("  [T3] FAIL — emergence ratio not > 1.0")
    return false
}

fn check_T4() -> bool {
    // T4: Determinism — same seeds produce byte-identical Phi values.
    let states_a = make_coupled_hive(N_AGENTS, T_STEPS, D_STATE, 42)
    let states_b = make_coupled_hive(N_AGENTS, T_STEPS, D_STATE, 42)
    // Check individual Phi
    let mut a = 0
    while a < N_AGENTS {
        let sa = extract_agent_state(states_a, a, T_STEPS, D_STATE)
        let sb = extract_agent_state(states_b, a, T_STEPS, D_STATE)
        let pa = phi_individual(sa, T_STEPS, D_STATE)
        let pb = phi_individual(sb, T_STEPS, D_STATE)
        if fabs(pa - pb) > 0.0 {
            println("  [T4] FAIL — agent " + str(a) + " Phi differs: " + str(pa) + " vs " + str(pb))
            return false
        }
        a = a + 1
    }
    // Check collective Phi
    let pc_a = phi_collective(states_a, N_AGENTS, T_STEPS, D_STATE)
    let pc_b = phi_collective(states_b, N_AGENTS, T_STEPS, D_STATE)
    if fabs(pc_a - pc_b) > 0.0 {
        println("  [T4] FAIL — Phi_collective differs: " + str(pc_a) + " vs " + str(pc_b))
        return false
    }
    println("  [T4] byte-identical Phi (individual x" + str(N_AGENTS) + " + collective) across two runs")
    return true
}

fn check_T5() -> bool {
    // T5: Latency < 2000 ms for full computation.
    let t0 = clock()
    let states = make_coupled_hive(N_AGENTS, T_STEPS, D_STATE, 42)
    let mut sum_phi = 0.0
    let mut a = 0
    while a < N_AGENTS {
        let agent_state = extract_agent_state(states, a, T_STEPS, D_STATE)
        let phi_i = phi_individual(agent_state, T_STEPS, D_STATE)
        sum_phi = sum_phi + phi_i
        a = a + 1
    }
    let phi_c = phi_collective(states, N_AGENTS, T_STEPS, D_STATE)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] full computation (N=" + str(N_AGENTS) + ", T=" + str(T_STEPS) + ", d=" + str(D_STATE) + ") = " + str(ms) + " ms")
    if ms < 2000.0 { return true }
    println("  [T5] FAIL — latency " + str(ms) + " ms >= 2000 ms")
    return false
}

// --- main ------------------------------------------------------------

fn main() {
    println("[alm_hive_aggregation] ALM-P18-1 hive mind aggregation self-test")
    println("  N_AGENTS=" + str(N_AGENTS) + "  D_STATE=" + str(D_STATE) + "  T_STEPS=" + str(T_STEPS))
    println("  done_criteria: sum(Phi_i) < Phi_collective (emergence)")

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    println("[alm_hive_aggregation] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[alm_hive_aggregation] ALL 5/5 PASS")
    } else {
        println("[alm_hive_aggregation] SOME FAILED")
    }
}

main()
