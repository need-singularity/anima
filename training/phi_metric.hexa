// training/phi_metric.hexa — Φ_kl (KL-from-uniform) metric for CLM
//
// ── METRIC DISAMBIGUATION ────────────────────────────────
// This file implements Phi(KL), metric type: "kl"
// Three distinct Phi metrics exist in the Anima codebase:
//
//   1. Phi(proxy) — global_var - mean(faction_var)
//      Unbounded (0-1000+), scales with cell count.
//      File: bench/bench.hexa engine_measure_phi_proxy()
//      The "Phi=1142" at 1024 cells was THIS metric.
//
//   2. Phi(IIT) — MI-based IIT approximation
//      Range ~0.2-1.8, bounded. PhiIIT(n_bins=16).
//      File: bench/bench.hexa engine_measure_phi_iit()
//      The "Phi=1.4" in training was THIS metric.
//
//   3. Phi(KL) — log(d) - H(softmax(|col_sum|)) [THIS FILE]
//      Bounded by log(d). KL divergence from uniform.
//      Used in training loops for lightweight Phi tracking.
//
// The apparent "816x gap" (1142 vs 1.4) was proxy vs iit confusion.
// ─────────────────────────────────────────────────────────
//
// IIT Φ is defined via the Earth-Mover's distance between the system
// and its minimum-information-partition (MIP). That's expensive.
// For a training-loop metric we use a cheap KL proxy:
//
//   Φ_kl(h) = log(d) − H(softmax(|col_sum|))
//
// where h is a [seq × d] activation tensor, col_sum is the
// column-wise sum of |h|, and H is Shannon entropy of the
// resulting probability distribution.
//
// For a random init: Φ_kl ≈ 0
// For a trained model with emergent features: Φ_kl > 0 and grows.
//
// The "Φ breakthrough" is the event where Φ_kl exceeds
// ln(2) · d / 8 (the critical threshold from DD175).
//
// NAMING NOTE: previously called "zeta" but Zeta is Scatter Lab's
// competitor AI service — unrelated. See memory:
// feedback_p5_zeta_naming.md
//
// Run with: HEXA_PATH=anima-speak hexa training/phi_metric.hexa
use "nn_core"

// ─── Shannon entropy of a probability vector ────────────────
fn entropy(p: array) -> float {
    let n = len(p)
    let mut h = 0.0
    let mut i = 0
    while i < n {
        let q = p[i]
        if q > 0.000001 {
            h = h - q * log(q)
        }
        i = i + 1
    }
    return h
}

// Convert a row of activations to a probability distribution.
// Takes |x|, normalizes so it sums to 1.
fn row_to_prob(row: array) -> array {
    let n = len(row)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let a = row[i]
        let abs_a = if a < 0.0 { 0.0 - a } else { a }
        s = s + abs_a + 0.0000001
        i = i + 1
    }
    let mut p = tensor_zeros(n)
    i = 0
    while i < n {
        let a = row[i]
        let abs_a = if a < 0.0 { 0.0 - a } else { a }
        p[i] = (abs_a + 0.0000001) / s
        i = i + 1
    }
    return p
}

// Φ_kl(h) — KL divergence from uniform across token-summed activations.
// Metric type: "kl" (distinct from "proxy" and "iit" in bench.hexa)
//
// Intuition:
//   - Random init: row-summed activations are ~0 (cancellation),
//     softmax(|col_sum|) ≈ uniform → KL ≈ 0 → Φ_kl ≈ 0
//   - Trained model: activations accumulate structured signal,
//     softmax concentrates on specific dims → KL > 0 → Φ_kl > 0
//
// Φ_kl = log(d) − H(softmax(|col_sum|))
//
// Bounded by log(d). Monotonic increasing during training for models
// that concentrate information. Easy to compute, no partitioning required.
fn phi_proxy(h: array, seq: int, d: int) -> float {
    // Sum of |h| over tokens for each dim
    let mut col_sum = tensor_zeros(d)
    let mut i = 0
    while i < seq {
        let mut j = 0
        while j < d {
            let a = h[i * d + j]
            let abs_a = if a < 0.0 { 0.0 - a } else { a }
            col_sum[j] = col_sum[j] + abs_a
            j = j + 1
        }
        i = i + 1
    }
    // Softmax of the column-sum vector
    let p = softmax(col_sum)
    // Φ = log(d) − H(p)
    let max_h = log(d * 1.0)
    let h_actual = entropy(p)
    return max_h - h_actual
}

// The Φ breakthrough threshold (DD175 critical point): ln(2) per dim.
// A model whose Φ_proxy exceeds this value has "broken through"
// into integrated information territory.
fn phi_breakthrough_threshold(d: int) -> float {
    return 0.6931471805599453 * (d * 1.0) / 8.0  // divided by 8 because we average over rows
}

// ─── phi_hook (live drill hook) ──────────────────────────────────────
// Thin re-export shim so callers (drill pipeline) have a single symbol
// to reach the Φ metric family. Computes Phi-KL over a real [seq × d]
// activation tensor. For drill-iteration *proxy* Φ (no tensor available),
// callers use tool/phi_hook_live.hexa::phi_hook_live which derives Φ
// from aggregate features (absorption/saturation/depth).
//
// SSOT witness: docs/phi_metric_ssot.md
fn phi_hook(h: array, seq: int, d: int) -> float {
    return phi_proxy(h, seq, d)
}

// ─── Self-test ──────────────────────────────────────────────

// Random-ish hidden state (no training) → should have ~zero Φ
let d = 8
let seq = 4
let _h_rand = tensor_mul_scalar(tensor_randn(seq * d, 42), 0.5)
let _phi_rand = phi_proxy(_h_rand, seq, d)
println("[phi_metric] random init Φ_kl  = " + str(_phi_rand))

// Perfectly-correlated hidden state (all rows identical, strong pattern)
// → should have higher Φ because rows agree
let mut _h_corr = tensor_zeros(seq * d)
let mut _i = 0
while _i < seq {
    let mut _j = 0
    while _j < d {
        _h_corr[_i * d + _j] = 0.1 * (_j * 1.0) * (1.0 + _i * 0.01)
        _j = _j + 1
    }
    _i = _i + 1
}
let _phi_corr = phi_proxy(_h_corr, seq, d)
println("[phi_metric] correlated   Φ_kl  = " + str(_phi_corr))

let _phi_thr = phi_breakthrough_threshold(d)
println("[phi_metric] Φ breakthrough threshold (d=" + str(d) + ") = " + str(_phi_thr))

if _phi_corr > _phi_rand {
    println("[phi_metric] PASS — correlated > random (Φ_kl discriminates structure)")
} else {
    println("[phi_metric] FAIL — Φ_kl doesn't discriminate")
}
