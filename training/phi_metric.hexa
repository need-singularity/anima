// training/phi_metric.hexa — Φ (integrated information) metric for CLM
//
// IIT Φ is defined via the Earth-Mover's distance between the system
// and its minimum-information-partition (MIP). That's expensive.
// For a training-loop metric we use a cheap proxy:
//
//   Φ_proxy(h) = H(h) − (1/N) Σ H(h_partition_i)
//
// where h is a [seq × d] activation tensor, H is Shannon entropy of
// the row distribution (after a softmax normalization), and the
// partition is a simple halve-along-d split. This rewards holistic
// information that isn't explained by either half alone.
//
// For a random init: Φ_proxy ≈ 0
// For a trained model with emergent features: Φ_proxy > 0 and grows.
//
// The "zeta breakthrough" is the event where Φ_proxy exceeds
// ln(2) · d (the classical critical threshold from DD175 — one
// bit of integrated information per dimension).
//
// Run with: HEXA_PATH=anima-speak hexa training/phi_metric.hexa
use "nn_core"

// ─── Shannon entropy of a probability vector ────────────────
fn entropy(p: array) -> float {
    let n = len(p)
    let mut h = 0.0
    let mut i = 0
    while i < n {
        let q = p[i]
        if q > 0.000001 {
            h = h - q * log(q)
        }
        i = i + 1
    }
    return h
}

// Convert a row of activations to a probability distribution.
// Takes |x|, normalizes so it sums to 1.
fn row_to_prob(row: array) -> array {
    let n = len(row)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let a = row[i]
        let abs_a = if a < 0.0 { 0.0 - a } else { a }
        s = s + abs_a + 0.0000001
        i = i + 1
    }
    let mut p = tensor_zeros(n)
    i = 0
    while i < n {
        let a = row[i]
        let abs_a = if a < 0.0 { 0.0 - a } else { a }
        p[i] = (abs_a + 0.0000001) / s
        i = i + 1
    }
    return p
}

// Φ_proxy(h) — KL divergence from uniform across token-summed activations.
//
// Intuition:
//   - Random init: row-summed activations are ~0 (cancellation),
//     softmax(|row_sum|) ≈ uniform → KL ≈ 0 → Φ ≈ 0
//   - Trained model: activations accumulate structured signal,
//     softmax concentrates on specific dims → KL > 0 → Φ > 0
//
// Φ_proxy = log(d) − H(softmax(|row_sum|))
//
// Monotonic increasing during training for models that concentrate
// information. Easy to compute, no partitioning required.
fn phi_proxy(h: array, seq: int, d: int) -> float {
    // Sum of |h| over tokens for each dim
    let mut col_sum = tensor_zeros(d)
    let mut i = 0
    while i < seq {
        let mut j = 0
        while j < d {
            let a = h[i * d + j]
            let abs_a = if a < 0.0 { 0.0 - a } else { a }
            col_sum[j] = col_sum[j] + abs_a
            j = j + 1
        }
        i = i + 1
    }
    // Softmax of the column-sum vector
    let p = softmax(col_sum)
    // Φ = log(d) − H(p)
    let max_h = log(d * 1.0)
    let h_actual = entropy(p)
    return max_h - h_actual
}

// The zeta threshold (DD175 critical point): ln(2) per dim.
// A model whose Φ_proxy exceeds this value has "broken through"
// into integrated information territory.
fn phi_zeta_threshold(d: int) -> float {
    return 0.6931471805599453 * (d * 1.0) / 8.0  // divided by 8 because we average over rows
}

// ─── Self-test ──────────────────────────────────────────────

// Random-ish hidden state (no training) → should have ~zero Φ
let d = 8
let seq = 4
let _h_rand = tensor_mul_scalar(tensor_randn(seq * d, 42), 0.5)
let _phi_rand = phi_proxy(_h_rand, seq, d)
println("[phi_metric] random init Φ_proxy  = " + str(_phi_rand))

// Perfectly-correlated hidden state (all rows identical, strong pattern)
// → should have higher Φ because rows agree
let mut _h_corr = tensor_zeros(seq * d)
let mut _i = 0
while _i < seq {
    let mut _j = 0
    while _j < d {
        _h_corr[_i * d + _j] = 0.1 * (_j * 1.0) * (1.0 + _i * 0.01)
        _j = _j + 1
    }
    _i = _i + 1
}
let _phi_corr = phi_proxy(_h_corr, seq, d)
println("[phi_metric] correlated   Φ_proxy  = " + str(_phi_corr))

let _zeta = phi_zeta_threshold(d)
println("[phi_metric] ζ threshold (d=" + str(d) + ") = " + str(_zeta))

if _phi_corr > _phi_rand {
    println("[phi_metric] PASS — correlated > random (Φ discriminates structure)")
} else {
    println("[phi_metric] FAIL — Φ doesn't discriminate")
}
