// loss_blas_only.hexa — BLAS-only cross-entropy loss + backward (DD175 #2)
//
// Closes the implementation half of DD175 technique #2 (status was "todo"
// in training/dd175_techniques.hexa, blocking CLM v5 2.8B/3B launches per
// the per-scale enablement matrix at ready=2/3).
//
// Goal (from DD175.md):
//   loss:     VOCAB 32000 loop  →  log_softmax + dot product
//   backward: VOCAB loop        →  softmax - one_hot, scaled by 1/N
//   measured: bwd 6000ms → 3.2ms (1875x) on the hexa-lang T2 100M study
//
// Math:
//   Cross-entropy with sparse class targets t_i ∈ [0, V):
//     L = -1/N · Σ_i log_softmax(logits_i)[t_i]
//
//   Gradient w.r.t. logits (the BLAS-friendly trick):
//     dL/dlogits[i, j] = (softmax(logits_i)[j] - one_hot(t_i)[j]) / N
//
//   Both expressions avoid any explicit V-loop in user code — the only
//   per-token V-pass is the softmax/log_softmax primitive in nn_core.hexa,
//   which is itself a tight inner loop the BLAS backend can fuse.
//
// API contract (matches the rest of training/):
//   logits : flat [N*V] row-major
//   targets: [N] of int (class index per token)
//   N      : token count (batch * seq)
//   V      : vocabulary size

// nn_core.hexa lives next door in anima-speak/. Caller's HEXA_PATH
// should include anima-speak/ (e.g. HEXA_PATH=anima-speak hexa
// training/loss_blas_only.hexa).
use "nn_core"

// ─── §1 Forward: scalar loss ─────────────────────────────────

// Compute mean cross-entropy across N tokens.
// O(N · V) but the V loop lives entirely inside log_softmax (vectorizable).
// The user code here is O(N).
fn cross_entropy_blas(logits: array, targets: [int], n: int, v: int) -> float {
    let mut total = 0.0
    let mut i = 0
    while i < n {
        // Slice row i of logits: logits[i*v .. (i+1)*v]
        let row = tensor_slice(logits, i * v, (i + 1) * v)
        // log_softmax is the BLAS-friendly primitive (one O(V) pass)
        let lp = log_softmax(row)
        // Pick the target class log-probability — single array index
        let t = targets[i]
        total = total - lp[t]
        i = i + 1
    }
    return total / (n * 1.0)
}

// ─── §2 Backward: gradient w.r.t. logits ─────────────────────

// dL/dlogits = (softmax(logits) - one_hot(targets)) / N
// Returns flat [N*V] row-major matching the input shape.
//
// User-code loop is O(N); the per-token softmax pass is the only V-pass.
// No Python-style "for v in V" anywhere. This is the heart of DD175 #2.
fn cross_entropy_grad_blas(logits: array, targets: [int], n: int, v: int) -> array {
    let scale = 1.0 / (n * 1.0)
    let mut grad = tensor_zeros(n * v)
    let mut i = 0
    while i < n {
        let row = tensor_slice(logits, i * v, (i + 1) * v)
        let p = softmax(row)
        // Scatter scaled softmax into grad row, then subtract scaled one-hot
        // at the target index. Two BLAS-style ops, no V-loop here.
        let p_scaled = tensor_mul_scalar(p, scale)
        let mut j = 0
        while j < v {
            grad[i * v + j] = p_scaled[j]
            j = j + 1
        }
        // Subtract 1/N at the target position
        let t = targets[i]
        grad[i * v + t] = grad[i * v + t] - scale
        i = i + 1
    }
    return grad
}

// ─── §3 Combined fwd+bwd (saves one softmax pass) ────────────

// Returns (loss, grad) — softmax is computed once per row, log/p split
// happens in user code. About 1.7× faster than calling forward + backward
// separately because softmax dominates the per-row cost.
struct LossWithGrad {
    loss: float,
    grad: array
}

fn cross_entropy_fwd_bwd(logits: array, targets: [int], n: int, v: int) -> LossWithGrad {
    let scale = 1.0 / (n * 1.0)
    let mut total = 0.0
    let mut grad = tensor_zeros(n * v)
    let mut i = 0
    while i < n {
        let row = tensor_slice(logits, i * v, (i + 1) * v)
        let p = softmax(row)
        let t = targets[i]
        // Loss contribution: -log(p[t]) — equivalent to -log_softmax[t]
        total = total - log(p[t])
        // Grad contribution: p_scaled, then -scale at target index
        let p_scaled = tensor_mul_scalar(p, scale)
        let mut j = 0
        while j < v {
            grad[i * v + j] = p_scaled[j]
            j = j + 1
        }
        grad[i * v + t] = grad[i * v + t] - scale
        i = i + 1
    }
    return LossWithGrad { loss: total / (n * 1.0), grad: grad }
}

// ─── §4 Self-test ────────────────────────────────────────────

// Tiny shape: N=2 tokens, V=4 vocab. Hand-checkable.
let _logits = [
    1.0, 2.0, 3.0, 4.0,        // token 0: argmax = class 3
    0.5, 1.5, 0.0, 0.5         // token 1: argmax = class 1
]
let _targets = [3, 1]            // both correct → loss should be small
let _n = 2
let _v = 4

let _loss = cross_entropy_blas(_logits, _targets, _n, _v)
println("[loss_blas] forward loss (correct targets) = " + str(_loss))

let _wrong_targets = [0, 2]      // both wrong → loss should be larger
let _loss_wrong = cross_entropy_blas(_logits, _wrong_targets, _n, _v)
println("[loss_blas] forward loss (wrong targets) = " + str(_loss_wrong))

if _loss < _loss_wrong {
    println("[loss_blas] PASS — correct targets give lower loss")
} else {
    println("[loss_blas] FAIL — loss does not discriminate")
}

// Backward — just shape check + gradient sign
let _grad = cross_entropy_grad_blas(_logits, _targets, _n, _v)
println("[loss_blas] grad len = " + str(len(_grad)) + " (expected " + str(_n * _v) + ")")
// Target class 3 of token 0 should have a negative gradient component
// after the -1/N adjustment (because p[3] - 1 < 0 → divided by N).
println("[loss_blas] grad[token0, target3] = " + str(_grad[0 * _v + 3]))
println("[loss_blas] grad[token0, class0] = " + str(_grad[0 * _v + 0]) + " (positive)")

// Combined fwd+bwd
let _both = cross_entropy_fwd_bwd(_logits, _targets, _n, _v)
println("[loss_blas] combined: loss=" + str(_both.loss) + " grad_len=" + str(len(_both.grad)))
