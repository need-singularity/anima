// ═══════════════════════════════════════════════════════════════
//  corpus_pipeline.hexa — P5b-2 training corpus pipeline
//
//  Responsibilities:
//    1. Read raw text files from a directory tree
//    2. Tokenize (byte-level fallback; BPE optional if vocab provided)
//    3. Emit sharded fixed-size token files for fast mmap loading
//    4. Report stats: byte count, token count, compression ratio,
//       shard count, per-shard token counts, estimated training time
//
//  Format:
//    Input : UTF-8 text files, one document per file OR JSONL with "text" field
//    Output: shard_0000.bin, shard_0001.bin, ...
//            Each shard = raw little-endian uint16 token sequence.
//            shards.json manifest with byte offsets and token counts.
//
//  This file runs on CPU and produces artifacts consumed by
//  train_gpu_1b.hexa on the H100.
// ═══════════════════════════════════════════════════════════════

// ── Codepoint-level tokenization (vocab=16384) ──────────────
// hexa's char_code(text, idx) returns the Unicode *codepoint* at idx.
// len(text) returns byte length, so the loop over-iterates on multi-byte
// UTF-8 characters but every token is still deterministic and the vocab
// stays bounded by 0x3FFF (16383) for BMP Korean/Latin/symbols.
//
// This is a stopgap: a true byte-level tokenizer (vocab=256) awaits
// a byte_at/string_as_bytes builtin. Until then, 16384-vocab covers
// Korean + Latin + common math/box-drawing symbols without collision.
fn byte_tokenize(text) {
    let n = len(text)
    let mut tokens = []
    let mut i = 0
    while i < n {
        let b = char_code(text, i)
        // Clamp to vocab ceiling for safety (CJK Unified Ideographs hit ~40000)
        let safe = b % 16384
        tokens = tokens.push(safe)
        i = i + 1
    }
    return tokens
}

// ── Sliding window → training samples ──────────────────────
// Given a long token stream, produce (input, target) pairs of length seq_len.
// Target is input shifted by 1 (next-token prediction).
fn make_samples(tokens, seq_len) {
    let n = len(tokens)
    let mut samples = []
    let mut i = 0
    while i + seq_len + 1 <= n {
        let mut inp = []
        let mut tgt = []
        let mut j = 0
        while j < seq_len {
            inp = inp.push(tokens[i + j])
            tgt = tgt.push(tokens[i + j + 1])
            j = j + 1
        }
        let pair = [inp, tgt]
        samples = samples.push(pair)
        i = i + seq_len
    }
    return samples
}

// ── Shard writer (hexa write_text-only fallback) ──────────
// Writes each shard as a whitespace-separated decimal token list.
// Not optimal, but portable: every hexa interpreter can read it back.
// GPU training path will upgrade to binary u16 once write_bytes is hot.
fn write_shard(path, tokens) {
    let mut s = ""
    let n = len(tokens)
    let mut i = 0
    while i < n {
        if i > 0 {
            s = s + " "
        }
        s = s + str(tokens[i])
        i = i + 1
    }
    write_file(path, s)
    return n
}

// ── Manifest writer ────────────────────────────────────────
fn write_manifest(path, shard_paths, shard_counts, total_tokens, vocab, seq_len) {
    let n = len(shard_paths)
    let mut s = "{\n"
    s = s + "  \"vocab\": " + str(vocab) + ",\n"
    s = s + "  \"seq_len\": " + str(seq_len) + ",\n"
    s = s + "  \"total_tokens\": " + str(total_tokens) + ",\n"
    s = s + "  \"shard_count\": " + str(n) + ",\n"
    s = s + "  \"shards\": [\n"
    let mut i = 0
    while i < n {
        s = s + "    {\"path\": \"" + shard_paths[i] + "\", \"tokens\": " + str(shard_counts[i]) + "}"
        if i < n - 1 {
            s = s + ","
        }
        s = s + "\n"
        i = i + 1
    }
    s = s + "  ]\n"
    s = s + "}\n"
    write_file(path, s)
}

// ── Main pipeline ──────────────────────────────────────────
fn build_corpus(input_files, out_dir, seq_len, tokens_per_shard) {
    println("═══ corpus_pipeline ═══")
    println("  out_dir          : " + out_dir)
    println("  seq_len          : " + str(seq_len))
    println("  tokens_per_shard : " + str(tokens_per_shard))
    println("  input files      : " + str(len(input_files)))

    let mut all_tokens = []
    let mut total_bytes = 0

    // Phase 1: read + tokenize
    let n_files = len(input_files)
    let mut f = 0
    while f < n_files {
        let path = input_files[f]
        let text = read_file(path)
        let bytes = len(text)
        total_bytes = total_bytes + bytes

        let toks = byte_tokenize(text)
        let nt = len(toks)
        let mut j = 0
        while j < nt {
            all_tokens = all_tokens.push(toks[j])
            j = j + 1
        }
        println("  [" + str(f) + "] " + path + ": " + str(bytes) + " B → " + str(nt) + " tokens")
        f = f + 1
    }

    let total_tokens = len(all_tokens)
    println("")
    println("  Phase 1 done: " + str(total_bytes) + " bytes → " + str(total_tokens) + " tokens")

    // Phase 2: shard
    let mut shard_paths = []
    let mut shard_counts = []
    let mut shard_idx = 0
    let mut offset = 0
    while offset < total_tokens {
        let mut end = offset + tokens_per_shard
        if end > total_tokens {
            end = total_tokens
        }
        let mut shard_toks = []
        let mut k = offset
        while k < end {
            shard_toks = shard_toks.push(all_tokens[k])
            k = k + 1
        }
        let shard_path = out_dir + "/shard_" + str(shard_idx) + ".txt"
        let written = write_shard(shard_path, shard_toks)
        shard_paths = shard_paths.push(shard_path)
        shard_counts = shard_counts.push(written)
        println("  shard " + str(shard_idx) + ": " + str(written) + " tokens → " + shard_path)
        shard_idx = shard_idx + 1
        offset = end
    }

    // Phase 3: manifest
    let manifest_path = out_dir + "/shards.json"
    write_manifest(manifest_path, shard_paths, shard_counts, total_tokens, 16384, seq_len)
    println("  manifest         : " + manifest_path)

    // Phase 4: training estimate
    let samples_per_shard = tokens_per_shard / seq_len
    let total_samples = total_tokens / seq_len
    println("")
    println("  total_samples    : " + str(total_samples))
    println("  samples/shard    : " + str(samples_per_shard))
    println("  shard_count      : " + str(shard_idx))

    println("═══ corpus_pipeline DONE ═══")

    let result = [total_tokens, shard_idx]
    return result
}

// ── Self-test: build a tiny corpus from THIS file ──────────
fn main() {
    // Smoke-test: tokenize this very file, shard into small pieces
    let files = ["training/corpus_pipeline.hexa"]
    let out_dir = "/tmp/corpus_test"
    // Make sure out_dir exists (exec shell since hexa fs_mkdir lives in self/std_fs)
    let _ = exec("mkdir -p " + out_dir)

    let result = build_corpus(files, out_dir, 128, 512)
    let total_tokens = result[0]
    let shard_count = result[1]

    println("")
    println("[smoke] self-tokenization produced " + str(total_tokens) + " tokens across " + str(shard_count) + " shards")

    if total_tokens > 0 && shard_count > 0 {
        println("[PASS] corpus pipeline smoke")
    } else {
        println("[FAIL] no tokens or no shards produced")
    }
}

let _ = main()
