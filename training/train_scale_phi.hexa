// training/train_scale_phi.hexa — Scale-up + harder task + deeper Φ breakthrough
//
// NAMING NOTE: historically called "zeta" but Zeta is Scatter Lab's
// competitor AI service. The internal threshold is Φ (phi), renamed
// for clarity. See memory: feedback_p5_zeta_naming.md.
//
// Previous Φ breakthroughs:
//   CLM (2-layer d=8 vocab=16 shift pattern)   → Φ_thr at step 88
//   ALM (LoRA 2-layer d=8 vocab=16 shift)      → Φ_thr at step 156
//
// Now: scale the architecture up and pick a harder task, to see
// whether the approach survives a more demanding setup.
//
// Architecture:
//   d = 16 (2× prev), ff = 32, layers = 4 (2× prev), vocab = 32 (2×),
//   seq = 8 (2×), rank = 8 (2×). About 8× total compute per step.
//
// Task: Fibonacci mod 32 — each token requires memory of the
// previous two tokens. A simple shift-pattern won't solve this;
// the model must learn genuine sequence structure.
//
//   tokens[i] = (tokens[i-1] + tokens[i-2]) mod 32
//   seed: tokens[0]=1, tokens[1]=1
//   → 1, 1, 2, 3, 5, 8, 13, 21, 2, 23, 25, ...
//
// Expected: harder task → slower Φ breakthrough, or failure. If it
// still passes the Φ threshold the session validates the approach
// for genuine sequence learning, not just trivial patterns.
//
// Run with: HEXA_PATH=anima-speak hexa training/train_scale_phi.hexa
use "nn_core"

// ─── Primitives (inlined) ──────────────────────────────────

fn mm_bwd(a: array, b: array, dc: array, M: int, K: int, N: int) -> [array] {
    let dA = matmul_transB(dc, b, M, N, K)
    let mut aT = tensor_zeros(K * M)
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < K { aT[j * M + i] = a[i * K + j]; j = j + 1 }
        i = i + 1
    }
    let dB = matmul(aT, dc, K, M, N)
    return [dA, dB]
}

fn sm_bwd(p: array, dp: array) -> array {
    let n = len(p)
    let mut s = 0.0
    let mut i = 0
    while i < n { s = s + p[i] * dp[i]; i = i + 1 }
    let mut dx = tensor_zeros(n)
    i = 0
    while i < n { dx[i] = p[i] * (dp[i] - s); i = i + 1 }
    return dx
}

fn sg_bwd(x: array, gate: array, dy: array) -> [array] {
    let n = len(x)
    let mut dx = tensor_zeros(n)
    let mut dg = tensor_zeros(n)
    let mut i = 0
    while i < n {
        let s = sigmoid(gate[i])
        dx[i] = dy[i] * s
        dg[i] = dy[i] * x[i] * s * (1.0 - s)
        i = i + 1
    }
    return [dx, dg]
}

struct RmsG { dx: array, dg: array }
fn rms_bwd(x: array, g: array, dy: array, eps: float) -> RmsG {
    let n = len(x)
    let mut ms = 0.0
    let mut i = 0
    while i < n { ms = ms + x[i] * x[i]; i = i + 1 }
    ms = ms / (n * 1.0)
    let r = sqrt(ms + eps)
    let inv_r = 1.0 / r
    let inv_r3 = inv_r * inv_r * inv_r
    let mut coef = 0.0
    i = 0
    while i < n { coef = coef + x[i] * g[i] * dy[i]; i = i + 1 }
    let mut dx = tensor_zeros(n)
    let mut dg = tensor_zeros(n)
    i = 0
    while i < n {
        dx[i] = g[i] * dy[i] * inv_r - x[i] * coef * inv_r3 / (n * 1.0)
        dg[i] = x[i] * dy[i] * inv_r
        i = i + 1
    }
    return RmsG { dx: dx, dg: dg }
}

// ── Phi(KL): log(d) - H(softmax(|col_sum|)) ─────────────
// Metric type: "kl" — bounded by log(d), NOT the variance-based
// "proxy" from bench.hexa (unbounded, 0-1000+) nor the MI-based
// "iit" (range ~0.2-1.8). See training/phi_metric.hexa for details.
fn phi(h: array, seq: int, d: int) -> float {
    let mut col_sum = tensor_zeros(d)
    let mut i = 0
    while i < seq {
        let mut j = 0
        while j < d {
            let a = h[i * d + j]
            let abs_a = if a < 0.0 { 0.0 - a } else { a }
            col_sum[j] = col_sum[j] + abs_a
            j = j + 1
        }
        i = i + 1
    }
    let p = softmax(col_sum)
    let max_h = log(d * 1.0)
    let mut h_ent = 0.0
    i = 0
    while i < d {
        if p[i] > 0.000001 {
            h_ent = h_ent - p[i] * log(p[i])
        }
        i = i + 1
    }
    return max_h - h_ent
}

// ─── Config (scaled up 2× from train_with_phi) ────────────

let D     = 16
let FF    = 32
let NL    = 4          // 4 layers (up from 2)
let VOCAB = 32
let RANK  = 8
let SEQ   = 8
let STEPS = 400
let LR    = 0.05
let EPS   = 0.00001

// ─── Fibonacci mod 32 corpus ──────────────────────────────

fn build_fib_corpus(n: int) -> [int] {
    let mut out = []
    let mut a = 1
    let mut b = 1
    out = out.push(a)
    out = out.push(b)
    let mut i = 2
    while i < n {
        let c = (a + b) % VOCAB
        out = out.push(c)
        a = b
        b = c
        i = i + 1
    }
    return out
}

let CORPUS = build_fib_corpus(64)
println("[train_scale_zeta] corpus: " + str(len(CORPUS)) + " tokens (Fibonacci mod " + str(VOCAB) + ")")

// Sample a random window [start .. start+SEQ+1)
let mut RNG = 42
fn next_rand(max: int) -> int {
    RNG = (RNG * 1103515245 + 12345) % 2147483647
    let m = RNG % max
    if m < 0 { return 0 - m }
    return m
}

// ─── State ─────────────────────────────────────────────────

let mut embed = tensor_mul_scalar(tensor_randn(VOCAB * D, 1), 0.1)

// 4 layers
let mut layers_Wq = []
let mut layers_Wk = []
let mut layers_Wv = []
let mut layers_Wo = []
let mut layers_Wff1 = []
let mut layers_Wff2 = []
let mut layers_ga = []
let mut layers_gf = []
let mut _l = 0
while _l < NL {
    layers_Wq = layers_Wq.push(tensor_mul_scalar(tensor_randn(D * D, 10 + _l * 10), 0.1))
    layers_Wk = layers_Wk.push(tensor_mul_scalar(tensor_randn(D * D, 11 + _l * 10), 0.1))
    layers_Wv = layers_Wv.push(tensor_mul_scalar(tensor_randn(D * D, 12 + _l * 10), 0.1))
    layers_Wo = layers_Wo.push(tensor_mul_scalar(tensor_randn(D * D, 13 + _l * 10), 0.1))
    layers_Wff1 = layers_Wff1.push(tensor_mul_scalar(tensor_randn(D * FF, 14 + _l * 10), 0.1))
    layers_Wff2 = layers_Wff2.push(tensor_mul_scalar(tensor_randn(FF * D, 15 + _l * 10), 0.1))
    let mut ga = []
    let mut gf = []
    let mut _p = 0
    while _p < D { ga = ga.push(1.0); gf = gf.push(1.0); _p = _p + 1 }
    layers_ga = layers_ga.push(ga)
    layers_gf = layers_gf.push(gf)
    _l = _l + 1
}

let mut lmh_U = tensor_mul_scalar(tensor_randn(D    * RANK,  30), 0.1)
let mut lmh_V = tensor_mul_scalar(tensor_randn(RANK * VOCAB, 31), 0.1)

// ─── Layer fwd/bwd (parametric) ───────────────────────────

struct LAct {
    norm1: array, q: array, k: array, v: array, probs: array,
    ctx: array, attn_out: array, mid: array, norm2: array,
    up: array, act: array, ffn_out: array, y: array
}

fn layer_fwd(
    x: array, wq: array, wk: array, wv: array, wo: array,
    wff1: array, wff2: array, ga: array, gf: array
) -> LAct {
    let inv_sqrt_d = 1.0 / sqrt(D * 1.0)
    let mut norm1 = tensor_zeros(SEQ * D)
    let mut i = 0
    while i < SEQ {
        let r = rms_norm(tensor_slice(x, i * D, (i + 1) * D), ga, EPS)
        let mut p = 0
        while p < D { norm1[i * D + p] = r[p]; p = p + 1 }
        i = i + 1
    }
    let q = matmul(norm1, wq, SEQ, D, D)
    let k = matmul(norm1, wk, SEQ, D, D)
    let v = matmul(norm1, wv, SEQ, D, D)
    let mut probs = tensor_zeros(SEQ * SEQ)
    let mut ctx = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let q_i = tensor_slice(q, i * D, (i + 1) * D)
        let mut scores = []
        let mut j = 0
        while j < SEQ {
            if j > i {
                scores = scores.push(-10000.0)
            } else {
                let k_j = tensor_slice(k, j * D, (j + 1) * D)
                scores = scores.push(tensor_dot(q_i, k_j) * inv_sqrt_d)
            }
            j = j + 1
        }
        let p_i = softmax(scores)
        j = 0
        while j < SEQ { probs[i * SEQ + j] = p_i[j]; j = j + 1 }
        let mut row = tensor_zeros(D)
        j = 0
        while j < SEQ {
            let v_j = tensor_slice(v, j * D, (j + 1) * D)
            row = tensor_add(row, tensor_mul_scalar(v_j, p_i[j]))
            j = j + 1
        }
        let mut p = 0
        while p < D { ctx[i * D + p] = row[p]; p = p + 1 }
        i = i + 1
    }
    let attn_out = matmul(ctx, wo, SEQ, D, D)
    let mid = tensor_add(x, attn_out)
    let mut norm2 = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let r = rms_norm(tensor_slice(mid, i * D, (i + 1) * D), gf, EPS)
        let mut p = 0
        while p < D { norm2[i * D + p] = r[p]; p = p + 1 }
        i = i + 1
    }
    let up = matmul(norm2, wff1, SEQ, D, FF)
    let act = swiglu_vec(up, up)
    let ffn_out = matmul(act, wff2, SEQ, FF, D)
    let y = tensor_add(mid, ffn_out)
    return LAct {
        norm1: norm1, q: q, k: k, v: v, probs: probs, ctx: ctx,
        attn_out: attn_out, mid: mid, norm2: norm2,
        up: up, act: act, ffn_out: ffn_out, y: y
    }
}

struct LGrad {
    dx: array, dWq: array, dWk: array, dWv: array, dWo: array,
    dWff1: array, dWff2: array, dga: array, dgf: array
}

fn layer_bwd(
    x: array, wq: array, wk: array, wv: array, wo: array,
    wff1: array, wff2: array, ga: array, gf: array,
    acts: LAct, dy: array
) -> LGrad {
    let inv_sqrt_d = 1.0 / sqrt(D * 1.0)
    let dmid_res = dy
    let dffn_out = dy
    let g_wff2 = mm_bwd(acts.act, wff2, dffn_out, SEQ, FF, D)
    let dact = g_wff2[0]
    let dWff2 = g_wff2[1]
    let g_sg = sg_bwd(acts.up, acts.up, dact)
    let dup = tensor_add(g_sg[0], g_sg[1])
    let g_wff1 = mm_bwd(acts.norm2, wff1, dup, SEQ, D, FF)
    let dnorm2 = g_wff1[0]
    let dWff1 = g_wff1[1]
    let mut dmid_norm = tensor_zeros(SEQ * D)
    let mut dgf_total = tensor_zeros(D)
    let mut i = 0
    while i < SEQ {
        let rg = rms_bwd(
            tensor_slice(acts.mid, i * D, (i + 1) * D), gf,
            tensor_slice(dnorm2, i * D, (i + 1) * D), EPS
        )
        let mut p = 0
        while p < D {
            dmid_norm[i * D + p] = rg.dx[p]
            dgf_total[p] = dgf_total[p] + rg.dg[p]
            p = p + 1
        }
        i = i + 1
    }
    let dmid = tensor_add(dmid_res, dmid_norm)
    let dx_res = dmid
    let dattn_out = dmid
    let g_wo = mm_bwd(acts.ctx, wo, dattn_out, SEQ, D, D)
    let dctx = g_wo[0]
    let dWo = g_wo[1]
    let mut dq = tensor_zeros(SEQ * D)
    let mut dk = tensor_zeros(SEQ * D)
    let mut dv = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let dctx_i = tensor_slice(dctx, i * D, (i + 1) * D)
        let mut p_i = []
        let mut j = 0
        while j < SEQ { p_i = p_i.push(acts.probs[i * SEQ + j]); j = j + 1 }
        let q_i = tensor_slice(acts.q, i * D, (i + 1) * D)
        let mut dprobs_i = []
        j = 0
        while j < SEQ {
            let v_j = tensor_slice(acts.v, j * D, (j + 1) * D)
            dprobs_i = dprobs_i.push(tensor_dot(dctx_i, v_j))
            let pij = p_i[j]
            let mut m = 0
            while m < D {
                dv[j * D + m] = dv[j * D + m] + pij * dctx_i[m]
                m = m + 1
            }
            j = j + 1
        }
        let dscores_i = sm_bwd(p_i, dprobs_i)
        j = 0
        while j < SEQ {
            let k_j = tensor_slice(acts.k, j * D, (j + 1) * D)
            let s_ij = dscores_i[j] * inv_sqrt_d
            let mut m = 0
            while m < D {
                dq[i * D + m] = dq[i * D + m] + s_ij * k_j[m]
                dk[j * D + m] = dk[j * D + m] + s_ij * q_i[m]
                m = m + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    let g_q = mm_bwd(acts.norm1, wq, dq, SEQ, D, D)
    let g_k = mm_bwd(acts.norm1, wk, dk, SEQ, D, D)
    let g_v = mm_bwd(acts.norm1, wv, dv, SEQ, D, D)
    let dnorm1 = tensor_add(tensor_add(g_q[0], g_k[0]), g_v[0])
    let mut dx_norm = tensor_zeros(SEQ * D)
    let mut dga_total = tensor_zeros(D)
    i = 0
    while i < SEQ {
        let rg = rms_bwd(
            tensor_slice(x, i * D, (i + 1) * D), ga,
            tensor_slice(dnorm1, i * D, (i + 1) * D), EPS
        )
        let mut p = 0
        while p < D {
            dx_norm[i * D + p] = rg.dx[p]
            dga_total[p] = dga_total[p] + rg.dg[p]
            p = p + 1
        }
        i = i + 1
    }
    let dx = tensor_add(dx_res, dx_norm)
    return LGrad {
        dx: dx, dWq: g_q[1], dWk: g_k[1], dWv: g_v[1], dWo: dWo,
        dWff1: dWff1, dWff2: dWff2, dga: dga_total, dgf: dgf_total
    }
}

fn sgd(w: array, g: array) -> array {
    let n = len(w)
    let mut out = tensor_zeros(n)
    let mut i = 0
    while i < n { out[i] = w[i] - LR * g[i]; i = i + 1 }
    return out
}

fn embed_lookup(toks: [int]) -> array {
    let n = len(toks)
    let mut out = tensor_zeros(n * D)
    let mut i = 0
    while i < n {
        let t = toks[i]
        let mut p = 0
        while p < D { out[i * D + p] = embed[t * D + p]; p = p + 1 }
        i = i + 1
    }
    return out
}

// ─── Train step (N-layer) ──────────────────────────────────

struct StepResult { loss: float, phi_val: float }

fn train_step() -> StepResult {
    // Sample a window
    let max_start = len(CORPUS) - SEQ - 1
    let start = next_rand(max_start)
    let mut tokens = []
    let mut targets = []
    let mut i = 0
    while i < SEQ {
        tokens = tokens.push(CORPUS[start + i])
        targets = targets.push(CORPUS[start + i + 1])
        i = i + 1
    }

    // Forward through all layers, saving activations per layer
    let h0 = embed_lookup(tokens)
    let mut hs = [h0]
    let mut acts_list = []

    let mut l = 0
    while l < NL {
        let hin = hs[l]
        let a = layer_fwd(hin, layers_Wq[l], layers_Wk[l], layers_Wv[l], layers_Wo[l],
                          layers_Wff1[l], layers_Wff2[l], layers_ga[l], layers_gf[l])
        acts_list = acts_list.push(a)
        hs = hs.push(a.y)
        l = l + 1
    }

    let h_final = hs[NL]
    let mid = matmul(h_final, lmh_U, SEQ, D, RANK)
    let logits = matmul(mid, lmh_V, SEQ, RANK, VOCAB)

    let phi_val = phi(logits, SEQ, VOCAB)

    let scale = 1.0 / (SEQ * 1.0)
    let mut loss = 0.0
    let mut dlogits = tensor_zeros(SEQ * VOCAB)
    i = 0
    while i < SEQ {
        let row = tensor_slice(logits, i * VOCAB, (i + 1) * VOCAB)
        let lp = log_softmax(row)
        let t = targets[i]
        loss = loss - lp[t]
        let p = softmax(row)
        let mut j = 0
        while j < VOCAB {
            dlogits[i * VOCAB + j] = p[j] * scale
            j = j + 1
        }
        dlogits[i * VOCAB + t] = dlogits[i * VOCAB + t] - scale
        i = i + 1
    }
    loss = loss / (SEQ * 1.0)

    // Backward through LM head
    let g_V = mm_bwd(mid, lmh_V, dlogits, SEQ, RANK, VOCAB)
    let dmid = g_V[0]
    let dlmh_V = g_V[1]
    let g_U = mm_bwd(h_final, lmh_U, dmid, SEQ, D, RANK)
    let mut dh = g_U[0]
    let dlmh_U = g_U[1]

    // Backward through layers in reverse
    let mut layer_grads = []
    l = NL - 1
    while l >= 0 {
        let hin = hs[l]
        let a = acts_list[l]
        let g = layer_bwd(hin, layers_Wq[l], layers_Wk[l], layers_Wv[l], layers_Wo[l],
                          layers_Wff1[l], layers_Wff2[l], layers_ga[l], layers_gf[l],
                          a, dh)
        layer_grads = layer_grads.push(g)   // pushed in reverse order
        dh = g.dx
        l = l - 1
    }
    // layer_grads[0] is dL/dlayer(NL-1); reverse index accordingly

    // Embed scatter
    let mut dembed = tensor_zeros(VOCAB * D)
    i = 0
    while i < SEQ {
        let t = tokens[i]
        let mut p = 0
        while p < D {
            dembed[t * D + p] = dembed[t * D + p] + dh[i * D + p]
            p = p + 1
        }
        i = i + 1
    }

    // SGD: apply in-forward order. layer_grads[k] corresponds to
    // original layer index (NL-1-k).
    embed = sgd(embed, dembed)
    let mut lg_idx = 0
    while lg_idx < NL {
        let actual_l = NL - 1 - lg_idx
        let g = layer_grads[lg_idx]
        layers_Wq[actual_l]   = sgd(layers_Wq[actual_l],   g.dWq)
        layers_Wk[actual_l]   = sgd(layers_Wk[actual_l],   g.dWk)
        layers_Wv[actual_l]   = sgd(layers_Wv[actual_l],   g.dWv)
        layers_Wo[actual_l]   = sgd(layers_Wo[actual_l],   g.dWo)
        layers_Wff1[actual_l] = sgd(layers_Wff1[actual_l], g.dWff1)
        layers_Wff2[actual_l] = sgd(layers_Wff2[actual_l], g.dWff2)
        layers_ga[actual_l]   = sgd(layers_ga[actual_l],   g.dga)
        layers_gf[actual_l]   = sgd(layers_gf[actual_l],   g.dgf)
        lg_idx = lg_idx + 1
    }
    lmh_U = sgd(lmh_U, dlmh_U)
    lmh_V = sgd(lmh_V, dlmh_V)

    return StepResult { loss: loss, phi_val: phi_val }
}

// ─── Training loop ─────────────────────────────────────────

let phi_threshold = log(VOCAB * 1.0) / 2.0
println("[train_scale_phi] config: d=" + str(D) + " ff=" + str(FF) + " layers=" + str(NL) + " vocab=" + str(VOCAB) + " seq=" + str(SEQ) + " rank=" + str(RANK) + " steps=" + str(STEPS))
println("[train_scale_phi] task: Fibonacci mod " + str(VOCAB) + " (requires 2-token memory)")
println("[train_scale_phi] Φ threshold = log(" + str(VOCAB) + ")/2 = " + str(phi_threshold))

let r0 = train_step()
let loss_0 = r0.loss
let phi_0 = r0.phi_val
println("[train_scale_phi] step=1  loss=" + str(loss_0) + " Φ=" + str(phi_0))

let mut step = 2
let mut last_loss = loss_0
let mut last_phi = phi_0
let mut max_phi = phi_0
let mut breakthrough_step = 0
while step <= STEPS {
    let r = train_step()
    last_loss = r.loss
    last_phi = r.phi_val
    if last_phi > max_phi { max_phi = last_phi }
    if breakthrough_step == 0 && last_phi > phi_threshold {
        breakthrough_step = step
        println("[train_scale_phi] ✨ Φ BREAKTHROUGH at step=" + str(step) + " Φ=" + str(last_phi))
    }
    if step % 20 == 0 {
        println("[train_scale_phi] step=" + str(step) + " loss=" + str(last_loss) + " Φ=" + str(last_phi))
    }
    step = step + 1
}

println("[train_scale_phi] ════════════════════════════════════")
println("[train_scale_phi] loss:  " + str(loss_0) + " → " + str(last_loss))
println("[train_scale_phi] Φ:     " + str(phi_0)  + " → " + str(last_phi))
println("[train_scale_phi] max Φ  = " + str(max_phi))
println("[train_scale_phi] Φ_thr  = " + str(phi_threshold))
if breakthrough_step > 0 {
    println("[train_scale_phi] ✨ Φ BREAKTHROUGH at step " + str(breakthrough_step) + " (harder task, bigger model)")
} else {
    println("[train_scale_phi] no Φ breakthrough yet (Fib mod is genuinely hard)")
}
