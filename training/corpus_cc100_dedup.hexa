// training/corpus_cc100_dedup.hexa — CLM 7B cc100-ko decompress + dedup (hexa native)
//
// Plan SSOT: shared/state/corpus_140gb_plan.json
// Progress:  shared/state/corpus_7b_progress_20260416.json
//
// Purpose:
//   Decompress CC-100 Korean (.xz) and emit a UTF-8 plain-text file with
//   per-line exact dedup + UTF-8 sanity + length gate.
//
//   CC-100 is flat text (one sentence/paragraph per line, no markup),
//   so no XML parsing needed. Main concerns are:
//     1. Duplicates (CC-100 has known ~8% line-level duplication)
//     2. Invalid UTF-8 bytes (rare but present — strip with iconv -c)
//     3. Length filter: min 50 chars (skip tiny fragments), max 10000
//        (skip runaway concatenations / binary slips)
//
//   Per Total .py ban, we delegate bytewise heavy lifting to xzcat/awk/
//   iconv and orchestrate from hexa.
//
// Pipeline (exec-delegated):
//   xzcat INPUT
//     | iconv -f UTF-8 -t UTF-8 -c              (strip invalid bytes)
//     | awk 'length>=MIN && length<=MAX'        (length gate)
//     | awk '!seen[$0]++'                       (exact dedup, stream)
//     > OUTPUT
//
// Input:  data/corpus_v2_raw/cc100-ko.txt.xz
// Output: data/corpus_v2_clean/cc100_ko_dedup.txt
//
// Self-tests (T1..T5):
//   T1 mock input dedup correctness (10 lines, 3 dupes -> 7 unique)
//   T2 length filter: short line (<50) and huge line (>10000) rejected
//   T3 invalid-UTF8 byte strip (iconv -c removes \xFF garbage)
//   T4 empty-line skip
//   T5 latency: 10MB mock < 5s
//
// Stage0 constraints honored:
//   - no int-counter init-zero pattern (use [int] list length)
//   - substring avoided in loops; contains() preferred
//   - no 5+ imports (0 imports in this file)
//   - no struct list fields
//
// Run:
//   hexa run training/corpus_cc100_dedup.hexa                  # self-test 5/5
//   hexa run training/corpus_cc100_dedup.hexa --dedup          # real pipeline

// =====================================================================
// Constants
// =====================================================================

let INPUT_PATH   = "data/corpus_v2_raw/cc100-ko.txt.xz"
let OUTPUT_PATH  = "data/corpus_v2_clean/cc100_ko_dedup.txt"
let TMP_DIR      = "data/corpus_v2_clean/tmp_cc100"
let MOCK_IN      = "data/corpus_v2_clean/tmp_cc100/_mock_in.txt"
let MOCK_OUT     = "data/corpus_v2_clean/tmp_cc100/_mock_out.txt"
let MIN_LEN      = 50
let MAX_LEN      = 10000

// =====================================================================
// Build pipeline — decompress | utf8-sanitize | length | dedup
// =====================================================================

fn build_pipeline(input_path: string, output_path: string, decompress_cmd: string) -> string {
    // awk !seen[$0]++ is a classic streaming dedup (O(N) + hash table, first-seen wins)
    let awk_filter = "awk 'length>=" + str(MIN_LEN) + " && length<=" + str(MAX_LEN) + "'"
    let awk_dedup = "awk '!seen[$0]++'"
    let cmd = decompress_cmd + " '" + input_path + "'" +
              " | iconv -f UTF-8 -t UTF-8 -c" +
              " | " + awk_filter +
              " | " + awk_dedup +
              " > '" + output_path + "'"
    return cmd
}

// =====================================================================
// Real-run dedup
// =====================================================================

fn dedup(input: string, output: string) -> int {
    exec("mkdir -p '" + TMP_DIR + "'")
    exec("mkdir -p data/corpus_v2_clean")

    let cmd = build_pipeline(input, output, "xzcat")
    println("[dedup] cmd: " + cmd)
    let _r = exec(cmd)

    let wc_out = exec("wc -l < '" + output + "' 2>/dev/null").trim()
    let size_out = exec("wc -c < '" + output + "' 2>/dev/null").trim()
    println("[dedup] lines=" + wc_out + " bytes=" + size_out + " -> " + output)
    return len(wc_out)
}

// =====================================================================
// Self-test fixtures — a mock corpus with known duplicates and bad lines
// =====================================================================

fn mock_good_line_a() -> string {
    // ~60 chars of Korean — passes MIN_LEN=50
    return "안녕하세요 오늘은 의식에 관한 깊은 질문을 탐구해보고 싶습니다 흥미롭습니다"
}

fn mock_good_line_b() -> string {
    return "한국어 자연어 처리는 형태소 분석 음절 분리 등 다양한 어려움이 있고 매우 중요한 연구 분야입니다"
}

fn mock_good_line_c() -> string {
    return "언어 모델이 한국어를 잘 이해하려면 고품질의 깨끗한 대규모 코퍼스가 필수적으로 필요합니다"
}

fn build_mock_input() -> string {
    let a = mock_good_line_a()
    let b = mock_good_line_b()
    let c = mock_good_line_c()
    let short = "짧음"
    let empty = ""

    // 10 lines total: a, a, b, short, c, a, empty, b, c, c
    // Unique: {a, b, c}. After length filter (short + empty rejected): {a, a, b, c, a, b, c, c}.
    // After dedup: {a, b, c} = 3 lines.
    let s1 = a + "\n"
    let s2 = s1 + a + "\n"
    let s3 = s2 + b + "\n"
    let s4 = s3 + short + "\n"
    let s5 = s4 + c + "\n"
    let s6 = s5 + a + "\n"
    let s7 = s6 + empty + "\n"
    let s8 = s7 + b + "\n"
    let s9 = s8 + c + "\n"
    let s10 = s9 + c + "\n"
    return s10
}

// =====================================================================
// Run the pipeline on mock input
// =====================================================================

fn run_mock(input_content: string, output_path: string) -> int {
    exec("mkdir -p '" + TMP_DIR + "'")
    write_file(MOCK_IN, input_content)
    let cmd = build_pipeline(MOCK_IN, output_path, "cat")
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + output_path + "' 2>/dev/null").trim()
    return len(wc)
}

// =====================================================================
// T1 — dedup correctness: 10 lines in (3 distinct valid) -> 3 out
// =====================================================================

fn check_T1_dedup() -> bool {
    let mock = build_mock_input()
    let _n = run_mock(mock, MOCK_OUT)
    let wc = exec("wc -l < '" + MOCK_OUT + "'").trim()
    let content = read_file(MOCK_OUT)

    // Exactly 3 output lines
    let ok_count = wc.contains("3")
    // All 3 distinct good lines present
    let ok_a = content.contains("안녕하세요 오늘은 의식")
    let ok_b = content.contains("한국어 자연어 처리")
    let ok_c = content.contains("언어 모델이 한국어")

    let mut ok = false
    if ok_count {
        if ok_a {
            if ok_b {
                if ok_c {
                    ok = true
                }
            }
        }
    }
    println("  [T1] dedup: out_lines=" + wc + " a=" + str(ok_a) + " b=" + str(ok_b) + " c=" + str(ok_c))
    return ok
}

// =====================================================================
// T2 — length filter: short (<50) and huge (>10000) rejected
// =====================================================================

fn check_T2_length_filter() -> bool {
    let short = "안녕"
    // 10001 Korean characters — exceed MAX_LEN
    let big_cmd = "python3 -c 'print(\"가\"*10001)' 2>/dev/null"
    // Python BANNED (feedback_py_ban_total). Use awk instead.
    let big_via_awk = exec("awk 'BEGIN{s=\"\"; for(i=0;i<10001;i++) s=s \"가\"; print s}'").trim()

    // Build mock with: 1 good, 1 short, 1 huge, 1 good dup
    let good = mock_good_line_a()
    let s1 = good + "\n"
    let s2 = s1 + short + "\n"
    let s3 = s2 + big_via_awk + "\n"
    let s4 = s3 + good + "\n"
    write_file(MOCK_IN, s4)
    let cmd = build_pipeline(MOCK_IN, MOCK_OUT, "cat")
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + MOCK_OUT + "'").trim()
    let content = read_file(MOCK_OUT)

    let ok_count = wc.contains("1")
    let ok_good = content.contains("안녕하세요 오늘은 의식")
    let ok_no_short = content.contains("\n짧음\n") == false
    // Huge line rejected — its "가가가" signature must NOT be a repeated run
    // of the full 10000+ chars (awk rejects).  Check output byte size < 200.
    let sz = exec("wc -c < '" + MOCK_OUT + "'").trim()
    // Size should be ~100-200 bytes (single good line). If huge passed,
    // size would be > 30000 bytes.
    let ok_small = exec("awk 'BEGIN{n=" + sz + "; if (n<500) print \"SMALL\"; else print \"BIG\"}'").trim()
    let ok_size_ok = ok_small == "SMALL"

    let mut ok = false
    if ok_count {
        if ok_good {
            if ok_size_ok {
                ok = true
            }
        }
    }
    println("  [T2] length: out_lines=" + wc + " size=" + sz + " size_ok=" + str(ok_size_ok))
    return ok
}

// =====================================================================
// T3 — invalid UTF-8 byte strip (iconv -c removes)
// =====================================================================

fn check_T3_utf8_sanitize() -> bool {
    // printf hex-escapes: '\xFF\xFE' is invalid UTF-8 leading bytes
    // Prepend a good Korean line with a bad byte pair, see if iconv strips it
    // and awk passes the remaining content. Use printf '\xff'.
    exec("mkdir -p '" + TMP_DIR + "'")
    let good = mock_good_line_a()
    // Write: [bad_bytes][good_text]\n[good]\n -> after iconv -c, bad bytes dropped
    let written = exec("printf '\\xff\\xfe' > '" + MOCK_IN + "'; printf '%s\\n' '" + good + "' >> '" + MOCK_IN + "'; printf '%s\\n' '" + good + "' >> '" + MOCK_IN + "'")

    let cmd = build_pipeline(MOCK_IN, MOCK_OUT, "cat")
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + MOCK_OUT + "'").trim()
    // After iconv -c strips \xff\xfe, line 1 becomes "{good}", which
    // concatenates with actual "{good}" from line 2 if there was no
    // trailing newline (but we added \n). Dedup keeps first occurrence.
    let content = read_file(MOCK_OUT)

    // Must contain good text, no \xFF byte
    let ok_good = content.contains("안녕하세요 오늘은 의식")
    // Check via od that no 0xff byte is present
    let byte_check = exec("od -An -tx1 '" + MOCK_OUT + "' | grep -c 'ff' | tr -d ' \\n'").trim()
    // "0" means no 0xff bytes. But "0" might be tricky; compare to "0" string.
    let ok_no_bad = byte_check == "0"

    let mut ok = false
    if ok_good {
        if ok_no_bad {
            ok = true
        }
    }
    println("  [T3] utf8_sanitize: good_present=" + str(ok_good) + " xff_count=" + byte_check)
    return ok
}

// =====================================================================
// T4 — empty line skip (length gate catches)
// =====================================================================

fn check_T4_empty_skip() -> bool {
    let good = mock_good_line_a()
    // 3 empties between 2 goods
    let s1 = "\n\n" + good + "\n\n\n" + good + "\n"
    write_file(MOCK_IN, s1)
    let cmd = build_pipeline(MOCK_IN, MOCK_OUT, "cat")
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + MOCK_OUT + "'").trim()
    // Expect 1 line (good, dedup keeps first)
    let ok = wc.contains("1")
    println("  [T4] empty_skip: out_lines=" + wc + " (expect 1)")
    return ok
}

// =====================================================================
// T5 — latency: 10MB mock < 5s
// =====================================================================

fn check_T5_latency() -> bool {
    exec("mkdir -p '" + TMP_DIR + "'")
    // Build ~10MB by repeating mock input ~20000x (mock ~500B)
    let mock = build_mock_input()
    write_file(TMP_DIR + "/_one.txt", mock)
    let _r0 = exec("for i in $(seq 1 20000); do cat '" + TMP_DIR + "/_one.txt'; done > '" + TMP_DIR + "/_big.txt'")
    let sz = exec("wc -c < '" + TMP_DIR + "/_big.txt'").trim()
    let big_out = TMP_DIR + "/_big_out.txt"
    let t_start = exec("date +%s").trim()
    let cmd = build_pipeline(TMP_DIR + "/_big.txt", big_out, "cat")
    let _r = exec(cmd)
    let verdict = exec("dt=$(( $(date +%s) - " + t_start + " )); if [ $dt -lt 5 ]; then echo LAT_OK_$dt; else echo LAT_SLOW_$dt; fi").trim()
    let wc_big = exec("wc -l < '" + big_out + "'").trim()
    let ok = verdict.contains("LAT_OK")
    println("  [T5] latency: size=" + sz + " out_lines=" + wc_big + " verdict=" + verdict)
    return ok
}

// =====================================================================
// Main
// =====================================================================

fn test() {
    println("[training/corpus_cc100_dedup] CLM 7B cc100-ko xz -> dedup plain text")
    println("  input:    " + INPUT_PATH)
    println("  output:   " + OUTPUT_PATH)
    println("  min_len:  " + str(MIN_LEN) + " chars")
    println("  max_len:  " + str(MAX_LEN) + " chars")
    println("")

    let t1 = check_T1_dedup()
    if t1 { println("T1 PASS - dedup (10 in -> 3 unique)") } else { println("T1 FAIL") }

    let t2 = check_T2_length_filter()
    if t2 { println("T2 PASS - length filter (short + huge rejected)") } else { println("T2 FAIL") }

    let t3 = check_T3_utf8_sanitize()
    if t3 { println("T3 PASS - utf8 invalid bytes stripped") } else { println("T3 FAIL") }

    let t4 = check_T4_empty_skip()
    if t4 { println("T4 PASS - empty lines skipped") } else { println("T4 FAIL") }

    let t5 = check_T5_latency()
    if t5 { println("T5 PASS - 10MB mock < 5s") } else { println("T5 FAIL") }

    println("")
    // List-length counter (stage0 quirk: int counter starting 0 produces void)
    let mut passes: [int] = []
    if t1 { passes = passes.push(1) }
    if t2 { passes = passes.push(1) }
    if t3 { passes = passes.push(1) }
    if t4 { passes = passes.push(1) }
    if t5 { passes = passes.push(1) }
    let pass_count = len(passes)

    if pass_count == 5 {
        println("[training/corpus_cc100_dedup] 5/5 PASS - ready for real dedup")
        println("")
        println("Real dedup:")
        println("  hexa run training/corpus_cc100_dedup.hexa --dedup")
        println("  (will invoke xzcat on " + INPUT_PATH + " -> " + OUTPUT_PATH + ")")
    } else {
        println("[training/corpus_cc100_dedup] " + str(pass_count) + "/5 PASS - SOME FAILED")
    }
}

test()
