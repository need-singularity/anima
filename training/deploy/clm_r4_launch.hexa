// clm_r4_launch.hexa — CLM 1B r4 corpus-expansion training (RunPod H100)
//
// Status: NOT YET FIRED. Single-shot launcher generated 2026-04-16.
// Plan source:  training/deploy/clm_r4_corpus_plan.json (option B recommended)
// Baseline:     r3f best_eval_loss = 1.2296 @ step 9500 (ppl 3.42), 1.51B params,
//               10K steps, corpus 1.30 GB, 32.8 min, ~20.8K tok/s
// Goal:         eval_loss <= 1.0 (ppl <= 2.72) on 5.38 GB corpus, ~750K steps
//
// r4 changes vs r3f (per clm_r4_corpus_plan.json training_parameters_r4):
//   - corpus:        corpus_clm_combined.txt (1.30 GB) -> corpus_clm_r4.txt (5.38 GB)
//   - total steps:   10000 -> 750000  (75x increase, option B = 1 epoch over 5 GB)
//   - warmup:        2000 -> 5000     (proportional to step count)
//   - save_every:    1000 -> 5000     (runpod_mfs_quota: save_every >= 2000)
//   - eval_every:    500  -> 2500     (proportional scale)
//   - patience:      5    -> 10       (longer run absorbs noise)
//   - fresh start:   MANDATORY (data changed -> feedback_no_resume_data_change)
//
// UNCHANGED from r3f (one-shot best, no mid-stream tuning):
//   - architecture (d=2048, L=24, H=16, n_kv_head=8, d_ff=8192, vocab=256, 1.51B)
//   - lr_max=3e-4, lr_min=3e-5, cosine warmup, AdamW(beta1=0.9, beta2=0.95, wd=0.1)
//   - dtype bf16, grad_clip 1.0, torch.compile on
//   - consciousness controller (Hexad P1->P2->P3 curriculum, phi_holo + GWT + cache)
//   - orch-or quantum controller, phi_q_norm bonus
//   - batch_size=8, seq_len=512 (from clm_1b_config.json scale_1_5b)
//
// Why a hexa wrapper around train_clm_1b.py (per AI-native CLM policy):
//   train_clm.hexa is the structural .hexa port of this trainer (see scale_1_5b
//   header at line 132-145). The hexa-native CUDA path (cuda_rtc + nn_core) still
//   has cuLaunchKernelEx failures on the H100 SM90 build (see deploy/h100_clm_native_run.log,
//   2026-04-16). Until those land, r4 must run on the proven Python trainer to
//   meet the One-Shot Best rule. The wrapper preserves the hexa-first launch
//   surface (this file is the SSOT) and the migration target is documented in
//   train_clm.hexa scale_1_5b. See feedback_ai_native_clm.md and CLM-P5 roadmap.
//
// Run sequence on the H100 pod (after the runpod create + ssh):
//   1. scp clm_r4_launch.hexa root@$POD:/workspace/
//   2. scp train_clm_1b.py    root@$POD:/workspace/
//   3. scp corpus_clm_r4.txt.gz root@$POD:/workspace/
//   4. ssh root@$POD
//   5. cd /workspace && gunzip -k corpus_clm_r4.txt.gz
//   6. hexa /workspace/clm_r4_launch.hexa     # this script
//
// Self-test note: this file contains no logic at module top level beyond the
// fn main() definition and the trailing main() call, so `hexa parse-check`
// is safe to run locally without side effects (per launch_alm_32b_r1.hexa
// preflight pattern).

fn main() {
    let runner = "/tmp/_clm_r4_launch_runner.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "\n" +
        "echo \"============================================================\"\n" +
        "echo \"  CLM 1B r4 -- 5.38 GB corpus, 750K steps, target eval<=1.0\"\n" +
        "echo \"  Baseline r3f: eval=1.2296 ppl=3.42 @ step 9500\"\n" +
        "echo \"============================================================\"\n" +
        "\n" +
        // ── Tunables (env-overridable; defaults match clm_r4_corpus_plan.json option B) ──
        "STEPS=\"${STEPS:-750000}\"\n" +
        "BATCH=\"${BATCH:-8}\"\n" +
        "SEQ=\"${SEQ:-512}\"\n" +
        "LR_MAX=\"${LR_MAX:-3e-4}\"\n" +
        "WARMUP=\"${WARMUP:-5000}\"\n" +
        "SAVE_EVERY=\"${SAVE_EVERY:-5000}\"\n" +
        "EVAL_EVERY=\"${EVAL_EVERY:-2500}\"\n" +
        "MODEL_TAG=\"${MODEL_TAG:-clm1b}\"\n" +
        "ROUND=\"${ROUND:-4}\"\n" +
        "CKPT_DIR=\"${CKPT_DIR:-/workspace/ckpt_clm1b_r4}\"\n" +
        "CORPUS=\"${CORPUS:-/workspace/corpus_clm_r4.txt}\"\n" +
        "CONFIG=\"${CONFIG:-/workspace/anima/training/clm_1b_config.json}\"\n" +
        "TRAINER=\"${TRAINER:-/workspace/anima/training/train_clm_1b.py}\"\n" +
        "R2_PREFIX=\"${R2_PREFIX:-r2:anima-models/clm1b/r4/}\"\n" +
        "\n" +
        "echo \"[config] STEPS=$STEPS BATCH=$BATCH SEQ=$SEQ LR_MAX=$LR_MAX WARMUP=$WARMUP\"\n" +
        "echo \"[config] SAVE_EVERY=$SAVE_EVERY EVAL_EVERY=$EVAL_EVERY MODEL_TAG=$MODEL_TAG ROUND=$ROUND\"\n" +
        "echo \"[config] CKPT_DIR=$CKPT_DIR\"\n" +
        "echo \"[config] CORPUS=$CORPUS\"\n" +
        "echo \"[config] CONFIG=$CONFIG\"\n" +
        "echo \"[config] R2_PREFIX=$R2_PREFIX\"\n" +
        "\n" +
        // ── Preflight 1: GPU ──
        "echo \"[preflight] checking GPU...\"\n" +
        "nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv,noheader\n" +
        "GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader | head -n1)\n" +
        "if ! echo \"$GPU_NAME\" | grep -qi 'H100'; then\n" +
        "    echo \"[preflight] FAIL: r4 requires H100 (found: $GPU_NAME). Refusing to launch.\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] OK: $GPU_NAME\"\n" +
        "\n" +
        // ── Preflight 2: Corpus ──
        "echo \"[preflight] checking corpus...\"\n" +
        "if [[ ! -f \"$CORPUS\" ]]; then\n" +
        "    echo \"[preflight] FAIL: corpus missing at $CORPUS\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "CORPUS_BYTES=$(stat -c%s \"$CORPUS\" 2>/dev/null || stat -f%z \"$CORPUS\")\n" +
        "echo \"[preflight] corpus bytes: $CORPUS_BYTES (~$((CORPUS_BYTES / 1024 / 1024 / 1024)) GB)\"\n" +
        "if (( CORPUS_BYTES < 4500000000 )); then\n" +
        "    echo \"[preflight] FAIL: corpus < 4.5 GB; r4 plan requires ~5 GB\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "\n" +
        // ── Preflight 3: Trainer + config ──
        "echo \"[preflight] checking trainer + config...\"\n" +
        "if [[ ! -f \"$TRAINER\" ]]; then echo \"[preflight] FAIL: trainer missing: $TRAINER\"; exit 1; fi\n" +
        "if [[ ! -f \"$CONFIG\" ]]; then echo \"[preflight] FAIL: config missing: $CONFIG\"; exit 1; fi\n" +
        "ls -lh \"$TRAINER\" \"$CONFIG\"\n" +
        "\n" +
        // ── Preflight 4: MFS quota dd test (per training/CLAUDE.md runpod_mfs_quota) ──
        "echo \"[preflight] MFS quota dd probe (20 GB) -- per runpod_mfs_quota golden rule\"\n" +
        "if ! dd if=/dev/zero of=/workspace/_q_test bs=1M count=20000 status=none; then\n" +
        "    echo \"[preflight] FAIL: dd quota probe failed -- run rm -rf /workspace/ckpt_* and retry\"\n" +
        "    rm -f /workspace/_q_test 2>/dev/null || true\n" +
        "    exit 1\n" +
        "fi\n" +
        "rm -f /workspace/_q_test\n" +
        "echo \"[preflight] OK: 20 GB MFS write succeeded\"\n" +
        "\n" +
        // ── Preflight 5: Disk free + clean stale ckpts (R3 absolute rule) ──
        "echo \"[preflight] /workspace usage:\"\n" +
        "du -sh /workspace 2>/dev/null || true\n" +
        "df -h /workspace\n" +
        "echo \"[preflight] cleaning stale CLM checkpoint dirs (data changed -> no resume)\"\n" +
        "for d in /workspace/ckpt_clm1b_r3 /workspace/ckpt_clm1b /workspace/ckpt_clm_byte_kr /workspace/ckpt_clm_*; do\n" +
        "    if [[ -d \"$d\" && \"$d\" != \"$CKPT_DIR\" ]]; then\n" +
        "        echo \"[preflight]   rm -rf $d\"\n" +
        "        rm -rf \"$d\"\n" +
        "    fi\n" +
        "done\n" +
        "\n" +
        // ── Preflight 6: Fresh ckpt dir ──
        "rm -rf \"$CKPT_DIR\"\n" +
        "mkdir -p \"$CKPT_DIR\"\n" +
        "echo \"[preflight] fresh ckpt dir: $CKPT_DIR\"\n" +
        "\n" +
        // ── Preflight 7: Python deps sanity ──
        "echo \"[preflight] python deps sanity\"\n" +
        "python3 -c 'import torch; print(\"torch:\", torch.__version__, \"cuda:\", torch.cuda.is_available())'\n" +
        "python3 -c 'import torch; assert torch.cuda.is_available(), \"CUDA missing\"; print(\"sm:\", torch.cuda.get_device_capability())'\n" +
        "\n" +
        // ── Env: bf16 + alloc tuning + R1/R4/R9 enforcement ──
        "export PYTHONUNBUFFERED=1\n" +
        "export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True\n" +
        "export CUBLAS_WORKSPACE_CONFIG=\":4096:8\"\n" +
        "export ANIMA_ROOT=/workspace/anima\n" +
        "export HF_HOME=/workspace/hf_cache\n" +
        "\n" +
        // ── Launch (no in-training R2 upload; queue for post-run rclone) ──
        "echo \"[launch] firing train_clm_1b.py at $(date -u +%FT%TZ)\"\n" +
        "python3 \"$TRAINER\" \\\n" +
        "    --config \"$CONFIG\" \\\n" +
        "    --corpus \"$CORPUS\" \\\n" +
        "    --steps \"$STEPS\" \\\n" +
        "    --batch \"$BATCH\" \\\n" +
        "    --seq \"$SEQ\" \\\n" +
        "    --lr \"$LR_MAX\" \\\n" +
        "    --warmup \"$WARMUP\" \\\n" +
        "    --save-every \"$SAVE_EVERY\" \\\n" +
        "    --eval-every \"$EVAL_EVERY\" \\\n" +
        "    --ckpt-dir \"$CKPT_DIR\" \\\n" +
        "    --model-tag \"$MODEL_TAG\" \\\n" +
        "    --round \"$ROUND\" \\\n" +
        "    2>&1 | tee \"$CKPT_DIR/train_r4.log\"\n" +
        "\n" +
        // ── Post-training: deferred R2 upload queue (per runpod_mfs_quota mandatory) ──
        "echo \"[done] training process exited at $(date -u +%FT%TZ)\"\n" +
        "echo \"[r2-queue] writing deferred upload manifest (no in-training upload)\"\n" +
        "cat > \"$CKPT_DIR/_r2_upload_queue.json\" <<EOF\n" +
        "{\n" +
        "  \"model_tag\": \"$MODEL_TAG\",\n" +
        "  \"round\": $ROUND,\n" +
        "  \"local_dir\": \"$CKPT_DIR\",\n" +
        "  \"r2_prefix\": \"$R2_PREFIX\",\n" +
        "  \"upload_cmd\": \"rclone copy $CKPT_DIR $R2_PREFIX -v --s3-no-check-bucket\",\n" +
        "  \"created_at\": \"$(date -u +%FT%TZ)\",\n" +
        "  \"note\": \"Run the upload_cmd MANUALLY after verifying ckpts are intact\"\n" +
        "}\n" +
        "EOF\n" +
        "echo \"[r2-queue] manifest -> $CKPT_DIR/_r2_upload_queue.json\"\n" +
        "echo \"\"\n" +
        "echo \"[next] Manual R2 upload (do NOT run during training):\"\n" +
        "echo \"         rclone copy $CKPT_DIR $R2_PREFIX -v --s3-no-check-bucket\"\n" +
        "echo \"[next] Then verify and clean local:\"\n" +
        "echo \"         rclone ls $R2_PREFIX\"\n" +
        "echo \"         rm -rf $CKPT_DIR/step_* (keep only training_summary.json + latest)\"\n" +
        "echo \"[next] Eval the final ckpt:\"\n" +
        "echo \"         python3 /workspace/anima/training/eval_clm.py --ckpt $CKPT_DIR/step_$STEPS\"\n"
    )
    exec("bash " + runner)
}

main()
