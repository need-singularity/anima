// ── Utility ───────────────────────────────────────────────────────────

fn env_or(key: string, fallback: string) -> string {
    let v = env(key)
    if v == "" { return fallback }
    return v
}

fn now_epoch() -> string {
    return exec("date +%s").trim()
}

fn now_iso() -> string {
    return exec("date -u +%Y%m%dT%H%M%SZ").trim()
}

fn stamp_step(label: string, log_path: string) {
    let line = "[" + now_epoch() + "] " + label
    println(line)
    append_file(log_path, line + "\n")
}

fn abort(code: int, msg: string) {
    println("")
    println("FAIL: " + msg)
    println("  exit code = " + str(code))
    println("")
    exit(code)
}

// ── ssh / scp helpers ─────────────────────────────────────────────────

// Build "ssh user@ip -p port" prefix, using POD_IP/POD_PORT when resolved.
// When POD_IP is empty we fall back to a raw runpodctl ssh alias `root@<pod>`.
fn ssh_base(ip: string, port: string) -> string {
    if ip == "" { return "ssh root@POD_IP_UNRESOLVED" }
    // LogLevel=ERROR suppresses "Warning: Permanently added ..." hostkey notice on stderr;
    // that warning otherwise contaminates rc parsing in exec_with_status (false positive
    // FAIL_MFS_QUOTA etc.). Fix: 2026-04-18.
    let opts = " -o LogLevel=ERROR -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10"
    if port == "" || port == "22" {
        return "ssh" + opts + " root@" + ip
    }
    return "ssh" + opts + " -p " + port + " root@" + ip
}

fn scp_base(ip: string, port: string) -> string {
    if ip == "" { return "scp POD_IP_UNRESOLVED" }
    // Same LogLevel=ERROR fix as ssh_base — suppress hostkey warning on stderr.
    let opts = " -o LogLevel=ERROR -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10"
    if port == "" || port == "22" {
        return "scp" + opts
    }
    return "scp" + opts + " -P " + port
}

// runpodctl lookup — returns "ip:port" or "" on failure.
// Shell does the parsing so we avoid char-level string math (multibyte-safe rule).
fn lookup_pod(pod_id: string) -> string {
    if pod_id == "" { return "" }
    // runpodctl get pod <id> prints a line like: "ssh root@1.2.3.4 -p 54321"
    let ip_cmd = "runpodctl get pod " + pod_id
        + " 2>/dev/null | grep -oE 'root@[^ ]+' | head -1 | sed 's/root@//'"
    let port_cmd = "runpodctl get pod " + pod_id
        + " 2>/dev/null | grep -oE -- '-p [0-9]+' | head -1 | awk '{print $2}'"
    let ip = exec(ip_cmd).trim()
    let port = exec(port_cmd).trim()
    if ip == "" { return "" }
    if port == "" { return ip + ":22" }
    return ip + ":" + port
}

// ── Exec wrapper with logging ─────────────────────────────────────────

fn run_step(n: int, label: string, cmd: string, dry: bool, log_path: string) -> int {
    stamp_step("step " + str(n) + " START — " + label, log_path)
    println("    $ " + cmd)
    append_file(log_path, "    $ " + cmd + "\n")
    if dry {
        stamp_step("step " + str(n) + " SKIP (dry-run)", log_path)
        return 0
    }
    // exec_with_status returns [stdout, exit_code] (hexa-lang runtime.c hexa_exec_with_status).
    // The rc is element [1]; [0] is the captured stdout. Treating the array as an int is
    // what caused FAIL_MFS_QUOTA false positive on 2026-04-18 ("rc=[, 0]").
    let result = exec_with_status(cmd)
    let rc = result[1]
    stamp_step("step " + str(n) + " END — rc=" + str(rc), log_path)
    return rc
}

