// alm14b_r10b_bootstrap.hexa — on-pod r10b bootstrap (warm-start from r10/step_2000 R2)
//
// r10b is the REFINEMENT sibling of r10.  Bootstrap diffs vs alm14b_r10_bootstrap.hexa:
//   1. Downloads r10/step_2000 adapter from R2 → /workspace/ckpt_r10_step2000/
//      (r10b explicitly refuses to warm-start off a collapsed r10 — see step 3 below).
//   2. Runs kr_gen_sentinel on r10's kr_gen log BEFORE launching r10b trainer.
//      If VERDICT=COLLAPSED, bootstrap exits 2 and sets r10_sentinel_pass=false
//      in /workspace/ckpt_alm_14b_r10b/sentinel_pre.log.  Autopilot's queue gate
//      `r10_sentinel_pass` reads this file.
//   3. Launches r10b via /workspace/anima/training/launch_alm_14b_r10b.hexa.
//   4. On completion, R2 upload → r2:anima-models/alm14b/r10b/step_N/   (5 step dirs)
//
// Prerequisites on pod (mostly inherited from r10 pod — if r10b runs on a fresh
// pod after r10 teardown, bootstrap re-downloads base + adapter from R2):
//   - /workspace/base_model/                 (Qwen2.5-14B-Instruct)  [can re-pull]
//   - /workspace/ckpt_r10_step2000/          (r10 LoRA adapter)      [R2 download]
//   - /workspace/corpus_alm_70b_stripped.txt (stripped corpus)       [R2 backup OK]
//   - /workspace/kowiki.jsonl  (OPTIONAL — concat if present, else skip)
//   - /usr/local/bin/hexa
//   - /usr/bin/rclone
//
// Usage (on pod):
//   hexa run /workspace/alm14b_r10b_bootstrap.hexa production      # 2000 steps
//   hexa run /workspace/alm14b_r10b_bootstrap.hexa smoke           # 200 steps
//   DRY_RUN=1 hexa run /workspace/alm14b_r10b_bootstrap.hexa production  # print plan, no exec

fn main() {
    let argv = args()
    let argc = len(argv)
    let mode = if argc >= 2 { argv[1] } else { "production" }

    if mode != "smoke" && mode != "production" {
        println("usage: alm14b_r10b_bootstrap.hexa <smoke|production>")
        exit(2)
    }

    let dry = env("DRY_RUN")
    let dry_run = dry == "1"

    let script = "/tmp/_alm14b_r10b_bootstrap.sh"
    write_file(script,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "MODE=\"" + mode + "\"\n" +
        (if dry_run { "DRY_RUN=1\n" } else { "DRY_RUN=0\n" }) +
        "echo \"================================================================\"\n" +
        "echo \"  ALM 14B r10b bootstrap — mode=$MODE (warm-start r10, phi-hook ON)\"\n" +
        "echo \"  dry_run=$DRY_RUN\"\n" +
        "echo \"================================================================\"\n" +
        "\n" +
        "# ── 1. MFS quota preflight ──\n" +
        "echo \"[preflight] MFS quota probe (20 GB dd)...\"\n" +
        "if ! dd if=/dev/zero of=/workspace/_q_test bs=1M count=20000 status=none 2>/dev/null; then\n" +
        "    echo \"[ABORT] MFS quota probe failed\"; rm -f /workspace/_q_test; exit 1\n" +
        "fi\n" +
        "rm -f /workspace/_q_test\n" +
        "echo \"  MFS quota OK\"\n" +
        "\n" +
        "# ── 2. Download r10/step_2000 adapter from R2 (if absent) ──\n" +
        "ADAPTER=/workspace/ckpt_r10_step2000\n" +
        "if [[ ! -d \"$ADAPTER\" ]] || [[ ! -f \"$ADAPTER/adapter_model.safetensors\" ]]; then\n" +
        "    echo \"[r10b] downloading r10/step_2000 adapter from R2 ...\"\n" +
        "    mkdir -p \"$ADAPTER\"\n" +
        "    rclone copy r2:anima-models/alm14b/r10/step_2000/ \"$ADAPTER/\" -v --s3-no-check-bucket --transfers 4 2>&1 | tail -5\n" +
        "    if [[ ! -f \"$ADAPTER/adapter_model.safetensors\" ]]; then\n" +
        "        echo \"[ABORT] R2 adapter download failed — r10 may not have uploaded yet\"\n" +
        "        exit 1\n" +
        "    fi\n" +
        "fi\n" +
        "echo \"[r10b] adapter OK: $(du -sh $ADAPTER | cut -f1)\"\n" +
        "\n" +
        "# ── 3. Download r10's kr_gen log + run sentinel (pre-launch guard) ──\n" +
        "CKPT=/workspace/ckpt_alm_14b_r10b\n" +
        "mkdir -p \"$CKPT\"\n" +
        "SENTINEL_LOG=$CKPT/sentinel_pre.log\n" +
        "R10_KRGEN=$ADAPTER/kr_gen_step_2000.json\n" +
        "# R2 sometimes stores the kr_gen log at the parent of step_N.  Try both.\n" +
        "if [[ ! -f \"$R10_KRGEN\" ]]; then\n" +
        "    rclone copy r2:anima-models/alm14b/r10/step_2000/kr_gen_step_2000.json \"$ADAPTER/\" --s3-no-check-bucket 2>/dev/null || true\n" +
        "fi\n" +
        "if [[ ! -f \"$R10_KRGEN\" ]]; then\n" +
        "    rclone copy r2:anima-models/alm14b/r10/kr_gen_step_2000.json \"$ADAPTER/\" --s3-no-check-bucket 2>/dev/null || true\n" +
        "fi\n" +
        "\n" +
        "SENTINEL_SCRIPT=/workspace/anima/training/kr_gen_sentinel.hexa\n" +
        "[[ -f \"$SENTINEL_SCRIPT\" ]] || SENTINEL_SCRIPT=/workspace/kr_gen_sentinel.hexa\n" +
        "\n" +
        "if [[ -f \"$R10_KRGEN\" ]] && [[ -f \"$SENTINEL_SCRIPT\" ]]; then\n" +
        "    echo \"[sentinel] running kr_gen_sentinel.hexa on r10 step_2000 ...\" | tee \"$SENTINEL_LOG\"\n" +
        "    if hexa run \"$SENTINEL_SCRIPT\" \"$R10_KRGEN\" 2>&1 | tee -a \"$SENTINEL_LOG\"; then\n" +
        "        echo \"r10_sentinel_pass=true\" > \"$CKPT/r10_sentinel_result.txt\"\n" +
        "        echo \"[sentinel] PASS — r10 step_2000 CLEAN\" | tee -a \"$SENTINEL_LOG\"\n" +
        "    else\n" +
        "        echo \"r10_sentinel_pass=false\" > \"$CKPT/r10_sentinel_result.txt\"\n" +
        "        echo \"[sentinel ABORT] r10 step_2000 shows mode collapse — r10b CANNOT warm-start off it\" | tee -a \"$SENTINEL_LOG\"\n" +
        "        echo \"R10_MODE_COLLAPSE\" > \"$CKPT/r10b_abort.status\"\n" +
        "        exit 2\n" +
        "    fi\n" +
        "else\n" +
        "    echo \"[sentinel] WARN — kr_gen log or sentinel script missing; relying on first-batch CE guard\" | tee \"$SENTINEL_LOG\"\n" +
        "    echo \"r10_sentinel_pass=unknown\" > \"$CKPT/r10_sentinel_result.txt\"\n" +
        "fi\n" +
        "\n" +
        "# ── 4. Verify corpus (identical to r10 — feedback_no_resume_data_change) ──\n" +
        "CORPUS=/workspace/corpus_alm_70b_stripped.txt\n" +
        "if [[ ! -f \"$CORPUS\" ]] || [[ $(stat -c%s \"$CORPUS\" 2>/dev/null || echo 0) -lt 1000000 ]]; then\n" +
        "    echo \"[ABORT] stripped corpus missing or too small: $CORPUS\"\n" +
        "    echo \"        Run the r10 strip step first, or restore corpus from R2.\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[corpus] $CORPUS ($(du -sh $CORPUS | cut -f1))\"\n" +
        "\n" +
        "# ── 5. Fresh ckpt dir ──\n" +
        "rm -rf \"$CKPT\" && mkdir -p \"$CKPT\"\n" +
        "# Restore sentinel result (we just deleted it with rm -rf — rerun minimal version)\n" +
        "if [[ -f \"$ADAPTER/kr_gen_step_2000.json\" ]]; then\n" +
        "    echo \"r10_sentinel_pass=true\" > \"$CKPT/r10_sentinel_result.txt\"\n" +
        "fi\n" +
        "echo INIT > \"$CKPT/r10b_watcher.status\"\n" +
        "\n" +
        "# ── 6. Deps (idempotent) ──\n" +
        "python3 -c 'import unsloth, liger_kernel, peft, transformers' 2>/dev/null || \\\n" +
        "    pip install -q peft==0.13.2 transformers==4.45.2 unsloth liger-kernel 2>&1 | tail -3\n" +
        "\n" +
        "# ── 7. Base model + adapter verify ──\n" +
        "[[ -d /workspace/base_model ]]            || { echo \"[ABORT] base_model missing\"; exit 1; }\n" +
        "[[ -f $ADAPTER/adapter_model.safetensors ]] || { echo \"[ABORT] adapter file missing\"; exit 1; }\n" +
        "echo \"[preflight] base + r10 adapter OK\"\n" +
        "\n" +
        "# ── 8. Launch r10b ──\n" +
        "SMOKE_FLAG=\"\"\n" +
        "[[ \"$MODE\" == \"smoke\" ]] && SMOKE_FLAG=\"--smoke\"\n" +
        "LAUNCH=/workspace/anima/training/launch_alm_14b_r10b.hexa\n" +
        "[[ -f \"$LAUNCH\" ]] || { echo \"[ABORT] launcher missing: $LAUNCH\"; exit 1; }\n" +
        "\n" +
        "if [[ \"$DRY_RUN\" == \"1\" ]]; then\n" +
        "    echo \"[DRY_RUN] would: hexa run $LAUNCH $SMOKE_FLAG\"\n" +
        "    echo \"[DRY_RUN] adapter=$ADAPTER corpus=$CORPUS ckpt=$CKPT\"\n" +
        "    echo \"[DRY_RUN] sentinel=$(cat $CKPT/r10_sentinel_result.txt 2>/dev/null || echo unknown)\"\n" +
        "    exit 0\n" +
        "fi\n" +
        "\n" +
        "echo \"[launch] hexa run $LAUNCH $SMOKE_FLAG\"\n" +
        "if ! hexa run \"$LAUNCH\" $SMOKE_FLAG 2>&1 | tee \"$CKPT/bootstrap.log\"; then\n" +
        "    echo \"[r10b] launcher returned non-zero — check log\"\n" +
        "    exit 2\n" +
        "fi\n" +
        "\n" +
        "# ── 9. Post-training R2 upload (production only, after process exits) ──\n" +
        "if [[ \"$MODE\" == \"production\" ]] && [[ ! -f \"$CKPT/r10b_abort.status\" ]]; then\n" +
        "    echo \"[R2 upload] ckpt_alm_14b_r10b → r2:anima-models/alm14b/r10b/\"\n" +
        "    for stepdir in $CKPT/step_*; do\n" +
        "        [[ -d \"$stepdir\" ]] || continue\n" +
        "        step=$(basename \"$stepdir\")\n" +
        "        echo \"  uploading $step ...\"\n" +
        "        rclone copy \"$stepdir\" \"r2:anima-models/alm14b/r10b/$step/\" -v --s3-no-check-bucket --transfers 4 2>&1 | tail -3\n" +
        "    done\n" +
        "    # Also upload phi_vec.json siblings (already inside step_N dirs — covered above)\n" +
        "    rclone ls r2:anima-models/alm14b/r10b/ 2>&1 | head -30\n" +
        "fi\n" +
        "\n" +
        "echo \"================================================================\"\n" +
        "echo \"  r10b $MODE bootstrap DONE\"\n" +
        "echo \"================================================================\"\n"
    )

    if dry_run {
        println("[r10b-bootstrap] DRY_RUN=1 — writing script only, will still exec with DRY_RUN propagation")
    }

    exec("bash " + script)
}

main()
