// ═══════════════════════════════════════════════════════════════
//  train_gpu_real_extern.hexa — declares real CUDA/cuBLAS extern fns
//
//  Purpose: validate that self/build_c.hexa emits a C file whose
//  EXTERN DECLARATIONS match the actual cuBLAS / cudart ABI byte-for-
//  byte. The compile step on mac will SUCCEED (extern decls don't need
//  the symbols at compile time, only at link time). Linker step is
//  expected to FAIL on mac (no libcublas) — we look at the comment
//  `/* hexa @link libs: -lcudart -lcublas */` to confirm the linker
//  recipe is correct.
//
//  On H100 the same source compiles AND links, becoming a real
//  pure-hexa GPU training step (no C shim).
// ═══════════════════════════════════════════════════════════════

// ── CUDA Runtime ───────────────────────────────────────────────
// int cudaSetDevice(int device);
@link("cudart")
extern fn cudaSetDevice(device: int) -> int

// cudaError_t cudaMalloc(void** devPtr, size_t size);
@link("cudart")
extern fn cudaMalloc(ptr_ptr: long, size: long) -> int

// cudaError_t cudaFree(void* devPtr);
@link("cudart")
extern fn cudaFree(dev_ptr: long) -> int

// cudaError_t cudaMemcpy(void* dst, const void* src, size_t count, int kind);
@link("cudart")
extern fn cudaMemcpy(dst: long, src: long, n: long, kind: int) -> int

// cudaError_t cudaDeviceSynchronize(void);
@link("cudart")
extern fn cudaDeviceSynchronize() -> int

// ── cuBLAS ────────────────────────────────────────────────────
// cublasStatus_t cublasCreate_v2(cublasHandle_t* handle_);
@link("cublas")
extern fn cublasCreate_v2(handle_out: long) -> int

// cublasStatus_t cublasDestroy_v2(cublasHandle_t handle_);
@link("cublas")
extern fn cublasDestroy_v2(handle_: long) -> int

// cublasStatus_t cublasSgemm_v2(
//     cublasHandle_t h, cublasOperation_t ta, cublasOperation_t tb,
//     int m, int n, int k,
//     const float *alpha, const float *A, int lda,
//                         const float *B, int ldb,
//     const float *beta,  float *C, int ldc);
//
// On the hexa side this is 14 args. We pass everything as int (long
// 64-bit word) and the C side reinterprets:
//   - cublasHandle_t = void*
//   - cublasOperation_t = int (0=N, 1=T)
//   - alpha/beta/A/B/C = float*  (passed as raw addresses)
@link("cublas")
extern fn cublasSgemm_v2(h: long, ta: int, tb: int, m: int, n: int, k: int, alpha: long, A: long, lda: int, B: long, ldb: int, beta: long, C: long, ldc: int) -> int

// ── Constants ────────────────────────────────────────────────
let CUDA_MEMCPY_H_TO_D = 1
let CUDA_MEMCPY_D_TO_H = 2
let CUBLAS_OP_N = 0
let CUBLAS_OP_T = 1

// ── Stub init: would do real cudaMalloc on H100 ──────────────
// On mac this is just a sanity check that the call dispatch path
// works (the linker resolves cudaSetDevice symbol when -lcudart is
// available; otherwise fails as expected).
fn gpu_init() {
    // Make a dummy call so the linker actually tries to resolve the symbol
    let rc = cudaSetDevice(0)
    return rc
}

fn main() {
    println("=== train_gpu_real_extern: declaration-only build ===")
    println("(extern fns declared; on H100 with -lcudart -lcublas this links)")
    let rc = gpu_init()
    println("cudaSetDevice rc=", rc)
    println("=== DONE ===")
}

let _ = main()
