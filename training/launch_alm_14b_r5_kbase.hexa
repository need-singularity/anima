// launch_alm_14b_r5_kbase.hexa — ALM 14B-class r5 LoRA (Korean base SWAP)
//                              on RunPod H100 80GB
//
// r4 (Qwen2.5-14B-Instruct) reached eval_loss 0.0289 but Korean generation
// is incoherent. This launcher pivots to a Korean-pretrained base.
//
// Base swap (vs r4):
//   - base:         Qwen/Qwen2.5-14B-Instruct  ->  beomi/OPEN-SOLAR-KO-10.7B
//   - model_tag:    alm14b                     ->  alm14b_kbase
//   - round:        4                          ->  5
//   - ckpt_dir:     /workspace/ckpt_alm_14b_r4 ->  /workspace/ckpt_alm_14b_r5_kbase
//
// Run on RunPod H100 80GB:
//   1. Confirm r4 generation is still incoherent at step 4000+.
//   2. echo "r4 gen incoherent at step N" > /workspace/READY_FOR_R5_KBASE
//   3. scp this script to /workspace/
//   4. hexa launch_alm_14b_r5_kbase.hexa

fn main() {
    let runner = "/tmp/_launch_alm_14b_r5_kbase_runner.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "\n" +
        "echo \"================================================\"\n" +
        "echo \"  ALM 14B r5 kbase -- LoRA r=64 alpha=128, Korean\"\n" +
        "echo \"  base: beomi/OPEN-SOLAR-KO-10.7B (Apache-2.0)\"\n" +
        "echo \"================================================\"\n" +
        "\n" +
        "MARKER=\"/workspace/READY_FOR_R5_KBASE\"\n" +
        "if [[ ! -f \"$MARKER\" ]]; then\n" +
        "    echo \"[preflight] $MARKER missing\"\n" +
        "    echo \"[preflight]   r5_kbase is human-gated: operator must review r4 generation\"\n" +
        "    echo \"[preflight]   To launch: echo 'r4 gen incoherent ...' > $MARKER\"\n" +
        "    echo \"[preflight]             hexa launch_alm_14b_r5_kbase.hexa\"\n" +
        "    exit 1\n" +
        "fi\n" +
        "echo \"[preflight] trigger marker present: $MARKER\"\n" +
        "cat \"$MARKER\" 2>/dev/null || true\n" +
        "\n" +
        "if [[ -f \"/workspace/READY_FOR_32B\" ]]; then\n" +
        "    echo \"[preflight] BOTH READY_FOR_R5_KBASE AND READY_FOR_32B exist.\"\n" +
        "    echo \"[preflight]   Continuing in 5 s -- Ctrl-C to abort.\"\n" +
        "    sleep 5\n" +
        "fi\n" +
        "\n" +
        "HEXA_BIN=\"${HEXA_BIN:-/usr/local/bin/hexa}\"\n" +
        "HEXA_CFG=\"/workspace/train_alm_14b_r5_kbase.hexa\"\n" +
        "if [[ -x \"$HEXA_BIN\" && -f \"$HEXA_CFG\" ]]; then\n" +
        "    echo \"[preflight] parse-checking $HEXA_CFG ...\"\n" +
        "    \"$HEXA_BIN\" \"$HEXA_CFG\" > /workspace/train_alm_14b_r5_kbase.plan.log 2>&1 || {\n" +
        "        echo \"[preflight] parse failed\"\n" +
        "        cat /workspace/train_alm_14b_r5_kbase.plan.log\n" +
        "        exit 1\n" +
        "    }\n" +
        "    echo \"[preflight] hexa config OK\"\n" +
        "else\n" +
        "    echo \"[preflight] hexa binary or config missing -- continuing without dry-run\"\n" +
        "fi\n" +
        "\n" +
        "echo \"[preflight] checking GPU...\"\n" +
        "nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv,noheader\n" +
        "\n" +
        "CORPUS=\"/workspace/anima/training/corpus_large.txt\"\n" +
        "echo \"[preflight] checking corpus...\"\n" +
        "if [[ ! -f \"$CORPUS\" ]]; then echo \"[preflight] corpus missing: $CORPUS\"; exit 1; fi\n" +
        "ls -lh \"$CORPUS\"\n" +
        "\n" +
        "echo \"[preflight] checking disk...\"\n" +
        "df -h /workspace\n" +
        "echo \"[preflight] HF_TOKEN set: ${HF_TOKEN:+yes}\"\n" +
        "\n" +
        "export HF_HUB_CACHE=\"/workspace/hf_cache\"\n" +
        "export HF_HOME=\"/workspace/hf_cache\"\n" +
        "export TRANSFORMERS_CACHE=\"/workspace/hf_cache\"\n" +
        "\n" +
        "QWEN14_CACHE=\"/workspace/hf_cache/models--Qwen--Qwen2.5-14B-Instruct\"\n" +
        "QWEN32_CACHE=\"/workspace/hf_cache/models--Qwen--Qwen2.5-32B-Instruct\"\n" +
        "SOLARKO_CACHE=\"/workspace/hf_cache/models--beomi--OPEN-SOLAR-KO-10.7B\"\n" +
        "if [[ -d \"$QWEN14_CACHE\" ]]; then echo \"[preflight] Qwen2.5-14B cache: $(du -sh \"$QWEN14_CACHE\" 2>/dev/null | awk '{print $1}')\"; fi\n" +
        "if [[ -d \"$QWEN32_CACHE\" ]]; then echo \"[preflight] Qwen2.5-32B cache: $(du -sh \"$QWEN32_CACHE\" 2>/dev/null | awk '{print $1}')\"; fi\n" +
        "if [[ -d \"$SOLARKO_CACHE\" ]]; then\n" +
        "    echo \"[preflight] OPEN-SOLAR-KO pre-staged: $(du -sh \"$SOLARKO_CACHE\" 2>/dev/null | awk '{print $1}')\"\n" +
        "else\n" +
        "    echo \"[preflight] OPEN-SOLAR-KO NOT pre-staged -- will download ~22 GB\"\n" +
        "    AVAIL=$(df -BG /workspace | awk 'NR==2 {print $4}' | tr -d 'G')\n" +
        "    if [[ \"$AVAIL\" -lt 30 ]]; then\n" +
        "        echo \"[preflight] only ${AVAIL} GB free -- need ~30 GB\"\n" +
        "        exit 1\n" +
        "    fi\n" +
        "fi\n" +
        "\n" +
        "CKPT_DIR=\"/workspace/ckpt_alm_14b_r5_kbase\"\n" +
        "rm -rf \"$CKPT_DIR\"\n" +
        "mkdir -p \"$CKPT_DIR\"\n" +
        "\n" +
        "python3 /workspace/anima/training/train_alm_14b.py \\\n" +
        "    --base beomi/OPEN-SOLAR-KO-10.7B \\\n" +
        "    --corpus \"$CORPUS\" \\\n" +
        "    --steps 10000 \\\n" +
        "    --lr 5e-6 \\\n" +
        "    --batch 1 \\\n" +
        "    --grad-accum 8 \\\n" +
        "    --seq 1024 \\\n" +
        "    --warmup 500 \\\n" +
        "    --lora-r 64 \\\n" +
        "    --lora-alpha 128 \\\n" +
        "    --lora-dropout 0.05 \\\n" +
        "    --target-modules q_proj k_proj v_proj o_proj gate_proj up_proj down_proj \\\n" +
        "    --ckpt-dir \"$CKPT_DIR\" \\\n" +
        "    --save-every 2000 \\\n" +
        "    --eval-every 500 \\\n" +
        "    --model-tag alm14b_kbase \\\n" +
        "    --round 5 \\\n" +
        "    2>&1 | tee \"$CKPT_DIR/train_r5_kbase.log\"\n" +
        "\n" +
        "echo \"[done] 14B r5 kbase training complete -- check $CKPT_DIR\"\n" +
        "echo \"[next] hexa eval_alm_14b.hexa --ckpt $CKPT_DIR/step_10000\"\n"
    )

    exec("bash " + runner)
}

main()
