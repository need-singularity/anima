// launch_alm_r4.hexa — ALM 14B r4 LoRA training (RunPod H100)
//
// r4 changes vs r3:
//   - lora_r: 32 -> 64  (2x capacity)
//   - lora_alpha: 64 -> 128  (keep 2:1 ratio)
//   - target_modules: +gate_proj +up_proj +down_proj (MLP layers)
//   - starts from step 0 (data/param change = full restart)
//
// r3 diagnosis: eval plateau at 3.7-3.8 = LoRA capacity limit
//   (only 4 attn modules, r=32 -> insufficient expressivity)
//
// Run on RunPod H100:
//   1. Wait for r3 to complete
//   2. scp this script to /workspace/
//   3. hexa launch_alm_r4.hexa

fn main() {
    let runner = "/tmp/_launch_alm_r4_runner.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "\n" +
        "echo \"============================================\"\n" +
        "echo \"  ALM 14B r4 -- LoRA r=64, attn+MLP\"\n" +
        "echo \"============================================\"\n" +
        "\n" +
        "echo \"[preflight] checking GPU...\"\n" +
        "nvidia-smi --query-gpu=name,memory.total --format=csv,noheader\n" +
        "echo \"[preflight] checking corpus...\"\n" +
        "ls -lh /workspace/corpus.txt\n" +
        "echo \"[preflight] checking disk...\"\n" +
        "df -h /workspace\n" +
        "echo \"[preflight] HF_TOKEN set: ${HF_TOKEN:+yes}\"\n" +
        "\n" +
        "CKPT_DIR=\"/workspace/ckpt_alm_14b_r4\"\n" +
        "rm -rf \"$CKPT_DIR\"\n" +
        "mkdir -p \"$CKPT_DIR\"\n" +
        "\n" +
        "python3 /workspace/anima/training/train_alm_14b.py \\\n" +
        "    --corpus /workspace/corpus.txt \\\n" +
        "    --steps 10000 \\\n" +
        "    --lr 5e-6 \\\n" +
        "    --lora-r 64 \\\n" +
        "    --lora-alpha 128 \\\n" +
        "    --target-modules q_proj k_proj v_proj o_proj gate_proj up_proj down_proj \\\n" +
        "    --ckpt-dir \"$CKPT_DIR\" \\\n" +
        "    --save-every 2000 \\\n" +
        "    --eval-every 500 \\\n" +
        "    --model-tag alm14b \\\n" +
        "    --round 4 \\\n" +
        "    2>&1 | tee \"$CKPT_DIR/train_r4.log\"\n" +
        "\n" +
        "echo \"[done] r4 training complete -- check $CKPT_DIR\"\n" +
        "echo \"[next] hexa eval_alm_14b.hexa --ckpt $CKPT_DIR/step_10000\"\n"
    )

    exec("bash " + runner)
}

main()
