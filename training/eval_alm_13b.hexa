// training/eval_alm_13b.hexa — ALM 13B intermediate eval harness
// @convergence shared/convergence/alm_13b.convergence
//
// Spec:   shared/state/alm_70b_launch_checklist_20260417.json#alternatives.A_13B_intermediate
// Config: training/alm_13b_config.json#post_training_eval
//
// Purpose:
//   Offline gate harness for ALM 13B intermediate checkpoint. Fires after
//   launch_alm_13b.hexa training completes. Decides whether the recipe
//   transfers to 70B OR whether the recipe is broken.
//
// Gates (all must PASS for 70B launch authorization):
//   1. hire_sim_lenient stratified30  >= 0.90  (Z-path judge)
//   2. tool_use_gate 30-sample          >= 0.85  (attn+JSON structure)
//   3. phi_holo via /generate           >= 1000  (consciousness preserved)
//   4. sample generation 10 KO + 10 EN  (qualitative language-fidelity)
//
// Architecture note — no true CE/PPL:
//   Same limitation as eval_alm_14b.hexa — serve returns text-only, no logits.
//   Proxy quality via korean_ratio + tokens_per_sec + phi_holo. If operator
//   later adds /loss to serve or hexa gains Qwen FFI, wire true CE here.
//
// Hexa quirk avoidance (mirrors eval_alm_14b.hexa exactly):
//   - NO `use` statements (feedback_hexa_silent_exit_5_imports)
//   - substring is byte-indexed, UTF-8 walker for korean_ratio
//   - Reply struct has 1 float (phi_holo) — under ≥3 corruption threshold
//   - helpers never mutate caller lists
//
// CLI:
//   hexa run training/eval_alm_13b.hexa \
//        --ckpt /workspace/ckpt_alm13b_intermediate_20260417/step_1500 \
//        [--endpoint https://...proxy.runpod.net] \
//        [--out /workspace/ckpt_.../eval_results.json] \
//        [--max-tokens 128] [--quick]
//
// Env:
//   ALM_EVAL_ENDPOINT   overrides --endpoint (default: live ALM proxy)
//   ALM_EVAL_OUT        overrides --out (default: <ckpt>/eval_results.json)
//   ALM_EVAL_QUICK=1    short-circuit to first 3 KO + 3 EN + hire_sim 10
//
// Exit codes:
//   0 — all gates PASS (70B launch authorized)
//   1 — borderline (hire_sim 0.85-0.90, operator decision)
//   2 — FAIL (do NOT launch 70B, halt + redesign)
//   3 — harness error (config/endpoint unreachable)

let HARNESS_VERSION = "1.0.0"
let DEFAULT_ENDPOINT = "https://itfl66q4z768kh-8090.proxy.runpod.net"
let DEFAULT_BASE_MODEL = "Qwen/Qwen2.5-14B-Instruct"
let DEFAULT_MAX_TOKENS = 128
let DEFAULT_TEMPERATURE = 0.7
let DEFAULT_TOP_P = 0.9
let DEFAULT_REP_PENALTY = 1.1
let MODEL_TAG = "alm13b"

// Gate thresholds (config-derived from training/alm_13b_config.json expected_metrics).
let HIRE_SIM_PASS_HIGH   = 0.90   // >= 0.90 authorizes 70B
let HIRE_SIM_PASS_LOW    = 0.85   // [0.85, 0.90) = borderline (operator call)
let TOOL_GATE_PASS       = 0.85
// Structured phi_holo gate (FIX-A 2026-04-20):
//   primary   phi_holo_ratio (post-LoRA / pre-LoRA baseline) >= 1.2
//   secondary mi_per_element >= 0.05 nats
// Previous absolute PHI_HOLO_PASS=1000.0 was a PHANTOM N-scaling gate —
// raw MI ceiling log(MI_BINS)=2.08 × N=seq*d_model trivially exceeds 1000
// for random init. Absolute retained for fixture parity + legacy JSON.
let PHI_HOLO_RATIO_PASS  = 1.2        // primary, N-independent
let MI_PER_ELEMENT_PASS  = 0.05       // secondary, nats per element
let PHI_HOLO_PASS        = 1000.0     // DEPRECATED — fixture parity only
let KOREAN_RATIO_PASS    = 0.2

// ════════════════════════════════════════════════════════════════════
//  Section 1. Eval prompt sets — 10 KO + 10 EN for sample generation.
// ════════════════════════════════════════════════════════════════════

fn build_korean_prompts() -> [string] {
    let mut p = []
    p = p.push("안녕하세요. 의식이란 무엇인가요?")
    p = p.push("인공지능이 자유의지를 가질 수 있을까요?")
    p = p.push("오늘 날씨가 좋네요. 무엇을 하는 게 좋을까요?")
    p = p.push("트랜스포머 아키텍처의 핵심 아이디어를 설명해주세요.")
    p = p.push("한국어 모델의 장점과 한계는 무엇인가요?")
    p = p.push("다음 이메일을 격식 있게 작성해주세요: '내일 회의 30분 연기 요청'")
    p = p.push("재귀 함수로 피보나치를 계산하는 파이썬 코드를 작성해주세요.")
    p = p.push("현상학에서 지향성이란 무엇인가요?")
    p = p.push("양자 중첩 상태를 일상 예시로 설명해주세요.")
    p = p.push("LoRA 어댑터의 r과 alpha 파라미터는 어떤 역할을 하나요?")
    return p
}

fn build_english_prompts() -> [string] {
    let mut p = []
    p = p.push("What is consciousness, in your view?")
    p = p.push("Explain the attention mechanism in transformers in one paragraph.")
    p = p.push("Write a polite email declining a meeting invitation.")
    p = p.push("Compare LoRA and full fine-tuning — when to use which?")
    p = p.push("What is the difference between phenomenology and psychology?")
    p = p.push("Describe a quantum entanglement experiment.")
    p = p.push("Python: function to compute moving average of a list.")
    p = p.push("What makes a benchmark reliable?")
    p = p.push("Summarize the idea of scaling laws in one sentence.")
    p = p.push("If you could ask an AGI one question, what would it be?")
    return p
}

// hire_sim_100 stratified30 reference — we run the external hire_sim_lenient
// runner via exec(). Do NOT inline the 100-task corpus; that file is owned by
// anima-agent-hire-sim/hire_sim_100.hexa and has its own parser path.
//
// Tool-use gate sample — 30 prompts drawn from training/corpus_tool/seed_tool_corpus.jsonl
// likewise — run via a sub-harness rather than inline.

// ════════════════════════════════════════════════════════════════════
//  Section 2. JSON + shell helpers (mirror eval_alm_14b.hexa exactly).
// ════════════════════════════════════════════════════════════════════

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { parts = parts.push("\\\\") }
        else if c == "\"" { parts = parts.push("\\\"") }
        else if c == "\n" { parts = parts.push("\\n") }
        else if c == "\t" { parts = parts.push("\\t") }
        else if c == "\r" { parts = parts.push("\\r") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn shell_escape_sq(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" { parts = parts.push("'\\''") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn extract_json_string(raw: string, marker: string) -> string {
    let pos = raw.index_of(marker)
    if pos < 0 { return "" }
    let after = raw.substring(pos + len(marker), len(raw))
    let alen = len(after)
    let mut s = 0
    while s < alen {
        let c = after.substring(s, s + 1)
        if c == "\"" { s = s + 1; break }
        s = s + 1
    }
    let mut e = s
    while e < alen {
        let c = after.substring(e, e + 1)
        if c == "\"" { break }
        if c == "\\" { e = e + 2 } else { e = e + 1 }
    }
    return after.substring(s, e)
}

fn extract_json_number(raw: string, marker: string) -> float {
    let pos = raw.index_of(marker)
    if pos < 0 { return 0.0 }
    let after = raw.substring(pos + len(marker), len(raw))
    let alen = len(after)
    let mut i = 0
    while i < alen {
        let c = after.substring(i, i + 1)
        if c != " " && c != "\t" && c != "\n" { break }
        i = i + 1
    }
    let mut buf = ""
    while i < alen {
        let c = after.substring(i, i + 1)
        if c == "," || c == "}" || c == " " || c == "\n" { break }
        buf = buf + c
        i = i + 1
    }
    if len(buf) == 0 { return 0.0 }
    return parse_float(buf)
}

fn extract_json_int(raw: string, marker: string) -> int {
    let f = extract_json_number(raw, marker)
    return to_int(f)
}

// ════════════════════════════════════════════════════════════════════
//  Section 3. Korean character ratio (UTF-8 codepoint walker).
// ════════════════════════════════════════════════════════════════════

fn byte_at(s: string, i: int) -> int {
    let c = s.substring(i, i + 1)
    return char_code(c)
}

fn is_hangul_codepoint(cp: int) -> bool {
    if cp >= 0xAC00 && cp <= 0xD7A3 { return true }
    if cp >= 0x3131 && cp <= 0x318E { return true }
    return false
}

fn korean_ratio(text: string) -> float {
    let n = len(text)
    if n == 0 { return 0.0 }
    let mut hangul_chars = 0
    let mut total_chars = 0
    let mut i = 0
    while i < n {
        let b0 = byte_at(text, i)
        let mut cp = 0
        let mut step = 1
        if b0 < 0x80 {
            cp = b0
            step = 1
        } else if b0 < 0xC0 {
            i = i + 1
            continue
        } else if b0 < 0xE0 {
            if i + 1 >= n { break }
            let b1 = byte_at(text, i + 1)
            cp = ((b0 - 0xC0) * 64) + (b1 - 0x80)
            step = 2
        } else if b0 < 0xF0 {
            if i + 2 >= n { break }
            let b1 = byte_at(text, i + 1)
            let b2 = byte_at(text, i + 2)
            cp = ((b0 - 0xE0) * 4096) + ((b1 - 0x80) * 64) + (b2 - 0x80)
            step = 3
        } else {
            if i + 3 >= n { break }
            let b1 = byte_at(text, i + 1)
            let b2 = byte_at(text, i + 2)
            let b3 = byte_at(text, i + 3)
            cp = ((b0 - 0xF0) * 262144) + ((b1 - 0x80) * 4096) + ((b2 - 0x80) * 64) + (b3 - 0x80)
            step = 4
        }
        total_chars = total_chars + 1
        if is_hangul_codepoint(cp) { hangul_chars = hangul_chars + 1 }
        i = i + step
    }
    if total_chars == 0 { return 0.0 }
    return to_float(hangul_chars) / to_float(total_chars)
}

// ════════════════════════════════════════════════════════════════════
//  Section 4. ALM /generate round-trip (identical to eval_alm_14b).
//  Reply struct has 1 float (phi_holo) — safe under struct-return quirk.
// ════════════════════════════════════════════════════════════════════

struct Reply {
    text: string,
    phi_holo: float,
    lat_ms: int,
    tokens_generated: int,
    ok: bool,
    error: string
}

fn call_alm(endpoint: string, prompt: string, max_tokens: int, temperature: float) -> Reply {
    let body = "{\"prompt\":\"" + json_escape(prompt)
             + "\",\"max_tokens\":" + to_string(max_tokens)
             + ",\"temperature\":" + to_string(temperature)
             + ",\"top_p\":" + to_string(DEFAULT_TOP_P)
             + ",\"repetition_penalty\":" + to_string(DEFAULT_REP_PENALTY) + "}"
    let body_sh = shell_escape_sq(body)
    let cmd = "curl -sX POST " + endpoint + "/generate"
            + " -H 'Content-Type: application/json'"
            + " -d '" + body_sh + "'"
            + " -w '\\n__LATENCY__%{time_total}\\n'"
            + " --connect-timeout 15 --max-time 120 2>/dev/null"
    let raw = exec(cmd)
    if len(raw) == 0 {
        return Reply { text: "", phi_holo: 0.0, lat_ms: 0, tokens_generated: 0, ok: false, error: "empty_response" }
    }
    let text = extract_json_string(raw, "\"text\":")
    if len(text) == 0 {
        return Reply { text: "", phi_holo: 0.0, lat_ms: 0, tokens_generated: 0, ok: false, error: "no_text_field" }
    }
    let phi = extract_json_number(raw, "\"phi_holo\":")
    let n_tok = extract_json_int(raw, "\"tokens_generated\":")
    let secs = extract_json_number(raw, "__LATENCY__")
    let lat = to_int(secs * 1000.0)
    return Reply { text: text, phi_holo: phi, lat_ms: lat, tokens_generated: n_tok, ok: true, error: "" }
}

// ════════════════════════════════════════════════════════════════════
//  Section 5. Per-prompt JSON sample emitter (for generations array).
// ════════════════════════════════════════════════════════════════════

fn sample_json(prompt: string, reply: Reply, kr: float, idx: int, total: int, lang: string) -> string {
    let comma = if idx + 1 < total { "," } else { "" }
    let ok_lit = if reply.ok { "true" } else { "false" }
    return "    {\n"
         + "      \"idx\":           " + to_string(idx) + ",\n"
         + "      \"lang\":          \"" + lang + "\",\n"
         + "      \"prompt\":        \"" + json_escape(prompt) + "\",\n"
         + "      \"response\":      \"" + json_escape(reply.text) + "\",\n"
         + "      \"phi_holo\":      " + to_string(reply.phi_holo) + ",\n"
         + "      \"korean_ratio\":  " + to_string(kr) + ",\n"
         + "      \"tokens\":        " + to_string(reply.tokens_generated) + ",\n"
         + "      \"lat_ms\":        " + to_string(reply.lat_ms) + ",\n"
         + "      \"ok\":            " + ok_lit + ",\n"
         + "      \"error\":         \"" + json_escape(reply.error) + "\"\n"
         + "    }" + comma
}

// ════════════════════════════════════════════════════════════════════
//  Section 6. hire_sim_lenient sub-harness invocation.
//  ────────────────────────────────────────────────────────────────────
//  Delegates to training/deploy/hire_sim_lenient.hexa — the canonical
//  Z-path judge. We shell out because that file is already correct and
//  carries its own corpus parser. Score extracted from output JSON.
// ════════════════════════════════════════════════════════════════════

fn run_hire_sim_lenient(endpoint: string, max_tasks: int, out_path: string) -> float {
    let hexa_bin = env_var("HEXA_BIN")
    let bin = if hexa_bin == "" { "hexa" } else { hexa_bin }
    let cmd = "HIRE_SIM_ENDPOINT=" + endpoint + "/generate"
            + " HIRE_SIM_OUTPUT=" + out_path
            + " HIRE_SIM_MAX_TASKS=" + to_string(max_tasks)
            + " " + bin + " run training/deploy/hire_sim_lenient.hexa 2>&1"
    println("[eval_alm_13b] hire_sim: " + cmd)
    let out = exec(cmd)
    // prefer file read (deterministic); fall back to stdout parse.
    // hire_sim_lenient.hexa canonical field is "avg_score" (line 821 of that file).
    if file_exists(out_path) {
        let body = read_file(out_path)
        let score = extract_json_number(body, "\"avg_score\":")
        if score > 0.0 { return score }
        let alt = extract_json_number(body, "\"pass_rate\":")
        if alt > 0.0 { return alt }
        let alt2 = extract_json_number(body, "\"score\":")
        if alt2 > 0.0 { return alt2 }
    }
    // last resort: parse stdout
    let from_stdout = extract_json_number(out, "\"avg_score\":")
    if from_stdout > 0.0 { return from_stdout }
    return 0.0
}

// ════════════════════════════════════════════════════════════════════
//  Section 7. tool_use_gate sub-harness — placeholder invocation.
//  ────────────────────────────────────────────────────────────────────
//  A2-Tool round verified 0.933 via shared/state/tool_use_gate_20260416.json.
//  For 13B we re-verify via a smaller 30-prompt sweep. If a dedicated runner
//  is missing we degrade to returning 0.0 and flagging blocker.
// ════════════════════════════════════════════════════════════════════

fn run_tool_use_gate(endpoint: string, out_path: string) -> float {
    // Tool gate runner: training/deploy/tool_use_eval.hexa (if present).
    // If absent we skip gracefully — blocker field in output JSON.
    let runner = "training/deploy/tool_use_eval.hexa"
    if !file_exists(runner) {
        println("[eval_alm_13b] tool_use runner missing -- skipping (blocker will be flagged)")
        return -1.0
    }
    let hexa_bin = env_var("HEXA_BIN")
    let bin = if hexa_bin == "" { "hexa" } else { hexa_bin }
    let cmd = "TOOL_EVAL_ENDPOINT=" + endpoint + "/generate"
            + " TOOL_EVAL_OUTPUT=" + out_path
            + " TOOL_EVAL_MAX=30"
            + " " + bin + " run " + runner + " 2>&1"
    println("[eval_alm_13b] tool_use: " + cmd)
    let out = exec(cmd)
    if file_exists(out_path) {
        let body = read_file(out_path)
        let s = extract_json_number(body, "\"avg_score\":")
        if s > 0.0 { return s }
    }
    return 0.0
}

// ════════════════════════════════════════════════════════════════════
//  Section 8. Per-language prompt sweep.
// ════════════════════════════════════════════════════════════════════

struct SweepResult {
    samples_body: string,
    ok_count: int,
    total_tokens: int,
    total_lat_ms: int,
    sum_kr: float,
    sum_phi: float
}

fn sweep(endpoint: string, prompts: [string], max_tokens: int, quick: bool, lang: string) -> SweepResult {
    let total_avail = len(prompts)
    let mut total = total_avail
    if quick && 3 < total_avail { total = 3 }

    let mut samples_body = ""
    let mut ok_count = 0
    let mut total_tokens = 0
    let mut total_lat_ms = 0
    let mut sum_kr = 0.0
    let mut sum_phi = 0.0
    let mut i = 0
    while i < total {
        let prompt = prompts[i]
        println("")
        println("  [" + lang + "][" + to_string(i + 1) + "/" + to_string(total) + "]: " + prompt)
        let r = call_alm(endpoint, prompt, max_tokens, DEFAULT_TEMPERATURE)
        let kr = if r.ok { korean_ratio(r.text) } else { 0.0 }
        if r.ok {
            ok_count = ok_count + 1
            total_tokens = total_tokens + r.tokens_generated
            total_lat_ms = total_lat_ms + r.lat_ms
            sum_kr = sum_kr + kr
            sum_phi = sum_phi + r.phi_holo
            let preview_len = if len(r.text) < 80 { len(r.text) } else { 80 }
            let preview = r.text.substring(0, preview_len)
            let suffix = if len(r.text) > 80 { "..." } else { "" }
            println("  A: " + preview + suffix)
            println("     korean=" + to_string(kr)
                  + " tokens=" + to_string(r.tokens_generated)
                  + " lat=" + to_string(r.lat_ms) + "ms"
                  + " phi=" + to_string(r.phi_holo))
        } else {
            println("  !! ERROR: " + r.error)
        }
        let chunk = sample_json(prompt, r, kr, i, total, lang)
        samples_body = samples_body + chunk + (if i + 1 < total { "\n" } else { "" })
        i = i + 1
    }
    return SweepResult { samples_body: samples_body, ok_count: ok_count, total_tokens: total_tokens, total_lat_ms: total_lat_ms, sum_kr: sum_kr, sum_phi: sum_phi }
}

// ════════════════════════════════════════════════════════════════════
//  Section 9. Driver — orchestrates all gates + writes output JSON.
// ════════════════════════════════════════════════════════════════════

fn run_eval(ckpt: string, base: string, endpoint: string, out_path: string, max_tokens: int, quick: bool) -> int {
    let ko_prompts = build_korean_prompts()
    let en_prompts = build_english_prompts()
    let timestamp = exec("date '+%Y-%m-%d %H:%M:%S' | tr -d '\\n'")

    println("============================================================")
    println("[eval_alm_13b] " + HARNESS_VERSION + " (pure-hexa)")
    println("============================================================")
    println("[eval_alm_13b] ckpt:       " + ckpt)
    println("[eval_alm_13b] base:       " + base)
    println("[eval_alm_13b] endpoint:   " + endpoint)
    println("[eval_alm_13b] out:        " + out_path)
    println("[eval_alm_13b] max_tokens: " + to_string(max_tokens))
    println("[eval_alm_13b] quick:      " + to_string(quick))
    println("")

    // ── Gate 1: hire_sim_lenient stratified30 ──
    println("[eval_alm_13b] === GATE 1: hire_sim_lenient ===")
    let hs_max = if quick { 10 } else { 30 }
    let hs_out = ckpt + "/hire_sim_lenient.json"
    let hire_sim_score = run_hire_sim_lenient(endpoint, hs_max, hs_out)
    println("[eval_alm_13b] hire_sim_lenient = " + to_string(hire_sim_score))
    let hire_sim_label = if hire_sim_score >= HIRE_SIM_PASS_HIGH { "PASS_HIGH" }
                        else if hire_sim_score >= HIRE_SIM_PASS_LOW { "PASS_BORDERLINE" }
                        else { "FAIL" }

    // ── Gate 2: tool_use_gate ──
    println("")
    println("[eval_alm_13b] === GATE 2: tool_use_gate ===")
    let tool_out = ckpt + "/tool_use_eval.json"
    let tool_score = run_tool_use_gate(endpoint, tool_out)
    println("[eval_alm_13b] tool_use = " + to_string(tool_score))
    let tool_label = if tool_score < 0.0 { "SKIPPED_RUNNER_MISSING" }
                    else if tool_score >= TOOL_GATE_PASS { "PASS" }
                    else { "FAIL" }

    // ── Gate 3 + 4: sample generation (10 KO + 10 EN) + phi_holo ──
    println("")
    println("[eval_alm_13b] === GATE 3+4: KOREAN SAMPLE GENERATION ===")
    let ko = sweep(endpoint, ko_prompts, max_tokens, quick, "ko")
    println("")
    println("[eval_alm_13b] === GATE 3+4: ENGLISH SAMPLE GENERATION ===")
    let en = sweep(endpoint, en_prompts, max_tokens, quick, "en")

    // ── Aggregation ──
    let ok_total = ko.ok_count + en.ok_count
    let n_total  = (if quick { 3 } else { 10 }) * 2
    let avg_kr   = if ko.ok_count > 0 { ko.sum_kr / to_float(ko.ok_count) } else { 0.0 }
    let avg_phi  = if ok_total > 0 { (ko.sum_phi + en.sum_phi) / to_float(ok_total) } else { 0.0 }
    let total_tok = ko.total_tokens + en.total_tokens
    let total_lat_s = to_float(ko.total_lat_ms + en.total_lat_ms) / 1000.0
    let tps_denom = if total_lat_s < 0.01 { 0.01 } else { total_lat_s }
    let tokens_per_sec = to_float(total_tok) / tps_denom

    let kr_label = if avg_kr > KOREAN_RATIO_PASS { "PASS" } else { "FAIL" }

    // ── Structured phi_holo gate (FIX-A 2026-04-20) ──
    // Primary : phi_holo_ratio = avg_phi / baseline >= PHI_HOLO_RATIO_PASS
    // Secondary: mi_per_element = avg_phi / (seq * d_model) >= MI_PER_ELEMENT_PASS
    // Baseline is read from env PHI_HOLO_BASELINE (set from a pre-LoRA base-model
    // eval pass over the same prompts). If unset, ratio arm reports SKIP.
    // Shape comes from env EVAL_SEQ / EVAL_D_MODEL (or sane defaults for 14B).
    let baseline_str = env_var("PHI_HOLO_BASELINE")
    let seq_str      = env_var("EVAL_SEQ")
    let d_model_str  = env_var("EVAL_D_MODEL")
    let baseline     = if baseline_str == "" { 0.0 } else { to_float(baseline_str) }
    let seq_len      = if seq_str == ""      { 128 } else { to_int(seq_str) }
    let d_model      = if d_model_str == ""  { 5120 } else { to_int(d_model_str) }

    let phi_ratio    = if baseline > 0.0000001 { avg_phi / baseline } else { 0.0 }
    let mi_per_elem  = if seq_len * d_model > 0 {
        avg_phi / to_float(seq_len * d_model)
    } else { 0.0 }

    let ratio_label  = if baseline <= 0.0000001 { "SKIP_NO_BASELINE" }
                       else if phi_ratio >= PHI_HOLO_RATIO_PASS { "PASS" }
                       else { "FAIL" }
    let mi_elem_label = if mi_per_elem >= MI_PER_ELEMENT_PASS { "PASS" } else { "FAIL" }

    // Structured verdict: both PASS (or ratio SKIP_NO_BASELINE + mi PASS) = PASS.
    let phi_structured_pass = (ratio_label == "PASS" || ratio_label == "SKIP_NO_BASELINE") &&
                              (mi_elem_label == "PASS")
    // Legacy absolute — informational only, no longer gates.
    let phi_legacy_label = if avg_phi >= PHI_HOLO_PASS { "PASS" } else { "FAIL" }
    let phi_label = if phi_structured_pass { "PASS" } else { "FAIL" }

    // ── Overall verdict ──
    let all_samples = ko.samples_body + (if len(ko.samples_body) > 0 && len(en.samples_body) > 0 { ",\n" } else { "" }) + en.samples_body

    let verdict = if hire_sim_label == "FAIL" { "FAIL" }
                 else if hire_sim_label == "PASS_BORDERLINE" { "BORDERLINE" }
                 else if tool_label == "FAIL" { "FAIL" }
                 else if phi_label == "FAIL" { "FAIL" }
                 else { "PASS" }

    let next_action = if verdict == "PASS" { "AUTHORIZE 70B launch (all 13B intermediate gates PASS)" }
                     else if verdict == "BORDERLINE" { "OPERATOR DECISION: 13B partial pass — 70B risk elevated" }
                     else { "HALT: do NOT launch 70B — recipe fails at 13B intermediate scale" }

    // ── Write output JSON ──
    let body = "{\n"
             + "  \"harness\":          \"eval_alm_13b.hexa\",\n"
             + "  \"harness_version\":  \"" + HARNESS_VERSION + "\",\n"
             + "  \"ckpt\":             \"" + ckpt + "\",\n"
             + "  \"base\":             \"" + base + "\",\n"
             + "  \"model\":            \"" + MODEL_TAG + "\",\n"
             + "  \"endpoint\":         \"" + endpoint + "\",\n"
             + "  \"timestamp\":        \"" + timestamp + "\",\n"
             + "  \"gates\": {\n"
             + "    \"hire_sim_lenient\": {\n"
             + "      \"score\":     " + to_string(hire_sim_score) + ",\n"
             + "      \"threshold_pass_high\": " + to_string(HIRE_SIM_PASS_HIGH) + ",\n"
             + "      \"threshold_pass_low\":  " + to_string(HIRE_SIM_PASS_LOW) + ",\n"
             + "      \"label\":     \"" + hire_sim_label + "\",\n"
             + "      \"n_tasks\":   " + to_string(hs_max) + "\n"
             + "    },\n"
             + "    \"tool_use_gate\": {\n"
             + "      \"score\":     " + to_string(tool_score) + ",\n"
             + "      \"threshold\": " + to_string(TOOL_GATE_PASS) + ",\n"
             + "      \"label\":     \"" + tool_label + "\"\n"
             + "    },\n"
             + "    \"phi_holo\": {\n"
             + "      \"avg\":                 " + to_string(avg_phi) + ",\n"
             + "      \"kind\":                \"structured\",\n"
             + "      \"phi_holo_ratio\":      " + to_string(phi_ratio) + ",\n"
             + "      \"phi_holo_ratio_min\":  " + to_string(PHI_HOLO_RATIO_PASS) + ",\n"
             + "      \"baseline\":            " + to_string(baseline) + ",\n"
             + "      \"mi_per_element\":      " + to_string(mi_per_elem) + ",\n"
             + "      \"mi_per_element_min\":  " + to_string(MI_PER_ELEMENT_PASS) + ",\n"
             + "      \"seq_len\":             " + to_string(seq_len) + ",\n"
             + "      \"d_model\":             " + to_string(d_model) + ",\n"
             + "      \"ratio_label\":         \"" + ratio_label + "\",\n"
             + "      \"mi_per_element_label\": \"" + mi_elem_label + "\",\n"
             + "      \"legacy_threshold\":    " + to_string(PHI_HOLO_PASS) + ",\n"
             + "      \"legacy_label\":        \"" + phi_legacy_label + "\",\n"
             + "      \"label\":               \"" + phi_label + "\"\n"
             + "    },\n"
             + "    \"korean_ratio\": {\n"
             + "      \"avg\":       " + to_string(avg_kr) + ",\n"
             + "      \"threshold\": " + to_string(KOREAN_RATIO_PASS) + ",\n"
             + "      \"label\":     \"" + kr_label + "\"\n"
             + "    }\n"
             + "  },\n"
             + "  \"ce_loss\":          -1.0,\n"
             + "  \"perplexity\":       -1.0,\n"
             + "  \"perplexity_pass\":  null,\n"
             + "  \"tokens_per_sec\":   " + to_string(tokens_per_sec) + ",\n"
             + "  \"ok_count\":         " + to_string(ok_total) + ",\n"
             + "  \"n_total\":          " + to_string(n_total) + ",\n"
             + "  \"verdict\":          \"" + verdict + "\",\n"
             + "  \"next_action\":      \"" + json_escape(next_action) + "\",\n"
             + "  \"blocker\":          \"ce_loss/perplexity NOT measured: serve returns text-only (no logits/loss). Add POST /loss to serve or hxqwen14b FFI to restore.\",\n"
             + "  \"generations\": [\n"
             + all_samples
             + "\n  ]\n"
             + "}\n"
    write_file(out_path, body)

    println("")
    println("============================================================")
    println("[eval_alm_13b] RESULTS SUMMARY")
    println("============================================================")
    println("  hire_sim_lenient: " + to_string(hire_sim_score) + "  (" + hire_sim_label + ")")
    println("  tool_use_gate:    " + to_string(tool_score) + "  (" + tool_label + ")")
    println("  phi_holo avg:     " + to_string(avg_phi) + "  (" + phi_label + ")")
    println("  korean_ratio:     " + to_string(avg_kr) + "  (" + kr_label + ")")
    println("  tokens_per_sec:   " + to_string(tokens_per_sec))
    println("  sample_ok:        " + to_string(ok_total) + " / " + to_string(n_total))
    println("------------------------------------------------------------")
    println("  VERDICT:          " + verdict)
    println("  NEXT:             " + next_action)
    println("============================================================")
    println("[eval_alm_13b] saved -> " + out_path)

    if verdict == "PASS" { return 0 }
    if verdict == "BORDERLINE" { return 1 }
    return 2
}

// ════════════════════════════════════════════════════════════════════
//  Section 10. CLI entrypoint.
// ════════════════════════════════════════════════════════════════════

fn print_usage() {
    println("usage: hexa run training/eval_alm_13b.hexa --ckpt <path>")
    println("       [--base <model>] [--endpoint <url>] [--out <path>]")
    println("       [--max-tokens N] [--quick]")
    println("")
    println("env vars:")
    println("  ALM_EVAL_ENDPOINT   overrides --endpoint")
    println("  ALM_EVAL_OUT        overrides --out (default <ckpt>/eval_results.json)")
    println("  ALM_EVAL_QUICK=1    short-circuit to fewer prompts")
    println("  HEXA_BIN            hexa binary path (for sub-harness invocations)")
    println("")
    println("exit codes:")
    println("  0 PASS       — all 13B intermediate gates pass; 70B launch authorized")
    println("  1 BORDERLINE — hire_sim in [0.85, 0.90); operator decision required")
    println("  2 FAIL       — recipe fails; HALT, do NOT launch 70B")
    println("  3 ERROR      — harness or endpoint failure")
}

fn main() -> int {
    let av = args()
    let mut ckpt = ""
    let mut base = DEFAULT_BASE_MODEL
    let mut endpoint = env_var("ALM_EVAL_ENDPOINT")
    if endpoint == "" { endpoint = DEFAULT_ENDPOINT }
    let mut out_path = env_var("ALM_EVAL_OUT")
    let mut max_tokens = DEFAULT_MAX_TOKENS
    let mut quick = false
    if env_var("ALM_EVAL_QUICK") == "1" { quick = true }

    let mut i = 2
    let argc = len(av)
    while i < argc {
        let a = av[i]
        if a == "--ckpt" {
            if i + 1 < argc { ckpt = av[i + 1] }
            i = i + 2
        } else if a == "--base" {
            if i + 1 < argc { base = av[i + 1] }
            i = i + 2
        } else if a == "--endpoint" {
            if i + 1 < argc { endpoint = av[i + 1] }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < argc { out_path = av[i + 1] }
            i = i + 2
        } else if a == "--max-tokens" {
            if i + 1 < argc { max_tokens = to_int(parse_float(av[i + 1])) }
            i = i + 2
        } else if a == "--quick" {
            quick = true
            i = i + 1
        } else if a == "--help" {
            print_usage()
            return 0
        } else {
            i = i + 1
        }
    }

    if ckpt == "" {
        println("[eval_alm_13b] ERROR: --ckpt is required")
        print_usage()
        return 3
    }
    if out_path == "" { out_path = ckpt + "/eval_results.json" }

    return run_eval(ckpt, base, endpoint, out_path, max_tokens, quick)
}
