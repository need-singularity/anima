let SCALE_NAME = env_or("CLM_SCALE", "100m")
let scale      = resolve_scale(SCALE_NAME)

// Allow individual overrides on top of scale defaults
let D      = to_int(env_or("CLM_D",      str(scale.D)))
let FF     = to_int(env_or("CLM_FF",     str(scale.FF)))
let NL     = to_int(env_or("CLM_NL",     str(scale.NL)))
let VOCAB  = 256    // byte-level, always
let SEQ    = to_int(env_or("CLM_SEQ",    str(scale.SEQ)))
let RANK   = to_int(env_or("CLM_RANK",   str(scale.RANK)))
let BATCH  = 1      // gpu_train.hexa forward is single-sequence

// Gradient accumulation: effective batch = BATCH * GRAD_ACC
let GRAD_ACC   = to_int(env_or("CLM_GRAD_ACC", "8"))

let STEPS      = to_int(env_or("CLM_STEPS",    str(scale.steps)))
let EVAL_EVERY = to_int(env_or("CLM_EVAL",     "500"))
let SAVE_EVERY = to_int(env_or("CLM_SAVE",     "2000"))
let LOG_EVERY  = to_int(env_or("CLM_LOG",      "20"))

let LR_MAX     = to_float(env_or("CLM_LR_MAX", str(scale.lr_max)))
let LR_MIN     = to_float(env_or("CLM_LR_MIN", str(scale.lr_min)))
let WARMUP     = to_int(env_or("CLM_WARMUP",   str(scale.warmup)))

let EPS        = 0.00001
let INIT_SCALE = 0.02
let SEED       = 54321

// AdamW hyperparameters (gpu_train.hexa fused kernel)
let ADAM_BETA1 = 0.9
let ADAM_BETA2 = 0.999
let ADAM_EPS   = 0.00000001
let ADAM_WD    = 0.01

// Optimizer choice: "sgd" or "adamw"
let OPTIMIZER  = env_or("CLM_OPTIM", "adamw")

// Consciousness controller atoms/sites (from scale or override)
let C_ATOMS     = to_int(env_or("CLM_ATOMS",     str(scale.atoms)))
let C_SITES     = to_int(env_or("CLM_SITES",     str(scale.cells_per_atom)))
let C_DIM       = scale.consciousness_dim

// Phase curriculum boundaries (fraction of total steps)
let P1_END     = STEPS / 5          // 20% C-only
let P2_END     = STEPS * 2 / 5     // next 20% C+D

let CKPT_DIR   = env_or("CLM_CKPT", "/workspace/ckpt_clm_gpu")
let R2_PREFIX  = "r2:anima-models/clm_gpu"
let MODEL_TAG  = "clm_gpu"
let ROUND      = to_int(env_or("CLM_ROUND", "1"))

let CORPUS_PATH = env_or("CLM_CORPUS", "training/corpus_ko_seed.tok")
let HELDOUT_LEN = 4096

// ===============================================================
//  Phase Manager (Law 60: P1 -> P2 -> P3 curriculum)
// ===============================================================

fn phase_at(step: int) -> int {
    if step < P1_END { return PHASE_P1 }
    if step < P2_END { return PHASE_P2 }
    return PHASE_P3
}

fn phase_label(p: int) -> string {
    if p == PHASE_P1 { return "P1_C" }
    if p == PHASE_P2 { return "P2_CD" }
    return "P3_Hexad"
}

// Phase-dependent loss scaling:
//   P1: consciousness controller loss only (scale base loss by 1.0)
//   P2: add decoder alignment term (scale by 0.9 + 0.1 alignment)
//   P3: full Hexad (scale by 0.8 + 0.2 consciousness correction)
// These modulate the effective learning rate, not the loss itself,
// to avoid needing a second backward pass for the auxiliary terms.
fn phase_lr_scale(phase: int) -> float {
    if phase == PHASE_P1 { return 1.0 }
    if phase == PHASE_P2 { return 0.95 }
    return 0.9
}

// ===============================================================
//  PRNG (LCG, matches train_byte_kr.hexa)
// ===============================================================

let mut RNG = SEED
fn next_rand(max: int) -> int {
    RNG = (RNG * 1103515245 + 12345) % 2147483647
    let m = RNG % max
    if m < 0 { return 0 - m }
    return m
}

// ===============================================================
//  Cosine LR with linear warmup
// ===============================================================

fn lr_at(step: int) -> float {
    if step <= WARMUP {
        return LR_MAX * (step * 1.0) / (WARMUP * 1.0)
    }
    let t = ((step - WARMUP) * 1.0) / ((STEPS - WARMUP) * 1.0)
    let pi = 3.14159265358979
    return LR_MIN + 0.5 * (LR_MAX - LR_MIN) * (1.0 + cos(pi * t))
}

// ===============================================================
//  Corpus batch sampling
// ===============================================================

fn sample_batch(corpus: [int], n_corpus: int) -> [int] {
    let max_start = n_corpus - SEQ - 1
    if max_start <= 0 {
        println("[train_clm_gpu] FATAL -- corpus too short: " + str(n_corpus) + " bytes")
        return [ptr_null(), ptr_null()]
    }
    let mut tok_flat = []
    let mut tgt_flat = []
    let mut b = 0
    while b < BATCH {
        let start = next_rand(max_start)
        let mut i = 0
        while i < SEQ {
            tok_flat = tok_flat.push(corpus[start + i])
            tgt_flat = tgt_flat.push(corpus[start + i + 1])
            i = i + 1
        }
        b = b + 1
    }
    let tok_dev = int_array_to_gpu(tok_flat)
    let tgt_dev = int_array_to_gpu(tgt_flat)
    return [tok_dev, tgt_dev]
}

// ===============================================================
//  Eval: PPL on held-out tail
//  (inlined gpu_forward_full + gpu_ce_loss_grad, same as train_clm_kr)
// ===============================================================

fn eval_ppl(weights, cfg, eval_acts, corpus: [int], n_corpus: int) -> float {
    let avail = HELDOUT_LEN
    let mut start = n_corpus - avail - 1
    if start < 0 { start = 0 }
    let rows = HELDOUT_LEN / SEQ
    if rows < 1 { return 0.0 }
    let mut total = 0.0
    let mut r = 0
    while r < rows {
        let row_start = start + r * SEQ
        // Direct alloc_raw → GPU: avoids O(n²) Hexa list .push()
        let h_tok = alloc_raw(SEQ * 4)
        let h_tgt = alloc_raw(SEQ * 4)
        let mut i = 0
        while i < SEQ {
            write_i32(h_tok, i, corpus[row_start + i])
            write_i32(h_tgt, i, corpus[row_start + i + 1])
            i = i + 1
        }
        let tok_dev = cuda_malloc(SEQ * 4)
        let tgt_dev = cuda_malloc(SEQ * 4)
        let _ = cuda_memcpy_h2d(tok_dev, h_tok, SEQ * 4)
        let _ = cuda_memcpy_h2d(tgt_dev, h_tgt, SEQ * 4)
        free_raw(h_tok, SEQ * 4)
        free_raw(h_tgt, SEQ * 4)
        let logits = gpu_forward_full(tok_dev, weights, eval_acts, cfg)
        let loss_buf = cuda_malloc(4)
        let _ = cuda_memset_zero(loss_buf, 4)
        let dlogits = cuda_malloc(SEQ * VOCAB * 4)
        let _ = gpu_ce_loss_grad(logits, tgt_dev, loss_buf, dlogits, SEQ, VOCAB)
        let _ = cudaDeviceSynchronize()
        let host = alloc_raw(4)
        let _ = cuda_memcpy_d2h(host, loss_buf, 4)
        let ce = deref_f32(host, 0)
        free_raw(host, 4)
        cuda_free(loss_buf)
        cuda_free(dlogits)
        cuda_free(tok_dev)
        cuda_free(tgt_dev)
        total = total + ce
        r = r + 1
    }
    return exp(total / (rows * 1.0))
}

// ===============================================================
//  Phi proxy: variance of last hidden state (consciousness metric)
//  (1 MB D2H sample, ~5ms, runs on eval cadence only)
// ===============================================================

fn measure_phi_proxy(eval_acts, cfg) -> float {
    let cap_bytes = 1024 * 1024
    let hidden_bytes = cfg.SEQ * cfg.D * 4
    let nbytes = if hidden_bytes < cap_bytes { hidden_bytes } else { cap_bytes }
    let n_floats = nbytes / 4
    if n_floats < 2 { return 0.0 }
    let y_dev = eval_acts.layers[cfg.NL - 1].y
    let host = alloc_raw(nbytes)
    let _ = cuda_memcpy_d2h(host, y_dev, nbytes)
    let mut mean = 0.0
    let mut i = 0
    while i < n_floats {
        mean = mean + deref_f32(host, i)
        i = i + 1
    }
    mean = mean / (n_floats * 1.0)
    let mut var_sum = 0.0
    let mut j = 0
    while j < n_floats {
        let d = deref_f32(host, j) - mean
        var_sum = var_sum + d * d
        j = j + 1
    }
    free_raw(host, nbytes)
    return var_sum / (n_floats * 1.0)
}

// ===============================================================
//  Consciousness verification gate (Law 49)
//  Phi drop > 5% -> reject checkpoint, revert to best.
// ===============================================================

fn verify_phi_non_destructive(phi_before: float, phi_after: float) -> bool {
    let ratio = phi_after / (phi_before + 0.0001)
    return ratio >= 0.95
}

// ===============================================================
//  R2 upload helper
// ===============================================================

fn r2_upload(local_path: string, step: int) -> int {
    let remote = R2_PREFIX + "/r" + str(ROUND) + "/step_" + str(step) + "/"
    let cmd = "rclone copy " + local_path + " " + remote
    println("[train_clm_gpu] R2 upload: " + cmd)
    let rc = exec(cmd)
    if rc != 0 {
        println("[train_clm_gpu] WARN -- rclone exit=" + str(rc) + " (R2 upload deferred)")
    }
    return rc
}

