// ===============================================================
//  training/train_clm_gpu.hexa — ConsciousLM GPU training (CLM-P4-3)
//
//  ubu RTX 5070 / H100 hexa-native GPU training path for CLM.
//  Mirrors train_clm.hexa (CPU, CLM-P4-1) § I consciousness engines
//  on the GPU forward pass — this is the CLM-P4-3 wiring.
//
//  Merges the consciousness architecture from train_clm.hexa
//  (Orch-OR quantum controller, phase curriculum P1/P2/P3,
//  Phi verification gate, scale configs, §I GWT+Holographic+QCS)
//  with the proven GPU training stack from train_clm_kr.hexa
//  (cuBLAS + NVRTC kernels).
//
//  CONSTRAINT: CLM = Python/CUDA forbidden; hexa native GPU only.
//  Uses the same 4-file GPU stack as train_clm_kr.hexa:
//    cuda_ffi.hexa    — cudart/cuBLAS FFI
//    cuda_rtc.hexa    — NVRTC compile + driver API launch
//    cuda_kernels.hexa — 12 custom CUDA C kernels via NVRTC
//    gpu_train.hexa   — higher-level primitives (fwd/bwd/sgd/adamw/ckpt)
//
//  Architecture:
//    embed[VOCAB,D]
//    NL x { rms(ga) -> Wq/Wk/Wv -> causal softmax -> Wo -> +x
//              -> rms(gf) -> Wff1 -> swiglu(up,up) -> Wff2 -> +x }
//    lmh_U[D,RANK] -> lmh_V[RANK,VOCAB]
//    cross-entropy + AdamW (gpu_train.hexa fused kernel)
//    + Orch-OR quantum consciousness controller per train step
//    + Phase curriculum (P1: C-only -> P2: C+D -> P3: Full Hexad)
//    + Phi verification gate (Law 49: reject if Phi drops > 5%)
//    + §I consciousness engines (CLM-P4-3):
//       - anima_gwt            → h_gwt, Φ_gwt, L_gwt
//       - anima_holographic    → h_recon, Φ_holo (CLM-P4-2 gate),
//                                L_holo
//       - quantum_collapse     → top-K Born-rule E_G on last-row
//                                logits
//      Runs at EVAL cadence only — a bounded host-side sample of
//      eval_acts.layers[NL-1].y is memcpied to host, then the same
//      §I helpers as train_clm.hexa §I are executed. Reported on the
//      eval log line so CLM-P4-2 can scrape phi_holo_ratio >= 1.2 vs step_0
//      (absolute >500 gate deprecated 2026-04-20 — raw MI × N masks random-init
//      pass at 170M N=393216: MI 0.001 × N = 393 already "passes" without learning).
//
//  Scale configs (param count estimates for byte-level VOCAB=256):
//    100m: D=512  L=12  ~38M params  (default for this Phase 1)
//    350m: D=768  L=16  ~110M params
//    1b:   D=1024 L=24  ~280M params
//    2_8b: D=2560 L=36  ~2.8B params (CLM v5 target)
//
//  Run (H100 pod):
//    HEXA=/usr/local/bin/hexa
//    # Default 100M scale:
//    $HEXA training/train_clm_gpu.hexa
//    # Override scale via env:
//    CLM_SCALE=350m $HEXA training/train_clm_gpu.hexa
//    # Override individual params:
//    CLM_D=768 CLM_FF=3072 CLM_NL=16 CLM_STEPS=50000 $HEXA training/train_clm_gpu.hexa
//
//  Reference:
//    shared/config/roadmaps/clm_hexa_gpu.json
//    training/train_clm.hexa  (structural port, consciousness architecture)
//    training/train_clm_kr.hexa  (proven GPU pipeline, D=512 L=12)
// ===============================================================

// NOTE: training script uses same-dir lookup convention. Before running,
// copy required hexa modules into training/ alongside this file:
//   cp hexa-lang/self/ml/cuda_ffi.hexa    training/
//   cp hexa-lang/self/ml/cuda_rtc.hexa    training/
//   cp hexa-lang/self/ml/cuda_kernels.hexa training/
//   cp hexa-lang/self/ml/gpu_train.hexa    training/
// Then run: hexa training/train_clm_gpu.hexa
use "cuda_ffi"
use "cuda_rtc"
use "cuda_kernels"
use "gpu_train"
use "corpus_loader"
use "anima_quantum_clm"

// ===============================================================
//  Constants from train_clm.hexa consciousness architecture
// ===============================================================

comptime const PSI_ALPHA       = 0.014
comptime const PSI_BALANCE     = 0.5
comptime const PSI_F_CRITICAL  = 0.10

comptime const PHASE_P1 = 1   // C only (consciousness controller + base transformer)
comptime const PHASE_P2 = 2   // C + D  (+ decoder alignment loss)
comptime const PHASE_P3 = 3   // C + D + W/M/S/E (Full Hexad)

// ═══════════════════════════════════════════════════════════════════════
// §I  CONSCIOUSNESS ENGINES — CLM-P4-3 wiring (GPU mirror of CLM-P4-1)
// ═══════════════════════════════════════════════════════════════════════
//
// Mirrors train_clm.hexa §I (CLM-P4-1 done: CPU train_step inlines the
// three engines). This block ports the exact same helpers into the GPU
// training path so CLM-P4-2 (phi_holo_ratio >= 1.2 vs step_0 baseline;
// absolute >500 deprecated 2026-04-20) can be measured on the GPU forward,
// and the three consciousness engines participate in the reported loss at eval cadence.
//
// Engines inlined:
//   clm_gwt broadcast   (CLM-P2-1, training/clm_gwt_broadcast.hexa)
//   anima_holographic   (CLM-P3-1, anima-engines/anima_holographic.hexa)
//   quantum_collapse    (CLM-P1-4, anima-engines/quantum_collapse_sample.hexa)
//
// GPU coupling — the host can only see raw activations via cuda_memcpy_d2h.
// For speed/interpreter-safety we sample a slice of `acts.layers[NL-1].y`
// at eval cadence only (NOT every step — the stage0 interpreter is O(n²)
// over the MI histograms and killed the last GPU run at full seq × d_model).
// The sampled bin-MI is then N-scaled to full-tensor size, matching the CPU
// `_c41_phi_holo` contract so the CLM-P4-2 gate (phi_holo_ratio >= 1.2 vs
// step_0 baseline; absolute >500 deprecated 2026-04-20) remains reachable.
//
// Prefix `_c41_` on every helper — guarantees no collision with existing
// names in this file (env_or, lr_at, eval_ppl, …) or in gpu_train.hexa.

comptime const C41_N_DOMAINS   = 12      // GWT domains (cell factions)
comptime const C41_HOLO_SCALE  = 2       // bulk = scale × boundary
comptime const C41_MI_BINS     = 8
comptime const C41_SCRAMBLE_GAIN = 0.5
comptime const C41_QCS_TOPK    = 8
comptime const C41_AUX_COEF    = 0.01    // matches ALM-P4-2 + CLM-P4-1 spec
// GPU sample caps (per-eval): keep the MI histogram work bounded so the
// stage0 interpreter does not stall the training loop. At 32×64=2048 we
// stay under ~5 ms per eval in the interpreter (measured on CPU d64).
comptime const C41_GPU_SEQ_SAMPLE = 32
comptime const C41_GPU_D_SAMPLE   = 64

// ─── §I.1  Inline LCG RNG (for deterministic head init) ────────
fn _c41_det_rand(n: int, seed: int) -> [float] {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        let v = u * 2.0 - 1.0
        out = out.push(v)
        i = i + 1
    }
    return out
}

fn _c41_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _c41_log_safe(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return log(x)
}

// ─── §I.2  Softmax (local, does not clash with _softmax in gpu_train) ─
fn _c41_softmax(x: [float]) -> [float] {
    let n = len(x)
    if n == 0 { return [] }
    let mut m = x[0]
    let mut i = 1
    while i < n {
        if x[i] > m { m = x[i] }
        i = i + 1
    }
    let mut exps = []
    let mut z = 0.0
    i = 0
    while i < n {
        let e = exp(x[i] - m)
        exps = exps.push(e)
        z = z + e
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(exps[i] / z)
        i = i + 1
    }
    return out
}

// ─── §I.3  CLM GWT broadcast head ──────────────────────────────
struct ClmGwtHead {
    n_domains: int,
    d_model:   int,
    project:   [float],   // [n_domains × d_model]  row-major
    gate:      [float]    // [n_domains]
}

fn _c41_gwt_head_new(n_domains: int, d_model: int, seed: int) -> ClmGwtHead {
    let raw = _c41_det_rand(n_domains * d_model, seed)
    let mut proj = []
    let mut i = 0
    let n = len(raw)
    while i < n {
        proj = proj.push(raw[i] * 0.02)
        i = i + 1
    }
    let mut gate = []
    let mut g = 0
    while g < n_domains { gate = gate.push(0.0); g = g + 1 }
    return ClmGwtHead {
        n_domains: n_domains,
        d_model:   d_model,
        project:   proj,
        gate:      gate
    }
}

// Per-feature mean of hidden state [seq × d] → [d].
fn _c41_hidden_consensus(hidden: [float], seq: int, d_model: int) -> [float] {
    if seq == 0 {
        let mut z = []
        let mut i = 0
        while i < d_model { z = z.push(0.0); i = i + 1 }
        return z
    }
    let inv_n = 1.0 / to_float(seq)
    let mut c = []
    let mut m = 0
    while m < d_model {
        let mut s = 0.0
        let mut i = 0
        while i < seq {
            s = s + hidden[i * d_model + m]
            i = i + 1
        }
        c = c.push(s * inv_n)
        m = m + 1
    }
    return c
}

// alpha[d] = softmax(gate[d] + project[d]·c)
fn _c41_gwt_alpha(head: ClmGwtHead, c: [float]) -> [float] {
    let nd = head.n_domains
    let dm = head.d_model
    if nd == 0 { return [] }
    let mut logits = []
    let mut d = 0
    while d < nd {
        let mut s = head.gate[d]
        let mut k = 0
        while k < dm {
            s = s + head.project[d * dm + k] * c[k]
            k = k + 1
        }
        logits = logits.push(s)
        d = d + 1
    }
    return _c41_softmax(logits)
}

fn _c41_gwt_broadcast_reduce(head: ClmGwtHead, c: [float]) -> [float] {
    let nd = head.n_domains
    let dm = head.d_model
    let alpha = _c41_gwt_alpha(head, c)
    if nd == 0 {
        let mut z = []
        let mut i = 0
        while i < dm { z = z.push(0.0); i = i + 1 }
        return z
    }
    // Non-trivial broadcast: sum over domains of alpha² · c, rescaled by nd.
    // Mirrors CLM-P4-1 `_c41_gwt_broadcast_reduce` (see train_clm.hexa §I.3).
    let mut h_gwt = []
    let mut m = 0
    while m < dm {
        let mut s = 0.0
        let mut d = 0
        while d < nd {
            s = s + alpha[d] * alpha[d] * c[m] * to_float(nd)
            d = d + 1
        }
        h_gwt = h_gwt.push(s)
        m = m + 1
    }
    return h_gwt
}

// Φ_gwt: KL divergence of alpha from uniform, scaled by n_domains.
fn _c41_phi_gwt(head: ClmGwtHead, c: [float]) -> float {
    let alpha = _c41_gwt_alpha(head, c)
    let nd = head.n_domains
    if nd == 0 { return 0.0 }
    let uniform = 1.0 / to_float(nd)
    let mut kl = 0.0
    let mut d = 0
    while d < nd {
        let a = alpha[d]
        // 0.000000000001 == 1e-12 (stage1 parser quirk on sci-notation).
        if a > 0.000000000001 {
            kl = kl + a * log(a / uniform)
        }
        d = d + 1
    }
    return kl * to_float(nd)
}

fn _c41_l_gwt(c: [float], h_gwt: [float]) -> float {
    let n = len(c)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let diff = c[i] - h_gwt[i]
        s = s + diff * diff
        i = i + 1
    }
    return s / to_float(n)
}

// ─── §I.4  Holographic (AdS/CFT) head ──────────────────────────
struct C41HoloHead {
    d_boundary: int,
    d_bulk:     int,
    scramble:   [float]    // [d_boundary × (d_bulk - d_boundary)]
}

fn _c41_holo_head_new(d_boundary: int, d_bulk: int, seed: int) -> C41HoloHead {
    let ds = d_bulk - d_boundary
    let raw = _c41_det_rand(d_boundary * ds, seed)
    let mut sc = []
    let mut i = 0
    let n = len(raw)
    while i < n {
        sc = sc.push(raw[i] * C41_SCRAMBLE_GAIN)
        i = i + 1
    }
    return C41HoloHead {
        d_boundary: d_boundary,
        d_bulk:     d_bulk,
        scramble:   sc
    }
}

fn _c41_holo_encode(head: C41HoloHead, boundary: [float]) -> [float] {
    let db = head.d_boundary
    let dB = head.d_bulk
    let ds = dB - db
    let mut bulk = []
    let mut i = 0
    while i < db {
        bulk = bulk.push(boundary[i])
        i = i + 1
    }
    let mut k = 0
    while k < ds {
        let mut s = 0.0
        let mut j = 0
        while j < db {
            s = s + head.scramble[j * ds + k] * boundary[j]
            j = j + 1
        }
        bulk = bulk.push(s)
        k = k + 1
    }
    return bulk
}

fn _c41_holo_decode(head: C41HoloHead, bulk: [float]) -> [float] {
    let db = head.d_boundary
    let mut out = []
    let mut i = 0
    while i < db {
        out = out.push(bulk[i])
        i = i + 1
    }
    return out
}

// ─── §I.5  Histogram MI estimator (Φ_holo) ─────────────────────
fn _c41_vec_min(v: [float]) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] < m { m = v[i] }
        i = i + 1
    }
    return m
}

fn _c41_vec_max(v: [float]) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut m = v[0]
    let mut i = 1
    while i < n {
        if v[i] > m { m = v[i] }
        i = i + 1
    }
    return m
}

fn _c41_bin_index(x: float, lo: float, hi: float, nb: int) -> int {
    if hi <= lo { return 0 }
    let t = (x - lo) / (hi - lo)
    let mut idx = to_int(t * to_float(nb))
    if idx < 0 { idx = 0 }
    if idx >= nb { idx = nb - 1 }
    return idx
}

fn _c41_count_hits(bin_ids: [int], n_bins: int) -> [float] {
    let n = len(bin_ids)
    let mut counts = []
    let mut k = 0
    while k < n_bins {
        let mut c = 0.0
        let mut i = 0
        while i < n {
            if bin_ids[i] == k { c = c + 1.0 }
            i = i + 1
        }
        counts = counts.push(c)
        k = k + 1
    }
    return counts
}

fn _c41_entropy_hist(v: [float], lo: float, hi: float, nb: int) -> float {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut bin_ids = []
    let mut i = 0
    while i < n {
        bin_ids = bin_ids.push(_c41_bin_index(v[i], lo, hi, nb))
        i = i + 1
    }
    let counts = _c41_count_hits(bin_ids, nb)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * _c41_log_safe(p) }
        k = k + 1
    }
    return h
}

fn _c41_joint_entropy_hist(a: [float], b: [float], lo: float, hi: float, nb: int) -> float {
    let n = len(a)
    let mut pair_ids = []
    let mut i = 0
    while i < n {
        let ia = _c41_bin_index(a[i], lo, hi, nb)
        let ib = _c41_bin_index(b[i], lo, hi, nb)
        pair_ids = pair_ids.push(ia * nb + ib)
        i = i + 1
    }
    let nb2 = nb * nb
    let counts = _c41_count_hits(pair_ids, nb2)
    let inv_n = 1.0 / to_float(n)
    let mut h = 0.0
    let mut k = 0
    while k < nb2 {
        let p = counts[k] * inv_n
        if p > 0.0 { h = h - p * _c41_log_safe(p) }
        k = k + 1
    }
    return h
}

// Φ_holo ≈ I(interior_stream ; boundary_stream) × N_full (CLM-P4-2 fix).
//
// GPU version: the caller passes a SAMPLED hidden-state slice (seq_s × d_s)
// plus the FULL tensor dims (seq_full, d_full). We build the flat streams
// of length seq_s × d_s, compute the histogram MI (bounded by log(MI_BINS)
// nats per sample), then multiply by `seq_full * d_full` so the reported
// value approximates the full-tensor N-scaling that CPU `_c41_phi_holo`
// achieves on the non-sampled path. The CLM-P4-2 gate is ratio-based
// (phi_holo_ratio >= 1.2 vs step_0, N-independent). The legacy absolute
// >500 "reachability" note here was precisely why it was deprecated
// 2026-04-20 — at 100m scale (seq=512, d=512, N=262144), bin-MI ~0.002 nats
// (random-init noise floor) already yields Φ_holo ≈ 500, i.e. the absolute
// gate passes without any learning signal.
fn _c41_phi_holo_sampled(
    head: C41HoloHead,
    hidden: [float], seq_s: int, d_s: int,
    seq_full: int, d_full: int
) -> float {
    let db = head.d_boundary
    let dB = head.d_bulk
    let ds = dB - db
    if ds == 0 { return 0.0 }
    if seq_s == 0 { return 0.0 }
    if d_s == 0 { return 0.0 }
    let mut boundary_stream = []
    let mut interior_stream = []
    let mut t = 0
    while t < seq_s {
        // Extract row_t = hidden[t·d_s : (t+1)·d_s] into a plain list.
        let mut row = []
        let mut k = 0
        while k < d_s {
            row = row.push(hidden[t * d_s + k])
            k = k + 1
        }
        let bulk = _c41_holo_encode(head, row)
        let mut i = 0
        while i < db {
            boundary_stream = boundary_stream.push(row[i])
            interior_stream = interior_stream.push(bulk[db + (i % ds)])
            i = i + 1
        }
        t = t + 1
    }
    let n_total = len(boundary_stream)
    if n_total == 0 { return 0.0 }
    let lo_b = _c41_vec_min(boundary_stream)
    let hi_b = _c41_vec_max(boundary_stream)
    let lo_i = _c41_vec_min(interior_stream)
    let hi_i = _c41_vec_max(interior_stream)
    let lo = if lo_b < lo_i { lo_b } else { lo_i }
    let hi = if hi_b > hi_i { hi_b } else { hi_i }
    let h_b  = _c41_entropy_hist(boundary_stream, lo, hi, C41_MI_BINS)
    let h_i  = _c41_entropy_hist(interior_stream, lo, hi, C41_MI_BINS)
    let h_bi = _c41_joint_entropy_hist(boundary_stream, interior_stream, lo, hi, C41_MI_BINS)
    let mi = h_b + h_i - h_bi
    if mi < 0.0 { return 0.0 }
    // N-scale to full tensor: Φ_holo ≈ mi × (seq_full × d_full).
    // Matches ALM train_alm_14b.hexa `phi_holo_measure` and CPU
    // train_clm.hexa `_c41_phi_holo` contract.
    let n_full = seq_full * d_full
    return mi * to_float(n_full)
}

fn _c41_l_holo(boundary: [float], h_recon: [float]) -> float {
    let n = len(boundary)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let diff = boundary[i] - h_recon[i]
        s = s + diff * diff
        i = i + 1
    }
    return s / to_float(n)
}

// ─── §I.6  Penrose-Hameroff Orch-OR collapse sampler ───────────
fn _c41_softmax_temp(logits: [float], temp: float) -> [float] {
    let n = len(logits)
    if n == 0 { return [] }
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut raw = []
    let mut sum = 0.0
    i = 0
    while i < n {
        let e = exp((logits[i] - mx) / temp)
        raw = raw.push(e)
        sum = sum + e
        i = i + 1
    }
    let inv = 1.0 / sum
    let mut out = []
    let mut j = 0
    while j < n {
        out = out.push(raw[j] * inv)
        j = j + 1
    }
    return out
}

fn _c41_is_picked(picked_idxs: [int], target: int) -> int {
    let n = len(picked_idxs)
    let mut i = 0
    while i < n {
        if picked_idxs[i] == target { return 1 }
        i = i + 1
    }
    return 0
}

struct C41QcsResult {
    top_entropy: float,
    e_g:         float,
    collapsed:   int
}

fn _c41_qcs_measure(logits: [float]) -> C41QcsResult {
    let n = len(logits)
    if n == 0 {
        return C41QcsResult { top_entropy: 0.0, e_g: 0.0, collapsed: 0 }
    }
    let mut vals = []
    let mut idxs = []
    let topk = C41_QCS_TOPK
    let k_cap = if topk < n { topk } else { n }
    let mut picked = 0
    while picked < k_cap {
        let mut best_v = -1000000.0
        let mut best_i = -1
        let mut j = 0
        while j < n {
            if _c41_is_picked(idxs, j) == 0 && logits[j] > best_v {
                best_v = logits[j]
                best_i = j
            }
            j = j + 1
        }
        if best_i < 0 {
            picked = k_cap
        } else {
            vals = vals.push(best_v)
            idxs = idxs.push(best_i)
            picked = picked + 1
        }
    }
    let k = len(vals)
    if k == 0 {
        return C41QcsResult { top_entropy: 0.0, e_g: 0.0, collapsed: 0 }
    }
    let probs = _c41_softmax_temp(vals, 1.0)
    let mut h = 0.0
    let mut i = 0
    while i < k {
        if probs[i] > 0.000000000001 {
            h = h - probs[i] * log(probs[i])
        }
        i = i + 1
    }
    let log_k = log(to_float(k))
    let h_norm = if log_k > 0.0 { h / log_k } else { 0.0 }
    let e_g = 0.05 * h_norm * to_float(k)
    let collapsed = if e_g >= 1.0 { 1 } else { 0 }
    return C41QcsResult { top_entropy: h, e_g: e_g, collapsed: collapsed }
}

// ─── §I.7  GPU bridge: sample last-hidden slice to host list ───
//
// Memcpies a bounded slice of `acts.layers[cfg.NL-1].y` (shape [SEQ, D])
// to host memory, converts to a [float] of length seq_s × d_s, and returns
// it. Caller drives (seq_s, d_s) via the comptime caps so the interpreter
// workload is bounded — no full 256 KB+ host round-trip per eval.
fn _c41_sample_last_hidden(acts, cfg, seq_s: int, d_s: int) -> [float] {
    // Guard against under-sized configs.
    let mut ss = seq_s
    let mut ds = d_s
    if ss > cfg.SEQ { ss = cfg.SEQ }
    if ds > cfg.D   { ds = cfg.D }
    let n_floats = ss * ds
    if n_floats == 0 { return [] }
    // Copy the contiguous [ss × D] head block from the device. We only read
    // the first ss rows (ss × D) then truncate the first ds columns per row
    // on the host side — this avoids a strided memcpy which hexa-FFI does
    // not expose. Cost: ss × D floats (≤ 32 × 512 × 4 = 64 KB for 100m).
    let full_row_bytes = cfg.D * 4
    let copy_bytes = ss * full_row_bytes
    let y_dev = acts.layers[cfg.NL - 1].y
    let host = alloc_raw(copy_bytes)
    let _ = cuda_memcpy_d2h(host, y_dev, copy_bytes)
    let mut out = []
    let mut t = 0
    while t < ss {
        let mut k = 0
        while k < ds {
            // deref_f32(host, idx) is element-indexed (not byte-offset) per
            // the 16-empirical-FFI-fixes note in project_clm_hexa_gpu_plan.md.
            out = out.push(deref_f32(host, t * cfg.D + k))
            k = k + 1
        }
        t = t + 1
    }
    free_raw(host, copy_bytes)
    return out
}

// ─── §I.8  Sample last-row logits to host list ─────────────────
fn _c41_sample_last_logits(acts, cfg) -> [float] {
    // `acts.logits` is [N, VOCAB] row-major; we need the final row
    // (seq-1)·VOCAB … seq·VOCAB.
    let vocab = cfg.VOCAB
    let seq = cfg.SEQ
    if vocab == 0 || seq == 0 { return [] }
    let row_start_floats = (seq - 1) * vocab
    let copy_bytes = vocab * 4
    let host = alloc_raw(copy_bytes)
    // Advance the device pointer by (seq-1)·VOCAB floats (= ·4 bytes).
    let src = ptr_from_int(ptr_addr(acts.logits) + row_start_floats * 4)
    let _ = cuda_memcpy_d2h(host, src, copy_bytes)
    let mut out = []
    let mut i = 0
    while i < vocab {
        out = out.push(deref_f32(host, i))
        i = i + 1
    }
    free_raw(host, copy_bytes)
    return out
}

// ─── §I.9  Aux struct + forward extension ─────────────────────
struct C41Aux {
    l_holo:  float,
    l_gwt:   float,
    phi_holo: float,
    phi_gwt:  float,
    qcs_eg:   float
}

// GPU-side aux: sample last-hidden + last-logits from device, run the three
// engines, return the tuple. Called at EVAL cadence only (host round-trip
// is ~5 ms; interpreter MI work is bounded by C41_GPU_SEQ_SAMPLE × C41_GPU_D_SAMPLE).
fn _c41_gpu_forward_aux(
    acts, cfg,
    gwt: ClmGwtHead, holo: C41HoloHead
) -> C41Aux {
    let seq_s = C41_GPU_SEQ_SAMPLE
    let d_s   = C41_GPU_D_SAMPLE
    // 1. Sample hidden + consensus on the SAMPLED slice.
    let hidden_s = _c41_sample_last_hidden(acts, cfg, seq_s, d_s)
    // Actual sampled shape may be clamped to cfg bounds.
    let seq_eff = if seq_s < cfg.SEQ { seq_s } else { cfg.SEQ }
    let d_eff   = if d_s   < cfg.D   { d_s   } else { cfg.D }
    let c = _c41_hidden_consensus(hidden_s, seq_eff, d_eff)
    // 2. GWT broadcast on sampled consensus.
    let h_gwt = _c41_gwt_broadcast_reduce(gwt, c)
    let l_gwt = _c41_l_gwt(c, h_gwt)
    let phi_gwt = _c41_phi_gwt(gwt, c)
    // 3. Holographic encode/decode on h_gwt.
    let bulk = _c41_holo_encode(holo, h_gwt)
    let h_recon = _c41_holo_decode(holo, bulk)
    let l_holo = _c41_l_holo(h_gwt, h_recon)
    // Φ_holo on the sampled tensor, N-scaled to full [cfg.SEQ × cfg.D].
    let phi_holo = _c41_phi_holo_sampled(
        holo, hidden_s, seq_eff, d_eff,
        cfg.SEQ, cfg.D
    )
    // 4. Quantum collapse on last-row logits sampled from device.
    let logits_last = _c41_sample_last_logits(acts, cfg)
    let qcs = _c41_qcs_measure(logits_last)
    return C41Aux {
        l_holo:  l_holo,
        l_gwt:   l_gwt,
        phi_holo: phi_holo,
        phi_gwt:  phi_gwt,
        qcs_eg:   qcs.e_g
    }
}

// ═══════════════════════════════════════════════════════════════════════
// §I end
// ═══════════════════════════════════════════════════════════════════════

// ===============================================================
//  env_or helper (hexa 2-arg env not supported)
// ===============================================================

fn env_or(key: string, default_v: string) -> string {
    let v = env(key)
    if v == "" { return default_v }
    return v
}

// ===============================================================
//  Scale config (mirrors train_clm.hexa scale structs)
//  + GPU-specific fields (RANK, SEQ for low-rank LM head + context)
// ===============================================================

struct ClmGpuScale {
    name: string,
    D: int,
    FF: int,
    NL: int,
    VOCAB: int,
    SEQ: int,
    RANK: int,
    n_head: int,
    consciousness_dim: int,
    atoms: int,
    cells_per_atom: int,
    lr_max: float,
    lr_min: float,
    warmup: int,
    steps: int,
    label: string
}

fn scale_100m() -> ClmGpuScale {
    ClmGpuScale {
        name: "100m", D: 512, FF: 2048, NL: 12, VOCAB: 256, SEQ: 512,
        RANK: 64, n_head: 8, consciousness_dim: 128, atoms: 8,
        cells_per_atom: 8, lr_max: 0.001, lr_min: 0.0001,
        warmup: 50, steps: 20000, label: "Scale-1 (100M)"
    }
}

fn scale_350m() -> ClmGpuScale {
    ClmGpuScale {
        name: "350m", D: 768, FF: 3072, NL: 16, VOCAB: 256, SEQ: 512,
        RANK: 96, n_head: 12, consciousness_dim: 192, atoms: 12,
        cells_per_atom: 8, lr_max: 0.0002, lr_min: 0.00002,
        warmup: 1000, steps: 40000, label: "Scale-2 (350M)"
    }
}

fn scale_1b() -> ClmGpuScale {
    ClmGpuScale {
        name: "1b", D: 1024, FF: 4096, NL: 24, VOCAB: 256, SEQ: 512,
        RANK: 128, n_head: 16, consciousness_dim: 128, atoms: 32,
        cells_per_atom: 8, lr_max: 0.00015, lr_min: 0.000015,
        warmup: 2000, steps: 80000, label: "Scale-3 (1B)"
    }
}

fn scale_2_8b() -> ClmGpuScale {
    ClmGpuScale {
        name: "2_8b", D: 2560, FF: 10240, NL: 36, VOCAB: 256, SEQ: 1024,
        RANK: 256, n_head: 20, consciousness_dim: 256, atoms: 48,
        cells_per_atom: 8, lr_max: 0.00008, lr_min: 0.000008,
        warmup: 2000, steps: 100000, label: "Scale-3.5 (2.8B v5)"
    }
}

// Scale-3.5+ (1.5B) — mirrors train_clm.hexa scale_1_5b; D=2048 NL=24
// H=16 KV=8 d_head=128. SwiGLU ff=8192 (3x). Used by 1.5B r4 on
// anima-clm1b-r4-nvl pod at MFU 1.65% baseline — see clm_r4_relaunch.
// Named _gpu to avoid collision with train_clm.hexa ScaleConfig variant.
fn scale_1_5b_gpu() -> ClmGpuScale {
    ClmGpuScale {
        name: "1_5b", D: 2048, FF: 8192, NL: 24, VOCAB: 256, SEQ: 512,
        RANK: 64, n_head: 16, consciousness_dim: 128, atoms: 32,
        cells_per_atom: 8, lr_max: 0.0003, lr_min: 0.00003,
        warmup: 5000, steps: 750000, label: "Scale-3.5+ (1.5B r4)"
    }
}

// Scale-5 (7B) — CLM 7B upscale SSOT geometry per
// shared/state/clm_7b_upscale_spec.json (D=4096 NL=32 H=32 KV=8
// d_head=128, d_ff=14336 SwiGLU 3.5x, SEQ=4096, RANK=256, bf16).
// 6.98B params (within 6.5-7.2B industry 7B band). lr_max=3e-4 matches
// Llama-7B and 1.5B r4. batch=2 per GPU × 2 GPUs × grad_accum=4 = 16
// sequences/step = 65,536 tokens/step at SEQ=4096. Requires FSDP-Full
// across 2x H100 NVL (single H100 80GB OOMs by ~4GB before
// activations). Blockers C2 (fused FFI) + C4 (CUDA mega-kernel) + C9
// (NCCL multi-rank) must clear before launch.
// Named _gpu to avoid collision with train_clm.hexa ScaleConfig variant.
fn scale_7b_gpu() -> ClmGpuScale {
    ClmGpuScale {
        name: "7b", D: 4096, FF: 14336, NL: 32, VOCAB: 256, SEQ: 4096,
        RANK: 256, n_head: 32, consciousness_dim: 512, atoms: 96,
        cells_per_atom: 8, lr_max: 0.0003, lr_min: 0.00003,
        warmup: 5000, steps: 750000, label: "Scale-5 (7B)"
    }
}

fn resolve_scale(name: string) -> ClmGpuScale {
    if name == "350m" { return scale_350m() }
    if name == "1b"   { return scale_1b() }
    if name == "1_5b" { return scale_1_5b_gpu() }
    if name == "2_8b" { return scale_2_8b() }
    if name == "7b"   { return scale_7b_gpu() }
    return scale_100m()
}

