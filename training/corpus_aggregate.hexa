// training/corpus_aggregate.hexa — CLM 7B corpus aggregate + R2 upload (hexa native)
// @convergence shared/convergence/corpus_7b.convergence
//
// Plan SSOT: state/corpus_140gb_plan.json
// Progress:  state/corpus_7b_progress_20260416.json
//
// Purpose:
//   Concatenate the per-source cleaned files (kowiki.txt + cc100_ko_dedup.txt)
//   into a single corpus file for training, and upload both the per-source
//   shards and the aggregate to R2 for archive persistence.
//
//   Delegates to corpus_kowiki_extract.hexa and corpus_cc100_dedup.hexa
//   for the actual content production — this file is the glue + uploader.
//
// Pipeline:
//   1. Verify input files exist at expected paths
//   2. Cross-source global dedup (line-level, awk !seen[$0]++)
//   3. cat kowiki.txt + cc100_ko_dedup.txt > corpus_clm_7b_korean.txt
//   4. zstd compress each shard (level 19)
//   5. rclone copy to r2:anima-models/corpus/v2/korean/
//
// Input:
//   data/corpus_v2_clean/kowiki.txt           (from corpus_kowiki_extract.hexa)
//   data/corpus_v2_clean/cc100_ko_dedup.txt   (from corpus_cc100_dedup.hexa)
// Output (local):
//   data/corpus_v2_clean/corpus_clm_7b_korean.txt
//   data/corpus_v2_clean/kowiki.txt.zst
//   data/corpus_v2_clean/cc100_ko_dedup.txt.zst
//   data/corpus_v2_clean/corpus_clm_7b_korean.txt.zst
// Output (R2):
//   r2:anima-models/corpus/v2/korean/kowiki.txt.zst
//   r2:anima-models/corpus/v2/korean/cc100_ko_dedup.txt.zst
//   r2:anima-models/corpus/v2/corpus_clm_7b_korean.txt.zst
//
// Self-tests (T1..T5):
//   T1 mock aggregate: 2 small inputs concat with correct total line count
//   T2 cross-source dedup: shared line present once only
//   T3 zstd roundtrip integrity (compress + decompress == original)
//   T4 rclone command plan: dry-run emits expected R2 paths
//   T5 total size gate: aggregate > sum-minus-overlap (sanity)
//
// Stage0 constraints honored:
//   - list-length pass counter (int init-0 bug workaround)
//   - contains() not substring()
//   - exec() for all file ops
//   - 0 imports
//
// Run:
//   hexa run training/corpus_aggregate.hexa               # self-test 5/5
//   hexa run training/corpus_aggregate.hexa --aggregate   # real concat + upload

// =====================================================================
// Constants
// =====================================================================

let KOWIKI_IN     = "data/corpus_v2_clean/kowiki.txt"
let CC100_IN      = "data/corpus_v2_clean/cc100_ko_dedup.txt"
let AGGREGATE_OUT = "data/corpus_v2_clean/corpus_clm_7b_korean.txt"
let TMP_DIR       = "data/corpus_v2_clean/tmp_agg"

let R2_REMOTE      = "r2"
let R2_BUCKET      = "anima-models"
let R2_PREFIX      = "corpus/v2"
let R2_KOREAN      = "corpus/v2/korean"

let ZSTD_LEVEL = 19

// =====================================================================
// Build aggregate: cross-source dedup via cat | awk !seen
//
// Stage0 quirk: passing a [string] list into fn + indexing inside a while
// loop causes hang/empty-output for Korean content. We take 2 paths as
// direct string params (kowiki + cc100). If future sources are added,
// add parameters here or use a flat expansion.
// =====================================================================

fn build_aggregate_pipeline(ko_path: string, cc_path: string, output: string) -> string {
    // Concatenate both inputs, dedup line-wise across the whole corpus.
    // awk hash table handles ~GB of unique lines on 16GB RAM; for 60GB
    // we may need to switch to sort -u (O(N log N)) but awk is preferred
    // for streaming at first pass.
    let cmd = "cat '" + ko_path + "' '" + cc_path + "' | awk '!seen[$0]++' > '" + output + "'"
    return cmd
}

fn aggregate(ko_path: string, cc_path: string, output: string) -> int {
    exec("mkdir -p data/corpus_v2_clean")
    exec("mkdir -p '" + TMP_DIR + "'")
    let cmd = build_aggregate_pipeline(ko_path, cc_path, output)
    println("[aggregate] cmd: " + cmd)
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + output + "' 2>/dev/null").trim()
    let sz = exec("wc -c < '" + output + "' 2>/dev/null").trim()
    println("[aggregate] lines=" + wc + " bytes=" + sz + " -> " + output)
    return len(wc)
}

// =====================================================================
// Compress via zstd
// =====================================================================

fn compress_zstd(input: string) -> string {
    let out = input + ".zst"
    let cmd = "zstd -" + str(ZSTD_LEVEL) + " -q -f '" + input + "' -o '" + out + "'"
    println("[zstd] " + cmd)
    let _r = exec(cmd)
    let sz_in = exec("wc -c < '" + input + "' 2>/dev/null").trim()
    let sz_out = exec("wc -c < '" + out + "' 2>/dev/null").trim()
    println("[zstd] " + sz_in + " -> " + sz_out + " (" + out + ")")
    return out
}

// =====================================================================
// R2 upload via rclone
// =====================================================================

fn r2_path_for(local_path: string) -> string {
    // local basename under R2_KOREAN prefix for per-shard,
    // under R2_PREFIX for the aggregate.
    let base = exec("basename '" + local_path + "'").trim()
    // Use contains-based check. Aggregate goes to top-level v2/.
    if base.contains("corpus_clm_7b_korean") {
        return R2_REMOTE + ":" + R2_BUCKET + "/" + R2_PREFIX + "/" + base
    }
    return R2_REMOTE + ":" + R2_BUCKET + "/" + R2_KOREAN + "/" + base
}

fn r2_upload_cmd(local_path: string) -> string {
    let dest = r2_path_for(local_path)
    return "rclone copyto '" + local_path + "' '" + dest + "' --s3-no-check-bucket"
}

fn upload_one(path: string, dry_run: bool) -> int {
    let cmd = r2_upload_cmd(path)
    println("[r2] " + cmd)
    if dry_run == false {
        let _r = exec(cmd)
    }
    return 1
}

// =====================================================================
// Orchestrate — end-to-end aggregate + compress + upload
// =====================================================================

fn orchestrate(dry_run: bool) -> int {
    // Verify inputs exist
    let k_exists = exec("test -f '" + KOWIKI_IN + "' && echo YES || echo NO").trim()
    let c_exists = exec("test -f '" + CC100_IN + "' && echo YES || echo NO").trim()
    println("[orchestrate] kowiki exists=" + k_exists + " cc100 exists=" + c_exists)

    if k_exists == "NO" {
        println("[orchestrate] MISSING: " + KOWIKI_IN + " — run corpus_kowiki_extract.hexa first")
        return -1
    }
    if c_exists == "NO" {
        println("[orchestrate] MISSING: " + CC100_IN + " — run corpus_cc100_dedup.hexa first")
        return -1
    }

    let _n = aggregate(KOWIKI_IN, CC100_IN, AGGREGATE_OUT)

    // Compress all 3 shards
    let k_zst = compress_zstd(KOWIKI_IN)
    let c_zst = compress_zstd(CC100_IN)
    let a_zst = compress_zstd(AGGREGATE_OUT)

    // Upload via 3 direct calls (list param into fn has same quirk as above)
    let _u1 = upload_one(k_zst, dry_run)
    let _u2 = upload_one(c_zst, dry_run)
    let _u3 = upload_one(a_zst, dry_run)
    return 0
}

// =====================================================================
// Self-test fixtures
// =====================================================================

fn mock_kowiki_content() -> string {
    let s1 = "한국어 위키백과 첫 번째 문서 내용입니다 흥미로운 주제에 대해 이야기합니다\n"
    let s2 = s1 + "공유된 문장 예시 이 문장은 양쪽 말뭉치에 같이 나옵니다\n"
    let s3 = s2 + "위키 고유 내용 알고리즘과 자료구조 철학과 수학의 관계를 연구합니다\n"
    return s3
}

fn mock_cc100_content() -> string {
    let s1 = "크롤 말뭉치 첫 줄 일반 인터넷 텍스트의 전형적 예시 문장입니다 다양합니다\n"
    let s2 = s1 + "공유된 문장 예시 이 문장은 양쪽 말뭉치에 같이 나옵니다\n"
    let s3 = s2 + "CC100 고유 줄 대화체와 뉴스 스타일이 섞여 있습니다 다양한 주제를 다룹니다\n"
    return s3
}

// =====================================================================
// T1 — mock aggregate: 2 × 3 = 6 lines, with 1 shared -> 5 unique
// =====================================================================

fn check_T1_aggregate() -> bool {
    exec("mkdir -p '" + TMP_DIR + "'")
    let k = TMP_DIR + "/_mock_ko.txt"
    let c = TMP_DIR + "/_mock_cc.txt"
    let out = TMP_DIR + "/_mock_agg.txt"
    // Clean prior runs to avoid stale output masking a failure
    exec("rm -f '" + out + "'")
    write_file(k, mock_kowiki_content())
    write_file(c, mock_cc100_content())

    let cmd = build_aggregate_pipeline(k, c, out)
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + out + "'").trim()
    // After dedup: 3 + 3 - 1 = 5 lines
    let ok_count = wc.contains("5")
    println("  [T1] aggregate: out_lines=" + wc + " (expect 5)")
    return ok_count
}

// =====================================================================
// T2 — cross-source dedup: shared line appears exactly once
// =====================================================================

fn check_T2_cross_dedup() -> bool {
    let out = TMP_DIR + "/_mock_agg.txt"
    let content = read_file(out)
    // Count occurrences of the shared signature
    let hit_cmd = "grep -c '공유된 문장 예시' '" + out + "' 2>/dev/null || echo 0"
    let count = exec(hit_cmd).trim()
    let ok = count == "1"
    println("  [T2] cross-dedup: shared_line_count=" + count + " (expect 1)")
    return ok
}

// =====================================================================
// T3 — zstd roundtrip integrity
// =====================================================================

fn check_T3_zstd_roundtrip() -> bool {
    let src = TMP_DIR + "/_mock_agg.txt"
    let zst = src + ".zst"
    let rt = TMP_DIR + "/_mock_agg.rt"

    // compress
    let _c = exec("zstd -" + str(ZSTD_LEVEL) + " -q -f '" + src + "' -o '" + zst + "'")
    // decompress to different path
    let _d = exec("zstd -d -q -f '" + zst + "' -o '" + rt + "'")

    // diff
    let diff_out = exec("cmp -s '" + src + "' '" + rt + "' && echo SAME || echo DIFF").trim()
    let ok = diff_out == "SAME"

    let sz_src = exec("wc -c < '" + src + "'").trim()
    let sz_zst = exec("wc -c < '" + zst + "'").trim()
    println("  [T3] zstd_rt: src=" + sz_src + " zst=" + sz_zst + " integrity=" + diff_out)
    return ok
}

// =====================================================================
// T4 — rclone command plan: R2 paths correct
// =====================================================================

fn check_T4_r2_paths() -> bool {
    let k_path = r2_path_for(KOWIKI_IN + ".zst")
    let c_path = r2_path_for(CC100_IN + ".zst")
    let a_path = r2_path_for(AGGREGATE_OUT + ".zst")

    let ok_k = k_path.contains("anima-models/corpus/v2/korean/kowiki.txt.zst")
    let ok_c = c_path.contains("anima-models/corpus/v2/korean/cc100_ko_dedup.txt.zst")
    let ok_a = a_path.contains("anima-models/corpus/v2/corpus_clm_7b_korean.txt.zst")

    let mut ok = false
    if ok_k {
        if ok_c {
            if ok_a {
                ok = true
            }
        }
    }
    println("  [T4] r2 paths:")
    println("       kowiki: " + k_path)
    println("       cc100:  " + c_path)
    println("       agg:    " + a_path)
    return ok
}

// =====================================================================
// T5 — size sanity: aggregate > each source, < sum (dedup saves bytes)
// =====================================================================

fn check_T5_size_sanity() -> bool {
    let out = TMP_DIR + "/_mock_agg.txt"
    let k = TMP_DIR + "/_mock_ko.txt"
    let c = TMP_DIR + "/_mock_cc.txt"

    let sz_out = exec("wc -c < '" + out + "'").trim()
    let sz_k = exec("wc -c < '" + k + "'").trim()
    let sz_c = exec("wc -c < '" + c + "'").trim()
    // Use shell-side arithmetic for comparison (hexa int 32-bit / 0 quirks)
    let verdict = exec("o=$(wc -c < '" + out + "'); k=$(wc -c < '" + k + "'); c=$(wc -c < '" + c + "'); s=$((k+c)); if [ $o -gt $k ] && [ $o -gt $c ] && [ $o -lt $s ]; then echo SIZE_OK; else echo SIZE_BAD; fi").trim()
    let ok = verdict == "SIZE_OK"
    println("  [T5] size: agg=" + sz_out + " ko=" + sz_k + " cc=" + sz_c + " verdict=" + verdict)
    return ok
}

// =====================================================================
// Main
// =====================================================================

fn test() {
    println("[training/corpus_aggregate] CLM 7B aggregate + R2 upload")
    println("  kowiki_in:    " + KOWIKI_IN)
    println("  cc100_in:     " + CC100_IN)
    println("  aggregate:    " + AGGREGATE_OUT)
    println("  r2 prefix:    " + R2_REMOTE + ":" + R2_BUCKET + "/" + R2_PREFIX)
    println("")

    let t1 = check_T1_aggregate()
    if t1 { println("T1 PASS - mock aggregate 2+2-1=5 lines") } else { println("T1 FAIL") }

    let t2 = check_T2_cross_dedup()
    if t2 { println("T2 PASS - cross-source dedup correct") } else { println("T2 FAIL") }

    let t3 = check_T3_zstd_roundtrip()
    if t3 { println("T3 PASS - zstd compress/decompress lossless") } else { println("T3 FAIL") }

    let t4 = check_T4_r2_paths()
    if t4 { println("T4 PASS - R2 paths correct per layout") } else { println("T4 FAIL") }

    let t5 = check_T5_size_sanity()
    if t5 { println("T5 PASS - aggregate size bounded by sources") } else { println("T5 FAIL") }

    println("")
    // List-length pass counter (stage0 int=0 counter bug workaround)
    let mut passes: [int] = []
    if t1 { passes = passes.push(1) }
    if t2 { passes = passes.push(1) }
    if t3 { passes = passes.push(1) }
    if t4 { passes = passes.push(1) }
    if t5 { passes = passes.push(1) }
    let pass_count = len(passes)

    if pass_count == 5 {
        println("[training/corpus_aggregate] 5/5 PASS - ready for real aggregation + R2 upload")
        println("")
        println("Real orchestrate:")
        println("  hexa run training/corpus_aggregate.hexa --aggregate")
        println("")
        println("R2 layout:")
        println("  r2:anima-models/corpus/v2/korean/kowiki.txt.zst")
        println("  r2:anima-models/corpus/v2/korean/cc100_ko_dedup.txt.zst")
        println("  r2:anima-models/corpus/v2/corpus_clm_7b_korean.txt.zst")
    } else {
        println("[training/corpus_aggregate] " + str(pass_count) + "/5 PASS - SOME FAILED")
    }
}

test()
