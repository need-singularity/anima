fn gen_get_weather(target: int) -> [string] {
    let tool = build_tool("get_weather", "Get current weather for a location", build_params2("location", "string", "City name or coordinates", "units", "string", "Temperature units (celsius or fahrenheit)"))

    let cities_en = [
        "Seoul", "Tokyo", "New York", "London", "Paris", "Berlin",
        "San Francisco", "Sydney", "Shanghai", "Mumbai", "Dubai", "Moscow",
        "Toronto", "Cape Town", "Singapore", "Bangkok"
    ]
    let cities_ko = [
        "서울", "부산", "도쿄", "뉴욕", "런던", "파리", "베를린", "상하이", "싱가포르"
    ]
    let units = ["celsius", "fahrenheit"]

    let openers_en = [
        "What's the weather in ",
        "Get weather for ",
        "How's the weather in ",
        "Weather forecast for "
    ]
    let openers_ko = [
        "날씨 알려줘: ",
        "오늘 날씨는? ",
        "기온 확인 — "
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 3 == 0)
        let mut city = ""
        let mut instruction = ""
        if use_ko {
            let ci = prng(i, len(cities_ko))
            city = cities_ko[ci]
            let oi = prng(i + 137, len(openers_ko))
            instruction = openers_ko[oi] + city
        } else {
            let ci = prng(i, len(cities_en))
            city = cities_en[ci]
            let oi = prng(i + 139, len(openers_en))
            instruction = openers_en[oi] + city
        }
        let ui = prng(i + 149, len(units))
        let u = units[ui]
        let args = "{\"location\":\"" + json_esc(city) + "\",\"units\":\"" + u + "\"}"
        lines = lines.push(build_record(tool, instruction, "get_weather", args))
        i = i + 1
    }
    return lines
}

