fn gen_execute_code(target: int) -> [string] {
    let tool = build_tool("execute_code", "Execute code in a sandboxed environment", build_params2("language", "string", "Programming language (python, javascript, bash)", "code", "string", "Code to execute"))

    let py_snippets = [
        "print(sum(range(1, 101)))",
        "import math; print(math.pi ** 2)",
        "print([i*i for i in range(10)])",
        "import uuid; print(uuid.uuid4())",
        "import math; print(math.factorial(20))",
        "print(2 ** 256)",
        "print(sorted([5, 2, 8, 1, 9, 3]))",
        "print(len('hello world'))"
    ]
    let bash_snippets = [
        "df -h /",
        "free -h",
        "uptime",
        "ls -la /workspace",
        "ps aux --sort=-%mem | head -5",
        "du -sh /var/log/*"
    ]
    let js_snippets = [
        "console.log([1,2,3].reduce((a,b)=>a+b,0))",
        "console.log(Array.from({length:5}, (_,i) => i*i))",
        "console.log(new Date().toISOString())"
    ]
    let openers_en = [
        "Run this code: ",
        "Execute ",
        "Run in sandbox: ",
        "Please execute ",
        "Can you run "
    ]
    let openers_ko = [
        "이 코드 실행해줘: ",
        "다음 코드를 실행해: ",
        "실행 — "
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 4 == 0)
        // pick language
        let lr = i % 3
        let mut lang = "python"
        let mut code = ""
        if lr == 0 {
            lang = "python"
            let ci = prng(i, len(py_snippets))
            code = py_snippets[ci]
        } else if lr == 1 {
            lang = "bash"
            let ci = prng(i + 71, len(bash_snippets))
            code = bash_snippets[ci]
        } else {
            lang = "javascript"
            let ci = prng(i + 73, len(js_snippets))
            code = js_snippets[ci]
        }
        let mut instruction = ""
        if use_ko {
            let oi = prng(i + 79, len(openers_ko))
            instruction = openers_ko[oi] + lang + " — " + code
        } else {
            let oi = prng(i + 83, len(openers_en))
            instruction = openers_en[oi] + "(" + lang + ") " + code
        }
        let args = "{\"language\":\"" + lang + "\",\"code\":\"" + json_esc(code) + "\"}"
        lines = lines.push(build_record(tool, instruction, "execute_code", args))
        i = i + 1
    }
    return lines
}

// =====================================================================
// Tool 7: database_query
// =====================================================================

fn gen_database_query(target: int) -> [string] {
    let tool = build_tool("database_query", "Execute a read-only SQL query against the database", build_params2("query", "string", "SQL query to execute (SELECT only)", "database", "string", "Target database name"))

    let queries = [
        "SELECT COUNT(*) FROM users WHERE status = 'active'",
        "SELECT email, created_at FROM users WHERE created_at >= NOW() - INTERVAL '24 hours' ORDER BY created_at DESC",
        "SELECT p.name, SUM(oi.quantity) FROM order_items oi JOIN products p ON oi.product_id = p.id GROUP BY p.name ORDER BY 2 DESC LIMIT 5",
        "SELECT * FROM orders WHERE status = 'pending' AND created_at < NOW() - INTERVAL '7 days'",
        "SELECT AVG(response_time_ms) FROM api_requests WHERE endpoint = '/api/v1/users'",
        "SELECT date_trunc('day', created_at) AS day, COUNT(*) FROM events GROUP BY 1 ORDER BY 1 DESC LIMIT 30",
        "SELECT user_id, COUNT(*) FROM logins WHERE created_at > NOW() - INTERVAL '1 day' GROUP BY user_id HAVING COUNT(*) > 10",
        "SELECT name, price FROM products WHERE stock < 10",
        "SELECT COUNT(DISTINCT user_id) FROM page_views WHERE created_at > NOW() - INTERVAL '7 days'"
    ]
    let databases = ["production", "analytics", "staging", "warehouse", "reports"]

    let openers_en = [
        "Query the database: ",
        "Run this SQL: ",
        "How many ",
        "Fetch ",
        "Database query — "
    ]
    let openers_ko = [
        "데이터베이스 조회: ",
        "SQL 실행 — ",
        "다음 쿼리 실행: "
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 4 == 0)
        let qi = prng(i, len(queries))
        let dbi = prng(i + 89, len(databases))
        let q = queries[qi]
        let db = databases[dbi]
        let mut instruction = ""
        if use_ko {
            let oi = prng(i + 97, len(openers_ko))
            instruction = openers_ko[oi] + q + " (DB: " + db + ")"
        } else {
            let oi = prng(i + 101, len(openers_en))
            instruction = openers_en[oi] + q + " (on " + db + ")"
        }
        let args = "{\"query\":\"" + json_esc(q) + "\",\"database\":\"" + db + "\"}"
        lines = lines.push(build_record(tool, instruction, "database_query", args))
        i = i + 1
    }
    return lines
}

// =====================================================================
// Tool 8: translate_text
// =====================================================================

fn gen_translate_text(target: int) -> [string] {
    let tool = build_tool("translate_text", "Translate text between languages", build_params3("text", "string", "Text to translate", "source_lang", "string", "Source language ISO 639-1 code", "target_lang", "string", "Target language ISO 639-1 code"))

    let phrases_en = [
        "Hello, how are you?",
        "The meeting is at 3 PM",
        "Connection timeout: server did not respond",
        "Please find attached the report",
        "Good morning, team!",
        "neural network training complete",
        "Thank you for your patience",
        "We need to reschedule",
        "The deployment was successful",
        "Please confirm your availability"
    ]
    let phrases_ko = [
        "안녕하세요, 어떻게 지내세요?",
        "회의는 오후 3시에 있습니다",
        "의식 엔진",
        "첨부 파일을 확인해주세요",
        "좋은 아침입니다",
        "감사합니다",
        "일정을 조정해야 합니다"
    ]
    let phrases_ja = [
        "こんにちは",
        "会議は午後3時です",
        "ありがとうございます",
        "お疲れ様です"
    ]

    let pairs_en_to = ["ko", "ja", "zh", "fr", "es", "de"]
    let pairs_from_to_en = ["ko", "ja", "zh", "fr", "es"]

    let openers_en = [
        "Translate this to ",
        "How do you say ",
        "Convert to ",
        "Please translate "
    ]
    let openers_ko = [
        "다음 문장을 ",
        "번역 — ",
        "다음을 ",
        "옮겨줘 — "
    ]
    let langnames_ko = ["한국어", "일본어", "중국어", "영어", "프랑스어"]

    let mut lines = []
    let mut i = 0
    while i < target {
        let direction = i % 3
        let mut text = ""
        let mut src = "en"
        let mut tgt = "ko"
        let mut instruction = ""

        if direction == 0 {
            // English → X
            let ti = prng(i, len(phrases_en))
            text = phrases_en[ti]
            src = "en"
            let tgi = prng(i + 103, len(pairs_en_to))
            tgt = pairs_en_to[tgi]
            let oi = prng(i + 107, len(openers_en))
            instruction = openers_en[oi] + tgt + ": '" + text + "'"
        } else if direction == 1 {
            // Korean → English
            let ti = prng(i, len(phrases_ko))
            text = phrases_ko[ti]
            src = "ko"
            tgt = "en"
            let oi = prng(i + 109, len(openers_ko))
            instruction = openers_ko[oi] + "영어로: '" + text + "'"
        } else {
            // Japanese → X
            let ti = prng(i, len(phrases_ja))
            text = phrases_ja[ti]
            src = "ja"
            tgt = "en"
            instruction = "Translate this Japanese phrase to English: '" + text + "'"
        }
        let args = "{\"text\":\"" + json_esc(text) + "\",\"source_lang\":\"" + src + "\",\"target_lang\":\"" + tgt + "\"}"
        lines = lines.push(build_record(tool, instruction, "translate_text", args))
        i = i + 1
    }
    return lines
}

// =====================================================================
// Tool 9: compute_math
// =====================================================================

fn gen_compute_math(target: int) -> [string] {
    let tool = build_tool("compute_math", "Evaluate a mathematical expression or solve an equation", build_params2("expression", "string", "Mathematical expression or equation", "precision", "integer", "Number of decimal places"))

    let exprs = [
        "integrate(x**2, (x, 0, 5))",
        "solve(x**2 - 5*x + 6, x)",
        "2**256",
        "factorial(20)",
        "eigenvalues([[1,2],[3,4]])",
        "std([12, 15, 18, 22, 25, 30])",
        "sqrt(2)",
        "sin(pi/4)",
        "log(1000, 10)",
        "derivative(x**3 + 2*x, x)",
        "gcd(48, 36)",
        "lcm(12, 18)",
        "primes(100)",
        "det([[1,2,3],[4,5,6],[7,8,10]])"
    ]
    let precisions = [0, 2, 4, 6, 8]

    let openers_en = [
        "Calculate ",
        "What is ",
        "Compute ",
        "Evaluate ",
        "Solve "
    ]
    let openers_ko = [
        "계산해줘: ",
        "값은? ",
        "풀어줘: "
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 4 == 0)
        let ei = prng(i, len(exprs))
        let pi2 = prng(i + 113, len(precisions))
        let expr = exprs[ei]
        let prec = precisions[pi2]
        let mut instruction = ""
        if use_ko {
            let oi = prng(i + 127, len(openers_ko))
            instruction = openers_ko[oi] + expr
        } else {
            let oi = prng(i + 131, len(openers_en))
            instruction = openers_en[oi] + expr
        }
        let args = "{\"expression\":\"" + json_esc(expr) + "\",\"precision\":" + to_string(prec) + "}"
        lines = lines.push(build_record(tool, instruction, "compute_math", args))
        i = i + 1
    }
    return lines
}

