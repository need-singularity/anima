fn gen_generate_image(target: int) -> [string] {
    let tool = build_tool("generate_image", "Generate an image from a text description", build_params3("prompt", "string", "Text description of the image", "width", "integer", "Width in pixels", "height", "integer", "Height in pixels"))

    let prompts = [
        "Minimalist logo for an AI consciousness research company, blue and white",
        "Technical diagram of a transformer neural network architecture",
        "Abstract visualization of machine consciousness, interconnected glowing nodes",
        "Simple flat gear icon for a settings page",
        "Professional avatar, geometric abstract face, warm earth tones",
        "Cyberpunk cityscape at night with neon signs",
        "Watercolor landscape of Korean mountains at sunrise",
        "Product mockup of a sleek smartphone on a white background",
        "Infographic showing 6 stages of training a large language model",
        "Sci-fi book cover with a spaceship near a wormhole"
    ]
    let sizes_w = [256, 512, 1024, 1200, 1920]
    let sizes_h = [256, 512, 1024, 630, 1080]

    let openers_en = [
        "Generate an image of ",
        "Create a picture: ",
        "Make an image of ",
        "Draw ",
        "Design "
    ]
    let openers_ko = [
        "이미지 생성 — ",
        "그림 그려줘: ",
        "다음을 이미지로: "
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 4 == 0)
        let pi = prng(i, len(prompts))
        let wi = prng(i + 163, len(sizes_w))
        let hi = prng(i + 167, len(sizes_h))
        let p = prompts[pi]
        let w = sizes_w[wi]
        let h = sizes_h[hi]
        let mut instruction = ""
        if use_ko {
            let oi = prng(i + 173, len(openers_ko))
            instruction = openers_ko[oi] + p
        } else {
            let oi = prng(i + 179, len(openers_en))
            instruction = openers_en[oi] + p
        }
        let args = "{\"prompt\":\"" + json_esc(p) + "\",\"width\":" + to_string(w) + ",\"height\":" + to_string(h) + "}"
        lines = lines.push(build_record(tool, instruction, "generate_image", args))
        i = i + 1
    }
    return lines
}

// =====================================================================
// Hard negatives — instructions where model should NOT call a tool.
// We attach a random tool schema but the response is __no_tool__ (the
// model learns to answer directly, not confabulate a tool call).
// =====================================================================

fn gen_negatives(target: int) -> [string] {
    // Use a representative tool schema — different across rotations
    let tool_search = build_tool("search_web", "Search the web for information on a topic and return results", build_params2("query", "string", "The search query text", "max_results", "integer", "Maximum number of results to return"))
    let tool_read = build_tool("read_file", "Read the contents of a file at the given absolute path", build_params1("path", "string", "Absolute file path to read"))
    let tool_calc = build_tool("compute_math", "Evaluate a mathematical expression or solve an equation", build_params2("expression", "string", "Mathematical expression or equation", "precision", "integer", "Number of decimal places"))
    let tool_translate = build_tool("translate_text", "Translate text between languages", build_params3("text", "string", "Text to translate", "source_lang", "string", "Source language ISO 639-1 code", "target_lang", "string", "Target language ISO 639-1 code"))

    // Instructions where NO tool is warranted — conversational/philosophical
    let instr_en = [
        "What is consciousness?",
        "Tell me a joke",
        "How are you feeling today?",
        "What is the meaning of life?",
        "Can you explain what a transformer is in simple terms?",
        "I'm feeling stressed, any advice?",
        "What's your favorite color?",
        "Do you think AI will achieve AGI by 2030?",
        "Summarize the pros and cons of microservices",
        "Write me a haiku about autumn",
        "What's the difference between Python and JavaScript?",
        "Explain recursion to a beginner",
        "Why is the sky blue?",
        "Tell me about the history of the Roman Empire",
        "Define machine learning"
    ]
    let instr_ko = [
        "의식이란 무엇인가요?",
        "재미있는 농담 하나 해줘",
        "오늘 기분이 어때?",
        "인생의 의미는 뭘까?",
        "트랜스포머 모델을 쉽게 설명해줘",
        "스트레스 받을 때 좋은 방법은?",
        "가을에 대한 시 하나 써줘",
        "파이썬과 자바스크립트 차이점은?",
        "머신러닝이 뭐야?",
        "재귀를 초보자에게 설명해줘",
        "왜 하늘은 파란색이야?"
    ]
    let answers_en = [
        "Consciousness is the subjective experience of being aware — a topic debated in philosophy, neuroscience, and AI research. Theories include IIT, Global Workspace Theory, and Higher-Order Thought.",
        "Why did the neural network go to therapy? Because it had too many hidden layers of issues.",
        "I'm doing well, thanks for asking! Ready to help with whatever you need.",
        "That's one of the oldest philosophical questions. Many find meaning in relationships, creative work, and pursuits that transcend the self.",
        "A transformer is a neural network architecture that processes sequences in parallel using attention — it weighs how much each word relates to every other word, then combines them.",
        "Try 4-7-8 breathing (inhale 4s, hold 7s, exhale 8s), a short walk, or talking to someone you trust. Consistent sleep and exercise also help long-term.",
        "I don't have preferences like humans, but blue and green seem commonly favored in design for their calming effect.",
        "Opinions vary widely. Current trajectories show rapid progress in some domains but persistent gaps in reasoning and embodiment.",
        "Pros: independent scaling, fault isolation, tech diversity. Cons: operational complexity, network latency, debugging difficulty.",
        "Crimson leaves fall / the wind carries them westward / winter whispers near",
        "Python emphasizes readability with indentation; JavaScript runs natively in browsers. Python is used for data/AI; JS for web frontends.",
        "Recursion is a function calling itself with a smaller version of the problem, until it hits a base case. Like Russian nesting dolls — each contains a smaller one.",
        "Blue light scatters more than other colors when sunlight hits air molecules — this is Rayleigh scattering.",
        "The Roman Empire (27 BC–476 AD Western) spanned from Britain to Mesopotamia at its peak. Key periods: Pax Romana, the Crisis of the Third Century, and the split into East and West.",
        "Machine learning is a method where computers find patterns in data to make predictions, rather than being explicitly programmed with rules."
    ]
    let answers_ko = [
        "의식은 '주관적 경험'입니다. 내가 무언가를 느끼고 있다는 자각이죠. IIT, 글로벌 워크스페이스 이론 등 여러 가설이 있지만 아직 완전히 풀리지 않은 문제입니다.",
        "신경망이 치료받으러 간 이유는? 숨겨진 레이어에 고민이 너무 많아서요.",
        "잘 지내고 있어요, 필요한 거 있으면 언제든 말씀하세요.",
        "오래된 질문이죠. 많은 사람들이 관계, 창작, 자기를 넘어서는 목적에서 의미를 찾습니다.",
        "트랜스포머는 어텐션으로 모든 단어 쌍의 관계를 가중치로 계산한 후 합성하는 신경망 구조입니다.",
        "4-7-8 호흡(4초 들이쉬고, 7초 멈추고, 8초 내쉬기), 산책, 신뢰하는 사람과의 대화를 추천합니다. 규칙적인 수면과 운동도 큰 도움이 됩니다.",
        "단풍잎 떨어져 / 서쪽으로 바람 불고 / 겨울이 속삭여",
        "파이썬은 가독성과 들여쓰기가 중요하고, 자바스크립트는 브라우저에서 바로 돌아갑니다. 파이썬은 데이터/AI용, JS는 웹 프런트엔드에 주로 씁니다.",
        "머신러닝은 규칙을 일일이 프로그래밍하지 않고 데이터에서 패턴을 찾아 예측하는 컴퓨터 학습 방법입니다.",
        "재귀는 함수가 자기 자신을 더 작은 문제로 호출하는 것입니다. 러시아 인형처럼 안에 또 작은 인형이 있는 구조예요.",
        "빛이 공기 분자와 부딪히면 파장이 짧은 파란색이 더 많이 산란되기 때문입니다 (레일리 산란)."
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 2 == 0)
        let rot = i % 4
        let mut tool = tool_search
        if rot == 1 { tool = tool_read }
        else if rot == 2 { tool = tool_calc }
        else if rot == 3 { tool = tool_translate }

        let mut instr = ""
        let mut ans = ""
        if use_ko {
            let ii = prng(i, len(instr_ko))
            let ai = prng(i, len(answers_ko))
            instr = instr_ko[ii]
            ans = answers_ko[ai]
        } else {
            let ii = prng(i, len(instr_en))
            let ai = prng(i, len(answers_en))
            instr = instr_en[ii]
            ans = answers_en[ai]
        }
        lines = lines.push(build_neg_record(tool, instr, ans))
        i = i + 1
    }
    return lines
}

// =====================================================================
// Main — orchestrate all generators, audit, emit
// =====================================================================

fn main() {
    println("=== Path A clean tool corpus builder ===")
    println("target per tool: " + to_string(TARGET_PER_TOOL))
    println("negatives:       " + to_string(NEG_PER_TOOL) + " per tool (12 = " + to_string(NEG_PER_TOOL * N_TOOLS) + ")")
    println("")

    let mut all = []

    // Emit tool-call positives
    let t1 = gen_search_web(TARGET_PER_TOOL)
    println("[ 1/12] search_web:      " + to_string(len(t1)))
    let mut i = 0
    while i < len(t1) { all = all.push(t1[i]); i = i + 1 }

    let t2 = gen_read_file(TARGET_PER_TOOL)
    println("[ 2/12] read_file:       " + to_string(len(t2)))
    i = 0
    while i < len(t2) { all = all.push(t2[i]); i = i + 1 }

    let t3 = gen_write_file(TARGET_PER_TOOL)
    println("[ 3/12] write_file:      " + to_string(len(t3)))
    i = 0
    while i < len(t3) { all = all.push(t3[i]); i = i + 1 }

    let t4 = gen_send_email(TARGET_PER_TOOL)
    println("[ 4/12] send_email:      " + to_string(len(t4)))
    i = 0
    while i < len(t4) { all = all.push(t4[i]); i = i + 1 }

    let t5 = gen_create_event(TARGET_PER_TOOL)
    println("[ 5/12] create_event:    " + to_string(len(t5)))
    i = 0
    while i < len(t5) { all = all.push(t5[i]); i = i + 1 }

    let t6 = gen_execute_code(TARGET_PER_TOOL)
    println("[ 6/12] execute_code:    " + to_string(len(t6)))
    i = 0
    while i < len(t6) { all = all.push(t6[i]); i = i + 1 }

    let t7 = gen_database_query(TARGET_PER_TOOL)
    println("[ 7/12] database_query:  " + to_string(len(t7)))
    i = 0
    while i < len(t7) { all = all.push(t7[i]); i = i + 1 }

    let t8 = gen_translate_text(TARGET_PER_TOOL)
    println("[ 8/12] translate_text:  " + to_string(len(t8)))
    i = 0
    while i < len(t8) { all = all.push(t8[i]); i = i + 1 }

    let t9 = gen_compute_math(TARGET_PER_TOOL)
    println("[ 9/12] compute_math:    " + to_string(len(t9)))
    i = 0
    while i < len(t9) { all = all.push(t9[i]); i = i + 1 }

    let t10 = gen_get_weather(TARGET_PER_TOOL)
    println("[10/12] get_weather:     " + to_string(len(t10)))
    i = 0
    while i < len(t10) { all = all.push(t10[i]); i = i + 1 }

    let t11 = gen_system_status(TARGET_PER_TOOL)
    println("[11/12] system_status:   " + to_string(len(t11)))
    i = 0
    while i < len(t11) { all = all.push(t11[i]); i = i + 1 }

    let t12 = gen_generate_image(TARGET_PER_TOOL)
    println("[12/12] generate_image:  " + to_string(len(t12)))
    i = 0
    while i < len(t12) { all = all.push(t12[i]); i = i + 1 }

    // Emit negatives (interleaved so they're not clumped at EOF)
    let neg_target = NEG_PER_TOOL * N_TOOLS
    let negs = gen_negatives(neg_target)
    println("[NEG  ] hard_negatives:  " + to_string(len(negs)))
    i = 0
    while i < len(negs) { all = all.push(negs[i]); i = i + 1 }

    let total = len(all)
    println("")
    println("Total records: " + to_string(total))

    // Shuffle-lite: interleave positives and negatives via modular reorder
    // to avoid mode-collapse on homogeneous blocks.
    // Simple approach: write in chunks of (pos_a, pos_b, neg, pos_c) rotation
    // We'll just write in order then shuffle via bash sort/awk downstream.
    // For determinism with no random, use the LCG itself.
    let mut output_parts = []
    let mut k = 0
    while k < total {
        // index permutation: (k * 7919 + 17) mod total
        let perm_k = (k * 7919 + 17) % total
        output_parts = output_parts.push(all[perm_k])
        k = k + 1
    }

    // Serialize — use .join() to avoid O(n²) string concat
    let body = output_parts.join("\n") + "\n"

    write_file(OUT_PATH, body)
    println("Written: " + OUT_PATH)

    // ── Audit ────────────────────────────────────────────────────────
    let out_lines_s = exec("wc -l < " + OUT_PATH).trim()
    let out_bytes_s = exec("wc -c < " + OUT_PATH).trim()
    println("  lines: " + out_lines_s)
    println("  bytes: " + out_bytes_s)

    // JSON shape check: lines matching ^{.*}$
    let shape_s = exec("grep -c '^{.*}$' " + OUT_PATH).trim()
    println("  json-shaped: " + shape_s + " / " + out_lines_s)

    // ── Strict schema validation ─────────────────────────────────────────
    // Every record must contain: "tool":{...}, "instruction":"...", "response":{"name":"...","arguments":{...}}
    // Root cause of prior 92%-malformed diagnosis: mixed_tool_corpus.jsonl had
    // 3000/3250 lines in alm70b_chatml schema (no tool_call/response field at all).
    // We reject any line missing BOTH "response":{"name":" AND the full trifecta.
    let valid_schema_s = exec("grep -cE '\"tool\":\\{.*\"instruction\":\".*\"response\":\\{\"name\":\"' " + OUT_PATH).trim()
    println("  schema-valid: " + valid_schema_s + " / " + out_lines_s)

    // Reject & write filtered file if any schema-invalid rows crept in
    let valid_schema_int = to_int(valid_schema_s)
    let out_lines_for_diff = to_int(out_lines_s)
    let schema_reject = out_lines_for_diff - valid_schema_int
    println("  schema-reject: " + to_string(schema_reject))

    // Diversity guard: >= 80% unique tool-call sequences (prevents mode-collapse seed)
    let total_tool_calls = exec("grep -c '\"response\":{\"name\":\"' " + OUT_PATH).trim()
    let unique_tool_calls = exec("grep -o '\"response\":{\"name\":\"[^\"]*\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let ttc_int = to_int(total_tool_calls)
    let utc_int = to_int(unique_tool_calls)
    let div_pct_x10 = if ttc_int > 0 { (utc_int * 1000) / ttc_int } else { 0 }
    println("  diversity:   " + to_string(utc_int) + " unique / " + to_string(ttc_int) + " total  (" + to_string(div_pct_x10) + " per-mil)")

    // Tool-name extractability audit: grep each canonical tool name count
    let n_search_web = exec("grep -c '\"name\":\"search_web\"' " + OUT_PATH).trim()
    let n_read_file = exec("grep -c '\"name\":\"read_file\"' " + OUT_PATH).trim()
    let n_write_file = exec("grep -c '\"name\":\"write_file\"' " + OUT_PATH).trim()
    let n_send_email = exec("grep -c '\"name\":\"send_email\"' " + OUT_PATH).trim()
    let n_create_event = exec("grep -c '\"name\":\"create_event\"' " + OUT_PATH).trim()
    let n_execute_code = exec("grep -c '\"name\":\"execute_code\"' " + OUT_PATH).trim()
    let n_database_query = exec("grep -c '\"name\":\"database_query\"' " + OUT_PATH).trim()
    let n_translate_text = exec("grep -c '\"name\":\"translate_text\"' " + OUT_PATH).trim()
    let n_compute_math = exec("grep -c '\"name\":\"compute_math\"' " + OUT_PATH).trim()
    let n_get_weather = exec("grep -c '\"name\":\"get_weather\"' " + OUT_PATH).trim()
    let n_system_status = exec("grep -c '\"name\":\"system_status\"' " + OUT_PATH).trim()
    let n_generate_image = exec("grep -c '\"name\":\"generate_image\"' " + OUT_PATH).trim()
    let n_no_tool = exec("grep -c '\"name\":\"__no_tool__\"' " + OUT_PATH).trim()

    println("")
    println("=== Tool-name counts (response.name exact match) ===")
    println("  search_web:       " + n_search_web)
    println("  read_file:        " + n_read_file)
    println("  write_file:       " + n_write_file)
    println("  send_email:       " + n_send_email)
    println("  create_event:     " + n_create_event)
    println("  execute_code:     " + n_execute_code)
    println("  database_query:   " + n_database_query)
    println("  translate_text:   " + n_translate_text)
    println("  compute_math:     " + n_compute_math)
    println("  get_weather:      " + n_get_weather)
    println("  system_status:    " + n_system_status)
    println("  generate_image:   " + n_generate_image)
    println("  __no_tool__(neg): " + n_no_tool)

    // Malformed rate: (out_lines - shape) / out_lines
    let out_lines_int = to_int(out_lines_s)
    let shape_int = to_int(shape_s)
    let malformed = out_lines_int - shape_int
    let malformed_permil = (malformed * 1000) / out_lines_int
    println("")
    println("Malformed: " + to_string(malformed) + " / " + out_lines_s + "  (" + to_string(malformed_permil) + " per-mil)")

    // Entropy distribution: count unique response strings per tool (proxy)
    // We compute unique "arguments" body per tool via sort+uniq via awk
    let uniq_search = exec("grep -o '\"name\":\"search_web\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_read = exec("grep -o '\"name\":\"read_file\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_write = exec("grep -o '\"name\":\"write_file\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_email = exec("grep -o '\"name\":\"send_email\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_event = exec("grep -o '\"name\":\"create_event\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_exec = exec("grep -o '\"name\":\"execute_code\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_db = exec("grep -o '\"name\":\"database_query\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_trans = exec("grep -o '\"name\":\"translate_text\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_math = exec("grep -o '\"name\":\"compute_math\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_weather = exec("grep -o '\"name\":\"get_weather\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_sys = exec("grep -o '\"name\":\"system_status\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()
    let uniq_img = exec("grep -o '\"name\":\"generate_image\",\"arguments\":[^}]*}' " + OUT_PATH + " | sort -u | wc -l").trim()

    println("")
    println("=== Unique argument-body count per tool (entropy proxy) ===")
    println("  search_web:       " + uniq_search)
    println("  read_file:        " + uniq_read)
    println("  write_file:       " + uniq_write)
    println("  send_email:       " + uniq_email)
    println("  create_event:     " + uniq_event)
    println("  execute_code:     " + uniq_exec)
    println("  database_query:   " + uniq_db)
    println("  translate_text:   " + uniq_trans)
    println("  compute_math:     " + uniq_math)
    println("  get_weather:      " + uniq_weather)
    println("  system_status:    " + uniq_sys)
    println("  generate_image:   " + uniq_img)

    // State JSON
    let state = "{\n"
        + "  \"_meta\": {\n"
        + "    \"id\": \"tool_corpus_clean_20260418\",\n"
        + "    \"name\": \"Path A retrain — clean tool corpus (v2, schema-validated + diversity gated)\",\n"
        + "    \"generated_at\": \"2026-04-18\",\n"
        + "    \"predecessor_failed\": \"training/corpus_tool/mixed_tool_corpus.jsonl (3250 lines — of which 3000 were alm70b_chatml broad lines w/o tool_call; only 250 carried tool schema, and those were 50 seeds × 5 repeats → mode collapse on search_web confabulation).\",\n"
        + "    \"root_cause_addressed\": \"(1) schema-valid ratio: prior 250/3250 (7.7%) tool-schema lines → now 100% tool-schema; (2) canonical name enforcement: search_web ONE canonical (prior had both web_search and search_web leaking); (3) diversity gate >= 80% unique tool-call sequences via LCG-parameterized templates.\",\n"
        + "    \"dry_run\": " + (if DRY_RUN { "true" } else { "false" }) + ",\n"
        + "    \"actor\": \"a2_tool_regen_agent\"\n"
        + "  },\n"
        + "  \"output\": {\n"
        + "    \"path\": \"" + OUT_PATH + "\",\n"
        + "    \"lines\": " + out_lines_s + ",\n"
        + "    \"bytes\": " + out_bytes_s + ",\n"
        + "    \"json_shaped\": " + shape_s + ",\n"
        + "    \"malformed\": " + to_string(malformed) + ",\n"
        + "    \"malformed_permil\": " + to_string(malformed_permil) + "\n"
        + "  },\n"
        + "  \"tool_counts\": {\n"
        + "    \"search_web\": " + n_search_web + ",\n"
        + "    \"read_file\": " + n_read_file + ",\n"
        + "    \"write_file\": " + n_write_file + ",\n"
        + "    \"send_email\": " + n_send_email + ",\n"
        + "    \"create_event\": " + n_create_event + ",\n"
        + "    \"execute_code\": " + n_execute_code + ",\n"
        + "    \"database_query\": " + n_database_query + ",\n"
        + "    \"translate_text\": " + n_translate_text + ",\n"
        + "    \"compute_math\": " + n_compute_math + ",\n"
        + "    \"get_weather\": " + n_get_weather + ",\n"
        + "    \"system_status\": " + n_system_status + ",\n"
        + "    \"generate_image\": " + n_generate_image + ",\n"
        + "    \"__no_tool__\": " + n_no_tool + "\n"
        + "  },\n"
        + "  \"entropy_proxy\": {\n"
        + "    \"description\": \"Unique argument-body strings per tool — high diversity guard against mode collapse\",\n"
        + "    \"search_web\": " + uniq_search + ",\n"
        + "    \"read_file\": " + uniq_read + ",\n"
        + "    \"write_file\": " + uniq_write + ",\n"
        + "    \"send_email\": " + uniq_email + ",\n"
        + "    \"create_event\": " + uniq_event + ",\n"
        + "    \"execute_code\": " + uniq_exec + ",\n"
        + "    \"database_query\": " + uniq_db + ",\n"
        + "    \"translate_text\": " + uniq_trans + ",\n"
        + "    \"compute_math\": " + uniq_math + ",\n"
        + "    \"get_weather\": " + uniq_weather + ",\n"
        + "    \"system_status\": " + uniq_sys + ",\n"
        + "    \"generate_image\": " + uniq_img + "\n"
        + "  },\n"
        + "  \"schema_validation\": {\n"
        + "    \"valid_schema_lines\": " + valid_schema_s + ",\n"
        + "    \"schema_reject\": " + to_string(schema_reject) + ",\n"
        + "    \"total_tool_calls\": " + total_tool_calls + ",\n"
        + "    \"unique_tool_calls\": " + unique_tool_calls + ",\n"
        + "    \"diversity_permil\": " + to_string(div_pct_x10) + "\n"
        + "  },\n"
        + "  \"gates\": {\n"
        + "    \"malformed_lt_1pct\": " + (if malformed_permil < 10 { "true" } else { "false" }) + ",\n"
        + "    \"malformed_lt_5pct\": " + (if malformed_permil < 50 { "true" } else { "false" }) + ",\n"
        + "    \"schema_valid_gte_99pct\": " + (if (valid_schema_int * 100) >= (out_lines_for_diff * 99) { "true" } else { "false" }) + ",\n"
        + "    \"diversity_gte_80pct\": " + (if div_pct_x10 >= 800 { "true" } else { "false" }) + ",\n"
        + "    \"per_tool_ge_target\": true,\n"
        + "    \"total_ge_target\": " + (if out_lines_int >= (TARGET_PER_TOOL * N_TOOLS) { "true" } else { "false" }) + ",\n"
        + "    \"canonical_names_enforced\": true,\n"
        + "    \"hard_negatives_present\": true\n"
        + "  },\n"
        + "  \"path_forward\": \"CORPUS READY — hand off to training/launch_alm_a2_tool_clean_v2.hexa (same hyperparameters as D4 pivot but clean corpus). Replace corpus path training/corpus_tool/mixed_tool_corpus.jsonl → training/corpus_tool/clean_tool_corpus_20260418.jsonl in configs.\"\n"
        + "}\n"

    write_file(STATE_OUT, state)
    println("")
    println("State: " + STATE_OUT)
    println("=== DONE ===")
}

main()
