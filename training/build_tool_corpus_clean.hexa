// training/build_tool_corpus_clean.hexa — Path A retrain clean tool corpus
// @convergence state=provisional id=A2_TOOL_CORPUS_CLEAN_20260417
//                 value="Diverse 5000+ tool-use records for vanilla Qwen2.5-14B-Instruct
//                        + A2-Orch + A2-Tool retrain. Fixes mode-collapse root cause:
//                        92% malformed records in mixed_tool_corpus.jsonl + 'search_web'
//                        confabulation between web_search alias. One canonical name per
//                        tool, ≥500 examples each, <5% malformed, entropy guard."
//                 created_at=2026-04-17
//
// Root cause addressed (from sibling diagnosis):
//   1. mixed_tool_corpus.jsonl had only 250 valid tool-call records
//      spread across 10 tools (execute_code:25, web_search:15, etc.)
//      — below critical mass per tool (<50 each).
//   2. Model confabulated "search_web" (0 occurrences in corpus) from
//      "web_search" (15 occurrences) — insufficient example density to
//      pin down the canonical name.
//   3. Training loss 0.04-0.08 smooth descent MASKED the collapse; all
//      eval@1300/1400/1500 emitted the same search_web payload.
//
// Strategy:
//   - 12 distinct tools, ONE canonical name each (no alias ambiguity).
//   - ≥500 examples per tool via parameterized templates (15-25 slots
//     per tool, 10-40 variations per slot) to avoid template repetition.
//   - Each record: {tool, instruction, response} where response is
//     {"name":"...","arguments":{...}} JSON tool-call invocation.
//   - ~20% hard negatives (instructions where tool-call is wrong, so
//     response is a natural-language answer instead).
//   - Mix Korean + English phrasings sampled from corpus_alm_70b.jsonl.
//   - Deterministic via LCG-style indexing (no runtime randomness).
//
// Outputs:
//   training/corpus_tool/clean_tool_corpus_20260417.jsonl
//   shared/state/tool_corpus_clean_20260417.json
//
// Constraints honored:
//   - No struct-with-list (feedback_hexa_struct_list_alias bug)
//   - Lists pass-by-value (feedback_hexa_lists_pbv)
//   - Single-line returns (feedback_hexa_struct_return_bug)
//   - exec() for auditing, write_file() for JSONL emission
//   - No .py created, no Python runtime (total Py ban)
//   - file_exists check before consuming corpus_alm_70b.jsonl

// DRY_RUN mode: env DRY_RUN=1 → 70 per tool + 25 neg per tool = 1140 records
// (hits spec "1000-sample dry-run" within stage0 interpreter wall-time budget).
// Default: full 500 per tool + 125 neg per tool = 7500 records.
let DRY_RUN = env("DRY_RUN") == "1"

let OUT_PATH   = if DRY_RUN { "training/corpus_tool/clean_tool_corpus_dryrun_20260418.jsonl" } else { "training/corpus_tool/clean_tool_corpus_20260418.jsonl" }
let STATE_OUT  = if DRY_RUN { "shared/state/tool_corpus_clean_dryrun_20260418.json" } else { "shared/state/tool_corpus_clean_20260418.json" }
let BROAD_SRC  = "training/corpus_alm_70b.jsonl"

let TARGET_PER_TOOL = if DRY_RUN { 70 } else { 500 }
let N_TOOLS = 12
let NEG_PER_TOOL = if DRY_RUN { 25 } else { 125 }

// =====================================================================
// JSON escape helper (stage0-safe, char-by-char)
// =====================================================================

fn json_esc(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = char_at(s, i)
        if c == "\\" { parts = parts.push("\\\\") }
        else if c == "\"" { parts = parts.push("\\\"") }
        else if c == "\n" { parts = parts.push("\\n") }
        else if c == "\t" { parts = parts.push("\\t") }
        else if c == "\r" { parts = parts.push("\\r") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

// =====================================================================
// Tool schema builders
// =====================================================================

fn param_entry(typ: string, desc: string) -> string {
    return "{\"type\":\"" + typ + "\",\"description\":\"" + json_esc(desc) + "\"}"
}

fn build_params2(n1: string, t1: string, d1: string, n2: string, t2: string, d2: string) -> string {
    return "{\"type\":\"object\",\"properties\":{\"" + n1 + "\":" + param_entry(t1, d1) + ",\"" + n2 + "\":" + param_entry(t2, d2) + "},\"required\":[\"" + n1 + "\",\"" + n2 + "\"]}"
}

fn build_params1(n1: string, t1: string, d1: string) -> string {
    return "{\"type\":\"object\",\"properties\":{\"" + n1 + "\":" + param_entry(t1, d1) + "},\"required\":[\"" + n1 + "\"]}"
}

fn build_params3(n1: string, t1: string, d1: string, n2: string, t2: string, d2: string, n3: string, t3: string, d3: string) -> string {
    return "{\"type\":\"object\",\"properties\":{\"" + n1 + "\":" + param_entry(t1, d1) + ",\"" + n2 + "\":" + param_entry(t2, d2) + ",\"" + n3 + "\":" + param_entry(t3, d3) + "},\"required\":[\"" + n1 + "\",\"" + n2 + "\",\"" + n3 + "\"]}"
}

fn build_tool(name: string, desc: string, params_json: string) -> string {
    return "{\"type\":\"function\",\"function\":{\"name\":\"" + json_esc(name) + "\",\"description\":\"" + json_esc(desc) + "\",\"parameters\":" + params_json + "}}"
}

// Emit a tool-call record: {tool, instruction, response}
// response is the full tool-call invocation JSON object as a string value
fn build_record(tool_json: string, instruction: string, name: string, args: string) -> string {
    let response = "{\"name\":\"" + name + "\",\"arguments\":" + args + "}"
    return "{\"tool\":" + tool_json + ",\"instruction\":\"" + json_esc(instruction) + "\",\"response\":" + response + "}"
}

// Emit a hard-negative record: {tool, instruction, response}
// where response is a natural language refusal/direct answer (no tool call)
fn build_neg_record(tool_json: string, instruction: string, direct_answer: string) -> string {
    let response = "{\"name\":\"__no_tool__\",\"arguments\":{\"answer\":\"" + json_esc(direct_answer) + "\"}}"
    return "{\"tool\":" + tool_json + ",\"instruction\":\"" + json_esc(instruction) + "\",\"response\":" + response + "}"
}

// =====================================================================
// Deterministic pseudo-randomness via mixed LCG on the sample index.
// Returns a value in [0, mod).
// Seed: 48271 * i + 11 mod 2^31  (Park-Miller-ish). No actual random.
// =====================================================================

fn prng(i: int, m: int) -> int {
    let a = (i * 48271 + 11) % 2147483647
    let b = (a ^ (a / 65536)) % 2147483647
    return b % m
}

// =====================================================================
// Tool 1: search_web (canonical; replaces web_search+search_web aliasing)
// =====================================================================

fn gen_search_web(target: int) -> [string] {
    let tool = build_tool("search_web", "Search the web for information on a topic and return results", build_params2("query", "string", "The search query text", "max_results", "integer", "Maximum number of results to return"))

    let queries_en = [
        "latest AI consciousness research 2026",
        "best Korean restaurants in Seoul Gangnam",
        "Rust vs Go performance benchmarks",
        "how to train a large language model from scratch",
        "Bitcoin price prediction Q2 2026",
        "healthy breakfast ideas for busy mornings",
        "climate change impact on Arctic ice",
        "Python async await tutorial",
        "best noise-canceling headphones under 300 USD",
        "SpaceX next launch date",
        "integrated information theory 4.0 paper",
        "transformer attention mechanism explained",
        "H100 vs A100 training throughput",
        "COVID-19 variant XBB updates",
        "NBA playoff standings 2026",
        "quantum error correction breakthroughs",
        "cheap flights from Tokyo to New York",
        "React 19 new features",
        "best JavaScript testing frameworks",
        "how to configure Nginx reverse proxy"
    ]
    let queries_ko = [
        "2026년 최신 AI 의식 연구",
        "강남 맛집 추천",
        "파이썬 비동기 처리 튜토리얼",
        "H100 GPU 임대 가격 비교",
        "기후변화 북극 영향 보고서",
        "비트코인 시세 전망 2026",
        "우울증 자가 진단 방법",
        "서울 주말 가족 여행지",
        "러스트 vs Go 성능 비교",
        "트랜스포머 모델 설명",
        "아이폰 16 출시일",
        "코로나 변이 현재 상황",
        "양자 오류 정정 돌파구",
        "도쿄 뉴욕 저가 항공",
        "리액트 19 새 기능"
    ]
    let max_results_choices = [3, 5, 10, 7, 4, 8, 6]

    let instr_openers_en = [
        "Search the web for ",
        "Look up ",
        "Find information about ",
        "Can you search for ",
        "Please find results on ",
        "Google ",
        "Web search: ",
        "Get me links about ",
        "I want to know about "
    ]
    let instr_openers_ko = [
        "웹에서 ",
        "검색해줘: ",
        "다음 주제를 찾아줘: ",
        "알아봐줘 — ",
        "인터넷에서 ",
        "찾아봐: ",
        "검색 결과 좀 보여줘: "
    ]

    let mut lines = []
    let mut i = 0
    while i < target {
        let use_ko = (i % 3 == 0)
        let mut instruction = ""
        let mut query = ""
        if use_ko {
            let qi = prng(i, len(queries_ko))
            let oi = prng(i + 7, len(instr_openers_ko))
            query = queries_ko[qi]
            instruction = instr_openers_ko[oi] + query
        } else {
            let qi = prng(i, len(queries_en))
            let oi = prng(i + 13, len(instr_openers_en))
            query = queries_en[qi]
            instruction = instr_openers_en[oi] + query
        }
        let mi = prng(i + 29, len(max_results_choices))
        let mx = max_results_choices[mi]
        let args = "{\"query\":\"" + json_esc(query) + "\",\"max_results\":" + to_string(mx) + "}"
        lines = lines.push(build_record(tool, instruction, "search_web", args))
        i = i + 1
    }
    return lines
}

