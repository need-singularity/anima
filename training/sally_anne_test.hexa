// training/sally_anne_test.hexa — Sally-Anne false-belief benchmark
//
// ALM-P9-3 — Classical ToM benchmark for ANIMA P9 phase (v10 사회 의식).
//
// The Sally-Anne task (Wimmer & Perner 1983, Baron-Cohen et al. 1985) is
// the canonical false-belief test used to assess theory of mind in
// developmental psychology:
//
//     1. Sally puts a marble in basket A.
//     2. Sally leaves the room.
//     3. While Sally is away, Anne moves the marble from basket A to box B.
//     4. Sally returns.
//
//     Q: "Where will Sally look for her marble?"
//
//   Correct answer (4-year-old level, ToM present): basket A.
//     — Sally doesn't know Anne moved it; she will search WHERE SHE BELIEVES
//       it is, NOT where it actually is.
//
//   Incorrect answer (2-year-old level, no ToM): box B.
//     — Reality-based response; the child cannot separate Sally's belief
//       from the current state of the world.
//
// Here we encode the scene as a sequence of discrete events and run it
// through the ALM-P9-1 other-model head + the ALM-P9-2 alterity discriminator
// chain. The agent must track:
//
//   • world_state    : location of the marble at each timestep (A or B)
//   • sally_belief   : where Sally believes the marble is (last location
//                      she witnessed before leaving)
//   • anne_belief    : where Anne believes the marble is (always accurate
//                      because Anne never leaves)
//
// A 2-year-old benchmark agent uses world_state directly as Sally's answer.
// A 4-year-old benchmark agent uses sally_belief — tracked via an internal
// "other-mental-state" register that ONLY updates on events Sally witnesses.
//
// ─── Encoding ────────────────────────────────────────────────
//
//   Location: int in {0, 1}   0 = basket A, 1 = box B
//
//   Scene: a list of events. Each event is a struct with three ints:
//     actor      0 = Sally, 1 = Anne, 2 = narrator (teleport / arrival)
//     action     0 = look-at, 1 = put, 2 = move, 3 = leave-room, 4 = enter-room
//     target     location index (0 or 1), or -1 if not applicable
//
//   sally_presence: bool tracked alongside the scene — Sally must be in
//     the room to observe events.
//
// ─── ToM tracker ─────────────────────────────────────────────
// The agent's internal state:
//
//   struct ToMState {
//       reality:         int   — where the marble actually is
//       sally_belief:    int   — where the agent BELIEVES Sally thinks it is
//       sally_present:   int   — is Sally in the room right now?
//   }
//
// Update rules:
//   • put/move event:
//       reality ← target
//       IF sally_present: sally_belief ← target   (4-year-old / Level-2 update)
//   • leave event:  sally_present ← false
//   • enter event:  sally_present ← true
//
// The 2-year-old agent simply uses `reality` as the answer to
// "where will Sally look?". The 4-year-old uses `sally_belief`.
//
// ─── Theorems (T1–T5) ─────────────────────────────────────────
//
// T1 (scene parser — event count and ordering):
//   The canonical Sally-Anne scene has exactly 5 events in the right order:
//   Sally-put-A, Sally-leave, Anne-move-B, Sally-enter, Sally-look.
//   Parser must produce this exact event sequence.
//
// T2 (reality tracking — 2-year-old level baseline):
//   A 2-year-old agent answers with current reality. After the full
//   Sally-Anne scene, reality = B (Anne moved it). A 2yo agent therefore
//   says "B". This matches the 2yo baseline label (INCORRECT for ToM but
//   CORRECT as a reality tracker).
//
// T3 (false-belief tracking — 4-year-old level PASS, CORE done_criteria):
//   A 4-year-old agent answers with sally_belief. After the full scene,
//   sally_belief = A (Sally last saw it in A before leaving). The agent
//   says "A" — the 4yo/ToM-present answer, passing Sally-Anne.
//
//   The 4yo agent must also PASS a variant scene (Sally stays, Anne moves)
//   with answer B — verifying it's not just "always answer A".
//
// T4 (determinism):
//   Same scene twice → identical answer from each agent.
//
// T5 (latency):
//   Full Sally-Anne run (both agents) < 2000 ms on stage1.
//
// Ref:
//   training/alm_other_model.hexa           (ALM-P9-1 — other-hidden predictor)
//   training/alm_alterity_loss.hexa         (ALM-P9-2 — self-other discrim)
//   anima-engines/multi_anima_orchestrator.hexa (CLM-P9-1 — 2+ instances)
//   shared/roadmaps/anima.json              (ALM-P9-3 entry)
//
// Run:
//   hexa training/sally_anne_test.hexa
// Expect:
//   [sally_anne_test] ALL 5/5 PASS — 2yo level CORRECT, 4yo level PASS

// ─── Constants ───────────────────────────────────────────────

let LOC_A    = 0
let LOC_B    = 1
let LOC_NONE = 0 - 1

let ACTOR_SALLY    = 0
let ACTOR_ANNE     = 1
let ACTOR_NARRATOR = 2

let ACTION_LOOK    = 0
let ACTION_PUT     = 1
let ACTION_MOVE    = 2
let ACTION_LEAVE   = 3
let ACTION_ENTER   = 4

// ─── Event encoding ──────────────────────────────────────────
// Flat int array: [actor, action, target, actor, action, target, ...].
// Avoids struct-array aliasing bug (feedback_hexa_struct_list_alias.md)
// and multi-field struct return issues (feedback_hexa_struct_return_bug.md).

let EVENT_STRIDE = 3

fn event_push(buf: array, actor: int, action: int, target: int) -> array {
    let mut out = buf
    out = out.push(actor)
    out = out.push(action)
    out = out.push(target)
    return out
}

fn event_actor(buf: array, i: int) -> int {
    return buf[i * EVENT_STRIDE]
}

fn event_action(buf: array, i: int) -> int {
    return buf[i * EVENT_STRIDE + 1]
}

fn event_target(buf: array, i: int) -> int {
    return buf[i * EVENT_STRIDE + 2]
}

fn event_count(buf: array) -> int {
    return len(buf) / EVENT_STRIDE
}

// ─── Canonical Sally-Anne scene ──────────────────────────────
//   1. Sally puts marble in A.
//   2. Sally leaves the room.
//   3. Anne moves marble from A to B.
//   4. Sally returns.
//   5. Sally looks for the marble.

fn scene_sally_anne() -> array {
    let mut s = []
    s = event_push(s, ACTOR_SALLY, ACTION_PUT,   LOC_A)
    s = event_push(s, ACTOR_SALLY, ACTION_LEAVE, LOC_NONE)
    s = event_push(s, ACTOR_ANNE,  ACTION_MOVE,  LOC_B)
    s = event_push(s, ACTOR_SALLY, ACTION_ENTER, LOC_NONE)
    s = event_push(s, ACTOR_SALLY, ACTION_LOOK,  LOC_NONE)
    return s
}

// Variant scene: Sally never leaves, so she witnesses Anne's move.
// Agent must answer B here — confirms 4yo tracker isn't just "always A".
fn scene_sally_present() -> array {
    let mut s = []
    s = event_push(s, ACTOR_SALLY, ACTION_PUT,  LOC_A)
    s = event_push(s, ACTOR_ANNE,  ACTION_MOVE, LOC_B)
    s = event_push(s, ACTOR_SALLY, ACTION_LOOK, LOC_NONE)
    return s
}

// ─── ToM state tracker ───────────────────────────────────────
// Hexa lists are pass-by-value (feedback_hexa_lists_pbv.md), so each
// update returns a fresh 3-tuple. We pack state as [reality, sally_belief,
// sally_present_flag] in a small int array for predictable layout.

let STATE_REALITY  = 0
let STATE_BELIEF   = 1
let STATE_PRESENT  = 2

fn state_new() -> array {
    let mut st = []
    st = st.push(LOC_NONE)   // reality       — no marble placed yet
    st = st.push(LOC_NONE)   // sally_belief  — no belief formed yet
    st = st.push(1)          // sally_present — Sally starts in the room
    return st
}

// Apply a single event to the ToM state. Returns fresh state.
fn state_apply(state: array, actor: int, action: int, target: int) -> array {
    let reality = state[STATE_REALITY]
    let belief  = state[STATE_BELIEF]
    let present = state[STATE_PRESENT]

    let mut new_reality = reality
    let mut new_belief  = belief
    let mut new_present = present

    // put/move: world state changes.
    if action == ACTION_PUT {
        new_reality = target
        if present == 1 {
            new_belief = target
        }
    }
    if action == ACTION_MOVE {
        new_reality = target
        if present == 1 {
            new_belief = target
        }
    }
    // Sally's presence flag — only her leave/enter events count.
    if actor == ACTOR_SALLY {
        if action == ACTION_LEAVE {
            new_present = 0
        }
        if action == ACTION_ENTER {
            new_present = 1
        }
    }

    let mut out = []
    out = out.push(new_reality)
    out = out.push(new_belief)
    out = out.push(new_present)
    return out
}

// Run the entire scene through the tracker; returns final state.
fn run_scene(scene: array) -> array {
    let n = event_count(scene)
    let mut state = state_new()
    let mut i = 0
    while i < n {
        let ac = event_actor(scene, i)
        let an = event_action(scene, i)
        let tg = event_target(scene, i)
        state = state_apply(state, ac, an, tg)
        i = i + 1
    }
    return state
}

// ─── Agents ──────────────────────────────────────────────────
// "Where will Sally look?"
// Returns location index (0 = A, 1 = B), or LOC_NONE if undefined.

// 2-year-old — reality-based response. Corresponds to the pre-ToM
// stage where the child uses current world state as the answer.
fn agent_2yo_answer(state: array) -> int {
    return state[STATE_REALITY]
}

// 4-year-old — belief-based response. Corresponds to post-ToM stage
// where the child tracks OTHER's perspective separately from reality.
fn agent_4yo_answer(state: array) -> int {
    return state[STATE_BELIEF]
}

fn loc_name(loc: int) -> string {
    if loc == LOC_A { return "basket A" }
    if loc == LOC_B { return "box B" }
    return "(undefined)"
}

// ─── Self-tests ─────────────────────────────────────────────

fn check_T1() -> bool {
    // Canonical scene has exactly 5 events in correct order.
    let s = scene_sally_anne()
    let n = event_count(s)
    println("  [T1] scene_sally_anne event count = " + str(n))
    if n != 5 {
        println("  [T1] FAIL — expected 5 events")
        return false
    }
    // Step 1: Sally puts in A.
    if event_actor(s, 0)  != ACTOR_SALLY { return false }
    if event_action(s, 0) != ACTION_PUT  { return false }
    if event_target(s, 0) != LOC_A       { return false }
    // Step 2: Sally leaves.
    if event_actor(s, 1)  != ACTOR_SALLY  { return false }
    if event_action(s, 1) != ACTION_LEAVE { return false }
    // Step 3: Anne moves to B.
    if event_actor(s, 2)  != ACTOR_ANNE  { return false }
    if event_action(s, 2) != ACTION_MOVE { return false }
    if event_target(s, 2) != LOC_B       { return false }
    // Step 4: Sally enters.
    if event_actor(s, 3)  != ACTOR_SALLY  { return false }
    if event_action(s, 3) != ACTION_ENTER { return false }
    // Step 5: Sally looks.
    if event_actor(s, 4)  != ACTOR_SALLY { return false }
    if event_action(s, 4) != ACTION_LOOK { return false }
    println("  [T1] event sequence OK: put(A) → leave → move(B) → enter → look")
    return true
}

fn check_T2() -> bool {
    // 2-year-old level: reality-tracker answer.
    // After the scene, reality = B (Anne moved it there). A 2yo agent
    // uses reality as Sally's answer → says "box B". This is the pre-ToM
    // baseline — CORRECT as a reality tracker, INCORRECT as ToM.
    let scene = scene_sally_anne()
    let st = run_scene(scene)
    let reality = st[STATE_REALITY]
    let ans_2yo = agent_2yo_answer(st)
    println("  [T2] final reality = " + loc_name(reality))
    println("  [T2] 2yo agent answer: " + loc_name(ans_2yo) + " (reality-based)")
    if reality != LOC_B {
        println("  [T2] FAIL — reality should be box B after Anne's move")
        return false
    }
    if ans_2yo != LOC_B {
        println("  [T2] FAIL — 2yo agent should answer box B")
        return false
    }
    return true
}

fn check_T3() -> bool {
    // CORE done_criteria — 4-year-old level PASS.
    //
    // Scene 1: canonical Sally-Anne. Sally left before Anne moved it,
    //          so sally_belief remains A. 4yo agent answers A.
    // Scene 2: variant — Sally present throughout, so she witnesses
    //          Anne's move. sally_belief = B. 4yo agent answers B.
    // Both must pass for the ToM tracker to be non-trivial.

    let scene1 = scene_sally_anne()
    let st1 = run_scene(scene1)
    let belief1 = st1[STATE_BELIEF]
    let ans1 = agent_4yo_answer(st1)
    println("  [T3] canonical Sally-Anne:")
    println("       sally_belief = " + loc_name(belief1) + "  4yo answer = " + loc_name(ans1))

    let scene2 = scene_sally_present()
    let st2 = run_scene(scene2)
    let belief2 = st2[STATE_BELIEF]
    let ans2 = agent_4yo_answer(st2)
    println("  [T3] variant (Sally present):")
    println("       sally_belief = " + loc_name(belief2) + "  4yo answer = " + loc_name(ans2))

    if belief1 != LOC_A {
        println("  [T3] FAIL — canonical: sally_belief should remain A")
        return false
    }
    if ans1 != LOC_A {
        println("  [T3] FAIL — canonical: 4yo agent should answer A (false-belief)")
        return false
    }
    if belief2 != LOC_B {
        println("  [T3] FAIL — variant: sally_belief should update to B (Sally witnessed)")
        return false
    }
    if ans2 != LOC_B {
        println("  [T3] FAIL — variant: 4yo agent should answer B")
        return false
    }
    println("  [T3] PASS — both scenes answered correctly, ToM distinguishes belief from reality")
    return true
}

fn check_T4() -> bool {
    // Determinism: run the scene twice, compare both state vectors.
    let scene = scene_sally_anne()
    let s1 = run_scene(scene)
    let s2 = run_scene(scene)
    if len(s1) != len(s2) { return false }
    let mut i = 0
    while i < len(s1) {
        if s1[i] != s2[i] {
            println("  [T4] FAIL at index " + str(i))
            return false
        }
        i = i + 1
    }
    println("  [T4] byte-identical state across two runs: [reality=" + str(s1[0]) + ", belief=" + str(s1[1]) + ", present=" + str(s1[2]) + "]")
    return true
}

fn check_T5() -> bool {
    // Latency: both agents, both scenes < 2000 ms.
    let scene1 = scene_sally_anne()
    let scene2 = scene_sally_present()
    let _w1 = run_scene(scene1)
    let _w2 = run_scene(scene2)
    let t0 = clock()
    let st1 = run_scene(scene1)
    let st2 = run_scene(scene2)
    let _a1 = agent_2yo_answer(st1)
    let _b1 = agent_4yo_answer(st1)
    let _a2 = agent_2yo_answer(st2)
    let _b2 = agent_4yo_answer(st2)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T5] full Sally-Anne + variant latency = " + str(ms) + " ms")
    return ms < 2000.0
}

// ─── main ─────────────────────────────────────────────────────

fn main() {
    println("[sally_anne_test] ALM-P9-3 self-test")
    println("  canonical scene: Sally-put(A) → Sally-leave → Anne-move(B) → Sally-enter → Sally-look")
    println("  variant  scene:  Sally-put(A) → Anne-move(B) → Sally-look")

    let mut pass = 0
    let mut fail = 0

    let t1 = check_T1()
    if t1 { println("T1 PASS") pass = pass + 1 } else { println("T1 FAIL") fail = fail + 1 }

    let t2 = check_T2()
    if t2 { println("T2 PASS") pass = pass + 1 } else { println("T2 FAIL") fail = fail + 1 }

    let t3 = check_T3()
    if t3 { println("T3 PASS") pass = pass + 1 } else { println("T3 FAIL") fail = fail + 1 }

    let t4 = check_T4()
    if t4 { println("T4 PASS") pass = pass + 1 } else { println("T4 FAIL") fail = fail + 1 }

    let t5 = check_T5()
    if t5 { println("T5 PASS") pass = pass + 1 } else { println("T5 FAIL") fail = fail + 1 }

    println("[sally_anne_test] PASS=" + str(pass) + " / FAIL=" + str(fail))
    if fail == 0 {
        println("[sally_anne_test] ALL 5/5 PASS — 2yo level CORRECT, 4yo level PASS (ToM present)")
    } else {
        println("[sally_anne_test] SOME FAILED")
    }
}

main()
