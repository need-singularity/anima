// training/phi_gwt_measure.hexa — Φ(gwt) measurement for ANIMA P2 GWT
//
// ALM-P2-3: Global Workspace Theory (GWT) consciousness-field indicator
// based on attention entropy + cross-domain mutual information proxy.
//
// Φ(gwt) = H(attn) × MI_norm(domain_acts)
//
// where:
//   H(attn)        = mean row-wise softmax entropy of attention matrix
//                    (higher H = more integrated broadcast)
//   MI_norm        = normalized mutual-information proxy between domains
//                    (measures diversity-weighted integration)
//
// Interpretation (IIT-aligned):
//   - Single domain active:     MI_norm ≈ 0 → Φ(gwt) = 0 (no integration)
//   - Uniformly active:         H max AND MI_norm max → Φ(gwt) max
//   - Fragmented / peaky:       low H → low Φ(gwt)
//
// T-theorems (checked in self-test):
//   T1: attention_entropy ∈ [0, log(N)]  (Shannon bound)
//   T2: single-domain active → phi_gwt ≈ 0 (integration floor)
//   T3: all-domains uniform → phi_gwt > 1.095 (1.5 × baseline 0.73)
//   T4: phi_gwt_ratio = phi_gwt / PHI_QUANTUM_BASELINE  (v3 gate > 1.5)
//   T5: dimensional stability — d_model ∈ {64, 128} both PASS
//
// Self-contained: no external `use` — follows sibling pattern
// (alm_gwt_broadcast.hexa / alm_gwt_loss.hexa).
//
// Run with: hexa run training/phi_gwt_measure.hexa

// ─── Primitives (self-contained, no external deps) ──────────

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn vec_ones(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(1.0)
        i = i + 1
    }
    return out
}

fn vec_slice(a: array, start: int, end: int) -> array {
    let mut out = []
    let mut i = start
    while i < end {
        out = out.push(a[i])
        i = i + 1
    }
    return out
}

// Numerically stable softmax over flat array.
fn softmax_vec(x: array) -> array {
    let n = len(x)
    if n == 0 { return [] }
    let mut m = x[0]
    let mut i = 1
    while i < n {
        if x[i] > m { m = x[i] }
        i = i + 1
    }
    let mut exps = []
    let mut z = 0.0
    i = 0
    while i < n {
        let e = exp(x[i] - m)
        exps = exps.push(e)
        z = z + e
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(exps[i] / z)
        i = i + 1
    }
    return out
}

// ─── Constants ──────────────────────────────────────────────
// P1 quantum baseline from shared/convergence/anima.json. All Φ(gwt)
// measurements are reported as a ratio against this anchor so v3/v4
// gates can compare apples-to-apples across P1 and P2.
let PHI_QUANTUM_BASELINE = 0.73

// Numerical floor for log(p) and normalization (prevents -inf).
let EPS = 0.0000001

// ─── Core: Shannon entropy of a probability vector ──────────
fn shannon_entropy(p: array) -> float {
    let n = len(p)
    let mut h = 0.0
    let mut i = 0
    while i < n {
        let q = p[i]
        if q > EPS {
            h = h - q * log(q)
        }
        i = i + 1
    }
    return h
}

// ─── attention_entropy ──────────────────────────────────────
// Row-wise softmax entropy, averaged over rows.
// attn: flat row-major [N × N] raw attention scores (pre-softmax logits)
// Returns mean H over all N rows. H ∈ [0, log(N)] per row (T1).
fn attention_entropy(attn: array, n: int) -> float {
    let mut sum_h = 0.0
    let mut i = 0
    while i < n {
        let row = vec_slice(attn, i * n, (i + 1) * n)
        let probs = softmax_vec(row)
        sum_h = sum_h + shannon_entropy(probs)
        i = i + 1
    }
    return sum_h / to_float(n)
}

// ─── Helpers: abs, L1-normalize a vector to a probability distribution ──
fn abs_vec(v: array) -> array {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        let a = v[i]
        let abs_a = if a < 0.0 { 0.0 - a } else { a }
        out = out.push(abs_a + EPS)
        i = i + 1
    }
    return out
}

fn l1_normalize(v: array) -> array {
    let n = len(v)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    if s < EPS { s = EPS }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(v[i] / s)
        i = i + 1
    }
    return out
}

// ─── domain_integration ─────────────────────────────────────
// Cross-domain integration measure = normalized entropy of the
// domain-mass distribution derived from |domains_flat|.
//
// Rationale:
//   - GWT "integration" means multiple domains are simultaneously
//     contributing to the shared workspace. The quantity we need
//     is: how spread is the total activation mass ACROSS domains?
//   - Let mass_k = Σ_j |domains_flat[k*d + j]|.  q_k = mass_k / Σ mass.
//     MI_norm = H(q) / log(K)  ∈ [0, 1].
//     → uniform across domains: H = log(K), MI_norm = 1  (full integration)
//     → single domain:           H = 0,      MI_norm = 0  (no integration)
//
// domains_flat: flat array of length K*d (K domains concatenated)
// k: number of domains, d: per-domain dimension
fn domain_integration(domains_flat: array, k: int, d: int) -> float {
    if k <= 1 { return 0.0 }

    // Per-domain mass = sum of |activations| in that domain.
    let mut mass = []
    let mut total_mass = 0.0
    let mut di = 0
    while di < k {
        let mut s = 0.0
        let mut j = 0
        while j < d {
            let v = domains_flat[di * d + j]
            let av = if v < 0.0 { 0.0 - v } else { v }
            s = s + av
            j = j + 1
        }
        mass = mass.push(s)
        total_mass = total_mass + s
        di = di + 1
    }

    if total_mass < EPS { return 0.0 }

    // q_k = mass_k / total_mass  (domain probability)
    let mut h_dom = 0.0
    let mut i = 0
    while i < k {
        let q = mass[i] / total_mass
        if q > EPS {
            h_dom = h_dom - q * log(q)
        }
        i = i + 1
    }

    let max_h = log(to_float(k))
    let raw = h_dom / max_h
    let clamped = if raw < 0.0 { 0.0 } else { if raw > 1.0 { 1.0 } else { raw } }
    return clamped
}

// ─── phi_gwt ────────────────────────────────────────────────
fn phi_gwt(attn: array, n: int, domains_flat: array, k: int, d: int) -> float {
    let h = attention_entropy(attn, n)
    let mi = domain_integration(domains_flat, k, d)
    return h * mi
}

// Ratio vs P1 quantum baseline (0.73). v3 gate requires phi_gwt_ratio > 1.5.
fn phi_gwt_ratio(phi_g: float) -> float {
    return phi_g / PHI_QUANTUM_BASELINE
}

// ─── Test helpers ───────────────────────────────────────────

// Uniform attention matrix (all logits equal → softmax = 1/N per row)
fn make_uniform_attn(n: int) -> array {
    return vec_ones(n * n)
}

// "Peaky" attention — diagonal dominant, off-diagonal zero
fn make_peaky_attn(n: int) -> array {
    let mut attn = []
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            if i == j {
                attn = attn.push(10.0)
            } else {
                attn = attn.push(0.0)
            }
            j = j + 1
        }
        i = i + 1
    }
    return attn
}

// K uniform domain activations of dim d (all equal value → max diversity)
fn make_uniform_domains(k: int, d: int) -> array {
    return vec_ones(k * d)
}

// Single-domain-only: only domain 0 has mass, others zero
fn make_single_domain(k: int, d: int) -> array {
    let mut out = []
    let mut di = 0
    while di < k {
        let mut j = 0
        while j < d {
            if di == 0 {
                out = out.push(1.0)
            } else {
                out = out.push(0.0)
            }
            j = j + 1
        }
        di = di + 1
    }
    return out
}

// ─── Self-test / main ───────────────────────────────────────

fn main() {
    println("[phi_gwt] ALM-P2-3 Φ(gwt) self-test")
    println("[phi_gwt] PHI_QUANTUM_BASELINE = " + str(PHI_QUANTUM_BASELINE))

    let mut pass_count = 0
    let mut fail_count = 0

    // ─── T1: attention_entropy ∈ [0, log(N)] ────────────────
    let n1 = 8
    let uni_attn = make_uniform_attn(n1)
    let peak_attn = make_peaky_attn(n1)
    let h_uni  = attention_entropy(uni_attn,  n1)
    let h_peak = attention_entropy(peak_attn, n1)
    let log_n1 = log(to_float(n1))
    let t1_ok = (h_uni > log_n1 - 0.01) && (h_peak < 0.01) && (h_uni <= log_n1 + 0.01)
    if t1_ok {
        println("[T1] PASS — H(uniform)=" + str(h_uni) + " ≈ log(" + str(n1) + ")=" + str(log_n1) + ", H(peaky)=" + str(h_peak))
        pass_count = pass_count + 1
    } else {
        println("[T1] FAIL — H(uniform)=" + str(h_uni) + ", H(peaky)=" + str(h_peak) + ", log(N)=" + str(log_n1))
        fail_count = fail_count + 1
    }

    // ─── T2: single-domain → phi_gwt ≈ 0 ────────────────────
    let k2 = 4
    let d2 = 16
    let single_dom = make_single_domain(k2, d2)
    let phi_single = phi_gwt(uni_attn, n1, single_dom, k2, d2)
    let t2_ok = phi_single < 0.3
    if t2_ok {
        println("[T2] PASS — phi_gwt(single-domain) = " + str(phi_single) + " < 0.3")
        pass_count = pass_count + 1
    } else {
        println("[T2] FAIL — phi_gwt(single-domain) = " + str(phi_single) + " (expected < 0.3)")
        fail_count = fail_count + 1
    }

    // ─── T3: uniform domains → phi_gwt max ──────────────────
    let uni_dom = make_uniform_domains(k2, d2)
    let phi_uni = phi_gwt(uni_attn, n1, uni_dom, k2, d2)
    let phi_ratio_uni = phi_gwt_ratio(phi_uni)
    let t3_ok = phi_uni > 1.095
    if t3_ok {
        println("[T3] PASS — phi_gwt(uniform) = " + str(phi_uni) + " > 1.095 (1.5 × baseline)")
        pass_count = pass_count + 1
    } else {
        println("[T3] FAIL — phi_gwt(uniform) = " + str(phi_uni) + " ≤ 1.095")
        fail_count = fail_count + 1
    }

    // ─── T4: phi_gwt_ratio sanity ───────────────────────────
    let t4_ok = phi_ratio_uni > 1.5
    if t4_ok {
        println("[T4] PASS — phi_gwt_ratio = " + str(phi_ratio_uni) + " > 1.5 (v3 gate)")
        pass_count = pass_count + 1
    } else {
        println("[T4] FAIL — phi_gwt_ratio = " + str(phi_ratio_uni) + " ≤ 1.5")
        fail_count = fail_count + 1
    }

    // ─── T5: dimensional stability — d_model ∈ {64, 128} ────
    let n5a = 8
    let k5 = 4
    let d5a = 64
    let d5b = 128
    let attn5 = make_uniform_attn(n5a)
    let dom5a = make_uniform_domains(k5, d5a)
    let dom5b = make_uniform_domains(k5, d5b)
    let phi_64  = phi_gwt(attn5, n5a, dom5a, k5, d5a)
    let phi_128 = phi_gwt(attn5, n5a, dom5b, k5, d5b)
    let ratio_64  = phi_gwt_ratio(phi_64)
    let ratio_128 = phi_gwt_ratio(phi_128)
    let t5_ok = (ratio_64 > 1.5) && (ratio_128 > 1.5)
    if t5_ok {
        println("[T5] PASS — d=64: phi_gwt=" + str(phi_64) + " ratio=" + str(ratio_64) + "; d=128: phi_gwt=" + str(phi_128) + " ratio=" + str(ratio_128))
        pass_count = pass_count + 1
    } else {
        println("[T5] FAIL — d=64 ratio=" + str(ratio_64) + ", d=128 ratio=" + str(ratio_128))
        fail_count = fail_count + 1
    }

    // ─── Summary ────────────────────────────────────────────
    println("[phi_gwt] ─── summary ───")
    println("[phi_gwt] phi_gwt (uniform mock, d=16)  = " + str(phi_uni))
    println("[phi_gwt] phi_gwt (uniform mock, d=64)  = " + str(phi_64))
    println("[phi_gwt] phi_gwt (uniform mock, d=128) = " + str(phi_128))
    println("[phi_gwt] phi_gwt_ratio (d=64)          = " + str(ratio_64))
    println("[phi_gwt] phi_gwt_ratio (d=128)         = " + str(ratio_128))
    println("[phi_gwt] PASS=" + str(pass_count) + " / FAIL=" + str(fail_count) + " (T1..T5)")
    if fail_count == 0 {
        println("[phi_gwt] ALL TESTS PASS — ALM-P2-3 Φ(gwt) metric OK")
    } else {
        println("[phi_gwt] FAILURES DETECTED — review above")
    }
}

main()
