    ckpt_dir: string,
    ckpt_every: int,
    eval_every: int,
    log_every: int,
    corpus_path: string,
    val_split: float
}

fn train_config_default() -> TrainConfig {
    TrainConfig {
        vocab_size: 256,
        d_model: 384,
        n_head: 4,
        n_layer: 6,
        n_kv_head: 2,
        block_size: 256,
        consciousness_dim: 128,
        dropout: 0.1,
        n_cells: 64,
        cell_dim: 64,
        hidden_dim: 128,
        n_factions: 12,
        batch_size: 8,
        grad_accum: 4,
        lr: 0.0003,
        min_lr: 0.00001,
        warmup_steps: 500,
        total_steps: 100000,
        weight_decay: 0.1,
        max_grad_norm: 1.0,
        p1_end_frac: 0.25,
        p2_end_frac: 0.50,
        phi_weight: 0.01,
        phi_target: 0.5,
        ckpt_dir: "checkpoints/decoder_cpu",
        ckpt_every: 1000,
        eval_every: 200,
        log_every: 50,
        corpus_path: "data/corpus_tier_m_v2.txt",
        val_split: 0.001
    }
}

