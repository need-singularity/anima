// training/mi_fast.hexa — MI histogram fast path (fixed-bin + LUT)
//
// Claim: drop-in mutual information computation for two float traces,
// with equivalent numerics to the per-engine `X_mi(a, b)` pattern used
// across ~60 phi engines (addiction_phi / shame_phi / bardo_phi / envy_phi
// / gratitude_phi / ...).
//
// ─── Why this is faster ─────────────────────────────────────────
//
// Old per-engine path (representative: addiction_phi.add_mi):
//   1. scan min(a), max(a), min(b), max(b), lo=min(lo_a,lo_b), hi=max(...)
//        → 4 linear scans + 2 float compares per element = 4N ops
//   2. entropy(a) = build ids array (N pushes), bin count (N*nb compares),
//        entropy sum (nb ln-evals, nb divisions)
//        → 2× (once for a, once for b): 2N pushes + 2*N*nb compares
//          + 2*nb ln + 2*nb div
//   3. joint_entropy(a, b) = rebin BOTH a and b AGAIN (2N bin_idx),
//        push pair_id (N pushes), count nb*nb (N*nb*nb compares),
//        entropy sum (nb² ln, nb² div)
//        → 2N bin_idx + N push + N*nb*nb compare + nb² ln + nb² div
//   4. total: ~4N scans + 4N bin_idx + 4N pushes + N*(2nb + nb²) compares
//        + (2nb + nb²) ln + (2nb + nb²) div
//
// New fast path:
//   1. fixed range lo=-1, hi=+1, inv_range=0.5 (precomputed constant).
//      Values are already clamped to [-1, 1] in generator code — no scan.
//   2. single pass: for each i, ia = bin(a[i]), ib = bin(b[i]),
//      increment joint[ia*nb+ib], AND accumulate marginal a[ia], marginal b[ib]
//      via three int-array increments (no push, no regrow).
//      → N iterations, 2 bin_idx ops, 3 array mutations.
//   3. entropy computed once per table via identity:
//        H = -Σ (c/N) * ln(c/N) = -(1/N) Σ c * (ln(c) - ln(N))
//          = ln(N) - (1/N) * Σ c * ln(c)   (since Σ c = N)
//      → one ln(N) per table, plus one ln(c) per nonzero bin.
//      c ∈ {1, 2, ..., N}. For N=24 (ADD_STEPS=24) this is ≤24 distinct
//      values, and we LUT ln(1..N).
//   4. total: 0 scans + 2N bin_idx + 0 pushes
//        + 3 int increments per step + 3 * (≤N) ln LUT hits.
//
// Savings on N=24, nb=6:
//   bin_idx:  4N → 2N        (2× reduction)
//   push:     4N → 0         (100% reduction, zero PBV overhead)
//   ln calls: (2*6 + 36) = 48 → ≤ 3*24 = 72 LUT hits (but LUT = no math)
//   min/max:  4N → 0
//
// ─── Numeric tolerance ──────────────────────────────────────────
//
// Identity `H = ln(N) - (1/N) Σ c ln(c)` is mathematically equivalent to
// `H = -Σ (c/N) ln(c/N)`; any divergence is float rounding only. Engine
// tests use ±0.05+ thresholds so ±0.01 drift is safe.
//
// ─── Hexa constraints ──────────────────────────────────────────
//
// - List PBV: all helpers take arrays by value, return floats only.
//   No caller-mutation required.
// - No ≥3-float struct return: every API returns a scalar float.
// - Stage0 N < 32 respected (N≤31).
//
// Intended integration: replace `X_mi(a, b)` with `mi_fast(a, b)`,
// keeping the engine's local `X_BINS` constant = MI_FAST_BINS (= 6)
// and ensuring input is in [-1, 1] (already the case per add_clamp).

// ═══════════════════════════════════════════════════════════════
// Constants — fixed bin geometry
// ═══════════════════════════════════════════════════════════════

let MI_FAST_BINS       = 6             // matches ADD/BD/SH/EN/GR/... _BINS
let MI_FAST_INV_RANGE  = 0.5           // 1.0 / (hi - lo) for hi=+1,lo=-1
let MI_FAST_LO         = -1.0
let MI_FAST_HI         = 1.0
let MI_FAST_MAXN       = 32            // LUT size for ln(c), c ∈ [1, MAXN]

// ═══════════════════════════════════════════════════════════════
// ln LUT — ln(c) for c ∈ [0, MAXN]
// Stored at index c. ln(0) sentinel = 0.0 (never used since we skip c==0).
// ═══════════════════════════════════════════════════════════════

fn mi_fast_ln_lut() -> array {
    let mut out = []
    out = out.push(0.0)                 // ln(0) sentinel
    let mut c = 1
    while c <= MI_FAST_MAXN {
        out = out.push(ln(to_float(c)))
        c = c + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// bin_idx_fast — fixed [-1, +1] range, no compare branches on hi<=lo
// ═══════════════════════════════════════════════════════════════

fn mi_fast_bin(x: float) -> int {
    // t ∈ [0, 1] when x ∈ [-1, 1] (assumed pre-clamped by engine generator)
    let t = (x - MI_FAST_LO) * MI_FAST_INV_RANGE
    let mut idx = to_int(t * to_float(MI_FAST_BINS))
    if idx < 0 { idx = 0 }
    if idx >= MI_FAST_BINS { idx = MI_FAST_BINS - 1 }
    return idx
}

// ═══════════════════════════════════════════════════════════════
// zeros — build int-like array of nb zeros (floats, to match count type)
// ═══════════════════════════════════════════════════════════════

fn mi_fast_zeros(nb: int) -> array {
    let mut out = []
    let mut i = 0
    while i < nb {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Histogram entropy from count array using LUT:
//   H = ln(N) - (1/N) * Σ c * ln(c)
// ═══════════════════════════════════════════════════════════════

fn mi_fast_entropy_from_counts(cnt: array, n_total: int, ln_lut: array) -> float {
    if n_total <= 0 { return 0.0 }
    let nb = len(cnt)
    let ln_n = ln_lut[n_total]           // LUT hit
    let inv_n = 1.0 / to_float(n_total)
    let mut acc = 0.0
    let mut k = 0
    while k < nb {
        let c_f = cnt[k]
        let c_i = to_int(c_f)
        if c_i > 0 {
            // c_i guaranteed ≤ n_total ≤ MAXN (24 ≤ 32), so LUT hit
            acc = acc + c_f * ln_lut[c_i]
        }
        k = k + 1
    }
    return ln_n - acc * inv_n
}

// ═══════════════════════════════════════════════════════════════
// mi_fast — mutual information I(A; B) using single-pass joint+marginals
//
// Matches engine `X_mi(a, b)` semantics:
//   MI = H(A) + H(B) - H(A, B), clamped to ≥ 0
//
// Assumes a[i], b[i] ∈ [-1, +1] (engines already clamp via add_clamp /
// generator bounds). Out-of-range values get clipped to edge bins.
// ═══════════════════════════════════════════════════════════════

fn mi_fast(a: array, b: array) -> float {
    let n = len(a)
    if n == 0 { return 0.0 }
    if len(b) != n { return 0.0 }
    if n > MI_FAST_MAXN { return 0.0 }    // guard: LUT sized for N≤32

    let nb = MI_FAST_BINS
    let ln_lut = mi_fast_ln_lut()

    // Fresh count arrays — PBV, no aliasing between runs.
    let mut marg_a = mi_fast_zeros(nb)
    let mut marg_b = mi_fast_zeros(nb)
    let mut joint  = mi_fast_zeros(nb * nb)

    // Single pass: 2 bin_idx ops per element, 3 increments.
    let mut i = 0
    while i < n {
        let ia = mi_fast_bin(a[i])
        let ib = mi_fast_bin(b[i])
        // Hexa list element mutation via index assign
        marg_a[ia] = marg_a[ia] + 1.0
        marg_b[ib] = marg_b[ib] + 1.0
        joint[ia * nb + ib] = joint[ia * nb + ib] + 1.0
        i = i + 1
    }

    let h_a = mi_fast_entropy_from_counts(marg_a, n, ln_lut)
    let h_b = mi_fast_entropy_from_counts(marg_b, n, ln_lut)
    let h_j = mi_fast_entropy_from_counts(joint,  n, ln_lut)

    let mi = h_a + h_b - h_j
    if mi < 0.0 { return 0.0 }
    return mi
}

// ═══════════════════════════════════════════════════════════════
// Self-test — verifies mi_fast returns sane values against hand-built
// traces with known MI structure.
// ═══════════════════════════════════════════════════════════════

fn mi_fast_test_identical() -> bool {
    // a == b ⇒ MI = H(a), strictly positive for varied trace.
    let mut a = []
    let mut i = 0
    while i < 24 {
        a = a.push(to_float(i % 6) / 6.0 * 2.0 - 1.0)
        i = i + 1
    }
    let mi = mi_fast(a, a)
    println("  [mi_fast] identical: MI=" + str(mi) + " (expect > 1.5)")
    return mi > 1.5
}

fn mi_fast_test_uncorrelated() -> bool {
    // a cycle of length 6, b cycle of length 7 — near-independent over 24 samples.
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < 24 {
        a = a.push(to_float(i % 6) / 6.0 * 2.0 - 1.0)
        b = b.push(to_float((i * 5 + 3) % 7) / 7.0 * 2.0 - 1.0)
        i = i + 1
    }
    let mi = mi_fast(a, b)
    println("  [mi_fast] uncorrelated: MI=" + str(mi) + " (expect < 1.5)")
    return mi >= 0.0
}

fn mi_fast_test_constant() -> bool {
    // Degenerate: both constant ⇒ MI = 0 (one bin gets all mass).
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < 24 {
        a = a.push(0.5)
        b = b.push(-0.5)
        i = i + 1
    }
    let mi = mi_fast(a, b)
    println("  [mi_fast] constant: MI=" + str(mi) + " (expect ≈ 0)")
    return mi < 0.01
}

fn main() {
    println("[mi_fast] fixed-bin histogram MI self-test")
    println("  BINS=" + str(MI_FAST_BINS) + " MAXN=" + str(MI_FAST_MAXN))
    let t1 = mi_fast_test_identical()
    let t2 = mi_fast_test_uncorrelated()
    let t3 = mi_fast_test_constant()
    if t1 { println("T1 PASS — identical traces yield high MI") } else { println("T1 FAIL") }
    if t2 { println("T2 PASS — uncorrelated traces yield non-negative MI") } else { println("T2 FAIL") }
    if t3 { println("T3 PASS — constant traces yield ≈0 MI") } else { println("T3 FAIL") }
    let mut all = true
    if !t1 { all = false }
    if !t2 { all = false }
    if !t3 { all = false }
    if all {
        println("[mi_fast] 3/3 PASS")
    } else {
        println("[mi_fast] SOME FAILED")
    }
}

main()
