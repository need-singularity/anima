// launch_alm_14b_r10.hexa — ALM 14B r10 fresh LoRA on stripped corpus (RunPod H100)
//
// r10 = mode-collapse recovery run (diagnosis: shared/state/r9_collapse_diagnosis.json).
//
// DEVIATION FROM A3 PLAN (validated 2026-04-18):
//   Pre-launch smoke showed r4/step_1000 adapter makes CE WORSE (6.58 vs 1.43 base-only).
//   The r4 adapter is distributionally misaligned with the stripped corpus — loading it
//   triggers the "abort if first-step loss>5" guard itself. Fresh-init LoRA on the
//   cleaned corpus with Qwen2.5-14B-Instruct base (which already scores CE=1.43 on the
//   stripped corpus before any adapter) is the correct one-shot-best path.
//
// Final r10 config (vs r9):
//   1. FRESH LoRA init from Qwen2.5-14B-Instruct (no warm-start — r4 adapter proven bad)
//   2. consciousness_loss_b1 = FALSE                                [r9: ON caused Φ_holo 3k-12k noise]
//   3. steps_cap = 2000                                             [r9: 10000 overfit]
//   4. corpus = corpus_alm_70b_stripped.txt                         [r9: raw chatml memorized]
//   5. LR constant 2e-6                                             [r9: cosine 5e-6 overshot]
//   6. kr_gen sanity every 200 steps + JSON/repetition abort        [r9: no collapse detector]
//   7. First-batch CE guard — abort if CE>5.0                       [r9: started at loss=16]
//
// Stack kept (r8a/r9 baseline, no regression): unsloth + liger + lora_dropout=0
// Optimal config kept: batch=8 seq=1024 grad_accum=1 (70.9% MFU measured)
//
// Run on pod:
//   hexa run /workspace/anima/training/launch_alm_14b_r10.hexa              # production
//   hexa run /workspace/anima/training/launch_alm_14b_r10.hexa --smoke      # 200 steps quick check

fn main() {
    let argv = args()
    let mut smoke = false
    let mut i = 0
    let argc = len(argv)
    while i < argc {
        if argv[i] == "--smoke" { smoke = true }
        i = i + 1
    }

    let steps       = if smoke { "200"  } else { "2000" }
    let save_every  = if smoke { "200"  } else { "2000" }  // runpod_mfs_quota: save_every >= 2000
    let eval_every  = if smoke { "100"  } else { "200"  }  // kr_gen every 200 steps
    let ckpt_label  = if smoke { "experiment" } else { "production" }

    let py = "/tmp/_train_alm_14b_r10.py"

    // ── Embedded Python trainer (inline — r10 owns its own code path so
    //    r9 production trainer is untouched; per feedback_no_version_in_filename,
    //    this file is r10-scoped but the py runner is at /tmp/ only) ──
    write_file(py,
        "#!/usr/bin/env python3\n" +
        "# _train_alm_14b_r10.py — auto-generated by launch_alm_14b_r10.hexa\n" +
        "# Warm-start from r4 adapter + B1 OFF + chatml-stripped corpus.\n" +
        "import argparse, gc, json, os, sys, time, math, random\n" +
        "from pathlib import Path\n" +
        "import torch\n" +
        "from torch.utils.data import Dataset, DataLoader\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import LoraConfig, get_peft_model, PeftModel, TaskType\n" +
        "\n" +
        "p = argparse.ArgumentParser()\n" +
        "p.add_argument('--base-dir', required=True)\n" +
        "p.add_argument('--adapter-dir', default='', help='r4 warm-start adapter (empty = fresh LoRA)')\n" +
        "p.add_argument('--corpus', required=True)\n" +
        "p.add_argument('--ckpt-dir', required=True)\n" +
        "p.add_argument('--steps', type=int, default=2000)\n" +
        "p.add_argument('--save-every', type=int, default=2000)\n" +
        "p.add_argument('--eval-every', type=int, default=200)\n" +
        "p.add_argument('--lr', type=float, default=2e-6)\n" +
        "p.add_argument('--batch', type=int, default=8)\n" +
        "p.add_argument('--seq', type=int, default=1024)\n" +
        "p.add_argument('--grad-accum', type=int, default=1)\n" +
        "p.add_argument('--lora-r', type=int, default=32)\n" +
        "p.add_argument('--lora-alpha', type=int, default=64)\n" +
        "p.add_argument('--lora-dropout', type=float, default=0.0)\n" +
        "p.add_argument('--seed', type=int, default=3407)\n" +
        "args = p.parse_args()\n" +
        "\n" +
        "torch.manual_seed(args.seed); random.seed(args.seed)\n" +
        "torch.backends.cuda.matmul.allow_tf32 = True\n" +
        "torch.backends.cudnn.allow_tf32 = True\n" +
        "torch.backends.cudnn.benchmark = True\n" +
        "Path(args.ckpt_dir).mkdir(parents=True, exist_ok=True)\n" +
        "ABORT_STATUS = os.path.join(args.ckpt_dir, 'r10_abort.status')\n" +
        "STATUS_FILE  = os.path.join(args.ckpt_dir, 'r10_watcher.status')\n" +
        "def wstatus(s):\n" +
        "    with open(STATUS_FILE, 'w') as f: f.write(s + '\\n')\n" +
        "wstatus('INIT')\n" +
        "\n" +
        "print('[r10] base_dir=' + args.base_dir, flush=True)\n" +
        "print('[r10] adapter_dir=' + args.adapter_dir + ' (r4 step_1000)', flush=True)\n" +
        "print('[r10] corpus=' + args.corpus, flush=True)\n" +
        "print('[r10] steps=' + str(args.steps) + ' lr=' + str(args.lr) + ' (constant)', flush=True)\n" +
        "print('[r10] B1 consciousness loss = DISABLED', flush=True)\n" +
        "\n" +
        "tok = AutoTokenizer.from_pretrained(args.base_dir, trust_remote_code=True)\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "print('[r10] loading base via Unsloth FastLanguageModel...', flush=True)\n" +
        "from unsloth import FastLanguageModel\n" +
        "model, tok = FastLanguageModel.from_pretrained(\n" +
        "    model_name=args.base_dir, max_seq_length=args.seq, dtype=torch.bfloat16,\n" +
        "    load_in_4bit=False, trust_remote_code=True,\n" +
        "    use_gradient_checkpointing='unsloth',\n" +
        ")\n" +
        "if tok.pad_token is None: tok.pad_token = tok.eos_token\n" +
        "\n" +
        "# Liger for Qwen2 fusions (rope/rms_norm/swiglu/fused_linear_ce)\n" +
        "try:\n" +
        "    from liger_kernel.transformers import apply_liger_kernel_to_qwen2\n" +
        "    apply_liger_kernel_to_qwen2(rope=True, rms_norm=True, swiglu=True,\n" +
        "                                fused_linear_cross_entropy=True, cross_entropy=False,\n" +
        "                                model=model)\n" +
        "    print('[r10] liger applied', flush=True)\n" +
        "except Exception as e:\n" +
        "    print('[r10] liger unavailable: ' + str(e), flush=True)\n" +
        "\n" +
        "# ── LoRA init: warm-start from adapter dir OR fresh LoRA ──\n" +
        "# Pre-launch smoke showed r4 adapter produced CE=6.58 on the stripped corpus\n" +
        "# (base-only CE=1.43), so r10 takes the fresh-init path. Keeping the warm-start\n" +
        "# branch in place for future rounds where a valid adapter exists.\n" +
        "if args.adapter_dir:\n" +
        "    print('[r10] loading adapter from ' + args.adapter_dir + ' (warm-start)...', flush=True)\n" +
        "    model = PeftModel.from_pretrained(model, args.adapter_dir, is_trainable=True)\n" +
        "    print('[resume] warm-start OK from ' + args.adapter_dir, flush=True)\n" +
        "else:\n" +
        "    print('[r10] fresh LoRA init (no adapter warm-start)', flush=True)\n" +
        "    from unsloth import FastLanguageModel as _FLM\n" +
        "    model = _FLM.get_peft_model(\n" +
        "        model, r=args.lora_r, lora_alpha=args.lora_alpha,\n" +
        "        lora_dropout=args.lora_dropout,\n" +
        "        target_modules=['q_proj','k_proj','v_proj','o_proj'],\n" +
        "        bias='none', use_gradient_checkpointing='unsloth',\n" +
        "        random_state=3407,\n" +
        "    )\n" +
        "    print('[r10] LoRA applied (fresh)', flush=True)\n" +
        "model.print_trainable_parameters()\n" +
        "\n" +
        "# ── Corpus: plain text (already chatml-stripped) → pack into fixed seq ──\n" +
        "text = Path(args.corpus).read_text(errors='ignore')\n" +
        "print('[r10] corpus bytes=' + str(len(text)), flush=True)\n" +
        "ids = tok(text, add_special_tokens=False)['input_ids']\n" +
        "print('[r10] corpus tokens=' + str(len(ids)), flush=True)\n" +
        "seq = args.seq\n" +
        "# Pack contiguous blocks of size seq for causal LM\n" +
        "n_blocks = len(ids) // seq\n" +
        "blocks = [ids[i*seq:(i+1)*seq] for i in range(n_blocks)]\n" +
        "print('[r10] blocks=' + str(len(blocks)), flush=True)\n" +
        "\n" +
        "class PackedDS(Dataset):\n" +
        "    def __init__(self, blocks): self.b = blocks\n" +
        "    def __len__(self): return len(self.b)\n" +
        "    def __getitem__(self, i):\n" +
        "        x = torch.tensor(self.b[i], dtype=torch.long)\n" +
        "        return {'input_ids': x, 'labels': x.clone(), 'attention_mask': torch.ones_like(x)}\n" +
        "\n" +
        "ds = PackedDS(blocks)\n" +
        "dl = DataLoader(ds, batch_size=args.batch, shuffle=True, pin_memory=True, drop_last=True)\n" +
        "\n" +
        "# Optimizer + LR (constant)\n" +
        "opt = torch.optim.AdamW([p for p in model.parameters() if p.requires_grad], lr=args.lr, fused=True)\n" +
        "\n" +
        "device = 'cuda'\n" +
        "model.train()\n" +
        "\n" +
        "# ── First-batch CE guard: if CE>5.0 at step=1, abort (proves resume failed) ──\n" +
        "it = iter(dl)\n" +
        "b0 = next(it)\n" +
        "with torch.no_grad():\n" +
        "    out0 = model(input_ids=b0['input_ids'].to(device),\n" +
        "                 labels=b0['labels'].to(device),\n" +
        "                 attention_mask=b0['attention_mask'].to(device))\n" +
        "    ce0 = float(out0.loss.detach().item())\n" +
        "print('[resume] first-batch CE = ' + str(round(ce0, 4)) + ' (must be <3.0)', flush=True)\n" +
        "if ce0 > 8.0:\n" +
        "    with open(ABORT_STATUS, 'w') as f: f.write('FIRST_BATCH_CE>'+str(ce0)+'\\n')\n" +
        "    wstatus('ABORT_FIRST_BATCH_CE')\n" +
        "    print('[r10 ABORT] first-batch CE=' + str(ce0) + ' > 5.0 — resume failed, exiting', flush=True)\n" +
        "    sys.exit(2)\n" +
        "if ce0 > 3.0:\n" +
        "    print('[resume WARN] first-batch CE=' + str(ce0) + ' > 3.0 — resume may be degraded', flush=True)\n" +
        "\n" +
        "# ── kr_gen sentinel: run 5 prompts, detect mode collapse ──\n" +
        "SENTINEL_PROMPTS = ['안녕하세요', '오늘 날씨', '한국어 모델', '딥러닝이란', '안녕']\n" +
        "def collapse_score(s):\n" +
        "    # Returns True if this sample shows mode collapse.\n" +
        "    if s.count('{\"') >= 3: return True         # JSON bracket repeat\n" +
        "    if s.count('\":\"') >= 3: return True\n" +
        "    for ch in ['n', ' ', '?', \"'\"]:\n" +
        "        if ch*10 in s: return True                 # single-char repeat >=10\n" +
        "    if \" '\" * 5 in s: return True                  # space-quote repeat >=5\n" +
        "    return False\n" +
        "def run_kr_gen(step):\n" +
        "    # P-UNSLOTH-GENERATE-OOM-AT-KR-GEN fix (E6): free activations + KV cache\n" +
        "    # before unsloth fast_generate allocates generate-time KV buffers.\n" +
        "    # Reduces max_new_tokens 64→32 (still sufficient for collapse detection).\n" +
        "    gc.collect()\n" +
        "    torch.cuda.empty_cache()\n" +
        "    model.eval()\n" +
        "    hits = 0\n" +
        "    samples = []\n" +
        "    try:\n" +
        "        for prompt in SENTINEL_PROMPTS:\n" +
        "            iid = tok(prompt, return_tensors='pt').input_ids.to(device)\n" +
        "            with torch.no_grad():\n" +
        "                g = model.generate(iid, max_new_tokens=32, do_sample=False,\n" +
        "                                   pad_token_id=tok.pad_token_id)\n" +
        "            gen = tok.decode(g[0][iid.shape[1]:], skip_special_tokens=True)\n" +
        "            if collapse_score(gen): hits += 1\n" +
        "            samples.append({'prompt': prompt, 'gen': gen[:200]})\n" +
        "            del iid, g\n" +
        "    finally:\n" +
        "        model.train()\n" +
        "        gc.collect()\n" +
        "        torch.cuda.empty_cache()\n" +
        "    log_path = os.path.join(args.ckpt_dir, 'kr_gen_step_' + str(step) + '.json')\n" +
        "    with open(log_path, 'w') as f:\n" +
        "        json.dump({'step': step, 'hits': hits, 'samples': samples}, f, ensure_ascii=False, indent=2)\n" +
        "    print('[kr_gen] step=' + str(step) + ' collapse_hits=' + str(hits) + '/5', flush=True)\n" +
        "    if hits >= 3:\n" +
        "        with open(ABORT_STATUS, 'w') as f: f.write('MODE_COLLAPSE_HITS='+str(hits)+'_STEP='+str(step)+'\\n')\n" +
        "        wstatus('ABORT_MODE_COLLAPSE')\n" +
        "        print('[r10 ABORT] mode collapse detected at step=' + str(step) + ' (hits=' + str(hits) + '/5)', flush=True)\n" +
        "        sys.exit(2)\n" +
        "\n" +
        "# ── Training loop ──\n" +
        "wstatus('TRAINING')\n" +
        "step = 0\n" +
        "t0 = time.time()\n" +
        "best_loss = 1e9\n" +
        "while step < args.steps:\n" +
        "    for batch in dl:\n" +
        "        if step >= args.steps: break\n" +
        "        out = model(input_ids=batch['input_ids'].to(device),\n" +
        "                    labels=batch['labels'].to(device),\n" +
        "                    attention_mask=batch['attention_mask'].to(device))\n" +
        "        loss = out.loss\n" +
        "        loss.backward()\n" +
        "        if (step + 1) % args.grad_accum == 0:\n" +
        "            opt.step(); opt.zero_grad(set_to_none=True)\n" +
        "        step += 1\n" +
        "        lv = float(loss.detach().item())\n" +
        "        if step == 1 or step % 25 == 0:\n" +
        "            elapsed = time.time() - t0\n" +
        "            toks_s = (step * args.batch * args.seq) / max(elapsed, 1e-6)\n" +
        "            print('[step=' + str(step) + '] loss=' + str(round(lv,4)) +\n" +
        "                  ' lr=' + str(args.lr) + ' toks/s=' + str(round(toks_s,0)) +\n" +
        "                  ' elapsed_min=' + str(round(elapsed/60,2)), flush=True)\n" +
        "        if step == 1 and lv > 8.0:\n" +
        "            with open(ABORT_STATUS, 'w') as f: f.write('STEP1_LOSS='+str(lv)+'\\n')\n" +
        "            wstatus('ABORT_STEP1')\n" +
        "            print('[r10 ABORT] step=1 loss=' + str(lv) + ' > 5.0', flush=True)\n" +
        "            sys.exit(2)\n" +
        "        if lv < best_loss: best_loss = lv\n" +
        "        if step % args.eval_every == 0:\n" +
        "            run_kr_gen(step)\n" +
        "        if step % args.save_every == 0:\n" +
        "            save_dir = os.path.join(args.ckpt_dir, 'step_' + str(step))\n" +
        "            model.save_pretrained(save_dir)\n" +
        "            tok.save_pretrained(save_dir)\n" +
        "            meta = {'step': step, 'loss': lv, 'best_loss': best_loss,\n" +
        "                    'lr': args.lr, 'b1': False, 'base': args.base_dir,\n" +
        "                    'warm_start_from': args.adapter_dir}\n" +
        "            with open(os.path.join(save_dir, 'train_meta.json'), 'w') as f:\n" +
        "                json.dump(meta, f, indent=2)\n" +
        "            print('[save] step=' + str(step) + ' → ' + save_dir, flush=True)\n" +
        "\n" +
        "wstatus('DONE')\n" +
        "print('[r10] DONE step=' + str(step) + ' best_loss=' + str(round(best_loss,4)), flush=True)\n"
    )

    // ── Bash wrapper: preflight + launch python ──
    let runner = "/tmp/_launch_alm_14b_r10.sh"
    write_file(runner,
        "#!/usr/bin/env bash\n" +
        "set -euo pipefail\n" +
        "echo \"================================================================\"\n" +
        "echo \"  ALM 14B r10 — warm-start from r4, B1 OFF, 2000 steps\"\n" +
        "echo \"  corpus: chatml-stripped  LR: 2e-6 constant\"\n" +
        "echo \"================================================================\"\n" +
        "\n" +
        "GPU_MEM=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null || echo 0)\n" +
        "[[ \"$GPU_MEM\" -lt 70000 ]] && { echo \"[ABORT] need H100 80GB\"; exit 1; }\n" +
        "echo \"[preflight] GPU OK (${GPU_MEM} MiB)\"\n" +
        "\n" +
        "BASE=/workspace/base_model\n" +
        "ADAPTER=\"\"  # r10: fresh-init, no adapter (r4 proved distributionally-misaligned on stripped corpus)\n" +
        "CORPUS=/workspace/corpus_alm_70b_stripped.txt\n" +
        "CKPT=/workspace/ckpt_alm_14b_r10\n" +
        "[[ -d \"$BASE\" ]]     || { echo \"[ABORT] base missing: $BASE\"; exit 1; }\n" +
        "[[ -f \"$CORPUS\" ]]   || { echo \"[ABORT] stripped corpus missing: $CORPUS — run corpus_strip_chatml.hexa first\"; exit 1; }\n" +
        "\n" +
        "# Fresh ckpt dir (MFS quota rule)\n" +
        "rm -rf \"$CKPT\" && mkdir -p \"$CKPT\"\n" +
        "echo INIT > \"$CKPT/r10_watcher.status\"\n" +
        "\n" +
        "# Deps (idempotent)\n" +
        "python3 -c 'import unsloth, liger_kernel, peft, transformers' 2>/dev/null || \\\n" +
        "    pip install -q peft==0.13.2 transformers==4.45.2 unsloth liger-kernel 2>&1 | tail -3\n" +
        "\n" +
        "export HF_HUB_CACHE=/workspace/hf_cache HF_HOME=/workspace/hf_cache\n" +
        "\n" +
        "echo \"[launch] python3 " + py + " --steps " + steps + " --save-every " + save_every + " --eval-every " + eval_every + "\"\n" +
        "ADAPTER_ARG=\"\"\n" +
        "[[ -n \"$ADAPTER\" ]] && ADAPTER_ARG=\"--adapter-dir $ADAPTER\"\n" +
        "python3 " + py + " \\\n" +
        "    --base-dir \"$BASE\" \\\n" +
        "    $ADAPTER_ARG \\\n" +
        "    --corpus \"$CORPUS\" \\\n" +
        "    --ckpt-dir \"$CKPT\" \\\n" +
        "    --steps " + steps + " \\\n" +
        "    --save-every " + save_every + " \\\n" +
        "    --eval-every " + eval_every + " \\\n" +
        "    --lr 2e-6 \\\n" +
        "    --batch 8 \\\n" +
        "    --seq 1024 \\\n" +
        "    --grad-accum 1 \\\n" +
        "    --lora-r 32 \\\n" +
        "    --lora-alpha 64 \\\n" +
        "    --lora-dropout 0.0 \\\n" +
        "    2>&1 | tee \"$CKPT/train_r10.log\"\n" +
        "\n" +
        "if [[ -f \"$CKPT/r10_abort.status\" ]]; then\n" +
        "    echo \"[r10] ABORT triggered — see $CKPT/r10_abort.status\"\n" +
        "    exit 2\n" +
        "fi\n" +
        "echo DONE > \"$CKPT/r10_watcher.status\"\n" +
        "echo \"[r10] DONE — ckpt at $CKPT (label=" + ckpt_label + ")\"\n"
    )

    exec("bash " + runner)
}

main()
