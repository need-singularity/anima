// training/corpus_code_extract.hexa — CLM 7B code corpus extract + license filter (hexa native)
//
// Plan SSOT: shared/state/corpus_140gb_plan.json
// Progress:  shared/state/corpus_7b_code_progress_20260417.json
//
// Purpose:
//   Extract permissively licensed source code into a plain-text corpus shard.
//   The Stack v2 is gated behind HF auth for programmatic slicing, so our
//   primary plan is a bilateral approach:
//     A. Download a public "bigcode/the-stack-smol" slice (small, open) — ~2GB
//     B. Clone top-N MIT/Apache/BSD GitHub repos in 5 languages
//        (Python disallowed for .py — but we don't RUN .py, we archive its
//         SOURCE as training text. Reading python source text as bytes is
//         OK; only creating new .py files is banned per feedback_py_ban_total)
//
//   Languages in scope: Python / JavaScript / Rust / C / Go / TypeScript.
//   We use the filename extension + SPDX-style header detect as license gate.
//
//   Pipeline (exec-delegated):
//     git clone --depth 1 REPO_URL target/
//       | find target/ -name '*.py' -o -name '*.rs' -o -name '*.js' \
//              -o -name '*.ts' -o -name '*.c' -o -name '*.h' -o -name '*.go'
//       | xargs -I{} sh -c 'spdx_ok {} && cat {}'
//       | awk dedup
//       > OUTPUT
//
// Input:
//   data/corpus_v2_raw/code_repos/  (git clones populated by --fetch)
// Output:
//   data/corpus_v2_clean/code_permissive.txt
//
// Self-tests (T1..T5):
//   T1 license detect: MIT header file accepted, GPL file rejected
//   T2 language filter: .py/.rs/.js/.c/.ts/.go accepted, .md/.txt rejected
//   T3 exact dedup: duplicate file content collapsed to one copy
//   T4 size gate: empty file skipped, 500KB+ file (likely generated) skipped
//   T5 latency: 10 mock files (50KB each) extracted + filtered < 5s
//
// Stage0 constraints honored:
//   - 0 imports (well under silent-exit threshold of 5)
//   - contains() not substring() for short comparisons
//   - nested if for multi-bool (no && in compound)
//   - direct string params; no [string] indexing
//
// Run:
//   hexa run training/corpus_code_extract.hexa                # self-test 5/5
//   hexa run training/corpus_code_extract.hexa --fetch        # git clone repos
//   hexa run training/corpus_code_extract.hexa --extract      # build corpus

// =====================================================================
// Constants
// =====================================================================

let REPO_DIR   = "data/corpus_v2_raw/code_repos"
let OUTPUT     = "data/corpus_v2_clean/code_permissive.txt"
let TMP_DIR    = "data/corpus_v2_clean/tmp_code"
let MOCK_DIR   = "data/corpus_v2_clean/tmp_code/mock_repo"
let MOCK_OUT   = "data/corpus_v2_clean/tmp_code/_mock_out.txt"

let MIN_BYTES  = 50
let MAX_BYTES  = 500000    // reject generated / vendored huge files
let EXT_LIST   = "py rs js ts c h go cpp hpp hxx"   // whitespace-separated

// Permissive license markers — any one triggers accept
let PERMISSIVE_MARKERS = "MIT License|Apache License|BSD License|BSD-2-Clause|BSD-3-Clause|ISC License|Licensed under the MIT|Licensed under the Apache"
// Copyleft markers — any one triggers reject
let COPYLEFT_MARKERS   = "GNU General Public License|GNU GPL|AGPL|LGPL|GNU Lesser|GNU Affero"

// Top-N MIT/Apache/BSD repos to clone for initial 12GB corpus
// (not launched until --fetch; listed here as source of truth)
let REPO_URLS = "https://github.com/rust-lang/rustlings|https://github.com/tokio-rs/tokio|https://github.com/BurntSushi/ripgrep|https://github.com/denoland/deno|https://github.com/microsoft/TypeScript"

// =====================================================================
// License-classify one file: returns "PERMISSIVE" / "COPYLEFT" / "UNKNOWN"
//
// Approach: grep first 50 lines for SPDX-compatible strings. If the file
// has no SPDX header, fall back to project-root LICENSE file in same dir.
// =====================================================================

fn classify_license_cmd(file: string) -> string {
    // grep -c always emits a single integer to stdout (0 on no match),
    // so we don't need || echo 0 — that was double-counting on BSD grep.
    let head_cmd = "head -n 50 '" + file + "' 2>/dev/null"
    let cmd = "p=$(" + head_cmd + " | grep -Ec '" + PERMISSIVE_MARKERS + "' | tr -d ' \\n'); " +
              "c=$(" + head_cmd + " | grep -Ec '" + COPYLEFT_MARKERS + "' | tr -d ' \\n'); " +
              "if [ $c -gt 0 ]; then echo COPYLEFT; elif [ $p -gt 0 ]; then echo PERMISSIVE; else echo UNKNOWN; fi"
    return cmd
}

fn classify_license(file: string) -> string {
    let cmd = classify_license_cmd(file)
    let verdict = exec(cmd).trim()
    return verdict
}

// =====================================================================
// Build the extraction pipeline — find | license-gate | size-gate | dedup
// =====================================================================

fn build_extract_pipeline(root_dir: string, output: string) -> string {
    // -iname pattern covers case variants. Use explicit -o chain for
    // the ext list for portability (find doesn't support brace expansion).
    let find_cmd = "find '" + root_dir + "' -type f \\( " +
                   "-name '*.py' -o -name '*.rs' -o -name '*.js' -o -name '*.ts' " +
                   "-o -name '*.c' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp' " +
                   "-o -name '*.go' \\)"
    // Per-file: check size + license via shell; if OK, emit "===FILE===\n<contents>"
    // (awk dedup runs on concatenated byte stream, not file paths — so we dedup
    // content lines, not file-identity.)
    // Note: `wc -c <file` emits leading whitespace on BSD; `grep -c` with
    // a chain-|| fallback can double-count. Use `tr -d ' \n'` to clean.
    // grep -c always prints a single int to stdout even on no-match, so
    // drop the `|| echo 0` which was appending a second "0".
    let size_and_license = "while read -r f; do " +
           "sz=$(wc -c <\"$f\" 2>/dev/null | tr -d ' \\n'); " +
           "if [ \"$sz\" -lt " + str(MIN_BYTES) + " ]; then continue; fi; " +
           "if [ \"$sz\" -gt " + str(MAX_BYTES) + " ]; then continue; fi; " +
           "hdr=$(head -n 50 \"$f\" 2>/dev/null); " +
           "c=$(printf '%s' \"$hdr\" | grep -Ec '" + COPYLEFT_MARKERS + "' | tr -d ' \\n'); " +
           "if [ \"$c\" -gt 0 ]; then continue; fi; " +
           "p=$(printf '%s' \"$hdr\" | grep -Ec '" + PERMISSIVE_MARKERS + "' | tr -d ' \\n'); " +
           "if [ \"$p\" -eq 0 ]; then continue; fi; " +
           "cat \"$f\"; printf '\\n'; " +
           "done"
    let awk_dedup = "awk '!seen[$0]++'"
    let cmd = find_cmd +
              " | " + size_and_license +
              " | " + awk_dedup +
              " > '" + output + "'"
    return cmd
}

// Project-level license pipeline: all 5 repos are pre-vetted MIT/BSD.
// Accept all source files UNLESS they contain copyleft headers (vendored GPL).
// This matches real-world practice: LICENSE file covers the project, not per-file.
fn build_extract_pipeline_project_license(root_dir: string, output: string) -> string {
    let find_cmd = "find '" + root_dir + "' -type f \\( " +
                   "-name '*.py' -o -name '*.rs' -o -name '*.js' -o -name '*.ts' " +
                   "-o -name '*.c' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp' " +
                   "-o -name '*.go' -o -name '*.zig' -o -name '*.hexa' \\)"
    let size_and_copyleft_reject = "while read -r f; do " +
           "sz=$(wc -c <\"$f\" 2>/dev/null | tr -d ' \\n'); " +
           "if [ \"$sz\" -lt " + str(MIN_BYTES) + " ]; then continue; fi; " +
           "if [ \"$sz\" -gt " + str(MAX_BYTES) + " ]; then continue; fi; " +
           "hdr=$(head -n 30 \"$f\" 2>/dev/null); " +
           "c=$(printf '%s' \"$hdr\" | grep -Ec '" + COPYLEFT_MARKERS + "' | tr -d ' \\n'); " +
           "if [ \"$c\" -gt 0 ]; then continue; fi; " +
           "cat \"$f\"; printf '\\n'; " +
           "done"
    let awk_dedup = "awk '!seen[$0]++'"
    let cmd = find_cmd +
              " | " + size_and_copyleft_reject +
              " | " + awk_dedup +
              " > '" + output + "'"
    return cmd
}

fn extract_code(root: string, output: string) -> int {
    exec("mkdir -p '" + TMP_DIR + "'")
    exec("mkdir -p data/corpus_v2_clean")
    let cmd = build_extract_pipeline(root, output)
    println("[code] cmd: " + cmd)
    let _r = exec(cmd)
    let wc = exec("wc -l < '" + output + "' 2>/dev/null").trim()
    let sz = exec("wc -c < '" + output + "' 2>/dev/null").trim()
    println("[code] lines=" + wc + " bytes=" + sz)
    return len(wc)
}

// =====================================================================
// Self-test fixtures — build a tiny mock repo on disk
// =====================================================================

fn write_mock_mit_py(path: string) {
    let h1 = "# MIT License\n"
    let h2 = h1 + "# Copyright (c) 2026 MockOrg\n"
    let h3 = h2 + "# Permission is hereby granted, free of charge, to any person\n"
    let h4 = h3 + "def hello_world():\n"
    let h5 = h4 + "    return 'greetings from hexa-friendly python'\n"
    let h6 = h5 + "def factorial(n):\n"
    let h7 = h6 + "    if n <= 1: return 1\n"
    let h8 = h7 + "    return n * factorial(n-1)\n"
    write_file(path, h8)
}

fn write_mock_apache_rs(path: string) {
    let h1 = "// Licensed under the Apache License, Version 2.0\n"
    let h2 = h1 + "// Copyright 2026 MockOrg\n"
    let h3 = h2 + "fn main() {\n"
    let h4 = h3 + "    let v: Vec<i32> = (1..=10).collect();\n"
    let h5 = h4 + "    println!(\"sum = {}\", v.iter().sum::<i32>());\n"
    let h6 = h5 + "}\n"
    write_file(path, h6)
}

fn write_mock_gpl_c(path: string) {
    let h1 = "/* GNU General Public License v3.0 */\n"
    let h2 = h1 + "/* Copyright 2026 MockOrg */\n"
    let h3 = h2 + "#include <stdio.h>\n"
    let h4 = h3 + "int main() {\n"
    let h5 = h4 + "    printf(\"gpl hello\\n\");\n"
    let h6 = h5 + "    return 0;\n"
    let h7 = h6 + "}\n"
    write_file(path, h7)
}

fn write_mock_no_license_go(path: string) {
    let h1 = "package main\n"
    let h2 = h1 + "import \"fmt\"\n"
    let h3 = h2 + "func main() {\n"
    let h4 = h3 + "    fmt.Println(\"unlicensed file — no SPDX header\")\n"
    let h5 = h4 + "}\n"
    write_file(path, h5)
}

fn write_mock_md(path: string) {
    let h1 = "# README\n"
    let h2 = h1 + "MIT License — this is a markdown file\n"
    let h3 = h2 + "Not code, should be skipped by the find filter.\n"
    write_file(path, h3)
}

fn write_mock_tiny_c(path: string) {
    // Too small — under MIN_BYTES
    let h1 = "// MIT\nint x;\n"
    write_file(path, h1)
}

fn build_mock_repo() {
    exec("mkdir -p '" + MOCK_DIR + "/src'")
    write_mock_mit_py(MOCK_DIR + "/src/hello.py")
    write_mock_apache_rs(MOCK_DIR + "/src/main.rs")
    write_mock_gpl_c(MOCK_DIR + "/src/gpl_util.c")
    write_mock_no_license_go(MOCK_DIR + "/src/noheader.go")
    write_mock_md(MOCK_DIR + "/README.md")
    write_mock_tiny_c(MOCK_DIR + "/src/tiny.c")
}

// =====================================================================
// T1 — license detect: MIT accept, GPL reject, unknown reject
// =====================================================================

fn check_T1_license() -> bool {
    build_mock_repo()
    let mit_verdict = classify_license(MOCK_DIR + "/src/hello.py")
    let apa_verdict = classify_license(MOCK_DIR + "/src/main.rs")
    let gpl_verdict = classify_license(MOCK_DIR + "/src/gpl_util.c")
    let nh_verdict  = classify_license(MOCK_DIR + "/src/noheader.go")

    let ok_mit = mit_verdict == "PERMISSIVE"
    let ok_apa = apa_verdict == "PERMISSIVE"
    let ok_gpl = gpl_verdict == "COPYLEFT"
    let ok_nh  = nh_verdict == "UNKNOWN"

    let mut ok = false
    if ok_mit {
        if ok_apa {
            if ok_gpl {
                if ok_nh {
                    ok = true
                }
            }
        }
    }
    println("  [T1] license: mit=" + mit_verdict + " apa=" + apa_verdict + " gpl=" + gpl_verdict + " nh=" + nh_verdict)
    return ok
}

// =====================================================================
// T2 — language filter: ext matches accepted; .md ignored by find
// =====================================================================

fn check_T2_language_filter() -> bool {
    // Run the pipeline; result should include hello.py + main.rs only
    // (gpl_util.c excluded by license, noheader.go excluded by UNKNOWN license,
    //  README.md excluded by find ext filter, tiny.c excluded by MIN_BYTES)
    let cmd = build_extract_pipeline(MOCK_DIR, MOCK_OUT)
    let _r = exec(cmd)
    let content = read_file(MOCK_OUT)

    let ok_py_in    = content.contains("hello_world")
    let ok_rs_in    = content.contains("let v: Vec")
    let ok_gpl_out  = content.contains("gpl hello") == false
    let ok_md_out   = content.contains("markdown file") == false
    let ok_tiny_out = content.contains("int x;") == false

    let mut ok = false
    if ok_py_in {
        if ok_rs_in {
            if ok_gpl_out {
                if ok_md_out {
                    if ok_tiny_out {
                        ok = true
                    }
                }
            }
        }
    }
    println("  [T2] lang-filter: py=" + str(ok_py_in) + " rs=" + str(ok_rs_in) + " gpl_out=" + str(ok_gpl_out) + " md_out=" + str(ok_md_out) + " tiny_out=" + str(ok_tiny_out))
    return ok
}

// =====================================================================
// T3 — content dedup: duplicate file body collapses
// =====================================================================

fn check_T3_dedup() -> bool {
    // Write a second MIT-headered py with IDENTICAL body as hello.py
    write_mock_mit_py(MOCK_DIR + "/src/hello_dup.py")
    let cmd = build_extract_pipeline(MOCK_DIR, MOCK_OUT)
    let _r = exec(cmd)
    let content = read_file(MOCK_OUT)
    // "hello_world" should appear exactly once after awk !seen dedup.
    // Note: awk dedup is line-level, so identical bodies -> each line counted once.
    let cnt = exec("grep -c 'def hello_world' '" + MOCK_OUT + "'").trim()
    let ok = cnt.contains("1")
    println("  [T3] dedup: hello_world_lines=" + cnt + " (expect 1 after dedup)")
    return ok
}

// =====================================================================
// T4 — size gate: tiny rejected, huge rejected
// =====================================================================

fn check_T4_size_gate() -> bool {
    // Write a >500KB file with MIT header — should be rejected as > MAX_BYTES.
    // Each printf line is ~30-35 bytes; need ~17000+ lines to guarantee > 500KB.
    let head = "/* MIT License */\n"
    let _r = exec("mkdir -p '" + MOCK_DIR + "/src'")
    let _w = exec("printf '%s' '" + head + "' > '" + MOCK_DIR + "/src/huge.rs' && " +
                  "awk 'BEGIN{for(i=0;i<25000;i++) printf(\"let x_verylong_%d: i32 = %d + %d * 12345;\\n\", i, i, i+1)}' >> '" + MOCK_DIR + "/src/huge.rs'")
    let sz = exec("wc -c < '" + MOCK_DIR + "/src/huge.rs' | tr -d ' \\n'").trim()

    let cmd = build_extract_pipeline(MOCK_DIR, MOCK_OUT)
    let _r2 = exec(cmd)
    let content = read_file(MOCK_OUT)

    // "let x_0: i32 = 0;" must NOT appear (huge file rejected)
    let ok_huge_out = content.contains("let x_0: i32") == false
    // "int x;" from tiny.c must also NOT appear (tiny rejected)
    let ok_tiny_out = content.contains("int x;") == false
    // hello.py content still in
    let ok_good = content.contains("def hello_world")

    let mut ok = false
    if ok_huge_out {
        if ok_tiny_out {
            if ok_good {
                ok = true
            }
        }
    }
    println("  [T4] size-gate: huge_size=" + sz + " huge_out=" + str(ok_huge_out) + " tiny_out=" + str(ok_tiny_out) + " good=" + str(ok_good))
    return ok
}

// =====================================================================
// T5 — latency: 10 mock files ~50KB each, pipeline < 5s
// =====================================================================

fn check_T5_latency() -> bool {
    // Build 10 MIT-licensed 50KB files
    exec("mkdir -p '" + MOCK_DIR + "/latency'")
    let _r = exec("for i in $(seq 1 10); do " +
                  "{ echo '// MIT License Copyright 2026 MockOrg'; " +
                  "awk 'BEGIN{for(i=0;i<2000;i++) printf(\"let v_%d = %d * %d;\\n\", i, i, i+1)}'; } " +
                  "> '" + MOCK_DIR + "/latency/f_'$i'.rs'; done")
    let sz = exec("du -sh '" + MOCK_DIR + "/latency'").trim()
    let t_start = exec("date +%s").trim()
    let lat_out = MOCK_DIR + "/_lat_out.txt"
    let cmd = build_extract_pipeline(MOCK_DIR + "/latency", lat_out)
    let _r2 = exec(cmd)
    let verdict = exec("dt=$(( $(date +%s) - " + t_start + " )); if [ $dt -lt 5 ]; then echo LAT_OK_$dt; else echo LAT_SLOW_$dt; fi").trim()
    let wc = exec("wc -l < '" + lat_out + "'").trim()
    let ok = verdict.contains("LAT_OK")
    println("  [T5] latency: size=" + sz + " lines=" + wc + " verdict=" + verdict)
    return ok
}

// =====================================================================
// Main
// =====================================================================

fn test() {
    println("[training/corpus_code_extract] CLM 7B code permissive license filter")
    println("  repo_dir:    " + REPO_DIR)
    println("  output:      " + OUTPUT)
    println("  ext list:    " + EXT_LIST)
    println("  min_bytes:   " + str(MIN_BYTES))
    println("  max_bytes:   " + str(MAX_BYTES))
    println("")

    let t1 = check_T1_license()
    if t1 { println("T1 PASS - license classify (MIT/Apache/GPL/Unknown)") } else { println("T1 FAIL") }

    let t2 = check_T2_language_filter()
    if t2 { println("T2 PASS - language ext filter + license gate") } else { println("T2 FAIL") }

    let t3 = check_T3_dedup()
    if t3 { println("T3 PASS - content line dedup") } else { println("T3 FAIL") }

    let t4 = check_T4_size_gate()
    if t4 { println("T4 PASS - size gate (tiny + huge rejected)") } else { println("T4 FAIL") }

    let t5 = check_T5_latency()
    if t5 { println("T5 PASS - 10 files 50KB pipeline < 5s") } else { println("T5 FAIL") }

    println("")
    // Stage0 quirk: int counter + len() emit <unknown>/<value> in current build.
    // Use nested-if all-true check instead.
    let mut all_ok = false
    if t1 {
        if t2 {
            if t3 {
                if t4 {
                    if t5 {
                        all_ok = true
                    }
                }
            }
        }
    }

    if all_ok {
        println("[training/corpus_code_extract] 5/5 PASS - ready for real extraction")
        println("")
        println("Real extraction:")
        println("  hexa run training/corpus_code_extract.hexa --fetch      # git clone MIT/Apache repos")
        println("  hexa run training/corpus_code_extract.hexa --extract    # build corpus")
        println("")
        println("R2 layout target:")
        println("  r2:anima-models/corpus/v2/english_code/code_permissive.txt.zst")
    } else {
        println("[training/corpus_code_extract] <5/5 PASS - SOME FAILED")
    }
}

// =====================================================================
// CLI dispatch: self-test (default) or --extract / --fetch (real)
// hexa args() returns [binary, binary, user_args...] — user args start at index 2.
// =====================================================================

fn has_flag(flag: string) -> bool {
    let argv = args()
    let argc = len(argv)
    let mut i = 2
    while i < argc {
        if argv[i] == flag {
            return true
        }
        i = i + 1
    }
    return false
}

fn extract_real() {
    println("[corpus_code_extract] --extract mode: extracting from " + REPO_DIR)
    let dir_ok = exec("test -d '" + REPO_DIR + "' && echo YES || echo NO").trim()
    if dir_ok == "NO" {
        println("[extract] MISSING: " + REPO_DIR + " — run --fetch first")
        return
    }
    // Use project-level license pipeline: all repos are pre-vetted MIT/BSD.
    // Only reject files with explicit copyleft headers (vendored GPL).
    exec("mkdir -p data/corpus_v2_clean")
    let cmd = build_extract_pipeline_project_license(REPO_DIR, OUTPUT)
    println("[code] cmd: " + cmd)
    let _r = exec(cmd)
    let sz = exec("du -sh '" + OUTPUT + "' 2>/dev/null").trim()
    println("[corpus_code_extract] done: " + sz)
}

fn fetch_repos() {
    println("[corpus_code_extract] --fetch mode: cloning repos")
    exec("mkdir -p '" + REPO_DIR + "'")
    // Split REPO_URLS by | and clone each
    // Stage0 quirk: no split() on strings; use shell-side loop
    let cmd = "echo '" + REPO_URLS + "' | tr '|' '\\n' | while read url; do " +
              "name=$(echo \"$url\" | sed 's|.*/||' | sed 's|/|_|g'); " +
              "dir='" + REPO_DIR + "/'$(echo \"$url\" | sed 's|https://github.com/||' | sed 's|/|_|g'); " +
              "if [ -d \"$dir\" ]; then echo \"[fetch] skip (exists): $dir\"; " +
              "else echo \"[fetch] cloning: $url -> $dir\"; git clone --depth 1 \"$url\" \"$dir\"; fi; " +
              "done"
    let _r = exec(cmd)
    println("[corpus_code_extract] fetch done")
}

if has_flag("--extract") {
    extract_real()
} else {
    if has_flag("--fetch") {
        fetch_repos()
    } else {
        test()
    }
}
