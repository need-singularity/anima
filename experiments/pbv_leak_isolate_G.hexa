// G: 2048 index writes (one full sweep) — matches inner loop in isolate C
fn zeros_list(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

let mut W = zeros_list(2048)
let mut i = 0
while i < 2048 {
    W[i] = 1.0
    i = i + 1
}
println("G done, len=" + str(len(W)))
