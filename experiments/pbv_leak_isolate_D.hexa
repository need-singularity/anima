// Isolate D: only reads, no writes
fn zeros_list(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

let W = zeros_list(2048)
let G = zeros_list(2048)
let mut sum = 0.0
let mut step = 0
while step < 50 {
    let n = len(W)
    let mut i = 0
    while i < n {
        sum = sum + W[i] - 0.01 * G[i]
        i = i + 1
    }
    step = step + 1
}
println("D done step=" + str(step) + " sum=" + str(sum))
