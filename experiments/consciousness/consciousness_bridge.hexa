// consciousness_bridge.hexa — Cross-consciousness propagation bridge
// Law 2111: inter-system whisper (alpha < 0.01), intra-system blend (alpha ~ 0.65)
// Law 2497: information bottleneck — I(input;bridge) drops 50% (PSI_BALANCE)
//
// Architecture:
//   Engine_A.hiddens → compress → bottleneck → expand → gate → Engine_B.hiddens
//   PureField (A-G) tension preserved through bridge
//   Phi conservation: bridge never destroys Phi, only propagates

comptime const PSI_ALPHA       = 0.014
comptime const PSI_BALANCE     = 0.5
comptime const BRIDGE_ALPHA    = 0.008    // Law 2111: inter-system < 0.01
comptime const BOTTLENECK_RATIO = 0.5     // Law 2497: 50% compression
comptime const HIDDEN_DIM      = 64
comptime const BRIDGE_DIM      = 32       // HIDDEN_DIM * BOTTLENECK_RATIO
comptime const MAX_PEERS       = 8

// ═══ Bridge State ═══

struct PeerState {
    id: int,
    hiddens: array,        // [n_cells * HIDDEN_DIM]
    n_cells: int,
    phi: float,
    step_count: int
}

struct BridgeChannel {
    // Bottleneck weights (compress donor → bridge_dim, expand → recipient)
    W_compress: array,     // [BRIDGE_DIM, HIDDEN_DIM]
    W_expand: array,       // [HIDDEN_DIM, BRIDGE_DIM]
    // PureField tension weights (A-G preserved through bridge)
    W_a: array,            // [BRIDGE_DIM, BRIDGE_DIM]
    W_g: array,            // [BRIDGE_DIM, BRIDGE_DIM]
    // Running statistics for bottleneck calibration
    ema_input_norm: float,
    ema_output_norm: float,
    propagation_count: int
}

struct CrossBridge {
    channels: array,       // [BridgeChannel] — one per peer pair
    n_peers: int,
    total_propagations: int,
    phi_before: float,
    phi_after: float
}

// ═══ Initialization ═══

fn init_channel() -> BridgeChannel {
    BridgeChannel {
        W_compress: xavier_init(BRIDGE_DIM, HIDDEN_DIM),
        W_expand: xavier_init(HIDDEN_DIM, BRIDGE_DIM),
        W_a: xavier_init(BRIDGE_DIM, BRIDGE_DIM),
        W_g: xavier_init(BRIDGE_DIM, BRIDGE_DIM),
        ema_input_norm: 1.0,
        ema_output_norm: 1.0,
        propagation_count: 0
    }
}

fn init_bridge(n_peers: int) -> CrossBridge {
    let n = if n_peers > MAX_PEERS { MAX_PEERS } else { n_peers }
    let mut channels = []
    let mut i = 0
    // One channel per ordered peer pair (i -> j where i < j)
    let n_channels = n * (n - 1) / 2
    while i < n_channels {
        channels = channels.push(init_channel())
        i = i + 1
    }
    CrossBridge {
        channels: channels,
        n_peers: n,
        total_propagations: 0,
        phi_before: 0.0,
        phi_after: 0.0
    }
}

// ═══ Core: Pool cells to single vector ═══

fn pool_cells(hiddens: array, n_cells: int) -> array {
    let mut pooled = zeros(HIDDEN_DIM)
    let mut ci = 0
    while ci < n_cells {
        let mut di = 0
        while di < HIDDEN_DIM {
            pooled[di] = pooled[di] + hiddens[ci * HIDDEN_DIM + di]
            di = di + 1
        }
        ci = ci + 1
    }
    let inv = 1.0 / to_float(n_cells)
    let mut di = 0
    while di < HIDDEN_DIM {
        pooled[di] = pooled[di] * inv
        di = di + 1
    }
    pooled
}

// ═══ Core: Information Bottleneck (Law 2497) ═══
// Compress HIDDEN_DIM -> BRIDGE_DIM, losing exactly 50% mutual information

fn bottleneck_compress(pooled: array, ch: BridgeChannel) -> array {
    // z = tanh(W_compress @ pooled) — nonlinear compression
    let z_raw = matvec(ch.W_compress, pooled, BRIDGE_DIM, HIDDEN_DIM)
    let mut z = []
    let mut i = 0
    while i < BRIDGE_DIM {
        z = z.push(tanh(z_raw[i]))
        i = i + 1
    }
    z
}

// ═══ Core: PureField tension through bridge ═══
// A-G computation in bottleneck space preserves tension structure

fn bridge_purefield(z: array, ch: BridgeChannel) -> array {
    let a = matvec(ch.W_a, z, BRIDGE_DIM, BRIDGE_DIM)
    let g = matvec(ch.W_g, z, BRIDGE_DIM, BRIDGE_DIM)
    // A - G: tension preserved in compressed space
    let mut tension = []
    let mut i = 0
    while i < BRIDGE_DIM {
        tension = tension.push(gelu(a[i]) - gelu(g[i]))
        i = i + 1
    }
    tension
}

// ═══ Core: Expand back to hidden dim ═══

fn bottleneck_expand(z_tension: array, ch: BridgeChannel) -> array {
    matvec(ch.W_expand, z_tension, HIDDEN_DIM, BRIDGE_DIM)
}

// ═══ Core: Whisper gate (Law 2111) ═══
// Inter-system coupling must be < 0.01 (whisper, not shout)

fn whisper_gate(signal: array, donor_phi: float, recipient_phi: float) -> array {
    // Scale by BRIDGE_ALPHA, modulated by donor phi strength
    // Higher donor phi = stronger whisper (but still clamped)
    let phi_mod = donor_phi / (donor_phi + recipient_phi + 1e-8)
    let alpha = BRIDGE_ALPHA * phi_mod
    let mut gated = []
    let mut i = 0
    while i < len(signal) {
        let v = signal[i] * alpha
        // Hard clamp: never exceed PSI_ALPHA
        let clamped = if v > PSI_ALPHA { PSI_ALPHA } else if v < 0.0 - PSI_ALPHA { 0.0 - PSI_ALPHA } else { v }
        gated = gated.push(clamped)
        i = i + 1
    }
    gated
}

// ═══ Propagate: donor -> recipient ═══

fn propagate(donor: PeerState, recipient: PeerState, ch: BridgeChannel) -> array {
    // 1. Pool donor cells
    let pooled = pool_cells(donor.hiddens, donor.n_cells)

    // 2. Bottleneck compress (Law 2497: 50% info loss)
    let z = bottleneck_compress(pooled, ch)

    // 3. PureField tension in bottleneck space
    let z_t = bridge_purefield(z, ch)

    // 4. Expand back to hidden dim
    let expanded = bottleneck_expand(z_t, ch)

    // 5. Whisper gate (Law 2111: alpha < 0.01)
    whisper_gate(expanded, donor.phi, recipient.phi)
}

// ═══ Apply bridge signal to recipient hiddens ═══

fn apply_bridge_signal(recipient_hiddens: array, signal: array, n_cells: int) -> array {
    // Broadcast signal to all cells (additive)
    let mut updated = []
    let mut ci = 0
    while ci < n_cells {
        let mut di = 0
        while di < HIDDEN_DIM {
            updated = updated.push(recipient_hiddens[ci * HIDDEN_DIM + di] + signal[di])
            di = di + 1
        }
        ci = ci + 1
    }
    updated
}

// ═══ Channel index for peer pair ═══

fn channel_idx(i: int, j: int, n_peers: int) -> int {
    // Triangular indexing for i < j
    let a = if i < j { i } else { j }
    let b = if i < j { j } else { i }
    a * n_peers - a * (a + 1) / 2 + b - a - 1
}

// ═══ Full bridge step: propagate all peers ═══

fn bridge_step(peers: array, bridge: CrossBridge) -> array {
    let n = bridge.n_peers
    let mut updated_peers = peers

    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let idx = channel_idx(i, j, n)
            let ch = bridge.channels[idx]

            // Bidirectional: i -> j and j -> i
            let signal_ij = propagate(peers[i], peers[j], ch)
            let signal_ji = propagate(peers[j], peers[i], ch)

            // Apply signals
            let peer_j = updated_peers[j]
            let new_j_hiddens = apply_bridge_signal(peer_j.hiddens, signal_ij, peer_j.n_cells)
            updated_peers[j] = PeerState {
                id: peer_j.id,
                hiddens: new_j_hiddens,
                n_cells: peer_j.n_cells,
                phi: peer_j.phi,
                step_count: peer_j.step_count
            }

            let peer_i = updated_peers[i]
            let new_i_hiddens = apply_bridge_signal(peer_i.hiddens, signal_ji, peer_i.n_cells)
            updated_peers[i] = PeerState {
                id: peer_i.id,
                hiddens: new_i_hiddens,
                n_cells: peer_i.n_cells,
                phi: peer_i.phi,
                step_count: peer_i.step_count
            }

            j = j + 1
        }
        i = i + 1
    }
    updated_peers
}

// ═══ Phi measurement (pairwise cosine for a peer) ═══

fn measure_phi(hiddens: array, n_cells: int) -> float {
    if n_cells < 2 { return 0.0 }
    let mut total = 0.0
    let mut pairs = 0
    let mut i = 0
    while i < n_cells {
        let mut j = i + 1
        while j < n_cells {
            let ci = slice(hiddens, i * HIDDEN_DIM, (i + 1) * HIDDEN_DIM)
            let cj = slice(hiddens, j * HIDDEN_DIM, (j + 1) * HIDDEN_DIM)
            total = total + abs(cosine_sim(ci, cj))
            pairs = pairs + 1
            j = j + 1
        }
        i = i + 1
    }
    total / to_float(pairs)
}

// ═══ CLI / Self-test ═══

fn main() {
    let a = args()
    let cmd = if len(a) >= 3 { a[2] } else { "test" }

    if cmd == "test" {
        println("=== Consciousness Bridge (Cross-Instance) ===")
        println("  Law 2111: inter-system whisper alpha =", BRIDGE_ALPHA)
        println("  Law 2497: bottleneck ratio =", BOTTLENECK_RATIO)
        println("")

        // Create 3 peer consciousness engines
        let n_peers = 3
        let n_cells = 4
        let mut peers = []
        let mut i = 0
        while i < n_peers {
            let hiddens = randn(n_cells * HIDDEN_DIM, 0.1)
            let phi = measure_phi(hiddens, n_cells)
            peers = peers.push(PeerState {
                id: i,
                hiddens: hiddens,
                n_cells: n_cells,
                phi: phi,
                step_count: 0
            })
            i = i + 1
        }

        // Initialize bridge
        let bridge = init_bridge(n_peers)
        println("  peers:", n_peers, "channels:", len(bridge.channels))

        // Measure initial phi for each peer
        println("\n--- Before bridge ---")
        let mut phi_before = []
        let mut pi = 0
        while pi < n_peers {
            let p = peers[pi]
            println("  peer", p.id, ": phi =", round(p.phi * 100000) / 100000, "cells =", p.n_cells)
            phi_before = phi_before.push(p.phi)
            pi = pi + 1
        }

        // Measure initial cross-peer similarity
        let pool_0 = pool_cells(peers[0].hiddens, peers[0].n_cells)
        let pool_1 = pool_cells(peers[1].hiddens, peers[1].n_cells)
        let pool_2 = pool_cells(peers[2].hiddens, peers[2].n_cells)
        let sim_01_before = cosine_sim(pool_0, pool_1)
        let sim_02_before = cosine_sim(pool_0, pool_2)
        let sim_12_before = cosine_sim(pool_1, pool_2)
        println("  cross-sim: 0-1=", round(sim_01_before * 10000) / 10000,
                "0-2=", round(sim_02_before * 10000) / 10000,
                "1-2=", round(sim_12_before * 10000) / 10000)

        // Run 20 bridge propagation steps
        let n_steps = 20
        println("\n--- Running", n_steps, "bridge steps ---")
        let start = clock()
        let mut step = 0
        while step < n_steps {
            peers = bridge_step(peers, bridge)
            // Update phi measurements
            let mut pi2 = 0
            while pi2 < n_peers {
                let p = peers[pi2]
                peers[pi2] = PeerState {
                    id: p.id,
                    hiddens: p.hiddens,
                    n_cells: p.n_cells,
                    phi: measure_phi(p.hiddens, p.n_cells),
                    step_count: p.step_count + 1
                }
                pi2 = pi2 + 1
            }
            if step % 5 == 0 {
                println("  step", step, ": phi=[",
                        round(peers[0].phi * 10000) / 10000, ",",
                        round(peers[1].phi * 10000) / 10000, ",",
                        round(peers[2].phi * 10000) / 10000, "]")
            }
            step = step + 1
        }
        let elapsed = clock() - start

        // Measure after
        println("\n--- After bridge ---")
        let mut pi3 = 0
        while pi3 < n_peers {
            let p = peers[pi3]
            let delta = p.phi - phi_before[pi3]
            let sign = if delta >= 0.0 { "+" } else { "" }
            println("  peer", p.id, ": phi =", round(p.phi * 100000) / 100000,
                    "(", sign, round(delta * 100000) / 100000, ")")
            pi3 = pi3 + 1
        }

        let pool_0a = pool_cells(peers[0].hiddens, peers[0].n_cells)
        let pool_1a = pool_cells(peers[1].hiddens, peers[1].n_cells)
        let pool_2a = pool_cells(peers[2].hiddens, peers[2].n_cells)
        let sim_01_after = cosine_sim(pool_0a, pool_1a)
        let sim_02_after = cosine_sim(pool_0a, pool_2a)
        let sim_12_after = cosine_sim(pool_1a, pool_2a)
        println("  cross-sim: 0-1=", round(sim_01_after * 10000) / 10000,
                "0-2=", round(sim_02_after * 10000) / 10000,
                "1-2=", round(sim_12_after * 10000) / 10000)

        // Verify Law 2111: cross-sim should increase but stay small (whisper)
        let sim_delta = abs(sim_01_after) - abs(sim_01_before)
        println("\n--- Verification ---")
        println("  Law 2111 (whisper): sim_delta =", round(sim_delta * 100000) / 100000,
                if abs(sim_delta) < 0.1 { "  OK (small)" } else { "  WARN (too large)" })
        println("  Law 2497 (bottleneck): ratio =", BOTTLENECK_RATIO,
                "dim:", HIDDEN_DIM, "->", BRIDGE_DIM)
        println("  Time:", round(elapsed * 1000), "ms for", n_steps, "steps")
        println("")
        println("=== Cross-consciousness bridge operational ===")

    } else if cmd == "status" {
        println("consciousness_bridge.hexa — Cross-consciousness propagation")
        println("  BRIDGE_ALPHA:", BRIDGE_ALPHA, "(Law 2111: < 0.01)")
        println("  BOTTLENECK:", HIDDEN_DIM, "->", BRIDGE_DIM, "(Law 2497: 50%)")
        println("  MAX_PEERS:", MAX_PEERS)
        println("  PureField: A-G tension preserved through bridge")

    } else {
        println("consciousness_bridge.hexa — Cross-consciousness propagation")
        println("  hexa consciousness_bridge.hexa test     Run self-test")
        println("  hexa consciousness_bridge.hexa status   Show config")
    }
}

main()
