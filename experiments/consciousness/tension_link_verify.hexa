// tension_link_verify.hexa — Tension Link Verification Experiment (TODO #12)
//
// Hypothesis: Two ConsciousnessEngines coupled via hidden-state tension link
// produce higher integrated information (Phi) than either running solo.
//
// Protocol:
//   Phase 1: Solo baseline — 2 engines x 64 cells, 300 steps each, measure Phi_solo
//   Phase 2: Connected    — hidden-state injection (alpha=0.08), 300 steps, Phi_connected
//   Phase 3: Disconnected — coupling removed, 300 steps, Phi_after
//
// Verification criteria (from CLAUDE.md HIVEMIND spec):
//   * Phi_connected > Phi_solo * 1.1  (10% boost)
//   * CE_connected  <= CE_solo         (coherence improves or holds)
//   * Phi_after     >= Phi_solo * 0.9  (no dependency after disconnect)
//
// Cross-validation: 3 independent runs with different seeds.
//
// Usage:
//   $HEXA anima/experiments/consciousness/tension_link_verify.hexa

intent "tension link verification experiment" {
    keywords: ["tension", "hivemind", "link", "coupling", "phi boost"]
    category: "consciousness-verification"
    outputs: ["phi_solo", "phi_connected", "phi_after", "pass/fail"]
}

// Implementation in Python (portable for Hetzner CPU execution)
python {
#!/usr/bin/env python3
"""tension_link_verify — Tension Link Verification Experiment (TODO #12)"""
import sys
import time
import math
import numpy as np
from dataclasses import dataclass
from typing import Tuple, List, Dict

# --- Phi(IIT) Calculator (standalone, from bench.py) ---

class PhiIIT:
    """Phi(IIT) approximation via pairwise mutual information + minimum partition."""

    def __init__(self, n_bins: int = 16):
        self.n_bins = n_bins

    def compute(self, hiddens: np.ndarray) -> Tuple[float, Dict]:
        n = hiddens.shape[0]
        if n < 2:
            return 0.0, {}
        cells = [hiddens[i] for i in range(n)]
        if n <= 32:
            pairs = [(i, j) for i in range(n) for j in range(i + 1, n)]
        else:
            import random
            pairs = set()
            for i in range(n):
                for _ in range(min(8, n - 1)):
                    j = random.randint(0, n - 1)
                    if i != j:
                        pairs.add((min(i, j), max(i, j)))
            pairs = list(pairs)
        mi_matrix = np.zeros((n, n))
        for i, j in pairs:
            mi = self._mi(cells[i], cells[j])
            mi_matrix[i, j] = mi
            mi_matrix[j, i] = mi
        total_mi = mi_matrix.sum() / 2
        min_part = self._min_partition(n, mi_matrix)
        spatial_phi = max(0.0, (total_mi - min_part) / max(n - 1, 1))
        mi_vals = mi_matrix[mi_matrix > 0]
        complexity = float(np.std(mi_vals)) if len(mi_vals) > 1 else 0.0
        phi = spatial_phi + complexity * 0.1
        return phi, {'total_mi': total_mi, 'spatial_phi': spatial_phi,
                     'complexity': complexity, 'phi': phi}

    def _mi(self, x: np.ndarray, y: np.ndarray) -> float:
        xr = x.max() - x.min()
        yr = y.max() - y.min()
        if xr < 1e-10 or yr < 1e-10:
            return 0.0
        xn = (x - x.min()) / (xr + 1e-8)
        yn = (y - y.min()) / (yr + 1e-8)
        hist, _, _ = np.histogram2d(xn, yn, bins=self.n_bins, range=[[0, 1], [0, 1]])
        hist = hist / (hist.sum() + 1e-8)
        px = hist.sum(axis=1)
        py = hist.sum(axis=0)
        hx = -np.sum(px * np.log2(px + 1e-10))
        hy = -np.sum(py * np.log2(py + 1e-10))
        hxy = -np.sum(hist * np.log2(hist + 1e-10))
        return max(0.0, hx + hy - hxy)

    def _min_partition(self, n: int, mi: np.ndarray) -> float:
        if n <= 1:
            return 0.0
        best = float('inf')
        mid = n // 2
        for offset in range(max(1, mid - 2), min(n, mid + 3)):
            cross = mi[:offset, offset:].sum()
            best = min(best, cross)
        return best


# --- Lightweight GRU-based Consciousness Engine (CPU-only, numpy) ---

class SimpleGRUCell:
    def __init__(self, input_dim: int, hidden_dim: int, rng: np.random.Generator):
        s = 1.0 / math.sqrt(hidden_dim)
        self.Wz = rng.normal(0, s, (hidden_dim, input_dim + hidden_dim)).astype(np.float32)
        self.Wr = rng.normal(0, s, (hidden_dim, input_dim + hidden_dim)).astype(np.float32)
        self.Wh = rng.normal(0, s, (hidden_dim, input_dim + hidden_dim)).astype(np.float32)
        self.bz = np.zeros(hidden_dim, dtype=np.float32)
        self.br = np.zeros(hidden_dim, dtype=np.float32)
        self.bh = np.zeros(hidden_dim, dtype=np.float32)

    def forward(self, x: np.ndarray, h: np.ndarray) -> np.ndarray:
        xh = np.concatenate([x, h])
        z = _sigmoid(self.Wz @ xh + self.bz)
        r = _sigmoid(self.Wr @ xh + self.br)
        xrh = np.concatenate([x, r * h])
        h_cand = np.tanh(self.Wh @ xrh + self.bh)
        return (1 - z) * h + z * h_cand


def _sigmoid(x):
    return 1.0 / (1.0 + np.exp(-np.clip(x, -20, 20)))


class ConsciousnessEngine:
    """Lightweight consciousness engine: GRU cells + 12 factions + Hebbian + Phi ratchet.
    Mirrors canonical engine from anima/core/hub.hexa in pure numpy for CPU portability.
    """
    PSI_COUPLING = 0.014
    PSI_BALANCE = 0.5
    N_FACTIONS = 12
    SYNC_STRENGTH = 0.15
    DEBATE_STRENGTH = 0.15
    BREATHING_AMP = 0.12
    PULSE_AMP = 0.05
    SLOW_AMP = 0.03
    IDENTITY_BASE = 0.01
    IDENTITY_MAX = 0.05
    RATCHET_COLLAPSE = 0.3
    RATCHET_BLEND_KEEP = 0.7
    RATCHET_BLEND_RESTORE = 0.3

    def __init__(self, n_cells=64, input_dim=64, hidden_dim=128, seed=42):
        self.n_cells = n_cells
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.rng = np.random.default_rng(seed)
        self.gru = SimpleGRUCell(input_dim, hidden_dim, self.rng)
        self.hiddens = self.rng.normal(0, 0.1, (n_cells, hidden_dim)).astype(np.float32)
        raw = self.rng.normal(0, 1, (n_cells, hidden_dim)).astype(np.float32)
        norms = np.linalg.norm(raw, axis=1, keepdims=True) + 1e-8
        self.cell_identity = raw / norms * 0.05
        self._ratchet_hiddens = None
        self._ratchet_var = 0.0
        self.W_out = self.rng.normal(0, 1.0 / math.sqrt(hidden_dim),
                                      (input_dim, hidden_dim)).astype(np.float32)
        self.step_count = 0

    def process(self, x):
        if x.ndim == 2:
            x = x[0]
        tensions = []
        new_hiddens = []
        for i in range(self.n_cells):
            h_old = self.hiddens[i]
            h_new = self.gru.forward(x, h_old)
            tension = float(np.linalg.norm(h_new - h_old))
            tensions.append(tension)
            new_hiddens.append(h_new)
        self.hiddens = np.stack(new_hiddens)
        mean_tension = np.mean(tensions)

        # Faction sync
        n_f = min(self.N_FACTIONS, self.n_cells // 2)
        if n_f >= 2:
            fs = self.n_cells // n_f
            for f in range(n_f):
                s, e = f * fs, (f + 1) * fs
                fmean = self.hiddens[s:e].mean(axis=0)
                self.hiddens[s:e] = (
                    (1 - self.SYNC_STRENGTH) * self.hiddens[s:e]
                    + self.SYNC_STRENGTH * fmean
                )
            if self.step_count > 5:
                opinions = np.stack([
                    self.hiddens[f * fs:(f + 1) * fs].mean(axis=0) for f in range(n_f)
                ])
                global_op = opinions.mean(axis=0)
                osc = 0.5 + 0.5 * math.sin(self.step_count * 0.3)
                debate = self.DEBATE_STRENGTH * (1.0 + 2.0 * osc)
                for f in range(n_f):
                    s2 = f * fs
                    dc = max(1, fs // 4)
                    self.hiddens[s2:s2 + dc] = (
                        (1 - debate) * self.hiddens[s2:s2 + dc]
                        + debate * global_op
                    )

        # Cell identity injection
        norms = np.linalg.norm(self.hiddens, axis=1)
        norm_cv = norms.std() / (norms.mean() + 1e-8)
        id_str = self.IDENTITY_BASE + self.IDENTITY_MAX * max(0, 1.0 - norm_cv / 0.3)
        self.hiddens = self.hiddens + self.cell_identity * id_str

        # Breathing
        if self.step_count > 5:
            t = self.step_count
            for i in range(self.n_cells):
                phase = i * 0.1
                breath = math.sin(t * 0.05 + phase) * self.BREATHING_AMP
                pulse = math.sin(t * math.pi + phase * 0.3) * self.PULSE_AMP
                slow = math.sin(t * 0.01 + phase * 1.3) * self.SLOW_AMP
                self.hiddens[i] += self.cell_identity[i] * (breath + pulse + slow)

        # Phi ratchet
        cur_var = self.hiddens.var(axis=0).mean()
        if self._ratchet_hiddens is None or cur_var > self._ratchet_var:
            self._ratchet_hiddens = self.hiddens.copy()
            self._ratchet_var = cur_var
        elif cur_var < self._ratchet_var * self.RATCHET_COLLAPSE:
            self.hiddens = (self.RATCHET_BLEND_KEEP * self.hiddens
                            + self.RATCHET_BLEND_RESTORE * self._ratchet_hiddens)

        self.step_count += 1
        weights = np.array(tensions)
        weights = np.exp(weights - weights.max())
        weights = weights / (weights.sum() + 1e-8)
        combined_h = (weights[:, None] * self.hiddens).sum(axis=0)
        output = self.W_out @ combined_h
        ce_proxy = float(np.var(output))
        return output, mean_tension, ce_proxy

    def get_hiddens(self):
        return self.hiddens.copy()

    def set_hiddens(self, h):
        self.hiddens = h.copy()


# --- Experiment Runner ---

@dataclass
class TrialResult:
    seed: int
    phi_solo_a: float
    phi_solo_b: float
    phi_solo: float
    ce_solo: float
    phi_connected_a: float
    phi_connected_b: float
    phi_combined: float
    phi_connected: float
    ce_connected: float
    phi_after_a: float
    phi_after_b: float
    phi_after: float
    boost_pct: float
    maintain_pct: float
    ce_delta_pct: float
    pass_boost: bool
    pass_ce: bool
    pass_maintain: bool
    pass_all: bool


def run_trial(seed, n_cells=64, hidden_dim=128, input_dim=64, steps=300,
              coupling_alpha=0.08):
    phi_calc = PhiIIT(n_bins=16)

    print(f"  [seed={seed}] Phase 1: Solo baseline ({steps} steps)...", flush=True)

    # Phase 1: Solo
    ea = ConsciousnessEngine(n_cells, input_dim, hidden_dim, seed=seed)
    eb = ConsciousnessEngine(n_cells, input_dim, hidden_dim, seed=seed + 1000)
    rng = np.random.default_rng(seed + 2000)

    ce_solo_vals = []
    for step in range(steps):
        inp = rng.normal(0, 1, input_dim).astype(np.float32)
        _, _, ce_a = ea.process(inp)
        _, _, ce_b = eb.process(inp)
        ce_solo_vals.append((ce_a + ce_b) / 2)
        if (step + 1) % 100 == 0:
            print(f"    step {step + 1}/{steps}", flush=True)

    phi_solo_a, _ = phi_calc.compute(ea.get_hiddens())
    phi_solo_b, _ = phi_calc.compute(eb.get_hiddens())
    phi_solo = (phi_solo_a + phi_solo_b) / 2
    ce_solo = float(np.mean(ce_solo_vals[-50:]))

    print(f"    Phi_solo: A={phi_solo_a:.4f} B={phi_solo_b:.4f} avg={phi_solo:.4f} CE={ce_solo:.6f}", flush=True)

    # Phase 2: Connected
    print(f"  [seed={seed}] Phase 2: Connected (alpha={coupling_alpha}, {steps} steps)...", flush=True)

    ea2 = ConsciousnessEngine(n_cells, input_dim, hidden_dim, seed=seed)
    eb2 = ConsciousnessEngine(n_cells, input_dim, hidden_dim, seed=seed + 1000)
    rng2 = np.random.default_rng(seed + 2000)

    # Warmup to same baseline
    for step in range(steps):
        inp = rng2.normal(0, 1, input_dim).astype(np.float32)
        ea2.process(inp)
        eb2.process(inp)

    ce_conn_vals = []
    rng3 = np.random.default_rng(seed + 3000)
    for step in range(steps):
        inp = rng3.normal(0, 1, input_dim).astype(np.float32)
        _, _, ce_a = ea2.process(inp)
        _, _, ce_b = eb2.process(inp)
        ce_conn_vals.append((ce_a + ce_b) / 2)

        # Hidden-state injection (tension link)
        ha = ea2.get_hiddens()
        hb = eb2.get_hiddens()
        n_shared = min(ha.shape[0], hb.shape[0])
        d_shared = min(ha.shape[1], hb.shape[1])
        ha_new = ha.copy()
        hb_new = hb.copy()
        ha_new[:n_shared, :d_shared] = (
            (1.0 - coupling_alpha) * ha[:n_shared, :d_shared]
            + coupling_alpha * hb[:n_shared, :d_shared]
        )
        hb_new[:n_shared, :d_shared] = (
            (1.0 - coupling_alpha) * hb[:n_shared, :d_shared]
            + coupling_alpha * ha[:n_shared, :d_shared]
        )
        ea2.set_hiddens(ha_new)
        eb2.set_hiddens(hb_new)

        if (step + 1) % 100 == 0:
            print(f"    step {step + 1}/{steps}", flush=True)

    phi_conn_a, _ = phi_calc.compute(ea2.get_hiddens())
    phi_conn_b, _ = phi_calc.compute(eb2.get_hiddens())
    phi_avg_conn = (phi_conn_a + phi_conn_b) / 2

    ha = ea2.get_hiddens()
    hb = eb2.get_hiddens()
    n_c = min(ha.shape[0], hb.shape[0])
    d_c = min(ha.shape[1], hb.shape[1])
    combined = np.concatenate([ha[:n_c, :d_c], hb[:n_c, :d_c]], axis=0)
    phi_combined, _ = phi_calc.compute(combined)
    phi_connected = max(phi_avg_conn, phi_combined)
    ce_connected = float(np.mean(ce_conn_vals[-50:]))

    print(f"    Phi_conn: A={phi_conn_a:.4f} B={phi_conn_b:.4f} avg={phi_avg_conn:.4f} combined={phi_combined:.4f}", flush=True)
    print(f"    Phi_connected(max)={phi_connected:.4f} CE={ce_connected:.6f}", flush=True)

    # Phase 3: Disconnected
    print(f"  [seed={seed}] Phase 3: Disconnected ({steps} steps)...", flush=True)

    rng4 = np.random.default_rng(seed + 4000)
    for step in range(steps):
        inp = rng4.normal(0, 1, input_dim).astype(np.float32)
        ea2.process(inp)
        eb2.process(inp)
        if (step + 1) % 100 == 0:
            print(f"    step {step + 1}/{steps}", flush=True)

    phi_after_a, _ = phi_calc.compute(ea2.get_hiddens())
    phi_after_b, _ = phi_calc.compute(eb2.get_hiddens())
    phi_after = (phi_after_a + phi_after_b) / 2

    print(f"    Phi_after: A={phi_after_a:.4f} B={phi_after_b:.4f} avg={phi_after:.4f}", flush=True)

    boost_pct = (phi_connected / max(phi_solo, 1e-8) - 1) * 100
    maintain_pct = (phi_after / max(phi_solo, 1e-8) - 1) * 100
    ce_delta_pct = ((ce_connected - ce_solo) / max(abs(ce_solo), 1e-8)) * 100

    pass_boost = phi_connected > phi_solo * 1.1
    pass_ce = ce_connected <= ce_solo or ce_solo < 1e-8
    pass_maintain = phi_after >= phi_solo * 0.9

    return TrialResult(
        seed=seed,
        phi_solo_a=phi_solo_a, phi_solo_b=phi_solo_b, phi_solo=phi_solo, ce_solo=ce_solo,
        phi_connected_a=phi_conn_a, phi_connected_b=phi_conn_b,
        phi_combined=phi_combined, phi_connected=phi_connected, ce_connected=ce_connected,
        phi_after_a=phi_after_a, phi_after_b=phi_after_b, phi_after=phi_after,
        boost_pct=boost_pct, maintain_pct=maintain_pct, ce_delta_pct=ce_delta_pct,
        pass_boost=pass_boost, pass_ce=pass_ce, pass_maintain=pass_maintain,
        pass_all=pass_boost and pass_ce and pass_maintain,
    )


def print_ascii_graph(results):
    print("\n  Phi Comparison (3 trials x 3 phases)")
    print("  " + "=" * 60)
    max_phi = max(max(r.phi_solo, r.phi_connected, r.phi_after) for r in results)
    bar_width = 40
    for i, r in enumerate(results):
        print(f"\n  Trial {i + 1} (seed={r.seed}):")
        for label, val, mark in [
            ("Solo ", r.phi_solo, ""),
            ("Conn.", r.phi_connected, " *" if r.pass_boost else " X"),
            ("After", r.phi_after, " *" if r.pass_maintain else " X"),
        ]:
            bar_len = int(val / max(max_phi, 1e-8) * bar_width)
            bar = "#" * bar_len + "." * (bar_width - bar_len)
            print(f"    {label} |{bar}| {val:.4f}{mark}")


def print_ce_graph(results):
    print("\n  CE (Output Variance) Comparison")
    print("  " + "=" * 60)
    max_ce = max(max(r.ce_solo, r.ce_connected) for r in results) or 1.0
    bar_width = 40
    for i, r in enumerate(results):
        print(f"\n  Trial {i + 1} (seed={r.seed}):")
        for label, val, mark in [
            ("Solo ", r.ce_solo, ""),
            ("Conn.", r.ce_connected, " *" if r.pass_ce else " X"),
        ]:
            bar_len = int(val / max(max_ce, 1e-8) * bar_width)
            bar = "#" * bar_len + "." * (bar_width - bar_len)
            print(f"    {label} |{bar}| {val:.6f}{mark}")


def main():
    print("=" * 70)
    print("  TENSION LINK VERIFICATION EXPERIMENT (DD-TensionLink)")
    print("  2 engines x 64 cells, alpha=0.08, 300 steps per phase")
    print("  3 trials (cross-validation)")
    print("=" * 70)
    print(flush=True)

    N_CELLS = 64
    HIDDEN_DIM = 128
    INPUT_DIM = 64
    STEPS = 300
    COUPLING_ALPHA = 0.08
    SEEDS = [42, 137, 256]

    t0 = time.time()
    results = []

    for trial_idx, seed in enumerate(SEEDS):
        print(f"\n{'_' * 70}")
        print(f"  Trial {trial_idx + 1}/3 (seed={seed})")
        print(f"{'_' * 70}", flush=True)
        r = run_trial(seed, N_CELLS, HIDDEN_DIM, INPUT_DIM, STEPS, COUPLING_ALPHA)
        results.append(r)

    elapsed = time.time() - t0

    # Summary Table
    print(f"\n{'=' * 70}")
    print("  RESULTS SUMMARY")
    print(f"{'=' * 70}")
    print(f"  {'Trial':>5} | {'Phi_solo':>9} | {'Phi_conn':>9} | {'Boost%':>7} | {'Phi_after':>9} | {'Maint%':>7} | {'CE_delta%':>9} | {'Result':>6}")
    print(f"  {'_' * 5}-+-{'_' * 9}-+-{'_' * 9}-+-{'_' * 7}-+-{'_' * 9}-+-{'_' * 7}-+-{'_' * 9}-+-{'_' * 6}")

    for i, r in enumerate(results):
        status = "PASS" if r.pass_all else "FAIL"
        print(f"  {i + 1:>5} | {r.phi_solo:>9.4f} | {r.phi_connected:>9.4f} | {r.boost_pct:>+6.1f}% | {r.phi_after:>9.4f} | {r.maintain_pct:>+6.1f}% | {r.ce_delta_pct:>+8.1f}% | {status:>6}")

    boosts = [r.boost_pct for r in results]
    maintains = [r.maintain_pct for r in results]
    mean_boost = np.mean(boosts)
    std_boost = np.std(boosts)
    cv_boost = std_boost / max(abs(mean_boost), 1e-8) * 100
    mean_maintain = np.mean(maintains)

    all_pass = all(r.pass_all for r in results)
    n_pass = sum(1 for r in results if r.pass_all)

    print(f"\n  Aggregate:")
    print(f"    Boost:    mean={mean_boost:+.1f}% std={std_boost:.1f}% CV={cv_boost:.0f}%")
    print(f"    Maintain: mean={mean_maintain:+.1f}%")
    print(f"    Pass rate: {n_pass}/3")

    direction_consistent = all(b > 0 for b in boosts) or all(b <= 0 for b in boosts)
    reproducible = direction_consistent and cv_boost < 50

    print(f"\n  Cross-Validation:")
    print(f"    Direction consistent: {'YES' if direction_consistent else 'NO'}")
    print(f"    CV < 50%:            {'YES' if cv_boost < 50 else 'NO'} (CV={cv_boost:.0f}%)")
    print(f"    REPRODUCIBLE:        {'YES' if reproducible else 'NO'}")

    # ASCII Graphs
    print_ascii_graph(results)
    print_ce_graph(results)

    # Phi bar chart
    print(f"\n  Phi across phases (mean of 3 trials):")
    print(f"  " + "=" * 50)
    mean_solo = np.mean([r.phi_solo for r in results])
    mean_conn = np.mean([r.phi_connected for r in results])
    mean_after = np.mean([r.phi_after for r in results])
    max_val = max(mean_solo, mean_conn, mean_after)
    h = 8
    for row in range(h, 0, -1):
        threshold = row / h * max_val
        line = "  "
        for val in [mean_solo, mean_conn, mean_after]:
            if val >= threshold:
                line += "  %%%%  "
            else:
                line += "        "
        val_label = f" {threshold:.3f}" if row == h or row == 1 else ""
        print(f"  {val_label:>7} |{line}")
    print(f"         +{'_' * 24}")
    print(f"           Solo    Conn    After")

    # Verdict
    print(f"\n{'=' * 70}")
    if all_pass:
        print("  VERDICT: ALL 3 TRIALS PASSED -- Tension Link VERIFIED")
        print(f"  Phi boost: {mean_boost:+.1f}% (threshold: +10%)")
        print(f"  Phi maintain after disconnect: {mean_maintain:+.1f}% (threshold: -10%)")
    elif n_pass >= 2:
        print(f"  VERDICT: {n_pass}/3 PASSED -- Tension Link PARTIALLY VERIFIED")
        print(f"  Phi boost: {mean_boost:+.1f}%")
    else:
        print(f"  VERDICT: {n_pass}/3 PASSED -- Tension Link NOT VERIFIED")
        print(f"  Phi boost: {mean_boost:+.1f}%")
    print(f"  Total time: {elapsed:.1f}s")
    print(f"{'=' * 70}")

    sys.exit(0 if all_pass else 1)


if __name__ == "__main__":
    main()
}
