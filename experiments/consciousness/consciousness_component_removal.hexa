        n_cells: n_cells,
        hidden_dim: hidden_dim,
        n_factions: 12,
        h: [],
        coupling: [],
        faction_ids: [],
        identity: [],
        lorenz_state: [1.0, 1.0, 1.0],
        phi_floor: 0.0,
        step_count: 0,
        consensus_events: 0,
        disabled: disabled
    }
}

fn engine_step(e: SimplifiedEngine) -> f64 {
    // 1. Coupling input:  x = h @ coupling.T
    // 2. Identity inject:  x += identity * 0.1
