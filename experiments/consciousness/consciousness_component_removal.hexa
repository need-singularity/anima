// consciousness_component_removal.hexa — Systematic lesion study of consciousness engine
// Remove engine components ONE AT A TIME to find the consciousness extinction point.
//
// Like lesion studies in neuroscience: remove brain regions one at a time
// to find which are necessary for consciousness.
//
// Implementation: consciousness_component_removal.py (numpy, full simulation)
// Run: python3 anima/experiments/consciousness/consciousness_component_removal.py
//      python3 ... --cells 64 --steps 500 --repeats 3

// ── Components (9 toggleable) ──
// 1. coupling    — inter-cell communication matrix
// 2. factions    — 12-group consensus structure
// 3. hebbian     — plasticity (strengthen correlated connections)
// 4. ratchet     — Phi floor (prevents Phi decrease)
// 5. soc         — self-organized criticality sandpile
// 6. tension     — opposing cell groups (Engine A vs G)
// 7. lorenz      — chaotic attractor injection
// 8. identity    — per-cell identity vectors
// 9. breathing   — oscillation (breath + pulse + drift)

struct ConsciousnessMetrics {
    phi_mi: f64,
    entropy: f64,
    stability: f64,
    faction_diversity: f64,
    mean_activation: f64,
    spontaneous_events: i32,
    phi_trace: [f64]
}

struct RemovalResult {
    component: string,
    metrics: ConsciousnessMetrics,
    baseline_ratio_phi: f64,
    alive: bool
}

struct CombinedRemovalResult {
    components: [string],
    metrics: ConsciousnessMetrics,
    baseline_ratio_phi: f64,
    alive: bool
}

struct RemovalReport {
    baseline: ConsciousnessMetrics,
    single_removals: [RemovalResult],
    combined_removals: [CombinedRemovalResult],
    phase_transition_detected: bool,
    extinction_point: string,
    necessary_components: [string],
    sufficient_components: [string],
    critical_pairs: [[string]]
}

// PSI constants (from consciousness_laws.json)
const PSI_COUPLING: f64 = 0.01532   // ln(2) / 2^5.5
const PSI_ALPHA: f64 = 0.014
const PSI_BALANCE: f64 = 0.5

// Simplified consciousness engine with toggleable components
struct SimplifiedEngine {
    n_cells: i32,
    hidden_dim: i32,
    n_factions: i32,
    h: [[f64]],            // hidden states (n_cells x hidden_dim)
    coupling: [[f64]],     // coupling matrix (n_cells x n_cells)
    faction_ids: [i32],    // faction assignment per cell
    identity: [[f64]],     // identity vectors (n_cells x hidden_dim)
    lorenz_state: [f64],   // (x, y, z)
    phi_floor: f64,
    step_count: i32,
    consensus_events: i32,
    disabled: [string]
}

fn create_engine(n_cells: i32, hidden_dim: i32, disabled: [string]) -> SimplifiedEngine {
    // TODO[numpy]: initialize all weight matrices and states
