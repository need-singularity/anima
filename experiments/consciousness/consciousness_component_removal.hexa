// ── Experiment class ──

fn run_full_experiment(n_cells: i32, steps: i32, repeats: i32) -> RemovalReport {
    // 1. Baseline (all enabled)
    // 2. Single removals (9 components)
    // 3. Combinatorial removals (36 pairs)
    // 4. Phase transition analysis
    return RemovalReport {
        baseline: ConsciousnessMetrics {
            phi_mi: 0.0, entropy: 0.0, stability: 0.0,
            faction_diversity: 0.0, mean_activation: 0.0,
            spontaneous_events: 0, phi_trace: []
        },
        single_removals: [],
        combined_removals: [],
        phase_transition_detected: false,
        extinction_point: "",
        necessary_components: [],
        sufficient_components: [],
        critical_pairs: []
    }
}

fn is_alive(metrics: ConsciousnessMetrics, baseline: ConsciousnessMetrics) -> bool {
    // Alive if Phi > 30% baseline AND entropy > 20% baseline AND stability > 0.1
    let phi_ratio = metrics.phi_mi / (baseline.phi_mi + 1e-10)
    let ent_ratio = metrics.entropy / (baseline.entropy + 1e-10)
    phi_ratio > 0.30 && ent_ratio > 0.20 && metrics.stability > 0.1
}

