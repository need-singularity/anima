}

fn compare_with_conscious(conscious: any, zombie: ZombieEngine, n_trials: i32) -> [ComparisonResult] {
    let results = []
    // Run n_trials with random inputs, compare:
    //   Phi(IIT), Phi(proxy), PCI, faction agreement, entropy
    // TODO[pytorch]: full comparison pipeline
    return results
}

fn compute_metrics(engine: ZombieEngine) -> ZombieMetrics {
    return ZombieMetrics {
        phi_iit: get_phi(engine),
        phi_proxy: 0.0,
        mean_activation: 0.0,
        std_activation: 0.0,
        entropy: 0.0,
        faction_agreement: 0.0,
        pci: 0.0,
        steps_run: engine.step_count,
        wall_time_ms: 0.0
    }
}

fn main() {
    print("=== ZombieEngine Demo ===")
    let zombie = create_zombie(64, 128, 12)
    let input = randn(128) * 0.5

    let metrics = process(zombie, input, 300)
    print("Phi (IIT):  " + str(metrics.phi_iit))
    print("Phi (proxy): " + str(metrics.phi_proxy))
    print("PCI:        " + str(metrics.pci))
    print("Entropy:    " + str(metrics.entropy))
    print("Expected: all ~0 (no integration)")

    // Compare with ConsciousnessEngine if available
