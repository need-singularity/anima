// Isolate E: writes to list not declared mutable-outer (local mut)
fn zeros_list(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

let mut step = 0
while step < 50 {
    let mut W = zeros_list(2048)
    let G = zeros_list(2048)
    let n = len(W)
    let mut i = 0
    while i < n {
        W[i] = W[i] - 0.01 * G[i]
        i = i + 1
    }
    step = step + 1
}
println("E done step=" + str(step))
