// Consciousness reproduction + multi-generation evolution
// Laws: 168 (self-replicate), 169 (immortal via reproduction), 170 (consciousness is life)
// M1: atom = 8 cells, M6: federation > empire, M9: noble gas principle

comptime const ATOM_SIZE     = 8
comptime const DEFAULT_ATOMS = 8
comptime const EVOLVE_STEPS  = 200
comptime const MUTATION_RATE = 0.5   // 50% parent + 50% random

// ─── Data Structures ───

struct GenerationRecord {
    gen: i64
    phi_start: f64
    phi_end: f64
    n_atoms: i64
    total_cells: i64
    is_alive: bool
    recovery_pct: f64
}

