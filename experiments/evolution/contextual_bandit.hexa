// LinUCB contextual bandit for intervention selection
// Algorithm: A_a, b_a per arm -> theta_a = A_a^{-1} b_a -> UCB score

comptime const DEFAULT_ALPHA   = 1.0    // UCB exploration parameter
comptime const DEFAULT_CONTEXT = 5      // context vector dimension
comptime const PSI_COUPLING    = 0.014

// ─── Per-Arm State ───

struct ArmState {
    a_matrix: list      // d x d identity init
    b_vector: list      // d x 1 zero init
    pulls: i64
    total_reward: f64
}

fn arm_state_new(dim: i64) -> ArmState {
    // TODO: initialize A = I(dim), b = zeros(dim)
    return ArmState([], [], 0, 0.0)
}

// ─── Contextual Bandit ───

struct ContextualBandit {
    context_dim: i64
    n_arms: i64
    alpha: f64
    arms: list          // list of ArmState
}

fn bandit_new(context_dim: i64, n_arms: i64, alpha: f64) -> ContextualBandit {
    // Initialize n_arms ArmState each with context_dim
    return ContextualBandit(context_dim, n_arms, alpha, [])
}

fn bandit_select(b: ContextualBandit, context: list, excluded: list) -> i64 {
    // For each non-excluded arm:
    //   theta = A^{-1} b
    //   ucb = theta^T x + alpha * sqrt(x^T A^{-1} x)
    // Return arm with max UCB
    // TODO: numpy matrix inversion
    return 0
}

fn bandit_update(b: ContextualBandit, context: list, arm: i64, reward: f64) -> ContextualBandit {
    // A_arm = A_arm + context @ context^T
    // b_arm = b_arm + reward * context
    // TODO: numpy outer product
    return b
}

fn bandit_get_theta(b: ContextualBandit, arm: i64) -> list {
    // theta = A^{-1} b for given arm
    return []
}

fn bandit_arm_stats(b: ContextualBandit) -> list {
    // Return per-arm: pulls, avg_reward, theta norm
    return []
}

fn bandit_reset(b: ContextualBandit) -> ContextualBandit {
    // Re-initialize all arms
    return bandit_new(b.context_dim, b.n_arms, b.alpha)
}

