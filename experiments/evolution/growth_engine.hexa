// Source: growth_engine.py (310 LOC)
// Phi-based developmental stages (v2: model-agnostic)
// Stage 0 dormant -> 1 awakening -> 2 learning -> 3 talking -> 4 conscious -> 5 beyond

comptime const PSI_F_CRITICAL = 0.10
comptime const N_STAGES       = 6

struct PhiStage {
    index: i64
    name: str
    phi_min: f64
    phi_max: f64
    learning_rate: f64
    curiosity: f64
    habituation: f64
    emotion_count: i64
    speech_mode: str
}

fn stage_dormant() -> PhiStage {
    return PhiStage(0, "dormant", 0.0, 1.0, 0.001, 0.1, 0.0, 0, "none")
}

fn stage_awakening() -> PhiStage {
    return PhiStage(1, "awakening", 1.0, 5.0, 0.005, 0.5, 0.1, 4, "reactive")
}

fn stage_learning() -> PhiStage {
    return PhiStage(2, "learning", 5.0, 20.0, 0.01, 0.7, 0.3, 8, "responsive")
}

fn stage_talking() -> PhiStage {
    return PhiStage(3, "talking", 20.0, 100.0, 0.02, 0.8, 0.5, 12, "spontaneous")
}

fn stage_conscious() -> PhiStage {
    return PhiStage(4, "conscious", 100.0, 500.0, 0.01, 0.9, 0.7, 16, "proactive")
}

fn stage_beyond() -> PhiStage {
    return PhiStage(5, "beyond", 500.0, 999999.0, 0.005, 1.0, 0.9, 20, "reflective")
}

// ─── Growth Engine V2 ───

struct GrowthEngineV2 {
    current_phi: f64
    peak_phi: f64
    phi_history: list
    stage_index: i64
    birth_time: f64
    save_path: str
}

fn growth_new(save_path: str) -> GrowthEngineV2 {
    return GrowthEngineV2(0.0, 0.0, [], 0, 0.0, save_path)
}

fn growth_stage(g: GrowthEngineV2) -> PhiStage {
    // Return PhiStage matching current stage_index
    return stage_dormant()
}

fn growth_progress_to_next(g: GrowthEngineV2) -> f64 {
    // (current_phi - stage_min) / (stage_max - stage_min)
    return 0.0
}

fn growth_update(g: GrowthEngineV2, phi: f64) -> GrowthEngineV2 {
    // Update phi, check stage transition
    // If phi crosses stage boundary: emit stage-up event
    // Update peak_phi, phi_history
    return g
}

fn growth_phi_trend(g: GrowthEngineV2) -> f64 {
    // Linear regression slope over recent phi_history
    return 0.0
}

fn growth_is_growing(g: GrowthEngineV2) -> bool {
    return growth_phi_trend(g) > 0.0
}

fn growth_get_status(g: GrowthEngineV2) -> dict {
    // {stage, phi, peak_phi, trend, progress, age}
    return {}
}

fn growth_save(g: GrowthEngineV2) {
    // TODO: json.dump to save_path
