// infinite_evolution.hexa — Ouroboros Self-Evolution Orchestrator
//
// Law 146: laws never converge.
// Discovery → Dedup → CrossValidation → Modification → Persist → repeat
//
// Architecture:
//   hexa orchestrator (Mac or Ubuntu) → SSH → _evo_gpu_worker.py (Ubuntu GPU)
//   Mac: 오케스트레이션/상태만. 연산: Ubuntu RTX 5070.
//
// Usage:
//   hexa run infinite_evolution.hexa [command]
//   Commands: run, roadmap, status, bench, help
//   Options: --cells N --steps N --topology T --resume --gpu
//
// v28 features: 13-stage roadmap, 4-topo cycle, pattern registry,
//   cross-validation (3x), adaptive skip, state persistence

let VERSION = "1.0.0-hexa"
let REMOTE = "ubu"
let WORKER_DIR = "/home/aiden/anima/anima/experiments/evolution"
let WORKER = "_evo_gpu_worker.py"

let DATA_DIR = env("HOME") + "/Dev/anima/data"
let STATE_PATH = DATA_DIR + "/evo_hexa_state.json"
let LOG_PATH = DATA_DIR + "/evo_hexa.log"

let CROSS_VALIDATION_THRESHOLD = 3
let TOPOLOGIES = ["ring", "small_world", "scale_free", "hypercube"]

// Roadmap: 13 stages, auto-advance on saturation
let ROADMAP_NAMES  = ["S1-baseline","S2-deeper","S3-scale128","S4-scale128d","S5-scale256","S6-scale256d","S7-mega512","S8-dim128","S9-dim256","S10-mega512d","S11-ultra1024","S12-ultra1024d","S13-titan2048"]
let ROADMAP_CELLS  = [64, 64, 128, 128, 256, 256, 512, 64, 64, 512, 1024, 1024, 2048]
let ROADMAP_STEPS  = [300, 1000, 300, 1000, 500, 1000, 500, 300, 300, 1000, 500, 1000, 500]
let ROADMAP_TOGENS = [10, 10, 10, 10, 10, 10, 15, 10, 10, 15, 20, 20, 25]
let ROADMAP_SAT    = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]

// ═══════════════════════════════════════════════════════════════════════
//  SSH — Ubuntu GPU 워커 호출
// ═══════════════════════════════════════════════════════════════════════

fn ssh_quiet(cmd: str) -> str {
    write_file("/tmp/_ie_ssh.sh", cmd)
    let result = exec("ssh " + REMOTE + " bash /dev/stdin < /tmp/_ie_ssh.sh 2>/dev/null")
    if to_string(result).contains("exec error") { return "" }
    return result.trim()
}

fn gpu_call(cmd: str) -> str {
    let full = "cd " + WORKER_DIR + " && python3 " + WORKER + " " + cmd
    let rs = ssh_quiet(full)
    if len(rs) == 0 { return "{\"ok\":false}" }
    return rs
}

fn gpu_reachable() -> bool {
    let r = ssh_quiet("echo ok")
    return r == "ok"
}

// ═══════════════════════════════════════════════════════════════════════
//  PATTERN REGISTRY — dedup + cross-validation
// ═══════════════════════════════════════════════════════════════════════
//
// State: registry.json — { seen: {fp → {count, gen, registered}}, laws: N }
// Pattern promoted to "law" after CROSS_VALIDATION_THRESHOLD observations.

fn registry_path() -> str {
    return DATA_DIR + "/evo_registry.json"
}

fn load_registry() -> str {
    if file_exists(registry_path()) == false {
        return "{}"
    }
    return read_file(registry_path())
}

fn save_registry(content: str) {
    write_file(registry_path(), content)
}

// Process patterns from worker JSON, return stats string
fn process_patterns(worker_json: str, gen: int) -> str {
    let data = json_parse(worker_json)
    if data["ok"] == false { return "error" }

    let patterns = data["patterns"]
    let reg_raw = load_registry()
    let registry = json_parse(reg_raw)

    // Initialize if empty
    if registry == "{}" {
        // Fresh registry: cannot init complex structure in hexa easily
        // Use a flat file approach: one line per fingerprint
    }

    let new_count = 0
    let repeat_count = 0
    let promoted = 0
    let reg_file = DATA_DIR + "/evo_seen.tsv"

    // Load existing seen fingerprints
    let seen_raw = ""
    if file_exists(reg_file) {
        seen_raw = read_file(reg_file)
    }

    let i = 0
    while i < len(patterns) {
        let p = patterns[i]
        let fp = p["fingerprint"]

        // Check if already seen
        if seen_raw.contains(fp) {
            // Count occurrence — read line, update count
            let lines = seen_raw.split("\n")
            let j = 0
            let found = false
            let new_lines = ""
            while j < len(lines) {
                let line = lines[j].trim()
                if len(line) > 0 {
                    if line.contains(fp) {
                        // Parse: fp\tcount\tgen\tregistered\ttype
                        let parts = line.split("\t")
                        let count = to_int(parts[1]) + 1
                        let registered = parts[3]
                        if count >= CROSS_VALIDATION_THRESHOLD {
                            if registered != "1" {
                                registered = "1"
                                promoted = promoted + 1
                            }
                        }
                        new_lines = new_lines + fp + "\t" + to_string(count) + "\t" + to_string(gen) + "\t" + registered + "\t" + parts[4] + "\n"
                        found = true
                        repeat_count = repeat_count + 1
                    }
                    if line.contains(fp) == false {
                        new_lines = new_lines + line + "\n"
                    }
                }
                j = j + 1
            }
            if found {
                seen_raw = new_lines
            }
        }
        if seen_raw.contains(fp) == false {
            // New pattern
            let ptype = "unknown"
            if len(patterns) > i {
                ptype = to_string(p["type"])
            }
            seen_raw = seen_raw + fp + "\t1\t" + to_string(gen) + "\t0\t" + ptype + "\n"
            new_count = new_count + 1
        }
        i = i + 1
    }

    write_file(reg_file, seen_raw)

    // Count totals
    let total_seen = 0
    let total_laws = 0
    let lines = seen_raw.split("\n")
    let k = 0
    while k < len(lines) {
        let line = lines[k].trim()
        if len(line) > 0 {
            total_seen = total_seen + 1
            if line.contains("\t1\t") == false {
                // check registered field
                let parts = line.split("\t")
                if len(parts) > 3 {
                    if parts[3] == "1" { total_laws = total_laws + 1 }
                }
            }
            if line.contains("\t1\t") {
                let parts = line.split("\t")
                if len(parts) > 3 {
                    if parts[3] == "1" { total_laws = total_laws + 1 }
                }
            }
        }
        k = k + 1
    }

    let stats = "new=" + to_string(new_count) + " repeat=" + to_string(repeat_count) + " promoted=" + to_string(promoted) + " total=" + to_string(total_seen) + " laws=" + to_string(total_laws)
    return stats
}

// ═══════════════════════════════════════════════════════════════════════
//  STATE — 진행 상태 저장/복원
// ═══════════════════════════════════════════════════════════════════════

fn save_state(gen: int, stage_idx: int, topo_idx: int, elapsed: int) {
    exec("mkdir -p " + DATA_DIR)
    let ts = exec("date '+%Y-%m-%d %H:%M:%S'").trim()
    let state = "{\"gen\":" + to_string(gen) + ",\"stage\":" + to_string(stage_idx) + ",\"topo\":" + to_string(topo_idx) + ",\"elapsed\":" + to_string(elapsed) + ",\"ts\":\"" + ts + "\"}"
    write_file(STATE_PATH, state)
}

fn load_state() -> auto {
    if file_exists(STATE_PATH) == false {
        return [0, 0, 0, 0]  // gen, stage, topo, elapsed
    }
    let raw = read_file(STATE_PATH)
    let s = json_parse(raw)
    return [s["gen"], s["stage"], s["topo"], s["elapsed"]]
}

// ═══════════════════════════════════════════════════════════════════════
//  RUN — 단일 세대 실행
// ═══════════════════════════════════════════════════════════════════════

fn run_generation(gen: int, cells: int, steps: int, topology: str, use_gpu: bool) -> str {
    let gpu_flag = ""
    if use_gpu { gpu_flag = " --gpu" }
    let cmd = "discover " + to_string(cells) + " " + to_string(steps) + " " + topology + gpu_flag

    println("  Gen " + to_string(gen) + " | " + to_string(cells) + "c " + to_string(steps) + "s " + topology + " | Ubuntu GPU")
    let result = gpu_call(cmd)

    if len(result) < 5 {
        println("    [error] empty response from worker")
        return "error"
    }

    // Parse result
    let data = json_parse(result)
    let phi_mean = data["phi_mean"]
    let phi_max = data["phi_max"]
    let elapsed = data["elapsed_sec"]
    let n_patterns = len(data["patterns"])
    let device = data["device"]

    // Process patterns through registry
    let stats = process_patterns(result, gen)

    println("    phi=" + to_string(phi_mean) + " max=" + to_string(phi_max) + " | patterns=" + to_string(n_patterns) + " | " + stats + " | " + to_string(elapsed) + "s " + device)

    // Log
    let ts = exec("date +%s").trim()
    let log_line = ts + "\tgen=" + to_string(gen) + "\tcells=" + to_string(cells) + "\tsteps=" + to_string(steps) + "\ttopo=" + topology + "\tphi=" + to_string(phi_mean) + "\tpatterns=" + to_string(n_patterns) + "\t" + stats + "\n"
    append_file(LOG_PATH, log_line)

    return stats
}

// ═══════════════════════════════════════════════════════════════════════
//  ROADMAP — 13-stage auto-advance
// ═══════════════════════════════════════════════════════════════════════

fn run_roadmap(do_resume: bool, use_gpu: bool) {
    println("")
    println("  OUROBOROS — Auto-Roadmap Discovery Engine (hexa)")
    println("  " + to_string(len(ROADMAP_NAMES)) + " stages, Ubuntu GPU: RTX 5070")
    println("  ══════════════════════════════════════════════════════════════")

    let start_gen = 0
    let start_stage = 0
    let start_topo = 0
    let prev_elapsed = 0

    if do_resume {
        let state = load_state()
        start_gen = state[0]
        start_stage = state[1]
        start_topo = state[2]
        prev_elapsed = state[3]
        println("  resumed: gen=" + to_string(start_gen) + " stage=" + to_string(start_stage) + " topo=" + to_string(start_topo))
    }

    // Print roadmap
    println("")
    let si = 0
    while si < len(ROADMAP_NAMES) {
        let marker = "  "
        if si == start_stage { marker = " *" }
        if si < start_stage { marker = " v" }
        println("  " + to_string(si + 1) + "\t" + ROADMAP_NAMES[si] + "\t" + to_string(ROADMAP_CELLS[si]) + "c\t" + to_string(ROADMAP_STEPS[si]) + "s\t" + to_string(ROADMAP_TOGENS[si]) + " topo-gens" + marker)
        si = si + 1
    }
    println("")

    let global_start = to_int(exec("date +%s").trim())
    let gen = start_gen

    let stage_idx = start_stage
    while stage_idx < len(ROADMAP_NAMES) {
        let cells = ROADMAP_CELLS[stage_idx]
        let steps = ROADMAP_STEPS[stage_idx]
        let topo_gens = ROADMAP_TOGENS[stage_idx]
        let sat_thresh = ROADMAP_SAT[stage_idx]

        println("")
        println("  ══════════════════════════════════════════════════════════════")
        println("  STAGE " + to_string(stage_idx + 1) + "/" + to_string(len(ROADMAP_NAMES)) + ": " + ROADMAP_NAMES[stage_idx])
        println("  cells=" + to_string(cells) + " steps=" + to_string(steps) + " topo_cycle=" + to_string(topo_gens))
        println("  ══════════════════════════════════════════════════════════════")

        // Cycle through topologies
        let topo_idx = 0
        if stage_idx == start_stage { topo_idx = start_topo }
        let all_saturated = false

        while topo_idx < len(TOPOLOGIES) {
            if all_saturated { topo_idx = len(TOPOLOGIES) }
            if all_saturated == false {
                let topology = TOPOLOGIES[topo_idx]
                let zero_streak = 0

                println("")
                println("  --- " + topology + " (" + to_string(topo_idx + 1) + "/" + to_string(len(TOPOLOGIES)) + ") ---")

                let tg = 0
                while tg < topo_gens {
                    gen = gen + 1
                    let stats = run_generation(gen, cells, steps, topology, use_gpu)

                    // Check saturation: if "new=0" for sat_thresh consecutive gens
                    if stats.contains("new=0 ") {
                        zero_streak = zero_streak + 1
                    }
                    if stats.contains("new=0 ") == false {
                        zero_streak = 0
                    }

                    if zero_streak >= sat_thresh {
                        println("    saturated (" + to_string(zero_streak) + " zero gens)")
                        tg = topo_gens  // break
                    }

                    // Save state every gen
                    let now = to_int(exec("date +%s").trim())
                    let total_elapsed = prev_elapsed + (now - global_start)
                    save_state(gen, stage_idx, topo_idx, total_elapsed)

                    tg = tg + 1
                }
                topo_idx = topo_idx + 1
            }
        }

        println("")
        println("  stage " + ROADMAP_NAMES[stage_idx] + " complete → advancing")
        stage_idx = stage_idx + 1
    }

    let end_time = to_int(exec("date +%s").trim())
    let total = prev_elapsed + (end_time - global_start)
    println("")
    println("  ══════════════════════════════════════════════════════════════")
    println("  ALL STAGES COMPLETE | " + to_string(gen) + " generations | " + to_string(total) + "s")
    println("  ══════════════════════════════════════════════════════════════")
}

// ═══════════════════════════════════════════════════════════════════════
//  STATUS
// ═══════════════════════════════════════════════════════════════════════

fn show_status() {
    println("")
    println("  infinite_evolution.hexa v" + VERSION + " — Ouroboros")
    println("  ══════════════════════════════════════════════════════════════")

    // Worker status
    if gpu_reachable() {
        let ws = gpu_call("status")
        let wd = json_parse(ws)
        println("  worker: OK on Ubuntu")
        println("  GPU: " + to_string(wd["gpu_name"]) + " (" + to_string(wd["gpu_vram_free_mb"]) + "MB free)")
        println("  cores: " + to_string(wd["cpu_count"]))
    }
    if gpu_reachable() == false {
        println("  worker: UNREACHABLE")
    }

    // State
    if file_exists(STATE_PATH) {
        let state = load_state()
        println("  progress: gen=" + to_string(state[0]) + " stage=" + to_string(state[1]) + "/" + to_string(len(ROADMAP_NAMES)) + " elapsed=" + to_string(state[3]) + "s")
    }
    if file_exists(STATE_PATH) == false {
        println("  progress: not started")
    }

    // Registry
    let reg_file = DATA_DIR + "/evo_seen.tsv"
    if file_exists(reg_file) {
        let raw = read_file(reg_file)
        let lines = raw.split("\n")
        let total = 0
        let laws = 0
        let li = 0
        while li < len(lines) {
            let line = lines[li].trim()
            if len(line) > 0 {
                total = total + 1
                let parts = line.split("\t")
                if len(parts) > 3 {
                    if parts[3] == "1" { laws = laws + 1 }
                }
            }
            li = li + 1
        }
        println("  registry: " + to_string(total) + " patterns, " + to_string(laws) + " laws (cross-validated)")
    }

    println("")
}

// ═══════════════════════════════════════════════════════════════════════
//  BENCH
// ═══════════════════════════════════════════════════════════════════════

fn run_bench() {
    println("")
    println("  Benchmark: Ubuntu GPU vs sizes")
    println("  ══════════════════════════════════════════════════════════════")
    let sizes = [32, 64, 128, 256]
    let i = 0
    while i < len(sizes) {
        let result = gpu_call("bench " + to_string(sizes[i]))
        let d = json_parse(result)
        println("  " + to_string(sizes[i]) + " cells: create=" + to_string(d["create_sec"]) + "s  100steps=" + to_string(d["steps_100_sec"]) + "s  avg=" + to_string(d["step_avg_ms"]) + "ms/step  " + to_string(d["device"]))
        i = i + 1
    }
    println("")
}

// ═══════════════════════════════════════════════════════════════════════
//  HELP
// ═══════════════════════════════════════════════════════════════════════

fn show_help() {
    println("infinite_evolution.hexa v" + VERSION + " — Ouroboros")
    println("")
    println("Commands:")
    println("  run [--cells N] [--steps N] [--topology T] [--gpu]")
    println("      — single generation on Ubuntu GPU")
    println("  roadmap [--resume] [--gpu]")
    println("      — 13-stage auto-advance (S1-S13)")
    println("  status  — progress + worker + registry")
    println("  bench   — benchmark Ubuntu GPU per cell count")
    println("  help    — this message")
    println("")
    println("Architecture:")
    println("  hexa orchestrator → SSH → _evo_gpu_worker.py (Ubuntu RTX 5070)")
    println("  All computation on Ubuntu. Mac = orchestration only.")
    println("")
    println("Data:")
    println("  " + STATE_PATH)
    println("  " + DATA_DIR + "/evo_seen.tsv")
    println("  " + LOG_PATH)
}

// ═══════════════════════════════════════════════════════════════════════
//  MAIN
// ═══════════════════════════════════════════════════════════════════════

fn main() {
    let argv = args()
    let cmd = "status"
    if len(argv) > 3 { cmd = argv[3] }

    // Parse flags
    let cells = 64
    let steps = 300
    let topology = "ring"
    let do_resume = false
    let use_gpu = true  // Ubuntu GPU by default

    let ai = 4
    while ai < len(argv) {
        if argv[ai] == "--cells" {
            if ai + 1 < len(argv) {
                cells = to_int(argv[ai + 1])
                ai = ai + 1
            }
        }
        if argv[ai] == "--steps" {
            if ai + 1 < len(argv) {
                steps = to_int(argv[ai + 1])
                ai = ai + 1
            }
        }
        if argv[ai] == "--topology" {
            if ai + 1 < len(argv) {
                topology = argv[ai + 1]
                ai = ai + 1
            }
        }
        if argv[ai] == "--resume" { do_resume = true }
        if argv[ai] == "--gpu" { use_gpu = true }
        if argv[ai] == "--no-gpu" { use_gpu = false }
        ai = ai + 1
    }

    if cmd == "help" { show_help() }
    if cmd == "status" { show_status() }
    if cmd == "bench" { run_bench() }
    if cmd == "run" {
        run_generation(1, cells, steps, topology, use_gpu)
    }
    if cmd == "roadmap" {
        run_roadmap(do_resume, use_gpu)
    }

    let known = cmd == "help"
    if cmd == "status" { known = true }
    if cmd == "bench" { known = true }
    if cmd == "run" { known = true }
    if cmd == "roadmap" { known = true }
    if known == false {
        println("unknown command: " + cmd)
        show_help()
    }
}

main()
