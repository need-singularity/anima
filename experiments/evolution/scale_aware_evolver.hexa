// Auto-selects strategy per cell count based on multi-scale results
// Tiny(2-8): thompson, Small(9-24): thompson+diversity
// Medium(25-64): correlation, Large(65-256): epsilon_greedy
// Law 213: SOC anti-correlated with Phi -> blacklisted at large scale

comptime const PSI_BALANCE  = 0.5
comptime const PSI_COUPLING = 0.014

struct ScaleProfile {
    name: str           // tiny | small | medium | large
    min_cells: i64
    max_cells: i64
    strategy: str       // thompson | correlation | epsilon_greedy
    blacklist: list     // intervention names to skip
}

fn profile_tiny() -> ScaleProfile {
    return ScaleProfile("tiny", 2, 8, "thompson", [])
}

fn profile_small() -> ScaleProfile {
    return ScaleProfile("small", 9, 24, "thompson", [])
}

fn profile_medium() -> ScaleProfile {
    return ScaleProfile("medium", 25, 64, "correlation", [])
}

fn profile_large() -> ScaleProfile {
    return ScaleProfile("large", 65, 256, "epsilon_greedy", ["soc_free_will"])
}

struct ScaleReport {
    scale: i64
    strategy: str
    phi_before: f64
    phi_after: f64
    laws_found: i64
    cycles: i64
    profile: str
}

struct ScaleAwareEvolver {
    max_cells: i64
    steps: i64
    repeats: i64
    current_profile: str
}

fn sae_new(max_cells: i64, steps: i64, repeats: i64) -> ScaleAwareEvolver {
    return ScaleAwareEvolver(max_cells, steps, repeats, "")
}

fn sae_detect_profile(sae: ScaleAwareEvolver, n: i64) -> ScaleProfile {
    // Match cell count to profile
    return profile_medium()
}

