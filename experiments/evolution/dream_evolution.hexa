fn entropy(p: f64) -> f64 {
    // H(p) = -p*ln(p) - (1-p)*ln(1-p)
    // Returns 0.0 for p <= 0 or p >= 1
    return 0.0
}

struct DreamEvolution {
    n_rules: i64
    population_size: i64
    population: list        // list of rule sets (list of f64)
