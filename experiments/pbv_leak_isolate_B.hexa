// Isolate B: only W reassignment (no push)
fn zeros_list(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}
fn sgd_copy(w: [float], g: [float], lr: float) -> [float] {
    let n = len(w)
    let mut out = zeros_list(n)
    let mut i = 0
    while i < n { out[i] = w[i] - lr * g[i]; i = i + 1 }
    return out
}

let mut W = zeros_list(2048)
let mut G = zeros_list(2048)
let mut step = 0
while step < 50 {
    W = sgd_copy(W, G, 0.01)
    step = step + 1
}
println("B done step=" + str(step) + " len_W=" + str(len(W)))
