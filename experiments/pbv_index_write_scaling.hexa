// Does per-element index write w[i] = x leak O(N²) or is it O(1)?
// Build list via .push (proven O(N)) then measure index-writes only.

fn build_push(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

// 50 steps of full-list rewrite
let mut W = build_push(2048)
let mut step = 0
while step < 50 {
    let mut i = 0
    while i < 2048 {
        W[i] = 1.0
        i = i + 1
    }
    step = step + 1
}
println("done steps=" + str(step) + " len=" + str(len(W)))
