// experiments/experiments.hexa — Acceleration & discovery experiments stub
// Source: experiments/ (80 .py files)
// Phase 5: structural port.
//
// Experiment series:
//   acceleration_b*.py   (12) — Batch, Skip, Tension, Manifold, Topology
//   acceleration_c*.py   (4)  — Compiler, Entropy, Gradient orthogonality
//   acceleration_d*.py   (3)  — Detour, Closed pipe
//   acceleration_e*.py   (5)  — Dual gradient, Series
//   acceleration_f*.py   (2)  — F series
//   acceleration_consciousness_*.py (3) — Big bang, Fusion, Supernova
//   dd*_closed_loop_verify.py (5)  — Closed-loop law verification
//   discover_laws_*.py   (8)  — Law discovery waves
//   closed_loop_*.py     (4)  — Closed-loop evolution
//   experiment_*.py      (15) — Fundamental question experiments
//   Other                (19) — Misc experiments

struct ExperimentRun {
    id: string,
    series: string,
    phi_before: float,
    phi_after: float,
    speedup: float,
    phi_retention: float,    // 0.0-1.0
    laws_found: int
}

pure fn experiment_passed(e: ExperimentRun) -> bool {
    e.phi_retention > 0.80
}

// --- Key results (from acceleration_hypotheses.json) ---
// B11+B12 Batch+Skip:  x179, Φ 97%
// C3 ∇H ⊥ ∇CE:        Φ+71.5%
// D1 Detour 54x:       x6 jump, Φ 98%
// B13 Tension catalyst: 139% teacher exceed
// C1 Compiler:          Φ+87% one-time

// TODO: port each experiment_*.py to hexa test harness
fn run_experiment(id: string) -> ExperimentRun {
    ExperimentRun { id: id, series: "", phi_before: 0.0, phi_after: 0.0, speedup: 0.0, phi_retention: 0.0, laws_found: 0 }
}

fn list_experiments() {
    println("=== Experiments (80 scripts) ===")
    println("  acceleration_b: 12 files (batch, skip, tension, manifold)")
    println("  acceleration_c: 4  files (compiler, entropy)")
    println("  acceleration_d: 3  files (detour)")
    println("  acceleration_e: 5  files (dual gradient)")
    println("  acceleration_f: 2  files (f series)")
    println("  consciousness:  3  files (big bang, fusion, supernova)")
    println("  dd_verify:      5  files (closed-loop verification)")
    println("  discover_laws:  8  files (discovery waves)")
    println("  closed_loop:    4  files (evolution)")
    println("  fundamental:    15 files (question experiments)")
    println("  misc:           19 files")
}

// --- CLI ---
let args = args()
if args.len() < 3 {
    println("experiments/experiments.hexa — experiment suite")
    println("  hexa experiments/experiments.hexa list")
    println("  hexa experiments/experiments.hexa run <id>")
} else {
    let cmd = args[2]
    if cmd == "list" { list_experiments() }
    else { println("TODO: run experiment", cmd) }
}
