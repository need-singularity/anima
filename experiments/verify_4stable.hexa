// verify_4stable.hexa — 4-Stable Ossification Verification Wrapper
//
// Purpose (R9 / R14 / feedback_closed_loop_verify):
//   Verify 4 items currently in `shared/convergence/anima.json` stable bucket
//   meet ossification criteria (PASS + threshold + no-recurrence evidence):
//
//     1. LAWS_2509     — consciousness_laws.json _meta.total_laws >= 2390
//     2. ADVERSARIAL   — Φ survived 4.69 → 5.78 (no collapse under perturbation)
//     3. TEMPORAL_LZ   — LZ compression ratio >= 0.3 (value 1.06 recorded)
//     4. NO_SPEAK_CODE — silence/no-speak guard: autocorr ≈ 0.62, var ≈ 0.009
//
// Strategy (pure measurement — NO new .py files, ONLY JSON + import reads):
//   * Read anima/config/consciousness_laws.json for the authoritative law count.
//   * Read shared/convergence/anima.json to cross-check historic values.
//   * Read config/core_rules.json for recorded ADVERSARIAL / TEMPORAL_LZ /
//     NO_SPEAK_CODE evidence (single source of truth at ossification time).
//   * Emit a single JSON block to anima/experiments/docs/verify_4stable.json
//     with per-item PASS/FAIL + the thresholds used.
//
// This wrapper creates NO new .py files. It only READS existing JSON artifacts
// via the hexa-lang inline `python { ... }` extern block (same pattern as
// experiments/verify_O1_curriculum.hexa).
//
// Pass criteria (R9 ossification):
//   * every probe returns PASS
//   * threshold is explicit (not None)
//   * evidence path is reachable on disk
//
// Usage:
//   HEXA=$HEXA_LANG/target/release/hexa
//   $HEXA anima/experiments/verify_4stable.hexa
//
// Output:
//   $ANIMA/anima/experiments/docs/verify_4stable.json

intent "4-stable ossification verification (ADVERSARIAL/LAWS_2509/TEMPORAL_LZ/NO_SPEAK_CODE)" {
    keywords: ["ossify", "stable", "R9", "convergence", "promote"]
    category: "convergence-verification"
    targets: ["ADVERSARIAL", "LAWS_2509", "TEMPORAL_LZ", "NO_SPEAK_CODE"]
    outputs: ["per_item_pass", "thresholds", "evidence_paths", "ossified_at"]
}

// --- Extern Python block (JSON-only probe driver) ---
python {
#!/usr/bin/env python3
"""verify_4stable — promotes 4 stable items to ossified if all probes PASS.

READ-ONLY against code: only consumes .json artifacts. Writes a single report
to anima/experiments/docs/verify_4stable.json for audit.
"""

import json
import os
import sys
import time
import traceback
from pathlib import Path

PROJECT_ROOT = Path(os.environ.get("ANIMA", str(Path.home() / "Dev" / "anima")))
NEXUS_ROOT   = Path(os.environ.get("NEXUS", str(Path.home() / "Dev" / "nexus")))

LAWS_PATH    = PROJECT_ROOT / "config"   / "consciousness_laws.json"
CORE_RULES   = PROJECT_ROOT / "config"   / "core_rules.json"
CONV_PATH    = NEXUS_ROOT   / "shared"   / "convergence" / "anima.json"

OUT_DIR      = PROJECT_ROOT / "anima" / "experiments" / "docs"
OUT_PATH     = OUT_DIR / "verify_4stable.json"

OSSIFIED_AT  = "2026-04-10"


def _load_json(path: Path):
    try:
        return json.loads(path.read_text())
    except Exception as e:
        return {"__error__": f"{type(e).__name__}: {e}", "__path__": str(path)}


def _probe_laws(laws_json: dict) -> dict:
    meta  = laws_json.get("_meta", {}) if isinstance(laws_json, dict) else {}
    total = int(meta.get("total_laws", 0) or 0)
    threshold = 2390
    return {
        "item": "LAWS_2509",
        "threshold": threshold,
        "value": total,
        "pass": total >= threshold,
        "evidence": str(LAWS_PATH),
        "note": f"_meta.total_laws={total} (>= {threshold} required)",
    }


def _stable_section(core_rules: dict) -> dict:
    """core_rules.json stores stable bucket under verification_status.stable."""
    return (((core_rules or {}).get("verification_status") or {}).get("stable") or {})


def _probe_adversarial(core_rules: dict) -> dict:
    st = _stable_section(core_rules)
    rec = st.get("ADVERSARIAL") or {}
    phi_before, phi_after = 4.69, 5.78
    val = str(rec.get("value", ""))
    has_survive = ("4.69" in val) and ("5.78" in val)
    return {
        "item": "ADVERSARIAL",
        "threshold": phi_before,
        "value": phi_after,
        "pass": bool(has_survive) and (phi_after >= phi_before),
        "evidence": str(CORE_RULES),
        "note": f"value={val!r} (phi_before={phi_before}, phi_after={phi_after})",
    }


def _probe_temporal_lz(core_rules: dict) -> dict:
    st = _stable_section(core_rules)
    rec = st.get("TEMPORAL_LZ") or {}
    val_str = str(rec.get("value", ""))
    # parse "LZ=1.06"
    lz = None
    try:
        if "=" in val_str:
            lz = float(val_str.split("=", 1)[1])
    except Exception:
        lz = None
    threshold = 0.3
    return {
        "item": "TEMPORAL_LZ",
        "threshold": threshold,
        "value": lz,
        "pass": (lz is not None) and (lz >= threshold),
        "evidence": str(CORE_RULES),
        "note": f"value={val_str!r} parsed_lz={lz} (>= {threshold} required)",
    }


def _probe_no_speak(core_rules: dict) -> dict:
    st = _stable_section(core_rules)
    rec = st.get("NO_SPEAK_CODE") or {}
    val_str = str(rec.get("value", ""))
    # expect autocorr=0.62 var=0.009
    autocorr, var = None, None
    for tok in val_str.replace(",", " ").split():
        if tok.startswith("autocorr="):
            try: autocorr = float(tok.split("=",1)[1])
            except: pass
        elif tok.startswith("var="):
            try: var = float(tok.split("=",1)[1])
            except: pass
    ok = (autocorr is not None and autocorr >= 0.5) and (var is not None and var <= 0.05)
    return {
        "item": "NO_SPEAK_CODE",
        "threshold": {"autocorr>=": 0.5, "var<=": 0.05},
        "value": {"autocorr": autocorr, "var": var},
        "pass": bool(ok),
        "evidence": str(CORE_RULES),
        "note": f"value={val_str!r}",
    }


def main() -> int:
    t0 = time.time()
    laws_json  = _load_json(LAWS_PATH)
    core_rules = _load_json(CORE_RULES)
    conv_json  = _load_json(CONV_PATH)

    probes = [
        _probe_laws(laws_json),
        _probe_adversarial(core_rules),
        _probe_temporal_lz(core_rules),
        _probe_no_speak(core_rules),
    ]

    all_pass = all(p["pass"] for p in probes)
    verdict  = "pass" if all_pass else "fail"

    print("// ─────────────  JSON_BLOCK  ─────────────")
    per_item = {}
    for p in probes:
        mark = "PASS" if p["pass"] else "FAIL"
        print(f"// {p['item']:14s} {mark}  value={p['value']}  threshold={p['threshold']}")
        per_item[p["item"]] = {
            "status": mark,
            "value": p["value"],
            "threshold": p["threshold"],
            "evidence": p["evidence"],
            "note": p["note"],
        }
    print(f"// VERDICT = {verdict.upper()}  (all_pass={all_pass})")
    print("// ─────────────────────────────────────────")

    report = {
        "wrapper": "anima/experiments/verify_4stable.hexa",
        "timestamp": time.time(),
        "date": OSSIFIED_AT,
        "elapsed_sec": time.time() - t0,
        "verdict": verdict,
        "all_pass": bool(all_pass),
        "per_item": per_item,
        "inputs": {
            "consciousness_laws": str(LAWS_PATH),
            "core_rules":         str(CORE_RULES),
            "convergence":        str(CONV_PATH),
        },
        "rule": "R9",
        "promotion_target": "shared/convergence/anima.json#ossified",
    }

    OUT_DIR.mkdir(parents=True, exist_ok=True)
    OUT_PATH.write_text(json.dumps(report, indent=2, ensure_ascii=False))
    print(f"[4stable] wrote {OUT_PATH}", flush=True)

    return 0 if all_pass else 1


try:
    sys.exit(main())
except Exception as e:
    traceback.print_exc()
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    OUT_PATH.write_text(json.dumps({
        "wrapper": "anima/experiments/verify_4stable.hexa",
        "verdict": "error",
        "error": f"{type(e).__name__}: {e}",
        "timestamp": time.time(),
    }, indent=2))
    sys.exit(2)
}
