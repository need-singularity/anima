// experiments/pbv_leak_repro.hexa — minimal PBV list-growth RSS test
//
// Task #24 repro: confirm stage0 interpreter PBV list-growth causes
// O(N²) RSS growth. We grow a "model state" list 250 times via
// whole-list reassignment (mirrors bench_train_step_flag_on.hexa driver
// pattern where STEP_MS/STEP_LOSS + model weights grow each step).
//
// Expected on buggy stage0: RSS climbs ~linearly per step, death near
// step 250-500.
// Expected after workaround: RSS flat.

fn zeros_list(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

fn sgd_copy(w: [float], g: [float], lr: float) -> [float] {
    let n = len(w)
    let mut out = zeros_list(n)
    let mut i = 0
    while i < n {
        out[i] = w[i] - lr * g[i]
        i = i + 1
    }
    return out
}

comptime const MODEL_N = 2048
comptime const STEPS   = 50

let mut W    = zeros_list(MODEL_N)
let mut G    = zeros_list(MODEL_N)
let mut MS   = []
let mut LOSS = []

let mut step = 0
while step < STEPS {
    W = sgd_copy(W, G, 0.01)
    MS = MS.push(1.0)
    LOSS = LOSS.push(2.0)
    if step % 10 == 0 {
        println("step=" + str(step) + " len_W=" + str(len(W)) + " len_MS=" + str(len(MS)))
    }
    step = step + 1
}
println("done step=" + str(step))
