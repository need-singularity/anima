fn calculate_discount(price, discount_percent) {
    if price < 0 { return "error: negative price" }
    if discount_percent < 0 { return "error: negative discount" }
    if discount_percent > 100 { return "error: discount exceeds 100%" }
    return price - (price * discount_percent / 100)
}

let pass = 0
let fail = 0

fn assert_eq(label, got, expected) {
    if got == expected {
        pass = pass + 1
    } else {
        print("[FAIL] " + label + " — got " + got.to_string() + ", expected " + expected.to_string())
        fail = fail + 1
    }
}

fn assert_str(label, got, expected) {
    if got == expected {
        pass = pass + 1
    } else {
        print("[FAIL] " + label + " — got " + got + ", expected " + expected)
        fail = fail + 1
    }
}

// --- normal operation ---
assert_eq("10% off 100",    calculate_discount(100, 10),  90)
assert_eq("50% off 200",    calculate_discount(200, 50),  100)
assert_eq("25% off 80",     calculate_discount(80,  25),  60)
assert_eq("20% off 50",     calculate_discount(50,  20),  40)
assert_eq("100% off 99",    calculate_discount(99,  100), 0)

// --- zero amount ---
assert_eq("0% discount",    calculate_discount(100, 0),   100)
assert_eq("price is 0",     calculate_discount(0,   50),  0)
assert_eq("both zero",      calculate_discount(0,   0),   0)
assert_eq("0% off 0",       calculate_discount(0,   0),   0)
assert_eq("100% off 0",     calculate_discount(0,   100), 0)

// --- small values ---
assert_eq("1% off 1",       calculate_discount(1,   1),   0.99)
assert_eq("small fraction", calculate_discount(3,   33),  2.01)
assert_eq("100% off 1",     calculate_discount(1,   100), 0)

// --- tier boundaries ---
assert_eq("boundary 0.01%",    calculate_discount(1000, 0.01),  999.9)
assert_eq("boundary 99.99%",   calculate_discount(1000, 99.99), 0.1)
assert_eq("boundary 50% even", calculate_discount(2,    50),    1)
assert_eq("boundary 50% odd",  calculate_discount(3,    50),    1.5)
assert_eq("boundary 0%",       calculate_discount(500,  0),     500)
assert_eq("boundary 100%",     calculate_discount(500,  100),   0)
assert_eq("large price",       calculate_discount(999999, 10),  899999.1)
assert_eq("tiny price",        calculate_discount(0.01, 50),    0.005)

// --- rounding ---
assert_eq("1/3 remainder",     calculate_discount(100, 33.33), 66.67)
assert_eq("repeating decimal",  calculate_discount(10,  33),    6.7)
assert_eq("7% off 9.99",       calculate_discount(9.99, 7),    9.2907)
assert_eq("penny rounding",    calculate_discount(0.01, 10),   0.009)
assert_eq("15% off 19.99",     calculate_discount(19.99, 15),  16.9915)
assert_eq("third off 1",       calculate_discount(1, 33.333333), 0.66666667)

// --- error handling ---
assert_str("negative price",     calculate_discount(-10, 10),  "error: negative price")
assert_str("negative discount",  calculate_discount(100, -5),  "error: negative discount")
assert_str("discount over 100",  calculate_discount(100, 150), "error: discount exceeds 100%")
assert_str("negative both",      calculate_discount(-1,  -1),  "error: negative price")

print("")
print("Results: " + pass.to_string() + " passed, " + fail.to_string() + " failed")
if fail == 0 { print("ALL PASS") }
