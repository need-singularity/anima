// scripts/preflight_check.hexa — Hexa wrapper (Phase 2d port of preflight_check.py)
// HEXA-FIRST: canonical entry; .py kept as backing implementation for behavior parity.
// Usage: hexa scripts/preflight_check.hexa  (forwards $HEXA_ARGS to python3 script)

let home = exec("printenv HOME").trim()
let script = home + "/Dev/anima/scripts/preflight_check.py"
let args = exec("printenv HEXA_ARGS").trim()
let out = exec("python3 " + script + " " + args)
println(out)
