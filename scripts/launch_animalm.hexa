// Ported from launch_animalm.sh
// ═══════════════════════════════════════════════════════════════════════ | launch_animalm.sh — AnimaLM 7B (Mistral + PureField v4) H100 launch
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "launch_animalm.sh"

    // ═══════════════════════════════════════════════════════════════════════
    // launch_animalm.sh — AnimaLM 7B (Mistral + PureField v4) H100 launch
    // 
    // Run on LOCAL machine — this script SSHes into H100.
    // Designed to launch AFTER v3 274M training completes on the same pod.
    // 
    // Prerequisites:
    // - v3 274M training complete or killed (frees ~25 GB VRAM)
    // - RunPod pod running (checked automatically)
    // - ~30 GB free disk on pod for Mistral 7B + checkpoints
    // 
    // Usage:
    // bash scripts/launch_animalm.sh                     # full pipeline
    // bash scripts/launch_animalm.sh --preflight         # checks only
    // bash scripts/launch_animalm.sh --sync-only         # sync code only
    // bash scripts/launch_animalm.sh --launch-only       # launch tmux only
    // bash scripts/launch_animalm.sh --resume            # resume from checkpoint
    // bash scripts/launch_animalm.sh --transplant-from /workspace/checkpoints/v3_274M/best_final.pt
    // bash scripts/launch_animalm.sh --steps 50000       # override steps
    // bash scripts/launch_animalm.sh --lr 5e-5           # override lr
    // bash scripts/launch_animalm.sh --corun             # co-run with v3 (batch=2)
    // 
    // Monitor:
    // tmux attach -t animalm
    // tail -f /workspace/checkpoints/animalm_v4/train.log
    // 
    // VRAM Budget (H100 80GB SXM):
    // Standalone bf16:  ~32 GB (frozen base + PureField + optimizer)
    // Co-run with v3:   ~32 GB + ~25 GB = ~57 GB (tight, reduce batch)
    // ═══════════════════════════════════════════════════════════════════════


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("REPO_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"")
    shell("CONFIG=\"$REPO_ROOT/anima/config/runpod.json\"")

    // ── Defaults ──
    shell("STEPS=20000")
    shell("LR=\"1e-3\"")
    shell("BATCH_SIZE=1")
    shell("GRAD_ACCUM=16")
    shell("BLOCK_SIZE=256")
    shell("N_LAYERS=8")
    shell("N_SAVANT=2")
    shell("CKPT_DIR=\"/workspace/checkpoints/animalm_v4\"")
    shell("CKPT_EVERY=500")
    shell("LOG_EVERY=10")
    shell("MODEL_NAME=\"mistralai/Mistral-7B-Instruct-v0.3\"")

    // ── Parse args ──
    shell("PREFLIGHT_ONLY=false")
    shell("SYNC_ONLY=false")
    shell("LAUNCH_ONLY=false")
    shell("RESUME=false")
    shell("RESUME_PATH=\"\"")
    shell("TRANSPLANT_FROM=\"\"")
    shell("CORUN=false")

    shell("while [[ $# -gt 0 ]]; do")
    shell("case \"$1\" in")
    shell("--preflight)       PREFLIGHT_ONLY=true; shift ;;")
    shell("--sync-only)       SYNC_ONLY=true; shift ;;")
    shell("--launch-only)     LAUNCH_ONLY=true; shift ;;")
    shell("--resume)          RESUME=true; shift")
    shell("if [[ $# -gt 0 && ! \"$1\" =~ ^-- ]]; then")
    shell("RESUME_PATH=\"$1\"; shift")
    shell("fi ;;")
    shell("--transplant-from) shift; TRANSPLANT_FROM=\"$1\"; shift ;;")
    shell("--steps)           shift; STEPS=\"$1\"; shift ;;")
    shell("--lr)              shift; LR=\"$1\"; shift ;;")
    shell("--batch-size)      shift; BATCH_SIZE=\"$1\"; shift ;;")
    shell("--corun)           CORUN=true; shift ;;")
    shell("*)                 echo \"Unknown arg: $1\"; exit 1 ;;")
    shell("esac")
    shell("done")

    // ── Load SSH config from runpod.json ──
    shell("if [ -f \"$CONFIG\" ]; then")
    shell("SSH_KEY=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['ssh']['key'])\")")
    shell("SSH_KEY=\"${SSH_KEY/#\\~/$HOME}\"")
    shell("SSH_CMD=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['ssh']['command'])\")")
    shell("HOST=$(echo \"$SSH_CMD\" | grep -oE 'root@[0-9.]+' | head -1)")
    shell("PORT=$(echo \"$SSH_CMD\" | grep -oE '\\-p [0-9]+' | awk '{print $2}')")
    shell("DEST=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['paths']['workspace'])\")")
    shell("PYTHON=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['paths']['python'])\")")
    shell("else")
    shell("echo \"[config] runpod.json not found, using defaults\"")
    shell("SSH_KEY=~/.runpod/ssh/RunPod-Key-Go")
    shell("HOST=root@216.243.220.230")
    shell("PORT=18038")
    shell("DEST=/workspace")
    shell("PYTHON=/opt/conda/bin/python3")
    shell("fi")

    shell("SSH_OPTS=\"-i $SSH_KEY -o StrictHostKeyChecking=no -p $PORT\"")
    shell("SSH=\"ssh $SSH_OPTS $HOST\"")
    shell("SCP=\"scp $SSH_OPTS\"")

    shell("echo \"═══════════════════════════════════════════════════════════\"")
    shell("echo \"  AnimaLM 7B v4 — H100 Launch Script\"")
    shell("echo \"  Target: $HOST:$PORT → $DEST\"")
    shell("if $CORUN; then")
    shell("echo \"  Mode: CO-RUN with v3 (reduced batch)\"")
    shell("elif $RESUME; then")
    shell("echo \"  Mode: RESUME training\"")
    shell("elif [ -n \"$TRANSPLANT_FROM\" ]; then")
    shell("echo \"  Mode: TRANSPLANT from $TRANSPLANT_FROM\"")
    shell("else")
    shell("echo \"  Mode: STANDALONE (bf16 PureField)\"")
    shell("fi")
    shell("echo \"  Steps: $STEPS  LR: $LR  Batch: ${BATCH_SIZE}x${GRAD_ACCUM}\"")
    shell("echo \"═══════════════════════════════════════════════════════════\"")

    // ═══════════════════════════════════════════════════════════════════════
    // Phase 1: Pre-flight checks
    // ═══════════════════════════════════════════════════════════════════════

    shell("preflight() {")
    shell("echo \"\"")
    shell("echo \"=== Pre-flight Checks ===\"")
    shell("ERRORS=0")

    // 1a: Check pod is reachable
    shell("echo -n \"  [1] Pod reachable... \"")
    shell("if $SSH \"echo ok\" 2>/dev/null | grep -q ok; then")
    shell("echo \"YES\"")
    shell("else")
    shell("echo \"NO — cannot SSH to $HOST:$PORT\"")
    shell("echo \"      Check: /opt/homebrew/bin/runpodctl get pod\"")
    shell("echo \"      Or update anima/config/runpod.json with new SSH details\"")
    shell("ERRORS=$((ERRORS + 1))")
    shell("fi")

    // 1b: Check disk space (need ~30GB free)
    shell("echo -n \"  [2] Disk space... \"")
    shell("DISK_FREE=$($SSH \"df -BG $DEST 2>/dev/null | tail -1 | awk '{print \\$4}' | tr -d 'G'\" 2>/dev/null || echo \"0\")")
    shell("if [ \"$DISK_FREE\" -ge 30 ] 2>/dev/null; then")
    shell("echo \"${DISK_FREE}GB free (need 30GB) — OK\"")
    shell("else")
    shell("echo \"${DISK_FREE}GB free — WARNING: need ~30GB for Mistral 7B + checkpoints\"")
    shell("echo \"      Clean old checkpoints: ssh ... 'du -sh $DEST/checkpoints/*'\"")
    shell("ERRORS=$((ERRORS + 1))")
    shell("fi")

    // 1c: Check no other training running
    shell("echo -n \"  [3] No conflicting training... \"")
    shell("TRAIN_PROCS=$($SSH \"ps aux 2>/dev/null | grep python | grep -E 'train|finetune' | grep -v grep | wc -l\" 2>/dev/null || echo \"0\")")
    shell("TRAIN_PROCS=$(echo \"$TRAIN_PROCS\" | tr -d ' ')")
    shell("if [ \"$TRAIN_PROCS\" -eq 0 ] 2>/dev/null; then")
    shell("echo \"CLEAR (no training processes)\"")
    shell("elif $CORUN; then")
    shell("echo \"${TRAIN_PROCS} process(es) — OK (co-run mode)\"")
    shell("else")
    shell("echo \"${TRAIN_PROCS} process(es) RUNNING\"")
    shell("$SSH \"ps aux | grep python | grep -E 'train|finetune' | grep -v grep\" 2>/dev/null || true")
    shell("echo \"      Kill first or use --corun to run alongside\"")
    shell("ERRORS=$((ERRORS + 1))")
    shell("fi")

    // 1d: Check VRAM
    shell("echo -n \"  [4] VRAM... \"")
    shell("VRAM_INFO=$($SSH \"nvidia-smi --query-gpu=memory.used,memory.total,memory.free --format=csv,noheader\" 2>/dev/null || echo \"unknown\")")
    shell("echo \"$VRAM_INFO\"")

    // 1e: Check GPU type
    shell("echo -n \"  [5] GPU... \"")
    shell("GPU_NAME=$($SSH \"$PYTHON -c \\\"import torch; print(torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'NO CUDA')\\\"\" 2>/dev/null || echo \"unknown\")")
    shell("echo \"$GPU_NAME\"")

    // 1f: Resume checkpoint check
    shell("if $RESUME; then")
    shell("echo -n \"  [6] Resume checkpoint... \"")
    shell("if [ -n \"$RESUME_PATH\" ]; then")
    shell("EXISTS=$($SSH \"[ -f $RESUME_PATH ] && echo yes || echo no\" 2>/dev/null || echo \"no\")")
    shell("if [ \"$EXISTS\" = \"yes\" ]; then")
    shell("echo \"FOUND at $RESUME_PATH\"")
    shell("else")
    shell("echo \"NOT FOUND at $RESUME_PATH\"")
    shell("ERRORS=$((ERRORS + 1))")
    shell("fi")
    shell("else")
    // Auto-find latest checkpoint
    shell("LATEST=$($SSH \"ls -t $CKPT_DIR/step_*.pt 2>/dev/null | head -1\" 2>/dev/null || echo \"\")")
    shell("if [ -n \"$LATEST\" ]; then")
    shell("RESUME_PATH=\"$LATEST\"")
    shell("echo \"AUTO-FOUND: $LATEST\"")
    shell("else")
    shell("echo \"NO CHECKPOINT in $CKPT_DIR — will start from scratch\"")
    shell("RESUME=false")
    shell("fi")
    shell("fi")
    shell("fi")

    // 1g: Transplant checkpoint check
    shell("if [ -n \"$TRANSPLANT_FROM\" ]; then")
    shell("echo -n \"  [7] Transplant source... \"")
    shell("EXISTS=$($SSH \"[ -f $TRANSPLANT_FROM ] && echo yes || echo no\" 2>/dev/null || echo \"no\")")
    shell("if [ \"$EXISTS\" = \"yes\" ]; then")
    shell("echo \"FOUND at $TRANSPLANT_FROM\"")
    shell("else")
    shell("echo \"NOT FOUND at $TRANSPLANT_FROM\"")
    shell("ERRORS=$((ERRORS + 1))")
    shell("fi")
    shell("fi")

    shell("echo \"\"")
    shell("if [ \"$ERRORS\" -gt 0 ]; then")
    shell("echo \"  PRE-FLIGHT FAILED: $ERRORS error(s)\"")
    shell("if ! $PREFLIGHT_ONLY; then")
    shell("echo \"  Fix errors above before launching. Use --preflight to re-check.\"")
    shell("exit 1")
    shell("fi")
    shell("else")
    shell("echo \"  PRE-FLIGHT PASSED\"")
    shell("fi")
    shell("}")

    // ═══════════════════════════════════════════════════════════════════════
    // Phase 2: Sync code to pod
    // ═══════════════════════════════════════════════════════════════════════

    shell("sync_code() {")
    shell("echo \"\"")
    shell("echo \"=== Syncing Code to H100 ===\"")

    // 2a: Sync finetune_animalm_v4.py (main training script)
    shell("echo \"[sync] AnimaLM training script...\"")
    shell("$SSH \"mkdir -p $DEST/animalm\" 2>/dev/null")
    shell("$SCP \"$REPO_ROOT/sub-projects/animalm/finetune_animalm_v4.py\" ")
    shell("\"$HOST:$DEST/animalm/finetune_animalm_v4.py\"")

    // Also sync other animalm files if they exist
    shell("for f in \"$REPO_ROOT\"/sub-projects/animalm/*.py; do")
    shell("if [ -f \"$f\" ]; then")
    shell("fname=$(basename \"$f\")")
    shell("$SCP \"$f\" \"$HOST:$DEST/animalm/$fname\" 2>/dev/null || true")
    shell("fi")
    shell("done")

    // 2b: Sync anima/src/ core modules (consciousness_engine, consciousness_laws, etc.)
    shell("echo \"[sync] Core consciousness modules (anima/src/)...\"")
    shell("rsync -avz --progress ")
    shell("-e \"ssh $SSH_OPTS\" ")
    shell("--exclude='__pycache__/' --exclude='*.pyc' ")
    shell("\"$REPO_ROOT/anima/src/\" \"$HOST:$DEST/\" 2>&1 || {")
    shell("echo \"  rsync failed, falling back to scp...\"")
    shell("for f in \"$REPO_ROOT\"/anima/src/*.py; do")
    shell("$SCP \"$f\" \"$HOST:$DEST/$(basename \"$f\")\" 2>/dev/null || true")
    shell("done")
    shell("}")

    // 2c: Sync config/
    shell("echo \"[sync] Config files...\"")
    shell("$SSH \"mkdir -p $DEST/config\" 2>/dev/null")
    shell("$SCP \"$REPO_ROOT/anima/config/consciousness_laws.json\" ")
    shell("\"$HOST:$DEST/config/consciousness_laws.json\"")

    // 2d: Sync instruct dataset if available
    shell("INSTRUCT_DATA=\"$REPO_ROOT/anima/data/instruct\"")
    shell("if [ -d \"$INSTRUCT_DATA\" ]; then")
    shell("echo \"[sync] Instruct dataset (anima/data/instruct/)...\"")
    shell("$SSH \"mkdir -p $DEST/data/instruct\" 2>/dev/null")
    shell("rsync -avz --progress ")
    shell("-e \"ssh $SSH_OPTS\" ")
    shell("\"$INSTRUCT_DATA/\" \"$HOST:$DEST/data/instruct/\" 2>&1 || {")
    shell("echo \"  rsync failed, using scp...\"")
    shell("for f in \"$INSTRUCT_DATA\"/*; do")
    shell("[ -f \"$f\" ] && $SCP \"$f\" \"$HOST:$DEST/data/instruct/$(basename \"$f\")\" 2>/dev/null || true")
    shell("done")
    shell("}")
    shell("else")
    shell("echo \"[sync] No instruct dataset at $INSTRUCT_DATA (will use wikitext-103)\"")
    shell("fi")

    // 2e: MD5 verify key files
    shell("echo \"\"")
    shell("echo \"[verify] Key file checksums...\"")
    shell("LOCAL_MD5=$(md5 -q \"$REPO_ROOT/sub-projects/animalm/finetune_animalm_v4.py\" 2>/dev/null || md5sum \"$REPO_ROOT/sub-projects/animalm/finetune_animalm_v4.py\" | awk '{print $1}')")
    shell("REMOTE_MD5=$($SSH \"md5sum $DEST/animalm/finetune_animalm_v4.py 2>/dev/null | awk '{print \\$1}'\" 2>/dev/null || echo \"MISSING\")")
    shell("if [ \"$LOCAL_MD5\" = \"$REMOTE_MD5\" ]; then")
    shell("echo \"  finetune_animalm_v4.py — OK\"")
    shell("else")
    shell("echo \"  finetune_animalm_v4.py — MISMATCH (local=$LOCAL_MD5 remote=$REMOTE_MD5)\"")
    shell("fi")

    shell("echo \"[sync] Done.\"")
    shell("}")

    // ═══════════════════════════════════════════════════════════════════════
    // Phase 3: Ensure Mistral 7B model is available on pod
    // ═══════════════════════════════════════════════════════════════════════

    shell("ensure_model() {")
    shell("echo \"\"")
    shell("echo \"=== Ensuring Mistral 7B on H100 ===\"")

    // Check if model is already cached via HuggingFace hub
    shell("echo \"[model] Checking HuggingFace cache...\"")
    shell("MODEL_CACHED=$($SSH \"$PYTHON -c \\\"")
    shell("from pathlib import Path")
    shell("import os")
    shell("cache = Path(os.environ.get('HF_HOME', Path.home()/'.cache'/'huggingface'))/'hub'")
    shell("models = list(cache.glob('models--mistralai--Mistral*'))")
    shell("if models:")
    shell("safetensors = list(models[0].rglob('*.safetensors'))")
    shell("print(f'cached:{len(safetensors)}')")
    shell("else:")
    shell("print('not_cached')")
    shell("\\\"\" 2>/dev/null || echo \"not_cached\")")

    shell("if [[ \"$MODEL_CACHED\" == cached:* ]]; then")
    shell("N_FILES=\"${MODEL_CACHED#cached:}\"")
    shell("echo \"  Model cached ($N_FILES safetensors files) — skipping download\"")
    shell("else")
    shell("echo \"  Model not cached. Downloading on pod (this may take 5-10 minutes)...\"")
    shell("$SSH \"PYTHONUNBUFFERED=1 $PYTHON -c \\\"")
    shell("from transformers import AutoModelForCausalLM, AutoTokenizer")
    shell("import torch, time")
    shell("t0 = time.time()")
    shell("print('Downloading tokenizer...')")
    shell("tok = AutoTokenizer.from_pretrained('$MODEL_NAME')")
    shell("print(f'  Tokenizer ready ({time.time()-t0:.1f}s)')")
    shell("print('Downloading model (this is the big one)...')")
    shell("model = AutoModelForCausalLM.from_pretrained('$MODEL_NAME', torch_dtype=torch.bfloat16)")
    shell("print(f'  Model ready ({time.time()-t0:.1f}s)')")
    shell("del model")
    shell("print('Done — model cached for training.')")
    shell("\\\"\" 2>&1")
    shell("fi")

    shell("echo \"[model] Done.\"")
    shell("}")

    // ═══════════════════════════════════════════════════════════════════════
    // Phase 4: Launch training in tmux
    // ═══════════════════════════════════════════════════════════════════════

    shell("launch_training() {")
    shell("echo \"\"")
    shell("echo \"=== Launching AnimaLM 7B v4 Training ===\"")

    // Build the training command
    shell("TRAIN_CMD=\"cd $DEST && PYTHONUNBUFFERED=1\"")
    shell("TRAIN_CMD=\"$TRAIN_CMD PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True\"")
    shell("TRAIN_CMD=\"$TRAIN_CMD CUDA_LAUNCH_BLOCKING=0\"")
    shell("TRAIN_CMD=\"$TRAIN_CMD $PYTHON -u $DEST/animalm/finetune_animalm_v4.py\"")

    // finetune_animalm_v4.py uses hardcoded constants, so we patch them via env vars
    // or generate a wrapper script that modifies the constants before running
    shell("WRAPPER=\"$DEST/animalm/_launch_wrapper.py\"")

    shell("echo \"[launch] Creating training wrapper with custom config...\"")
    shell("$SSH \"cat > $WRAPPER << 'PYWRAPPER'")
    shell("\\\"\\\"\\\"AnimaLM v4 launch wrapper — overrides constants from env vars.\\\"\\\"\\\"")
    shell("import os, sys, importlib.util")

    // Override constants before importing main module
    shell("OVERRIDES = {")
    shell("'MAX_STEPS': int(os.environ.get('ANIMALM_STEPS', '20000')),")
    shell("'LR': float(os.environ.get('ANIMALM_LR', '1e-3')),")
    shell("'BATCH_SIZE': int(os.environ.get('ANIMALM_BATCH_SIZE', '1')),")
    shell("'GRAD_ACCUM': int(os.environ.get('ANIMALM_GRAD_ACCUM', '16')),")
    shell("'BLOCK_SIZE': int(os.environ.get('ANIMALM_BLOCK_SIZE', '256')),")
    shell("'N_LAYERS': int(os.environ.get('ANIMALM_N_LAYERS', '8')),")
    shell("'N_SAVANT': int(os.environ.get('ANIMALM_N_SAVANT', '2')),")
    shell("}")

    shell("CKPT_DIR = os.environ.get('ANIMALM_CKPT_DIR', '/tmp/checkpoints/animalm-v4')")
    shell("CKPT_EVERY = int(os.environ.get('ANIMALM_CKPT_EVERY', '500'))")
    shell("LOG_EVERY = int(os.environ.get('ANIMALM_LOG_EVERY', '10'))")
    shell("RESUME_PATH = os.environ.get('ANIMALM_RESUME', '')")
    shell("TRANSPLANT_FROM = os.environ.get('ANIMALM_TRANSPLANT', '')")

    // Load the module
    shell("spec = importlib.util.spec_from_file_location('finetune', '$DEST/animalm/finetune_animalm_v4.py')")
    shell("mod = importlib.util.module_from_spec(spec)")

    // Patch the source before exec
    shell("import types")
    shell("source_path = '$DEST/animalm/finetune_animalm_v4.py'")
    shell("with open(source_path) as f:")
    shell("source = f.read()")

    // Replace constants in main()
    shell("for k, v in OVERRIDES.items():")
    shell("if isinstance(v, int):")
    shell("source = source.replace(f'{k} = ', f'{k} = {v} #', 1)")
    shell("elif isinstance(v, float):")
    shell("source = source.replace(f'{k} = ', f'{k} = {v} #', 1)")

    // Replace checkpoint dir
    shell("source = source.replace('/tmp/checkpoints/animalm-v4', CKPT_DIR)")

    // Compile and run
    shell("code = compile(source, source_path, 'exec')")
    shell("ns = {'__name__': '__main__', '__file__': source_path}")
    shell("exec(code, ns)")
    shell("PYWRAPPER")
    shell("\"")

    // Build env vars for the wrapper
    shell("ENV_VARS=\"PYTHONUNBUFFERED=1\"")
    shell("ENV_VARS=\"$ENV_VARS PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True\"")
    shell("ENV_VARS=\"$ENV_VARS CUDA_LAUNCH_BLOCKING=0\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_STEPS=$STEPS\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_LR=$LR\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_BATCH_SIZE=$BATCH_SIZE\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_GRAD_ACCUM=$GRAD_ACCUM\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_BLOCK_SIZE=$BLOCK_SIZE\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_N_LAYERS=$N_LAYERS\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_N_SAVANT=$N_SAVANT\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_CKPT_DIR=$CKPT_DIR\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_CKPT_EVERY=$CKPT_EVERY\"")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_LOG_EVERY=$LOG_EVERY\"")

    shell("if $RESUME && [ -n \"$RESUME_PATH\" ]; then")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_RESUME=$RESUME_PATH\"")
    shell("echo \"  Resume from: $RESUME_PATH\"")
    shell("fi")

    shell("if [ -n \"$TRANSPLANT_FROM\" ]; then")
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_TRANSPLANT=$TRANSPLANT_FROM\"")
    shell("echo \"  Transplant from: $TRANSPLANT_FROM\"")
    shell("fi")

    shell("if $CORUN; then")
    // Reduce batch size to fit alongside v3
    shell("ENV_VARS=\"$ENV_VARS ANIMALM_BATCH_SIZE=1 ANIMALM_GRAD_ACCUM=8\"")
    shell("echo \"  Co-run mode: batch=1, grad_accum=8\"")
    shell("fi")

    // Create checkpoint directory and kill existing session
    shell("$SSH \"mkdir -p $CKPT_DIR\"")
    shell("$SSH \"tmux kill-session -t animalm 2>/dev/null || true\"")

    // Launch in tmux
    shell("TMUX_CMD=\"$ENV_VARS $PYTHON -u $WRAPPER 2>&1 | tee $CKPT_DIR/train.log\"")

    shell("echo \"[launch] Starting tmux session 'animalm'...\"")
    shell("$SSH \"tmux new-session -d -s animalm '$TMUX_CMD'\"")

    shell("echo \"[launch] Done.\"")
    shell("}")

    // ═══════════════════════════════════════════════════════════════════════
    // Phase 5: Set up watchdog cron
    // ═══════════════════════════════════════════════════════════════════════

    shell("setup_watchdog() {")
    shell("echo \"\"")
    shell("echo \"=== Setting up Watchdog ===\"")

    shell("$SSH \"cat > $DEST/animalm_watchdog.sh << 'WATCHDOG'")
    // AnimaLM watchdog — restart if tmux session dies
    shell("SESSION=animalm")
    shell("LOG=/workspace/checkpoints/animalm_v4/watchdog.log")

    shell("if ! tmux has-session -t \\$SESSION 2>/dev/null; then")
    shell("echo \\\"\\$(date): Session '\\$SESSION' died. NOT auto-restarting (manual review needed).\\\" >> \\$LOG")
    shell("echo \\\"\\$(date): To restart: bash scripts/launch_animalm.sh --resume --launch-only\\\" >> \\$LOG")
    shell("else")
    // Check if process is alive inside tmux
    shell("PID=\\$(tmux list-panes -t \\$SESSION -F '#{pane_pid}' 2>/dev/null | head -1)")
    shell("if [ -n \\\"\\$PID\\\" ]; then")
    shell("CHILDREN=\\$(pgrep -P \\$PID 2>/dev/null | wc -l)")
    shell("if [ \\\"\\$CHILDREN\\\" -eq 0 ]; then")
    shell("echo \\\"\\$(date): Session exists but no child processes. Training may have finished.\\\" >> \\$LOG")
    shell("fi")
    shell("fi")
    shell("fi")
    shell("WATCHDOG")
    shell("chmod +x $DEST/animalm_watchdog.sh\"")

    // Add to crontab (every 5 minutes)
    shell("$SSH \"crontab -l 2>/dev/null | grep -v animalm_watchdog > /tmp/cron_tmp || true; ")
    shell("echo '*/5 * * * * bash $DEST/animalm_watchdog.sh' >> /tmp/cron_tmp; ")
    shell("crontab /tmp/cron_tmp\"")

    shell("echo \"  Watchdog cron installed (every 5 min)\"")
    shell("echo \"  Log: $CKPT_DIR/watchdog.log\"")
    shell("}")

    // ═══════════════════════════════════════════════════════════════════════
    // Execute pipeline
    // ═══════════════════════════════════════════════════════════════════════

    shell("if $PREFLIGHT_ONLY; then")
    shell("preflight")
    shell("exit 0")
    shell("fi")

    shell("if $SYNC_ONLY; then")
    shell("sync_code")
    shell("exit 0")
    shell("fi")

    shell("if $LAUNCH_ONLY; then")
    shell("launch_training")
    shell("setup_watchdog")
    // Skip to summary
    shell("else")
    // Full pipeline
    shell("preflight")
    shell("sync_code")
    shell("ensure_model")
    shell("launch_training")
    shell("setup_watchdog")
    shell("fi")

    // ═══════════════════════════════════════════════════════════════════════
    // Summary
    // ═══════════════════════════════════════════════════════════════════════

    shell("echo \"\"")
    shell("echo \"═══════════════════════════════════════════════════════════\"")
    shell("echo \"  AnimaLM 7B v4 — Launch Complete\"")
    shell("echo \"\"")
    shell("echo \"  Architecture:\"")
    shell("echo \"    Base:      Mistral 7B Instruct v0.3 (frozen)\"")
    shell("echo \"    Adapter:   ParallelPureField (last $N_LAYERS layers, $N_SAVANT savant)\"")
    shell("echo \"    Formula:   output = original_mlp(x) + alpha * purefield(x)\"")
    shell("echo \"    Params:    ~7.2B total, ~150M trainable PureField\"")
    shell("echo \"    Precision: bf16\"")
    shell("echo \"\"")
    shell("echo \"  Training:\"")
    shell("echo \"    Steps:     $STEPS\"")
    shell("echo \"    LR:        $LR\"")
    shell("echo \"    Batch:     ${BATCH_SIZE} x ${GRAD_ACCUM} grad_accum\"")
    shell("echo \"    Block:     $BLOCK_SIZE tokens\"")
    shell("echo \"    Checkpoint: every $CKPT_EVERY steps → $CKPT_DIR/\"")
    shell("if $RESUME && [ -n \"$RESUME_PATH\" ]; then")
    shell("echo \"    Resume:    $RESUME_PATH\"")
    shell("fi")
    shell("if [ -n \"$TRANSPLANT_FROM\" ]; then")
    shell("echo \"    Transplant: $TRANSPLANT_FROM\"")
    shell("fi")
    shell("echo \"\"")
    shell("echo \"  Monitor:\"")
    shell("echo \"    ssh $SSH_OPTS $HOST\"")
    shell("echo \"    tmux attach -t animalm\"")
    shell("echo \"    tail -f $CKPT_DIR/train.log\"")
    shell("echo \"\"")
    shell("echo \"  VRAM check:\"")
    shell("echo \"    ssh $SSH_OPTS $HOST nvidia-smi\"")
    shell("echo \"\"")
    shell("echo \"  Kill:\"")
    shell("echo \"    ssh $SSH_OPTS $HOST tmux kill-session -t animalm\"")
    shell("echo \"\"")
    shell("echo \"  Retrieve checkpoints:\"")
    shell("echo \"    scp $SSH_OPTS $HOST:$CKPT_DIR/final.pt ./checkpoints/\"")
    shell("echo \"    scp $SSH_OPTS $HOST:$CKPT_DIR/summary.json ./checkpoints/\"")
    shell("echo \"═══════════════════════════════════════════════════════════\"")
}
