// Ported from backup_checkpoints.sh
// backup_checkpoints.sh — Back up checkpoints to timestamped tarball, keep last 5 | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    // backup_checkpoints.sh — Back up checkpoints to timestamped tarball, keep last 5
    // 
    // Usage: ./backup_checkpoints.sh [checkpoint_dir] [backup_dir]
    // Default checkpoint_dir: anima/checkpoints/
    // Default backup_dir:     anima/checkpoints/backups/


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("PROJECT_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"")

    shell("CHECKPOINT_DIR=\"${1:-$PROJECT_ROOT/checkpoints}\"")
    shell("BACKUP_DIR=\"${2:-$CHECKPOINT_DIR/backups}\"")
    shell("MAX_BACKUPS=5")

    // --- Validation ---
    shell("if [ ! -d \"$CHECKPOINT_DIR\" ]; then")
    shell("echo \"ERROR: Checkpoint directory not found: $CHECKPOINT_DIR\"")
    shell("exit 1")
    shell("fi")

    // Check if there's anything to back up (exclude backups/ dir itself)
    shell("file_count=$(find \"$CHECKPOINT_DIR\" -maxdepth 1 -not -name backups -not -path \"$CHECKPOINT_DIR\" | wc -l | tr -d ' ')")
    shell("if [ \"$file_count\" -eq 0 ]; then")
    shell("echo \"Nothing to back up in $CHECKPOINT_DIR\"")
    shell("exit 0")
    shell("fi")

    // --- Create backup ---
    shell("mkdir -p \"$BACKUP_DIR\"")

    shell("TIMESTAMP=$(date +%Y%m%d_%H%M%S)")
    shell("TARBALL=\"$BACKUP_DIR/checkpoints_${TIMESTAMP}.tar.gz\"")

    shell("echo \"=== Checkpoint Backup ===\"")
    shell("echo \"  Source:  $CHECKPOINT_DIR\"")
    shell("echo \"  Target:  $TARBALL\"")
    shell("echo \"\"")

    // Tar everything except the backups/ subdirectory
    shell("tar czf \"$TARBALL\" ")
    shell("--exclude=\"$(basename \"$BACKUP_DIR\")\" ")
    shell("-C \"$(dirname \"$CHECKPOINT_DIR\")\" ")
    shell("\"$(basename \"$CHECKPOINT_DIR\")\"")

    shell("TARBALL_SIZE=$(du -h \"$TARBALL\" | cut -f1)")
    shell("echo \"  Created: $TARBALL ($TARBALL_SIZE)\"")

    // --- Rotate: keep last $MAX_BACKUPS ---
    shell("backup_count=$(ls -1 \"$BACKUP_DIR\"/checkpoints_*.tar.gz 2>/dev/null | wc -l | tr -d ' ')")
    shell("if [ \"$backup_count\" -gt \"$MAX_BACKUPS\" ]; then")
    shell("remove_count=$((backup_count - MAX_BACKUPS))")
    shell("echo \"\"")
    shell("echo \"  Rotating: removing $remove_count old backup(s) (keeping last $MAX_BACKUPS)\"")
    shell("ls -1t \"$BACKUP_DIR\"/checkpoints_*.tar.gz | tail -n \"$remove_count\" | while read -r old; do")
    shell("echo \"    Deleted: $(basename \"$old\")\"")
    shell("rm -f \"$old\"")
    shell("done")
    shell("fi")

    // --- Summary ---
    shell("echo \"\"")
    shell("echo \"  Backups on disk:\"")
    shell("ls -1t \"$BACKUP_DIR\"/checkpoints_*.tar.gz 2>/dev/null | while read -r f; do")
    shell("size=$(du -h \"$f\" | cut -f1)")
    shell("echo \"    $(basename \"$f\")  ($size)\"")
    shell("done")

    shell("echo \"\"")
    shell("echo \"Done.\"")
}
