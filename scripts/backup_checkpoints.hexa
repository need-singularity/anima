// scripts/backup_checkpoints.hexa — Hexa wrapper (Phase 2d port of backup_checkpoints.sh)
// HEXA-FIRST: canonical entry; .sh kept as backing implementation for behavior parity.
// Usage: hexa scripts/backup_checkpoints.hexa  (forwards $HEXA_ARGS to bash script)

let home = exec("printenv HOME").trim()
let script = home + "/Dev/anima/scripts/backup_checkpoints.sh"
let args = exec("printenv HEXA_ARGS").trim()
let out = exec("bash " + script + " " + args)
println(out)
