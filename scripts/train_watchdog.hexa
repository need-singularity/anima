// Ported from train_watchdog.sh
// train_watchdog.sh — Watchdog for H100 training process | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "train_watchdog.sh"

    // train_watchdog.sh — Watchdog for H100 training process
    // 
    // Checks every 60s if the training process (train_clm.py) is alive.
    // If dead, auto-resumes from latest checkpoint.
    // Designed to survive tmux death via crontab.
    // 
    // Usage:
    // bash train_watchdog.sh --install             # Install to crontab (runs every minute)
    // bash train_watchdog.sh --uninstall           # Remove from crontab
    // bash train_watchdog.sh --check               # Manual one-shot check
    // bash train_watchdog.sh --status              # Show current state
    // 
    // Environment (set these or use defaults):
    // TRAIN_SCRIPT    — training script path (default: /workspace/anima/anima/training/train_clm.py)
    // TRAIN_ARGS      — arguments (default: --data /workspace/anima/anima/data/corpus_v10_ko.txt --scale 100m)
    // CKPT_DIR        — checkpoint directory (default: /workspace/anima/checkpoints/v15_1b)
    // PYTHON          — python path (default: /opt/conda/bin/python3)
    // WATCHDOG_LOG    — log file (default: /workspace/watchdog.log)
    // ALERT_FILE      — alert file for consecutive failures (default: /workspace/watchdog_alert.txt)


    // ── Defaults ──
    shell("PYTHON=\"${PYTHON:-/opt/conda/bin/python3}\"")
    shell("TRAIN_SCRIPT=\"${TRAIN_SCRIPT:-/workspace/anima/anima/training/train_clm.py}\"")
    shell("TRAIN_ARGS=\"${TRAIN_ARGS:---data /workspace/anima/anima/data/corpus_v10_ko.txt --scale 100m}\"")
    shell("CKPT_DIR=\"${CKPT_DIR:-/workspace/anima/checkpoints/v15_1b}\"")
    shell("WATCHDOG_LOG=\"${WATCHDOG_LOG:-/workspace/watchdog.log}\"")
    shell("ALERT_FILE=\"${ALERT_FILE:-/workspace/watchdog_alert.txt}\"")
    shell("FAIL_COUNT_FILE=\"/tmp/watchdog_fail_count\"")
    shell("MAX_CONSECUTIVE_FAILS=5")

    // ── Logging ──
    shell("log() {")
    shell("local msg=\"[$(date '+%Y-%m-%d %H:%M:%S')] [watchdog] $1\"")
    shell("echo \"$msg\" >> \"$WATCHDOG_LOG\"")
    shell("echo \"$msg\"")
    shell("}")

    // ── Find latest checkpoint ──
    shell("find_latest_checkpoint() {")
    shell("local latest=\"\"")
    shell("local latest_step=-1")

    shell("if [ ! -d \"$CKPT_DIR\" ]; then")
    shell("echo \"\"")
    shell("return")
    shell("fi")

    // Search all subdirs for step_*.pt files
    shell("while IFS= read -r -d '' f; do")
    shell("local base")
    shell("base=$(basename \"$f\")")
    shell("local step_num")
    shell("step_num=$(echo \"$base\" | sed -n 's/step_\\([0-9]*\\)\\.pt/\\1/p')")
    shell("if [ -n \"$step_num\" ] && [ \"$step_num\" -gt \"$latest_step\" ]; then")
    shell("latest_step=$step_num")
    shell("latest=\"$f\"")
    shell("fi")
    shell("done < <(find \"$CKPT_DIR\" -name \"step_*.pt\" -print0 2>/dev/null)")

    // Fallback: best.pt
    shell("if [ -z \"$latest\" ]; then")
    shell("while IFS= read -r -d '' f; do")
    shell("latest=\"$f\"")
    shell("break")
    shell("done < <(find \"$CKPT_DIR\" -name \"best.pt\" -print0 2>/dev/null)")
    shell("fi")

    // Fallback: final.pt
    shell("if [ -z \"$latest\" ]; then")
    shell("while IFS= read -r -d '' f; do")
    shell("latest=\"$f\"")
    shell("break")
    shell("done < <(find \"$CKPT_DIR\" -name \"final.pt\" -print0 2>/dev/null)")
    shell("fi")

    shell("echo \"$latest\"")
    shell("}")

    // ── Check if training is running ──
    shell("is_training_alive() {")
    shell("pgrep -f \"train_clm.py\" > /dev/null 2>&1")
    shell("}")

    // ── GPU check ──
    shell("check_gpu() {")
    shell("if ! command -v nvidia-smi &> /dev/null; then")
    shell("log \"WARNING: nvidia-smi not found\"")
    shell("return 1")
    shell("fi")
    shell("local gpu_mem")
    shell("gpu_mem=$(nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits 2>/dev/null | head -1)")
    shell("if [ -z \"$gpu_mem\" ]; then")
    shell("log \"WARNING: Could not query GPU memory\"")
    shell("return 1")
    shell("fi")
    // Need at least 10GB free (10240 MB)
    shell("if [ \"$gpu_mem\" -lt 10240 ]; then")
    shell("log \"WARNING: GPU memory low (${gpu_mem}MB free). Waiting for cleanup.\"")
    shell("return 1")
    shell("fi")
    shell("return 0")
    shell("}")

    // ── Restart training ──
    shell("restart_training() {")
    shell("local ckpt")
    shell("ckpt=$(find_latest_checkpoint)")

    shell("local resume_arg=\"\"")
    shell("if [ -n \"$ckpt\" ]; then")
    shell("resume_arg=\"--resume $ckpt\"")
    shell("log \"Resuming from checkpoint: $ckpt\"")
    shell("else")
    shell("log \"No checkpoint found. Starting from scratch.\"")
    shell("fi")

    // Check GPU before starting
    shell("if ! check_gpu; then")
    shell("log \"GPU not ready. Will retry next cycle.\"")
    shell("return 1")
    shell("fi")

    // Kill any zombie training processes
    shell("pkill -f \"train_clm.py\" 2>/dev/null || true")
    shell("sleep 2")

    // Start in a new tmux session (survives SSH disconnect)
    shell("local tmux_session=\"train_clm\"")
    shell("tmux kill-session -t \"$tmux_session\" 2>/dev/null || true")

    shell("local cmd=\"PYTHONUNBUFFERED=1 $PYTHON -u $TRAIN_SCRIPT $TRAIN_ARGS $resume_arg 2>&1 | tee -a /workspace/train_clm.log\"")
    shell("tmux new-session -d -s \"$tmux_session\" \"$cmd\"")

    shell("log \"Training restarted in tmux session '$tmux_session'\"")
    shell("log \"  Command: $PYTHON $TRAIN_SCRIPT $TRAIN_ARGS $resume_arg\"")

    // Reset fail counter on successful restart
    shell("echo \"0\" > \"$FAIL_COUNT_FILE\"")
    shell("return 0")
    shell("}")

    // ── Track consecutive failures ──
    shell("increment_fail_count() {")
    shell("local count=0")
    shell("if [ -f \"$FAIL_COUNT_FILE\" ]; then")
    shell("count=$(cat \"$FAIL_COUNT_FILE\" 2>/dev/null || echo \"0\")")
    shell("fi")
    shell("count=$((count + 1))")
    shell("echo \"$count\" > \"$FAIL_COUNT_FILE\"")

    shell("if [ \"$count\" -ge \"$MAX_CONSECUTIVE_FAILS\" ]; then")
    shell("local alert_msg=\"ALERT: Training has failed to restart $count consecutive times. Manual intervention required.\"")
    shell("log \"$alert_msg\"")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $alert_msg\" >> \"$ALERT_FILE\"")
    // Could add telegram/webhook notification here
    shell("return 1")
    shell("fi")
    shell("return 0")
    shell("}")

    // ── Actions ──
    shell("do_check() {")
    shell("if is_training_alive; then")
    shell("log \"Training is ALIVE (PID: $(pgrep -f train_clm.py | head -1))\"")
    // Reset fail counter
    shell("echo \"0\" > \"$FAIL_COUNT_FILE\" 2>/dev/null || true")
    shell("else")
    shell("log \"Training is DEAD. Attempting restart...\"")
    shell("if increment_fail_count; then")
    shell("restart_training")
    shell("else")
    shell("log \"Too many consecutive failures. Stopping watchdog attempts.\"")
    shell("fi")
    shell("fi")
    shell("}")

    shell("do_status() {")
    shell("echo \"=== Train Watchdog Status ===\"")
    shell("echo \"\"")
    shell("if is_training_alive; then")
    shell("echo \"  Training: ALIVE (PID: $(pgrep -f train_clm.py | head -1))\"")
    shell("else")
    shell("echo \"  Training: DEAD\"")
    shell("fi")
    shell("echo \"\"")

    shell("local ckpt")
    shell("ckpt=$(find_latest_checkpoint)")
    shell("if [ -n \"$ckpt\" ]; then")
    shell("echo \"  Latest checkpoint: $ckpt\"")
    shell("echo \"  Checkpoint time:   $(stat -c '%Y' \"$ckpt\" 2>/dev/null | xargs -I{} date -d @{} 2>/dev/null || stat -f '%Sm' \"$ckpt\" 2>/dev/null || echo 'unknown')\"")
    shell("else")
    shell("echo \"  Latest checkpoint: (none found)\"")
    shell("fi")
    shell("echo \"\"")

    shell("local fail_count=0")
    shell("if [ -f \"$FAIL_COUNT_FILE\" ]; then")
    shell("fail_count=$(cat \"$FAIL_COUNT_FILE\" 2>/dev/null || echo \"0\")")
    shell("fi")
    shell("echo \"  Consecutive failures: $fail_count / $MAX_CONSECUTIVE_FAILS\"")
    shell("echo \"\"")

    shell("if command -v nvidia-smi &> /dev/null; then")
    shell("echo \"  GPU:\"")
    shell("nvidia-smi --query-gpu=name,memory.used,memory.free,utilization.gpu --format=csv,noheader 2>/dev/null | while read -r line; do")
    shell("echo \"    $line\"")
    shell("done")
    shell("fi")
    shell("echo \"\"")

    // Crontab status
    shell("if crontab -l 2>/dev/null | grep -q \"train_watchdog.sh\"; then")
    shell("echo \"  Crontab: INSTALLED\"")
    shell("else")
    shell("echo \"  Crontab: NOT INSTALLED (run --install)\"")
    shell("fi")

    shell("echo \"\"")
    shell("echo \"  Log: $WATCHDOG_LOG\"")
    shell("if [ -f \"$WATCHDOG_LOG\" ]; then")
    shell("echo \"  Last 5 log entries:\"")
    shell("tail -5 \"$WATCHDOG_LOG\" | while read -r line; do")
    shell("echo \"    $line\"")
    shell("done")
    shell("fi")
    shell("}")

    shell("do_install() {")
    shell("local script_path")
    shell("script_path=\"$(cd \"$(dirname \"$0\")\" && pwd)/$(basename \"$0\")\"")

    // Build crontab entry with environment
    shell("local cron_line=\"* * * * * PYTHON=$PYTHON TRAIN_SCRIPT=$TRAIN_SCRIPT TRAIN_ARGS=\\\"$TRAIN_ARGS\\\" CKPT_DIR=$CKPT_DIR WATCHDOG_LOG=$WATCHDOG_LOG bash $script_path --check >> $WATCHDOG_LOG 2>&1\"")

    // Add to crontab (preserving existing entries)
    shell("(crontab -l 2>/dev/null | grep -v \"train_watchdog.sh\"; echo \"$cron_line\") | crontab -")

    shell("echo \"Watchdog installed to crontab (runs every minute).\"")
    shell("echo \"  Script: $script_path\"")
    shell("echo \"  Log:    $WATCHDOG_LOG\"")
    shell("echo \"\"")
    shell("echo \"Current crontab:\"")
    shell("crontab -l 2>/dev/null | grep \"train_watchdog\" || echo \"  (none)\"")
    shell("log \"Watchdog crontab installed\"")
    shell("}")

    shell("do_uninstall() {")
    shell("crontab -l 2>/dev/null | grep -v \"train_watchdog.sh\" | crontab -")
    shell("echo \"Watchdog removed from crontab.\"")
    shell("log \"Watchdog crontab removed\"")
    shell("}")

    // ── Main ──
    shell("case \"${1:-}\" in")
    shell("--install)   do_install ;;")
    shell("--uninstall) do_uninstall ;;")
    shell("--check)     do_check ;;")
    shell("--status)    do_status ;;")
    shell("*)")
    shell("echo \"Usage: $0 {--install|--uninstall|--check|--status}\"")
    shell("echo \"\"")
    shell("echo \"  --install    Install to crontab (checks every minute)\"")
    shell("echo \"  --uninstall  Remove from crontab\"")
    shell("echo \"  --check      Manual one-shot check + restart if dead\"")
    shell("echo \"  --status     Show training status, checkpoint, GPU\"")
    shell("echo \"\"")
    shell("echo \"Environment variables:\"")
    shell("echo \"  PYTHON=$PYTHON\"")
    shell("echo \"  TRAIN_SCRIPT=$TRAIN_SCRIPT\"")
    shell("echo \"  TRAIN_ARGS=\\\"$TRAIN_ARGS\\\"\"")
    shell("echo \"  CKPT_DIR=$CKPT_DIR\"")
    shell("echo \"  WATCHDOG_LOG=$WATCHDOG_LOG\"")
    shell("exit 1")
    shell(";;")
    shell("esac")
}
