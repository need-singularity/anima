// Ported from preflight_training.sh
// One-Shot Best Pre-flight Checklist | Run before ANY full training launch
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "preflight_training.sh"

    // One-Shot Best Pre-flight Checklist
    // Run before ANY full training launch
    // Usage: bash scripts/preflight_training.sh <corpus_path> <tokenizer_path> <train_script> [extra_args...]


    shell("CORPUS=\"${1:?Usage: preflight_training.sh <corpus> <tokenizer> <train_script> [args...]}\"")
    shell("TOKENIZER=\"${2:?Missing tokenizer path}\"")
    shell("TRAIN_SCRIPT=\"${3:?Missing training script}\"")
    shell("shift 3")
    shell("EXTRA_ARGS=\"$@\"")

    shell("echo \"═══════════════════════════════════════════════════════\"")
    shell("echo \"  One-Shot Best — Pre-flight Checklist\"")
    shell("echo \"═══════════════════════════════════════════════════════\"")
    shell("PASS=0")
    shell("FAIL=0")

    shell("check() {")
    shell("if [ \"$1\" = \"PASS\" ]; then")
    shell("echo \"  ✅ $2\"")
    shell("PASS=$((PASS+1))")
    shell("else")
    shell("echo \"  ❌ $2\"")
    shell("FAIL=$((FAIL+1))")
    shell("fi")
    shell("}")

    // ① Corpus exists and has content
    shell("echo \"\"")
    shell("echo \"① Corpus\"")
    shell("if [ -f \"$CORPUS\" ]; then")
    shell("CORPUS_SIZE=$(du -sh \"$CORPUS\" | awk '{print $1}')")
    shell("CORPUS_LINES=$(wc -l < \"$CORPUS\")")
    shell("CORPUS_MD5=$(md5 -q \"$CORPUS\")")
    shell("check PASS \"Corpus: $CORPUS ($CORPUS_SIZE, $CORPUS_LINES lines)\"")
    shell("check PASS \"MD5: $CORPUS_MD5\"")
    shell("echo \"     ⚠️  Record this MD5 — changing corpus = restart from step 0\"")
    shell("else")
    shell("check FAIL \"Corpus not found: $CORPUS\"")
    shell("fi")

    // ② Tokenizer exists
    shell("echo \"\"")
    shell("echo \"② Tokenizer\"")
    shell("if [ -f \"$TOKENIZER\" ]; then")
    shell("TOK_SIZE=$(du -sh \"$TOKENIZER\" | awk '{print $1}')")
    shell("check PASS \"Tokenizer: $TOKENIZER ($TOK_SIZE)\"")
    shell("else")
    shell("check FAIL \"Tokenizer not found: $TOKENIZER\"")
    shell("fi")

    // ③ Training script exists
    shell("echo \"\"")
    shell("echo \"③ Training Script\"")
    shell("if [ -f \"$TRAIN_SCRIPT\" ]; then")
    shell("check PASS \"Script: $TRAIN_SCRIPT\"")
    shell("else")
    shell("check FAIL \"Script not found: $TRAIN_SCRIPT\"")
    shell("fi")

    // ④ No other training running
    shell("echo \"\"")
    shell("echo \"④ Conflict Check\"")
    shell("RUNNING=$(ps aux | grep \"python.*train\" | grep -v grep | grep -v preflight | wc -l | tr -d ' ')")
    shell("if [ \"$RUNNING\" = \"0\" ]; then")
    shell("check PASS \"No conflicting training processes\"")
    shell("else")
    shell("check FAIL \"$RUNNING training process(es) already running\"")
    shell("fi")

    // ⑤ 1K step validation
    shell("echo \"\"")
    shell("echo \"⑤ 1K Step Validation (takes ~2-5 min)\"")
    shell("echo \"  Running: python3 $TRAIN_SCRIPT --data $CORPUS --tokenizer $TOKENIZER --steps 1000 --log-every 100 --eval-every 500 --save-every 999999 $EXTRA_ARGS\"")
    shell("echo \"\"")

    shell("PYTHONUNBUFFERED=1 python3 \"$TRAIN_SCRIPT\" ")
    shell("--data \"$CORPUS\" ")
    shell("--tokenizer \"$TOKENIZER\" ")
    shell("--steps 1000 ")
    shell("--log-every 100 ")
    shell("--eval-every 500 ")
    shell("--save-every 999999 ")
    shell("--checkpoint /tmp/preflight_ckpt/ ")
    shell("$EXTRA_ARGS 2>&1 | tee /tmp/preflight_output.log")

    // Check output for NaN or errors
    shell("if grep -qi \"nan\" /tmp/preflight_output.log; then")
    shell("check FAIL \"NaN detected in training output!\"")
    shell("elif grep -qi \"error\\|traceback\" /tmp/preflight_output.log; then")
    shell("check FAIL \"Error detected in training output!\"")
    shell("else")
    shell("check PASS \"1K steps completed without NaN/errors\"")
    shell("fi")

    // Cleanup
    shell("rm -rf /tmp/preflight_ckpt/")

    // Summary
    shell("echo \"\"")
    shell("echo \"═══════════════════════════════════════════════════════\"")
    shell("echo \"  Results: $PASS passed, $FAIL failed\"")
    shell("if [ \"$FAIL\" -gt 0 ]; then")
    shell("echo \"  ❌ DO NOT LAUNCH — fix failures first\"")
    shell("exit 1")
    shell("else")
    shell("echo \"  ✅ ALL CLEAR — safe to launch full training\"")
    shell("fi")
    shell("echo \"═══════════════════════════════════════════════════════\"")
}
