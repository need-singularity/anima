// Ported from monitor_v3.sh
// Monitor v3 274M training on RunPod H100 | Usage: bash scripts/monitor_v3.sh [--poll N]  (poll every N seconds, default: show once)
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "monitor_v3.sh"

    // Monitor v3 274M training on RunPod H100
    // Usage: bash scripts/monitor_v3.sh [--poll N]  (poll every N seconds, default: show once)

    shell("SSH_KEY=~/.runpod/ssh/RunPod-Key-Go")
    shell("SSH_HOST=\"root@216.243.220.230\"")
    shell("SSH_PORT=18038")
    shell("SSH_CMD=\"ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o ConnectTimeout=10 $SSH_HOST -p $SSH_PORT\"")

    shell("POLL_INTERVAL=0")

    shell("while [[ \"$1\" ]]; do")
    shell("case \"$1\" in")
    shell("--poll) POLL_INTERVAL=\"$2\"; shift 2;;")
    shell("*) shift;;")
    shell("esac")
    shell("done")

    shell("check_status() {")
    shell("echo \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"")
    shell("echo \"  v3 274M Training Monitor — $(date '+%H:%M:%S')\"")
    shell("echo \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"")

    // Check pod status
    shell("POD_STATUS=$(/opt/homebrew/bin/runpodctl get pod 2>/dev/null | grep v13-train | awk '{print $2}')")
    shell("if [ -z \"$POD_STATUS\" ] || [ \"$POD_STATUS\" != \"RUNNING\" ]; then")
    shell("echo \"❌ Pod not running (status: ${POD_STATUS:-unknown})\"")
    shell("return 1")
    shell("fi")
    shell("echo \"✅ Pod: RUNNING ($2.69/hr)\"")

    // Get training log tail
    shell("echo \"\"")
    shell("echo \"📊 Latest training output:\"")
    shell("$SSH_CMD \"tail -30 /workspace/v3_train.log 2>/dev/null || tail -30 /workspace/nohup.out 2>/dev/null\" 2>/dev/null")

    // Get GPU status
    shell("echo \"\"")
    shell("echo \"🖥️  GPU Status:\"")
    shell("$SSH_CMD \"nvidia-smi --query-gpu=utilization.gpu,memory.used,memory.total,temperature.gpu --format=csv,noheader\" 2>/dev/null")

    // Get disk usage
    shell("echo \"\"")
    shell("echo \"💾 Disk:\"")
    shell("$SSH_CMD \"df -h /workspace | tail -1\" 2>/dev/null")

    // Get checkpoint info
    shell("echo \"\"")
    shell("echo \"📁 Latest checkpoints:\"")
    shell("$SSH_CMD \"ls -lhrt /workspace/checkpoints/v3_merged/*.pt 2>/dev/null | tail -5\" 2>/dev/null")

    shell("echo \"\"")
    shell("echo \"━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\"")
    shell("}")

    shell("if [ \"$POLL_INTERVAL\" -gt 0 ] 2>/dev/null; then")
    shell("while true; do")
    shell("clear")
    shell("check_status")
    shell("echo \"Next check in ${POLL_INTERVAL}s (Ctrl+C to stop)\"")
    shell("sleep \"$POLL_INTERVAL\"")
    shell("done")
    shell("else")
    shell("check_status")
    shell("fi")
}
