// roadmap.hexa — anima 로드맵 어댑터
//
// 외부접근 원칙: nexus CLI 독점. 직접 $NEXUS/tool/* 호출 금지.
// 사용: $HEXA scripts/roadmap.hexa [status|list|next|verify|artifacts|all]
//
// SSOT: config/roadmaps/anima.json (nexus 리포 내)

fn main() {
    let a = args()
    let cmd = if len(a) >= 3 { a[2] } else { "status" }

    // v2 subcmd 우선 (status|list|next), 그 외는 v1 roadmap-proj 위임
    let call = if cmd == "status" || cmd == "list" || cmd == "next" {
        "nexus roadmap-proj anima " + cmd + " --caller anima"
    } else {
        // verify/artifacts/all 등은 엔진 로드맵 서브커맨드
        "nexus roadmap " + cmd + " --project anima --caller anima"
    }
    let rc = to_string(exec(call))
    print(rc)
}

main()
