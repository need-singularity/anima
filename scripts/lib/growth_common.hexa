// Growth common library — shared helper functions for growth loop scripts
// Ported from growth_common.sh (symlink to nexus6, now standalone)
//
// Provides: log_info, log_warn, write_growth_bus, run_growth_loop
// Used by: infinite_growth.hexa and other growth scripts

fn log_info(msg: str) {
    var ts = timestamp()
    println("[{ts}] [INFO] {msg}")
}

fn log_warn(msg: str) {
    var ts = timestamp()
    println("[{ts}] [WARN] {msg}")
}

fn write_growth_bus(key: str, status: str, detail: str) {
    // Write a growth event to the shared growth bus file
    var bus_file = env("HOME") + "/Dev/anima/.growth/bus.jsonl"
    var ts = timestamp()
    var line = "{\"ts\": \"" + ts + "\", \"key\": \"" + key + "\", \"status\": \"" + status + "\", \"detail\": \"" + detail + "\"}"
    shell("echo '" + line + "' >> " + bus_file)
}

fn run_growth_loop(phase_fn: str) {
    // Load config from shared/loop/anima.json
    var config_path = env("HOME") + "/Dev/anima/shared/loop/anima.json"
    var max_cycles = 999
    var interval = 999

    log_info("Growth loop starting: max_cycles={max_cycles}, interval={interval}")

    for cycle in 0..max_cycles {
        log_info("=== Cycle {cycle + 1}/{max_cycles} ===")

        // Load factor (placeholder)
        var load = 0.0

        // Execute domain phases
        shell("echo 'Phase execution for cycle {cycle + 1}'")

        if cycle < max_cycles - 1 {
            log_info("Sleeping {interval}s before next cycle...")
            shell("sleep " + str(interval))
        }
    }

    log_info("Growth loop complete")
}
