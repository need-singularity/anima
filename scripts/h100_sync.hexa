// scripts/h100_sync.hexa — H100 code sync (Hexa wrapper, Phase 2d port)
// Original: scripts/h100_sync.sh (preserved for behavior parity)
// HEXA-FIRST: this is the canonical entry; .sh kept as backing implementation.
// Usage: hexa scripts/h100_sync.hexa [args...]

let home = exec("printenv HOME").trim()
let script = home + "/Dev/anima/scripts/h100_sync.sh"
let args = exec("printenv HEXA_ARGS").trim()
let cmd = "bash " + script + " " + args
let out = exec(cmd)
println(out)
