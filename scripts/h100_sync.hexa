// Ported from h100_sync.sh
// Sync local code to H100 RunPod pod | Usage: bash scripts/h100_sync.sh [--dry-run] [--verify-only]
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "h100_sync.sh"

    // Sync local code to H100 RunPod pod
    // Usage: bash scripts/h100_sync.sh [--dry-run] [--verify-only]
    // 
    // Transfer strategy (3-tier fallback):
    // 1. rsync  — fast, incremental, delta transfer
    // 2. scp    — file-by-file, works when rsync fails (read-only fs issue)
    // 3. cat|ssh cat > — always works, last resort (pipe transfer)
    // 
    // Reads SSH config from anima/config/runpod.json


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("REPO_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"")
    shell("CONFIG=\"$REPO_ROOT/anima/config/runpod.json\"")

    // ── Parse args ──
    shell("DRY_RUN=false")
    shell("VERIFY_ONLY=false")
    shell("for arg in \"$@\"; do")
    shell("case \"$arg\" in")
    shell("--dry-run) DRY_RUN=true ;;")
    shell("--verify-only) VERIFY_ONLY=true ;;")
    shell("esac")
    shell("done")

    // ── Load SSH config from runpod.json ──
    shell("if [ -f \"$CONFIG\" ]; then")
    // Extract values using python (available on macOS, no jq dependency)
    shell("SSH_KEY=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['ssh']['key'])\")")
    shell("SSH_KEY=\"${SSH_KEY/#\\~/$HOME}\"")
    shell("SSH_CMD=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['ssh']['command'])\")")
    // Parse host and port from ssh command: ssh -i KEY -o ... root@HOST -p PORT
    shell("HOST=$(echo \"$SSH_CMD\" | grep -oE 'root@[0-9.]+' | head -1)")
    shell("PORT=$(echo \"$SSH_CMD\" | grep -oE '\\-p [0-9]+' | awk '{print $2}')")
    shell("DEST=$(python3 -c \"import json; c=json.load(open('$CONFIG')); print(c['paths']['workspace'])\")")
    shell("echo \"[config] Loaded from $CONFIG\"")
    shell("echo \"  HOST=$HOST  PORT=$PORT  DEST=$DEST\"")
    shell("else")
    shell("echo \"[config] runpod.json not found, using defaults\"")
    shell("SSH_KEY=~/.runpod/ssh/RunPod-Key-Go")
    shell("HOST=root@216.243.220.230")
    shell("PORT=18038")
    shell("DEST=/workspace")
    shell("fi")

    shell("SSH_OPTS=\"-i $SSH_KEY -o StrictHostKeyChecking=no -p $PORT\"")

    // ── Define sync groups ──
    // Each group: LOCAL_DIR REMOTE_DIR INCLUDE_PATTERN LABEL
    shell("declare -a SYNC_GROUPS=(")
    shell("\"$REPO_ROOT/anima/src/|$DEST/|*.py *.json|src/\"")
    shell("\"$REPO_ROOT/anima/config/|$DEST/config/|*|config/\"")
    shell("\"$REPO_ROOT/anima/training/|$DEST/training/|*.py|training/*.py\"")
    shell("\"$REPO_ROOT/scripts/preflight_training.sh|$DEST/preflight_training.sh|single|preflight_training.sh\"")
    shell("\"$REPO_ROOT/scripts/merge_corpus.sh|$DEST/merge_corpus.sh|single|merge_corpus.sh\"")
    shell("\"$REPO_ROOT/scripts/h100_watchdog.sh|$DEST/h100_watchdog.sh|single|h100_watchdog.sh\"")
    shell("\"$REPO_ROOT/sub-projects/animalm/|$DEST/animalm/|*.py *.json|animalm/\"")
    shell("\"$REPO_ROOT/anima/benchmarks/bench.py|$DEST/bench.py|single|bench.py\"")
    shell("\"$REPO_ROOT/anima-core/conscious_chat.py|$DEST/conscious_chat.py|single|conscious_chat.py\"")
    shell(")")

    // ── Large file definitions (rsync with MD5 skip) ──
    shell("declare -a LARGE_FILES=(")
    shell("\"$REPO_ROOT/anima/data/corpus_multilingual/corpus_v11_multilingual.txt|$DEST/data/corpus_v11_multilingual.txt|corpus_v11_multilingual.txt\"")
    shell("\"$REPO_ROOT/anima/data/tokenizer_64k_multilingual.model|$DEST/data/tokenizer_64k_multilingual.model|tokenizer_64k_multilingual.model\"")
    shell(")")

    // ── Helper: collect files from a directory with includes ──
    shell("collect_files() {")
    shell("local dir=\"$1\"")
    shell("local includes=\"$2\"")
    shell("if [ \"$includes\" = \"*\" ]; then")
    shell("find \"$dir\" -maxdepth 3 -type f ! -name '*.pyc' ! -path '*__pycache__*' 2>/dev/null")
    shell("else")
    shell("for pat in $includes; do")
    shell("find \"$dir\" -maxdepth 3 -type f -name \"$pat\" ! -path '*__pycache__*' 2>/dev/null")
    shell("done")
    shell("fi")
    shell("}")

    // ── Transfer method 1: rsync ──
    shell("try_rsync() {")
    shell("local src=\"$1\" dst=\"$2\" label=\"$3\"")
    shell("echo \"  [rsync] $label\"")
    shell("if rsync -avz --progress ")
    shell("-e \"ssh $SSH_OPTS\" ")
    shell("--exclude='__pycache__/' --exclude='*.pyc' ")
    shell("\"$src\" \"$dst\" 2>&1; then")
    shell("return 0")
    shell("else")
    shell("echo \"  [rsync] FAILED for $label\"")
    shell("return 1")
    shell("fi")
    shell("}")

    // ── Transfer method 2: scp ──
    shell("try_scp() {")
    shell("local src=\"$1\" dst=\"$2\" label=\"$3\"")
    shell("echo \"  [scp] $label\"")

    // Single file
    shell("if [ -f \"$src\" ]; then")
    shell("if scp $SSH_OPTS \"$src\" \"$HOST:$dst\" 2>&1; then")
    shell("return 0")
    shell("else")
    shell("echo \"  [scp] FAILED for $label\"")
    shell("return 1")
    shell("fi")
    shell("fi")

    // Directory: file-by-file
    shell("local dir=\"$src\"")
    shell("local base_dir=\"${dir%/}\"")
    shell("local remote_base=\"${dst%/}\"")
    shell("local count=0")
    shell("local failed=0")

    // Ensure remote directory exists
    shell("ssh $SSH_OPTS \"$HOST\" \"mkdir -p '$remote_base'\" 2>/dev/null || true")

    shell("while IFS= read -r file; do")
    shell("local rel=\"${file#$base_dir/}\"")
    shell("local remote_dir")
    shell("remote_dir=$(dirname \"$remote_base/$rel\")")
    shell("ssh $SSH_OPTS \"$HOST\" \"mkdir -p '$remote_dir'\" 2>/dev/null || true")
    shell("if scp $SSH_OPTS \"$file\" \"$HOST:$remote_base/$rel\" 2>/dev/null; then")
    shell("count=$((count + 1))")
    shell("else")
    shell("failed=$((failed + 1))")
    shell("fi")
    shell("done < <(collect_files \"$base_dir\" \"*\")")

    shell("echo \"  [scp] $count files transferred, $failed failed\"")
    shell("[ \"$failed\" -eq 0 ] && return 0 || return 1")
    shell("}")

    // ── Transfer method 3: cat | ssh cat > (always works) ──
    shell("try_pipe() {")
    shell("local src=\"$1\" dst=\"$2\" label=\"$3\"")
    shell("echo \"  [pipe] $label (cat | ssh cat >)\"")

    // Single file
    shell("if [ -f \"$src\" ]; then")
    shell("ssh $SSH_OPTS \"$HOST\" \"mkdir -p '$(dirname \"$dst\")'\" 2>/dev/null || true")
    shell("if cat \"$src\" | ssh $SSH_OPTS \"$HOST\" \"cat > '$dst'\"; then")
    shell("return 0")
    shell("else")
    shell("echo \"  [pipe] FAILED for $label\"")
    shell("return 1")
    shell("fi")
    shell("fi")

    // Directory: file-by-file
    shell("local dir=\"${src%/}\"")
    shell("local remote_base=\"${dst%/}\"")
    shell("local count=0")
    shell("local failed=0")

    shell("while IFS= read -r file; do")
    shell("local rel=\"${file#$dir/}\"")
    shell("local remote_path=\"$remote_base/$rel\"")
    shell("ssh $SSH_OPTS \"$HOST\" \"mkdir -p '$(dirname \"$remote_path\")'\" 2>/dev/null || true")
    shell("if cat \"$file\" | ssh $SSH_OPTS \"$HOST\" \"cat > '$remote_path'\"; then")
    shell("count=$((count + 1))")
    shell("else")
    shell("failed=$((failed + 1))")
    shell("fi")
    shell("done < <(collect_files \"$dir\" \"*\")")

    shell("echo \"  [pipe] $count files transferred, $failed failed\"")
    shell("[ \"$failed\" -eq 0 ] && return 0 || return 1")
    shell("}")

    // ── Transfer with 3-tier fallback ──
    shell("transfer() {")
    shell("local src=\"$1\" dst=\"$2\" label=\"$3\"")

    shell("if $DRY_RUN; then")
    shell("echo \"  [dry-run] Would transfer: $src -> $HOST:$dst\"")
    shell("return 0")
    shell("fi")

    // Tier 1: rsync
    shell("if try_rsync \"$src\" \"$HOST:$dst\" \"$label\"; then")
    shell("return 0")
    shell("fi")

    shell("echo \"  >> rsync failed, falling back to scp...\"")

    // Tier 2: scp
    shell("if try_scp \"$src\" \"$dst\" \"$label\"; then")
    shell("return 0")
    shell("fi")

    shell("echo \"  >> scp failed, falling back to pipe transfer...\"")

    // Tier 3: cat | ssh cat >
    shell("if try_pipe \"$src\" \"$dst\" \"$label\"; then")
    shell("return 0")
    shell("fi")

    shell("echo \"  [ERROR] All 3 transfer methods failed for $label\"")
    shell("return 1")
    shell("}")

    // ── Large file transfer (rsync + MD5 skip) ──
    shell("transfer_large_file() {")
    shell("local src=\"$1\" dst=\"$2\" label=\"$3\"")

    shell("if [ ! -f \"$src\" ]; then")
    shell("echo \"  [SKIP] $label — local file not found: $src\"")
    shell("return 1")
    shell("fi")

    shell("local file_size")
    shell("file_size=$(stat -f%z \"$src\" 2>/dev/null || stat -c%s \"$src\" 2>/dev/null || echo \"unknown\")")
    shell("local file_size_mb=\"unknown\"")
    shell("if [ \"$file_size\" != \"unknown\" ]; then")
    shell("file_size_mb=$(( file_size / 1048576 ))")
    shell("fi")
    shell("echo \"  File size: ${file_size_mb}MB\"")

    // Compute local MD5
    shell("local local_md5")
    shell("echo \"  Computing local MD5 (this may take a moment for large files)...\"")
    shell("local_md5=$(md5 -q \"$src\" 2>/dev/null || md5sum \"$src\" | awk '{print $1}')")
    shell("echo \"  Local  MD5: $local_md5\"")

    // Check remote MD5 — skip transfer if match
    shell("local remote_md5")
    shell("remote_md5=$(ssh $SSH_OPTS \"$HOST\" \"md5sum '$dst' 2>/dev/null | awk '{print \\$1}'\" 2>/dev/null || echo \"MISSING\")")
    shell("echo \"  Remote MD5: $remote_md5\"")

    shell("if [ \"$local_md5\" = \"$remote_md5\" ]; then")
    shell("echo \"  [SKIP] $label — remote file already matches (MD5 identical), skipping ${file_size_mb}MB transfer\"")
    shell("return 0")
    shell("fi")

    shell("echo \"  [TRANSFER] $label — MD5 mismatch or missing, transferring ${file_size_mb}MB...\"")

    shell("if $DRY_RUN; then")
    shell("echo \"  [dry-run] Would transfer: $src -> $HOST:$dst (${file_size_mb}MB)\"")
    shell("return 0")
    shell("fi")

    // Ensure remote directory exists
    shell("local remote_dir")
    shell("remote_dir=$(dirname \"$dst\")")
    shell("ssh $SSH_OPTS \"$HOST\" \"mkdir -p '$remote_dir'\" 2>/dev/null || true")

    // Use rsync with progress + compression for large files
    shell("if rsync -avz --progress --partial ")
    shell("-e \"ssh $SSH_OPTS\" ")
    shell("\"$src\" \"$HOST:$dst\" 2>&1; then")
    // Verify after transfer
    shell("echo \"  Verifying transfer...\"")
    shell("local verify_md5")
    shell("verify_md5=$(ssh $SSH_OPTS \"$HOST\" \"md5sum '$dst' 2>/dev/null | awk '{print \\$1}'\" 2>/dev/null || echo \"FAILED\")")
    shell("if [ \"$local_md5\" = \"$verify_md5\" ]; then")
    shell("echo \"  [OK] $label — transfer verified (MD5 match)\"")
    shell("return 0")
    shell("else")
    shell("echo \"  [ERROR] $label — MD5 mismatch after transfer! local=$local_md5 remote=$verify_md5\"")
    shell("return 1")
    shell("fi")
    shell("else")
    shell("echo \"  [ERROR] rsync failed for $label, trying scp...\"")
    shell("if scp $SSH_OPTS \"$src\" \"$HOST:$dst\" 2>&1; then")
    shell("local verify_md5")
    shell("verify_md5=$(ssh $SSH_OPTS \"$HOST\" \"md5sum '$dst' 2>/dev/null | awk '{print \\$1}'\" 2>/dev/null || echo \"FAILED\")")
    shell("if [ \"$local_md5\" = \"$verify_md5\" ]; then")
    shell("echo \"  [OK] $label — scp transfer verified (MD5 match)\"")
    shell("return 0")
    shell("else")
    shell("echo \"  [ERROR] $label — MD5 mismatch after scp! local=$local_md5 remote=$verify_md5\"")
    shell("return 1")
    shell("fi")
    shell("else")
    shell("echo \"  [ERROR] All transfer methods failed for $label\"")
    shell("return 1")
    shell("fi")
    shell("fi")
    shell("}")

    // ── MD5 verification ──
    shell("verify_md5() {")
    shell("local src=\"$1\" dst=\"$2\" label=\"$3\"")
    shell("echo \"\"")
    shell("echo \"[verify] $label — md5 comparison\"")

    shell("local mismatches=0")
    shell("local checked=0")

    // Single file
    shell("if [ -f \"$src\" ]; then")
    shell("local local_md5")
    shell("local_md5=$(md5 -q \"$src\" 2>/dev/null || md5sum \"$src\" | awk '{print $1}')")
    shell("local remote_md5")
    shell("remote_md5=$(ssh $SSH_OPTS \"$HOST\" \"md5sum '$dst' 2>/dev/null | awk '{print \\$1}'\" 2>/dev/null || echo \"MISSING\")")

    shell("if [ \"$local_md5\" = \"$remote_md5\" ]; then")
    shell("echo \"  OK  $(basename \"$src\")\"")
    shell("else")
    shell("echo \"  MISMATCH  $(basename \"$src\")  local=$local_md5  remote=$remote_md5\"")
    shell("mismatches=$((mismatches + 1))")
    shell("fi")
    shell("checked=1")
    shell("else")
    // Directory
    shell("local dir=\"${src%/}\"")
    shell("local remote_base=\"${dst%/}\"")

    shell("while IFS= read -r file; do")
    shell("local rel=\"${file#$dir/}\"")
    shell("local local_md5")
    shell("local_md5=$(md5 -q \"$file\" 2>/dev/null || md5sum \"$file\" | awk '{print $1}')")
    shell("local remote_md5")
    shell("remote_md5=$(ssh $SSH_OPTS \"$HOST\" \"md5sum '$remote_base/$rel' 2>/dev/null | awk '{print \\$1}'\" 2>/dev/null || echo \"MISSING\")")

    shell("if [ \"$local_md5\" = \"$remote_md5\" ]; then")
    shell("checked=$((checked + 1))")
    shell("else")
    shell("echo \"  MISMATCH  $rel  local=$local_md5  remote=$remote_md5\"")
    shell("mismatches=$((mismatches + 1))")
    shell("checked=$((checked + 1))")
    shell("fi")
    shell("done < <(collect_files \"$dir\" \"*\")")
    shell("fi")

    shell("if [ \"$mismatches\" -eq 0 ]; then")
    shell("echo \"  All $checked files verified OK\"")
    shell("else")
    shell("echo \"  WARNING: $mismatches/$checked files mismatched!\"")
    shell("fi")
    shell("return \"$mismatches\"")
    shell("}")

    // ── Main ──
    shell("echo \"========================================\"")
    shell("echo \" H100 Sync — 3-tier fallback + md5\"")
    shell("echo \"========================================\"")
    shell("echo \"\"")

    shell("TOTAL_ERRORS=0")

    shell("if ! $VERIFY_ONLY; then")
    // Transfer: src/
    shell("echo \"[1/6] Syncing src/ to H100...\"")
    shell("transfer \"$REPO_ROOT/anima/src/\" \"$DEST/\" \"src/\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")

    // Transfer: config/
    shell("echo \"\"")
    shell("echo \"[2/6] Syncing config/...\"")
    shell("transfer \"$REPO_ROOT/anima/config/\" \"$DEST/config/\" \"config/\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")

    // Transfer: training scripts (all training/*.py)
    shell("echo \"\"")
    shell("echo \"[3/6] Syncing training/*.py...\"")
    shell("transfer \"$REPO_ROOT/anima/training/\" \"$DEST/training/\" \"training/*.py\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")

    // Transfer: operational scripts
    shell("echo \"\"")
    shell("echo \"[4/6] Syncing operational scripts...\"")
    shell("transfer \"$REPO_ROOT/scripts/preflight_training.sh\" \"$DEST/preflight_training.sh\" \"preflight_training.sh\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")
    shell("transfer \"$REPO_ROOT/scripts/merge_corpus.sh\" \"$DEST/merge_corpus.sh\" \"merge_corpus.sh\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")
    shell("transfer \"$REPO_ROOT/scripts/h100_watchdog.sh\" \"$DEST/h100_watchdog.sh\" \"h100_watchdog.sh\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")
    shell("transfer \"$REPO_ROOT/sub-projects/animalm/\" \"$DEST/animalm/\" \"animalm/\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")
    shell("transfer \"$REPO_ROOT/anima/benchmarks/bench.py\" \"$DEST/bench.py\" \"bench.py\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")
    shell("transfer \"$REPO_ROOT/anima-core/conscious_chat.py\" \"$DEST/conscious_chat.py\" \"conscious_chat.py\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")

    // Transfer: tokenizer (small, normal transfer)
    shell("echo \"\"")
    shell("echo \"[5/6] Syncing tokenizer...\"")
    shell("ssh $SSH_OPTS \"$HOST\" \"mkdir -p '$DEST/data'\" 2>/dev/null || true")
    shell("transfer_large_file ")
    shell("\"$REPO_ROOT/anima/data/tokenizer_64k_multilingual.model\" ")
    shell("\"$DEST/data/tokenizer_64k_multilingual.model\" ")
    shell("\"tokenizer_64k_multilingual.model\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")

    // Transfer: corpus_v11 (10.5GB — MD5 skip if already present)
    shell("echo \"\"")
    shell("echo \"[6/6] Syncing corpus_v11_multilingual.txt (10.5GB — will skip if MD5 matches)...\"")
    shell("transfer_large_file ")
    shell("\"$REPO_ROOT/anima/data/corpus_multilingual/corpus_v11_multilingual.txt\" ")
    shell("\"$DEST/data/corpus_v11_multilingual.txt\" ")
    shell("\"corpus_v11_multilingual.txt\" || TOTAL_ERRORS=$((TOTAL_ERRORS + 1))")
    shell("fi")

    // MD5 verification (sample key files)
    shell("echo \"\"")
    shell("echo \"========================================\"")
    shell("echo \" MD5 Verification\"")
    shell("echo \"========================================\"")

    shell("VERIFY_ERRORS=0")
    shell("verify_md5 \"$REPO_ROOT/anima/src/consciousness_engine.py\" \"$DEST/consciousness_engine.py\" \"consciousness_engine.py\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/anima/src/trinity.py\" \"$DEST/trinity.py\" \"trinity.py\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/anima/src/conscious_decoder.py\" \"$DEST/conscious_decoder.py\" \"conscious_decoder.py\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/anima/training/train_clm.py\" \"$DEST/training/train_clm.py\" \"train_clm.py\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/anima/config/consciousness_laws.json\" \"$DEST/config/consciousness_laws.json\" \"consciousness_laws.json\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/anima/data/tokenizer_64k_multilingual.model\" \"$DEST/data/tokenizer_64k_multilingual.model\" \"tokenizer_64k_multilingual.model\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/anima/data/corpus_multilingual/corpus_v11_multilingual.txt\" \"$DEST/data/corpus_v11_multilingual.txt\" \"corpus_v11_multilingual.txt\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/scripts/preflight_training.sh\" \"$DEST/preflight_training.sh\" \"preflight_training.sh\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/scripts/merge_corpus.sh\" \"$DEST/merge_corpus.sh\" \"merge_corpus.sh\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")
    shell("verify_md5 \"$REPO_ROOT/scripts/h100_watchdog.sh\" \"$DEST/h100_watchdog.sh\" \"h100_watchdog.sh\" || VERIFY_ERRORS=$((VERIFY_ERRORS + 1))")

    shell("echo \"\"")
    shell("echo \"========================================\"")
    shell("if [ \"$TOTAL_ERRORS\" -eq 0 ] && [ \"$VERIFY_ERRORS\" -eq 0 ]; then")
    shell("echo \" DONE — All files synced and verified\"")
    shell("else")
    shell("echo \" DONE — $TOTAL_ERRORS transfer errors, $VERIFY_ERRORS verification mismatches\"")
    shell("fi")
    shell("echo \" Target: $HOST:$DEST\"")
    shell("echo \"========================================\"")
}
