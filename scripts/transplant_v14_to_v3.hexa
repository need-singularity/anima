// scripts/transplant_v14_to_v3.hexa — Hexa wrapper (Phase 2d port of transplant_v14_to_v3.sh)
// HEXA-FIRST: canonical entry; .sh kept as backing implementation for behavior parity.
// Usage: hexa scripts/transplant_v14_to_v3.hexa  (forwards $HEXA_ARGS to bash script)

let home = exec("printenv HOME").trim()
let script = home + "/Dev/anima/scripts/transplant_v14_to_v3.sh"
let args = exec("printenv HEXA_ARGS").trim()
let out = exec("bash " + script + " " + args)
println(out)
