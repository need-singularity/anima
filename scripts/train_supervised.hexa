// Ported from train_supervised.sh
// train_supervised.sh — Immortal training wrapper (survives tmux death) | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "train_supervised.sh"

    // train_supervised.sh — Immortal training wrapper (survives tmux death)
    // 
    // Wraps any training script in a while-true loop with auto-resume.
    // When the training process dies (OOM, crash, tmux kill), it:
    // 1. Finds the latest checkpoint
    // 2. Checks GPU VRAM availability
    // 3. Waits 30s cooldown
    // 4. Restarts with --resume <latest_checkpoint>
    // 5. After 5 consecutive failures, writes alert and stops
    // 
    // Usage:
    // bash train_supervised.sh train_clm.py --data corpus.txt --scale 100m
    // bash train_supervised.sh train_clm.py --data corpus.txt --scale 1b --steps 300000
    // 
    // The script passes ALL arguments after the training script name directly to python.
    // It automatically adds --resume <latest_checkpoint> on restarts.
    // 
    // Best practice: run inside tmux, PLUS install watchdog crontab:
    // tmux new-session -d -s train "bash train_supervised.sh train_clm.py --data corpus.txt --scale 100m"
    // bash train_watchdog.sh --install   # crontab backup if tmux dies


    // ── Configuration ──
    shell("PYTHON=\"${PYTHON:-/opt/conda/bin/python3}\"")
    shell("WORKSPACE=\"${WORKSPACE:-/workspace/anima}\"")
    shell("TRAINING_DIR=\"$WORKSPACE/anima/training\"")
    shell("CKPT_BASE=\"${CKPT_BASE:-$WORKSPACE/checkpoints}\"")
    shell("LOG_DIR=\"$WORKSPACE\"")
    shell("MAX_CONSECUTIVE_FAILS=5")
    shell("COOLDOWN=30")
    shell("ALERT_FILE=\"$WORKSPACE/training_alert.txt\"")

    // ── Parse arguments ──
    shell("if [ $# -lt 1 ]; then")
    shell("echo \"Usage: $0 <train_script.py> [training args...]\"")
    shell("echo \"\"")
    shell("echo \"Examples:\"")
    shell("echo \"  $0 train_clm.py --data data/corpus_v10_ko.txt --scale 100m\"")
    shell("echo \"  $0 train_clm.py --data data/corpus_v10_ko.txt --scale 1b --steps 300000\"")
    shell("echo \"\"")
    shell("echo \"Environment:\"")
    shell("echo \"  PYTHON=$PYTHON\"")
    shell("echo \"  WORKSPACE=$WORKSPACE\"")
    shell("echo \"  CKPT_BASE=$CKPT_BASE\"")
    shell("exit 1")
    shell("fi")

    shell("TRAIN_SCRIPT=\"$1\"")
    shell("shift")
    shell("TRAIN_ARGS=(\"$@\")")

    // Resolve training script path
    shell("if [ ! -f \"$TRAIN_SCRIPT\" ]; then")
    shell("if [ -f \"$TRAINING_DIR/$TRAIN_SCRIPT\" ]; then")
    shell("TRAIN_SCRIPT=\"$TRAINING_DIR/$TRAIN_SCRIPT\"")
    shell("else")
    shell("echo \"ERROR: Training script not found: $TRAIN_SCRIPT\"")
    shell("echo \"  Tried: ./$TRAIN_SCRIPT and $TRAINING_DIR/$TRAIN_SCRIPT\"")
    shell("exit 1")
    shell("fi")
    shell("fi")

    // ── Determine checkpoint directory from args ──
    shell("CKPT_DIR=\"$CKPT_BASE/v15_1b\"  # Default")
    shell("for i in \"${!TRAIN_ARGS[@]}\"; do")
    shell("if [ \"${TRAIN_ARGS[$i]}\" = \"--checkpoint\" ] && [ $((i+1)) -lt ${#TRAIN_ARGS[@]} ]; then")
    shell("CKPT_DIR=\"${TRAIN_ARGS[$((i+1))]}\"")
    shell("fi")
    shell("done")

    // ── Logging ──
    shell("LOGFILE=\"$LOG_DIR/train_supervised.log\"")
    shell("log() {")
    shell("local msg=\"[$(date '+%Y-%m-%d %H:%M:%S')] [supervised] $1\"")
    shell("echo \"$msg\" | tee -a \"$LOGFILE\"")
    shell("}")

    // ── GPU VRAM check ──
    shell("wait_for_gpu() {")
    shell("local attempts=0")
    shell("local max_attempts=30  # 30 * 10s = 5 minutes max wait")

    shell("while [ $attempts -lt $max_attempts ]; do")
    shell("if ! command -v nvidia-smi &> /dev/null; then")
    shell("log \"WARNING: nvidia-smi not available, skipping GPU check\"")
    shell("return 0")
    shell("fi")

    shell("local gpu_info")
    shell("gpu_info=$(nvidia-smi --query-gpu=memory.free,memory.total,utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -1)")
    shell("if [ -z \"$gpu_info\" ]; then")
    shell("log \"WARNING: Could not query GPU. Proceeding anyway.\"")
    shell("return 0")
    shell("fi")

    shell("local free_mb")
    shell("free_mb=$(echo \"$gpu_info\" | cut -d',' -f1 | tr -d ' ')")
    shell("local total_mb")
    shell("total_mb=$(echo \"$gpu_info\" | cut -d',' -f2 | tr -d ' ')")
    shell("local util")
    shell("util=$(echo \"$gpu_info\" | cut -d',' -f3 | tr -d ' ')")

    // H100 80GB: need at least 60GB free for 1B training
    shell("if [ \"$free_mb\" -gt 10240 ]; then")
    shell("log \"GPU ready: ${free_mb}MB free / ${total_mb}MB total, ${util}% util\"")
    shell("return 0")
    shell("fi")

    shell("attempts=$((attempts + 1))")
    shell("log \"GPU busy: ${free_mb}MB free (need >10GB). Waiting... ($attempts/$max_attempts)\"")

    // Kill any zombie python processes hogging GPU
    shell("if [ $attempts -eq 5 ]; then")
    shell("log \"Checking for zombie processes...\"")
    shell("local zombies")
    shell("zombies=$(ps aux | grep \"python.*train\" | grep -v grep | grep -v \"$$\" | awk '{print $2}')")
    shell("if [ -n \"$zombies\" ]; then")
    shell("log \"Found zombie training processes: $zombies\"")
    shell("echo \"$zombies\" | xargs kill -9 2>/dev/null || true")
    shell("sleep 5")
    shell("fi")
    shell("fi")

    shell("sleep 10")
    shell("done")

    shell("log \"WARNING: GPU did not free up after 5 minutes. Attempting start anyway.\"")
    shell("return 0")
    shell("}")

    // ── Find latest checkpoint ──
    shell("find_latest_checkpoint() {")
    shell("local latest=\"\"")
    shell("local latest_step=-1")

    shell("if [ ! -d \"$CKPT_DIR\" ]; then")
    shell("echo \"\"")
    shell("return")
    shell("fi")

    // Search step_*.pt in all subdirs
    shell("while IFS= read -r f; do")
    shell("local base")
    shell("base=$(basename \"$f\")")
    shell("local step_num")
    shell("step_num=$(echo \"$base\" | sed -n 's/step_\\([0-9]*\\)\\.pt/\\1/p')")
    shell("if [ -n \"$step_num\" ] && [ \"$step_num\" -gt \"$latest_step\" ]; then")
    shell("latest_step=$step_num")
    shell("latest=\"$f\"")
    shell("fi")
    shell("done < <(find \"$CKPT_DIR\" -name \"step_*.pt\" 2>/dev/null)")

    // Fallback: best.pt
    shell("if [ -z \"$latest\" ]; then")
    shell("latest=$(find \"$CKPT_DIR\" -name \"best.pt\" 2>/dev/null | head -1)")
    shell("fi")

    // Fallback: final.pt
    shell("if [ -z \"$latest\" ]; then")
    shell("latest=$(find \"$CKPT_DIR\" -name \"final.pt\" 2>/dev/null | head -1)")
    shell("fi")

    shell("echo \"$latest\"")
    shell("}")

    // ── Check if --resume already in args ──
    shell("has_resume_arg() {")
    shell("for arg in \"${TRAIN_ARGS[@]}\"; do")
    shell("if [ \"$arg\" = \"--resume\" ]; then")
    shell("return 0")
    shell("fi")
    shell("done")
    shell("return 1")
    shell("}")

    // ── Main loop ──
    shell("echo \"═══════════════════════════════════════════════════\"")
    shell("echo \"  Train Supervised — Immortal Training Wrapper\"")
    shell("echo \"═══════════════════════════════════════════════════\"")
    shell("echo \"\"")
    shell("echo \"  Script:     $TRAIN_SCRIPT\"")
    shell("echo \"  Args:       ${TRAIN_ARGS[*]}\"")
    shell("echo \"  Python:     $PYTHON\"")
    shell("echo \"  Ckpt dir:   $CKPT_DIR\"")
    shell("echo \"  Log:        $LOGFILE\"")
    shell("echo \"  Max fails:  $MAX_CONSECUTIVE_FAILS\"")
    shell("echo \"  Cooldown:   ${COOLDOWN}s\"")
    shell("echo \"\"")
    shell("log \"Starting supervised training\"")

    shell("consecutive_fails=0")
    shell("total_restarts=0")
    shell("first_run=true")

    shell("while true; do")
    // ── Build command ──
    shell("cmd_args=(\"${TRAIN_ARGS[@]}\")")

    // On restart (not first run), add --resume if not already specified
    shell("if [ \"$first_run\" = false ] && ! has_resume_arg; then")
    shell("local_ckpt=$(find_latest_checkpoint)")
    shell("if [ -n \"$local_ckpt\" ]; then")
    shell("cmd_args+=(\"--resume\" \"$local_ckpt\")")
    shell("log \"Auto-resume from: $local_ckpt\"")
    shell("else")
    shell("log \"No checkpoint found for resume. Starting fresh.\"")
    shell("fi")
    shell("fi")

    // ── Pre-flight checks ──
    shell("wait_for_gpu")

    // ── Launch ──
    shell("log \"Launching training (run #$((total_restarts + 1)))...\"")
    shell("log \"  $PYTHON -u $TRAIN_SCRIPT ${cmd_args[*]}\"")

    shell("start_time=$(date +%s)")

    // Run with unbuffered output
    shell("set +e")
    shell("PYTHONUNBUFFERED=1 \"$PYTHON\" -u \"$TRAIN_SCRIPT\" \"${cmd_args[@]}\" 2>&1 | tee -a \"$LOG_DIR/train_output.log\"")
    shell("exit_code=${PIPESTATUS[0]}")

    shell("end_time=$(date +%s)")
    shell("duration=$((end_time - start_time))")
    shell("duration_human=$(printf '%dh %dm %ds' $((duration/3600)) $((duration%3600/60)) $((duration%60)))")

    shell("first_run=false")

    // ── Analyze exit ──
    shell("case $exit_code in")
    shell("0)")
    shell("log \"Training completed successfully (duration: $duration_human)\"")
    shell("log \"Total restarts: $total_restarts\"")
    shell("exit 0")
    shell(";;")
    shell("130|143)")
    // SIGINT (Ctrl+C) or SIGTERM — clean stop
    shell("log \"Training stopped by signal (code $exit_code, duration: $duration_human)\"")
    shell("exit 0")
    shell(";;")
    shell("137)")
    // SIGKILL — usually OOM
    shell("log \"Training KILLED (OOM? code 137, duration: $duration_human)\"")
    shell(";;")
    shell("*)")
    shell("log \"Training CRASHED (code $exit_code, duration: $duration_human)\"")
    shell(";;")
    shell("esac")

    // ── Failure tracking ──
    // If it ran for more than 5 minutes, reset fail counter (it was working)
    shell("if [ $duration -gt 300 ]; then")
    shell("consecutive_fails=0")
    shell("log \"Process ran for $duration_human — resetting failure counter\"")
    shell("else")
    shell("consecutive_fails=$((consecutive_fails + 1))")
    shell("log \"Process died quickly ($duration_human) — consecutive fails: $consecutive_fails/$MAX_CONSECUTIVE_FAILS\"")
    shell("fi")

    shell("total_restarts=$((total_restarts + 1))")

    // ── Too many failures? ──
    shell("if [ $consecutive_fails -ge $MAX_CONSECUTIVE_FAILS ]; then")
    shell("local alert_msg=\"FATAL: $MAX_CONSECUTIVE_FAILS consecutive quick failures. Manual intervention required.\"")
    shell("log \"$alert_msg\"")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $alert_msg\" >> \"$ALERT_FILE\"")
    shell("echo \"  Total restarts: $total_restarts\" >> \"$ALERT_FILE\"")
    shell("echo \"  Last exit code: $exit_code\" >> \"$ALERT_FILE\"")
    shell("exit 1")
    shell("fi")

    // ── Cooldown ──
    shell("log \"Waiting ${COOLDOWN}s before restart...\"")
    shell("sleep $COOLDOWN")
    shell("done")
}
