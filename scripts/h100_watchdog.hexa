// Ported from h100_watchdog.sh
// ═══════════════════════════════════════════════════════════════════════ | h100_watchdog.sh — Restart stale H100 training sessions
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "h100_watchdog.sh"

    // ═══════════════════════════════════════════════════════════════════════
    // h100_watchdog.sh — Restart stale H100 training sessions
    // 
    // Cron: */5 * * * * bash ~/anima/scripts/h100_watchdog.sh >> ~/anima/scripts/watchdog.log 2>&1
    // 
    // Checks heartbeat files written by train_clm.py every 100 steps.
    // If heartbeat is older than 600s (10 min), training is assumed stale.
    // Kills the tmux session and restarts.
    // ═══════════════════════════════════════════════════════════════════════


    shell("ANIMA_DIR=\"${ANIMA_DIR:-$(cd \"$(dirname \"$0\")/..\" && pwd)}\"")
    shell("STALE_THRESHOLD=600  # seconds")

    shell("check_session() {")
    shell("local session_name=\"$1\"")
    shell("local heartbeat_path=\"$2\"")
    shell("local restart_cmd=\"$3\"")

    shell("if [ ! -f \"$heartbeat_path\" ]; then")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] No heartbeat file at $heartbeat_path\"")
    shell("return")
    shell("fi")

    // Get file age (macOS: stat -f %m, Linux: stat -c %Y)
    shell("local mtime")
    shell("mtime=$(stat -c %Y \"$heartbeat_path\" 2>/dev/null || stat -f %m \"$heartbeat_path\" 2>/dev/null)")
    shell("if [ -z \"$mtime\" ]; then")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] Cannot stat heartbeat\"")
    shell("return")
    shell("fi")

    shell("local now")
    shell("now=$(date +%s)")
    shell("local age=$((now - mtime))")

    shell("if [ \"$age\" -gt \"$STALE_THRESHOLD\" ]; then")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] STALE (${age}s > ${STALE_THRESHOLD}s)\"")

    // Read last heartbeat content for logging
    shell("cat \"$heartbeat_path\" 2>/dev/null")

    // Kill existing tmux session
    shell("if tmux has-session -t \"$session_name\" 2>/dev/null; then")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] Killing tmux session...\"")
    shell("tmux kill-session -t \"$session_name\"")
    shell("sleep 2")
    shell("fi")

    // Restart
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] Restarting...\"")
    shell("eval \"$restart_cmd\"")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] Restarted.\"")
    shell("else")
    shell("echo \"[$(date '+%Y-%m-%d %H:%M:%S')] [$session_name] OK (age=${age}s)\"")
    shell("fi")
    shell("}")

    // ── Check v3_train session ──
    shell("check_session \"v3_train\" ")
    shell("\"$ANIMA_DIR/checkpoints/v3_274M/heartbeat.txt\" ")
    shell("\"tmux new-session -d -s v3_train 'cd $ANIMA_DIR && PYTHONUNBUFFERED=1 PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True python3 -u anima/training/train_clm.py --data anima/data/corpus_v9.txt --decoder v3 --federated --atoms 8 --cells-per-atom 8 --steps 200000 --checkpoint checkpoints/v3_274M/ --phase-optimal --batch-size 64 --block-size 512 --lr 3e-4 --resume checkpoints/v3_274M/best.pt 2>&1 | tee -a checkpoints/v3_274M/train.log'\"")

    // ── Check v14_128c session ──
    shell("check_session \"v14_128c\" ")
    shell("\"$ANIMA_DIR/checkpoints/v14_128c/heartbeat.txt\" ")
    shell("\"tmux new-session -d -s v14_128c 'cd $ANIMA_DIR && PYTHONUNBUFFERED=1 PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True python3 -u anima/training/train_clm.py --data anima/data/corpus_v9.txt --federated --atoms 16 --cells-per-atom 8 --steps 100000 --checkpoint checkpoints/v14_128c/ --phase-optimal --batch-size 32 --block-size 256 --lr 3e-4 --resume checkpoints/v14_128c/best.pt 2>&1 | tee -a checkpoints/v14_128c/train.log'\"")
}
