// hexa_native_build.hexa — native compile driver for Ready hexa modules
//
// Usage:
//   hexa scripts/hexa_native_build.hexa <target.hexa> [out_bin]
//
// Pipeline:
//   1. stage runtime.c into /tmp (reused)
//   2. transpile: hexa_v2 <target.hexa> /tmp/<name>.c
//   3. compile:   clang -I <hexa-lang/self> /tmp/<name>.c -o <out_bin>
//   4. validate:  report exit codes
//
// Defaults (override via env):
//   HEXA_V2     = /Users/ghost/Dev/hexa-lang/self/native/hexa_v2
//   HEXA_RT_DIR = /Users/ghost/Dev/hexa-lang/self
//
// SSOT: refs hexa_v2 POC (1526 Ready modules — 93.7% of anima/*.hexa)

fn basename(p: string) -> string {
    let parts = split(p, "/")
    let n = len(parts)
    if n == 0 { return p }
    let last = parts[n - 1]
    let dot = rfind(last, ".")
    if dot < 0 { return last }
    return slice(last, 0, dot)
}

fn main(args: list) -> int {
    if len(args) < 1 {
        print("usage: hexa_native_build.hexa <target.hexa> [out_bin]")
        return 2
    }
    let target = args[0]
    let stem = basename(target)
    let out_c = "/tmp/hxb_" + stem + ".c"
    let out_bin = if len(args) >= 2 { args[1] } else { "/tmp/hxb_" + stem }

    let hexa_v2 = env_or("HEXA_V2",
        "/Users/ghost/Dev/hexa-lang/self/native/hexa_v2")
    let rt_dir = env_or("HEXA_RT_DIR",
        "/Users/ghost/Dev/hexa-lang/self")

    // 1. transpile
    let t_cmd = hexa_v2 + " " + target + " " + out_c
    let rc1 = shell(t_cmd)
    if rc1 != 0 {
        print("TRANSPILE_FAIL " + target + " rc=" + str(rc1))
        return 1
    }

    // 2. compile
    let c_cmd = "clang -O2 -I " + rt_dir + " " + out_c + " -o " + out_bin
    let rc2 = shell(c_cmd)
    if rc2 != 0 {
        print("COMPILE_FAIL " + target + " rc=" + str(rc2))
        return 1
    }

    print("PASS " + target + " -> " + out_bin)
    return 0
}
