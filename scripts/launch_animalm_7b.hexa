// scripts/launch_animalm_7b.hexa — Hexa wrapper (Phase 2d port of launch_animalm_7b.sh)
// HEXA-FIRST: canonical entry; .sh kept as backing implementation for behavior parity.
// Usage: hexa scripts/launch_animalm_7b.hexa  (forwards $HEXA_ARGS to bash script)

let home = exec("printenv HOME").trim()
let script = home + "/Dev/anima/scripts/launch_animalm_7b.sh"
let args = exec("printenv HEXA_ARGS").trim()
let out = exec("bash " + script + " " + args)
println(out)
