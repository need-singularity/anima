// Ported from sync_readme.sh
// Sync core_rules.json → README.md (AUTO markers) | Usage: bash anima-core/sync_readme.sh
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    // Sync core_rules.json → README.md (AUTO markers)
    // Usage: bash anima-core/sync_readme.sh

    shell("DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("JSON=\"$DIR/core_rules.json\"")
    shell("README=\"$DIR/README.md\"")

    shell("if [ ! -f \"$JSON\" ]; then echo \"Error: $JSON not found\"; exit 1; fi")
    shell("if [ ! -f \"$README\" ]; then echo \"Error: $README not found\"; exit 1; fi")

    shell("python3 -c \"")
    shell("import json, re")

    shell("json_path = '$JSON'")
    shell("readme_path = '$README'")

    shell("d = json.load(open(json_path))")
    shell("readme = open(readme_path).read()")

    // Sync verification_status
    shell("vs = d.get('verification_status', {})")
    shell("if vs:")
    shell("vs_json = json.dumps(vs, indent=2, ensure_ascii=False)")
    shell("marker = 'verification_status'")
    shell("start = f'<!-- AUTO:{marker}:START -->'")
    shell("end = f'<!-- AUTO:{marker}:END -->'")
    shell("pattern = re.escape(start) + r'.*?' + re.escape(end)")
    shell("replacement = f'{start}\\n\\`\\`\\`json\\n{vs_json}\\n\\`\\`\\`\\n{end}'")
    shell("if start in readme:")
    shell("readme = re.sub(pattern, replacement, readme, flags=re.DOTALL)")
    shell("print(f'  synced: {marker} ({len(vs.get(\\\"ossified\\\",{}))-1} ossified, {len(vs.get(\\\"stable\\\",{}))-1} stable, {len(vs.get(\\\"failed\\\",{}))-1} failed)')")

    shell("open(readme_path, 'w').write(readme)")
    shell("print('Done.')")
    shell("\"")
}
