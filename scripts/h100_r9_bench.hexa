// h100_r9_bench.hexa — single-shot H100 R9 measurement script
//
// Run on a fresh H100 pod after `git pull anima && git pull hexa-lang`.
// Compiles train_gpu_pure.hexa via the pure-hexa->C path, links with
// cuBLAS, runs the bench loop, prints BENCH_RESULT lines for parsing.
//
// Expected runtime: < 60 seconds total.
//
// Compare BENCH_RESULT lines to R8 entries in
//   shared/hexa-lang/ml-perf-tracker.json -> training.gpu.history
//
// Pass criteria:
//   - SGEMM 1024^3 TFLOPS within 2x of R8 36.41 (so >= 18, target >= 30)
//   - SGEMM 4096^3 TFLOPS within 1.5x of R8 52.29 (so >= 35, target >= 50)

fn main() {
    let anima_dir = env("ANIMA_DIR")
    if anima_dir == "" {
        anima_dir = "/root/anima"
    }
    let hexa_dir = env("HEXA_DIR")
    if hexa_dir == "" {
        hexa_dir = "/root/hexa-lang"
    }
    let hexa_bin = env("HEXA_BIN")
    if hexa_bin == "" {
        hexa_bin = hexa_dir + "/target/release/hexa"
    }
    let out_dir = env("OUT_DIR")
    if out_dir == "" {
        out_dir = "/tmp/r9_out"
    }

    exec("mkdir -p " + out_dir)

    println("=== R9 H100 bench: pure-hexa -> C -> cublas ===")
    exec("echo \"  pod      : $(hostname)\"")
    exec("echo \"  date     : $(date -u +%Y-%m-%dT%H:%M:%SZ)\"")
    println("  hexa     : " + hexa_bin)
    println("  anima    : " + anima_dir)
    println("  out_dir  : " + out_dir)
    exec("nvidia-smi --query-gpu=name,memory.free --format=csv,noheader | head -2")
    println("")

    // Step 1: hexa source -> pure C
    println("[1/4] Compiling hexa -> C ...")
    exec(hexa_bin + " " + hexa_dir + "/self/build_c.hexa " + anima_dir + "/training/train_gpu_pure.hexa " + out_dir + "/train_gpu_pure.c 2>&1 | tail -5")
    exec("ls -la " + out_dir + "/train_gpu_pure.c")

    // Step 2: cc + cuBLAS link
    println("")
    println("[2/4] Compiling C -> native binary with -lcudart -lcublas ...")
    exec("cc -O3 -Wno-implicit-function-declaration -I/usr/local/cuda/include -L/usr/local/cuda/lib64 " + out_dir + "/train_gpu_pure.c -lcudart -lcublas -o " + out_dir + "/train_gpu_pure 2>&1 | tail -10")
    exec("ls -la " + out_dir + "/train_gpu_pure")

    // Step 3: run + capture output
    println("")
    println("[3/4] Running pure-hexa GPU bench ...")
    exec("export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH && time " + out_dir + "/train_gpu_pure 2>&1 | tee " + out_dir + "/r9_output.txt")

    // Step 4: parse BENCH_RESULT lines + compare to R8
    println("")
    println("[4/4] Comparison to R8 interpreter baseline:")
    println("  R8 t2_gpu_bench (interpreter):")
    println("    SGEMM  512^3 -> 17.48 TFLOPS")
    println("    SGEMM 1024^3 -> 38.35 TFLOPS")
    println("    SGEMM 2048^3 -> 50.66 TFLOPS")
    println("    SGEMM 4096^3 -> 52.29 TFLOPS (78% util)")
    println("")
    println("  R9 train_gpu_pure (PURE NATIVE BINARY):")
    println("    SGEMM bench:")
    exec("grep 'BENCH_RESULT' " + out_dir + "/r9_output.txt || echo '    (no BENCH_RESULT lines found)'")
    println("")
    println("    Full layer forward (9 cublasSgemm + 3 sync per call):")
    exec("grep 'LAYER_RESULT' " + out_dir + "/r9_output.txt || echo '    (no LAYER_RESULT lines found)'")

    println("")
    println("  R8 baseline for comparison:")
    println("    train_gpu.hexa 8-layer 100M = 161,448 ms / step (interpreter)")
    println("    -> per layer = 20,180 ms")
    println("")
    println("  R9 target (100M layer shape: seq=128 dim=512 ff=1536):")
    // AUDIT 2026-04-20 (phantom sweep): "1000x speedup" is a PROJECTED TARGET,
    // not a measurement. No r9_output.txt log exists in training/bench/. Keep as
    // goal-post but do not cite as achieved result.
    println("    per_layer_ms << 20  -> 1000x speedup over interpreter per layer (TARGET)")
    println("")
    println("=== R9 DONE -- copy r9_output.txt back to ml-perf-tracker.json ===")
    exec("echo \"  scp root@<pod>:" + out_dir + "/r9_output.txt $ANIMA/shared/sessions/r9_output_$(date -u +%Y%m%dT%H%M%S).txt\"")
}

main()
