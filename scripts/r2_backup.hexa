// Ported from r2_backup.sh
// r2_backup.sh — Checkpoint backup to Cloudflare R2 | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "r2_backup.sh"

    // r2_backup.sh — Checkpoint backup to Cloudflare R2
    // 
    // Usage:
    // bash scripts/r2_backup.sh                          # upload v14_128c_final (all)
    // bash scripts/r2_backup.sh --best                   # best.pt only
    // bash scripts/r2_backup.sh --version v14_federated  # specific version
    // bash scripts/r2_backup.sh --list                   # list R2 contents
    // bash scripts/r2_backup.sh --prune --keep 3         # keep latest 3


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("ROOT=\"$(dirname \"$SCRIPT_DIR\")\"")

    // Default: v14_128c_final
    shell("VERSION=\"${VERSION:-v14_128c_final}\"")
    shell("BEST_ONLY=\"\"")
    shell("LIST_MODE=\"\"")
    shell("PRUNE_MODE=\"\"")
    shell("KEEP=3")

    shell("while [[ $# -gt 0 ]]; do")
    shell("case \"$1\" in")
    shell("--version|-v) VERSION=\"$2\"; shift 2 ;;")
    shell("--best|-b) BEST_ONLY=\"--best\"; shift ;;")
    shell("--list|-l) LIST_MODE=\"1\"; shift ;;")
    shell("--prune) PRUNE_MODE=\"1\"; shift ;;")
    shell("--keep) KEEP=\"$2\"; shift 2 ;;")
    shell("*) echo \"Unknown: $1\"; exit 1 ;;")
    shell("esac")
    shell("done")

    shell("echo \"=== Anima R2 Checkpoint Backup ===\"")
    shell("echo \"Root: $ROOT\"")
    shell("echo \"Date: $(date -u +%Y-%m-%dT%H:%M:%SZ)\"")

    shell("if [[ -n \"$LIST_MODE\" ]]; then")
    shell("python3 \"$SCRIPT_DIR/r2_upload.py\" --list --prefix checkpoints/")
    shell("exit 0")
    shell("fi")

    shell("if [[ -n \"$PRUNE_MODE\" ]]; then")
    shell("python3 \"$SCRIPT_DIR/r2_upload.py\" --prune --keep \"$KEEP\"")
    shell("exit 0")
    shell("fi")

    // Check checkpoint exists
    shell("CKPT_DIR=\"$ROOT/anima/checkpoints/$VERSION\"")
    shell("if [[ ! -d \"$CKPT_DIR\" ]]; then")
    shell("echo \"ERROR: Checkpoint dir not found: $CKPT_DIR\"")
    shell("echo \"Available:\"")
    shell("ls -d \"$ROOT/anima/checkpoints\"/*/ 2>/dev/null || echo \"  (none)\"")
    shell("exit 1")
    shell("fi")

    shell("echo \"Checkpoint: $VERSION\"")
    shell("echo \"Files:\"")
    shell("ls -lh \"$CKPT_DIR\"/*.pt 2>/dev/null || echo \"  (no .pt files)\"")
    shell("echo \"\"")

    // Upload
    shell("python3 \"$SCRIPT_DIR/r2_upload.py\" --checkpoint \"$VERSION\" $BEST_ONLY")

    shell("echo \"\"")
    shell("echo \"=== Backup complete ===\"")
    shell("echo \"Verify with: bash scripts/r2_backup.sh --list\"")
}
