// Ported from cleanup_old_runs.sh
// cleanup_old_runs.sh — Find and remove stale logs, .tmp files, __pycache__ dirs | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "cleanup_old_runs.sh"

    // cleanup_old_runs.sh — Find and remove stale logs, .tmp files, __pycache__ dirs
    // 
    // Usage: ./cleanup_old_runs.sh [--confirm]
    // Without --confirm: dry run (shows what would be deleted)
    // With --confirm:    actually deletes
    // 
    // Protected directories (never touched): .git, data/, checkpoints/, models/


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("PROJECT_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"")

    shell("CONFIRM=false")
    shell("if [ \"${1:-}\" = \"--confirm\" ]; then")
    shell("CONFIRM=true")
    shell("fi")

    shell("echo \"=== Cleanup Old Runs ===\"")
    shell("echo \"  Root: $PROJECT_ROOT\"")
    shell("echo \"  Mode: $( $CONFIRM && echo 'DELETE' || echo 'DRY RUN (use --confirm to delete)' )\"")
    shell("echo \"\"")

    shell("TOTAL_SIZE=0")

    // Helper: accumulate size in bytes
    shell("add_size() {")
    shell("local bytes")
    shell("bytes=$(du -sk \"$1\" 2>/dev/null | cut -f1)")
    shell("TOTAL_SIZE=$((TOTAL_SIZE + bytes))")
    shell("}")

    // --- 1. __pycache__ directories ---
    shell("echo \"--- __pycache__ directories ---\"")
    shell("pycache_count=0")
    shell("while IFS= read -r -d '' dir; do")
    shell("size=$(du -sh \"$dir\" 2>/dev/null | cut -f1)")
    shell("echo \"  $dir  ($size)\"")
    shell("add_size \"$dir\"")
    shell("pycache_count=$((pycache_count + 1))")
    shell("if $CONFIRM; then")
    shell("rm -rf \"$dir\"")
    shell("fi")
    shell("done < <(find \"$PROJECT_ROOT\" ")
    shell("-path \"$PROJECT_ROOT/.git\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/data\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/checkpoints\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/models\" -prune -o ")
    shell("-name \"__pycache__\" -type d -print0)")

    shell("if [ \"$pycache_count\" -eq 0 ]; then")
    shell("echo \"  (none found)\"")
    shell("fi")
    shell("echo \"\"")

    // --- 2. Stale .tmp files (older than 1 day) ---
    shell("echo \"--- Stale .tmp files (>1 day old) ---\"")
    shell("tmp_count=0")
    shell("while IFS= read -r -d '' f; do")
    shell("size=$(du -sh \"$f\" 2>/dev/null | cut -f1)")
    shell("echo \"  $f  ($size)\"")
    shell("add_size \"$f\"")
    shell("tmp_count=$((tmp_count + 1))")
    shell("if $CONFIRM; then")
    shell("rm -f \"$f\"")
    shell("fi")
    shell("done < <(find \"$PROJECT_ROOT\" ")
    shell("-path \"$PROJECT_ROOT/.git\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/data\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/checkpoints\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/models\" -prune -o ")
    shell("-name \"*.tmp\" -type f -mtime +1 -print0)")

    shell("if [ \"$tmp_count\" -eq 0 ]; then")
    shell("echo \"  (none found)\"")
    shell("fi")
    shell("echo \"\"")

    // --- 3. Old log files (>7 days) ---
    shell("echo \"--- Old log files (>7 days) ---\"")
    shell("log_count=0")
    shell("while IFS= read -r -d '' f; do")
    shell("size=$(du -sh \"$f\" 2>/dev/null | cut -f1)")
    shell("echo \"  $f  ($size)\"")
    shell("add_size \"$f\"")
    shell("log_count=$((log_count + 1))")
    shell("if $CONFIRM; then")
    shell("rm -f \"$f\"")
    shell("fi")
    shell("done < <(find \"$PROJECT_ROOT\" ")
    shell("-path \"$PROJECT_ROOT/.git\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/data\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/checkpoints\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/models\" -prune -o ")
    shell("\\( -name \"*.log\" -o -name \"*.log.*\" \\) -type f -mtime +7 -print0)")

    shell("if [ \"$log_count\" -eq 0 ]; then")
    shell("echo \"  (none found)\"")
    shell("fi")
    shell("echo \"\"")

    // --- 4. .pyc files outside __pycache__ ---
    shell("echo \"--- Stray .pyc files ---\"")
    shell("pyc_count=0")
    shell("while IFS= read -r -d '' f; do")
    shell("size=$(du -sh \"$f\" 2>/dev/null | cut -f1)")
    shell("echo \"  $f  ($size)\"")
    shell("add_size \"$f\"")
    shell("pyc_count=$((pyc_count + 1))")
    shell("if $CONFIRM; then")
    shell("rm -f \"$f\"")
    shell("fi")
    shell("done < <(find \"$PROJECT_ROOT\" ")
    shell("-path \"$PROJECT_ROOT/.git\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/data\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/checkpoints\" -prune -o ")
    shell("-path \"$PROJECT_ROOT/models\" -prune -o ")
    shell("-path \"*/__pycache__\" -prune -o ")
    shell("-name \"*.pyc\" -type f -print0)")

    shell("if [ \"$pyc_count\" -eq 0 ]; then")
    shell("echo \"  (none found)\"")
    shell("fi")
    shell("echo \"\"")

    // --- Summary ---
    shell("total_items=$((pycache_count + tmp_count + log_count + pyc_count))")
    shell("total_human=$(echo \"$TOTAL_SIZE\" | awk '{")
    shell("if ($1 >= 1048576) printf \"%.1f GB\", $1/1048576;")
    shell("else if ($1 >= 1024) printf \"%.1f MB\", $1/1024;")
    shell("else printf \"%d KB\", $1;")
    shell("}')")

    shell("echo \"=== Summary ===\"")
    shell("echo \"  __pycache__: $pycache_count dirs\"")
    shell("echo \"  .tmp files:  $tmp_count files\"")
    shell("echo \"  Old logs:    $log_count files\"")
    shell("echo \"  Stray .pyc:  $pyc_count files\"")
    shell("echo \"  Total:       $total_items items (~${total_human})\"")
    shell("echo \"\"")

    shell("if ! $CONFIRM && [ \"$total_items\" -gt 0 ]; then")
    shell("echo \"Run with --confirm to delete these items.\"")
    shell("fi")

    shell("echo \"Done.\"")
}
