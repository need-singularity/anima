// Ported from merge_corpus.sh
// Merge multilingual corpus files into a single training corpus | Usage: bash scripts/merge_corpus.sh [output_path]
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "merge_corpus.sh"

    // Merge multilingual corpus files into a single training corpus
    // Usage: bash scripts/merge_corpus.sh [output_path]
    // 
    // Shuffles all language files together for balanced training.

    shell("OUTPUT=\"${1:-anima/data/corpus_v11_multilingual.txt}\"")
    shell("CORPUS_DIR=\"anima/data/corpus_multilingual\"")

    shell("echo \"в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\"")
    shell("echo \"  Corpus Merger вЂ” Multilingual в†’ Single\"")
    shell("echo \"в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\"")

    // Check source files
    shell("echo \"\"")
    shell("echo \"Source files:\"")
    shell("for f in \"$CORPUS_DIR\"/*.txt; do")
    shell("lang=$(basename \"$f\" .txt)")
    shell("size=$(du -sh \"$f\" | awk '{print $1}')")
    shell("lines=$(wc -l < \"$f\")")
    shell("printf \"  %-6s  %6s  %'12d lines\\n\" \"$lang\" \"$size\" \"$lines\"")
    shell("done")

    shell("TOTAL_SIZE=$(du -sh \"$CORPUS_DIR\" | awk '{print $1}')")
    shell("echo \"  в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\"")
    shell("echo \"  Total:  $TOTAL_SIZE\"")
    shell("echo \"\"")

    // Merge
    shell("echo \"Merging to: $OUTPUT\"")
    shell("cat \"$CORPUS_DIR\"/*.txt > \"${OUTPUT}.unsorted\"")

    // Shuffle (important for training вЂ” prevents language clustering)
    shell("echo \"Shuffling...\"")
    shell("if command -v shuf &>/dev/null; then")
    shell("shuf \"${OUTPUT}.unsorted\" > \"$OUTPUT\"")
    shell("elif command -v gshuf &>/dev/null; then")
    shell("gshuf \"${OUTPUT}.unsorted\" > \"$OUTPUT\"")
    shell("else")
    // macOS fallback: awk shuffle
    shell("awk 'BEGIN{srand(42)} {print rand() \"\\t\" $0}' \"${OUTPUT}.unsorted\" | ")
    shell("sort -t$'\\t' -k1,1n | cut -f2- > \"$OUTPUT\"")
    shell("fi")

    shell("rm \"${OUTPUT}.unsorted\"")

    // Report
    shell("FINAL_SIZE=$(du -sh \"$OUTPUT\" | awk '{print $1}')")
    shell("FINAL_LINES=$(wc -l < \"$OUTPUT\")")
    shell("echo \"\"")
    shell("echo \"в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\"")
    shell("printf \"  Output: %s (%s, %'d lines)\\n\" \"$OUTPUT\" \"$FINAL_SIZE\" \"$FINAL_LINES\"")
    shell("echo \"  MD5: $(md5 -q \"$OUTPUT\")\"")
    shell("echo \"в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\"")
}
