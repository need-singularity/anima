// Preflight checklist (from runpod.json)
fn preflight(cfg: DeployConfig) -> bool {
    let has_host = cfg.host != ""
    let has_md5 = cfg.corpus_md5 != ""
    has_host
}

fn main() {
    let cfg = deploy_v13("10.0.0.1", 22)
    print("deploy " + cfg.version + " -> " + cfg.host + ":" + to_string(cfg.port))
    let ready = preflight(cfg)
    print("preflight: " + to_string(ready))
}
