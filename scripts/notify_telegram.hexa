// Ported from notify_telegram.sh
// notify_telegram.sh — Send training alerts via Telegram bot | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "notify_telegram.sh"

    // notify_telegram.sh — Send training alerts via Telegram bot
    // 
    // Uses the same bot as anima-agent/channels/telegram_bot.py
    // (ANIMA_TELEGRAM_TOKEN).
    // 
    // Environment:
    // TELEGRAM_BOT_TOKEN  — Bot token (required)
    // TELEGRAM_CHAT_ID    — Target chat/group ID (required)
    // 
    // Usage:
    // bash notify_telegram.sh "v3 crash - step 125K에서 resume"
    // bash notify_telegram.sh "학습 완료 - CE=0.004, Φ=71"
    // bash notify_telegram.sh --test   # send a test ping
    // 
    // Integration with train_watchdog.sh:
    // Called on crash detection and auto-resume events.


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")

    // ── Config ──
    shell("BOT_TOKEN=\"${TELEGRAM_BOT_TOKEN:-}\"")
    shell("CHAT_ID=\"${TELEGRAM_CHAT_ID:-}\"")
    shell("HOSTNAME=\"${HOSTNAME:-$(hostname 2>/dev/null || echo 'unknown')}\"")
    shell("TIMESTAMP=\"$(date '+%Y-%m-%d %H:%M:%S')\"")

    // ── Validate ──
    shell("if [ -z \"$BOT_TOKEN\" ]; then")
    shell("echo \"[notify_telegram] ERROR: TELEGRAM_BOT_TOKEN not set\"")
    shell("exit 1")
    shell("fi")

    shell("if [ -z \"$CHAT_ID\" ]; then")
    shell("echo \"[notify_telegram] ERROR: TELEGRAM_CHAT_ID not set\"")
    shell("exit 1")
    shell("fi")

    // ── Send message ──
    shell("send_message() {")
    shell("local text=\"$1\"")
    shell("local formatted=\"[${HOSTNAME}] ${TIMESTAMP}")
    shell("${text}\"")

    shell("local response")
    shell("response=$(curl -s -X POST ")
    shell("\"https://api.telegram.org/bot${BOT_TOKEN}/sendMessage\" ")
    shell("-d chat_id=\"${CHAT_ID}\" ")
    shell("-d text=\"${formatted}\" ")
    shell("-d parse_mode=\"HTML\" ")
    shell("--connect-timeout 10 ")
    shell("--max-time 15 ")
    shell("2>&1)")

    // Check if successful
    shell("if echo \"$response\" | grep -q '\"ok\":true'; then")
    shell("echo \"[notify_telegram] Message sent successfully\"")
    shell("return 0")
    shell("else")
    shell("echo \"[notify_telegram] WARNING: Failed to send message\"")
    shell("echo \"[notify_telegram] Response: $response\"")
    shell("return 1")
    shell("fi")
    shell("}")

    // ── Main ──
    shell("case \"${1:-}\" in")
    shell("--test)")
    shell("send_message \"Telegram notification test from Anima watchdog.\"")
    shell(";;")
    shell("--help|-h)")
    shell("echo \"Usage: $0 MESSAGE\"")
    shell("echo \"       $0 --test\"")
    shell("echo \"\"")
    shell("echo \"Environment:\"")
    shell("echo \"  TELEGRAM_BOT_TOKEN  Bot token (required)\"")
    shell("echo \"  TELEGRAM_CHAT_ID    Target chat ID (required)\"")
    shell("exit 0")
    shell(";;")
    shell("\"\")")
    shell("echo \"[notify_telegram] ERROR: No message provided\"")
    shell("echo \"Usage: $0 MESSAGE\"")
    shell("exit 1")
    shell(";;")
    shell("*)")
    shell("send_message \"$*\"")
    shell(";;")
    shell("esac")
}
