// HEXA-FIRST: canonical entry; .sh kept as backing implementation for behavior parity.
// Usage: hexa scripts/monthly_eeg_validate.hexa  (forwards $HEXA_ARGS to bash script)

let home = exec("printenv HOME").trim()
let script = home + "/Dev/anima/scripts/monthly_eeg_validate.sh"
