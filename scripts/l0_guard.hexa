// scripts/l0_guard.hexa — L0 골화 자동 보호 (GitHub + CODEOWNERS + 검증)
//
// SSOT: config/core_rules.json → L0 components + github_protection
//
// Usage:
//   hexa scripts/l0_guard.hexa verify           전체 검증 (파일 + CODEOWNERS + GitHub)
//   hexa scripts/l0_guard.hexa sync             CODEOWNERS 재생성 + GitHub 보호 적용
//   hexa scripts/l0_guard.hexa merge <PR#>      solo-repo PR 머지 (enforce_admins 일시해제→머지→재활성)
//   hexa scripts/l0_guard.hexa status           현재 보호 상태 요약

comptime const CORE_RULES = "config/core_rules.json"
comptime const CODEOWNERS = ".github/CODEOWNERS"
comptime const OWNER      = "@need-singularity"
comptime const REPO       = "need-singularity/anima"
comptime const BRANCH     = "main"

// ─── JSON extraction via python3 (robust) ───

fn py_json(query: string) -> string {
    exec("python3 -c \"" +
        "import json; d=json.load(open('" + CORE_RULES + "')); " +
        query +
        "\" 2>/dev/null").trim()
}

fn get_protected_paths() -> string {
    py_json("print('\\n'.join(d['ossification_layers']['L0']['github_protection']['protected_paths']))")
}

fn get_l0_file_components() -> string {
    py_json("[print(c.split(' ')[0] if ' ' in c else c) for c in d['classification']['code_ossification']['L0']['components'] if '.hexa' in c or '.json' in c]")
}

// ─── GitHub API via gh CLI ───

fn gh_check(field: string) -> bool {
    let r = exec("gh api repos/" + REPO + "/branches/" + BRANCH + "/protection 2>/dev/null" +
        " | python3 -c \"import sys,json; d=json.load(sys.stdin); " + field + "\" 2>/dev/null").trim()
    r == "True" || r == "true"
}

fn gh_enforce_admins_status() -> bool {
    gh_check("print(d.get('enforce_admins',{}).get('enabled',False))")
}

fn gh_enforce_admins_on() {
    exec("gh api repos/" + REPO + "/branches/" + BRANCH + "/protection/enforce_admins -X POST 2>/dev/null")
}

fn gh_enforce_admins_off() {
    exec("gh api repos/" + REPO + "/branches/" + BRANCH + "/protection/enforce_admins -X DELETE 2>/dev/null")
}

fn check_require_pr() -> bool {
    gh_check("print(d.get('required_pull_request_reviews') is not None)")
}
fn check_code_owner_reviews() -> bool {
    gh_check("print(d.get('required_pull_request_reviews',{}).get('require_code_owner_reviews',False))")
}
fn check_force_push_blocked() -> bool {
    gh_check("print(not d.get('allow_force_pushes',{}).get('enabled',True))")
}
fn check_deletions_blocked() -> bool {
    gh_check("print(not d.get('allow_deletions',{}).get('enabled',True))")
}

// ─── CODEOWNERS generation ───

fn generate_codeowners() -> string {
    let paths = get_protected_paths()
    let files = get_l0_file_components()

    let mut out = "# L0 골화 보호 — core_rules.json SSOT 자동 생성\n"
    out = out + "# 변경 시 " + OWNER + " PR 승인 필수\n"
    out = out + "# 자동 생성: hexa scripts/l0_guard.hexa sync\n"
    out = out + "# 수동 편집 금지\n\n"
    out = out + "# === L0 보호 경로 ===\n"

    // protected_paths (newline-separated from python)
    let mut i = 0
    let path_lines = paths.split("\n")
    while i < path_lines.len() {
        let line = path_lines[i]
        if line != "" {
            out = out + line + " " + OWNER + "\n"
        }
        i = i + 1
    }

    out = out + "\n# === L0 골화 파일 (22 .hexa) ===\n"
    let file_lines = files.split("\n")
    i = 0
    while i < file_lines.len() {
        let line = file_lines[i]
        if line != "" {
            out = out + line + " " + OWNER + "\n"
        }
        i = i + 1
    }

    out
}

// ─── Commands ───

fn cmd_status() {
    println("═══ L0 보호 상태 ═══\n")

    let e = gh_enforce_admins_status()
    let pr = check_require_pr()
    let co = check_code_owner_reviews()
    let fp = check_force_push_blocked()
    let dl = check_deletions_blocked()
    let cf = read_file(CODEOWNERS) != ""

    if e { println("  PASS  enforce_admins") } else { println("  FAIL  enforce_admins") }
    if pr { println("  PASS  require_pull_request") } else { println("  FAIL  require_pull_request") }
    if co { println("  PASS  require_code_owner_reviews") } else { println("  FAIL  require_code_owner_reviews") }
    if fp { println("  PASS  force_push_blocked") } else { println("  FAIL  force_push_blocked") }
    if dl { println("  PASS  branch_delete_blocked") } else { println("  FAIL  branch_delete_blocked") }
    if cf { println("  PASS  CODEOWNERS 존재") } else { println("  FAIL  CODEOWNERS 없음") }

    if e && pr && co && fp && dl && cf {
        println("\n  L0 보호 완전. 빈틈 없음.")
    } else {
        println("\n  보호 갭 있음 — `hexa scripts/l0_guard.hexa sync` 실행")
    }
}

fn cmd_verify() {
    println("═══ L0 Guard — 전체 검증 ═══\n")
    let mut pass = 0
    let mut fail = 0

    // 1. L0 파일 존재 확인
    println("── 1. L0 파일 존재 ──")
    let files = get_l0_file_components()
    let file_lines = files.split("\n")
    let mut i = 0
    while i < file_lines.len() {
        let f = file_lines[i]
        if f != "" {
            let content = read_file(f)
            if content != "" {
                println("  PASS  " + f)
                pass = pass + 1
            } else {
                println("  FAIL  " + f + " — 파일 없음")
                fail = fail + 1
            }
        }
        i = i + 1
    }

    // 2. CODEOWNERS 동기화
    println("\n── 2. CODEOWNERS 동기화 ──")
    let co_content = read_file(CODEOWNERS)
    if co_content == "" {
        println("  FAIL  " + CODEOWNERS + " 없음")
        fail = fail + 1
    } else {
        let paths = get_protected_paths()
        let path_lines = paths.split("\n")
        let mut j = 0
        let mut co_ok = true
        while j < path_lines.len() {
            let p = path_lines[j]
            if p != "" {
                if co_content.contains(p) {
                    println("  PASS  " + p)
                    pass = pass + 1
                } else {
                    println("  FAIL  누락: " + p)
                    fail = fail + 1
                    co_ok = false
                }
            }
            j = j + 1
        }
    }

    // 3. GitHub branch protection
    println("\n── 3. GitHub Branch Protection ──")
    let e = gh_enforce_admins_status()
    let pr = check_require_pr()
    let co_r = check_code_owner_reviews()
    let fp = check_force_push_blocked()
    let dl = check_deletions_blocked()

    if e { println("  PASS  enforce_admins"); pass = pass + 1 } else { println("  FAIL  enforce_admins"); fail = fail + 1 }
    if pr { println("  PASS  require_pull_request"); pass = pass + 1 } else { println("  FAIL  require_pull_request"); fail = fail + 1 }
    if co_r { println("  PASS  require_code_owner_reviews"); pass = pass + 1 } else { println("  FAIL  require_code_owner_reviews"); fail = fail + 1 }
    if fp { println("  PASS  force_push_blocked"); pass = pass + 1 } else { println("  FAIL  force_push_blocked"); fail = fail + 1 }
    if dl { println("  PASS  branch_delete_blocked"); pass = pass + 1 } else { println("  FAIL  branch_delete_blocked"); fail = fail + 1 }

    println("\n═══ 결과: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL ═══")
    if fail == 0 {
        println("L0 보호 완전.")
    } else {
        println("보호 갭 " + to_string(fail) + "건 — `hexa scripts/l0_guard.hexa sync` 으로 복구")
    }
}

fn cmd_sync() {
    println("═══ L0 Guard — CODEOWNERS + GitHub 보호 동기화 ═══\n")

    // 1. CODEOWNERS 재생성
    println("── 1. CODEOWNERS 재생성 ──")
    let codeowners = generate_codeowners()
    write_file(CODEOWNERS, codeowners)
    println("  DONE  " + CODEOWNERS + " 갱신")

    // 2. GitHub enforce_admins
    println("\n── 2. GitHub Branch Protection ──")
    if !gh_enforce_admins_status() {
        println("  FIX   enforce_admins 활성화...")
        gh_enforce_admins_on()
        if gh_enforce_admins_status() {
            println("  DONE  enforce_admins = true")
        } else {
            println("  FAIL  enforce_admins 활성화 실패")
        }
    } else {
        println("  OK    enforce_admins 이미 활성")
    }

    if check_require_pr() {
        println("  OK    PR 리뷰 활성")
    } else {
        println("  WARN  PR 리뷰 미설정 — GitHub UI에서 확인")
    }

    println("\n═══ 동기화 완료 — verify 로 확인: hexa scripts/l0_guard.hexa verify ═══")
}

fn cmd_merge(pr_number: string) {
    println("═══ L0 Guard — Solo-repo PR #" + pr_number + " 머지 ═══\n")

    // 1. enforce_admins OFF
    println("  [1/3] enforce_admins 해제...")
    gh_enforce_admins_off()

    // 2. merge
    println("  [2/3] PR #" + pr_number + " 머지...")
    exec("gh pr merge " + pr_number + " --merge --admin 2>&1")

    // 3. enforce_admins ON (무조건 복구)
    println("  [3/3] enforce_admins 재활성화...")
    gh_enforce_admins_on()

    // 4. 결과 ���인 (gh pr view로 상태 체크)
    let state = exec("gh pr view " + pr_number + " --json state -q '.state' 2>/dev/null").trim()
    if state == "MERGED" {
        println("\n  DONE  PR #" + pr_number + " 머지 완료 + enforce_admins 복구")
        println("  " + exec("git checkout " + BRANCH + " && git pull origin " + BRANCH + " 2>&1").trim())
    } else {
        println("\n  FAIL  PR #" + pr_number + " 상태: " + state)
        println("  NOTE  enforce_admins는 복구됨")
    }
}

// ─── Entry ───

fn main() {
    let a = args()
    // args() = [hexa_binary, script_path, ...user_args]
    if a.len() < 3 {
        println("Usage: hexa scripts/l0_guard.hexa <command>")
        println("")
        println("  verify       전체 검증 (파일 + CODEOWNERS + GitHub)")
        println("  sync         CODEOWNERS 재생성 + GitHub 보호 적용")
        println("  merge <PR#>  solo-repo PR 머지 (enforce_admins 안전 패턴)")
        println("  status       현재 보호 상태 요약")
        return
    }

    let cmd = a[2]
    if cmd == "verify" { cmd_verify() }
    else if cmd == "sync" { cmd_sync() }
    else if cmd == "merge" {
        if a.len() < 4 {
            println("Usage: hexa scripts/l0_guard.hexa merge <PR#>")
            return
        }
        cmd_merge(a[3])
    }
    else if cmd == "status" { cmd_status() }
    else {
        println("Unknown: " + cmd)
        println("Usage: hexa scripts/l0_guard.hexa <verify|sync|merge|status>")
    }
}

main()
