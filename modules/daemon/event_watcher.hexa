// event_watcher.hexa — Auto-utterance event watcher (pipeline step 1)
//
// Monitors external perturbation sources defined in
// config/auto_utterance_architecture.json::event_sources
// and appends detected events to data/events.jsonl.
//
// Sources: checkpoint (.pt), git commit, GPU pod, time, file mtime.
// CLI: --scan (one-shot) | --watch (repeat every 60s)
//
// ROI #8: per-scan shell forks reduced from ~8 (date×N + ls + git×2 + stat +
// runpodctl) to 1 combined probe + 1 sleep. now_iso cached once per scan.
// Tuple destructuring removed (hexa 0.1.0-stage1 does not support it).

// ─── paths ───

let HOME = exec("printenv HOME").trim()
let BASE = HOME + "/Dev/anima"
let EVENTS_PATH = BASE + "/data/events.jsonl"
let CKPT_DIR    = BASE + "/checkpoints"
let LAWS_PATH   = BASE + "/config/consciousness_laws.json"

// ─── state ───

struct EventState {
    last_ckpt:  string,
    last_hash:  string,
    last_gpu:   string,
    last_mtime: string
}

struct Probe {
    ts:    string,
    ckpt:  string,
    git:   string,
    gpu:   string,
    mtime: string
}

struct StepResult {
    state: EventState,
    event: string
}

fn fresh_state() -> EventState {
    EventState {
        last_ckpt:  "",
        last_hash:  "",
        last_gpu:   "",
        last_mtime: ""
    }
}

// ─── helpers ───

fn event_json(ts: string, typ: string, detail: string, tension: string, curiosity: string) -> string {
    "{\"timestamp\":\"" + ts + "\",\"type\":\"" + typ + "\",\"detail\":\"" + detail + "\",\"perturbation\":{\"tension\":" + tension + ",\"curiosity\":" + curiosity + "}}"
}

// Extract value after a "KEY=" prefix from a probe line.
fn strip_prefix(line: string, prefix: string) -> string {
    let plen = len(prefix)
    if len(line) < plen { return "" }
    let head = ""
    let mut i = 0
    while i < plen {
        head = head + line[i]
        i = i + 1
    }
    if head != prefix { return "" }
    let out = ""
    let mut j = plen
    while j < len(line) {
        out = out + line[j]
        j = j + 1
    }
    out
}

// ─── one combined probe (1 exec fork, replaces 6+) ───

fn run_probe() -> Probe {
    // Single bash pipeline: emits 5 KEY=value lines. All 2>/dev/null
    // suppresses missing-tool noise (runpodctl optional on laptops).
    let cmd = "bash -c '"
        + "printf \"TS=%s\\nCKPT=%s\\nGIT=%s\\nGPU=%s\\nMTIME=%s\\n\" "
        + "\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" "
        + "\"$(ls -t " + CKPT_DIR + "/*.pt 2>/dev/null | head -1)\" "
        + "\"$(git -C " + BASE + " log -1 --format=%H@@%s 2>/dev/null | tr \"\\n\" \" \")\" "
        + "\"$(runpodctl get pod 2>/dev/null | head -3 | tr \"\\n\" \";\")\" "
        + "\"$(stat -f %m " + LAWS_PATH + " 2>/dev/null || stat -c %Y " + LAWS_PATH + " 2>/dev/null)\""
        + "'"
    let raw = exec(cmd)
    let lines = split(raw, "\n")

    let mut p = Probe { ts: "", ckpt: "", git: "", gpu: "", mtime: "" }
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        let v_ts    = strip_prefix(ln, "TS=")
        let v_ckpt  = strip_prefix(ln, "CKPT=")
        let v_git   = strip_prefix(ln, "GIT=")
        let v_gpu   = strip_prefix(ln, "GPU=")
        let v_mtime = strip_prefix(ln, "MTIME=")
        if len(v_ts) > 0    { p = Probe { ts: v_ts.trim(),    ckpt: p.ckpt,  git: p.git,  gpu: p.gpu,  mtime: p.mtime } }
        if len(v_ckpt) > 0  { p = Probe { ts: p.ts, ckpt: v_ckpt.trim(),  git: p.git,  gpu: p.gpu,  mtime: p.mtime } }
        if len(v_git) > 0   { p = Probe { ts: p.ts, ckpt: p.ckpt,  git: v_git.trim(),   gpu: p.gpu,  mtime: p.mtime } }
        if len(v_gpu) > 0   { p = Probe { ts: p.ts, ckpt: p.ckpt,  git: p.git,  gpu: v_gpu.trim(),   mtime: p.mtime } }
        if len(v_mtime) > 0 { p = Probe { ts: p.ts, ckpt: p.ckpt,  git: p.git,  gpu: p.gpu,  mtime: v_mtime.trim() } }
        i = i + 1
    }
    p
}

// ─── check functions ───

fn check_checkpoint(state: EventState, p: Probe) -> StepResult {
    if len(p.ckpt) == 0 { return StepResult { state: state, event: "" } }
    if p.ckpt == state.last_ckpt { return StepResult { state: state, event: "" } }
    let new_state = EventState {
        last_ckpt: p.ckpt, last_hash: state.last_hash,
        last_gpu: state.last_gpu, last_mtime: state.last_mtime
    }
    let ev = event_json(p.ts, "checkpoint", p.ckpt, "0.3", "0.8")
    StepResult { state: new_state, event: ev }
}

fn check_git(state: EventState, p: Probe) -> StepResult {
    if len(p.git) == 0 { return StepResult { state: state, event: "" } }
    // Split on @@ — combined into one git call (was 2 separate).
    let parts = split(p.git, "@@")
    let hash = if len(parts) > 0 { parts[0] } else { "" }
    if hash == state.last_hash { return StepResult { state: state, event: "" } }
    let new_state = EventState {
        last_ckpt: state.last_ckpt, last_hash: hash,
        last_gpu: state.last_gpu, last_mtime: state.last_mtime
    }
    let ev = event_json(p.ts, "git", p.git, "0.2", "0.5")
    StepResult { state: new_state, event: ev }
}

fn check_gpu(state: EventState, p: Probe) -> StepResult {
    if len(p.gpu) == 0 { return StepResult { state: state, event: "" } }
    if p.gpu == state.last_gpu { return StepResult { state: state, event: "" } }
    let new_state = EventState {
        last_ckpt: state.last_ckpt, last_hash: state.last_hash,
        last_gpu: p.gpu, last_mtime: state.last_mtime
    }
    let ev = event_json(p.ts, "gpu", "pod_state_changed", "0.5", "0.3")
    StepResult { state: new_state, event: ev }
}

fn check_time(p: Probe) -> string {
    event_json(p.ts, "time", "breath", "0.01", "0.05")
}

fn check_file(state: EventState, p: Probe) -> StepResult {
    if len(p.mtime) == 0 { return StepResult { state: state, event: "" } }
    if p.mtime == state.last_mtime { return StepResult { state: state, event: "" } }
    let new_state = EventState {
        last_ckpt: state.last_ckpt, last_hash: state.last_hash,
        last_gpu: state.last_gpu, last_mtime: p.mtime
    }
    let ev = event_json(p.ts, "file", "laws_modified", "0.1", "0.5")
    StepResult { state: new_state, event: ev }
}

// ─── scan + emit ───

struct ScanOutcome {
    state: EventState,
    events: [string]
}

fn scan_all(state: EventState) -> ScanOutcome {
    let p = run_probe()
    let mut events: [string] = []
    let mut s = state

    let r1 = check_checkpoint(s, p)
    s = r1.state
    if len(r1.event) > 0 { events = events + [r1.event] }

    let r2 = check_git(s, p)
    s = r2.state
    if len(r2.event) > 0 { events = events + [r2.event] }

    let r3 = check_gpu(s, p)
    s = r3.state
    if len(r3.event) > 0 { events = events + [r3.event] }

    let e4 = check_time(p)
    events = events + [e4]

    let r5 = check_file(s, p)
    s = r5.state
    if len(r5.event) > 0 { events = events + [r5.event] }

    ScanOutcome { state: s, events: events }
}

fn emit_events(events: [string], path: string) {
    let mut i = 0
    while i < len(events) {
        append_file(path, events[i] + "\n")
        i = i + 1
    }
}

// ─── CLI entry ───

fn main() {
    let a = args()
    let cmd = if len(a) > 2 { a[2] } else { "--scan" }

    exec("mkdir -p " + BASE + "/data")

    if cmd == "--scan" {
        let state = fresh_state()
        let out = scan_all(state)
        emit_events(out.events, EVENTS_PATH)
        println("scan: " + to_string(len(out.events)) + " events -> " + EVENTS_PATH)
    } else if cmd == "--watch" {
        println("watch: polling every 60s -> " + EVENTS_PATH)
        let mut state = fresh_state()
        while true {
            let out = scan_all(state)
            state = out.state
            emit_events(out.events, EVENTS_PATH)
            if len(out.events) > 0 {
                // ts already captured in the probe; no extra date fork.
                let last = out.events[len(out.events) - 1]
                println("[scan] " + to_string(len(out.events)) + " events emitted")
            }
            exec("sleep 60")
        }
    } else {
        println("event_watcher — auto-utterance event detector")
        println("  --scan   one-shot scan, emit to data/events.jsonl")
        println("  --watch  continuous 60s polling loop")
    }
}

main()
