// tool_affordance.hexa — Tool affordance detection and motor planning
// Affordances: graspable, pushable, liftable, throwable, container, tool
// Hebbian learning for tool-action associations

struct ObjectProps {
    shape: string,
    size: float,
    weight: float,
    rigid: bool
}

struct Affordance {
    action: string,
    confidence: float,
    grasp_type: string
}

fn detect_affordances(obj: ObjectProps) -> Affordance {
    if obj.size < 0.1 { return Affordance("grasp", 0.9, "pinch") }
    return Affordance("push", 0.7, "palm")
}

fn plan_grasp(affordance: Affordance) -> string {
    return "grasp_plan:" + affordance.grasp_type
}

fn learn_tool_action(tool: string, action: string, reward: float) -> bool {
    return reward > 0.5
}
