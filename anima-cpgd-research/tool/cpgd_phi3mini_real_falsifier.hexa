// ════════════════════════════════════════════════════════════════════════════
//  anima-cpgd-research/tool/cpgd_phi3mini_real_falsifier.hexa
//  Path C Q4 — Phi-3-mini REAL LM hidden-state CPGD falsifier
//
//  PURPOSE
//    Replaces the FNV synthetic surrogate (cpgd_phi3mini_real_lm_falsifier.hexa)
//    with the actual Phi-3-mini hidden-state matrix obtained from a Python
//    forward pass (anima-cpgd-research/scripts/cpgd_phi3mini_real_forward.py).
//
//    Loads the JSON `cpgd_phi3mini_real_hidden_state_v1.json`, parses the
//    flat 6×8 matrix, applies CPGD closed-form init, runs 100-step projected
//    gradient, evaluates G1/G2/G3/G4 as defined in the task briefing.
//
//  FROZEN GATES (real-LM, briefing-defined)
//    G1: closed-form init residual ≤ EPS_PROJ (=1e-4) on REAL Phi-3 matrix
//    G2: 100-step monotone descent — total_violations (cos < COS_FLOOR) == 0
//    G3: 2 sequential runs sha256(canonical_payload) byte-identical
//    G4: real Phi-3-mini cond_proxy ≥ EPS_C (=1.0)  — informational floor
//        (real LM hidden-state matrices observed in the wild typically
//         exhibit cond > 1; unconditional acceptance only requires that
//         cond is finite and non-degenerate. Strict cond ≥ 1.0 is trivially
//         satisfied by definition; this gate exists to detect numerical
//         pathology where the loaded matrix is degenerate.)
//
//    F_real_LM_PASS = G1 ∧ G2 ∧ G3 ∧ G4
//
//  NEGATIVE FALSIFY (mandatory ω-cycle step 5)
//    Reload the matrix, force a pathological substitution: v_2 := v_0
//    (collinear duplicate ⇒ Gram-Schmidt rank-deficient), confirm verdict
//    flips to FAIL with rank_def=true.
//
//  HONEST LIMIT (raw#10 closure note)
//    The 6×8 matrix is obtained from a deterministic Python wrapper that
//    runs Phi-3-mini's actual transformer forward on 6 frozen prompts and
//    reduces the (6, hidden_dim) full hidden state to (6, 8) via fp64
//    truncated SVD. Determinism rests on numpy LAPACK byte-stability and
//    torch.use_deterministic_algorithms; cross-host re-run may differ in
//    low bits, but on the same host the JSON hash is stable.
//
//  DEPENDENCIES (read-only)
//    anima-cpgd-research/state/cpgd_phi3mini_real_hidden_state_v1.json  (input)
//    anima-cpgd-research/tool/cpgd_phi3mini_real_lm_falsifier.hexa      (algorithmic sibling)
//
//  OUTPUT
//    anima-cpgd-research/state/cpgd_phi3mini_real_falsifier_v1.json
//
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only · $0
// ════════════════════════════════════════════════════════════════════════════

let IN_PATH        = "anima-cpgd-research/state/cpgd_phi3mini_real_hidden_state_v1.json"
let OUT_PATH       = "anima-cpgd-research/state/cpgd_phi3mini_real_falsifier_v1.json"
let DIM            = 8
let TPL_COUNT      = 6
let STEP_COUNT     = 100
let DEFAULT_LR     = 0.001
let GRAD_SEED      = 20260426
let GRAD_SCALE     = 1.0
let COS_FLOOR      = 0.5
let EPS_IDEM       = 0.00001
let EPS_PROJ       = 0.0001
let EPS_C          = 1.0

// ─── helpers ───────────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

fn vec_scale(a: array, s: float) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = push(out, to_float(a[i]) * s)
        i = i + 1
    }
    return out
}

fn vec_sub(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = push(out, to_float(a[i]) - to_float(b[i]))
        i = i + 1
    }
    return out
}

// ─── JSON matrix loader (jq-based, raw#9 hexa-only via exec helper) ────────
//
// We rely on jq to extract the flat 48-float array from the input JSON. jq
// is a stdlib-equivalent shell tool already used elsewhere in this codebase
// (see project_omega_rules_compliance memory entry). Output is parsed line
// by line into a 6×8 array.
//
// Rejects the load if length(matrix_8_flat) != TPL_COUNT * DIM.

fn load_real_matrix(json_path: string) -> array {
    let cmd = "jq -r '.matrix_8_flat[]' " + json_path
    let out = _str(exec(cmd))
    let lines = split(out.trim(), "\n")
    let expected = TPL_COUNT * DIM
    if len(lines) != expected {
        println("[load][ERR] expected " + to_string(expected) + " floats, got " + to_string(len(lines)))
        return []
    }
    let mut M = []
    let mut idx = 0
    let mut i = 0
    while i < TPL_COUNT {
        let mut row = []
        let mut j = 0
        while j < DIM {
            row = push(row, to_float(lines[idx]))
            j = j + 1
            idx = idx + 1
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

fn load_real_cond(json_path: string) -> float {
    let cmd = "jq -r '.matrix_8_cond' " + json_path
    let out = _str(exec(cmd)).trim()
    return to_float(out)
}

fn load_real_frobenius(json_path: string) -> float {
    let cmd = "jq -r '.matrix_8_frobenius' " + json_path
    let out = _str(exec(cmd)).trim()
    return to_float(out)
}

fn load_real_sha256(json_path: string) -> string {
    let cmd = "jq -r '.matrix_8_sha256' " + json_path
    return _str(exec(cmd)).trim()
}

fn load_real_model_id(json_path: string) -> string {
    let cmd = "jq -r '.model_id' " + json_path
    return _str(exec(cmd)).trim()
}

fn load_real_layer_index(json_path: string) -> int {
    let cmd = "jq -r '.layer_index' " + json_path
    let out = _str(exec(cmd)).trim()
    return to_int(out)
}

fn load_real_dim_full(json_path: string) -> int {
    let cmd = "jq -r '.dim_full' " + json_path
    let out = _str(exec(cmd)).trim()
    return to_int(out)
}

// ─── Gram-Schmidt orthonormalization (identical to surrogate sibling) ─────

fn gram_schmidt(V_raw: array) -> array {
    let n = len(V_raw)
    let mut Q = []
    let mut i = 0
    while i < n {
        let v = V_raw[i]
        let mut u = []
        let mut k = 0
        while k < DIM {
            u = push(u, to_float(v[k]))
            k = k + 1
        }
        let mut j = 0
        while j < len(Q) {
            let qj = Q[j]
            let proj_coef = vec_dot(u, qj)
            let proj_vec  = vec_scale(qj, proj_coef)
            u = vec_sub(u, proj_vec)
            j = j + 1
        }
        let nrm = vec_norm(u)
        if nrm < 0.000001 {
            let mut z = []
            let mut zk = 0
            while zk < DIM {
                z = push(z, 0.0)
                zk = zk + 1
            }
            Q = push(Q, z)
        } else {
            let u_norm = vec_scale(u, 1.0 / nrm)
            Q = push(Q, u_norm)
        }
        i = i + 1
    }
    return Q
}

fn detect_rank_deficient(Q: array) -> bool {
    let n = len(Q)
    let mut i = 0
    while i < n {
        if vec_norm(Q[i]) < 0.000001 { return true }
        i = i + 1
    }
    return false
}

// ─── Linear algebra (projector + cosine + projection residual) ────────────

fn build_projector(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < DIM {
        let mut row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

fn verify_projector_idempotent(P: array) -> bool {
    let mut max_delta = 0.0
    let mut a = 0
    while a < DIM {
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < DIM {
                s = s + to_float(P[a][k]) * to_float(P[k][b])
                k = k + 1
            }
            let d = fabs(s - to_float(P[a][b]))
            if d > max_delta { max_delta = d }
            b = b + 1
        }
        a = a + 1
    }
    return max_delta < EPS_IDEM
}

// ─── deterministic RNG (LCG + Box-Muller, identical to sibling) ──────────

fn lcg_next(state_arr: array) -> float {
    let mut s = to_int(state_arr[0])
    s = (s * 1103515245 + 12345) % 2147483648
    state_arr[0] = s
    return to_float(s % 1000000) / 1000000.0
}

fn randn_pair(state_arr: array) -> array {
    let u1_raw = lcg_next(state_arr)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let u2 = lcg_next(state_arr)
    let r = sqrt_newton(0.0 - 2.0 * log(u1))
    let theta = 2.0 * 3.141592653589793 * u2
    let z1 = r * cos(theta)
    let z2 = r * sin(theta)
    return [z1, z2]
}

fn rand_matrix(rows: int, cols: int, state_arr: array) -> array {
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = randn_pair(state_arr)
            row = push(row, to_float(pair[0]) * GRAD_SCALE)
            j = j + 1
            if j < cols {
                row = push(row, to_float(pair[1]) * GRAD_SCALE)
                j = j + 1
            }
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

fn matmul_right(G: array, P: array) -> array {
    let rows = len(G)
    let mut out = []
    let mut i = 0
    while i < rows {
        let g = G[i]
        let mut new_row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut a = 0
            while a < DIM {
                s = s + to_float(g[a]) * to_float(P[a][b])
                a = a + 1
            }
            new_row = push(new_row, s)
            b = b + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn gradient_step(W: array, grad_raw: array, P_S: array, lr: float) -> array {
    let grad_proj = matmul_right(grad_raw, P_S)
    let rows = len(W)
    let mut out = []
    let mut i = 0
    while i < rows {
        let w = W[i]
        let g = grad_proj[i]
        let mut new_row = []
        let mut j = 0
        while j < DIM {
            new_row = push(new_row, to_float(w[j]) - lr * to_float(g[j]))
            j = j + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn row_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

fn projection_residual(W: array, P_S: array) -> float {
    let n = len(W)
    let mut max_res = 0.0
    let mut i = 0
    while i < n {
        let w = W[i]
        let mut pw = []
        let mut a = 0
        while a < DIM {
            let mut s = 0.0
            let mut b = 0
            while b < DIM {
                s = s + to_float(P_S[a][b]) * to_float(w[b])
                b = b + 1
            }
            pw = push(pw, s)
            a = a + 1
        }
        let mut diff_norm_sq = 0.0
        let mut k = 0
        while k < DIM {
            let d = to_float(w[k]) - to_float(pw[k])
            diff_norm_sq = diff_norm_sq + d * d
            k = k + 1
        }
        let res = sqrt_newton(diff_norm_sq)
        if res > max_res { max_res = res }
        i = i + 1
    }
    return max_res
}

// ─── orchestration ────────────────────────────────────────────────────────

// Returns:
//  [step_count, min_per_tpl, global_min, max_drift, all_above,
//   idem_ok, init_cos_ok, init_residual, total_violations, cs_last,
//   rank_def]
fn dry_run_real(V_raw: array, lr: float) -> array {
    let V_orth = gram_schmidt(V_raw)
    let rank_def = detect_rank_deficient(V_orth)

    if rank_def {
        let mut empty_min = []
        let mut k = 0
        while k < TPL_COUNT {
            empty_min = push(empty_min, 0.0)
            k = k + 1
        }
        return [STEP_COUNT, empty_min, 0.0, 1.0, false,
                false, false, 1.0e30, STEP_COUNT * TPL_COUNT, empty_min,
                true]
    }

    let P_S = build_projector(V_orth)
    let idem_ok = verify_projector_idempotent(P_S)

    // template-aligned init: W_0 = V_orth (lies exactly in S)
    let mut W = []
    let mut r = 0
    while r < TPL_COUNT {
        let v = V_orth[r]
        let mut row = []
        let mut jj = 0
        while jj < DIM {
            row = push(row, to_float(v[jj]))
            jj = jj + 1
        }
        W = push(W, row)
        r = r + 1
    }

    let init_residual = projection_residual(W, P_S)
    let c_init = row_cosines(W, V_orth)
    let mut init_cos_ok = true
    let mut ii = 0
    while ii < TPL_COUNT {
        let ci = to_float(c_init[ii])
        if fabs(ci - 1.0) > 1e-8 { init_cos_ok = false }
        ii = ii + 1
    }

    let mut min_per_tpl = []
    let mut k = 0
    while k < TPL_COUNT {
        min_per_tpl = push(min_per_tpl, to_float(c_init[k]))
        k = k + 1
    }

    let state_arr = [GRAD_SEED]
    let mut max_drift = 0.0
    let mut all_above = true
    let mut total_violations = 0
    let mut global_min = 1.0
    let mut cs_last = c_init
    let mut step = 0
    while step < STEP_COUNT {
        let grad = rand_matrix(TPL_COUNT, DIM, state_arr)
        W = gradient_step(W, grad, P_S, lr)
        let cs = row_cosines(W, V_orth)
        cs_last = cs
        let mut i = 0
        while i < TPL_COUNT {
            let c = to_float(cs[i])
            if c < to_float(min_per_tpl[i]) { min_per_tpl[i] = c }
            if c < global_min { global_min = c }
            let drift = fabs(1.0 - c)
            if drift > max_drift { max_drift = drift }
            if c < COS_FLOOR {
                all_above = false
                total_violations = total_violations + 1
            }
            i = i + 1
        }
        step = step + 1
    }

    return [STEP_COUNT, min_per_tpl, global_min, max_drift, all_above,
            idem_ok, init_cos_ok, init_residual, total_violations, cs_last,
            false]
}

// ─── canonical payload ────────────────────────────────────────────────────

fn canonical_payload(step_count: int, min_per_tpl: array,
                     global_min: float, all_above: bool, max_drift: float,
                     init_residual: float, real_cond: float, real_fro: float,
                     real_sha: string, idem_ok: bool, init_cos_ok: bool,
                     rank_def: bool, total_violations: int) -> string {
    let mut s = "cpgd_phi3mini_real_falsifier_v1|"
    s = s + "step_count=" + to_string(step_count) + "|"
    s = s + "template_count=" + to_string(TPL_COUNT) + "|"
    s = s + "dim=" + to_string(DIM) + "|"
    s = s + "lr=" + to_string(DEFAULT_LR) + "|"
    s = s + "grad_seed=" + to_string(GRAD_SEED) + "|"
    s = s + "real_matrix_sha=" + real_sha + "|"
    s = s + "idem_ok=" + (if idem_ok { "true" } else { "false" }) + "|"
    s = s + "init_cos_ok=" + (if init_cos_ok { "true" } else { "false" }) + "|"
    s = s + "rank_def=" + (if rank_def { "true" } else { "false" }) + "|"
    s = s + "init_residual=" + to_string(init_residual) + "|"
    s = s + "real_cond=" + to_string(real_cond) + "|"
    s = s + "real_fro=" + to_string(real_fro) + "|"
    s = s + "all_above=" + (if all_above { "true" } else { "false" }) + "|"
    s = s + "total_violations=" + to_string(total_violations) + "|"
    s = s + "global_min_cos=" + to_string(global_min) + "|"
    s = s + "max_drift=" + to_string(max_drift) + "|"
    s = s + "min_per_tpl="
    let n = len(min_per_tpl)
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + to_string(to_float(min_per_tpl[i]))
        i = i + 1
    }
    return s
}

fn sha256_of_string(s: string) -> string {
    let tmp = "/tmp/cpgd_phi3_real_sha_" + to_string(len(s)) + ".txt"
    write_file(tmp, s)
    let r = _str(exec("shasum -a 256 " + tmp + " | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + tmp)
    return r
}

fn emit_float_array(a: array) -> string {
    let n = len(a)
    let mut s = "["
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + to_string(to_float(a[i]))
        i = i + 1
    }
    return s + "]"
}

// ─── pathological negative-falsify ──────────────────────────────────────
//  Take the real matrix, force v_2 := v_0 (collinear) ⇒ Gram-Schmidt
//  rank-deficient detection; expected verdict path: FAIL.

fn build_pathological_real(M: array) -> array {
    let mut Vp = []
    let mut i = 0
    while i < TPL_COUNT {
        let mut row = []
        let mut j = 0
        while j < DIM {
            if i == 2 {
                row = push(row, to_float(M[0][j]))
            } else {
                row = push(row, to_float(M[i][j]))
            }
            j = j + 1
        }
        Vp = push(Vp, row)
        i = i + 1
    }
    return Vp
}

fn negative_falsify(M: array) -> bool {
    let Vp = build_pathological_real(M)
    let r = dry_run_real(Vp, DEFAULT_LR)
    let rank_def = to_bool(r[10])
    return rank_def
}

// ─── 2-run determinism (G3) ──────────────────────────────────────────────

fn run_once(V_raw: array, lr: float, real_cond: float, real_fro: float, real_sha: string) -> array {
    let r = dry_run_real(V_raw, lr)
    let step_count   = to_int(r[0])
    let min_per_tpl  = r[1]
    let global_min   = to_float(r[2])
    let max_drift    = to_float(r[3])
    let all_above    = to_bool(r[4])
    let idem_ok      = to_bool(r[5])
    let init_cos_ok  = to_bool(r[6])
    let init_res     = to_float(r[7])
    let total_viol   = to_int(r[8])
    let cs_last      = r[9]
    let rank_def     = to_bool(r[10])
    let canon = canonical_payload(step_count, min_per_tpl, global_min, all_above,
                                   max_drift, init_res, real_cond, real_fro, real_sha,
                                   idem_ok, init_cos_ok, rank_def, total_viol)
    let sha = sha256_of_string(canon)
    return [sha, all_above, min_per_tpl, max_drift, step_count,
            idem_ok, init_cos_ok, init_res, total_viol, cs_last, global_min,
            rank_def]
}

// ─── main ────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "full"
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--selftest" { mode = "selftest" }
        if a == "--help"     { mode = "help" }
        k = k + 1
    }

    if mode == "help" {
        println("usage:")
        println("  hexa run anima-cpgd-research/tool/cpgd_phi3mini_real_falsifier.hexa")
        println("  hexa run anima-cpgd-research/tool/cpgd_phi3mini_real_falsifier.hexa --selftest")
        return
    }

    println("════════════════════════════════════════════════════════════════")
    println("  cpgd_phi3mini_real_falsifier.hexa — Path C Q4 real-LM")
    println("  Loads Phi-3-mini real hidden state matrix from JSON")
    println("════════════════════════════════════════════════════════════════")

    let root = resolve_root()
    let in_path  = root + "/" + IN_PATH
    let out_path = root + "/" + OUT_PATH

    // Verify input file exists
    let stat_check = _str(exec("test -f " + in_path + " && echo OK || echo MISSING")).trim()
    if stat_check != "OK" {
        println("[real][ERR] missing input " + in_path)
        println("[real]      run scripts/cpgd_phi3mini_real_forward.py first")
        if mode == "selftest" { exit(1) }
        return
    }

    let model_id   = load_real_model_id(in_path)
    let layer_idx  = load_real_layer_index(in_path)
    let dim_full   = load_real_dim_full(in_path)
    let real_sha   = load_real_sha256(in_path)
    let real_cond  = load_real_cond(in_path)
    let real_fro   = load_real_frobenius(in_path)
    let M          = load_real_matrix(in_path)

    if len(M) != TPL_COUNT {
        println("[real][ERR] matrix shape mismatch")
        if mode == "selftest" { exit(1) }
        return
    }

    println("[real] model=" + model_id + " layer=" + to_string(layer_idx) + " dim_full=" + to_string(dim_full))
    println("[real] reduced K=" + to_string(TPL_COUNT) + " dim=" + to_string(DIM))
    println("[real] real_cond=" + to_string(real_cond) + " real_fro=" + to_string(real_fro))
    println("[real] real_sha=" + real_sha)

    println("[real] ── positive run (G1+G2+G3+G4) ──")
    let a1 = run_once(M, DEFAULT_LR, real_cond, real_fro, real_sha)
    let sha1       = _str(a1[0])
    let all_above  = to_bool(a1[1])
    let min_per_tpl = a1[2]
    let max_drift  = to_float(a1[3])
    let step_count = to_int(a1[4])
    let idem_ok    = to_bool(a1[5])
    let init_cos_ok = to_bool(a1[6])
    let init_res   = to_float(a1[7])
    let total_viol = to_int(a1[8])
    let cs_last    = a1[9]
    let global_min = to_float(a1[10])
    let rank_def   = to_bool(a1[11])

    println("[real] run1=" + sha1)
    let a2 = run_once(M, DEFAULT_LR, real_cond, real_fro, real_sha)
    let sha2 = _str(a2[0])
    println("[real] run2=" + sha2)
    let byte_id = (sha1 != "" && sha1 == sha2)

    let g1_pass = (init_res < EPS_PROJ) && init_cos_ok
    let g2_pass = all_above && (total_viol == 0)
    let g3_pass = byte_id
    let g4_pass = real_cond >= EPS_C  // informational floor; degenerate=cond<1 rejected

    println("[real] ── negative falsify (collinear v_2 := v_0 on REAL matrix) ──")
    let neg_ok = negative_falsify(M)
    println("[real] negative_falsify_caught=" + (if neg_ok { "true" } else { "false" }))

    let real_verified = g1_pass && g2_pass && g3_pass && g4_pass && neg_ok && !rank_def

    println("[real] G1_init_residual=" + to_string(init_res) + " (<" + to_string(EPS_PROJ) + ") g1_pass=" + (if g1_pass { "true" } else { "false" }))
    println("[real] G2_total_violations=" + to_string(total_viol) + " g2_pass=" + (if g2_pass { "true" } else { "false" }))
    println("[real] G3_byte_identical=" + (if g3_pass { "true" } else { "false" }))
    println("[real] G4_real_cond=" + to_string(real_cond) + " (>=" + to_string(EPS_C) + ") g4_pass=" + (if g4_pass { "true" } else { "false" }))
    println("[real] global_min_cos=" + to_string(global_min) + " max_drift=" + to_string(max_drift))
    println("[real] verdict=" + (if real_verified { "CPGD_REAL_LM_GENERALIZED" } else { "CPGD_REAL_LM_FAIL" }))

    let mut j = "{\n"
    j = j + "  \"schema_version\": \"1\",\n"
    j = j + "  \"slug\": \"cpgd-phi3mini-real-falsifier-v1\",\n"
    j = j + "  \"title\": \"Path C Q4 — CPGD Phi-3-mini REAL LM falsifier\",\n"
    j = j + "  \"created\": \"2026-04-26\",\n"
    j = j + "  \"path\": \"C\",\n"
    j = j + "  \"raw_strict\": \"raw#9 hexa-only deterministic; input from python wrapper\",\n"
    j = j + "  \"honest_limit\": \"raw#10 — hidden state from REAL Phi-3-mini forward via deterministic Python wrapper; cross-host fp determinism may differ in low bits\",\n"
    j = j + "  \"tool\": \"anima-cpgd-research/tool/cpgd_phi3mini_real_falsifier.hexa\",\n"
    j = j + "  \"depends_on\": [\"anima-cpgd-research/scripts/cpgd_phi3mini_real_forward.py\", \"anima-cpgd-research/state/cpgd_phi3mini_real_hidden_state_v1.json\"],\n"
    j = j + "  \"model_id\": \"" + model_id + "\",\n"
    j = j + "  \"layer_index\": " + to_string(layer_idx) + ",\n"
    j = j + "  \"dim_full\": " + to_string(dim_full) + ",\n"
    j = j + "  \"step_count\": " + to_string(step_count) + ",\n"
    j = j + "  \"template_count\": " + to_string(TPL_COUNT) + ",\n"
    j = j + "  \"dim\": " + to_string(DIM) + ",\n"
    j = j + "  \"lr\": " + to_string(DEFAULT_LR) + ",\n"
    j = j + "  \"grad_seed\": " + to_string(GRAD_SEED) + ",\n"
    j = j + "  \"cos_floor\": " + to_string(COS_FLOOR) + ",\n"
    j = j + "  \"eps_proj\": " + to_string(EPS_PROJ) + ",\n"
    j = j + "  \"eps_c\": " + to_string(EPS_C) + ",\n"
    j = j + "  \"real_matrix_sha256\": \"" + real_sha + "\",\n"
    j = j + "  \"real_matrix_cond\": " + to_string(real_cond) + ",\n"
    j = j + "  \"real_matrix_frobenius\": " + to_string(real_fro) + ",\n"
    j = j + "  \"projector_idempotent\": " + (if idem_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"init_unit_cosine_ok\": " + (if init_cos_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"init_residual\": " + to_string(init_res) + ",\n"
    j = j + "  \"rank_deficient\": " + (if rank_def { "true" } else { "false" }) + ",\n"
    j = j + "  \"min_cos_per_template\": " + emit_float_array(min_per_tpl) + ",\n"
    j = j + "  \"cos_at_final_step\": " + emit_float_array(cs_last) + ",\n"
    j = j + "  \"global_min_cos\": " + to_string(global_min) + ",\n"
    j = j + "  \"max_cos_drift\": " + to_string(max_drift) + ",\n"
    j = j + "  \"total_violations\": " + to_string(total_viol) + ",\n"
    j = j + "  \"selftest_2run\": {\n"
    j = j + "    \"run1_sha\": \"" + sha1 + "\",\n"
    j = j + "    \"run2_sha\": \"" + sha2 + "\",\n"
    j = j + "    \"byte_identical\": " + (if byte_id { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"frozen_gates\": {\n"
    j = j + "    \"G1_init_residual_pass\": " + (if g1_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G2_monotone_no_violation\": " + (if g2_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G3_byte_identical\": " + (if g3_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G4_real_cond_floor\": " + (if g4_pass { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"negative_falsify_caught_pathological\": " + (if neg_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"verdict\": \"" + (if real_verified { "CPGD_REAL_LM_GENERALIZED" } else { "CPGD_REAL_LM_FAIL" }) + "\"\n"
    j = j + "}\n"
    write_file(out_path, j)
    println("[real] wrote " + OUT_PATH)

    if mode == "selftest" {
        if real_verified { exit(0) } else { exit(1) }
    }
}

main()
