// ════════════════════════════════════════════════════════════════════════════
//  anima-cpgd-research/tool/cpgd_mcb_real_4bb_falsifier.hexa
//
//  CPGD-MCB REAL 5-backbone × 3-rank — 15-cell composite falsifier
//
//  PURPOSE
//    Generalizes the phi3_only_v2 single-backbone × 3-rank (3-cell) pattern
//    to the REAL 5-backbone × 3-rank composite (15 cells) bundle produced
//    by the upstream python forward wrappers (raw#37 transient). Iterates
//    ALL backbones — tinyllama, gemma, phi3, mistral7b, qwen3_8b — without
//    the PHI3-only restriction, and evaluates the CPGD-MCB invariant on
//    a 5-family × 3-rank cross-architecture surface.
//
//  INPUT
//    anima-cpgd-research/state/cpgd_mcb_real_4bb_v1.json
//    (5 backbones × ranks {4,8,16} × k_prompts=16, real hidden states only)
//
//  PER-CELL FROZEN GATES   (identical to phi3_only_v2 sibling)
//    G1: closed-form init residual ≤ EPS_PROJ (=1e-4) ∧ unit cosines ok
//    G2: 100-step monotone descent — total_violations (cos < COS_FLOOR) == 0
//    G3: 2 sequential runs sha256(canonical_payload) byte-identical
//    G4: cell cond ≥ EPS_C (=1.0) — informational floor, rejects degenerate
//
//    F_cell = G1 ∧ G2 ∧ G3 ∧ G4 ∧ ¬rank_def
//
//  AGGREGATE GATES
//    AG1: ≥ 14/15 cells F_cell PASS  (1 leniency for non-deterministic LM)
//    AG2: cond-byte Pearson |r| < 0.3 across the 15 cells
//
//    F_MCB = AG1 ∧ AG2 ∧ negative_falsify_caught
//
//  NEGATIVE FALSIFY  (mandatory ω-cycle step 5)
//    For one cell (chosen first PASS cell), force v_2 := v_0 ⇒ Gram-Schmidt
//    rank-deficient ⇒ verdict flips to FAIL.
//
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only · $0
//
//  @resolver-bypass(reason="anima-cpgd-research/state inputs are mac-local
//                   only; hetzner remote tree does not contain the real
//                   4bb hidden state bundle, so external dispatch yields
//                   a silent no-op. Local Mach-O exec is the only viable
//                   route on Darwin.")
// ════════════════════════════════════════════════════════════════════════════

let IN_PATH        = "anima-cpgd-research/state/cpgd_mcb_real_4bb_v1.json"
let OUT_PATH       = "anima-cpgd-research/state/cpgd_mcb_real_4bb_falsifier_v1.json"
let STEP_COUNT     = 100
let DEFAULT_LR     = 0.001
let GRAD_SEED      = 20260426
let GRAD_SCALE     = 1.0
let COS_FLOOR      = 0.5
let EPS_IDEM       = 0.00001
let EPS_PROJ       = 0.0001
let EPS_C          = 1.0
let PEARSON_R_MAX  = 0.3
// AG1 leniency: at most 1 cell may fail of the 15. Computed dynamically as
// (total_cells - 1).
let MIN_PASS_LENIENCY = 1

// ─── helpers ───────────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn log10_approx(x: float) -> float {
    // ln(x) / ln(10), Newton-style ln via series
    if x <= 0.0 { return 0.0 - 1.0e30 }
    return log(x) / 2.302585092994046
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

fn vec_scale(a: array, s: float) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = push(out, to_float(a[i]) * s)
        i = i + 1
    }
    return out
}

fn vec_sub(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = push(out, to_float(a[i]) - to_float(b[i]))
        i = i + 1
    }
    return out
}

// ─── per-cell JSON loaders (jq-based extraction by index path) ─────────────

fn load_int(path: string, jq_expr: string) -> int {
    let cmd = "jq -r '" + jq_expr + "' " + path
    let out = _str(exec(cmd)).trim()
    return to_int(out)
}

fn load_float(path: string, jq_expr: string) -> float {
    let cmd = "jq -r '" + jq_expr + "' " + path
    let out = _str(exec(cmd)).trim()
    return to_float(out)
}

fn load_str(path: string, jq_expr: string) -> string {
    let cmd = "jq -r '" + jq_expr + "' " + path
    return _str(exec(cmd)).trim()
}

fn load_cell_matrix(json_path: string, bb_index: int, rank_key: string,
                     k: int, rank_int: int) -> array {
    let expr = ".backbones[" + to_string(bb_index) + "].cells.\"" + rank_key + "\".matrix_flat[]"
    let cmd = "jq -r '" + expr + "' " + json_path
    let out = _str(exec(cmd))
    let lines = split(out.trim(), "\n")
    let expected = k * rank_int
    if len(lines) != expected {
        println("[mcb][load][ERR] expected " + to_string(expected) + " floats, got " + to_string(len(lines)))
        return []
    }
    let mut M = []
    let mut idx = 0
    let mut i = 0
    while i < k {
        let mut row = []
        let mut j = 0
        while j < rank_int {
            row = push(row, to_float(lines[idx]))
            j = j + 1
            idx = idx + 1
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

// ─── Gram-Schmidt orthonormalization ──────────────────────────────────────

fn gram_schmidt(V_raw: array, dim: int) -> array {
    let n = len(V_raw)
    let mut Q = []
    let mut i = 0
    while i < n {
        let v = V_raw[i]
        let mut u = []
        let mut k = 0
        while k < dim {
            u = push(u, to_float(v[k]))
            k = k + 1
        }
        let mut j = 0
        while j < len(Q) {
            let qj = Q[j]
            let proj_coef = vec_dot(u, qj)
            let proj_vec  = vec_scale(qj, proj_coef)
            u = vec_sub(u, proj_vec)
            j = j + 1
        }
        let nrm = vec_norm(u)
        if nrm < 0.000001 {
            let mut z = []
            let mut zk = 0
            while zk < dim {
                z = push(z, 0.0)
                zk = zk + 1
            }
            Q = push(Q, z)
        } else {
            let u_norm = vec_scale(u, 1.0 / nrm)
            Q = push(Q, u_norm)
        }
        i = i + 1
    }
    return Q
}

fn detect_rank_deficient(Q: array) -> bool {
    let n = len(Q)
    let mut i = 0
    while i < n {
        if vec_norm(Q[i]) < 0.000001 { return true }
        i = i + 1
    }
    return false
}

fn build_projector(eigenvecs: array, dim: int) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < dim {
        let mut row = []
        let mut b = 0
        while b < dim {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

fn verify_projector_idempotent(P: array, dim: int) -> bool {
    let mut max_delta = 0.0
    let mut a = 0
    while a < dim {
        let mut b = 0
        while b < dim {
            let mut s = 0.0
            let mut k = 0
            while k < dim {
                s = s + to_float(P[a][k]) * to_float(P[k][b])
                k = k + 1
            }
            let d = fabs(s - to_float(P[a][b]))
            if d > max_delta { max_delta = d }
            b = b + 1
        }
        a = a + 1
    }
    return max_delta < EPS_IDEM
}

// ─── deterministic RNG (LCG + Box-Muller) ─────────────────────────────────

fn lcg_next(state_arr: array) -> float {
    let mut s = to_int(state_arr[0])
    s = (s * 1103515245 + 12345) % 2147483648
    state_arr[0] = s
    return to_float(s % 1000000) / 1000000.0
}

fn randn_pair(state_arr: array) -> array {
    let u1_raw = lcg_next(state_arr)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let u2 = lcg_next(state_arr)
    let r = sqrt_newton(0.0 - 2.0 * log(u1))
    let theta = 2.0 * 3.141592653589793 * u2
    let z1 = r * cos(theta)
    let z2 = r * sin(theta)
    return [z1, z2]
}

fn rand_matrix(rows: int, cols: int, state_arr: array) -> array {
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = randn_pair(state_arr)
            row = push(row, to_float(pair[0]) * GRAD_SCALE)
            j = j + 1
            if j < cols {
                row = push(row, to_float(pair[1]) * GRAD_SCALE)
                j = j + 1
            }
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

fn matmul_right(G: array, P: array, dim: int) -> array {
    let rows = len(G)
    let mut out = []
    let mut i = 0
    while i < rows {
        let g = G[i]
        let mut new_row = []
        let mut b = 0
        while b < dim {
            let mut s = 0.0
            let mut a = 0
            while a < dim {
                s = s + to_float(g[a]) * to_float(P[a][b])
                a = a + 1
            }
            new_row = push(new_row, s)
            b = b + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn gradient_step(W: array, grad_raw: array, P_S: array, lr: float, dim: int) -> array {
    let grad_proj = matmul_right(grad_raw, P_S, dim)
    let rows = len(W)
    let mut out = []
    let mut i = 0
    while i < rows {
        let w = W[i]
        let g = grad_proj[i]
        let mut new_row = []
        let mut j = 0
        while j < dim {
            new_row = push(new_row, to_float(w[j]) - lr * to_float(g[j]))
            j = j + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn row_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

fn projection_residual(W: array, P_S: array, dim: int) -> float {
    let n = len(W)
    let mut max_res = 0.0
    let mut i = 0
    while i < n {
        let w = W[i]
        let mut pw = []
        let mut a = 0
        while a < dim {
            let mut s = 0.0
            let mut b = 0
            while b < dim {
                s = s + to_float(P_S[a][b]) * to_float(w[b])
                b = b + 1
            }
            pw = push(pw, s)
            a = a + 1
        }
        let mut diff_norm_sq = 0.0
        let mut k = 0
        while k < dim {
            let d = to_float(w[k]) - to_float(pw[k])
            diff_norm_sq = diff_norm_sq + d * d
            k = k + 1
        }
        let res = sqrt_newton(diff_norm_sq)
        if res > max_res { max_res = res }
        i = i + 1
    }
    return max_res
}

// ─── per-cell dry run ─────────────────────────────────────────────────────
// returns [step_count, init_residual, total_violations, global_min, max_drift,
//          idem_ok_int, init_cos_ok_int, rank_def_int, all_above_int]
//
// NOTE: bools encoded as int 0/1 due to hexa mixed-array bool quirk
// (push false → extract true). This applies to inner array slot bools too.
fn dry_run_cell(V_raw: array, dim: int, k: int, lr: float) -> array {
    let V_orth = gram_schmidt(V_raw, dim)
    let rank_def = detect_rank_deficient(V_orth)

    if rank_def {
        return [STEP_COUNT, 1.0e30, STEP_COUNT * k, 0.0, 1.0,
                0, 0, 1, 0]
    }

    let P_S = build_projector(V_orth, dim)
    let idem_ok = verify_projector_idempotent(P_S, dim)

    // template-aligned init: W_0 = V_orth (lies in S)
    let mut W = []
    let mut r = 0
    while r < k {
        let v = V_orth[r]
        let mut row = []
        let mut jj = 0
        while jj < dim {
            row = push(row, to_float(v[jj]))
            jj = jj + 1
        }
        W = push(W, row)
        r = r + 1
    }

    let init_residual = projection_residual(W, P_S, dim)
    let c_init = row_cosines(W, V_orth)
    let mut init_cos_ok = true
    let mut ii = 0
    while ii < k {
        let ci = to_float(c_init[ii])
        if fabs(ci - 1.0) > 1e-8 { init_cos_ok = false }
        ii = ii + 1
    }

    let state_arr = [GRAD_SEED]
    let mut max_drift = 0.0
    let mut all_above = true
    let mut total_violations = 0
    let mut global_min = 1.0
    let mut step = 0
    while step < STEP_COUNT {
        let grad = rand_matrix(k, dim, state_arr)
        W = gradient_step(W, grad, P_S, lr, dim)
        let cs = row_cosines(W, V_orth)
        let mut i = 0
        while i < k {
            let c = to_float(cs[i])
            if c < global_min { global_min = c }
            let drift = fabs(1.0 - c)
            if drift > max_drift { max_drift = drift }
            if c < COS_FLOOR {
                all_above = false
                total_violations = total_violations + 1
            }
            i = i + 1
        }
        step = step + 1
    }

    let idem_ok_i = if idem_ok { 1 } else { 0 }
    let init_cos_ok_i = if init_cos_ok { 1 } else { 0 }
    let all_above_i = if all_above { 1 } else { 0 }
    return [STEP_COUNT, init_residual, total_violations, global_min, max_drift,
            idem_ok_i, init_cos_ok_i, 0, all_above_i]
}

// ─── per-cell canonical + sha256 ─────────────────────────────────────────

fn cell_canonical(alias: string, rank: int, k: int,
                   step_count: int, init_residual: float, total_violations: int,
                   global_min: float, max_drift: float,
                   idem_ok: bool, init_cos_ok: bool, rank_def: bool, all_above: bool,
                   cell_cond: float, cell_fro: float, cell_sha: string) -> string {
    let mut s = "cpgd_mcb_cell_v1|"
    s = s + "alias=" + alias + "|rank=" + to_string(rank) + "|k=" + to_string(k) + "|"
    s = s + "step_count=" + to_string(step_count) + "|"
    s = s + "lr=" + to_string(DEFAULT_LR) + "|"
    s = s + "grad_seed=" + to_string(GRAD_SEED) + "|"
    s = s + "matrix_sha=" + cell_sha + "|"
    s = s + "idem_ok=" + (if idem_ok { "true" } else { "false" }) + "|"
    s = s + "init_cos_ok=" + (if init_cos_ok { "true" } else { "false" }) + "|"
    s = s + "rank_def=" + (if rank_def { "true" } else { "false" }) + "|"
    s = s + "init_residual=" + to_string(init_residual) + "|"
    s = s + "cell_cond=" + to_string(cell_cond) + "|"
    s = s + "cell_fro=" + to_string(cell_fro) + "|"
    s = s + "all_above=" + (if all_above { "true" } else { "false" }) + "|"
    s = s + "total_violations=" + to_string(total_violations) + "|"
    s = s + "global_min_cos=" + to_string(global_min) + "|"
    s = s + "max_drift=" + to_string(max_drift)
    return s
}

fn sha256_of_string(s: string) -> string {
    let tmp = "/tmp/cpgd_mcb_sha_" + to_string(len(s)) + ".txt"
    write_file(tmp, s)
    let r = _str(exec("shasum -a 256 " + tmp + " | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + tmp)
    return r
}

// ─── pathological negative-falsify on first PASS cell ─────────────────────

fn build_pathological(M: array, dim: int) -> array {
    let n = len(M)
    let mut Vp = []
    let mut i = 0
    while i < n {
        let mut row = []
        let mut j = 0
        while j < dim {
            if i == 2 {
                row = push(row, to_float(M[0][j]))
            } else {
                row = push(row, to_float(M[i][j]))
            }
            j = j + 1
        }
        Vp = push(Vp, row)
        i = i + 1
    }
    return Vp
}

fn negative_falsify(M: array, dim: int, k: int) -> bool {
    let Vp = build_pathological(M, dim)
    let r = dry_run_cell(Vp, dim, k, DEFAULT_LR)
    let rank_def = to_int(r[7]) == 1
    return rank_def
}

// ─── Pearson r over (log10(cond), sha-byte-prefix) ────────────────────────

fn hex_prefix_to_float(sha: string) -> float {
    // first 8 hex chars → 32-bit unsigned int as float
    if len(sha) < 8 { return 0.0 }
    let prefix = sha.substring(0, 8)
    // printf-based hex parse via shell (use 64-bit-safe %llu)
    let cmd = "printf '%llu' 0x" + prefix
    let out = _str(exec(cmd)).trim()
    return to_float(out)
}

fn pearson_r(xs: array, ys: array) -> float {
    let n = len(xs)
    if n < 2 { return 0.0 }
    let mut sx = 0.0
    let mut sy = 0.0
    let mut i = 0
    while i < n {
        sx = sx + to_float(xs[i])
        sy = sy + to_float(ys[i])
        i = i + 1
    }
    let xm = sx / to_float(n)
    let ym = sy / to_float(n)
    let mut num = 0.0
    let mut dx2 = 0.0
    let mut dy2 = 0.0
    let mut j = 0
    while j < n {
        let dx = to_float(xs[j]) - xm
        let dy = to_float(ys[j]) - ym
        num = num + dx * dy
        dx2 = dx2 + dx * dx
        dy2 = dy2 + dy * dy
        j = j + 1
    }
    let denom = sqrt_newton(dx2) * sqrt_newton(dy2)
    if denom <= 0.0 { return 0.0 }
    return num / denom
}

// ─── main ────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "full"
    let mut k_arg = 0
    while k_arg < argc {
        let a = _str(argv[k_arg])
        if a == "--selftest" { mode = "selftest" }
        if a == "--help"     { mode = "help" }
        k_arg = k_arg + 1
    }

    if mode == "help" {
        println("usage:")
        println("  hexa run anima-cpgd-research/tool/cpgd_mcb_real_4bb_falsifier.hexa")
        println("  hexa run anima-cpgd-research/tool/cpgd_mcb_real_4bb_falsifier.hexa --selftest")
        return
    }

    println("════════════════════════════════════════════════════════════════")
    println("  cpgd_mcb_real_4bb_falsifier.hexa — CPGD-MCB REAL 5-bb × 3-rank 15-cell")
    println("  Loads 5-backbone × 3-rank hidden state matrix from JSON")
    println("════════════════════════════════════════════════════════════════")

    let root = resolve_root()
    let in_path  = root + "/" + IN_PATH
    let out_path = root + "/" + OUT_PATH

    let stat_check = _str(exec("test -f " + in_path + " && echo OK || echo MISSING")).trim()
    if stat_check != "OK" {
        println("[mcb][ERR] missing input " + in_path)
        println("[mcb]      run upstream forward wrappers first")
        if mode == "selftest" { exit(1) }
        return
    }

    let bb_count = load_int(in_path, ".backbones | length")
    let k = load_int(in_path, ".k_prompts")
    let ranks_str = _str(exec("jq -r '.ranks[]' " + in_path))
    let rank_lines = split(ranks_str.trim(), "\n")
    let rank_count = len(rank_lines)

    println("[mcb] backbones=" + to_string(bb_count) + " ranks=" + to_string(rank_count) + " k_prompts=" + to_string(k))

    // REAL 5-bb mode: process ALL backbones (tinyllama/gemma/phi3/mistral7b/
    // qwen3_8b) × ranks {4,8,16} = 15 cells single-pass.
    let mut cell_results = []  // each: [alias, rank, sha_canon, g1, g2, g3, g4, cell_cond, cell_sha, M, dim]
    let mut first_pass_idx = -1

    let mut bi = 0
    while bi < bb_count {
        let alias = load_str(in_path, ".backbones[" + to_string(bi) + "].alias")
        let model_id = load_str(in_path, ".backbones[" + to_string(bi) + "].model_id")
        println("\n[mcb] ── backbone " + to_string(bi) + ": " + alias + " (" + model_id + ") ──")

        let mut ri = 0
        while ri < rank_count {
            let rank = to_int(rank_lines[ri])
            let rank_key = to_string(rank)
            let cell_cond = load_float(in_path, ".backbones[" + to_string(bi) + "].cells.\"" + rank_key + "\".matrix_cond")
            let cell_fro  = load_float(in_path, ".backbones[" + to_string(bi) + "].cells.\"" + rank_key + "\".matrix_frobenius")
            let cell_sha  = load_str(in_path,   ".backbones[" + to_string(bi) + "].cells.\"" + rank_key + "\".matrix_sha256")

            println("[mcb] cell[" + alias + ", r=" + to_string(rank) + "] cond=" + to_string(cell_cond) + " fro=" + to_string(cell_fro))

            let M_full = load_cell_matrix(in_path, bi, rank_key, k, rank)
            if len(M_full) != k {
                println("[mcb][cell][ERR] matrix shape mismatch")
                ri = ri + 1
                continue
            }
            // Use first `rank` rows so K_eff == rank (square matrix).
            // The full SVD-reduced matrix preserves cond/sha; the dry_run
            // operates on a square block where Gram-Schmidt is rank-feasible.
            let mut M = []
            let mut mr = 0
            while mr < rank {
                M = push(M, M_full[mr])
                mr = mr + 1
            }
            let k_eff = rank

            // run twice for G3 byte-id (bools int-encoded due to hexa quirk)
            let r1 = dry_run_cell(M, rank, k_eff, DEFAULT_LR)
            let init_residual_1 = to_float(r1[1])
            let total_violations_1 = to_int(r1[2])
            let global_min_1 = to_float(r1[3])
            let max_drift_1 = to_float(r1[4])
            let idem_ok_1 = to_int(r1[5]) == 1
            let init_cos_ok_1 = to_int(r1[6]) == 1
            let rank_def_1 = to_int(r1[7]) == 1
            let all_above_1 = to_int(r1[8]) == 1
            let canon1 = cell_canonical(alias, rank, k_eff, STEP_COUNT, init_residual_1, total_violations_1,
                                          global_min_1, max_drift_1, idem_ok_1, init_cos_ok_1,
                                          rank_def_1, all_above_1, cell_cond, cell_fro, cell_sha)
            let sha1 = sha256_of_string(canon1)

            let r2 = dry_run_cell(M, rank, k_eff, DEFAULT_LR)
            let canon2 = cell_canonical(alias, rank, k_eff, STEP_COUNT, to_float(r2[1]), to_int(r2[2]),
                                          to_float(r2[3]), to_float(r2[4]),
                                          to_int(r2[5]) == 1, to_int(r2[6]) == 1,
                                          to_int(r2[7]) == 1, to_int(r2[8]) == 1,
                                          cell_cond, cell_fro, cell_sha)
            let sha2 = sha256_of_string(canon2)

            let g1 = (init_residual_1 < EPS_PROJ) && init_cos_ok_1
            let g2 = all_above_1 && (total_violations_1 == 0)
            let g3 = (sha1 != "" && sha1 == sha2)
            let g4 = cell_cond >= EPS_C
            let cell_pass = g1 && g2 && g3 && g4 && !rank_def_1

            println("[mcb]   G1=" + (if g1 { "P" } else { "F" })
                  + " G2=" + (if g2 { "P" } else { "F" })
                  + " G3=" + (if g3 { "P" } else { "F" })
                  + " G4=" + (if g4 { "P" } else { "F" })
                  + " cell=" + (if cell_pass { "PASS" } else { "FAIL" })
                  + " init_res=" + to_string(init_residual_1)
                  + " viol=" + to_string(total_violations_1)
                  + " gmin=" + to_string(global_min_1))

            // record cell — store bools as int 0/1 due to hexa mixed-array
            // bool quirk (false→true on extraction). entry indices 3..6 +
            // 9 + 14..16 are int-encoded booleans.
            let g1_i = if g1 { 1 } else { 0 }
            let g2_i = if g2 { 1 } else { 0 }
            let g3_i = if g3 { 1 } else { 0 }
            let g4_i = if g4 { 1 } else { 0 }
            let cp_i = if cell_pass { 1 } else { 0 }
            let rd_i = if rank_def_1 { 1 } else { 0 }
            let id_i = if idem_ok_1 { 1 } else { 0 }
            let ic_i = if init_cos_ok_1 { 1 } else { 0 }
            let entry = [alias, to_string(rank), sha1, g1_i, g2_i, g3_i, g4_i, cell_cond, cell_sha, cp_i,
                         init_residual_1, total_violations_1, global_min_1, max_drift_1, rd_i,
                         id_i, ic_i, M, rank]
            cell_results = push(cell_results, entry)
            if cell_pass && first_pass_idx < 0 {
                first_pass_idx = len(cell_results) - 1
            }
            ri = ri + 1
        }
        bi = bi + 1
    }

    // ─── Aggregate gates ─────────────────────────────────────────────────
    let total_cells = len(cell_results)
    let mut pass_count = 0
    let mut g1_pass_count = 0
    let mut g2_pass_count = 0
    let mut g3_pass_count = 0
    let mut g4_pass_count = 0
    let mut ci = 0
    while ci < total_cells {
        let entry = cell_results[ci]
        if to_int(entry[3]) == 1 { g1_pass_count = g1_pass_count + 1 }
        if to_int(entry[4]) == 1 { g2_pass_count = g2_pass_count + 1 }
        if to_int(entry[5]) == 1 { g3_pass_count = g3_pass_count + 1 }
        if to_int(entry[6]) == 1 { g4_pass_count = g4_pass_count + 1 }
        if to_int(entry[9]) == 1 { pass_count = pass_count + 1 }
        ci = ci + 1
    }

    // ─── Pearson r (cond-byte) ───────────────────────────────────────────
    let mut xs = []
    let mut ys = []
    let mut ck = 0
    while ck < total_cells {
        let entry = cell_results[ck]
        let cond_val = to_float(entry[7])
        let sha_str  = _str(entry[8])
        if cond_val > 0.0 && len(sha_str) >= 8 {
            xs = push(xs, log10_approx(cond_val))
            ys = push(ys, hex_prefix_to_float(sha_str))
        }
        ck = ck + 1
    }
    let r_value = pearson_r(xs, ys)
    let abs_r = fabs(r_value)
    let decoupled = abs_r < PEARSON_R_MAX

    // ─── Negative falsify on first PASS cell ─────────────────────────────
    let mut neg_caught = false
    if first_pass_idx >= 0 {
        let np_entry = cell_results[first_pass_idx]
        let M_np = np_entry[17]
        let dim_np = to_int(np_entry[18])
        let np_alias = _str(np_entry[0])
        let np_rank = _str(np_entry[1])
        println("\n[mcb] ── negative falsify on first PASS cell: " + np_alias + " r=" + np_rank + " ──")
        // M_np is K_eff=rank rows; pass dim_np (=rank) as K too.
        neg_caught = negative_falsify(M_np, dim_np, dim_np)
        println("[mcb] negative_falsify_caught=" + (if neg_caught { "true" } else { "false" }))
    } else {
        println("\n[mcb][WARN] no PASS cell found — skipping negative falsify")
    }

    let min_pass_required = total_cells - MIN_PASS_LENIENCY
    let ag1 = pass_count >= min_pass_required
    let ag2 = decoupled
    let mcb_verified = ag1 && ag2 && neg_caught

    println("\n[mcb] ════════════════════════════════════════════════════════")
    println("[mcb] AGGREGATE")
    println("[mcb]   total_cells=" + to_string(total_cells))
    println("[mcb]   G1_pass=" + to_string(g1_pass_count) + "/" + to_string(total_cells))
    println("[mcb]   G2_pass=" + to_string(g2_pass_count) + "/" + to_string(total_cells))
    println("[mcb]   G3_pass=" + to_string(g3_pass_count) + "/" + to_string(total_cells))
    println("[mcb]   G4_pass=" + to_string(g4_pass_count) + "/" + to_string(total_cells))
    println("[mcb]   cell_pass_total=" + to_string(pass_count) + "/" + to_string(total_cells))
    println("[mcb]   AG1 (>=" + to_string(min_pass_required) + " of " + to_string(total_cells) + " cells PASS) = " + (if ag1 { "true" } else { "false" }))
    println("[mcb]   pearson_r=" + to_string(r_value) + "  |r|=" + to_string(abs_r))
    println("[mcb]   AG2 (|r|<" + to_string(PEARSON_R_MAX) + ") = " + (if ag2 { "true" } else { "false" }))
    println("[mcb]   neg_falsify_caught=" + (if neg_caught { "true" } else { "false" }))
    println("[mcb]   verdict=" + (if mcb_verified { "CPGD_MCB_BRIDGE_CLOSED" } else { "CPGD_MCB_FAIL" }))
    println("[mcb] ════════════════════════════════════════════════════════")

    // ─── Write JSON output ───────────────────────────────────────────────
    let mut j = "{\n"
    j = j + "  \"schema_version\": \"3\",\n"
    j = j + "  \"slug\": \"cpgd-mcb-real-4bb-falsifier-v1\",\n"
    j = j + "  \"title\": \"CPGD-MCB REAL 5-backbone × 3-rank 15-cell bridge closure falsifier\",\n"
    j = j + "  \"created\": \"2026-04-27\",\n"
    j = j + "  \"path\": \"C-MCB\",\n"
    j = j + "  \"raw_strict\": \"raw#9 hexa-only deterministic; input from python wrapper raw#37\",\n"
    j = j + "  \"honest_limit\": \"raw#10 — 5-backbone (tinyllama/gemma/phi3/mistral7b/qwen3_8b) × 3-rank ({4,8,16}) × k_prompts=16 real hidden states bundle; mac-local exec only (anima-cpgd-research/state inputs not on hetzner remote tree)\",\n"
    j = j + "  \"tool\": \"anima-cpgd-research/tool/cpgd_mcb_real_4bb_falsifier.hexa\",\n"
    j = j + "  \"depends_on\": [\"anima-cpgd-research/state/cpgd_mcb_real_4bb_v1.json\"],\n"
    j = j + "  \"backbones\": " + to_string(bb_count) + ",\n"
    j = j + "  \"ranks\": " + to_string(rank_count) + ",\n"
    j = j + "  \"k_prompts\": " + to_string(k) + ",\n"
    j = j + "  \"step_count\": " + to_string(STEP_COUNT) + ",\n"
    j = j + "  \"lr\": " + to_string(DEFAULT_LR) + ",\n"
    j = j + "  \"grad_seed\": " + to_string(GRAD_SEED) + ",\n"
    j = j + "  \"cos_floor\": " + to_string(COS_FLOOR) + ",\n"
    j = j + "  \"eps_proj\": " + to_string(EPS_PROJ) + ",\n"
    j = j + "  \"eps_c\": " + to_string(EPS_C) + ",\n"
    j = j + "  \"pearson_r_max\": " + to_string(PEARSON_R_MAX) + ",\n"
    j = j + "  \"min_pass_required\": " + to_string(min_pass_required) + ",\n"
    j = j + "  \"min_pass_leniency\": " + to_string(MIN_PASS_LENIENCY) + ",\n"
    j = j + "  \"cells\": [\n"
    let mut wi = 0
    while wi < total_cells {
        let entry = cell_results[wi]
        if wi > 0 { j = j + ",\n" }
        j = j + "    {\n"
        j = j + "      \"alias\": \"" + _str(entry[0]) + "\",\n"
        j = j + "      \"rank\": " + _str(entry[1]) + ",\n"
        j = j + "      \"matrix_sha256\": \"" + _str(entry[8]) + "\",\n"
        j = j + "      \"matrix_cond\": " + to_string(to_float(entry[7])) + ",\n"
        j = j + "      \"canon_sha256\": \"" + _str(entry[2]) + "\",\n"
        j = j + "      \"init_residual\": " + to_string(to_float(entry[10])) + ",\n"
        j = j + "      \"total_violations\": " + to_string(to_int(entry[11])) + ",\n"
        j = j + "      \"global_min_cos\": " + to_string(to_float(entry[12])) + ",\n"
        j = j + "      \"max_cos_drift\": " + to_string(to_float(entry[13])) + ",\n"
        j = j + "      \"projector_idempotent\": " + (if to_int(entry[15]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"init_unit_cos_ok\": " + (if to_int(entry[16]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"rank_deficient\": " + (if to_int(entry[14]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"G1\": " + (if to_int(entry[3]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"G2\": " + (if to_int(entry[4]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"G3\": " + (if to_int(entry[5]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"G4\": " + (if to_int(entry[6]) == 1 { "true" } else { "false" }) + ",\n"
        j = j + "      \"cell_pass\": " + (if to_int(entry[9]) == 1 { "true" } else { "false" }) + "\n"
        j = j + "    }"
        wi = wi + 1
    }
    j = j + "\n  ],\n"
    j = j + "  \"aggregate\": {\n"
    j = j + "    \"total_cells\": " + to_string(total_cells) + ",\n"
    j = j + "    \"g1_pass\": " + to_string(g1_pass_count) + ",\n"
    j = j + "    \"g2_pass\": " + to_string(g2_pass_count) + ",\n"
    j = j + "    \"g3_pass\": " + to_string(g3_pass_count) + ",\n"
    j = j + "    \"g4_pass\": " + to_string(g4_pass_count) + ",\n"
    j = j + "    \"cell_pass_total\": " + to_string(pass_count) + ",\n"
    j = j + "    \"AG1_min_pass_cells\": " + (if ag1 { "true" } else { "false" }) + ",\n"
    j = j + "    \"pearson_r\": " + to_string(r_value) + ",\n"
    j = j + "    \"abs_pearson_r\": " + to_string(abs_r) + ",\n"
    j = j + "    \"AG2_decoupled\": " + (if ag2 { "true" } else { "false" }) + ",\n"
    j = j + "    \"negative_falsify_caught\": " + (if neg_caught { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"verdict\": \"" + (if mcb_verified { "CPGD_MCB_BRIDGE_CLOSED" } else { "CPGD_MCB_FAIL" }) + "\"\n"
    j = j + "}\n"
    write_file(out_path, j)
    println("[mcb] wrote " + OUT_PATH)

    if mode == "selftest" {
        if mcb_verified { exit(0) } else { exit(1) }
    }
}
