// ════════════════════════════════════════════════════════════════════════════
//  anima-cpgd-research/tool/cpgd_phi3mini_real_lm_falsifier.hexa
//  Path C (Q4 generalization) — Phi-3-mini real-LM surrogate falsifier
//
//  PURPOSE
//    Test whether CPGD closed-form init + 100-step convergence holds for a
//    Phi-3-mini family hidden-state surrogate (deterministic FNV 6×8 matrix,
//    condition_proxy ~ 5). raw#10 honest synthetic Phi-3-mini surrogate —
//    NOT real GPU forward.
//
//  FROZEN GATES (from README.md — DO NOT relax)
//    G1: closed-form init residual ‖(I - P_S) · W_0‖ ≤ EPS_PROJ (=1e-4)
//    G2: 100-step monotone descent — total_violations (cos < 0.5) == 0
//    G3: 2 sequential runs sha256(payload) byte-identical
//
//  TARGET (Phi-3-mini hidden-state surrogate)
//    DIM=8, TPL_COUNT=6 (Phi-3-mini-ish hidden subspace, 6 templates)
//    basis: deterministic FNV-1a-hashed 6 vectors in R^8, target cond ~5
//    seed: 0x70686933 ("phi3" ASCII) for byte-stable Phi-3 brand naming
//
//  NEGATIVE-FALSIFY (mandatory ω-cycle step 5)
//    Pathological: collinear v_2 = v_0 — Gram-Schmidt rank-deficient.
//
//  HONEST LIMIT (raw#10)
//    This is a Phi-3-mini *surrogate* — FNV bytes shaped as if from Phi-3
//    hidden states. Real Phi-3-mini forward requires GPU + transformer load,
//    which this $0 mac local cycle does not perform. Verdict applies to the
//    surrogate only; transition to real LM requires GPU prerequisite.
//
//  OUTPUT: anima-cpgd-research/state/cpgd_phi3mini_real_lm_v1.json
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only · $0
// ════════════════════════════════════════════════════════════════════════════

let OUT_PATH       = "anima-cpgd-research/state/cpgd_phi3mini_real_lm_v1.json"
let DIM            = 8
let TPL_COUNT      = 6
let STEP_COUNT     = 100
let DEFAULT_LR     = 0.001
let GRAD_SEED      = 20260426
let INIT_SEED      = 20260426
let PHI3_BRAND_SEED = 1885957427    // ASCII "phi3" big-endian
let GRAD_SCALE     = 1.0
let COS_FLOOR      = 0.5
let EPS_IDEM       = 0.00001
let EPS_PROJ       = 0.0001

let FNV_OFFSET = 2166136261
let FNV_PRIME  = 16777619
let FNV_MOD    = 4294967296

// ─── helpers ───────────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

fn vec_scale(a: array, s: float) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = push(out, to_float(a[i]) * s)
        i = i + 1
    }
    return out
}

fn vec_sub(a: array, b: array) -> array {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = push(out, to_float(a[i]) - to_float(b[i]))
        i = i + 1
    }
    return out
}

// ─── FNV-1a (modular arithmetic, no bitwise XOR) ──────────────────────────

fn fnv_step(h: int, b: int) -> int {
    let mixed = (h + b) % FNV_MOD
    return (mixed * FNV_PRIME) % FNV_MOD
}

fn fnv_seed_to_floats(seed: int, count: int) -> array {
    let mut h = (FNV_OFFSET + seed) % FNV_MOD
    let mut out = []
    let mut i = 0
    while i < count {
        let b1 = (i * 31 + 7) % 256
        let b2 = (i * 17 + 11) % 256
        let b3 = (i * 53 + 23) % 256
        let b4 = (i * 89 + 41) % 256
        h = fnv_step(h, b1)
        h = fnv_step(h, b2)
        h = fnv_step(h, b3)
        h = fnv_step(h, b4)
        let frac = to_float(h % 1000000) / 1000000.0
        let val  = 2.0 * frac - 1.0
        out = push(out, val)
        i = i + 1
    }
    return out
}

// Phi-3-mini surrogate basis — branded seed for byte-traceable provenance.
fn phi3_basis_raw() -> array {
    let mut V = []
    let mut i = 0
    while i < TPL_COUNT {
        let seed = PHI3_BRAND_SEED + i * 1000003
        let row = fnv_seed_to_floats(seed, DIM)
        V = push(V, row)
        i = i + 1
    }
    return V
}

// ─── Gram-Schmidt orthonormalization ──────────────────────────────────────

fn gram_schmidt(V_raw: array) -> array {
    let n = len(V_raw)
    let mut Q = []
    let mut i = 0
    while i < n {
        let v = V_raw[i]
        let mut u = []
        let mut k = 0
        while k < DIM {
            u = push(u, to_float(v[k]))
            k = k + 1
        }
        let mut j = 0
        while j < len(Q) {
            let qj = Q[j]
            let proj_coef = vec_dot(u, qj)
            let proj_vec  = vec_scale(qj, proj_coef)
            u = vec_sub(u, proj_vec)
            j = j + 1
        }
        let nrm = vec_norm(u)
        if nrm < 0.000001 {
            let mut z = []
            let mut zk = 0
            while zk < DIM {
                z = push(z, 0.0)
                zk = zk + 1
            }
            Q = push(Q, z)
        } else {
            let u_norm = vec_scale(u, 1.0 / nrm)
            Q = push(Q, u_norm)
        }
        i = i + 1
    }
    return Q
}

fn detect_rank_deficient(Q: array) -> bool {
    let n = len(Q)
    let mut i = 0
    while i < n {
        if vec_norm(Q[i]) < 0.000001 { return true }
        i = i + 1
    }
    return false
}

fn estimate_condition_proxy(V_raw: array) -> float {
    let n = len(V_raw)
    let mut max_norm = 0.0
    let mut min_norm = 1.0e30
    let mut i = 0
    while i < n {
        let nrm = vec_norm(V_raw[i])
        if nrm > max_norm { max_norm = nrm }
        if nrm < min_norm && nrm > 0.0 { min_norm = nrm }
        i = i + 1
    }
    if min_norm <= 0.0 || min_norm > 1.0e29 { return 1.0e30 }
    let mut max_offdiag = 0.0
    let mut a = 0
    while a < n {
        let mut b = 0
        while b < n {
            if a != b {
                let ip = fabs(vec_dot(V_raw[a], V_raw[b]))
                let scale = vec_norm(V_raw[a]) * vec_norm(V_raw[b])
                let normed = if scale > 0.0 { ip / scale } else { 0.0 }
                if normed > max_offdiag { max_offdiag = normed }
            }
            b = b + 1
        }
        a = a + 1
    }
    let ratio = max_norm / min_norm
    let offdiag_factor = if max_offdiag < 0.999 { 1.0 / (1.0 - max_offdiag) } else { 1000.0 }
    return ratio * offdiag_factor
}

// ─── linear algebra ────────────────────────────────────────────────────────

fn build_projector(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < DIM {
        let mut row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

fn verify_projector_idempotent(P: array) -> bool {
    let mut max_delta = 0.0
    let mut a = 0
    while a < DIM {
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < DIM {
                s = s + to_float(P[a][k]) * to_float(P[k][b])
                k = k + 1
            }
            let d = fabs(s - to_float(P[a][b]))
            if d > max_delta { max_delta = d }
            b = b + 1
        }
        a = a + 1
    }
    return max_delta < EPS_IDEM
}

// ─── deterministic RNG ─────────────────────────────────────────────────────

fn lcg_next(state_arr: array) -> float {
    let mut s = to_int(state_arr[0])
    s = (s * 1103515245 + 12345) % 2147483648
    state_arr[0] = s
    return to_float(s % 1000000) / 1000000.0
}

fn randn_pair(state_arr: array) -> array {
    let u1_raw = lcg_next(state_arr)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let u2 = lcg_next(state_arr)
    let r = sqrt_newton(0.0 - 2.0 * log(u1))
    let theta = 2.0 * 3.141592653589793 * u2
    let z1 = r * cos(theta)
    let z2 = r * sin(theta)
    return [z1, z2]
}

fn rand_matrix(rows: int, cols: int, state_arr: array) -> array {
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = randn_pair(state_arr)
            row = push(row, to_float(pair[0]) * GRAD_SCALE)
            j = j + 1
            if j < cols {
                row = push(row, to_float(pair[1]) * GRAD_SCALE)
                j = j + 1
            }
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

fn matmul_right(G: array, P: array) -> array {
    let rows = len(G)
    let mut out = []
    let mut i = 0
    while i < rows {
        let g = G[i]
        let mut new_row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut a = 0
            while a < DIM {
                s = s + to_float(g[a]) * to_float(P[a][b])
                a = a + 1
            }
            new_row = push(new_row, s)
            b = b + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn gradient_step(W: array, grad_raw: array, P_S: array, lr: float) -> array {
    let grad_proj = matmul_right(grad_raw, P_S)
    let rows = len(W)
    let mut out = []
    let mut i = 0
    while i < rows {
        let w = W[i]
        let g = grad_proj[i]
        let mut new_row = []
        let mut j = 0
        while j < DIM {
            new_row = push(new_row, to_float(w[j]) - lr * to_float(g[j]))
            j = j + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn row_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

fn projection_residual(W: array, P_S: array) -> float {
    let n = len(W)
    let mut max_res = 0.0
    let mut i = 0
    while i < n {
        let w = W[i]
        let mut pw = []
        let mut a = 0
        while a < DIM {
            let mut s = 0.0
            let mut b = 0
            while b < DIM {
                s = s + to_float(P_S[a][b]) * to_float(w[b])
                b = b + 1
            }
            pw = push(pw, s)
            a = a + 1
        }
        let mut diff_norm_sq = 0.0
        let mut k = 0
        while k < DIM {
            let d = to_float(w[k]) - to_float(pw[k])
            diff_norm_sq = diff_norm_sq + d * d
            k = k + 1
        }
        let res = sqrt_newton(diff_norm_sq)
        if res > max_res { max_res = res }
        i = i + 1
    }
    return max_res
}

// ─── orchestration ────────────────────────────────────────────────────────

// Returns:
//  [step_count, min_per_tpl, global_min, max_drift, all_above,
//   idem_ok, init_cos_ok, init_residual, total_violations, cs_last,
//   cond_proxy, rank_def]
fn dry_run_phi3(V_raw: array, lr: float) -> array {
    let cond_proxy = estimate_condition_proxy(V_raw)
    let V_orth = gram_schmidt(V_raw)
    let rank_def = detect_rank_deficient(V_orth)

    if rank_def {
        let mut empty_min = []
        let mut k = 0
        while k < TPL_COUNT {
            empty_min = push(empty_min, 0.0)
            k = k + 1
        }
        return [STEP_COUNT, empty_min, 0.0, 1.0, false,
                false, false, 1.0e30, STEP_COUNT * TPL_COUNT, empty_min,
                cond_proxy, true]
    }

    let P_S = build_projector(V_orth)
    let idem_ok = verify_projector_idempotent(P_S)

    let mut W = []
    let mut r = 0
    while r < TPL_COUNT {
        let v = V_orth[r]
        let mut row = []
        let mut jj = 0
        while jj < DIM {
            row = push(row, to_float(v[jj]))
            jj = jj + 1
        }
        W = push(W, row)
        r = r + 1
    }

    let init_residual = projection_residual(W, P_S)
    let c_init = row_cosines(W, V_orth)
    let mut init_cos_ok = true
    let mut ii = 0
    while ii < TPL_COUNT {
        let ci = to_float(c_init[ii])
        if fabs(ci - 1.0) > 1e-8 { init_cos_ok = false }
        ii = ii + 1
    }

    let mut min_per_tpl = []
    let mut k = 0
    while k < TPL_COUNT {
        min_per_tpl = push(min_per_tpl, to_float(c_init[k]))
        k = k + 1
    }

    let state_arr = [GRAD_SEED]
    let mut max_drift = 0.0
    let mut all_above = true
    let mut total_violations = 0
    let mut global_min = 1.0
    let mut cs_last = c_init
    let mut step = 0
    while step < STEP_COUNT {
        let grad = rand_matrix(TPL_COUNT, DIM, state_arr)
        W = gradient_step(W, grad, P_S, lr)
        let cs = row_cosines(W, V_orth)
        cs_last = cs
        let mut i = 0
        while i < TPL_COUNT {
            let c = to_float(cs[i])
            if c < to_float(min_per_tpl[i]) { min_per_tpl[i] = c }
            if c < global_min { global_min = c }
            let drift = fabs(1.0 - c)
            if drift > max_drift { max_drift = drift }
            if c < COS_FLOOR {
                all_above = false
                total_violations = total_violations + 1
            }
            i = i + 1
        }
        step = step + 1
    }

    return [STEP_COUNT, min_per_tpl, global_min, max_drift, all_above,
            idem_ok, init_cos_ok, init_residual, total_violations, cs_last,
            cond_proxy, false]
}

// ─── canonical payload ────────────────────────────────────────────────────

fn canonical_payload(step_count: int, min_per_tpl: array,
                     global_min: float, all_above: bool, max_drift: float,
                     init_residual: float, cond_proxy: float,
                     idem_ok: bool, init_cos_ok: bool, rank_def: bool,
                     total_violations: int) -> string {
    let mut s = "cpgd_phi3mini_real_lm_v1|"
    s = s + "step_count=" + to_string(step_count) + "|"
    s = s + "template_count=" + to_string(TPL_COUNT) + "|"
    s = s + "dim=" + to_string(DIM) + "|"
    s = s + "lr=" + to_string(DEFAULT_LR) + "|"
    s = s + "grad_seed=" + to_string(GRAD_SEED) + "|"
    s = s + "init_seed=" + to_string(INIT_SEED) + "|"
    s = s + "phi3_brand_seed=" + to_string(PHI3_BRAND_SEED) + "|"
    s = s + "idem_ok=" + (if idem_ok { "true" } else { "false" }) + "|"
    s = s + "init_cos_ok=" + (if init_cos_ok { "true" } else { "false" }) + "|"
    s = s + "rank_def=" + (if rank_def { "true" } else { "false" }) + "|"
    s = s + "init_residual=" + to_string(init_residual) + "|"
    s = s + "cond_proxy=" + to_string(cond_proxy) + "|"
    s = s + "all_above=" + (if all_above { "true" } else { "false" }) + "|"
    s = s + "total_violations=" + to_string(total_violations) + "|"
    s = s + "global_min_cos=" + to_string(global_min) + "|"
    s = s + "max_drift=" + to_string(max_drift) + "|"
    s = s + "min_per_tpl="
    let n = len(min_per_tpl)
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + to_string(to_float(min_per_tpl[i]))
        i = i + 1
    }
    return s
}

fn sha256_of_string(s: string) -> string {
    let tmp = "/tmp/cpgd_phi3_sha_" + to_string(len(s)) + ".txt"
    write_file(tmp, s)
    let r = _str(exec("shasum -a 256 " + tmp + " | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + tmp)
    return r
}

fn emit_float_array(a: array) -> string {
    let n = len(a)
    let mut s = "["
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + to_string(to_float(a[i]))
        i = i + 1
    }
    return s + "]"
}

// ─── pathological negative-falsify ───────────────────────────────────────

fn build_pathological_basis() -> array {
    let V = phi3_basis_raw()
    let mut Vp = []
    let mut i = 0
    while i < TPL_COUNT {
        let mut row = []
        let mut j = 0
        while j < DIM {
            // make v_2 = v_0 (collinear duplicate ⇒ rank-deficient)
            if i == 2 {
                row = push(row, to_float(V[0][j]))
            } else {
                row = push(row, to_float(V[i][j]))
            }
            j = j + 1
        }
        Vp = push(Vp, row)
        i = i + 1
    }
    return Vp
}

fn negative_falsify() -> bool {
    let Vp = build_pathological_basis()
    let r = dry_run_phi3(Vp, DEFAULT_LR)
    let rank_def = to_bool(r[11])
    return rank_def
}

// ─── 2-run determinism (G3) ───────────────────────────────────────────────

fn run_once(V_raw: array, lr: float) -> array {
    let r = dry_run_phi3(V_raw, lr)
    let step_count   = to_int(r[0])
    let min_per_tpl  = r[1]
    let global_min   = to_float(r[2])
    let max_drift    = to_float(r[3])
    let all_above    = to_bool(r[4])
    let idem_ok      = to_bool(r[5])
    let init_cos_ok  = to_bool(r[6])
    let init_res     = to_float(r[7])
    let total_viol   = to_int(r[8])
    let cs_last      = r[9]
    let cond_proxy   = to_float(r[10])
    let rank_def     = to_bool(r[11])
    let canon = canonical_payload(step_count, min_per_tpl, global_min, all_above,
                                   max_drift, init_res, cond_proxy,
                                   idem_ok, init_cos_ok, rank_def, total_viol)
    let sha = sha256_of_string(canon)
    return [sha, all_above, min_per_tpl, max_drift, step_count,
            idem_ok, init_cos_ok, init_res, total_viol, cs_last, global_min,
            cond_proxy, rank_def]
}

// ─── main ─────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "full"
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--selftest" { mode = "selftest" }
        if a == "--help"     { mode = "help" }
        k = k + 1
    }

    if mode == "help" {
        println("usage:")
        println("  hexa run anima-cpgd-research/tool/cpgd_phi3mini_real_lm_falsifier.hexa")
        println("  hexa run anima-cpgd-research/tool/cpgd_phi3mini_real_lm_falsifier.hexa --selftest")
        return
    }

    println("════════════════════════════════════════════════════════════════")
    println("  cpgd_phi3mini_real_lm_falsifier.hexa — Path C Q4 Task 1")
    println("  Phi-3-mini surrogate: K=6 dim=8 FNV-hashed, branded seed")
    println("  raw#10 honest synthetic — NOT real Phi-3 GPU forward")
    println("════════════════════════════════════════════════════════════════")

    let root = resolve_root()
    let out_path = root + "/" + OUT_PATH

    let V_raw = phi3_basis_raw()
    let cond_pre = estimate_condition_proxy(V_raw)
    println("[phi3] surrogate K=" + to_string(TPL_COUNT) + " dim=" + to_string(DIM))
    println("[phi3] cond_proxy(V_raw)=" + to_string(cond_pre))

    println("[phi3] ── positive run (G1+G2+G3) ──")
    let a1 = run_once(V_raw, DEFAULT_LR)
    let sha1       = _str(a1[0])
    let all_above  = to_bool(a1[1])
    let min_per_tpl = a1[2]
    let max_drift  = to_float(a1[3])
    let step_count = to_int(a1[4])
    let idem_ok    = to_bool(a1[5])
    let init_cos_ok = to_bool(a1[6])
    let init_res   = to_float(a1[7])
    let total_viol = to_int(a1[8])
    let cs_last    = a1[9]
    let global_min = to_float(a1[10])
    let cond_proxy = to_float(a1[11])
    let rank_def   = to_bool(a1[12])

    println("[phi3] run1=" + sha1)
    let a2 = run_once(V_raw, DEFAULT_LR)
    let sha2 = _str(a2[0])
    println("[phi3] run2=" + sha2)
    let byte_id = (sha1 != "" && sha1 == sha2)

    let g1_pass = (init_res < EPS_PROJ) && init_cos_ok
    let g2_pass = all_above && (total_viol == 0)
    let g3_pass = byte_id

    println("[phi3] ── negative falsify (collinear v_2 == v_0) ──")
    let neg_ok = negative_falsify()
    println("[phi3] negative_falsify_caught=" + (if neg_ok { "true" } else { "false" }))

    let phi3_verified = g1_pass && g2_pass && g3_pass && neg_ok && !rank_def

    println("[phi3] G1_init_residual=" + to_string(init_res) + " (<" + to_string(EPS_PROJ) + ") g1_pass=" + (if g1_pass { "true" } else { "false" }))
    println("[phi3] G2_total_violations=" + to_string(total_viol) + " g2_pass=" + (if g2_pass { "true" } else { "false" }))
    println("[phi3] G3_byte_identical=" + (if g3_pass { "true" } else { "false" }))
    println("[phi3] cond_proxy=" + to_string(cond_proxy) + " global_min_cos=" + to_string(global_min) + " max_drift=" + to_string(max_drift))
    println("[phi3] verdict=" + (if phi3_verified { "PHI3_SURROGATE_GENERALIZED" } else { "PHI3_SURROGATE_FAIL" }))

    let mut j = "{\n"
    j = j + "  \"schema_version\": \"1\",\n"
    j = j + "  \"slug\": \"cpgd-phi3mini-real-lm-v1\",\n"
    j = j + "  \"title\": \"Path C Q4 Task 1 — CPGD Phi-3-mini real-LM surrogate falsifier\",\n"
    j = j + "  \"created\": \"2026-04-26\",\n"
    j = j + "  \"path\": \"C\",\n"
    j = j + "  \"raw_strict\": \"raw#9 hexa-only deterministic no_python no_llm\",\n"
    j = j + "  \"honest_limit\": \"raw#10 honest Phi-3-mini surrogate — NOT real GPU forward; FNV deterministic 6x8 matrix branded with phi3 ASCII seed\",\n"
    j = j + "  \"tool\": \"anima-cpgd-research/tool/cpgd_phi3mini_real_lm_falsifier.hexa\",\n"
    j = j + "  \"depends_on\": [\"anima-cpgd-research/tool/cpgd_an9_falsifier.hexa\", \"anima-cpgd-research/tool/cpgd_anarbitrary_falsifier.hexa\"],\n"
    j = j + "  \"step_count\": " + to_string(step_count) + ",\n"
    j = j + "  \"template_count\": " + to_string(TPL_COUNT) + ",\n"
    j = j + "  \"dim\": " + to_string(DIM) + ",\n"
    j = j + "  \"lr\": " + to_string(DEFAULT_LR) + ",\n"
    j = j + "  \"grad_seed\": " + to_string(GRAD_SEED) + ",\n"
    j = j + "  \"init_seed\": " + to_string(INIT_SEED) + ",\n"
    j = j + "  \"phi3_brand_seed\": " + to_string(PHI3_BRAND_SEED) + ",\n"
    j = j + "  \"cos_floor\": " + to_string(COS_FLOOR) + ",\n"
    j = j + "  \"eps_proj\": " + to_string(EPS_PROJ) + ",\n"
    j = j + "  \"projector_idempotent\": " + (if idem_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"init_unit_cosine_ok\": " + (if init_cos_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"init_residual\": " + to_string(init_res) + ",\n"
    j = j + "  \"cond_proxy\": " + to_string(cond_proxy) + ",\n"
    j = j + "  \"rank_deficient\": " + (if rank_def { "true" } else { "false" }) + ",\n"
    j = j + "  \"min_cos_per_template\": " + emit_float_array(min_per_tpl) + ",\n"
    j = j + "  \"cos_at_final_step\": " + emit_float_array(cs_last) + ",\n"
    j = j + "  \"global_min_cos\": " + to_string(global_min) + ",\n"
    j = j + "  \"max_cos_drift\": " + to_string(max_drift) + ",\n"
    j = j + "  \"total_violations\": " + to_string(total_viol) + ",\n"
    j = j + "  \"selftest_2run\": {\n"
    j = j + "    \"run1_sha\": \"" + sha1 + "\",\n"
    j = j + "    \"run2_sha\": \"" + sha2 + "\",\n"
    j = j + "    \"byte_identical\": " + (if byte_id { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"frozen_gates\": {\n"
    j = j + "    \"G1_init_residual_pass\": " + (if g1_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G2_monotone_no_violation\": " + (if g2_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G3_byte_identical\": " + (if g3_pass { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"negative_falsify_caught_pathological\": " + (if neg_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"verdict\": \"" + (if phi3_verified { "PHI3_SURROGATE_GENERALIZED" } else { "PHI3_SURROGATE_FAIL" }) + "\"\n"
    j = j + "}\n"
    write_file(out_path, j)
    println("[phi3] wrote " + OUT_PATH)

    if mode == "selftest" {
        if phi3_verified { exit(0) } else { exit(1) }
    }
}

main()
