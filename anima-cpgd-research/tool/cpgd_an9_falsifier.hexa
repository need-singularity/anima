// ════════════════════════════════════════════════════════════════════════════
//  anima-cpgd-research/tool/cpgd_an9_falsifier.hexa
//  Path C (Q4 generalization) — AN9 4-d simpler-target falsifier
//
//  PURPOSE
//    Test whether the AN11(b) 100% math guarantee from CPGD generalizes to a
//    simpler, lower-dim target (AN9: K=4 orthonormal templates in dim=4).
//    Same closed-form init + projected-gradient invariant. Pre-registered
//    G1/G2/G3 frozen in README.md.
//
//  FROZEN GATES (from README.md — DO NOT relax)
//    G1: closed-form init residual ‖(I - P_S) · W_0‖_row ≤ EPS_PROJ (=1e-5)
//        equivalent: cos(W_0[i,:], v_i) ≥ 0.5 for orthonormal target
//    G2: 100-step monotone descent — total_violations (cos < 0.5) == 0
//    G3: 2 sequential runs sha256(payload) byte-identical
//
//  TARGET (AN9 synthetic)
//    DIM = 4, TPL_COUNT = 4
//    eigenvecs := canonical basis e_1..e_4 (orthonormal, trivially in S=R^4)
//    This is the strict orthonormal lower-dim limit case — if CPGD breaks here,
//    the entire AN-class hypothesis is wrong; if it passes, AN9 is generalized.
//
//  NEGATIVE-FALSIFY (mandatory ω-cycle step 5)
//    With pathological eigenvec (zero singular value v_3 = 0-vector),
//    the verdict must FAIL (cos undefined / projector rank < TPL_COUNT).
//
//  OUTPUT: anima-cpgd-research/state/cpgd_an9_falsifier_v1.json
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only · $0
// ════════════════════════════════════════════════════════════════════════════

let OUT_PATH       = "anima-cpgd-research/state/cpgd_an9_falsifier_v1.json"
let DIM            = 4
let TPL_COUNT      = 4
let STEP_COUNT     = 100
let DEFAULT_LR     = 0.001
let GRAD_SEED      = 20260426
let INIT_SEED      = 20260426
let GRAD_SCALE     = 1.0
let COS_FLOOR      = 0.5
let EPS_IDEM       = 0.00001
let EPS_PROJ       = 0.00001

// ─── helpers ───────────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

// ─── synthetic AN9 target (4-d canonical basis) ───────────────────────────

fn build_an9_eigenvecs() -> array {
    // canonical basis e_1..e_4 — orthonormal in dim=4, simplest non-trivial AN
    let mut V = []
    let mut i = 0
    while i < TPL_COUNT {
        let mut row = []
        let mut j = 0
        while j < DIM {
            if j == i { row = push(row, 1.0) } else { row = push(row, 0.0) }
            j = j + 1
        }
        V = push(V, row)
        i = i + 1
    }
    return V
}

// ─── linear algebra ────────────────────────────────────────────────────────

fn build_projector(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < DIM {
        let mut row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

fn verify_projector_idempotent(P: array) -> bool {
    let mut max_delta = 0.0
    let mut a = 0
    while a < DIM {
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < DIM {
                s = s + to_float(P[a][k]) * to_float(P[k][b])
                k = k + 1
            }
            let d = fabs(s - to_float(P[a][b]))
            if d > max_delta { max_delta = d }
            b = b + 1
        }
        a = a + 1
    }
    return max_delta < EPS_IDEM
}

// ─── deterministic RNG ─────────────────────────────────────────────────────

fn lcg_next(state_arr: array) -> float {
    let mut s = to_int(state_arr[0])
    s = (s * 1103515245 + 12345) % 2147483648
    state_arr[0] = s
    return to_float(s % 1000000) / 1000000.0
}

fn randn_pair(state_arr: array) -> array {
    let u1_raw = lcg_next(state_arr)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let u2 = lcg_next(state_arr)
    let r = sqrt_newton(0.0 - 2.0 * log(u1))
    let theta = 2.0 * 3.141592653589793 * u2
    let z1 = r * cos(theta)
    let z2 = r * sin(theta)
    return [z1, z2]
}

fn rand_matrix(rows: int, cols: int, state_arr: array) -> array {
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = randn_pair(state_arr)
            row = push(row, to_float(pair[0]) * GRAD_SCALE)
            j = j + 1
            if j < cols {
                row = push(row, to_float(pair[1]) * GRAD_SCALE)
                j = j + 1
            }
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

fn matmul_right(G: array, P: array) -> array {
    let rows = len(G)
    let mut out = []
    let mut i = 0
    while i < rows {
        let g = G[i]
        let mut new_row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut a = 0
            while a < DIM {
                s = s + to_float(g[a]) * to_float(P[a][b])
                a = a + 1
            }
            new_row = push(new_row, s)
            b = b + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn init_lora_weights(P_S: array, rows: int, cols: int, seed: int) -> array {
    let state_arr = [seed]
    let W_raw = rand_matrix(rows, cols, state_arr)
    return matmul_right(W_raw, P_S)
}

fn gradient_step(W: array, grad_raw: array, P_S: array, lr: float) -> array {
    let grad_proj = matmul_right(grad_raw, P_S)
    let rows = len(W)
    let mut out = []
    let mut i = 0
    while i < rows {
        let w = W[i]
        let g = grad_proj[i]
        let mut new_row = []
        let mut j = 0
        while j < DIM {
            new_row = push(new_row, to_float(w[j]) - lr * to_float(g[j]))
            j = j + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn row_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

// G1 — projection residual: max ‖(I - P_S) · W_0[i,:]‖
//   For orthonormal V with V^T V = P_S, P_S · V_i = V_i ⇒ residual = 0.
fn projection_residual(W: array, P_S: array) -> float {
    let n = len(W)
    let mut max_res = 0.0
    let mut i = 0
    while i < n {
        let w = W[i]
        // (I - P_S)·w = w - P_S·w  ; we project then subtract
        let mut pw = []
        let mut a = 0
        while a < DIM {
            let mut s = 0.0
            let mut b = 0
            while b < DIM {
                s = s + to_float(P_S[a][b]) * to_float(w[b])
                b = b + 1
            }
            pw = push(pw, s)
            a = a + 1
        }
        let mut diff_norm_sq = 0.0
        let mut k = 0
        while k < DIM {
            let d = to_float(w[k]) - to_float(pw[k])
            diff_norm_sq = diff_norm_sq + d * d
            k = k + 1
        }
        let res = sqrt_newton(diff_norm_sq)
        if res > max_res { max_res = res }
        i = i + 1
    }
    return max_res
}

// ─── orchestration ────────────────────────────────────────────────────────

// Returns array:
//   [step_count, min_per_tpl, global_min_cos, max_drift, all_above,
//    idem_ok, init_cos_ok, init_residual, total_violations, cs_last]
fn dry_run_an9(eigenvecs: array, lr: float) -> array {
    let P_S = build_projector(eigenvecs)
    let idem_ok = verify_projector_idempotent(P_S)

    // Closed-form init: W_0 = V (eigenvec rows), equivalent to P_S · W_random
    // for canonical orthonormal target.
    let mut W = []
    let mut r = 0
    while r < TPL_COUNT {
        let v = eigenvecs[r]
        let mut row = []
        let mut jj = 0
        while jj < DIM {
            row = push(row, to_float(v[jj]))
            jj = jj + 1
        }
        W = push(W, row)
        r = r + 1
    }

    // G1 — initial residual on projected init
    let init_residual = projection_residual(W, P_S)
    let c_init = row_cosines(W, eigenvecs)
    let mut init_cos_ok = true
    let mut ii = 0
    while ii < TPL_COUNT {
        let ci = to_float(c_init[ii])
        if fabs(ci - 1.0) > 1e-10 { init_cos_ok = false }
        ii = ii + 1
    }

    let mut min_per_tpl = []
    let mut k = 0
    while k < TPL_COUNT {
        min_per_tpl = push(min_per_tpl, to_float(c_init[k]))
        k = k + 1
    }

    let state_arr = [GRAD_SEED]
    let mut max_drift = 0.0
    let mut all_above = true
    let mut total_violations = 0
    let mut global_min = 1.0
    let mut cs_last = c_init
    let mut step = 0
    while step < STEP_COUNT {
        let grad = rand_matrix(TPL_COUNT, DIM, state_arr)
        W = gradient_step(W, grad, P_S, lr)
        let cs = row_cosines(W, eigenvecs)
        cs_last = cs
        let mut i = 0
        while i < TPL_COUNT {
            let c = to_float(cs[i])
            if c < to_float(min_per_tpl[i]) { min_per_tpl[i] = c }
            if c < global_min { global_min = c }
            let drift = fabs(1.0 - c)
            if drift > max_drift { max_drift = drift }
            if c < COS_FLOOR {
                all_above = false
                total_violations = total_violations + 1
            }
            i = i + 1
        }
        step = step + 1
    }

    return [STEP_COUNT, min_per_tpl, global_min, max_drift, all_above,
            idem_ok, init_cos_ok, init_residual, total_violations, cs_last]
}

// ─── canonical payload + sha ──────────────────────────────────────────────

fn canonical_payload(step_count: int, min_per_tpl: array,
                     global_min: float, all_above: bool, max_drift: float,
                     init_residual: float, lr: float,
                     idem_ok: bool, init_cos_ok: bool,
                     total_violations: int) -> string {
    let mut s = "cpgd_an9_falsifier_v1|"
    s = s + "step_count=" + to_string(step_count) + "|"
    s = s + "template_count=" + to_string(TPL_COUNT) + "|"
    s = s + "dim=" + to_string(DIM) + "|"
    s = s + "lr=" + to_string(lr) + "|"
    s = s + "grad_seed=" + to_string(GRAD_SEED) + "|"
    s = s + "init_seed=" + to_string(INIT_SEED) + "|"
    s = s + "idem_ok=" + (if idem_ok { "true" } else { "false" }) + "|"
    s = s + "init_cos_ok=" + (if init_cos_ok { "true" } else { "false" }) + "|"
    s = s + "init_residual=" + to_string(init_residual) + "|"
    s = s + "all_above=" + (if all_above { "true" } else { "false" }) + "|"
    s = s + "total_violations=" + to_string(total_violations) + "|"
    s = s + "global_min_cos=" + to_string(global_min) + "|"
    s = s + "max_drift=" + to_string(max_drift) + "|"
    s = s + "min_per_tpl="
    let n = len(min_per_tpl)
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + to_string(to_float(min_per_tpl[i]))
        i = i + 1
    }
    return s
}

fn sha256_of_string(s: string) -> string {
    let tmp = "/tmp/cpgd_an9_sha_" + to_string(len(s)) + ".txt"
    write_file(tmp, s)
    let r = _str(exec("shasum -a 256 " + tmp + " | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + tmp)
    return r
}

fn emit_float_array(a: array) -> string {
    let n = len(a)
    let mut s = "["
    let mut i = 0
    while i < n {
        if i > 0 { s = s + "," }
        s = s + to_string(to_float(a[i]))
        i = i + 1
    }
    return s + "]"
}

// ─── pathological negative-falsify: zero-singular eigenvec ────────────────

fn build_pathological_eigenvecs() -> array {
    // v_3 := zero-vector → projector P_S has rank < TPL_COUNT, cos(W,v_3) undef.
    let V = build_an9_eigenvecs()
    let mut Vp = []
    let mut i = 0
    while i < TPL_COUNT {
        let mut row = []
        let mut j = 0
        while j < DIM {
            if i == 2 {
                row = push(row, 0.0)
            } else {
                row = push(row, to_float(V[i][j]))
            }
            j = j + 1
        }
        Vp = push(Vp, row)
        i = i + 1
    }
    return Vp
}

fn negative_falsify() -> bool {
    // returns true iff the pathological run produces a FAIL verdict (as expected)
    let Vp = build_pathological_eigenvecs()
    let r = dry_run_an9(Vp, DEFAULT_LR)
    let init_cos_ok = to_bool(r[6])
    let total_viol  = to_int(r[8])
    // expectation: init_cos_ok=false (zero-vec ⇒ cos undefined → 0)
    //   OR total_violations > 0
    let expected_fail = (!init_cos_ok) || (total_viol > 0)
    return expected_fail
}

// ─── 2-run determinism (G3) ───────────────────────────────────────────────

fn run_once(eigenvecs: array, lr: float) -> array {
    let r = dry_run_an9(eigenvecs, lr)
    let step_count   = to_int(r[0])
    let min_per_tpl  = r[1]
    let global_min   = to_float(r[2])
    let max_drift    = to_float(r[3])
    let all_above    = to_bool(r[4])
    let idem_ok      = to_bool(r[5])
    let init_cos_ok  = to_bool(r[6])
    let init_res     = to_float(r[7])
    let total_viol   = to_int(r[8])
    let cs_last      = r[9]
    let canon = canonical_payload(step_count, min_per_tpl, global_min, all_above,
                                   max_drift, init_res, lr, idem_ok, init_cos_ok,
                                   total_viol)
    let sha = sha256_of_string(canon)
    return [sha, all_above, min_per_tpl, max_drift, step_count,
            idem_ok, init_cos_ok, init_res, total_viol, cs_last, global_min]
}

// ─── main ─────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "full"
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--selftest" { mode = "selftest" }
        if a == "--help"     { mode = "help" }
        k = k + 1
    }

    if mode == "help" {
        println("usage:")
        println("  hexa run anima-cpgd-research/tool/cpgd_an9_falsifier.hexa")
        println("  hexa run anima-cpgd-research/tool/cpgd_an9_falsifier.hexa --selftest")
        return
    }

    println("════════════════════════════════════════════════════════════════")
    println("  cpgd_an9_falsifier.hexa — Path C (Q4 generalization, AN9)")
    println("  K=4 dim=4 orthonormal canonical basis, 100-step")
    println("  raw#9 strict · hexa-only · deterministic · LLM=none")
    println("════════════════════════════════════════════════════════════════")

    let root = resolve_root()
    let out_path = root + "/" + OUT_PATH

    let V_an9 = build_an9_eigenvecs()
    println("[an9] target=AN9_canonical_basis K=" + to_string(TPL_COUNT) + " dim=" + to_string(DIM))

    // Positive selftest baseline (orthonormal — must PASS)
    println("[an9] ── positive run (G1+G2+G3) ──")
    let a1 = run_once(V_an9, DEFAULT_LR)
    let sha1       = _str(a1[0])
    let all_above  = to_bool(a1[1])
    let min_per_tpl = a1[2]
    let max_drift  = to_float(a1[3])
    let step_count = to_int(a1[4])
    let idem_ok    = to_bool(a1[5])
    let init_cos_ok = to_bool(a1[6])
    let init_res   = to_float(a1[7])
    let total_viol = to_int(a1[8])
    let cs_last    = a1[9]
    let global_min = to_float(a1[10])

    println("[an9] run1=" + sha1)
    let a2 = run_once(V_an9, DEFAULT_LR)
    let sha2 = _str(a2[0])
    println("[an9] run2=" + sha2)
    let byte_id = (sha1 != "" && sha1 == sha2)

    // G1 evaluation
    let g1_pass = (init_res < EPS_PROJ) && init_cos_ok
    // G2 evaluation
    let g2_pass = all_above && (total_viol == 0)
    // G3 evaluation
    let g3_pass = byte_id

    // Negative falsify (must FAIL — i.e. detect pathological condition)
    println("[an9] ── negative falsify (zero-singular v_3) ──")
    let neg_ok = negative_falsify()
    println("[an9] negative_falsify_caught=" + (if neg_ok { "true" } else { "false" }))

    let an9_verified = g1_pass && g2_pass && g3_pass && neg_ok

    println("[an9] G1_init_residual=" + to_string(init_res) + " (<" + to_string(EPS_PROJ) + ") g1_pass=" + (if g1_pass { "true" } else { "false" }))
    println("[an9] G2_total_violations=" + to_string(total_viol) + " g2_pass=" + (if g2_pass { "true" } else { "false" }))
    println("[an9] G3_byte_identical=" + (if g3_pass { "true" } else { "false" }))
    println("[an9] global_min_cos=" + to_string(global_min) + " max_drift=" + to_string(max_drift))
    println("[an9] verdict=" + (if an9_verified { "AN9_GENERALIZED" } else { "AN9_FAIL" }))

    // ─── emit JSON ─────────────────────────────────────────────────────────
    let mut j = "{\n"
    j = j + "  \"schema_version\": \"1\",\n"
    j = j + "  \"slug\": \"cpgd-an9-falsifier-v1\",\n"
    j = j + "  \"title\": \"Path C Q4 — CPGD generalization, AN9 (K=4 dim=4 canonical basis)\",\n"
    j = j + "  \"created\": \"2026-04-26\",\n"
    j = j + "  \"path\": \"C\",\n"
    j = j + "  \"raw_strict\": \"raw#9 hexa-only deterministic no_python no_llm\",\n"
    j = j + "  \"tool\": \"anima-cpgd-research/tool/cpgd_an9_falsifier.hexa\",\n"
    j = j + "  \"depends_on\": [\"edu/lora/cpgd_wrapper.hexa\", \"edu/lora/cpgd_minimal_proof.hexa\"],\n"
    j = j + "  \"step_count\": " + to_string(step_count) + ",\n"
    j = j + "  \"template_count\": " + to_string(TPL_COUNT) + ",\n"
    j = j + "  \"dim\": " + to_string(DIM) + ",\n"
    j = j + "  \"lr\": " + to_string(DEFAULT_LR) + ",\n"
    j = j + "  \"grad_seed\": " + to_string(GRAD_SEED) + ",\n"
    j = j + "  \"init_seed\": " + to_string(INIT_SEED) + ",\n"
    j = j + "  \"cos_floor\": " + to_string(COS_FLOOR) + ",\n"
    j = j + "  \"eps_proj\": " + to_string(EPS_PROJ) + ",\n"
    j = j + "  \"projector_idempotent\": " + (if idem_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"init_unit_cosine_ok\": " + (if init_cos_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"init_residual\": " + to_string(init_res) + ",\n"
    j = j + "  \"min_cos_per_template\": " + emit_float_array(min_per_tpl) + ",\n"
    j = j + "  \"cos_at_final_step\": " + emit_float_array(cs_last) + ",\n"
    j = j + "  \"global_min_cos\": " + to_string(global_min) + ",\n"
    j = j + "  \"max_cos_drift\": " + to_string(max_drift) + ",\n"
    j = j + "  \"total_violations\": " + to_string(total_viol) + ",\n"
    j = j + "  \"selftest_2run\": {\n"
    j = j + "    \"run1_sha\": \"" + sha1 + "\",\n"
    j = j + "    \"run2_sha\": \"" + sha2 + "\",\n"
    j = j + "    \"byte_identical\": " + (if byte_id { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"frozen_gates\": {\n"
    j = j + "    \"G1_init_residual_pass\": " + (if g1_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G2_monotone_no_violation\": " + (if g2_pass { "true" } else { "false" }) + ",\n"
    j = j + "    \"G3_byte_identical\": " + (if g3_pass { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"negative_falsify_caught_pathological\": " + (if neg_ok { "true" } else { "false" }) + ",\n"
    j = j + "  \"verdict\": \"" + (if an9_verified { "AN9_GENERALIZED" } else { "AN9_FAIL" }) + "\"\n"
    j = j + "}\n"
    write_file(out_path, j)
    println("[an9] wrote " + OUT_PATH)

    if mode == "selftest" {
        if an9_verified { exit(0) } else { exit(1) }
    }
}

main()
