// ════════════════════════════════════════════════════════════════════════════
//  anima-hci-research/tool/hci_smoke.hexa
//
//  PURPOSE  (HCI Path B — Q3 composite chain integration)
//    Read frozen state files written by hci_functor_falsifier.hexa (F1+F2)
//    and hci_adversarial_flip.hexa (F3), parse their verdicts, and emit
//    a single composite verdict:
//        HCI_VERIFIED  iff  F1 PASS ∧ F2 PASS ∧ F3 ROBUST
//
//  PRECONDITIONS
//    - state/hci_functor_falsifier_v1.json must exist (run that tool first)
//    - state/hci_adversarial_flip_v1.json must exist (run that tool first)
//
//  PARSE STRATEGY  (raw#9 hexa-only, no jq)
//    grep / substring scan on JSON for the boolean keys we wrote ourselves.
//    This is robust because we control the writer format.
//
//  OUTPUT
//    state/hci_smoke_v1.json
//
//  RAW
//    raw#9 · pure hexa · deterministic · no LLM · no Python emit
// ════════════════════════════════════════════════════════════════════════════

let FUNCTOR_PATH = "anima-hci-research/state/hci_functor_falsifier_v1.json"
let ADVERS_PATH  = "anima-hci-research/state/hci_adversarial_flip_v1.json"
let OUT_PATH     = "anima-hci-research/state/hci_smoke_v1.json"

fn bool_s(b: bool) -> string { if b { return "true" } else { return "false" } }
fn now_stamp() -> string { return exec("date +%Y-%m-%dT%H:%M:%S").trim() }

// ─── JSON-substring lookup ──────────────────────────────────────────────────
// For a key like "f1_pass" we look for the literal:    "f1_pass": true
// or                                                   "f1_pass": false
// We handle both with two probes; absence ⇒ false (conservative).
fn find_bool(content: string, key: string) -> bool {
    let needle_t = "\"" + key + "\": true"
    let needle_f = "\"" + key + "\": false"
    if content.contains(needle_t) { return true }
    if content.contains(needle_f) { return false }
    return false
}

fn find_string(content: string, key: string) -> string {
    let probe = "\"" + key + "\": \""
    let idx = content.index_of(probe)
    if idx < 0 { return "" }
    let start = idx + len(probe)
    let rest = content.substring(start, len(content))
    let end = rest.index_of("\"")
    if end < 0 { return "" }
    return rest.substring(0, end)
}

// ─── main ───────────────────────────────────────────────────────────────────
fn main() {
    println("[hci_smoke] HCI Path B Q3 composite chain")
    println("  read: " + FUNCTOR_PATH)
    println("  read: " + ADVERS_PATH)
    println("")

    let func_exists = file_exists(FUNCTOR_PATH)
    let adv_exists  = file_exists(ADVERS_PATH)
    if !func_exists {
        println("[hci_smoke] FATAL: missing functor falsifier state — run hci_functor_falsifier.hexa first")
        exit(2)
    }
    if !adv_exists {
        println("[hci_smoke] FATAL: missing adversarial flip state — run hci_adversarial_flip.hexa first")
        exit(2)
    }

    let func_json = read_file(FUNCTOR_PATH)
    let adv_json  = read_file(ADVERS_PATH)

    let f1_pass = find_bool(func_json, "f1_pass")
    let f2_pass = find_bool(func_json, "f2_pass")
    let f1_neg  = find_bool(func_json, "f1_neg_detects")
    let f2_neg  = find_bool(func_json, "f2_neg_detects")
    let func_verdict = find_string(func_json, "composite_verdict")

    let baseline_ok    = find_bool(adv_json, "baseline_both_closed")
    let revert_ok      = find_bool(adv_json, "revert_ok")
    let f3_verdict     = find_string(adv_json, "f3_verdict")
    let s1_bidir       = find_bool(adv_json, "bidirectional")  // first occurrence (s1)

    // For s2, scan after the s1 block (we know s1 occurs first).
    let s1_marker = "\"s1_phantom\""
    let s2_marker = "\"s2_leaky\""
    let s2_idx = adv_json.index_of(s2_marker)
    let s2_bidir = if s2_idx >= 0 {
        find_bool(adv_json.substring(s2_idx, len(adv_json)), "bidirectional")
    } else { false }

    println("=== F1+F2 from functor falsifier ===")
    println("  f1_pass         = " + bool_s(f1_pass))
    println("  f2_pass         = " + bool_s(f2_pass))
    println("  f1_neg_detects  = " + bool_s(f1_neg))
    println("  f2_neg_detects  = " + bool_s(f2_neg))
    println("  func_verdict    = " + func_verdict)
    println("")

    println("=== F3 from adversarial flip ===")
    println("  baseline_ok     = " + bool_s(baseline_ok))
    println("  s1_bidir flip   = " + bool_s(s1_bidir))
    println("  s2_bidir flip   = " + bool_s(s2_bidir))
    println("  revert_ok       = " + bool_s(revert_ok))
    println("  f3_verdict      = " + f3_verdict)
    println("")

    // ─── composite verdict ────────────────────────────────────────────────
    let f1_ok = f1_pass && f1_neg
    let f2_ok = f2_pass && f2_neg
    let f3_ok = baseline_ok && s1_bidir && s2_bidir && revert_ok
    let composite = f1_ok && f2_ok && f3_ok
    let verdict = if composite { "HCI_VERIFIED" } else { "HCI_FAIL" }

    println("=== composite chain ===")
    println("  F1 ok = " + bool_s(f1_ok))
    println("  F2 ok = " + bool_s(f2_ok))
    println("  F3 ok = " + bool_s(f3_ok))
    println("  HCI verdict = " + verdict)
    println("")

    // ─── JSON emit ───────────────────────────────────────────────────────
    let mut out = "{\n"
    out = out + "  \"schema\": \"anima/hci_smoke/1\",\n"
    out = out + "  \"schema_version\": 1,\n"
    out = out + "  \"verifier_type\": \"hci_smoke\",\n"
    out = out + "  \"version\": \"v1\",\n"
    out = out + "  \"generated\": \"" + now_stamp() + "\",\n"
    out = out + "  \"source\": \"anima-hci-research/tool/hci_smoke.hexa\",\n"
    out = out + "  \"inputs\": [\n"
    out = out + "    \"" + FUNCTOR_PATH + "\",\n"
    out = out + "    \"" + ADVERS_PATH + "\"\n"
    out = out + "  ],\n"
    out = out + "  \"f1_ok\": " + bool_s(f1_ok) + ",\n"
    out = out + "  \"f2_ok\": " + bool_s(f2_ok) + ",\n"
    out = out + "  \"f3_ok\": " + bool_s(f3_ok) + ",\n"
    out = out + "  \"f1_pass\": " + bool_s(f1_pass) + ",\n"
    out = out + "  \"f2_pass\": " + bool_s(f2_pass) + ",\n"
    out = out + "  \"f1_neg_detects\": " + bool_s(f1_neg) + ",\n"
    out = out + "  \"f2_neg_detects\": " + bool_s(f2_neg) + ",\n"
    out = out + "  \"baseline_both_closed\": " + bool_s(baseline_ok) + ",\n"
    out = out + "  \"s1_bidirectional\": " + bool_s(s1_bidir) + ",\n"
    out = out + "  \"s2_bidirectional\": " + bool_s(s2_bidir) + ",\n"
    out = out + "  \"revert_ok\": " + bool_s(revert_ok) + ",\n"
    out = out + "  \"functor_verdict\": \"" + func_verdict + "\",\n"
    out = out + "  \"f3_verdict\": \"" + f3_verdict + "\",\n"
    out = out + "  \"hci_verdict\": \"" + verdict + "\"\n"
    out = out + "}\n"
    write_file(OUT_PATH, out)
    println("  wrote: " + OUT_PATH)

    if verdict == "HCI_VERIFIED" { exit(0) }
    exit(1)
}

main()
