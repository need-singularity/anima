// eeg_recorder.hexa — EEG background recorder: dual-stream for --web mode
// Auto-segmentation into 5-minute files

struct EEGBackgroundRecorder {
    recording: bool,
    segment_duration: i32,
    board_type: string,
    output_dir: string
}

struct RecorderStatus {
    recording: bool,
    elapsed_sec: float,
    segments_saved: i32,
    current_phi: float
}

fn create_recorder(board_type: string) -> EEGBackgroundRecorder {
    return EEGBackgroundRecorder(false, 300, board_type, "data/eeg/")
}

fn start(recorder: EEGBackgroundRecorder) -> bool {
    print("starting EEG background recorder")
    return true
}

fn stop(recorder: EEGBackgroundRecorder) -> bool {
    print("stopping EEG background recorder")
    return true
}

fn get_status(recorder: EEGBackgroundRecorder) -> RecorderStatus {
    return RecorderStatus(recorder.recording, 0.0, 0, 0.0)
}
