// closed_loop.hexa — Closed-loop EEG protocol: nback + meditation + neurofeedback
// Feedback modes: eeg_only, bidirectional, neurofeedback_only

struct ClosedLoopConfig {
    protocol: string,
    feedback_mode: string,
    duration_sec: i32,
    adaptive: bool
}

struct ClosedLoopResult {
    phi_mean: float,
    alpha_power: float,
    n_back_accuracy: float,
    feedback_events: i32
}

fn run_closed_loop(config: ClosedLoopConfig) -> ClosedLoopResult {
    print("closed-loop EEG: " + config.protocol + " mode=" + config.feedback_mode)
    return ClosedLoopResult(0.0, 0.0, 0.0, 0)
}

fn run_nback(difficulty: i32, duration: i32) -> ClosedLoopResult {
    return run_closed_loop(ClosedLoopConfig("nback", "bidirectional", duration, true))
}

fn run_meditation(duration: i32) -> ClosedLoopResult {
    return run_closed_loop(ClosedLoopConfig("meditation", "bidirectional", duration, true))
}
