fn run_phi_only(cells: int, steps: int) {
    println("=== Phi-Only Measurement ===")
    let e = engine_new(cells)
    let iit = measure_phi_iit(e)
    let proxy = measure_phi_proxy(e)
    println("  Phi(IIT):", iit, "  Phi(proxy):", proxy)
}

