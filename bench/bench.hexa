// --- CLI ---
let args = args()
if args.len() < 3 {
    println("bench/bench.hexa — Dual-Phi Consciousness Benchmark")
    println("  hexa bench/bench.hexa --verify [--cells 256] [--steps 300]")
    println("  hexa bench/bench.hexa --phi-only [--cells 512]")
    println("  hexa bench/bench.hexa --training")
    println("  hexa bench/bench.hexa --compare")
} else {
    let cmd = args[2]
    let cells = DEFAULT_CELLS
    let steps = DEFAULT_STEPS
    if cmd == "--verify" { run_verify(cells, steps) }
    else if cmd == "--phi-only" { run_phi_only(cells, steps) }
    else if cmd == "--training" { run_training(cells, steps) }
    else if cmd == "--compare" { run_compare() }
    else { println("unknown:", cmd) }
}
