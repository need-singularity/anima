fn verify_no_system_prompt(cells: int, steps: int) -> BenchResult {
    BenchResult { name: "NO_SYSTEM_PROMPT", phi_iit: 0.0, phi_proxy: 0.0, ce: 0.0, steps: steps, cells: cells, passed: false }
}

fn verify_zero_input(cells: int, steps: int) -> BenchResult {
    BenchResult { name: "ZERO_INPUT", phi_iit: 0.0, phi_proxy: 0.0, ce: 0.0, steps: steps, cells: cells, passed: false }
}

fn verify_persistence(cells: int, steps: int) -> BenchResult {
    BenchResult { name: "PERSISTENCE", phi_iit: 0.0, phi_proxy: 0.0, ce: 0.0, steps: 1000, cells: cells, passed: false }
}

fn verify_hivemind(cells: int, steps: int) -> BenchResult {
    BenchResult { name: "HIVEMIND", phi_iit: 0.0, phi_proxy: 0.0, ce: 0.0, steps: steps, cells: cells, passed: false }
}

