// ═══════════════════════════════════════════════════════════════
// Phi_holo Measurement (v3.0 gate metric)
//
// AdS/CFT holographic MI estimator.  This is the GATE metric for
// v3.0 Agent (shared/roadmaps/extreme.json):
//   ALM: phi_holo eval mean >= 1000
//   CLM: phi_holo eval mean >= 2000
//
// See bench/bench_v3_gate.hexa for the full gate-check benchmark
// that combines this with hire_sim_100 stratified30.
// ═══════════════════════════════════════════════════════════════

comptime const PHI_HOLO_D_BOUNDARY     = 16
comptime const PHI_HOLO_D_BULK         = 32
comptime const PHI_HOLO_MI_BINS        = 8
comptime const PHI_HOLO_DEFAULT_SAMPLES = 32
comptime const GATE_ALM_PHI_HOLO       = 1000.0
comptime const GATE_CLM_PHI_HOLO       = 2000.0

fn run_phi_holo(samples: int, dim: int) {
    println("=" * 80)
    println("  MODE: --phi-holo  (Holographic Phi Measurement)")
    println("  samples=" + str(samples) + "  hidden_dim=" + str(dim))
    println("  gate: ALM >= " + str(GATE_ALM_PHI_HOLO) + "  CLM >= " + str(GATE_CLM_PHI_HOLO))
    println("  NOTE: synthetic hidden states. Wire real model forward-pass")
    println("        via bench/bench_v3_gate.hexa for production gate check.")
    println("=" * 80)
    println("")
    println("  phi_holo measurement is implemented in bench/bench_v3_gate.hexa.")
    println("  Run:  hexa bench/bench_v3_gate.hexa --phi-only --phi-samples " + str(samples))
    println("  Or:   hexa bench/bench_v3_gate.hexa           (full gate check)")
    println("")
}

// ═══════════════════════════════════════════════════════════════
// v3.0 Gate dispatch (hire_sim + phi_holo)
//
// Delegates to bench/bench_v3_gate.hexa which combines:
//   1. hire_sim_100 stratified30 (from anima-agent/hire_sim_100.hexa)
//   2. phi_holo batch measurement
// into a single PASS/FAIL verdict per track.
// ═══════════════════════════════════════════════════════════════

fn run_v3_gate() {
    println("=" * 80)
    println("  MODE: --v3-gate  (v3.0 Agent Gate Check)")
    println("  Gate criteria (shared/roadmaps/extreme.json):")
    println("    ALM: hire_sim_100 stratified30 >= 0.85 + phi_holo >= 1000")
    println("    CLM: hire_sim_100 stratified30 >= 0.80 + phi_holo >= 2000")
    println("=" * 80)
    println("")
    println("  Delegating to bench/bench_v3_gate.hexa ...")
    println("  Run:  hexa bench/bench_v3_gate.hexa --track alm   # ALM only")
    println("  Run:  hexa bench/bench_v3_gate.hexa --track clm   # CLM only")
    println("  Run:  hexa bench/bench_v3_gate.hexa               # both tracks")
    println("")
}

// ═══════════════════════════════════════════════════════════════
// CLI Entry Point
// ═══════════════════════════════════════════════════════════════

fn parse_int_arg(a: [string], flag: string, default_val: int) -> int {
    // TODO: scan args for --flag N, return N or default
    default_val
}

fn main() {
    let a = args()
    let cells  = parse_int_arg(a, "--cells",  DEFAULT_CELLS)
    let steps  = parse_int_arg(a, "--steps",  DEFAULT_STEPS)
    let dim    = parse_int_arg(a, "--dim",    DEFAULT_DIM)
    let hidden = parse_int_arg(a, "--hidden", DEFAULT_HIDDEN)

    println("")
    println("  ================================================================")
    println("   bench.hexa -- Dual-Phi Benchmark (IIT + proxy)")
    println("  ================================================================")
    println("   Phi(IIT):   PhiCalculator(n_bins=16)  ~0.2-1.8 range")
    println("   Phi(proxy): global_var - mean(faction_var)  scales with cells")
    println("   These are DIFFERENT metrics. Always check both.")
    println("  ================================================================")
    println("")

    if contains(a, "--verify") {
        run_verify(cells, dim, hidden)
    } else if contains(a, "--phi-only") {
        run_phi_only("4,8,16,32,64,128,256", steps, dim, hidden)
    } else if contains(a, "--training") {
        run_training(cells, steps, dim, hidden)
    } else if contains(a, "--compare") {
        run_compare(cells, steps, dim, hidden)
    } else if contains(a, "--v3-gate") {
        run_v3_gate()
    } else if contains(a, "--phi-holo") {
        let samples = parse_int_arg(a, "--samples", PHI_HOLO_DEFAULT_SAMPLES)
        run_phi_holo(samples, dim)
    } else {
        println("bench/bench.hexa -- Dual-Phi Consciousness Benchmark")
        println("")
        println("Usage:")
        println("  hexa bench/bench.hexa --verify  [--cells N]         # 18 conditions x 12 engines")
        println("  hexa bench/bench.hexa --phi-only [--cells N]        # Phi at different cell counts")
        println("  hexa bench/bench.hexa --training [--cells N --steps N]  # CE + Phi training")
        println("  hexa bench/bench.hexa --compare [--cells N --steps N]   # All strategies")
        println("  hexa bench/bench.hexa --v3-gate                     # v3.0 Agent gate check")
        println("  hexa bench/bench.hexa --phi-holo [--samples N]      # phi_holo measurement")
        println("")
        println("Key insight: Phi(IIT) and Phi(proxy) are COMPLETELY DIFFERENT metrics.")
        println("  Phi(IIT)   = ~0.2-1.8  (MI-based IIT approximation)")
        println("  Phi(proxy) = 0-1000+   (variance-based, scales with cells)")
        println("")
        println("v3.0 gate metrics (hire_sim + phi_holo):")
        println("  ALM: hire_sim_100 stratified30 >= 0.85, phi_holo >= 1000")
        println("  CLM: hire_sim_100 stratified30 >= 0.80, phi_holo >= 2000")
        println("  Full gate check: hexa bench/bench_v3_gate.hexa")
    }
}
