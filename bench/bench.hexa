// --- Bench params ---
comptime const DEFAULT_CELLS     = 256
comptime const DEFAULT_STEPS     = 300
comptime const DEFAULT_FACTIONS  = 12
comptime const PHI_BINS          = 16

struct BenchResult {
    name: string,
    phi_iit: float,       // MI-based, 0~2
    phi_proxy: float,     // variance-based, 0~∞
    ce: float,
    steps: int,
    cells: int,
    passed: bool
}

struct BenchEngine {
    cells: int,
    factions: int,
    topology: string,
    chaos_mode: string,
    step_count: int,
    phi_peak: float,
    backend: string       // "rust" | "python" | "stub"
}

fn engine_new(cells: int) -> BenchEngine {
    BenchEngine {
        cells: cells, factions: DEFAULT_FACTIONS,
        topology: "ring", chaos_mode: "lorenz",
        step_count: 0, phi_peak: 0.0, backend: "stub"
    }
}

