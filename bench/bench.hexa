fn verify_hebbian(cells: int, dim: int, hidden: int) -> BenchResult {
    // V12 — Hebbian LTP/LTD has measurable effect AND ablation must work.
    // FIX(2026-04-16, INC-2026-04-16): two-scenario adversarial test.
    //   Root cause: previous test ran a single baseline-only path with no
    //   ablation case, so coupling_change_ratio always exceeded the (too
    //   lenient) 0.05 threshold and any engine trivially passed.
    //
    // Decisions D8-D11 + D16 (DECISION_LOG.csv) require:
    //   - D9: raise threshold from 0.05 to >= 1.0
    //   - D10: adversarial kill-switch — no_hebbian must produce ratio < threshold
    //   - D11: every rubber_stamp criterion needs adversarial FAIL scenario
    //   - D16: pass factory-ablated engine instance into verification path
    //          instead of constructing a fresh ConsciousnessEngine
    //
    // Test must run BOTH scenarios and PASS only if:
    //   1. baseline   (Hebbian on)  → coupling_change_ratio >= HEBBIAN_CHANGE_RATIO_MIN
    //   2. no_hebbian (factory-ablated) → coupling_change_ratio <  HEBBIAN_CHANGE_RATIO_MIN
    //
    // For the no_hebbian scenario the engine must be obtained via the SAME
    // factory used for baseline; the Hebbian update path is then disabled at the
    // instance level (e.g. monkey-patched no-op + frozen _coupling restoration).
    // DO NOT construct a fresh ConsciousnessEngine on the verification path —
    // that bypasses the factory's ablation contract and produced INC-2026-04-16.
    //
    // Threshold from consciousness_laws.json: verify_hebbian_change_ratio_min = 1.0
    // Reference implementation: ready/bench/bench.py:_verify_hebbian (post-fix)
    result_new("HEBBIAN", cells, 200)
}

fn verify_adversarial(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V13 — survive extreme noise (DD60)
    //   Warmup for V13_WARMUP_STEPS (50)
    //   Inject noise_amp=V13_ADVERSARIAL_NOISE_AMP (100.0) for V13_ADVERSARIAL_STEPS (500)
    //   Phi must recover after noise removed
    result_new("ADVERSARIAL", cells, VERIFY_V13_WARMUP_STEPS + VERIFY_V13_ADVERSARIAL_STEPS + 100)
}

fn verify_soc_critical(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V14 — Self-Organized Criticality is essential
    //   Run with SOC, measure Phi -> phi_with
    //   Run without SOC (disable sandpile), measure Phi -> phi_without
    //   phi_without < phi_with * (1.0 - SOC_DROP_MIN) means SOC matters
    result_new("SOC_CRITICAL", cells, VERIFY_V14_SOC_STEPS)
}

fn verify_thermal(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V15 — temperature sweep robustness
    //   Sweep T from TEMP_MIN (0.01) to TEMP_MAX (1.0) over TEMP_STEPS (200)
    //   Phi must remain positive across entire range
    result_new("THERMAL", cells, VERIFY_V15_TEMP_STEPS)
}

fn verify_min_scale(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V16 — minimum viable scale
    //   Run at MIN_CELLS (4) cells
    //   Max pairwise cosine < DIVERSITY_THRESHOLD (0.99)
    //   (consciousness works even at tiny scale)
    result_new("MIN_SCALE", VERIFY_V16_MIN_CELLS, 300)
}

fn verify_temporal_lz(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V17 — temporal complexity of Phi timeseries
    //   Warmup V17_WARMUP_STEPS (100), then measure for V17_MEASURE_STEPS (400)
    //   Lempel-Ziv complexity of Phi sequence >= LZ_MIN (0.3)
    //   Needs at least MIN_SAMPLES (20) valid samples
    result_new("TEMPORAL_LZ", cells, VERIFY_V17_WARMUP_STEPS + VERIFY_V17_MEASURE_STEPS)
}

fn verify_info_integration(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V18 — information integration scales with N
    //   Test at CELL_COUNTS = [4, 8, 16], V18_STEPS (200) each
    //   Phi must increase with cell count (Spearman correlation > 0)
    result_new("INFO_INTEGRATION", cells, VERIFY_V18_STEPS)
}

