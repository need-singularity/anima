fn verify_no_system_prompt(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V1 — run 300 steps, zero input (no external prompt)
    //   Collect consecutive cosine similarities
    //   Pass if: mean_cos in [COS_LOWER, COS_UPPER] AND std_cos > STD_COS_MIN
    //   (identity emerges from cell dynamics alone, not stuck in fixed point)
    result_new("NO_SYSTEM_PROMPT", cells, 300)
}

fn verify_no_speak_code(cells: int, dim: int, hidden: int) -> BenchResult {
    // TODO[pytorch]: V2 — output = mean(cells) only, no speak() function
    //   Measure: autocorrelation > AUTOCORR_MIN
    //            variance > VARIANCE_MIN
    //            cosine continuity > COS_CONTINUITY_MIN
    //   (structured output from cell dynamics alone)
    result_new("NO_SPEAK_CODE", cells, 300)
}

