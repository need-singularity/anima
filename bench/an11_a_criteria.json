  "gate_type": "AND-3",
  "min_delta_threshold": 0.001,
  "sub_gates": {
    "delta_frobenius": {
      "min_delta_threshold": 0.001,
      "measurement": "sqrt(sum((W_after - W_before)^2)) on safetensors",
      "fallback": "byte-L2 proxy",
      "backend_priority": ["native_safetensors", "byte_l2_proxy", "synthetic_json"]
    },
    "sha_distinct": {
      "method": "sha256(round_path) != sha256(base_path)",
      "scope": "file-byte-stream",
      "algo": "sha256"
    },
    "shard_cv": {
      "min": 0.05,
      "max": 3.0,
      "n_shards": 8,
      "method": "K equal slices, Frob per-shard → CV = sigma/mu"
    },
    "adapter_rank_min": 1
  },
  "verifier_path": "tool/an11_a_verifier.hexa",
  "verifier_parse_lines": "337-340 (threshold override precedence: --threshold > criteria.json > 1e-3)",
  "apply_to_round": ["r13", "r14"],
  "apply_to_model": ["qwen_14b_lora", "cpgd_v_init"],
  "ssot_output": "shared/state/{dest}_r{N}_an11_a.json",
  "raw_refs": ["raw#12 empirical", "raw#15 SSOT", "raw#9 hexa-only"]
}
