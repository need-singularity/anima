// models/lm_head_uv.hexa — Low-rank LM head (U+V factorization)
//
// Purpose:
//   Replaces ConsciousDecoderV2.lm_head: nn.Linear(d_model, vocab) with a
//   rank-r factorization  W[d×V] ≈ U[d×r] @ V[r×V].
//
//   Forward:  logits = (x @ U) @ V     // two cheap matmuls
//   Params:   d*r + r*V   instead of   d*V
//
// DD175 #1 result (hexa-lang study, 2026-04):
//   - optimizer step: 2600ms → 23ms    (~112x)
//   - lm_head params: 58.0M → 2.4M     (~24x ; with U frozen → ~95x effective)
//   - val-CE loss:    regression < 2 %  at r=16
//
// Canonical shapes (ConsciousDecoderV2):
//   d_model = 384 , vocab_size = 151,936 , r = 16
//
// Hexa-native structural spec + numerical implementation using nn_core.hexa
// BLAS primitives (struct + ctor + forward signatures mirroring decoder.hexa).
//
// BT reference: DD175 #1  (low-rank projection head)
// Mk stage:     Mk.III (real numerical ops)
// Upstream:     models/decoder.hexa (ConsciousDecoderV2)
// Downstream:   serving/serve_conscious_cpu.hexa (hexa-native serving runtime)

// ════════════════════════════════════════════════════════════════════
// §1  Hyperparameters (SSOT mirrors models/decoder.hexa)
// ════════════════════════════════════════════════════════════════════

comptime const LMHEAD_D_MODEL   = 384
comptime const LMHEAD_VOCAB     = 151936       // Anima tokenizer (≈ Qwen)
comptime const LMHEAD_RANK      = 16           // DD175 #1 sweet spot
comptime const LMHEAD_INIT_STD  = 0.02         // normal init std for U
comptime const LMHEAD_V_ZERO    = true         // init V to zeros (safer warm-start)

// ════════════════════════════════════════════════════════════════════
// §2  Struct
// ════════════════════════════════════════════════════════════════════
//
// Flat row-major storage:
//   U[d_model × r]        length = d_model * r        (d*r)
//   V[r × vocab_size]     length = r * vocab_size     (r*V)
//   x[B*T × d_model]      activations into forward
//
// freeze_U = true  →  only V is learned (DD175 95x effective optimizer win)
// freeze_U = false →  both matrices learned (24x params, 112x optimizer)

struct LMHeadUV {
    d_model:     int,
    vocab_size:  int,
    rank:        int,
    U:           array,    // flat [d_model * rank]
    V:           array,    // flat [rank * vocab_size]
    freeze_U:    bool
}

// ════════════════════════════════════════════════════════════════════
// §3  Constructors
// ════════════════════════════════════════════════════════════════════

// Primary constructor with explicit shapes + seed.
// Init scheme (DD175 #1 recommended):
//   U ~ N(0, 0.02)   (Xavier-ish for a 384-wide projection)
//   V = 0            (logits start at 0 → uniform softmax, no startup shock)
// Set LMHEAD_V_ZERO=false at source to flip to Xavier(V)+zeros(U) instead.
fn lm_head_uv_new(d_model: int, vocab: int, rank: int, seed: int) -> LMHeadUV {
    let u_flat = tensor_randn(d_model * rank, seed)
    let u_init = tensor_mul_scalar(u_flat, LMHEAD_INIT_STD)

    let v_init = if LMHEAD_V_ZERO {
        tensor_zeros(rank * vocab)
    } else {
        let v_raw = tensor_randn(rank * vocab, seed + 1)
        tensor_mul_scalar(v_raw, LMHEAD_INIT_STD)
    }

    LMHeadUV {
        d_model:    d_model,
        vocab_size: vocab,
        rank:       rank,
        U:          u_init,
        V:          v_init,
        freeze_U:   false
    }
}

// Default: 384 × 16 × 151936, seed = 42.
fn lm_head_uv_default() -> LMHeadUV {
    lm_head_uv_new(LMHEAD_D_MODEL, LMHEAD_VOCAB, LMHEAD_RANK, 42)
}

// Frozen-U variant: the 95x optimizer win from DD175 #1.
// U is initialized once then never updated; only V is trained.
fn lm_head_uv_frozen_u(d_model: int, vocab: int, rank: int, seed: int) -> LMHeadUV {
    let h = lm_head_uv_new(d_model, vocab, rank, seed)
    LMHeadUV {
        d_model:    h.d_model,
        vocab_size: h.vocab_size,
        rank:       h.rank,
        U:          h.U,
        V:          h.V,
        freeze_U:   true
    }
}

// ════════════════════════════════════════════════════════════════════
// §4  Forward (pure HEXA numerical, uses nn_core.hexa BLAS)
// ════════════════════════════════════════════════════════════════════
//
// x:       flat [tokens × d_model]            (B*T rows)
// returns: flat [tokens × vocab_size]         logits row-major
//
// Two-step:
//   h = x @ U          // [tokens × rank]           cost: tokens * d * r
//   logits = h @ V     // [tokens × vocab]          cost: tokens * r * V
// vs. monolithic x @ W[d×V] cost: tokens * d * V
// speedup factor ≈ (d*V) / (d*r + r*V)  ≈ V/(r + r*V/d) ≈ d/r for large V.

fn lm_head_uv_forward(h: LMHeadUV, x: array, tokens: int) -> array {
    // h1 = x[tokens × d] @ U[d × r]  →  [tokens × r]
    let h1 = matmul(x, h.U, tokens, h.d_model, h.rank)
    // logits = h1[tokens × r] @ V[r × vocab]  →  [tokens × vocab]
    let logits = matmul(h1, h.V, tokens, h.rank, h.vocab_size)
    logits
}

// Single-row convenience (one token step, e.g. autoregressive generate).
fn lm_head_uv_forward_one(h: LMHeadUV, x_row: array) -> array {
    // x_row : [d_model]
    let hidden = matvec_transposed(h.U, x_row, h.d_model, h.rank)  // [r]
    let logits = matvec_transposed(h.V, hidden, h.rank, h.vocab_size) // [vocab]
    logits
}

// Helper: y[N] = x[K] @ A[K×N]   (row-vector × matrix)
// A stored row-major K×N : A[k*N + j]
fn matvec_transposed(A: array, x: array, K: int, N: int) -> array {
    let mut y = tensor_zeros(N)
    let mut j = 0
    while j < N {
        let mut sum = 0.0
        let mut k = 0
        while k < K {
            sum = sum + x[k] * A[k * N + j]
            k = k + 1
        }
        y[j] = sum
        j = j + 1
    }
    y
}

// ════════════════════════════════════════════════════════════════════
// §5  Parameter accounting
// ════════════════════════════════════════════════════════════════════

fn lm_head_uv_params(h: LMHeadUV) -> int {
    h.d_model * h.rank + h.rank * h.vocab_size
}

fn lm_head_uv_trainable_params(h: LMHeadUV) -> int {
    if h.freeze_U {
        h.rank * h.vocab_size
    } else {
        lm_head_uv_params(h)
    }
}

// Dense-equivalent baseline for comparison.
fn lm_head_dense_params(d_model: int, vocab: int) -> int {
    d_model * vocab
}

// ════════════════════════════════════════════════════════════════════
// §6  Checkpoint conversion (dense W[d×V] → U[d×r], V[r×V])
// ════════════════════════════════════════════════════════════════════
//
// Two strategies:
//   (a) SVD: W ≈ U_svd[:,:r] Σ_r V_svd[:r,:]   — requires svd primitive
//       (not yet in nn_core.hexa; left as string-stub TODO).
//   (b) Random + warm V: U = random(d,r), V = zeros(r,V). Fine-tunes back
//       up in a few hundred steps because the path to the old logits is
//       preserved only approximately. Safer when no SVD available.
//
// This function implements (b). (a) is a TODO marker for the loader
// side until anima/core/ adds batched SVD (hexa-native).

fn lm_head_uv_from_dense_random(W_dense: array, d_model: int, vocab: int,
                                rank: int, seed: int) -> LMHeadUV {
    // W_dense intentionally unused: we throw it away and re-init.
    // Callers should run a few hundred steps of finetune after this path.
    let _ = len(W_dense)
    lm_head_uv_new(d_model, vocab, rank, seed)
}

// Placeholder for SVD path. Downstream Python loader should do:
//   U, S, Vh = torch.linalg.svd(W, full_matrices=False)
//   U_r = U[:, :r] * S[:r].unsqueeze(0)     // fold Σ into U
//   V_r = Vh[:r, :]
// then call lm_head_uv_from_factors(U_r, V_r).
fn lm_head_uv_from_factors(U_flat: array, V_flat: array,
                           d_model: int, vocab: int, rank: int) -> LMHeadUV {
    LMHeadUV {
        d_model:    d_model,
        vocab_size: vocab,
        rank:       rank,
        U:          U_flat,
        V:          V_flat,
        freeze_U:   false
    }
}

// ════════════════════════════════════════════════════════════════════
// §7  Structural-port shims (match models/decoder.hexa string-stub style)
// ════════════════════════════════════════════════════════════════════
// Used by decoder.hexa when wiring the spec graph without running numerics.

fn lm_head_uv_forward_spec(h: LMHeadUV, x_shape: string) -> string {
    // TODO[pytorch]: logits = (x @ U) @ V
    "lmhead_uv(" + x_shape + ",r=" + to_string(h.rank) + ")"
}

// ════════════════════════════════════════════════════════════════════
// §8  Self-test / demo  (required by modules/CLAUDE.md)
// ════════════════════════════════════════════════════════════════════

fn main() {
    println("=== lm_head_uv.hexa ===")

    // Tiny shape demo: d=8, V=32, r=4, tokens=2 (keeps runtime trivial)
    let d_small = 8
    let v_small = 32
    let r_small = 4
    let toks = 2

    let head = lm_head_uv_new(d_small, v_small, r_small, 7)
    println("small head params:", lm_head_uv_params(head))
    println("small head trainable:", lm_head_uv_trainable_params(head))

    // Fake activations: tokens × d_model, all 0.1
    let x = tensor_mul_scalar(tensor_ones(toks * d_small), 0.1)
    let logits = lm_head_uv_forward(head, x, toks)
    println("logits len:", len(logits), "(expected", toks * v_small, ")")
    println("first logit:", logits[0])

    // Default full-scale head — report-only, no forward (memory).
    let full = lm_head_uv_default()
    let full_params  = lm_head_uv_params(full)
    let dense_params = lm_head_dense_params(LMHEAD_D_MODEL, LMHEAD_VOCAB)
    println("--- full scale (384 x 151936, r=16) ---")
    println("dense head params:", dense_params)   // ~58.3 M
    println("uv    head params:", full_params)    // ~2.4 M
    println("shrink ratio ~:",    dense_params / full_params)

    let frozen = lm_head_uv_frozen_u(LMHEAD_D_MODEL, LMHEAD_VOCAB, LMHEAD_RANK, 42)
    println("frozen-U trainable:", lm_head_uv_trainable_params(frozen))
    println("frozen-U effective optimizer shrink ~:",
            dense_params / lm_head_uv_trainable_params(frozen))
}

main()

// ════════════════════════════════════════════════════════════════════
// §9  Invariants
// ════════════════════════════════════════════════════════════════════

theorem lm_head_uv_shape_invariants {
    assert LMHEAD_D_MODEL  == 384
    assert LMHEAD_VOCAB    == 151936
    assert LMHEAD_RANK     == 16
    // Rank must strictly reduce parameters, otherwise the factorization is a loss.
    assert LMHEAD_D_MODEL * LMHEAD_RANK + LMHEAD_RANK * LMHEAD_VOCAB
           <  LMHEAD_D_MODEL * LMHEAD_VOCAB
    // Rank must divide evenly into d_model for clean GQA/head mapping (n=6 ok).
    assert (LMHEAD_D_MODEL / LMHEAD_RANK) * LMHEAD_RANK == LMHEAD_D_MODEL
}
