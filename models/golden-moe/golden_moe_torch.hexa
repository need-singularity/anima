    let topk = moe_model_new(784, 64, 10, 8, "topk")
    let golden = moe_model_new(784, 64, 10, 8, "boltzmann")
    let dense = moe_model_new(784, 64, 10, 8, "dense")

    print("  Top-K (K=2, 25%):       " + train_model(topk, 10, 0.001))
    print("  Golden MoE (T=e, 70%):  " + train_model(golden, 10, 0.001))
