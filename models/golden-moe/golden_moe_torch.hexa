// ─── Router: BoltzmannGate ───

struct BoltzmannGate {
    input_dim: int,
    n_experts: int,
    temperature: float,
    n_active: int
}

fn boltzmann_gate_new(input_dim: int, n_experts: int, temperature: float, active_ratio: float) -> BoltzmannGate {
    let na = if (n_experts * active_ratio) < 1.0 { 1 } else { n_experts * active_ratio }
    BoltzmannGate {
        input_dim: input_dim,
        n_experts: n_experts,
        temperature: temperature,
        n_active: na
    }
}

fn boltzmann_gate_forward(gate: BoltzmannGate, x: string) -> string {
    // TODO[pytorch]: nn.Linear(input_dim, n_experts) / temperature
    // probs = softmax(scores / temperature)
    // topk_vals, topk_idx = probs.topk(n_active, dim=-1)
    // mask = zeros_like(probs).scatter_(-1, topk_idx, 1.0)
    // weights = probs * mask / (weights.sum + 1e-8)
    "boltzmann_weights"
}

