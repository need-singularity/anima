// ─── Golden Zone Determination ───

fn golden_zone_check(i_effective: float) -> string {
    // Golden Zone: 0.213 <= I <= 0.500
    // G = 0.5 * 0.85 / max(I, 0.01)
    if i_effective >= 0.213 && i_effective <= 0.500 {
        "Golden Zone"
    } else if i_effective < 0.213 {
        "Below"
    } else {
        "Outside"
    }
}

// ─── CLI entry point ───

fn main() {
