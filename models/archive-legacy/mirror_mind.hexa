struct MirrorModel {
    target_id: string,
    observations: int,
    accuracy: float
}

fn mirror_new(target_id: string) -> MirrorModel {
    MirrorModel { target_id: target_id, observations: 0, accuracy: 0.0 }
}

fn observe(model: MirrorModel, state: string) -> MirrorModel {
    // TODO[pytorch]: update internal model from observed state
    MirrorModel { target_id: model.target_id, observations: model.observations + 1, accuracy: model.accuracy }
}

