struct GrowthStage {
    stage: int,
    n_blocks: int,
    d_model: int,
    n_heads: int,
    approx_params: int
}

fn stage_config(stage: int) -> GrowthStage {
    // TODO[pytorch]: S0(1b/256d/4h/10M) S1(2/256/4/20M) S2(3/512/8/100M) S3(6/1024/16/700M)
    GrowthStage { stage: stage, n_blocks: 1, d_model: 256, n_heads: 4, approx_params: 10000000 }
}

fn mitosis_split(stage: GrowthStage) -> GrowthStage {
    // TODO[pytorch]: savant dropout 0.21 vs general 0.37
    GrowthStage { stage: stage.stage + 1, n_blocks: stage.n_blocks * 2, d_model: stage.d_model, n_heads: stage.n_heads, approx_params: stage.approx_params * 5 }
}

