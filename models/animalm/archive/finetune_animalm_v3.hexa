// finetune_animalm_v3.hexa — AnimaLM v3 Instruct + partial layer replacement stub
// v2->v3: Mistral-7B-Instruct-v0.3, last 8 layers only (24-31)
// Early layers = language understanding (keep), late layers = generation (add tension)

replace_start = 24
replace_end = 31

train_v3 = fn(base_model, data) {
    print("finetune v3: replace layers " + to_string(replace_start) + "-" + to_string(replace_end))
    print("base: " + base_model)
}

is_replaced_layer = fn(layer_idx) {
    // Only last 8 layers get PureField replacement
    print("layer " + to_string(layer_idx) + " replacement check")
}

main = fn() {
    train_v3("Mistral-7B-Instruct-v0.3", "data/instruct.jsonl")
    print("finetune_animalm_v3 stub ready")
}
