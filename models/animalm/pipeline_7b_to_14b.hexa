// Ported from pipeline_7b_to_14b.sh
// AnimaLM Pipeline: 7B complete → eval → Qwen download → 14B launch | Run on H100: bash pipeline_7b_to_14b.sh
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    // AnimaLM Pipeline: 7B complete → eval → Qwen download → 14B launch
    // Run on H100: bash pipeline_7b_to_14b.sh
    shell("export PATH=/opt/conda/bin:$PATH")
    shell("cd /workspace")

    shell("echo \"=== AnimaLM Pipeline: 7B → eval → 14B ===\"")
    shell("echo \"$(date)\"")

    // 1. Wait for 7B training to complete
    shell("echo \"[1/5] Waiting for 7B training to complete...\"")
    shell("while pgrep -f train_anima > /dev/null 2>&1; do")
    shell("LAST=$(grep -E \"^  +[0-9]+ \" /workspace/animalm_resume.log 2>/dev/null | tail -1 || grep -E \"^  +[0-9]+ \" /workspace/animalm_fresh.log 2>/dev/null | tail -1)")
    shell("echo \"  $(date +%H:%M) | $LAST\"")
    shell("sleep 300")
    shell("done")
    shell("echo \"  7B training complete!\"")

    // 2. Find best checkpoint
    shell("echo \"[2/5] Finding best checkpoint...\"")
    shell("CKPT=$(ls -t /workspace/checkpoints/animalm_7b_fresh/*.pt 2>/dev/null | head -1)")
    shell("if [ -z \"$CKPT\" ]; then")
    shell("echo \"ERROR: No checkpoint found!\"")
    shell("exit 1")
    shell("fi")
    shell("echo \"  Checkpoint: $CKPT\"")

    // 3. Run eval
    shell("echo \"[3/5] Running evaluation...\"")
    shell("python3 -u /workspace/eval_animalm.py --checkpoint \"$CKPT\" 2>&1 | tee /workspace/eval_7b_result.log")
    shell("EVAL_EXIT=$?")

    shell("if [ $EVAL_EXIT -ne 0 ]; then")
    shell("echo \"  ⚠️ Eval did not fully pass. Check eval_7b_result.log\"")
    shell("echo \"  Continuing to 14B anyway (7B Korean was expected to be weak)\"")
    shell("fi")

    // 3.5. Instruction fix — swap base to Instruct and re-eval
    shell("echo \"[3.5/6] Instruction fix — downloading Mistral-7B-Instruct...\"")
    shell("if [ ! -d \"/workspace/models/mistral-7b-instruct\" ]; then")
    shell("python3 -c \"")
    shell("from huggingface_hub import snapshot_download")
    shell("snapshot_download('mistralai/Mistral-7B-Instruct-v0.2', local_dir='/workspace/models/mistral-7b-instruct', resume_download=True)")
    shell("print('INSTRUCT DOWNLOAD COMPLETE')")
    shell("\"")
    shell("fi")
    shell("echo \"  Re-eval with Instruct base...\"")
    shell("python3 -u /workspace/eval_animalm.py --checkpoint \"$CKPT\" --base /workspace/models/mistral-7b-instruct 2>&1 | tee /workspace/eval_7b_instruct.log")
    shell("echo \"  Instruct eval done\"")

    // Also test inference with Instruct
    shell("python3 -u /workspace/infer_animalm.py --checkpoint \"$CKPT\" --base /workspace/models/mistral-7b-instruct --prompt \"List 3 colors and explain why the sky is blue.\" --max-tokens 100 2>&1 | tee -a /workspace/eval_7b_instruct.log")

    // 4. Download Qwen2.5-14B
    shell("echo \"[4/5] Downloading Qwen2.5-14B...\"")
    shell("if [ ! -d \"/workspace/models/qwen2.5-14b\" ] || [ $(du -sm /workspace/models/qwen2.5-14b 2>/dev/null | cut -f1) -lt 25000 ]; then")
    shell("python3 -c \"")
    shell("from huggingface_hub import snapshot_download")
    shell("snapshot_download('Qwen/Qwen2.5-14B', local_dir='/workspace/models/qwen2.5-14b', resume_download=True)")
    shell("print('DOWNLOAD COMPLETE')")
    shell("\"")
    shell("else")
    shell("echo \"  Already downloaded\"")
    shell("fi")

    // 5. Launch 14B
    shell("echo \"[5/5] Launching AnimaLM 14B...\"")
    shell("bash /workspace/launch_14b.sh")

    shell("echo \"\"")
    shell("echo \"=== Pipeline complete ===\"")
    shell("echo \"7B eval: /workspace/eval_7b_result.log\"")
    shell("echo \"14B log: /workspace/animalm_14b.log\"")
    shell("echo \"$(date)\"")
}
