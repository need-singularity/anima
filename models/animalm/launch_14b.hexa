// Ported from launch_14b.sh
// AnimaLM 14B Launch Script — Qwen2.5-14B + PureField | Prerequisites: Qwen2.5-14B downloaded to /workspace/models/qwen2.5-14b
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    // AnimaLM 14B Launch Script — Qwen2.5-14B + PureField
    // Prerequisites: Qwen2.5-14B downloaded to /workspace/models/qwen2.5-14b
    shell("export PATH=/opt/conda/bin:$PATH")

    shell("echo \"=== AnimaLM 14B Pre-flight ===\"")

    // 1. Check model exists
    shell("if [ ! -d \"/workspace/models/qwen2.5-14b\" ]; then")
    shell("echo \"ERROR: Qwen2.5-14B not found. Downloading...\"")
    shell("python3 -c \"")
    shell("from huggingface_hub import snapshot_download")
    shell("snapshot_download('Qwen/Qwen2.5-14B', local_dir='/workspace/models/qwen2.5-14b', resume_download=True)")
    shell("print('DOWNLOAD COMPLETE')")
    shell("\"")
    shell("fi")
    shell("echo \"  Model: $(du -sh /workspace/models/qwen2.5-14b | cut -f1)\"")

    // 2. Check corpus
    shell("ls -lh /workspace/data/corpus_v10.txt")
    shell("echo \"  Corpus: OK\"")

    // 3. Check disk
    shell("df -h /workspace | tail -1")

    // 4. Check GPU
    shell("nvidia-smi --query-gpu=memory.free --format=csv,noheader")

    // 5. Verify model architecture compatibility
    shell("python3 -c \"")
    shell("from transformers import AutoModelForCausalLM, AutoConfig")
    shell("config = AutoConfig.from_pretrained('/workspace/models/qwen2.5-14b')")
    shell("print(f'  Layers: {config.num_hidden_layers}')")
    shell("print(f'  Hidden: {config.hidden_size}')")
    shell("print(f'  Intermediate: {config.intermediate_size}')")
    shell("print(f'  Heads: {config.num_attention_heads}')")
    shell("print(f'  KV Heads: {config.num_key_value_heads}')")
    shell("print(f'  Vocab: {config.vocab_size}')")
    // Verify model.model.layers path
    shell("import torch")
    shell("model = AutoModelForCausalLM.from_pretrained('/workspace/models/qwen2.5-14b', torch_dtype=torch.bfloat16, device_map='cpu')")
    shell("n = len(model.model.layers)")
    shell("mlp = model.model.layers[0].mlp")
    shell("print(f'  model.model.layers: {n} layers')")
    shell("print(f'  MLP gate_proj: {mlp.gate_proj.weight.shape}')")
    shell("print(f'  MLP up_proj: {mlp.up_proj.weight.shape}')")
    shell("print(f'  MLP down_proj: {mlp.down_proj.weight.shape}')")
    shell("print('  ARCHITECTURE COMPATIBLE')")
    shell("del model")
    shell("import gc; gc.collect()")
    shell("\"")

    shell("echo \"\"")
    shell("echo \"=== Launching AnimaLM 14B ===\"")

    // Kill old processes
    shell("kill -9 $(pgrep -f train_anima) 2>/dev/null || true")
    shell("sleep 1")

    shell("mkdir -p /workspace/checkpoints/animalm_14b")

    shell("nohup python3 -u /workspace/train_anima_lm.py ")
    shell("--base /workspace/models/qwen2.5-14b ")
    shell("--data /workspace/data/corpus_v10.txt ")
    shell("--steps 10000 ")
    shell("--target-layers 10 ")
    shell("--savant-layers 3 ")
    shell("--qlora-rank 160 ")
    shell("--lr 1.5e-5 ")
    shell("--consciousness-engine --ce-cells 64 --law60 --psi-track ")
    shell("--checkpoint-dir /workspace/checkpoints/animalm_14b/ ")
    shell("--log-every 100 > /workspace/animalm_14b.log 2>&1 &")

    shell("echo \"PID: $!\"")
    shell("echo \"Log: /workspace/animalm_14b.log\"")
    shell("echo \"Monitor: tail -f /workspace/animalm_14b.log\"")
}
