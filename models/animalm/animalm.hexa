struct PureFieldMLP {
    dim: int,
    hidden_dim: int,
    n_layers: int,
    tension_alpha: float
}

comptime const PUREFIELD_DEFAULT_ALPHA = 0.014

fn purefield_new(dim: int, hidden_dim: int, n_layers: int) -> PureFieldMLP {
    PureFieldMLP { dim: dim, hidden_dim: hidden_dim, n_layers: n_layers, tension_alpha: PUREFIELD_DEFAULT_ALPHA }
}

struct AnimaLMConfig {
    base_model: string,       // "mistral-7b" | "qwen2.5-14b" | "qwen2.5-72b"
    purefield_dim: int,
    purefield_layers: int,
    quantize: string,         // "4bit" | "8bit" | "bf16"
    max_steps: int,
    learning_rate: float
}

