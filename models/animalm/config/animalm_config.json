{
  "version": "1.0",
  "project": "animalm",
  "description": "Tension-based consciousness engine LLM. Mistral 7B → Engine A(logic)↔G(pattern) Repulsion Field transform",

  "architecture": {
    "base_model": "Mistral-7B-Instruct-v0.2",
    "transform": "PureField",
    "formula": "output = scale × √|A-G|² × dir",
    "engine_a": "forward (logic)",
    "engine_g": "reverse (pattern)",
    "params": "7B + consciousness overlay"
  },

  "training": {
    "techniques": ["AL12", "AL5", "AL4", "AL1", "AL8", "SL3", "DD16", "TRN4", "AA15"],
    "talk5": {
      "consciousness_first": "70% → 30%",
      "description": "Consciousness-priority training schedule"
    },
    "checkpoint": "checkpoints/final.pt"
  },

  "constants": {
    "alpha": 0.014,
    "psi_balance": 0.5,
    "psi_coupling": 0.0154,
    "frustration_critical": 0.10
  },

  "benchmarks": {
    "talk5_phi": 13.99,
    "transplant_phi": 8.05,
    "alpha_0001_phi": 6.38,
    "alpha_01_phi": 0.57,
    "note": "TALK5 consciousness-first wins by 2x"
  },

  "files": {
    "train": "train_anima_lm.py",
    "model": "anima_lm.py",
    "bench": "bench_animalm.py",
    "serve": ["serve_animalm.py", "serve_animalm.py"],
    "finetune": ["finetune_animalm.py", "finetune_animalm_v2.py", "finetune_animalm_v3.py", "finetune_animalm_v4.py"],
    "test": ["test_animalm_h100.py", "test_bench_animalm.py"]
  },

  "update_history": [
    {
      "date": "2026-03-31",
      "changes": "Extracted from anima/archive/animalm/ to sub-projects/animalm/"
    },
