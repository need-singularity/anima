{
  "schema": "anima.main.config.v1",
  "title": "anima β main unified CLI — phase/component → tool mapping",
  "created": "2026-04-21",
  "raw_compliance": "raw#9 hexa-only raw#11 snake_case raw#15 no-hardcode",
  "hexa_bin_default": "/Users/ghost/Dev/hexa-lang/hexa",

  "phases": {
    "0": {
      "label": "cpu_paradigm_smoke",
      "desc": "CPU paradigm smoke — learning_free_driver (stage all, smoke step_count=10)",
      "components": ["train_smoke", "hstar"],
      "fast": true
    },
    "1": {
      "label": "cpu_real_use",
      "desc": "CPU real-use — full learning_free_driver + bridge + hexad + an11 verifier triple",
      "components": ["train", "bridge", "hexad_closure", "an11"],
      "fast": false
    }
  },

  "components": {
    "corpus": {
      "label": "corpus gen+validate",
      "tools": [
        {
          "slug": "corpus_generator_v2",
          "path": "tool/corpus_generator_v2.hexa",
          "args": [],
          "ssot": "training/corpus_consciousness_v2_4gate_result.json",
          "optional_ssot": true,
          "timeout_s": 600
        },
        {
          "slug": "alm_corpus_validate",
          "path": "tool/alm_corpus_validate.hexa",
          "args": ["--corpus", "experiments/alm_r13/seed_corpus_10mb/corpus.jsonl"],
          "ssot": "shared/state/alm_r13_corpus_audit.json",
          "optional_ssot": true,
          "timeout_s": 300
        }
      ]
    },
    "train": {
      "label": "learning_free_driver (CPU real-use)",
      "tools": [
        {
          "slug": "anima_learning_free_driver",
          "path": "tool/anima_learning_free_driver.hexa",
          "args": ["--stage", "all"],
          "ssot": "shared/state/learning_free_driver_result.json",
          "optional_ssot": false,
          "timeout_s": 600
        }
      ]
    },
    "train_smoke": {
      "label": "learning_free_driver (smoke)",
      "tools": [
        {
          "slug": "anima_learning_free_driver_smoke",
          "path": "tool/anima_learning_free_driver.hexa",
          "args": ["--stage", "all", "--smoke"],
          "ssot": "shared/state/learning_free_driver_result.json",
          "optional_ssot": false,
          "timeout_s": 180
        }
      ]
    },
    "bench": {
      "label": "flops_landauer_bench (pending)",
      "tools": [
        {
          "slug": "flops_landauer_bench",
          "path": "tool/flops_landauer_bench.hexa",
          "args": [],
          "ssot": "shared/state/flops_landauer_bench.json",
          "optional_ssot": true,
          "pending": true,
          "timeout_s": 300
        }
      ]
    },
    "an11": {
      "label": "AN11 triple (a+b+c)",
      "tools": [
        {
          "slug": "an11_a_weight_emergent",
          "path": "verifier/an11_weight_emergent.hexa",
          "args": ["--dry-run"],
          "ssot": "shared/state/an11_weight_emergent_verdict.json",
          "optional_ssot": true,
          "timeout_s": 180
        },
        {
          "slug": "an11_b_verifier",
          "path": "tool/an11_b_verifier.hexa",
          "args": ["--dest", "alm", "--round", "r13"],
          "ssot": "shared/state/alm_r13_an11_b.json",
          "optional_ssot": true,
          "timeout_s": 180
        },
        {
          "slug": "an11_c_verifier",
          "path": "tool/an11_c_verifier.hexa",
          "args": ["--dest", "alm", "--round", "r13", "--dry-run"],
          "ssot": "shared/state/alm_r13_an11_c.json",
          "optional_ssot": true,
          "timeout_s": 180
        }
      ]
    },
    "bridge": {
      "label": "cell ↔ token bridge PoC",
      "tools": [
        {
          "slug": "cell_token_bridge_proto",
          "path": "tool/cell_token_bridge_proto.hexa",
          "args": [],
          "ssot": "shared/state/cell_token_bridge_proto.json",
          "optional_ssot": false,
          "timeout_s": 180
        }
      ]
    },
    "hexad_closure": {
      "label": "Hexad closure verifier",
      "tools": [
        {
          "slug": "hexad_closure_verifier",
          "path": "tool/hexad_closure_verifier.hexa",
          "args": [],
          "ssot": "shared/state/hexad_closure_verdict.json",
          "optional_ssot": false,
          "timeout_s": 120
        }
      ]
    },
    "hstar": {
      "label": "H★ EXP-1 + EXP-2 (n28 falsification + 5-term stress)",
      "tools": [
        {
          "slug": "hexad_n28_falsification",
          "path": "tool/hexad_n28_falsification.hexa",
          "args": [],
          "ssot": "shared/state/hexad_n28_falsification_verdict.json",
          "optional_ssot": true,
          "timeout_s": 180
        },
        {
          "slug": "l_ix_5term_stress_test",
          "path": "tool/l_ix_5term_stress_test.hexa",
          "args": [],
          "ssot": "shared/state/l_ix_5term_stress_verdict.json",
          "optional_ssot": true,
          "timeout_s": 180
        }
      ]
    }
  },

  "status_ssot_set": [
    "shared/state/learning_free_driver_result.json",
    "shared/state/cell_token_bridge_proto.json",
    "shared/state/hexad_closure_verdict.json",
    "shared/state/l_ix_integrator_verdict.json",
    "shared/state/v_sync_kuramoto_verdict.json",
    "shared/state/v_rg_verdict.json",
    "shared/state/landauer_tracker_verdict.json",
    "shared/state/efficiency_verdict.json",
    "shared/state/an11_a_verdict.json",
    "shared/state/an11_b_verdict.json",
    "shared/state/an11_weight_emergent_verdict.json",
    "shared/state/alm_r13_corpus_audit.json",
    "shared/state/hexad_n28_falsification_verdict.json",
    "shared/state/l_ix_5term_stress_verdict.json"
  ],

  "status_tool_set": [
    "tool/alm_corpus_validate.hexa",
    "tool/corpus_generator_v2.hexa",
    "tool/anima_learning_free_driver.hexa",
    "tool/cell_token_bridge_proto.hexa",
    "tool/an11_a_verifier.hexa",
    "tool/an11_b_verifier.hexa",
    "tool/an11_c_verifier.hexa",
    "verifier/an11_weight_emergent.hexa",
    "tool/hexad_closure_verifier.hexa",
    "tool/hexad_n28_falsification.hexa",
    "tool/l_ix_5term_stress_test.hexa",
    "tool/flops_landauer_bench.hexa"
  ],

  "result_ssot": "shared/state/anima_main_result.json"
}
