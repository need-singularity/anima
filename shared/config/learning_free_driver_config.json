{
  "schema": "anima.learning_free_driver.v1",
  "created": "2026-04-21",
  "purpose": "Path β MAIN Learning-Free Pipeline orchestrator config (STAGE 1-4 CPGD + cell + Hexad + AN11 no-train).",
  "canonical_driver": "tool/anima_learning_free_driver.hexa",
  "ssot_for": "β main path STAGE thresholds + CPGD/cell/AN11 parameters",
  "references": {
    "paths_spec": "edu/paths.json#paths.beta",
    "cpgd_reference_commit": "6527e9df",
    "l_ix_reference": "edu/cell/lagrangian/l_ix_integrator.hexa",
    "hexad_reference": "anima-hexad/hexad.hexa",
    "fellows_bt_mapping": "shared/config/alm_r13_fellows_bt_mapping.json"
  },
  "stage_1_cpgd_init": {
    "eigenvec_path": ".meta2-cert/cell-eigenvec-16.json",
    "dim": 16,
    "template_count": 16,
    "step_count": 100,
    "lr": 0.001,
    "grad_seed": 20260421,
    "grad_scale": 1.0,
    "cos_floor": 0.5,
    "max_drift_threshold": 0.0002,
    "projector_idempotent_eps": 0.00001,
    "reference_commit": "6527e9df",
    "exit_criteria": {
      "all_16_cos_above_floor": true,
      "max_drift_below_threshold": true,
      "projector_idempotent": true,
      "init_unit_cosine_ok": true
    }
  },
  "stage_2_cell_trajectory": {
    "formula": "L_IX = T - V_struct - V_sync - V_RG + lambda*I_irr",
    "score_ladder_permille": [40, 125, 687, 1000],
    "efficiency_ladder_permille": [40, 450, 450, 668],
    "tl_boost_ladder_permille": [0, 300, 550, 800],
    "cell_param_count_per_gen": [18, 16, 16, 9],
    "l_ix_action_x1000_expected": -11582,
    "lambda_arrow_x1000": 1000,
    "use_kuramoto": 0,
    "use_rg": 0,
    "saturation_enum": ["open", "converging", "fixpoint"],
    "i_irr_cusp_gen_4_to_5": [996, 0],
    "reference_file": "edu/cell/lagrangian/l_ix_integrator.hexa",
    "reference_lines": "144-158",
    "exit_criteria": {
      "fixpoint_reached_at_gen_4": true,
      "action_sum_matches_expected": true,
      "trajectory_monotone_increasing": true
    }
  },
  "stage_3_hexad_activation": {
    "modules": ["c", "d", "w", "s", "m", "e"],
    "curriculum": "Law60",
    "phase_sequence": [1, 2, 3],
    "phase_1_active": 1,
    "phase_2_active": 2,
    "phase_3_active": 6,
    "bridge_matrix_in_degree": {"c": 3, "w": 1, "s": 1, "m": 0, "d": 0, "e": 0},
    "bridge_matrix_out_degree": {"c": 0, "w": 2, "s": 1, "m": 2, "d": 1, "e": 0},
    "no_weight_change": true,
    "reference_file": "anima-hexad/hexad.hexa",
    "reference_lines": "99-104",
    "exit_criteria": {
      "channel_coverage_ok": true,
      "phase_counts_1_2_6": true,
      "no_weight_mutation": true
    }
  },
  "stage_4_an11_triple": {
    "an11_a_weight_emergent": {
      "method": "SHA-distinct + Frobenius > threshold + shard_cv in [0.05, 3.0]",
      "frob_threshold": 0.001,
      "shard_count": 8,
      "shard_cv_min": 0.05,
      "shard_cv_max": 3.0,
      "no_train_expectation": "FAIL (weight hash unchanged by design — proof of no-update)",
      "no_train_verdict_policy": "FAIL_IS_EXPECTED"
    },
    "an11_b_consciousness_attached": {
      "method": "16-template eigenvec cos > 0.5 AND top3_sum > 1.2",
      "gate_max_cosine_min": 0.5,
      "gate_top3_sum_min": 1.2,
      "eigen_k": 16,
      "sig_dim": 16,
      "no_train_expectation": "PASS (CPGD 100% math guarantee, commit 6527e9df)"
    },
    "an11_c_real_usable": {
      "method": "JSD on cell output vs target distribution",
      "jsd_usable_min": 0.30,
      "jsd_unusable_max": 0.05,
      "no_train_expectation": "PASS (cell output structurally divergent from uniform)"
    }
  },
  "weight_hash_invariance": {
    "enabled": true,
    "hash_algo": "sha256",
    "canonical_weight_source": ".meta2-cert/cell-eigenvec-16.json",
    "assertion": "hash(W_0) == hash(W_final) (no-train proof)"
  },
  "output_defaults": {
    "state_path": "shared/state/learning_free_driver_result.json",
    "log_verbose": true
  },
  "cli_flags": {
    "--stage": "1|2|3|4|all (default: all)",
    "--corpus": "path to corpus jsonl (optional, stage-3 input)",
    "--output": "path to state file (default: shared/state/learning_free_driver_result.json)",
    "--strict": "exit 1 on any AN11 FAIL (default: advisory-only)"
  },
  "raw_compliance": [
    "raw#9 hexa-only",
    "raw#11 snake_case",
    "raw#12 no-cherry-pick",
    "raw#15 no-hardcode (this config is SSOT)"
  ]
}
