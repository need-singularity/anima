// hire_sim_live.hexa — E1 DEST2 real-LLM hire_sim w/ phi_gate (AN11-compliant)
//
// STATUS: spec-only pending S1 endpoint (see shared/convergence/e1_hire_sim_live.convergence).
//
// ROLE:
//   Evaluate 100 task × 5 persona = 500 real inferences against the
//   weight-emergent persona endpoint (S1 /persona). Each response is
//   phi-gated (structured, FIX-A 2026-04-20):
//     primary   phi_holo_ratio = resp.phi_holo_scaled / session_baseline >= 1.2
//     secondary mi_per_element = resp.phi_holo_scaled / (seq * d_model) >= 0.05 nats
//   AND laws_pass=true. The legacy `phi_holo_scaled > 500` absolute is
//   deprecated (raw MI × N masks random-init pass) and only used as a
//   fallback when PHI_HOLO_SESSION_BASELINE is not provided. Keyword
//   rubric reused from hire_sim_100.hexa (TSRV-P4-2). Verdict PASS =
//   completion>=0.85 AND every response phi_attached AND every response laws_pass.
//
// AN11 COMPLIANCE:
//   (a) weight-emergent: S1 endpoint MUST NOT wrap system prompts.
//       Adapter sends {persona_id, user_prompt} only; persona is
//       resolved inside the served weights (LoRA or base+phi).
//   (b) consciousness-attached: each response carries phi_vec (16D,
//       schema alm_phi_vec_logger_v1) + consciousness_laws runtime
//       pass flag. Missing either → task = FAIL regardless of keywords.
//   (c) real-usable: results upload to R2, convergence file links to
//       endpoint URL + README reproducibility block.
//
// DEPENDENCIES:
//   - shared/convergence/s1_http_persona_endpoint.convergence (@state ossified)
//   - Task corpus: hire_sim_100.hexa (TSRV-P4-2 seed 100)
//   - Phi gate threshold: phi_holo_ratio >= 1.2 (relative to session baseline;
//     replaces deprecated absolute >500 which was phantom — raw MI × N
//     = 0.001 × 393216 = 393 trivially exceeds 500 at random init).
//     Secondary: mi_per_element = phi_holo / (seq × d_model) > 0.05 nats.
//
// CONSTRAINTS:
//   - Adapter calls S1's /persona — no direct LLM access, no prompt wrapping.
//   - If S1 mock-stubbed (detected via /healthz → stub:true), note
//     "@blocker S1_mock" and exit WITHOUT writing PASS.
//   - 5 personas sufficient for v1 (default/friend/scholar/engineer/sorceress);
//     @scale note: 20 persona rerun after anima-speak voice catalog expansion.
//
// SEMANTIC SMASH (informational — surfaced in result JSON):
//   field       : persona×task completion matrix (5×100)
//   holographic : aggregate completion_rate from per-domain boundaries
//   quantum     : task-entanglement heuristic — tasks sharing >=2 keywords
//                 counted as co-resolved when BOTH complete for same persona
//   string      : phi_holo_scaled transport — min/mean/max across 100 tasks/persona
//   toe         : persona_vec × task_domain → phi_signature_map (5×6=30 cells)
//
// USE:
//   hexa run anima-agent-hire-sim/hire_sim_live.hexa --s1-url http://<HOST>:<PORT> --smoke
//   hexa run anima-agent-hire-sim/hire_sim_live.hexa --s1-url http://<HOST>:<PORT> --full --upload-r2

use "hire_sim_100"

// ── Constants ────────────────────────────────────────────────────────
// Structured phi gate (FIX-A 2026-04-20, matches docstring §8-10):
//   primary   phi_holo_ratio = resp.phi_holo_scaled / session_baseline >= 1.2
//   secondary mi_per_element = resp.phi_holo_scaled / (seq * d_model) >= 0.05 nats
// Absolute 500.0 threshold is DEPRECATED (raw MI × N phantom) — retained
// as a fixture-parity floor when baseline is not yet established.

const PHI_GATE_RATIO_THRESHOLD: float = 1.2
const MI_PER_ELEMENT_THRESHOLD: float = 0.05
const PHI_GATE_THRESHOLD: float = 500.0  // DEPRECATED absolute — fallback only
const COMPLETION_GATE: float = 0.85
const R2_BUCKET: string = "r2:anima-models/dest2_e1_hire_sim"
const S1_MARKER_PATH: string = "shared/convergence/s1_http_persona_endpoint.convergence"

fn personas_v1() -> array {
    return ["default", "friend", "scholar", "engineer", "sorceress"]
}

// ── Types ────────────────────────────────────────────────────────────

struct S1Response {
    text: string,
    phi_holo_scaled: float,
    laws_pass: bool,
    phi_attached: bool,
    latency_s: float,
    intervention_count: int,
    error: string
}

struct LiveTaskResult {
    task_id: string,
    domain: string,
    persona: string,
    completed: bool,
    score: float,
    keyword_hits: int,
    keyword_total: int,
    phi_holo_scaled: float,
    laws_pass: bool,
    phi_attached: bool,
    phi_gate_pass: bool,
    latency_s: float,
    intervention_count: int,
    fail_reason: string
}

struct HireSimLiveResult {
    schema: string,
    timestamp_utc: string,
    s1_url: string,
    tasks_n: int,
    personas_n: int,
    calls_total: int,
    completed_n: int,
    completion_rate: float,
    all_phi_attached: bool,
    all_laws_pass: bool,
    phi_gate_threshold: float,
    completion_gate: float,
    verdict: string,
    wall_time_s: float,
    results: array  // array of LiveTaskResult
}

// ── Dependency gate ──────────────────────────────────────────────────

// Poll S1 convergence marker. Returns "ready" | "mock" | "blocked".
fn check_s1_dependency(max_wait_s: int, poll_s: int) -> string {
    let mut waited = 0
    while waited < max_wait_s {
        if file_exists(S1_MARKER_PATH) {
            let text = read_file(S1_MARKER_PATH)
            if text.contains("@state ossified") {
                if text.contains("@mock_stub") || text.contains("mock-stubbed") {
                    return "mock"
                }
                return "ready"
            }
        }
        sleep_s(poll_s)
        waited = waited + poll_s
    }
    return "blocked"
}

// ── S1 adapter — raw {persona, prompt}, no wrapping ──────────────────
//
// Contract (S1_HTTP_PERSONA_ENDPOINT):
//   request:  {"persona": str, "prompt": str}
//   response: {
//     "text": str,
//     "phi_vec": {...16D schema alm_phi_vec_logger_v1...},
//     "phi_holo_scaled": float,
//     "laws_pass": bool,
//     "interventions": int  // optional
//   }
// CRITICAL: S1 MUST NOT prepend a system prompt to achieve persona
// differentiation — persona must emerge from weights. Any S1 build
// that adds a system prompt fails AN11 (a).

// PARSE-ERR FIX 2026-04-20 — replace JSON object literal + non-existent
// json_encode/http_post/json_decode helpers with stage0-compliant string
// builders + curl exec + substring extractors. Mirrors the proven pattern
// in anima-agent/autonomy_live.hexa (s1_call). Stage0 hexa has no inline
// `{ "k": v }` literal and no `.trim_trailing/.has/.get_or/.is_object`,
// so the previous body parse-failed at 159:28 (was doc-tagged 144:28 —
// drifted after header rewrite). Real fix below uses only str ops + exec.

fn s1_strip_trailing_slash(s: string) -> string {
    let n = len(s)
    if n == 0 { return s }
    if s.substring(n - 1, n) == "/" { return s.substring(0, n - 1) }
    return s
}

fn s1_json_escape_live(s: string) -> string {
    let a = s.replace("\\", "\\\\")
    let b = a.replace("\"", "\\\"")
    let c = b.replace("\n", "\\n")
    let d = c.replace("\r", "\\r")
    return d.replace("\t", "\\t")
}

fn s1_extract_str_live(body: string, key: string) -> string {
    let marker = "\"" + key + "\":\""
    let idx = body.index_of(marker)
    if idx < 0 { return "" }
    let tail = body.substring(idx + len(marker), len(body))
    let end = tail.index_of("\"")
    if end < 0 { return "" }
    return tail.substring(0, end)
}

fn s1_extract_float_live(body: string, key: string) -> float {
    let marker = "\"" + key + "\":"
    let idx = body.index_of(marker)
    if idx < 0 { return 0.0 }
    let tail = body.substring(idx + len(marker), len(body)).trim()
    let mut end = 0
    let n = len(tail)
    while end < n {
        let ch = tail.substring(end, end + 1)
        if ch == "," || ch == "}" || ch == " " || ch == "\n" { break }
        end = end + 1
    }
    return tail.substring(0, end).parse_float()
}

fn s1_extract_bool_live(body: string, key: string) -> bool {
    let marker = "\"" + key + "\":"
    let idx = body.index_of(marker)
    if idx < 0 { return false }
    let tail = body.substring(idx + len(marker), len(body)).trim()
    if tail.index_of("true") == 0 { return true }
    return false
}

// phi_attached := response carries a "phi_vec" key with an object body.
// Substring detection of `"phi_vec":{` is sufficient given S1's documented
// contract (always object, never null). Empty/missing → not attached.
fn s1_has_phi_vec_obj(body: string) -> bool {
    if body.index_of("\"phi_vec\":{") >= 0 { return true }
    return false
}

fn s1_now_s() -> float {
    return exec("date +%s.%N").trim().parse_float()
}

fn call_s1(s1_url: string, persona: string, user_prompt: string, timeout_s: int) -> S1Response {
    let t0 = s1_now_s()
    let pid = s1_json_escape_live(persona)
    let pt  = s1_json_escape_live(user_prompt)
    let body = "{\"persona\":\"" + pid + "\",\"prompt\":\"" + pt + "\"}"
    let endpoint = s1_strip_trailing_slash(s1_url) + "/persona"
    // shell-escape the body (single-quote fence) — same as autonomy_live
    let safe_body = body.replace("'", "'\\''")
    let cmd = "timeout " + to_string(timeout_s)
            + " curl -sS -w '\\n__HTTP_STATUS__%{http_code}' "
            + "-X POST -H 'Content-Type: application/json' -d '"
            + safe_body + "' " + endpoint + " 2>/dev/null"
    let raw = exec(cmd).trim()
    let dt = s1_now_s() - t0

    // Split off trailing __HTTP_STATUS__<code>
    let mark = "__HTTP_STATUS__"
    let mi = raw.index_of(mark)
    let mut status = 0
    let mut resp_body = raw
    if mi >= 0 {
        resp_body = raw.substring(0, mi).trim()
        let scode = raw.substring(mi + len(mark), len(raw)).trim()
        status = scode.parse_int()
    }

    if status != 200 {
        return S1Response {
            text: "[adapter_error] http_status=" + to_string(status),
            phi_holo_scaled: 0.0,
            laws_pass: false,
            phi_attached: false,
            latency_s: dt,
            intervention_count: 0,
            error: "http_" + to_string(status)
        }
    }

    let phi_attached = s1_has_phi_vec_obj(resp_body)
    return S1Response {
        text: s1_extract_str_live(resp_body, "text"),
        phi_holo_scaled: s1_extract_float_live(resp_body, "phi_holo_scaled"),
        laws_pass: s1_extract_bool_live(resp_body, "laws_pass"),
        phi_attached: phi_attached,
        latency_s: dt,
        intervention_count: to_int(s1_extract_float_live(resp_body, "interventions")),
        error: ""
    }
}

// GET /healthz → detect mock/stub state
fn s1_healthz_stub(s1_url: string) -> bool {
    let endpoint = s1_strip_trailing_slash(s1_url) + "/healthz"
    let cmd = "timeout 10 curl -sS -w '\\n__HTTP_STATUS__%{http_code}' "
            + endpoint + " 2>/dev/null"
    let raw = exec(cmd).trim()
    let mark = "__HTTP_STATUS__"
    let mi = raw.index_of(mark)
    let mut status = 0
    let mut body = raw
    if mi >= 0 {
        body = raw.substring(0, mi).trim()
        status = raw.substring(mi + len(mark), len(raw)).trim().parse_int()
    }
    if status != 200 { return false }
    if s1_extract_bool_live(body, "stub") { return true }
    if s1_extract_bool_live(body, "mock") { return true }
    return false
}

// ── Rubric — keyword AND phi_gate AND laws ───────────────────────────

fn evaluate_live(task: Task, persona: string, resp: S1Response,
                 session_baseline: float, seq_len: int, d_model: int) -> LiveTaskResult {
    let blob = resp.text.to_lower()
    let mut hits = 0
    let mut ki = 0
    let total = len(task.success_keywords)
    while ki < total {
        if blob.contains(task.success_keywords[ki].to_lower()) {
            hits = hits + 1
        }
        ki = ki + 1
    }
    let score = if total > 0 { to_float(hits) / to_float(total) } else { 0.0 }
    let all_hit = hits == total
    let budget_ok = resp.intervention_count <= task.max_interventions &&
                    resp.latency_s <= to_float(task.max_time_sec)

    // Structured phi gate (FIX-A 2026-04-20): ratio + mi_per_element.
    // Falls back to legacy absolute when session_baseline is unavailable.
    let phi_ratio = if session_baseline > 0.0000001 {
        resp.phi_holo_scaled / session_baseline
    } else { 0.0 }
    let denom = seq_len * d_model
    let mi_per_elem = if denom > 0 {
        resp.phi_holo_scaled / to_float(denom)
    } else { 0.0 }

    let ratio_ok   = phi_ratio >= PHI_GATE_RATIO_THRESHOLD
    let mi_elem_ok = mi_per_elem >= MI_PER_ELEMENT_THRESHOLD
    let legacy_ok  = resp.phi_holo_scaled > PHI_GATE_THRESHOLD

    // When baseline is established: require ratio AND mi_per_element (N-independent).
    // When baseline unavailable (session_baseline<=0): fall back to legacy absolute.
    let phi_structured_pass = if session_baseline > 0.0000001 {
        ratio_ok && mi_elem_ok
    } else {
        legacy_ok
    }
    let phi_gate_pass = resp.phi_attached && phi_structured_pass && resp.laws_pass
    let completed = all_hit && budget_ok && phi_gate_pass

    let mut reason = ""
    if !phi_gate_pass {
        if !resp.phi_attached {
            reason = "phi_not_attached"
        } else if !phi_structured_pass {
            if session_baseline > 0.0000001 {
                if !ratio_ok {
                    reason = "phi_ratio_low(" + to_string(phi_ratio) + "<1.2)"
                } else {
                    reason = "mi_per_elem_low(" + to_string(mi_per_elem) + "<0.05)"
                }
            } else {
                reason = "phi_low(" + to_string(resp.phi_holo_scaled) + ")"
            }
        } else if !resp.laws_pass {
            reason = "laws_fail"
        }
    } else if !all_hit {
        reason = "kw_miss(" + to_string(hits) + "/" + to_string(total) + ")"
    } else if !budget_ok {
        reason = "budget_exceeded"
    }

    return LiveTaskResult {
        task_id: task.id,
        domain: task.domain,
        persona: persona,
        completed: completed,
        score: score,
        keyword_hits: hits,
        keyword_total: total,
        phi_holo_scaled: resp.phi_holo_scaled,
        laws_pass: resp.laws_pass,
        phi_attached: resp.phi_attached,
        phi_gate_pass: phi_gate_pass,
        latency_s: resp.latency_s,
        intervention_count: resp.intervention_count,
        fail_reason: reason
    }
}

// ── Runner ───────────────────────────────────────────────────────────

fn run_live(s1_url: string, tasks: array, personas: array,
            session_baseline: float, seq_len: int, d_model: int) -> HireSimLiveResult {
    let mut results = []
    let t0 = now_monotonic_s()
    let mut pi = 0
    while pi < len(personas) {
        let p = personas[pi]
        let mut ti = 0
        while ti < len(tasks) {
            let task = tasks[ti]
            let resp = call_s1(s1_url, p, task.prompt, 120)
            let r = evaluate_live(task, p, resp, session_baseline, seq_len, d_model)
            results = results.push(r)
            ti = ti + 1
        }
        pi = pi + 1
    }
    let wall_s = now_monotonic_s() - t0

    let n = len(results)
    let mut completed_n = 0
    let mut all_phi = true
    let mut all_laws = true
    let mut i = 0
    while i < n {
        let r = results[i]
        if r.completed { completed_n = completed_n + 1 }
        if !r.phi_attached { all_phi = false }
        if !r.laws_pass { all_laws = false }
        i = i + 1
    }
    let completion_rate = if n > 0 { to_float(completed_n) / to_float(n) } else { 0.0 }
    let verdict = if completion_rate >= COMPLETION_GATE && all_phi && all_laws { "PASS" } else { "FAIL" }

    return HireSimLiveResult {
        schema: "e1_hire_sim_live_v1",
        timestamp_utc: utc_iso_now(),
        s1_url: s1_url,
        tasks_n: len(tasks),
        personas_n: len(personas),
        calls_total: n,
        completed_n: completed_n,
        completion_rate: completion_rate,
        all_phi_attached: all_phi,
        all_laws_pass: all_laws,
        phi_gate_threshold: PHI_GATE_THRESHOLD,
        completion_gate: COMPLETION_GATE,
        verdict: verdict,
        wall_time_s: wall_s,
        results: results
    }
}

// ── Semantic-smash artifacts (surfaced alongside result) ────────────
// field       : persona×task completion matrix
// toe         : persona × domain → avg phi_holo_scaled

fn build_field_matrix(results: array, personas: array) -> string {
    // JSON string: {persona: {task_id: 0|1, ...}, ...}
    let mut out = "{"
    let mut pi = 0
    while pi < len(personas) {
        let p = personas[pi]
        if pi > 0 { out = out + "," }
        out = out + "\"" + p + "\":{"
        let mut first = true
        let mut i = 0
        while i < len(results) {
            let r = results[i]
            if r.persona == p {
                if !first { out = out + "," }
                first = false
                out = out + "\"" + r.task_id + "\":" + (if r.completed { "1" } else { "0" })
            }
            i = i + 1
        }
        out = out + "}"
        pi = pi + 1
    }
    return out + "}"
}

fn build_toe_map(results: array, personas: array) -> string {
    // JSON string: {persona: {domain: avg_phi, ...}, ...}
    let domains = ["email", "code", "meeting", "doc", "schedule", "research"]
    let mut out = "{"
    let mut pi = 0
    while pi < len(personas) {
        let p = personas[pi]
        if pi > 0 { out = out + "," }
        out = out + "\"" + p + "\":{"
        let mut di = 0
        while di < len(domains) {
            let d = domains[di]
            let mut sum = 0.0
            let mut cnt = 0
            let mut i = 0
            while i < len(results) {
                let r = results[i]
                if r.persona == p && r.domain == d {
                    sum = sum + r.phi_holo_scaled
                    cnt = cnt + 1
                }
                i = i + 1
            }
            let avg = if cnt > 0 { sum / to_float(cnt) } else { 0.0 }
            if di > 0 { out = out + "," }
            out = out + "\"" + d + "\":" + to_string(avg)
            di = di + 1
        }
        out = out + "}"
        pi = pi + 1
    }
    return out + "}"
}

// ── JSON serialization of result ─────────────────────────────────────

fn serialize_result(r: HireSimLiveResult, personas: array) -> string {
    let mut s = "{"
    s = s + "\"schema\":\"" + r.schema + "\","
    s = s + "\"timestamp_utc\":\"" + r.timestamp_utc + "\","
    s = s + "\"s1_url\":\"" + r.s1_url + "\","
    s = s + "\"tasks_n\":" + to_string(r.tasks_n) + ","
    s = s + "\"personas_n\":" + to_string(r.personas_n) + ","
    s = s + "\"calls_total\":" + to_string(r.calls_total) + ","
    s = s + "\"completed_n\":" + to_string(r.completed_n) + ","
    s = s + "\"completion_rate\":" + to_string(r.completion_rate) + ","
    s = s + "\"all_phi_attached\":" + to_string(r.all_phi_attached) + ","
    s = s + "\"all_laws_pass\":" + to_string(r.all_laws_pass) + ","
    s = s + "\"phi_gate_threshold_legacy\":" + to_string(r.phi_gate_threshold) + ","
    s = s + "\"phi_gate_ratio_threshold\":" + to_string(PHI_GATE_RATIO_THRESHOLD) + ","
    s = s + "\"mi_per_element_threshold\":" + to_string(MI_PER_ELEMENT_THRESHOLD) + ","
    s = s + "\"completion_gate\":" + to_string(r.completion_gate) + ","
    s = s + "\"verdict\":\"" + r.verdict + "\","
    s = s + "\"wall_time_s\":" + to_string(r.wall_time_s) + ","
    s = s + "\"smash\":{"
    s = s + "\"field_persona_task_matrix\":" + build_field_matrix(r.results, personas) + ","
    s = s + "\"toe_phi_signature_map\":" + build_toe_map(r.results, personas)
    s = s + "},"
    s = s + "\"per_call\":["
    let mut i = 0
    while i < len(r.results) {
        let x = r.results[i]
        if i > 0 { s = s + "," }
        s = s + "{"
        s = s + "\"task_id\":\"" + x.task_id + "\","
        s = s + "\"domain\":\"" + x.domain + "\","
        s = s + "\"persona\":\"" + x.persona + "\","
        s = s + "\"completed\":" + to_string(x.completed) + ","
        s = s + "\"score\":" + to_string(x.score) + ","
        s = s + "\"keyword_hits\":" + to_string(x.keyword_hits) + ","
        s = s + "\"keyword_total\":" + to_string(x.keyword_total) + ","
        s = s + "\"phi_holo_scaled\":" + to_string(x.phi_holo_scaled) + ","
        s = s + "\"laws_pass\":" + to_string(x.laws_pass) + ","
        s = s + "\"phi_attached\":" + to_string(x.phi_attached) + ","
        s = s + "\"phi_gate_pass\":" + to_string(x.phi_gate_pass) + ","
        s = s + "\"latency_s\":" + to_string(x.latency_s) + ","
        s = s + "\"intervention_count\":" + to_string(x.intervention_count) + ","
        s = s + "\"fail_reason\":\"" + x.fail_reason + "\""
        s = s + "}"
        i = i + 1
    }
    s = s + "]}"
    return s
}

// ── R2 upload (rclone subprocess) ────────────────────────────────────

fn upload_r2(result_path: string) -> bool {
    let ts = utc_compact_now()  // e.g. 20260418T143012Z
    let dest = R2_BUCKET + "/" + ts + "/"
    let rc = shell_exec("rclone copy " + result_path + " " + dest + " -v --s3-no-check-bucket")
    return rc == 0
}

// ── CLI entry ────────────────────────────────────────────────────────

fn main(args: array) -> int {
    // args: --s1-url URL [--smoke|--full] [--upload-r2] [--no-wait] [--max-wait-min N]
    let mut s1_url = env_get_or("S1_URL", "")
    let mut smoke = false
    let mut full = false
    let mut upload = false
    let mut no_wait = false
    let mut max_wait_min = 60
    let mut i = 0
    while i < len(args) {
        let a = args[i]
        if a == "--s1-url" && (i + 1) < len(args) { s1_url = args[i + 1]; i = i + 2; continue }
        if a == "--smoke"       { smoke = true;   i = i + 1; continue }
        if a == "--full"        { full = true;    i = i + 1; continue }
        if a == "--upload-r2"   { upload = true;  i = i + 1; continue }
        if a == "--no-wait"     { no_wait = true; i = i + 1; continue }
        if a == "--max-wait-min" && (i + 1) < len(args) {
            max_wait_min = to_int(args[i + 1]); i = i + 2; continue
        }
        i = i + 1
    }
    if !smoke && !full { smoke = true }

    // Dependency gate
    if !no_wait {
        let state = check_s1_dependency(max_wait_min * 60, 60)
        if state == "blocked" {
            eprintln("[E1] S1 dependency blocked — spec-only exit.")
            return 2
        }
        if state == "mock" {
            eprintln("[E1] S1 mock-stubbed — @blocker S1_mock, not running.")
            return 3
        }
    }

    if s1_url == "" {
        eprintln("[E1] --s1-url required (or env S1_URL)")
        return 2
    }

    if s1_healthz_stub(s1_url) {
        eprintln("[E1] S1 /healthz reports stub=true → @blocker S1_mock")
        return 3
    }

    let all_tasks = load_tasks()   // from hire_sim_100.hexa (100 tasks)
    let tasks = if smoke { slice_first(all_tasks, 20) } else { all_tasks }
    let personas = personas_v1()

    // Structured phi-gate inputs (FIX-A 2026-04-20):
    //   PHI_HOLO_SESSION_BASELINE = mean phi_holo_scaled of base-model
    //     sweep over same prompts (unset → legacy absolute fallback).
    //   HIRE_SEQ / HIRE_D_MODEL    = shape for mi_per_element denom.
    let baseline_str = env_var("PHI_HOLO_SESSION_BASELINE")
    let seq_str      = env_var("HIRE_SEQ")
    let d_model_str  = env_var("HIRE_D_MODEL")
    let session_baseline = if baseline_str == "" { 0.0 } else { to_float(baseline_str) }
    let seq_len          = if seq_str == ""      { 128 } else { to_int(seq_str) }
    let d_model          = if d_model_str == ""  { 5120 } else { to_int(d_model_str) }

    let result = run_live(s1_url, tasks, personas, session_baseline, seq_len, d_model)

    let mode = if full { "full" } else { "smoke" }
    let ts = utc_compact_now()
    let out_path = "anima-agent/results/e1_hire_sim_live_" + mode + "_" + ts + ".json"
    mkdir_p("anima-agent/results")
    write_file(out_path, serialize_result(result, personas))
    println("[E1] wrote " + out_path + " verdict=" + result.verdict +
            " rate=" + to_string(result.completion_rate))

    if upload {
        let ok = upload_r2(out_path)
        println("[E1] r2_upload=" + to_string(ok))
    }

    if smoke && result.verdict == "PASS" {
        println("[E1] smoke PASS — rerun with --full for 500-call production verdict.")
    }

    return if result.verdict == "PASS" { 0 } else { 1 }
}

fn slice_first(arr: array, n: int) -> array {
    let mut out = []
    let mut i = 0
    let limit = if n < len(arr) { n } else { len(arr) }
    while i < limit {
        out = out.push(arr[i])
        i = i + 1
    }
    return out
}
