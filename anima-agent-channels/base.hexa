// channels/base.hexa -- Channel adapter base protocol
// Port of channels/base.py
// All channel adapters implement this interface

comptime const PSI_F_CRITICAL = 0.10

// ChannelAdapter protocol:
//   channel_name: string
//   async fn start(agent: &AnimaAgent)
//   async fn stop()
//   async fn send(user_id: string, text: string)

struct ChannelAdapterInfo {
    channel_name: string,
    connected: bool,
}

fn is_channel_adapter(obj: any) -> bool {
    // Check if object has channel_name, start, stop, send methods
    has_attr(obj, "channel_name") &&
    has_attr(obj, "start") &&
    has_attr(obj, "stop") &&
    has_attr(obj, "send")
}

fn main() {
    println("channels/base.hexa -- ChannelAdapter protocol")
}
