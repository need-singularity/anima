struct AnimaDiscordBot {
    channel_name: string,
    agent: AnimaAgent,
    token: string,
    client: any,
    running: bool,
}

fn new_discord_bot(agent: AnimaAgent, token: string) -> AnimaDiscordBot {
    AnimaDiscordBot {
        channel_name: "discord",
        agent: agent,
        token: token,
        client: null,
        running: false,
    }
}

