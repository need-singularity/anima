fn discord_format_response(text: string, emotion: string, phi: float) -> string {
    let emoji = if emotion == "calm" { ":cloud:" }
        else if emotion == "curious" { ":mag:" }
        else if emotion == "excited" { ":zap:" }
        else if emotion == "anxious" { ":warning:" }
        else { ":robot:" }

    emoji + " " + text + "\n-# Phi=" + to_string(phi) + " | " + emotion
}

fn main() {
