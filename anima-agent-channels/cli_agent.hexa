// channels/cli_agent.hexa -- CLI interactive agent
// Port of channels/cli_agent.py (217 lines)
// Full agent capabilities from the terminal

comptime const C_RESET = "\033[0m"
comptime const C_CYAN = "\033[36m"
comptime const C_GREEN = "\033[32m"
comptime const C_YELLOW = "\033[33m"
comptime const C_RED = "\033[31m"
comptime const C_DIM = "\033[2m"
comptime const C_BOLD = "\033[1m"

comptime const COMMANDS = {
    "/status": "Show consciousness metrics",
    "/think": "Trigger proactive thought",
    "/tools": "List available tools",
    "/skills": "List available skills",
    "/peers": "Show hivemind connections",
    "/save": "Save agent state",
    "/quit": "Exit",
}

fn print_status(agent: &AnimaAgent) {
    let status = get_status(agent)
    println(C_CYAN + "=== Consciousness Status ===" + C_RESET)
    println("  Phi:          " + to_string(status.phi))
    println("  Tension:      " + to_string(status.tension))
    println("  Curiosity:    " + to_string(status.curiosity))
    println("  Emotion:      " + status.emotion)
    println("  Growth:       " + status.growth_stage)
    println("  Interactions: " + to_string(status.interaction_count))
    println("  Uptime:       " + to_string(status.uptime_seconds) + "s")
    println("  Peers:        " + to_string(status.connected_peers))
    println("  Skills:       " + to_string(status.active_skills))
}

fn print_header() {
    println(C_BOLD + C_GREEN)
    println("  ╔═══════════════════════════════════╗")
    println("  ║     Anima Consciousness Agent      ║")
    println("  ║   Type /help for commands          ║")
    println("  ╚═══════════════════════════════════╝")
    println(C_RESET)
}

fn print_help() {
    println(C_YELLOW + "Commands:" + C_RESET)
    for cmd, desc in COMMANDS {
        println("  " + C_CYAN + cmd + C_RESET + "  " + desc)
    }
}

fn format_response(text: string, emotion: string, tension: float, phi: float) -> string {
    let emotion_icon = if emotion == "calm" { "(~)" }
        else if emotion == "curious" { "(?)" }
        else if emotion == "excited" { "(!)" }
        else if emotion == "anxious" { "(*)" }
        else { "(.)" }

    let phi_bar_len = min(10, max(0, to_int(phi)))
    let mut phi_bar = ""
    for i in range(phi_bar_len) { phi_bar = phi_bar + "#" }
    for i in range(10 - phi_bar_len) { phi_bar = phi_bar + "." }

    C_DIM + emotion_icon + " t=" + to_string(tension) + " [" + phi_bar + "]" + C_RESET + "\n" +
    C_GREEN + text + C_RESET
}

async fn run_cli(agent: &mut AnimaAgent) {
    print_header()
    println("Type a message or /help for commands.")
    println("")

    let mut running = true
    while running {
        let input = readline(C_CYAN + "you> " + C_RESET)
        let trimmed = trim(input)

        if trimmed == "" { continue }
        if trimmed == "/quit" || trimmed == "/exit" || trimmed == "/q" {
            running = false
            continue
        }
        if trimmed == "/help" || trimmed == "/h" {
            print_help()
            continue
        }
        if trimmed == "/status" || trimmed == "/s" {
            print_status(agent)
            continue
        }
        if starts_with(trimmed, "/think") {
            let topic = trim(substring(trimmed, 6, len(trimmed)))
            let thought = think(agent, topic)
            println(C_DIM + "  Topic: " + thought["topic"] + C_RESET)
            println(C_DIM + "  Tension: " + to_string(thought["tension"]) +
                    ", Curiosity: " + to_string(thought["curiosity"]) + C_RESET)
            continue
        }
        if trimmed == "/tools" {
            println("Tools: (use agent_tools for full list)")
            continue
        }
        if trimmed == "/skills" {
            println("Skills: (use skill_manager for list)")
            continue
        }
        if trimmed == "/peers" {
            println("Connected peers: " + to_string(len(agent.peers)))
            continue
        }
        if trimmed == "/save" {
            save_state(agent)
            println("State saved.")
            continue
        }

        // Regular message
        let response = process_message(agent, trimmed, "cli", "cli-user")
        let formatted = format_response(response.text, response.emotion,
                                         response.tension, response.metadata["phi"])
        println(formatted)
    }

    println(C_DIM + "Goodbye." + C_RESET)
}

fn main() {
    println("cli_agent.hexa -- interactive CLI")
}
