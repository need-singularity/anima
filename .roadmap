  gate       corpus_g1_g7_pass && flops_landauer_bench_run && local_endpoint_ready
  why        β main 40→55% closure — corpus strict PASS + flops bench 실측 + local inference endpoint

checkpoint P2 "🔥 β main phase 2 — Qwen 14B scale-up"
