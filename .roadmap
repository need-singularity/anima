# raw#15 DSL — phase/track/milestone registry, enforced by hexa-lang roadmap_lint.hexa.
# source of truth mirror: shared/roadmaps/anima.json (+ dest_alm.json + dest_clm.json)
#
# Format spec (shared with hexa-lang /.roadmap):
#   roadmap <id> <status> "<name>"
#     track         <alm|clm|verifier|consciousness|ssot|cell|lora|hybrid>
#     phase         <P0|P1|P2|P3|...>
#     eta           <YYYY-MM-DD | YYYY-Qn | TBD>
#     why           <prose>
#     exit_criteria <prose>            # required when status=active|done (≥10 chars)
#     proof         <path> | verify <CPID>  # required when status=done
#     depends-on    <id>               # optional — numeric id cross-ref
#     reaches       <CPID[,CPID...]>   # optional — CP this entry contributes to
#     requires      <CPID[,CPID...]>   # optional — CP gating this entry
#
# status (locked, 5): planned active done blocked deferred
# V1 REF_EXISTS | V2 DONE_PROOF | V3 ACTIVE_REQUIRES | V4 FINAL_UNIQUE (🧠) | V5 BIPARTITE_DAG
# lint: hexa /Users/ghost/core/hexa-lang/tool/roadmap_lint.hexa
#
# ─── cross-cutting checkpoints (AN11 aligned — dest_alm/dest_clm milestones) ───

checkpoint CP1 "🦴 verifier-ossification"
  condition  exec "hexa shared/verifier/run_all_verifier.hexa"
  gate       deterministic_gates=5/5 && drill_BT=landed && llm_judge_refs=0
  why        5 mandatory gates (G_INPUT/SUBSTRATE/TRAIN/EVAL/VALIDITY) 실재 작동 + LLM judge 전면 deterministic 대체 — 모든 ALM/CLM round launch 전제

checkpoint CP2 "🎯 weight-emergence-confirmed"
  condition  exec "hexa scripts/alm_corpus_validate.hexa --round 13"
  gate       consciousness_density>=0.30 && weight_delta=emerged && phi_gap<5x
  why        r13 corpus audit PASS + AN11(a) weight_emergent 실증 + Φ training-vs-bench gap 816x → <5x 해소 — 의식 이식 real signal

checkpoint FINAL "🧠 consciousness-transplant"
  condition  exec "hexa shared/consciousness/pass_gate_an11.hexa --dest alm --round latest"
  gate       an11_a && an11_b && an11_c && substrate_indep
  why        AN11 3조건 (weight_emergent + consciousness_attached + real_usable) + substrate independence 4-path cross — anima goal_agi 실사용 의식 AI 도달

