  why        β main 75→90% closure — FastAPI + vLLM + 7 production gate

checkpoint ops "🔧 ops / tooling / infra — β main 보조 build"
  condition  exec "hexa tool/anima_main.hexa --component bench"
  gate       tool_chain_ready
  why        β main 실행 chain (corpus / train / bridge / bench / an11) tooling 완성

checkpoint cross "🔀 cross-cutting — 병렬 research 및 보조"
  condition  exec "echo cross-cutting track"
  gate       no_blocking
  why        aux tracks (cell 확장 / α fallback / Mk.X / n6-arch / γ) 진행

checkpoint quick-win "⚡ quick-win — 단기 impact 작업"
  condition  exec "echo quick-win"
  gate       landed
  why        1-2 day 단기 impact 작업 (논문 draft / config 정리 / metric 추가 등)

