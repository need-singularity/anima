checkpoint cross "🔀 cross-cutting — 병렬 research 및 보조"
  condition  exec "echo cross-cutting track"
  gate       no_blocking
  why        aux tracks (cell 확장 / α fallback / Mk.X / n6-arch / γ) 진행

checkpoint quick-win "⚡ quick-win — 단기 impact 작업"
  condition  exec "echo quick-win"
  gate       landed
  why        1-2 day 단기 impact 작업 (논문 draft / config 정리 / metric 추가 등)

