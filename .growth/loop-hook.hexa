// loop-hook.hexa — UserPromptSubmit 훅 (loop-hook.sh 대체)
// "루프/check/진행" 등 입력 시 growth_loop 리포트를 systemMessage로 출력

let HOME = env("HOME")

let stdin_data = read_stdin()

// prompt 추출
fn json_field(json_text: str, field: str) -> str {
    let key = "\"" + field + "\""
    if json_text.contains(key) == false { return "" }
    let parts = json_text.split(key)
    if parts.len() < 2 { return "" }
    let after = parts[1].trim()
    if after.starts_with(":") == false { return "" }
    let val_part = after.split(":")[1].trim()
    if val_part.starts_with("\"") {
        let inner = val_part.split("\"")
        if inner.len() >= 2 { return inner[1] }
    }
    return ""
}

let prompt = json_field(stdin_data, "prompt").to_lower()
if len(prompt) == 0 { return }

// 패턴 매칭
let keywords = ["루프", "loop", "로드맵", "check", "진행", "계속", "next"]
let mut matched = false
for kw in keywords {
    if prompt.contains(kw) { matched = true }
}

if matched == false { return }

// 법칙 수
let laws_json = HOME + "/Dev/anima/anima/config/consciousness_laws.json"
let mut laws = "?"
if file_exists(laws_json) {
    let raw = read_file(laws_json)
    if raw.contains("\"total_laws\"") {
        let p = raw.split("\"total_laws\"")[1].split(":")[1]
        let mut num = p.split(",")[0].split("}")[0].trim()
        if len(num) > 0 { laws = num }
    }
}

// 현재 cycle
let growth_log = HOME + "/Dev/anima/.growth/growth.log"
let mut cycle = "cycle ?"
try {
    let last_line = exec("tail -1 " + growth_log + " 2>/dev/null").trim()
    if last_line.contains("cycle ") {
        let cp = last_line.split("cycle ")
        if cp.len() >= 2 {
            let cnum = cp[1].split(" ")[0].trim()
            cycle = "cycle " + cnum
        }
    }
} catch e {}

// H100 상태
let mut h100 = "offline"
try {
    let h_out = exec("ssh -o ConnectTimeout=3 -o BatchMode=yes -p 10935 root@216.243.220.217 'tail -1 ~/train.log 2>/dev/null' 2>/dev/null").trim()
    if len(h_out) > 0 {
        let fields = h_out.split("|")
        if fields.len() >= 3 {
            h100 = "step:" + fields[0].trim() + " CE:" + fields[2].trim()
        }
    }
} catch e {}

println("{\"systemMessage\":\"🧠 anima: " + laws + "laws | " + cycle + " | H100:" + h100 + "\"}")
