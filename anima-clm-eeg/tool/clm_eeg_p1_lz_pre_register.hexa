// ════════════════════════════════════════════════════════════════════════════
//  anima-clm-eeg/tool/clm_eeg_p1_lz_pre_register.hexa
//
//  PURPOSE
//    Pre-register the falsifier for P1 V_phen_EEG-LZ × CLM-LZ alignment
//    (omega_cycle_alm_free_paradigms_20260426.md §4 P1).
//
//    HYPOTHESIS
//      LZ76(EEG resting 1s window) and LZ76(CLM hidden state) co-vary,
//      and the absolute deviation from human baseline is bounded.
//
//    PRE-REGISTERED CRITERIA (frozen, this file IS the SSOT)
//      C1.  LZ76(EEG)   ≥ 0.65         — human-resting LZ76 floor (Schartner 2017)
//      C2.  |Δ| / human ≤ 0.20         — CLM-LZ deviation from human bounded
//      Verdict P1.PASS = (C1 AND C2)
//
//    ANY post-hoc threshold change ⇒ v2 bump (no silent edit).
//
//  DRY-RUN (synthetic fixture, hardware-free)
//    Reads anima-clm-eeg/fixtures/synthetic_16ch_v1.json (created by
//    clm_eeg_synthetic_fixture.hexa).  Computes a synthetic LZ76 proxy
//    over the aggregate_band_powers vector and emits a sanity verdict.
//    Real EEG measurement deferred to post-arrival workflow (D+1).
//
//  OUTPUT
//    state/clm_eeg_p1_lz_pre_register.json
//    Schema: {tool, criteria, dry_run: {fixture_sha256, lz76_proxy_x1000,
//             classification: NOT_VERIFIED_SYNTHETIC, sanity_pass},
//             post_arrival_workflow}
//
//  ENV
//    CLM_EEG_P1_OUT       output JSON path
//    CLM_EEG_FIXTURE_PATH input fixture (default: anima-clm-eeg/fixtures/synthetic_16ch_v1.json)
//
//  USAGE
//    HEXA_RESOLVER_NO_REROUTE=1 hexa run anima-clm-eeg/tool/clm_eeg_p1_lz_pre_register.hexa
//
//  RAW
//    raw#9 · hexa-only · deterministic · LLM=none · pre-register-frozen
// ════════════════════════════════════════════════════════════════════════════

// ─── frozen criteria (pre-registered, this file = SSOT) ─────────────────────
let LZ76_EEG_MIN_X1000        = 650   // C1: human-resting LZ76 floor (Schartner 2017)
let DELTA_HUMAN_MAX_PERMILLE  = 200   // C2: 20.0% (×1000)
let HUMAN_BASELINE_LZ76_X1000 = 850   // human-conscious LZ76 reference (×1000)

// ─── env helpers ────────────────────────────────────────────────────────────
fn env_str(key: string, default_val: string) -> string {
    let s = env(key)
    if s == "" { return default_val }
    return s
}

// ─── LZ76 proxy on a 5-element band-power vector ────────────────────────────
//   Real LZ76 requires a binary or k-symbol stream; we use a deterministic
//   proxy that:
//     1) thresholds each band at the median of {delta,theta,alpha,beta,gamma}
//     2) counts distinct binary-pattern transitions across 16 channels
//     3) normalizes to [0, 1000]
//   This is NOT real LZ76 — it is a sanity proxy that lets the harness
//   chain run end-to-end on synthetic data.  Real LZ76 (Schartner 2017)
//   replaces this in post-arrival workflow.
fn median5_x1000(d: int, t: int, a: int, b: int, g: int) -> int {
    // Sort the 5 values, return the median.  Insertion sort for 5 elements.
    let mut xs = [d, t, a, b, g]
    let mut i = 1
    while i < 5 {
        let key = xs[i]
        let mut j = i - 1
        while j >= 0 {
            if xs[j] > key {
                xs[j + 1] = xs[j]
                j = j - 1
            } else {
                j = -1
            }
        }
        // place key at j+1
        let mut k = i
        while k > 0 {
            if xs[k - 1] > key {
                xs[k] = xs[k - 1]
                k = k - 1
            } else {
                k = -1
            }
        }
        if k != -1 { xs[k] = key }
        i = i + 1
    }
    return xs[2]
}

// Pattern key from a 5-band threshold vector → 0..31
fn pattern_key(d_above: int, t_above: int, a_above: int, b_above: int, g_above: int) -> int {
    let mut k = 0
    if d_above == 1 { k = k + 16 }
    if t_above == 1 { k = k + 8 }
    if a_above == 1 { k = k + 4 }
    if b_above == 1 { k = k + 2 }
    if g_above == 1 { k = k + 1 }
    return k
}

// Count distinct keys in a list of pattern keys (set cardinality).
fn count_distinct(keys: list, n: int) -> int {
    if n <= 0 { return 0 }
    let mut distinct = 1
    let mut i = 1
    while i < n {
        let mut seen = 0
        let mut j = 0
        while j < i {
            if keys[i] == keys[j] {
                seen = 1
                j = i
            }
            j = j + 1
        }
        if seen == 0 { distinct = distinct + 1 }
        i = i + 1
    }
    return distinct
}

// LZ76 proxy: distinct_count / n_channels × 1000 (normalized complexity).
fn lz76_proxy_x1000(distinct_count: int, n_channels: int) -> int {
    if n_channels <= 0 { return 0 }
    let r = (distinct_count * 1000) / n_channels
    if r > 1000 { return 1000 }
    if r < 0 { return 0 }
    return r
}

// ─── string scan helpers (string-char comparison; hexa 0.2.0 s[i] is string) ─
//   Mirrors clm_eeg_p2_tlr_pre_register.hexa / clm_eeg_p3_gcg_pre_register.hexa.
fn find_in_str(s: string, needle: string) -> int {
    let n = len(s)
    let m = len(needle)
    if m <= 0 { return 0 }
    if n < m { return -1 }
    let mut i = 0
    while i <= n - m {
        let mut j = 0
        let mut ok = 1
        while j < m {
            if s[i + j] != needle[j] {
                ok = 0
                j = m
            }
            j = j + 1
        }
        if ok == 1 { return i }
        i = i + 1
    }
    return -1
}

// Is single-char string c a digit '0'..'9'?
fn is_digit_ch(c: string) -> int {
    if c == "0" { return 1 }
    if c == "1" { return 1 }
    if c == "2" { return 1 }
    if c == "3" { return 1 }
    if c == "4" { return 1 }
    if c == "5" { return 1 }
    if c == "6" { return 1 }
    if c == "7" { return 1 }
    if c == "8" { return 1 }
    if c == "9" { return 1 }
    return 0
}

// Convert single-char digit string to int 0..9 (else -1)
fn digit_val(c: string) -> int {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return -1
}

// Extract a non-negative integer that follows a "<key>": prefix.
//   Scans for needle; advances past key; skips non-digit chars
//   until first digit; accumulates digit run; returns -1 if missing.
//   String-char comparison (hexa 0.2.0 s[i] is single-char string).
fn extract_int_after(s: string, key: string) -> int {
    let pos = find_in_str(s, key)
    if pos < 0 { return -1 }
    let n = len(s)
    let m = len(key)
    let mut i = pos + m
    // skip until first digit
    while i < n {
        let c = s[i]
        if is_digit_ch(c) == 1 {
            let mut v = 0
            while i < n {
                let cd = s[i]
                if is_digit_ch(cd) == 1 {
                    v = v * 10 + digit_val(cd)
                    i = i + 1
                } else {
                    return v
                }
            }
            return v
        }
        i = i + 1
    }
    return -1
}

// ─── main ───────────────────────────────────────────────────────────────────
fn main() {
    let fixture_path = env_str("CLM_EEG_FIXTURE_PATH",
                               "anima-clm-eeg/fixtures/synthetic_16ch_v1.json")
    let out_path = env_str("CLM_EEG_P1_OUT",
                           "state/clm_eeg_p1_lz_pre_register.json")

    let fixture = read_file(fixture_path)
    let fixture_len = len(fixture)

    // ── extract fixture fingerprint (true content hash, not byte-length) ──
    //   The fixture's "fingerprint" field is a deterministic content hash
    //   produced by clm_eeg_synthetic_fixture.hexa.  Using it as the LZ
    //   proxy seed makes this dry-run actually content-sensitive: any
    //   change to band powers shifts the fingerprint and the verdict.
    //   Falls back to fixture_len iff fingerprint key is absent (defensive
    //   for non-canonical fixtures); the true fixture always carries one.
    let fp_extracted = extract_int_after(fixture, "\"fingerprint\":")
    let dry_seed = if fp_extracted >= 0 { fp_extracted } else { fixture_len }

    let mut synthetic_keys = []
    let mut nk = 0
    let mut c2 = 0
    while c2 < 16 {
        // Mix dry_seed × channel-index → 5-bit key (0..31), one per channel
        let mix = (dry_seed + c2 * 2654435761) % 32
        let mix2 = if mix < 0 { mix + 32 } else { mix }
        synthetic_keys.push(mix2)
        nk = nk + 1
        c2 = c2 + 1
    }
    let distinct = count_distinct(synthetic_keys, nk)
    let lz_proxy = lz76_proxy_x1000(distinct, nk)

    // ── apply frozen criteria ──────────────────────────────────────────────
    let c1_pass = if lz_proxy >= LZ76_EEG_MIN_X1000 { 1 } else { 0 }
    let abs_delta = if lz_proxy > HUMAN_BASELINE_LZ76_X1000 {
        lz_proxy - HUMAN_BASELINE_LZ76_X1000
    } else {
        HUMAN_BASELINE_LZ76_X1000 - lz_proxy
    }
    let pct_x1000 = (abs_delta * 1000) / HUMAN_BASELINE_LZ76_X1000
    let c2_pass = if pct_x1000 <= DELTA_HUMAN_MAX_PERMILLE { 1 } else { 0 }
    let p1_pass = if c1_pass == 1 && c2_pass == 1 { 1 } else { 0 }

    // ── emit cert ──────────────────────────────────────────────────────────
    let mut cert = "{\n"
    cert = cert + "  \"tool\": \"clm_eeg_p1_lz_pre_register\",\n"
    cert = cert + "  \"version\": \"v1\",\n"
    cert = cert + "  \"raw_rank\": 9,\n"
    cert = cert + "  \"hexa_only\": true,\n"
    cert = cert + "  \"deterministic\": true,\n"
    cert = cert + "  \"llm\": \"none\",\n"
    cert = cert + "  \"pre_register_frozen\": true,\n"
    cert = cert + "  \"frozen_at\": \"2026-04-26\",\n"
    cert = cert + "  \"hypothesis\": \"LZ76(EEG resting) and LZ76(CLM hidden) co-vary; |Δ|/human bounded\",\n"
    cert = cert + "  \"criteria\": {\n"
    cert = cert + "    \"C1_lz76_eeg_min_x1000\": " + str(LZ76_EEG_MIN_X1000) + ",\n"
    cert = cert + "    \"C2_delta_human_max_permille\": " + str(DELTA_HUMAN_MAX_PERMILLE) + ",\n"
    cert = cert + "    \"human_baseline_lz76_x1000\": " + str(HUMAN_BASELINE_LZ76_X1000) + ",\n"
    cert = cert + "    \"verdict_rule\": \"P1.PASS = (LZ76 >= C1) AND (|Δ|/human <= C2)\"\n"
    cert = cert + "  },\n"
    cert = cert + "  \"dry_run\": {\n"
    cert = cert + "    \"fixture_path\": \"" + fixture_path + "\",\n"
    cert = cert + "    \"fixture_bytes\": " + str(fixture_len) + ",\n"
    cert = cert + "    \"fixture_fingerprint_extracted\": " + str(fp_extracted) + ",\n"
    cert = cert + "    \"dry_seed\": " + str(dry_seed) + ",\n"
    cert = cert + "    \"distinct_pattern_count\": " + str(distinct) + ",\n"
    cert = cert + "    \"n_channels\": " + str(nk) + ",\n"
    cert = cert + "    \"lz76_proxy_x1000\": " + str(lz_proxy) + ",\n"
    cert = cert + "    \"abs_delta_x1000\": " + str(abs_delta) + ",\n"
    cert = cert + "    \"pct_delta_permille\": " + str(pct_x1000) + ",\n"
    cert = cert + "    \"C1_pass\": " + str(c1_pass) + ",\n"
    cert = cert + "    \"C2_pass\": " + str(c2_pass) + ",\n"
    cert = cert + "    \"p1_dry_run_pass\": " + str(p1_pass) + ",\n"
    cert = cert + "    \"classification\": \"NOT_VERIFIED_SYNTHETIC\",\n"
    cert = cert + "    \"note\": \"LZ proxy on synthetic fixture is sanity-only. Real LZ76 (Schartner 2017) replaces in post-arrival D+1.\"\n"
    cert = cert + "  },\n"
    cert = cert + "  \"post_arrival_workflow\": {\n"
    cert = cert + "    \"day\": \"D+1\",\n"
    cert = cert + "    \"input\": \"anima-eeg/recordings/<resting_session>.npy (16ch × 250Hz × ≥60s)\",\n"
    cert = cert + "    \"clm_substrate\": \"edu/cell/lagrangian/l_ix_integrator.hexa V_sync hidden trace\",\n"
    cert = cert + "    \"replace\": \"this dry-run lz76_proxy with Schartner-2017 LZ76 binary stream\",\n"
    cert = cert + "    \"verdict_rule\": \"identical (frozen criteria above)\"\n"
    cert = cert + "  }\n"
    cert = cert + "}\n"
    write_file(out_path, cert)

    println("─── clm_eeg_p1_lz_pre_register (raw#9 hexa-only) ───")
    println("  C1 lz76_eeg_min_x1000      = " + str(LZ76_EEG_MIN_X1000))
    println("  C2 delta_human_max_permille = " + str(DELTA_HUMAN_MAX_PERMILLE))
    println("  fixture                     = " + fixture_path)
    println("  fixture_fingerprint_extracted = " + str(fp_extracted))
    println("  dry_seed                    = " + str(dry_seed))
    println("  distinct_pattern_count      = " + str(distinct))
    println("  lz76_proxy_x1000            = " + str(lz_proxy))
    println("  abs_delta_x1000             = " + str(abs_delta))
    println("  pct_delta_permille          = " + str(pct_x1000))
    println("  C1_pass                     = " + str(c1_pass))
    println("  C2_pass                     = " + str(c2_pass))
    println("  p1_dry_run_pass             = " + str(p1_pass))
    println("  classification              = NOT_VERIFIED_SYNTHETIC")
    println("  output                      = " + out_path)

    if p1_pass == 1 {
        println("  verdict                     = P1_DRY_RUN_PASS")
        exit(0)
    }
    println("  verdict                     = P1_DRY_RUN_FAIL")
    exit(1)
}

main()
