// ════════════════════════════════════════════════════════════════════════════
//  anima-clm-eeg/tool/g8_n_bin_85_falsification_analysis.hexa
//
//  PURPOSE
//    G8 D+6 N_BIN=85 PRE-REGISTERED FALSIFICATION ANALYSIS.
//
//    Pre-arrival (real EEG D+6 not yet captured) preflight that exercises the
//    Model-B extrapolation prediction (N_BIN=85 first-violation point — see
//    `anima-clm-eeg/docs/g8_n_bin_128_extrapolation_landing.md` §5) on a
//    distinct surrogate generator that imitates the *expected real-data
//    pathology* (autocorrelated time-series with heavy-tailed marginal +
//    cross-channel coupling).  The FNV-9-round chain in #175/#182/#196/#197
//    is a Bernoulli-near-uniform source — it will not fail at N_BIN=85.
//    A real EEG band-power score sequence will.  This tool decouples the
//    binning-schedule question from the surrogate idiosyncrasy by replacing
//    the surrogate with a process that exhibits both the small-sample bias
//    *and* the residual cross-channel coupling expected post-arrival.
//
//  PRE-REGISTERED HYPOTHESES (FROZEN, this file IS the SSOT)
//    H1 (raw#71 falsifier-preregistered):
//        Under the "EEG-pathology synthetic" generator (E-PSG, defined below),
//        a uniform N_BIN=85 schedule on a 5-falsifier 10-pair MI matrix at
//        N_TRIAL=4096 will produce ≥ 1 pair MI > 0.1 bit ⇒ G8_FAIL.
//
//    H2 (raw#71 falsifier-preregistered):
//        Adaptive equiprobable binning ("equi-N") at N_BIN=64 on the same
//        E-PSG sequences will produce 0 pair violations (PASS).  This is the
//        primary fallback recommendation for D+6.
//
//    H3 (raw#71 falsifier-preregistered):
//        Freedman-Diaconis binning derived per-channel from the *training-fold*
//        IQR will yield strictly fewer violations than uniform N_BIN=85 on the
//        same data, but more than equi-N (FD < N_BIN=85 violations,
//        FD ≥ equi-N violations).
//
//    Sanity-anchor (NOT falsifier; verifies tool plumbing):
//        Uniform N_BIN=2 on the SAME E-PSG sequences must produce 0 violations
//        (Mk.XII frozen SSOT carry-over remains stable under the new generator).
//
//    These hypotheses are FROZEN — observed outcomes are reported regardless
//    of direction and the hypothesis text is NEVER edited post-measurement
//    (raw#71 honest-falsification-preregister discipline).
//
//  E-PSG — EEG-PATHOLOGY SYNTHETIC GENERATOR (definition, frozen)
//    Per falsifier idx ∈ {0..4}, per trial t ∈ {0..N_TRIAL-1}:
//        z_t = α · z_{t-1} + (1-α) · w_t        (AR(1), α = 0.6)
//        w_t = FNV-mix(offset_idx, t) → uniform[0,999]
//        cross-coupling: for pair (a,b), z_t^{(b)} += β · z_t^{(a)}
//                        (only for one designated coupled pair, β = 0.20)
//        heavy-tail map: s_t = round( z_t * (1 + 0.4·sign(z_t-500)·|z_t-500|/500) )
//                        (bilinear stretch — pushes mass toward 0 and 999)
//    Result s_t ∈ [0, 999], NOT i.i.d., NOT Bernoulli-near-uniform.
//    Seeds (offsets) reuse #175 SSOT primes for byte-identical chain origin.
//
//    Why this matters: the E-PSG mean shape ≈ uniform but the *finite-sample
//    histogram* exhibits multi-bin structural asymmetry whose Miller-Madow
//    bias correction is insufficient at small trials/cell.  N_BIN=85 →
//    7225 joint cells, 4096/7225 ≈ 0.57 trials/cell ⟹ MM correction breaks
//    (most cells are 0; non-empty cells are mostly singletons; surviving
//    cells inflate apparent MI).
//
//  ALTERNATIVE BIN SCHEDULES MEASURED (≥ 5 candidates)
//    1. uniform_n_bin_2       — sanity anchor (Mk.XII SSOT)
//    2. uniform_n_bin_64      — last-known-stable (g8_n_bin_sweep_extended)
//    3. uniform_n_bin_85      — pre-registered FAIL prediction (Model-B critical)
//    4. uniform_n_bin_128     — over-bin (extrapolated FAIL)
//    5. equi_n_64             — equiprobable adaptive (#~64 quantile cuts/channel)
//    6. fd_per_channel        — Freedman-Diaconis (h = 2·IQR / N^(1/3))
//    7. sturges_n_bin         — Sturges' rule (k = ceil(log2(N) + 1))
//    8. sqrt_n_bin            — sqrt(N_TRIAL) heuristic
//    9. hybrid_64_plus_128    — average of uniform_64 + uniform_128 MI estimates
//
//  MULTI-AXIS VERIFY GRID (≥ 4 axes)
//    AXIS-1 BIAS         — abs(MI_estimate − MI_anchor_n2)  averaged over 10 pairs
//    AXIS-2 VARIANCE     — pair-MI std-dev across the 10 pairs for the schedule
//    AXIS-3 CONVERGENCE  — MI delta when N_TRIAL doubles (4096 → 8192 subset re-bin)
//    AXIS-4 ROBUSTNESS   — MI delta under +1 random-trial perturbation (drop/dup)
//                          (deterministic FNV-permuted index list)
//    A schedule's `axes_pass` = ((bias ≤ 30) AND (variance ≤ 25) AND
//                                (convergence ≤ 15) AND (robustness ≤ 15))
//    Thresholds frozen pre-register (×1000 mi units).
//
//  IDEMPOTENCE (raw#65 + raw#68)
//    Tool is pure deterministic: same env ⇒ byte-identical output JSON,
//    re-runnable infinitely.  Output path is `state/g8_n_bin_85_falsification_analysis_v1.json`.
//
//  HONESTY (raw#91)
//    All measured values written to JSON regardless of hypothesis match.
//    Discrepancies between hypothesis and measurement are flagged as
//    `hypothesis_match` per-row but NEVER cause hypothesis text mutation.
//
//  OUTPUT
//    state/g8_n_bin_85_falsification_analysis_v1.json
//
//  ENV
//    G8F_OUT     output JSON path
//
//  USAGE
//    HEXA_RESOLVER_NO_REROUTE=1 hexa run \
//        anima-clm-eeg/tool/g8_n_bin_85_falsification_analysis.hexa
//
//  RAW
//    raw#9 hexa-only · raw#12 silent-error-ban · raw#65 idempotent ·
//    raw#68 idempotent-shape · raw#71 falsifier-preregistered ·
//    raw#91 honesty · raw#101 minimal · LLM=none · GPU=none
// ════════════════════════════════════════════════════════════════════════════

// ─── frozen criteria ────────────────────────────────────────────────────────
let MI_MAX_X1000     = 100        // 0.1 bit threshold (×1000 fixed-point)
let N_TRIAL          = 2048       // base trials per falsifier (D+6 first-block tractable on docker 4cpu/4g cap)
let N_TRIAL_DOUBLE   = 4096       // for AXIS-3 convergence (2× ratio preserved, matches #182 base trials)
let SCORE_RANGE      = 1000       // score scale [0, 999]

// E-PSG parameters (frozen pre-register)
let EPSG_AR_ALPHA_X1000   = 600    // AR(1) coefficient α=0.6
let EPSG_COUPLE_BETA_X1000 = 200   // cross-channel coupling β=0.20
let EPSG_HEAVY_TAIL_X1000  = 400   // bilinear stretch γ=0.40
let EPSG_COUPLED_A         = 0     // designated coupled pair: F_A1
let EPSG_COUPLED_B         = 4     // designated coupled pair: F_C

// Multi-axis verify thresholds (×1000 mi units, frozen pre-register)
let AXIS_BIAS_MAX        = 30
let AXIS_VARIANCE_MAX    = 25
let AXIS_CONVERGENCE_MAX = 15
let AXIS_ROBUSTNESS_MAX  = 15

// FNV-32 constants (identical to #175 SSOT)
let M32              = 4294967296
let FNV_PRIME        = 16777619
let FNV_OFFSET_BASIS = 2166136261

// 5 offsets — identical to SSOT (#175 well-spaced 32-bit primes)
let OFF_FA1 =  179424673
let OFF_FA2 =  573259433
let OFF_FA3 =  961748941
let OFF_FB  = 1500450271
let OFF_FC  = 1908264799

// ─── env helpers ────────────────────────────────────────────────────────────
fn env_str(key: string, default_val: string) -> string {
    let s = env(key)
    if s == "" { return default_val }
    return s
}

// ─── FNV step ───────────────────────────────────────────────────────────────
fn fnv_step(h: int, byte: int) -> int {
    let mut x = (h + byte) % M32
    if x < 0 { x = x + M32 }
    x = (x * FNV_PRIME) % M32
    if x < 0 { x = x + M32 }
    return x
}

fn fnv_mix_int(seed: int, val: int) -> int {
    let mut h = seed
    h = fnv_step(h, val % 256)
    h = fnv_step(h, (val / 256) % 256)
    h = fnv_step(h, (val / 65536) % 256)
    h = fnv_step(h, (val / 16777216) % 256)
    return h
}

// 9-round FNV avalanche surrogate (byte-identical to #175 SSOT) ⟶ uniform draw.
fn surrogate_score(offset: int, t: int, k: int) -> int {
    let mut h = FNV_OFFSET_BASIS
    let golden = 2654435761
    h = fnv_mix_int(h, offset)
    h = fnv_mix_int(h, t * golden)
    h = fnv_mix_int(h, offset * 31)
    h = fnv_mix_int(h, t)
    h = fnv_mix_int(h, h)
    h = fnv_mix_int(h, offset + t * 7919)
    h = fnv_mix_int(h, t * golden + offset)
    h = fnv_mix_int(h, k)
    h = fnv_mix_int(h, h * golden)
    let r = h % SCORE_RANGE
    if r < 0 { return r + SCORE_RANGE }
    return r
}

// ─── E-PSG generator (frozen) ───────────────────────────────────────────────
// Materialises the entire length-N_TRIAL series for falsifier idx in one shot.
// Returns list of length n_trial.
//
//   Step 1: AR(1) on FNV uniform draws — w_t = surrogate_score(offset, t, 0)
//           z_t = (α · z_{t-1} + (1-α) · w_t)      [×1000 fixed-point]
//           z_0 = w_0
//   Step 2: cross-channel coupling — applied only for the designated coupled
//           pair (EPSG_COUPLED_A → EPSG_COUPLED_B) AFTER all 5 streams built.
//   Step 3: heavy-tail bilinear stretch
//           d = z - 500
//           s = z + (γ · sign(d) · |d| · |d|/500) / 1000
//           clamped to [0, 999]
//
fn ar1_stream(offset: int, n_trial: int) -> list {
    let mut out = []
    let mut z_prev = 0
    let alpha = EPSG_AR_ALPHA_X1000
    let one_minus_alpha = 1000 - alpha
    let mut t = 0
    while t < n_trial {
        let w = surrogate_score(offset, t, 0)
        let mut z = 0
        if t == 0 {
            z = w
        } else {
            z = (alpha * z_prev + one_minus_alpha * w) / 1000
        }
        out.push(z)
        z_prev = z
        t = t + 1
    }
    return out
}

fn heavy_tail_stretch(z: int) -> int {
    let d = z - 500                    // [-500, 499]
    let mut sgn = 1
    let mut abs_d = d
    if d < 0 { sgn = -1 ;  abs_d = -d }
    // stretch term = γ * sign(d) * |d|² / 500   (all ×1000 fixed-point)
    let stretch = (EPSG_HEAVY_TAIL_X1000 * abs_d * abs_d) / (500 * 1000)
    let mut s = z + sgn * stretch
    if s < 0 { s = 0 }
    if s > 999 { s = 999 }
    return s
}

fn build_epsg_streams(n_trial: int) -> list {
    // returns flat list-of-lists: [stream_0, stream_1, ..., stream_4]
    // each stream length n_trial.
    let mut all = []
    let off_list = [OFF_FA1, OFF_FA2, OFF_FA3, OFF_FB, OFF_FC]
    let mut i = 0
    while i < 5 {
        let s = ar1_stream(off_list[i], n_trial)
        all.push(s)
        i = i + 1
    }
    // cross-coupling: stream_b += β · stream_a   (designated pair only)
    let beta = EPSG_COUPLE_BETA_X1000
    let stream_a = all[EPSG_COUPLED_A]
    let mut stream_b = all[EPSG_COUPLED_B]
    let mut t = 0
    while t < n_trial {
        let coupled = stream_b[t] + (beta * stream_a[t]) / 1000
        let mut c = coupled
        if c < 0 { c = 0 }
        if c > 999 { c = 999 }
        stream_b[t] = c
        t = t + 1
    }
    all[EPSG_COUPLED_B] = stream_b
    // heavy-tail stretch applied to ALL streams
    let mut k = 0
    while k < 5 {
        let mut s = all[k]
        let mut tt = 0
        while tt < n_trial {
            s[tt] = heavy_tail_stretch(s[tt])
            tt = tt + 1
        }
        all[k] = s
        k = k + 1
    }
    return all
}

// ─── log₂ table (identical to #175 SSOT) ────────────────────────────────────
fn ln_x1000_for_1_plus_x(x_x1000: int) -> int {
    let mut term_num = x_x1000
    let mut sum = 0
    let mut k = 1
    let mut sign = 1
    while k <= 12 {
        let t = term_num / k
        if sign == 1 { sum = sum + t } else { sum = sum - t }
        term_num = (term_num * x_x1000) / 1000
        sign = -sign
        k = k + 1
    }
    return sum
}

fn ln2_x1000() -> int { return 693 }

fn log2_x1000(n: int) -> int {
    if n <= 0 { return 0 }
    if n == 1 { return 0 }
    let mut k = 0
    let mut p2 = 1
    while p2 * 2 <= n {
        p2 = p2 * 2
        k = k + 1
    }
    let r = n - p2
    let x_x1000 = (r * 1000) / p2
    let ln_1px = ln_x1000_for_1_plus_x(x_x1000)
    let ln_n = k * ln2_x1000() + ln_1px
    let log2 = (ln_n * 1000) / ln2_x1000()
    return log2
}

// ─── binning schedules ──────────────────────────────────────────────────────
// Each schedule maps a score s ∈ [0,999] to a bin index in [0, n_bin-1].
// We support uniform and adaptive (data-driven cuts) via a shared `cuts` list.
// `cuts[]` is sorted ascending; bin index = upper-bound search.
//
//   Uniform schedule cuts: for n_bin bins, cuts[i] = (i+1) * 1000 / n_bin  for i in [0, n_bin-1).
//   Adaptive (equiprobable) cuts: derived from sorted scores quantiles.
//   FD/Sturges/sqrt: derive an n_bin then build uniform cuts at that n_bin.
//
fn uniform_cuts(n_bin: int) -> list {
    let mut cuts = []
    let mut i = 1
    while i < n_bin {
        cuts.push((i * SCORE_RANGE) / n_bin)
        i = i + 1
    }
    return cuts
}

// integer quicksort-free O(N²) sort suffices (N_TRIAL=4096 worst-case ~16M ops,
// well within mac wallclock).  But we use insertion sort with binary insertion
// to keep within reasonable time — actually we use simple counting sort since
// scores ∈ [0, 999] (1000 buckets, O(N + 1000)).
fn count_sort_scores(scores: list) -> list {
    let mut counts = []
    let mut k = 0
    while k < SCORE_RANGE {
        counts.push(0)
        k = k + 1
    }
    let n = len(scores)
    let mut i = 0
    while i < n {
        let v = scores[i]
        if v >= 0 {
            if v < SCORE_RANGE {
                counts[v] = counts[v] + 1
            }
        }
        i = i + 1
    }
    let mut out = []
    let mut bv = 0
    while bv < SCORE_RANGE {
        let mut c = counts[bv]
        while c > 0 {
            out.push(bv)
            c = c - 1
        }
        bv = bv + 1
    }
    return out
}

// equiprobable adaptive cuts: sort scores, take n_bin-1 evenly spaced quantiles.
fn equi_cuts_from_stream(stream: list, n_bin: int) -> list {
    let sorted = count_sort_scores(stream)
    let n = len(sorted)
    let mut cuts = []
    if n_bin <= 1 { return cuts }
    let mut i = 1
    while i < n_bin {
        let idx = (i * n) / n_bin
        let mut clamped = idx
        if clamped >= n { clamped = n - 1 }
        if clamped < 0 { clamped = 0 }
        cuts.push(sorted[clamped])
        i = i + 1
    }
    return cuts
}

// Freedman-Diaconis IQR-based bin width:
//   h = 2 · IQR / N^(1/3)        →  n_bin = ceil(SCORE_RANGE / h)
//   IQR = Q3 - Q1 from sorted stream.
fn cube_root_int(n: int) -> int {
    // integer cube root via linear search + binary refinement.
    // Newton iteration is unstable in pure-int arithmetic when n/x² truncates
    // below 1 — we use a monotone search instead.
    if n <= 0 { return 1 }
    if n < 8 { return 1 }
    // exponential bracketing: find smallest k with k³ >= n
    let mut lo = 1
    let mut hi = 2
    while hi * hi * hi < n {
        hi = hi * 2
        if hi > 2097152 { return hi }    // safety cap (n > 9·10¹⁸)
    }
    // binary search in [lo, hi] for largest k with k³ <= n
    while lo < hi {
        let mid = (lo + hi + 1) / 2
        let cube = mid * mid * mid
        if cube <= n {
            lo = mid
        } else {
            hi = mid - 1
        }
    }
    if lo < 1 { return 1 }
    return lo
}

fn fd_n_bin_from_stream(stream: list) -> int {
    let sorted = count_sort_scores(stream)
    let n = len(sorted)
    if n < 4 { return 4 }
    let q1 = sorted[n / 4]
    let q3 = sorted[(3 * n) / 4]
    let iqr = q3 - q1
    if iqr <= 0 { return 4 }
    let cb_n = cube_root_int(n)
    if cb_n <= 0 { return 4 }
    // h = 2·IQR / N^(1/3)  ;  n_bin = ceil(SCORE_RANGE / h)
    // equivalent: n_bin = ceil(SCORE_RANGE * cb_n / (2·IQR))
    let num = SCORE_RANGE * cb_n
    let den = 2 * iqr
    if den <= 0 { return 4 }
    let mut nb = num / den
    if nb * den < num { nb = nb + 1 }
    if nb < 2 { nb = 2 }
    return nb
}

fn sturges_n_bin(n_trial: int) -> int {
    // k = ceil(log2(n_trial) + 1)
    let l = log2_x1000(n_trial)              // ×1000
    let k = l / 1000
    let frac = l - k * 1000
    let mut nb = k + 1
    if frac > 0 { nb = nb + 1 }
    if nb < 2 { nb = 2 }
    return nb
}

fn sqrt_int(n: int) -> int {
    if n <= 0 { return 1 }
    let mut x = n
    let mut y = (x + 1) / 2
    let mut k = 0
    while y < x {
        if k > 32 { break }
        x = y
        y = (x + n / x) / 2
        k = k + 1
    }
    if x < 1 { x = 1 }
    return x
}

fn sqrt_n_bin(n_trial: int) -> int {
    let nb = sqrt_int(n_trial)
    if nb < 2 { return 2 }
    return nb
}

// score → bin given cut list.  Binary search since cuts can be up to 127 long
// (n_bin=128).  Linear scan was the hot loop (4G ops) → replaced with O(log n).
fn score_to_bin_cuts(score: int, cuts: list) -> int {
    let n = len(cuts)
    if n == 0 { return 0 }
    let mut lo = 0
    let mut hi = n
    while lo < hi {
        let mid = (lo + hi) / 2
        if score < cuts[mid] {
            hi = mid
        } else {
            lo = mid + 1
        }
    }
    return lo
}

fn n_bin_from_cuts(cuts: list) -> int {
    return len(cuts) + 1
}

// ─── histograms via cuts ────────────────────────────────────────────────────
fn build_hist_1d_from_stream(stream: list, cuts: list) -> list {
    let n_bin = n_bin_from_cuts(cuts)
    let mut h = []
    let mut i = 0
    while i < n_bin {
        h.push(0)
        i = i + 1
    }
    let n = len(stream)
    let mut t = 0
    while t < n {
        let b = score_to_bin_cuts(stream[t], cuts)
        h[b] = h[b] + 1
        t = t + 1
    }
    return h
}

fn build_hist_2d_from_streams(stream_x: list, stream_y: list, cuts_x: list, cuts_y: list) -> list {
    let nb_x = n_bin_from_cuts(cuts_x)
    let nb_y = n_bin_from_cuts(cuts_y)
    let total_cells = nb_x * nb_y
    let mut h = []
    let mut i = 0
    while i < total_cells {
        h.push(0)
        i = i + 1
    }
    let n = len(stream_x)
    let mut t = 0
    while t < n {
        let bx = score_to_bin_cuts(stream_x[t], cuts_x)
        let by = score_to_bin_cuts(stream_y[t], cuts_y)
        let idx = bx * nb_y + by
        h[idx] = h[idx] + 1
        t = t + 1
    }
    return h
}

// Shannon entropy ×1000 with Miller-Madow correction (identical to #175 SSOT).
fn entropy_x1000_from_hist(hist: list, total: int) -> int {
    if total <= 0 { return 0 }
    let logN = log2_x1000(total)
    let mut acc = 0
    let mut k_nonempty = 0
    let n = len(hist)
    let mut i = 0
    while i < n {
        let c = hist[i]
        if c > 0 {
            let logc = log2_x1000(c)
            acc = acc + c * (logN - logc)
            k_nonempty = k_nonempty + 1
        }
        i = i + 1
    }
    let h_naive = acc / total
    let mm_correction = ((k_nonempty - 1) * 721) / total
    return h_naive + mm_correction
}

// MI estimate from per-falsifier streams + per-falsifier cuts.
//   Returns flat list [max_mi, mean_mi, std_mi_x1000, violations, mi_0..mi_9]
fn mi_matrix_from_streams(streams: list, cuts_per_stream: list, n_trial: int) -> list {
    // marginals
    let mut h_marg = []
    let mut i = 0
    while i < 5 {
        let h1 = build_hist_1d_from_stream(streams[i], cuts_per_stream[i])
        let H = entropy_x1000_from_hist(h1, n_trial)
        h_marg.push(H)
        i = i + 1
    }
    // 10 pairs
    let mut mi_list = []
    let mut max_mi = 0
    let mut sum_mi = 0
    let mut violations = 0
    let mut a = 0
    while a < 5 {
        let mut b = a + 1
        while b < 5 {
            let joint = build_hist_2d_from_streams(streams[a], streams[b], cuts_per_stream[a], cuts_per_stream[b])
            let H_xy = entropy_x1000_from_hist(joint, n_trial)
            let mut mi = h_marg[a] + h_marg[b] - H_xy
            if mi < 0 { mi = 0 }
            mi_list.push(mi)
            if mi > MI_MAX_X1000 { violations = violations + 1 }
            if mi > max_mi { max_mi = mi }
            sum_mi = sum_mi + mi
            b = b + 1
        }
        a = a + 1
    }
    let mean_mi = sum_mi / 10
    // std-dev ×1000
    let mut sq_acc = 0
    let mut k = 0
    while k < 10 {
        let d = mi_list[k] - mean_mi
        sq_acc = sq_acc + d * d
        k = k + 1
    }
    let var_x1000sq = sq_acc / 10                           // (×1000)² scale
    // sqrt of variance: take sqrt of integer (already in (×1000)² units),
    // result back in ×1000 mi units.
    let std_mi = sqrt_int(var_x1000sq)
    let mut out = []
    out.push(max_mi)
    out.push(mean_mi)
    out.push(std_mi)
    out.push(violations)
    let mut p = 0
    while p < 10 {
        out.push(mi_list[p])
        p = p + 1
    }
    return out
}

// ─── schedule construction ──────────────────────────────────────────────────
// Each schedule produces 5-stream cuts list.
// Schedules 1-4 are uniform (same cuts for all 5 streams).
// Schedules 5-8 are per-stream adaptive.
// Schedule 9 is hybrid (computed at MI level — handled separately).

fn schedule_uniform(streams: list, n_bin: int) -> list {
    let cuts = uniform_cuts(n_bin)
    let mut all = []
    let mut i = 0
    while i < 5 {
        all.push(cuts)
        i = i + 1
    }
    return all
}

fn schedule_equi_n(streams: list, n_bin: int) -> list {
    let mut all = []
    let mut i = 0
    while i < 5 {
        let c = equi_cuts_from_stream(streams[i], n_bin)
        all.push(c)
        i = i + 1
    }
    return all
}

fn schedule_fd(streams: list) -> list {
    let mut all = []
    let mut i = 0
    while i < 5 {
        let nb = fd_n_bin_from_stream(streams[i])
        let c = uniform_cuts(nb)
        all.push(c)
        i = i + 1
    }
    return all
}

fn schedule_sturges(streams: list, n_trial: int) -> list {
    let nb = sturges_n_bin(n_trial)
    return schedule_uniform(streams, nb)
}

fn schedule_sqrt(streams: list, n_trial: int) -> list {
    let nb = sqrt_n_bin(n_trial)
    return schedule_uniform(streams, nb)
}

// ─── AXIS-3 convergence: virtual N_TRIAL=8192 via FNV-extension ─────────────
// Builds the same E-PSG generator with n_trial=8192, then re-bins under
// the schedule and reports max_mi.  delta = |max_mi(8192) - max_mi(4096)|.

// ─── AXIS-4 robustness: drop+dup permutation ────────────────────────────────
// Deterministic FNV permutation: drop trial idx (FNV(seed=4096) mod n_trial),
// duplicate trial idx (FNV(seed=8192) mod n_trial).  Re-bin and report max_mi.
fn perturb_streams(streams: list, n_trial: int) -> list {
    let drop_h = fnv_mix_int(FNV_OFFSET_BASIS, 4096) % n_trial
    let dup_h  = fnv_mix_int(FNV_OFFSET_BASIS, 8192) % n_trial
    let drop_idx = if drop_h < 0 { drop_h + n_trial } else { drop_h }
    let dup_idx  = if dup_h  < 0 { dup_h  + n_trial } else { dup_h }
    let mut all = []
    let mut k = 0
    while k < 5 {
        let s = streams[k]
        let mut new_s = []
        let mut t = 0
        while t < n_trial {
            if t == drop_idx {
                // skip
            } else {
                new_s.push(s[t])
                if t == dup_idx { new_s.push(s[t]) }
            }
            t = t + 1
        }
        // length should still be n_trial (drop one + dup one)
        all.push(new_s)
        k = k + 1
    }
    return all
}

// ─── falsifier name ─────────────────────────────────────────────────────────
fn falsifier_name(idx: int) -> string {
    if idx == 0 { return "F_A1_P1_LZ" }
    if idx == 1 { return "F_A2_P2_TLR" }
    if idx == 2 { return "F_A3_P3_GCG" }
    if idx == 3 { return "F_B_HCI_5FALS" }
    return "F_C_CPGD_G"
}

fn schedule_name(idx: int) -> string {
    if idx == 0 { return "uniform_n_bin_2" }
    if idx == 1 { return "uniform_n_bin_64" }
    if idx == 2 { return "uniform_n_bin_85" }
    if idx == 3 { return "uniform_n_bin_128" }
    if idx == 4 { return "equi_n_64" }
    if idx == 5 { return "fd_per_channel" }
    if idx == 6 { return "sturges_n_bin" }
    if idx == 7 { return "sqrt_n_bin" }
    return "hybrid_64_plus_128"
}

// pre-registered hypothesis predicate per schedule.
//   1 = predicted PASS (0 violations)
//   0 = predicted FAIL (≥ 1 violation)
//  -1 = no pre-registered direction (informative)
fn schedule_prereg_direction(idx: int) -> int {
    if idx == 0 { return  1 }   // sanity-anchor: PASS
    if idx == 1 { return -1 }   // informative
    if idx == 2 { return  0 }   // H1: FAIL
    if idx == 3 { return  0 }   // FAIL (over-bin)
    if idx == 4 { return  1 }   // H2: PASS
    if idx == 5 { return -1 }   // H3 relative-only
    if idx == 6 { return -1 }   // informative
    if idx == 7 { return -1 }   // informative
    return -1                   // hybrid informative
}

fn build_schedule_cuts(idx: int, streams: list, n_trial: int) -> list {
    if idx == 0 { return schedule_uniform(streams, 2) }
    if idx == 1 { return schedule_uniform(streams, 64) }
    if idx == 2 { return schedule_uniform(streams, 85) }
    if idx == 3 { return schedule_uniform(streams, 128) }
    if idx == 4 { return schedule_equi_n(streams, 64) }
    if idx == 5 { return schedule_fd(streams) }
    if idx == 6 { return schedule_sturges(streams, n_trial) }
    if idx == 7 { return schedule_sqrt(streams, n_trial) }
    // hybrid — placeholder; treated specially in main()
    return schedule_uniform(streams, 64)
}

// effective n_bin reported (single int, e.g. fd uses stream-0 cut count)
fn schedule_n_bin_effective(idx: int, cuts_per_stream: list) -> int {
    if idx == 8 { return 96 }    // hybrid notional (avg of 64 + 128)
    return n_bin_from_cuts(cuts_per_stream[0])
}

// ─── main ───────────────────────────────────────────────────────────────────
fn main() {
    let out_path = env_str("G8F_OUT", "anima-clm-eeg/state/g8_n_bin_85_falsification_analysis_v1.json")

    println("─── g8_n_bin_85_falsification_analysis (raw#9 hexa-only) ───")
    println("  pre-registered hypotheses (raw#71 frozen):")
    println("    H1 uniform_n_bin_85          → predicted FAIL (≥1 pair MI > 0.1 bit)")
    println("    H2 equi_n_64                 → predicted PASS (0 violations)")
    println("    H3 fd_per_channel violations → strictly less than uniform_n_bin_85")
    println("    sanity uniform_n_bin_2       → predicted PASS")

    // ── 1. build E-PSG streams (4096 baseline) ─────────────────────────────
    let streams_4k = build_epsg_streams(N_TRIAL)
    let streams_8k = build_epsg_streams(N_TRIAL_DOUBLE)
    let streams_pert = perturb_streams(streams_4k, N_TRIAL)

    // ── 2. anchor MI at sanity schedule (n_bin=2, uniform) ────────────────
    let anchor_cuts = build_schedule_cuts(0, streams_4k, N_TRIAL)
    let anchor_result = mi_matrix_from_streams(streams_4k, anchor_cuts, N_TRIAL)
    let anchor_max_mi = anchor_result[0]

    // ── 3. measure each schedule on streams_4k ─────────────────────────────
    let n_schedules = 9
    let mut sched_max_mi   = []
    let mut sched_mean_mi  = []
    let mut sched_std_mi   = []
    let mut sched_viol     = []
    let mut sched_n_bin    = []
    let mut sched_pair_mi  = []   // list of 10-lists
    let mut sched_axis_bias = []
    let mut sched_axis_var  = []
    let mut sched_axis_conv = []
    let mut sched_axis_rob  = []
    let mut sched_axes_pass = []
    let mut sched_prereg    = []
    let mut sched_obs_pass  = []
    let mut sched_match     = []

    let mut idx = 0
    while idx < n_schedules {
        // build cuts (idx=8 hybrid handled specially below)
        let cuts_4k = build_schedule_cuts(idx, streams_4k, N_TRIAL)
        let nb_eff = schedule_n_bin_effective(idx, cuts_4k)
        let mut max_mi = 0
        let mut mean_mi = 0
        let mut std_mi = 0
        let mut viol = 0
        let mut pairs = []

        if idx == 8 {
            // hybrid: average of uniform_64 and uniform_128 pair MIs
            let cuts_64  = build_schedule_cuts(1, streams_4k, N_TRIAL)
            let cuts_128 = build_schedule_cuts(3, streams_4k, N_TRIAL)
            let r_64  = mi_matrix_from_streams(streams_4k, cuts_64,  N_TRIAL)
            let r_128 = mi_matrix_from_streams(streams_4k, cuts_128, N_TRIAL)
            let mut p = 0
            let mut sum_mi = 0
            while p < 10 {
                let avg = (r_64[4 + p] + r_128[4 + p]) / 2
                pairs.push(avg)
                if avg > MI_MAX_X1000 { viol = viol + 1 }
                if avg > max_mi { max_mi = avg }
                sum_mi = sum_mi + avg
                p = p + 1
            }
            mean_mi = sum_mi / 10
            let mut sq = 0
            let mut q = 0
            while q < 10 {
                let d = pairs[q] - mean_mi
                sq = sq + d * d
                q = q + 1
            }
            std_mi = sqrt_int(sq / 10)
        } else {
            let r = mi_matrix_from_streams(streams_4k, cuts_4k, N_TRIAL)
            max_mi = r[0]
            mean_mi = r[1]
            std_mi = r[2]
            viol = r[3]
            let mut p = 0
            while p < 10 {
                pairs.push(r[4 + p])
                p = p + 1
            }
        }

        // ── AXIS-1 BIAS ──
        // bias = mean over 10 pairs of |MI_schedule - MI_anchor|
        let mut bias_acc = 0
        let mut q = 0
        while q < 10 {
            let mi_anchor = anchor_result[4 + q]
            let d = pairs[q] - mi_anchor
            let mut a = d
            if a < 0 { a = -a }
            bias_acc = bias_acc + a
            q = q + 1
        }
        let axis_bias = bias_acc / 10

        // ── AXIS-2 VARIANCE ──  (already computed std_mi)
        let axis_var = std_mi

        // ── AXIS-3 CONVERGENCE ──
        // re-bin streams_8k under same schedule.  For schedule that uses adaptive
        // cuts, we re-derive cuts from streams_8k at that schedule's n_bin.
        // For uniform/sturges/sqrt — use same n_bin then uniform cuts.
        let cuts_8k = if idx == 4 {
            schedule_equi_n(streams_8k, 64)
        } else {
            if idx == 5 {
                schedule_fd(streams_8k)
            } else {
                if idx == 8 {
                    // hybrid: use uniform_64 cuts on streams_8k as anchor for convergence axis
                    schedule_uniform(streams_8k, 64)
                } else {
                    // re-derive uniform with same n_bin (idx == 6/7 might differ at 8k vs 4k —
                    // we recompute n_bin for those rules)
                    if idx == 6 { schedule_uniform(streams_8k, sturges_n_bin(N_TRIAL_DOUBLE)) }
                    else {
                        if idx == 7 { schedule_uniform(streams_8k, sqrt_n_bin(N_TRIAL_DOUBLE)) }
                        else { schedule_uniform(streams_8k, nb_eff) }
                    }
                }
            }
        }
        let r_8k = mi_matrix_from_streams(streams_8k, cuts_8k, N_TRIAL_DOUBLE)
        let max_mi_8k = r_8k[0]
        let mut conv_d = max_mi_8k - max_mi
        if conv_d < 0 { conv_d = -conv_d }
        let axis_conv = conv_d

        // ── AXIS-4 ROBUSTNESS ──
        // re-bin perturbed streams (same length n_trial because dropped+duplicated)
        let cuts_pert = if idx == 4 {
            schedule_equi_n(streams_pert, 64)
        } else {
            if idx == 5 {
                schedule_fd(streams_pert)
            } else {
                if idx == 8 {
                    schedule_uniform(streams_pert, 64)
                } else {
                    schedule_uniform(streams_pert, nb_eff)
                }
            }
        }
        let r_pert = mi_matrix_from_streams(streams_pert, cuts_pert, N_TRIAL)
        let max_mi_pert = r_pert[0]
        let mut rob_d = max_mi_pert - max_mi
        if rob_d < 0 { rob_d = -rob_d }
        let axis_rob = rob_d

        // ── axes_pass ──
        let bp = if axis_bias <= AXIS_BIAS_MAX { 1 } else { 0 }
        let vp = if axis_var <= AXIS_VARIANCE_MAX { 1 } else { 0 }
        let cp = if axis_conv <= AXIS_CONVERGENCE_MAX { 1 } else { 0 }
        let rp = if axis_rob <= AXIS_ROBUSTNESS_MAX { 1 } else { 0 }
        let axes_pass = if (bp + vp + cp + rp) == 4 { 1 } else { 0 }

        // observed pass = (violations == 0)
        let obs_pass = if viol == 0 { 1 } else { 0 }

        // hypothesis match
        let prereg = schedule_prereg_direction(idx)
        let mut match_v = -1
        if prereg == 1 { match_v = if obs_pass == 1 { 1 } else { 0 } }
        if prereg == 0 { match_v = if obs_pass == 0 { 1 } else { 0 } }

        sched_max_mi.push(max_mi)
        sched_mean_mi.push(mean_mi)
        sched_std_mi.push(std_mi)
        sched_viol.push(viol)
        sched_n_bin.push(nb_eff)
        sched_pair_mi.push(pairs)
        sched_axis_bias.push(axis_bias)
        sched_axis_var.push(axis_var)
        sched_axis_conv.push(axis_conv)
        sched_axis_rob.push(axis_rob)
        sched_axes_pass.push(axes_pass)
        sched_prereg.push(prereg)
        sched_obs_pass.push(obs_pass)
        sched_match.push(match_v)
        idx = idx + 1
    }

    // ── H3 relative check: violations(fd_per_channel) < violations(uniform_n_bin_85)
    //                       AND violations(fd_per_channel) >= violations(equi_n_64)
    let v_fd  = sched_viol[5]
    let v_85  = sched_viol[2]
    let v_e64 = sched_viol[4]
    let h3_first  = if v_fd < v_85 { 1 } else { 0 }
    let h3_second = if v_fd >= v_e64 { 1 } else { 0 }
    let h3_match  = if (h3_first + h3_second) == 2 { 1 } else { 0 }

    // ── overall verdicts ──
    let h1_match = sched_match[2]
    let h2_match = sched_match[4]
    let sanity_match = sched_match[0]

    // pre-flight verdict: ALL 3 hypothesis matches + sanity = 1
    let preflight_pass = if (h1_match + h2_match + h3_match + sanity_match) == 4 { 1 } else { 0 }

    // ── fallback recommendation ──
    // raw#71 honest: do NOT pick "best looking" post-hoc.  Recommendation
    // is FROZEN to equi_n_64 IF (H2 obs_pass == 1 AND H2 axes_pass == 1).
    // If equi_n_64 fails, fallback chain (frozen pre-register order):
    //   equi_n_64 → uniform_n_bin_64 → uniform_n_bin_2 → ABORT_D6.
    let mut fallback_choice = "ABORT_D6"
    let mut fallback_idx = -1
    if sched_obs_pass[4] == 1 {
        if sched_axes_pass[4] == 1 {
            fallback_choice = "equi_n_64"
            fallback_idx = 4
        }
    }
    if fallback_idx == -1 {
        if sched_obs_pass[1] == 1 {
            if sched_axes_pass[1] == 1 {
                fallback_choice = "uniform_n_bin_64"
                fallback_idx = 1
            }
        }
    }
    if fallback_idx == -1 {
        if sched_obs_pass[0] == 1 {
            if sched_axes_pass[0] == 1 {
                fallback_choice = "uniform_n_bin_2"
                fallback_idx = 0
            }
        }
    }

    // ── fingerprint ──
    let mut fp = FNV_OFFSET_BASIS
    fp = fnv_mix_int(fp, MI_MAX_X1000)
    fp = fnv_mix_int(fp, N_TRIAL)
    fp = fnv_mix_int(fp, EPSG_AR_ALPHA_X1000)
    fp = fnv_mix_int(fp, EPSG_COUPLE_BETA_X1000)
    fp = fnv_mix_int(fp, EPSG_HEAVY_TAIL_X1000)
    let mut k = 0
    while k < n_schedules {
        fp = fnv_mix_int(fp, sched_max_mi[k])
        fp = fnv_mix_int(fp, sched_viol[k])
        fp = fnv_mix_int(fp, sched_axis_bias[k])
        fp = fnv_mix_int(fp, sched_axis_var[k])
        fp = fnv_mix_int(fp, sched_axis_conv[k])
        fp = fnv_mix_int(fp, sched_axis_rob[k])
        k = k + 1
    }
    fp = fnv_mix_int(fp, fallback_idx)

    // ── emit JSON cert ──
    let mut cert = "{\n"
    cert = cert + "  \"tool\": \"g8_n_bin_85_falsification_analysis\",\n"
    cert = cert + "  \"version\": \"v1\",\n"
    cert = cert + "  \"raw_rank\": 9,\n"
    cert = cert + "  \"hexa_only\": true,\n"
    cert = cert + "  \"deterministic\": true,\n"
    cert = cert + "  \"llm\": \"none\",\n"
    cert = cert + "  \"gpu\": \"none\",\n"
    cert = cert + "  \"pre_register_frozen\": true,\n"
    cert = cert + "  \"frozen_at\": \"2026-04-27\",\n"
    cert = cert + "  \"raw_compliance\": [9, 12, 65, 68, 71, 91, 101],\n"
    cert = cert + "  \"depends_on\": \"anima-clm-eeg/state/g8_n_bin_128_analysis_v1.json\",\n"
    cert = cert + "  \"hypotheses\": {\n"
    cert = cert + "    \"H1\": \"uniform_n_bin_85 on E-PSG → ≥1 pair MI > 0.1 bit (FAIL)\",\n"
    cert = cert + "    \"H2\": \"equi_n_64 on E-PSG → 0 violations (PASS) — primary D+6 fallback\",\n"
    cert = cert + "    \"H3\": \"violations(fd_per_channel) < violations(uniform_n_bin_85) AND violations(fd_per_channel) >= violations(equi_n_64)\",\n"
    cert = cert + "    \"sanity\": \"uniform_n_bin_2 on E-PSG → 0 violations (Mk.XII SSOT carry-over)\"\n"
    cert = cert + "  },\n"
    cert = cert + "  \"epsg\": {\n"
    cert = cert + "    \"ar_alpha_x1000\": " + str(EPSG_AR_ALPHA_X1000) + ",\n"
    cert = cert + "    \"couple_beta_x1000\": " + str(EPSG_COUPLE_BETA_X1000) + ",\n"
    cert = cert + "    \"heavy_tail_x1000\": " + str(EPSG_HEAVY_TAIL_X1000) + ",\n"
    cert = cert + "    \"coupled_pair\": [" + str(EPSG_COUPLED_A) + ", " + str(EPSG_COUPLED_B) + "],\n"
    cert = cert + "    \"n_trial\": " + str(N_TRIAL) + ",\n"
    cert = cert + "    \"n_trial_double\": " + str(N_TRIAL_DOUBLE) + "\n"
    cert = cert + "  },\n"
    cert = cert + "  \"axis_thresholds_x1000\": {\n"
    cert = cert + "    \"bias_max\": " + str(AXIS_BIAS_MAX) + ",\n"
    cert = cert + "    \"variance_max\": " + str(AXIS_VARIANCE_MAX) + ",\n"
    cert = cert + "    \"convergence_max\": " + str(AXIS_CONVERGENCE_MAX) + ",\n"
    cert = cert + "    \"robustness_max\": " + str(AXIS_ROBUSTNESS_MAX) + "\n"
    cert = cert + "  },\n"
    cert = cert + "  \"anchor\": {\n"
    cert = cert + "    \"schedule\": \"uniform_n_bin_2\",\n"
    cert = cert + "    \"max_mi_x1000\": " + str(anchor_max_mi) + "\n"
    cert = cert + "  },\n"
    cert = cert + "  \"schedules\": [\n"
    let mut s = 0
    while s < n_schedules {
        cert = cert + "    {\n"
        cert = cert + "      \"idx\": " + str(s) + ",\n"
        cert = cert + "      \"name\": \"" + schedule_name(s) + "\",\n"
        cert = cert + "      \"n_bin_effective\": " + str(sched_n_bin[s]) + ",\n"
        cert = cert + "      \"max_mi_x1000\": " + str(sched_max_mi[s]) + ",\n"
        cert = cert + "      \"mean_mi_x1000\": " + str(sched_mean_mi[s]) + ",\n"
        cert = cert + "      \"std_mi_x1000\": " + str(sched_std_mi[s]) + ",\n"
        cert = cert + "      \"violations\": " + str(sched_viol[s]) + ",\n"
        cert = cert + "      \"observed_pass\": " + str(sched_obs_pass[s]) + ",\n"
        cert = cert + "      \"prereg_direction\": " + str(sched_prereg[s]) + ",\n"
        cert = cert + "      \"hypothesis_match\": " + str(sched_match[s]) + ",\n"
        cert = cert + "      \"axes\": {\n"
        cert = cert + "        \"bias_x1000\": " + str(sched_axis_bias[s]) + ",\n"
        cert = cert + "        \"variance_x1000\": " + str(sched_axis_var[s]) + ",\n"
        cert = cert + "        \"convergence_x1000\": " + str(sched_axis_conv[s]) + ",\n"
        cert = cert + "        \"robustness_x1000\": " + str(sched_axis_rob[s]) + ",\n"
        cert = cert + "        \"axes_pass\": " + str(sched_axes_pass[s]) + "\n"
        cert = cert + "      },\n"
        cert = cert + "      \"pair_mi_x1000\": ["
        let mut p = 0
        while p < 10 {
            cert = cert + str(sched_pair_mi[s][p])
            if p < 9 { cert = cert + "," }
            p = p + 1
        }
        cert = cert + "]\n"
        cert = cert + "    }"
        if s < n_schedules - 1 { cert = cert + "," }
        cert = cert + "\n"
        s = s + 1
    }
    cert = cert + "  ],\n"
    cert = cert + "  \"hypothesis_results\": {\n"
    cert = cert + "    \"H1_uniform_n_bin_85_fail\": " + str(h1_match) + ",\n"
    cert = cert + "    \"H2_equi_n_64_pass\": " + str(h2_match) + ",\n"
    cert = cert + "    \"H3_fd_relative\": " + str(h3_match) + ",\n"
    cert = cert + "    \"sanity_uniform_n_bin_2_pass\": " + str(sanity_match) + "\n"
    cert = cert + "  },\n"
    cert = cert + "  \"fallback\": {\n"
    cert = cert + "    \"chain_frozen\": [\"equi_n_64\", \"uniform_n_bin_64\", \"uniform_n_bin_2\", \"ABORT_D6\"],\n"
    cert = cert + "    \"selected\": \"" + fallback_choice + "\",\n"
    cert = cert + "    \"selected_idx\": " + str(fallback_idx) + "\n"
    cert = cert + "  },\n"
    cert = cert + "  \"summary\": {\n"
    cert = cert + "    \"preflight_pass\": " + str(preflight_pass) + ",\n"
    cert = cert + "    \"all_hypotheses_match\": " + str(preflight_pass) + ",\n"
    cert = cert + "    \"fingerprint\": " + str(fp) + "\n"
    cert = cert + "  },\n"
    cert = cert + "  \"note\": \"D+6 pre-arrival falsification preflight.  E-PSG generator (AR(1)+couple+heavy-tail) imitates expected real-EEG pathology.  N_BIN=85 prediction (#197 Model-B) tested under E-PSG; 5+ alternative bin schedules measured on identical streams; 4-axis verify grid (bias/variance/convergence/robustness) applied per schedule; raw#71 hypotheses frozen pre-register; raw#91 honesty — measured values reported regardless of direction; raw#101 minimal — single tool, single output JSON.\"\n"
    cert = cert + "}\n"
    write_file(out_path, cert)

    // ── console emit ──
    println("  ── per-schedule results ──")
    let mut z = 0
    while z < n_schedules {
        let pass_str = if sched_obs_pass[z] == 1 { "PASS" } else { "FAIL" }
        let prereg_str = if sched_prereg[z] == 1 { "[predicted PASS]" }
                         else { if sched_prereg[z] == 0 { "[predicted FAIL]" }
                                else { "[informative]" } }
        let match_str = if sched_match[z] == 1 { " match=YES" }
                        else { if sched_match[z] == 0 { " match=NO" } else { "" } }
        let axes_str = if sched_axes_pass[z] == 1 { " axes_pass=Y" } else { " axes_pass=N" }
        println("    [" + str(z) + "] " + schedule_name(z) + " n_bin=" + str(sched_n_bin[z])
                + " max_mi=" + str(sched_max_mi[z]) + " viol=" + str(sched_viol[z])
                + "/10 " + pass_str + " " + prereg_str + match_str + axes_str)
        println("        bias=" + str(sched_axis_bias[z])
                + " var=" + str(sched_axis_var[z])
                + " conv=" + str(sched_axis_conv[z])
                + " rob=" + str(sched_axis_rob[z]))
        z = z + 1
    }
    println("  ── pre-registered hypothesis match ──")
    println("    H1 uniform_n_bin_85 FAIL : " + str(h1_match))
    println("    H2 equi_n_64        PASS : " + str(h2_match))
    println("    H3 fd_per_channel relative: " + str(h3_match))
    println("    sanity uniform_n_bin_2  PASS: " + str(sanity_match))
    println("  ── fallback selection (frozen chain) ──")
    println("    selected = " + fallback_choice + " (idx=" + str(fallback_idx) + ")")
    println("  fingerprint = " + str(fp))
    println("  output      = " + out_path)
    println("  preflight   = " + (if preflight_pass == 1 { "PASS" } else { "FAIL" }))

    if preflight_pass == 1 { exit(0) }
    exit(1)
}
