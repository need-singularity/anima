// rust/phi_map.hexa — anima-phi-map summary port
// Source: archive/rust/anima-rs/crates/phi-map/ (terrain, heatmap, tracker, law_terrain)

comptime const SCALE_MIN = 8
comptime const SCALE_MAX = 1024

struct TerrainPoint {
    cell_count:     int,
    module_order:   int,    // attach order (0..N)
    step:           int,
    phi:            float
}

struct PhiTerrain {
    n_points: int,
    phi_min:  float,
    phi_max:  float
}

fn terrain_new() -> PhiTerrain {
    PhiTerrain { n_points: 0, phi_min: 1000000000.0, phi_max: 0.0 }
}

fn terrain_add(t: PhiTerrain, p: TerrainPoint) -> PhiTerrain {
    let new_min = if p.phi < t.phi_min { p.phi } else { t.phi_min }
    let new_max = if p.phi > t.phi_max { p.phi } else { t.phi_max }
    PhiTerrain { n_points: t.n_points + 1, phi_min: new_min, phi_max: new_max }
}

// ─── ASCII heatmap (heatmap.rs) ───
// Rust: AsciiHeatmap::render(grid) → " .:-=+*#%@"
pure fn density_glyph(d: float) -> string {
    if d < 0.1      { " " }
    else if d < 0.2 { "." }
    else if d < 0.3 { ":" }
    else if d < 0.4 { "-" }
    else if d < 0.5 { "=" }
    else if d < 0.6 { "+" }
    else if d < 0.7 { "*" }
    else if d < 0.8 { "#" }
    else if d < 0.9 { "%" }
    else            { "@" }
}

// ─── PhiTracker (time-series of Φ) ───
struct PhiTracker {
    samples:    int,
    phi_sum:    float,
    phi_peak:   float,
    last_step:  int
}

fn tracker_new() -> PhiTracker {
    PhiTracker { samples: 0, phi_sum: 0.0, phi_peak: 0.0, last_step: 0 }
}

fn tracker_record(t: PhiTracker, step: int, phi: float) -> PhiTracker {
    let new_peak = if phi > t.phi_peak { phi } else { t.phi_peak }
    PhiTracker {
        samples:   t.samples + 1,
        phi_sum:   t.phi_sum + phi,
        phi_peak:  new_peak,
        last_step: step
    }
}

pure fn tracker_mean(t: PhiTracker) -> float {
    if t.samples == 0 { return 0.0 }
    t.phi_sum / to_float(t.samples)
}

// ─── LawTerrain (per-law Φ landscape) ───
struct LawPoint {
    law_id: int,
    phi:    float,
    cells:  int
}

struct LawInteraction {
    a_law:  int,
    b_law:  int,
    delta:  float    // joint_phi - sum(individual)
}

// TODO: SVG terrain export

let t0 = tracker_new()
let t1 = tracker_record(t0, 100, 1.42)
let t2 = tracker_record(t1, 200, 2.71)
println("phi-map tracker mean=", tracker_mean(t2), "peak=", t2.phi_peak)
println("glyph(0.55)=", density_glyph(0.55))
