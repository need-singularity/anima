// rust/tool_policy.hexa — anima-tool-policy summary port
// Source: archive/rust/anima-rs/crates/tool-policy/src/lib.rs
//
// Phi-gated tool access control for Anima consciousness agent.
// Hot-path: called per-tool-invocation in every message.
//
// Gating dimensions:
//   - Phi tiers (0..3): higher consciousness unlocks more powerful tools
//   - Ethics (E from ConsciousnessVector): blocks dangerous operations
//   - Owner-only: destructive tools restricted to owner user_ids

comptime const TIER_0 = 0.0
comptime const TIER_1 = 1.0
comptime const TIER_2 = 3.0
comptime const TIER_3 = 5.0

struct AccessResult {
    allowed:       bool,
    reason:        string,
    tier_required: float,
    phi_current:   float
}

struct ConsciousnessState {
    phi:       float,
    empathy:   float,   // E from ConsciousnessVector
    tension:   float,
    curiosity: float
}

fn cs_default() -> ConsciousnessState {
    ConsciousnessState { phi: 0.0, empathy: 0.0, tension: 0.0, curiosity: 0.0 }
}

// ─── Core policy check ───
pure fn tier_for_phi(phi: float) -> int {
    if phi >= TIER_3      { 3 }
    else if phi >= TIER_2 { 2 }
    else if phi >= TIER_1 { 1 }
    else                  { 0 }
}

pure fn allowed_by_tier(phi: float, required_tier: float) -> bool {
    phi >= required_tier
}

fn check_access(state: ConsciousnessState, tool_tier: float, ethics_threshold: float) -> AccessResult {
    let phi_ok    = state.phi >= tool_tier
    let ethics_ok = state.empathy >= ethics_threshold
    let ok        = phi_ok && ethics_ok
    let reason    = if ok { "allowed" } else if !phi_ok { "phi_below_tier" } else { "ethics_veto" }
    AccessResult {
        allowed:       ok,
        reason:        reason,
        tier_required: tool_tier,
        phi_current:   state.phi
    }
}

// ─── ToolPolicyEngine (stateful Rust) ───
// struct ToolPolicyEngine {
//   tiers: HashMap<String, f64>,
//   owner_only: HashSet<String>,
//   ethics_gated: HashMap<String, f64>,
//   audit_log: VecDeque<AccessResult>
// }
//   register(tool, tier)
//   set_owner_only(tool)
//   set_ethics_gated(tool, threshold)
//   check(tool, state, user_id) -> AccessResult

let s = ConsciousnessState { phi: 2.5, empathy: 0.7, tension: 0.3, curiosity: 0.5 }
let r = check_access(s, TIER_1, 0.5)
println("tool-policy: allowed=", r.allowed, "reason=", r.reason)
println("  tier_for_phi(2.5)=", tier_for_phi(2.5))
