// rust/evo_runner.hexa — anima-evo-runner summary port
// Source: archive/rust/anima-rs/crates/evo-runner/ (main, runner, signal, status)
//
// Watchdog binary that supervises infinite_evolution.py:
//   - spawn python process
//   - monitor crash → auto-restart with --resume (max 3 crashes per stage)
//   - graceful SIGINT/SIGTERM propagation
//   - writes PID to data/evo_runner.pid
//   - reads data/evolution_roadmap.json to detect completion

comptime const MAX_CRASHES = 3

struct RunnerConfig {
    resume:        bool,
    src_dir:       string,
    data_dir:      string,
    max_crashes:   int,
    check_roadmap: bool
}

struct RunnerStatus {
    running:         bool,
    crashes:         int,
    last_exit_code:  int,
    stage:           string,
    pid:             int
}

fn runner_new(src_dir: string, data_dir: string, resume: bool) -> RunnerConfig {
    RunnerConfig {
        resume:        resume,
        src_dir:       src_dir,
        data_dir:      data_dir,
        max_crashes:   MAX_CRASHES,
        check_roadmap: true
    }
}

fn runner_status(c: RunnerConfig) -> RunnerStatus {
    RunnerStatus {
        running:        false,
        crashes:        0,
        last_exit_code: 0,
        stage:          "idle",
        pid:            0
    }
}

// ─── Control flow (runner.rs) ───
// fn start(cfg) -> Result<()>:
//   loop:
//     spawn `python3 infinite_evolution.py --auto-roadmap [--resume]`
//     wait_with_signal_handler()
//     if exit == 0 || roadmap_complete { break }
//     crashes = crashes + 1
//     if crashes >= MAX_CRASHES { log + skip stage + reset counter }
//     sleep 5s
//     resume = true
//
// fn stop(): read data/evo_runner.pid → SIGTERM → SIGKILL after 10s
//
// fn status(): parse data/evolution_roadmap.json + evolution_live.json
//
// ─── Signal handling (signal.rs) ───
// SIGINT/SIGTERM → forward to child → wait max 30s → SIGKILL

// TODO: main.rs wiring (clap args, subcommands start/status/stop)

let cfg = runner_new("anima/src", "data", false)
println("evo-runner: src=", cfg.src_dir, "max_crashes=", cfg.max_crashes)
let st = runner_status(cfg)
println("  status.stage=", st.stage, "crashes=", st.crashes)
