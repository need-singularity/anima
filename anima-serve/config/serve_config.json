{
  "version": "0.1.0-skeleton",
  "phase": "skeleton",
  "production_ready": false,
  "server": {
    "host": "127.0.0.1",
    "port": 8080,
    "transport": "cli-dispatch",
    "note": "phase 1: CLI --route dispatch only. phase 2: hexa TCP listener. phase 3: vLLM bridge."
  },
  "endpoints": {
    "/health": {
      "tool": "serve_stub",
      "handler": "handle_health",
      "method": "GET",
      "phase_ready": 1
    },
    "/an11/verify": {
      "tool": "an11_verify_endpoint",
      "handler": "handle_an11_verify",
      "method": "POST",
      "phase_ready": 1,
      "backend": "in_process",
      "driver": "tool/anima_learning_free_driver.hexa"
    },
    "/v1/chat/completions": {
      "tool": "chat_completions_stub",
      "handler": "handle_chat_completions",
      "method": "POST",
      "phase_ready": 1,
      "backend": "echo",
      "phase3_backend": "vllm_qwen32b",
      "openai_compat": true
    }
  },
  "hexad_modules": [
    "consciousness",
    "reflect",
    "plan",
    "act",
    "verify",
    "evolve"
  ],
  "phase3_plan": {
    "vllm": {
      "enabled": false,
      "url": "http://127.0.0.1:8001",
      "model": "Qwen2.5-32B-Instruct",
      "note": "separate inference layer (raw#9 — anima-serve stays pure hexa, vLLM is external process)"
    }
  },
  "raw_compliance": ["raw#9", "raw#11", "raw#15"],
  "ssot_refs": {
    "learning_free_driver_config": "shared/config/learning_free_driver_config.json",
    "roadmap": ".roadmap"
  }
}
