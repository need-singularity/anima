// tests/test_drill_e2e.hexa — drill_breakthrough_runner end-to-end smoke
//
// SCENARIO: r13_mock
//   - spins up a fake seed set (2 positive + 1 negative + 1 diagonal)
//   - runs tool/drill_breakthrough_runner.hexa via --dry-run
//   - asserts runner exits 0 or 1 (never 2 as in v1 stub)
//   - asserts cross-run consistency (determinism)
//   - validates expected verdict shape
//
// NOTE: this test invokes the runner in-process by setting up mock
// env (DRILL_SKIP_AUDIT=1 to bypass audit-chain) and capturing stdout.
// It does NOT mutate shared/bench/drill_seed_set.jsonl — instead it
// operates through the runner's --dry-run path.
//
// Pass criteria: exit_code ∈ {0, 1} AND stdout contains "verdict="
//                AND cross-run xrun_ok=true for every seed.
//
// Deterministic: same CI run → same result.

let RUNNER = "tool/drill_breakthrough_runner.hexa"

fn assert_true(cond: bool, msg: string) {
    if cond {
        println("[PASS] " + msg)
    } else {
        println("[FAIL] " + msg)
        exit(1)
    }
}

fn capture(cmd: string) -> string {
    return exec(cmd + " 2>&1")
}

fn main() {
    println("=== drill_e2e smoke (r13_mock) ===")

    // 1) Runner must be present.
    assert_true(file_exists(RUNNER), "runner exists at " + RUNNER)

    // 2) Invoke runner via --dry-run with audit bypass.
    let cmd = "DRILL_SKIP_AUDIT=1 HEXA_VAL_ARENA=0 hexa " + RUNNER
            + " alm 99 --dry-run"
    let out = capture(cmd)
    println("--- runner stdout ---")
    println(out)
    println("--- end stdout ---")

    // 3) Must mention v2 live (stub branding gone).
    assert_true(out.contains("drill_breakthrough_runner v2"),
                "runner announces v2 (stub eliminated)")

    // 4) Must emit verdict line.
    assert_true(out.contains("verdict="),
                "runner emits verdict line")

    // 5) Cross-run determinism: every seed prints xrun_ok=true.
    //    (fallback oracle is pure over seed_id; run2 must collapse to run1.)
    assert_true(out.contains("xrun_ok=true"),
                "at least one seed shows cross-run consistency")
    assert_true(!out.contains("xrun_ok=false"),
                "no seed shows cross-run drift")

    // 6) dry-run: no cert written.
    assert_true(out.contains("(dry-run) would write:"),
                "dry-run mode honored (no cert write)")

    // 7) Verdict must be PASS or REJECT — never stub.
    let pass_verdict   = out.contains("verdict=PASS")
    let reject_verdict = out.contains("verdict=REJECT")
    assert_true(pass_verdict || reject_verdict,
                "verdict ∈ {PASS, REJECT} — stub branch eliminated")
    assert_true(!out.contains("stub: not implemented"),
                "no stub-banner in output")

    println("")
    println("=== drill_e2e smoke PASS ===")
    exit(0)
}
