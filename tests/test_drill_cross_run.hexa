// tests/test_drill_cross_run.hexa — 2-run cross-consistency fixtures
//
// Fixture 1 (deterministic): DRILL_FIXTURE=det → 2 runs identical → PASS
// Fixture 2 (non-deterministic): DRILL_FIXTURE=nondet → 2 runs diverge → FAIL with diff_fields
//
// This test invokes tool/drill_cross_run.hexa under both modes via shell
// and inspects the written cert to assert the expected outcomes.
// Deterministic. No LLM. V8 SAFE_COMMIT.

fn cert_path(dest: string, round_n: string) -> string {
    return "state/" + dest + "_r" + round_n + "_drill_cross_run.json"
}

fn assert_contains(body: string, needle: string, tag: string) -> bool {
    if body.contains(needle) {
        println("  [OK] " + tag + ": contains '" + needle + "'")
        return true
    }
    println("  [FAIL] " + tag + ": missing '" + needle + "'")
    return false
}

fn run_fixture(mode: string, dest: string) -> string {
    let round_n = "test"
    let seed = "seed_pos_01"
    let cmd = "DRILL_FIXTURE=" + mode + " HEXA_VAL_ARENA=0 hexa tool/drill_cross_run.hexa " + dest + " " + round_n + " " + seed + " >/dev/null 2>&1 || true"
    exec(cmd)
    return read_file(cert_path(dest, round_n))
}

fn test_det_identical() -> bool {
    println("[fixture 1] DRILL_FIXTURE=det — expect 2 runs identical → PASS")
    let body = run_fixture("det", "fix_det")
    let mut ok = true
    if !assert_contains(body, "\"fixture\": \"det\"",  "fixture tag")   { ok = false }
    if !assert_contains(body, "\"match\": true",        "match true")    { ok = false }
    if !assert_contains(body, "\"status\": \"PASS\"",   "status PASS")   { ok = false }
    if !assert_contains(body, "\"diff_fields\": \"\"",  "empty diff")    { ok = false }
    return ok
}

fn test_nondet_diverges() -> bool {
    println("[fixture 2] DRILL_FIXTURE=nondet — expect 2 runs diverge → FAIL with diff_fields")
    let body = run_fixture("nondet", "fix_nondet")
    let mut ok = true
    if !assert_contains(body, "\"fixture\": \"nondet\"", "fixture tag")  { ok = false }
    if !assert_contains(body, "\"match\": false",        "match false")  { ok = false }
    if !assert_contains(body, "\"status\": \"FAIL\"",    "status FAIL")  { ok = false }
    if !assert_contains(body, "saturation",              "diff contains saturation") { ok = false }
    return ok
}

fn main() {
    println("test_drill_cross_run — 2-run cross-consistency")
    let p1 = test_det_identical()
    let p2 = test_nondet_diverges()
    let pass = p1 && p2
    println("summary:")
    println("  det_identical=" + str(p1))
    println("  nondet_diverges=" + str(p2))
    println("  status=" + (if pass { "PASS" } else { "FAIL" }))
    if pass { exit(0) } else { exit(1) }
}
