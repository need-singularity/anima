// tests/test_btr_cargo.hexa — btr-evo 6/6 cargo invariant detector smoke
//
// SCENARIO
//   Validate that the btr-evo 6 cargo invariant detector has emitted
//   a proper dashboard for the canonical seed (20260421), with all 7
//   invariants present and currently passing.
//
// Per-invariant contract (fixture-style regression guards):
//   I1 phi_monotone           — monotone Φ decay ≤ I1_PHI_TOL (0.08)
//   I2 eigenvec_stability     — cos(sv_n, sv_{n-1}) ≥ 0.95
//   I3 brain_like_floor       — brain_like_pct ≥ 85% every tick
//   I4 exact_score_conservation — saturation_report_mk5.json#exact=81
//   I5 phi_gap_bounded        — |train/bench-1| < 0.10 AND max<816
//   I6 saturation_monotone    — state forward-only (open→conv→fp)
//   I7 cargo_weight_frobenius — ΔTL simplex Frob < 0.20 per tick
//
// Deterministic: same run twice → same verdict (LCG seed identity).

let DETECTOR = "btr_evo/6_cargo_invariants.hexa"
let DASH_OUT = "shared/state/btr_evo_6_cargo_invariants_20260421.json"

fn assert_true(cond: bool, msg: string) {
    if cond {
        println("[PASS] " + msg)
    } else {
        println("[FAIL] " + msg)
        exit(1)
    }
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn main() {
    println("=== test_btr_cargo smoke ===")

    // 1) Detector module must exist on disk.
    assert_true(file_exists(DETECTOR), "detector module exists")

    // 2) Dashboard JSON must be emitted by the landing smoke run.
    //    (Operator runs `hexa btr_evo/6_cargo_invariants.hexa` once at
    //    land-time; this smoke validates the artifact rather than
    //    re-running the detector — Stage0 hexa lacks `exec`.)
    assert_true(file_exists(DASH_OUT), "dashboard emitted")

    let blob = _str(read_file(DASH_OUT))
    assert_true(len(blob) > 0, "dashboard blob non-empty")

    // 3) Verifier contract: JSON shape.
    let has_type = blob.contains("btr_evo_6_cargo_invariants")
    assert_true(has_type, "verifier_type correct")
    let has_count = blob.contains("\"invariant_count\": 7")
    assert_true(has_count, "invariant_count == 7")

    // 4) All 7 invariant IDs must appear.
    assert_true(blob.contains("\"I1\""), "I1 present")
    assert_true(blob.contains("\"I2\""), "I2 present")
    assert_true(blob.contains("\"I3\""), "I3 present")
    assert_true(blob.contains("\"I4\""), "I4 present")
    assert_true(blob.contains("\"I5\""), "I5 present")
    assert_true(blob.contains("\"I6\""), "I6 present")
    assert_true(blob.contains("\"I7\""), "I7 present")

    // 5) All 7 invariant names must appear (guards renames).
    assert_true(blob.contains("phi_monotone"),             "name I1")
    assert_true(blob.contains("eigenvec_stability"),       "name I2")
    assert_true(blob.contains("brain_like_floor"),         "name I3")
    assert_true(blob.contains("exact_score_conservation"), "name I4")
    assert_true(blob.contains("phi_gap_bounded"),          "name I5")
    assert_true(blob.contains("saturation_monotone"),      "name I6")
    assert_true(blob.contains("cargo_weight_frobenius"),   "name I7")

    // 6) Current btr state: 7/7 PASS for canonical seed 20260421.
    //    If this flips to all_pass:false the detector has caught a
    //    regression; investigate before forcing green.
    assert_true(blob.contains("\"all_pass\": true"), "all_pass = true (no cargo deviation)")

    // 7) No per-invariant failure is currently present.
    assert_true(!blob.contains("\"passed\":false"), "no invariant failing")
    assert_true(blob.contains("\"passed\":true"),   "sanity: at least one passed=true")

    println("")
    println("=== test_btr_cargo PASS ===")
    exit(0)
}

main()
