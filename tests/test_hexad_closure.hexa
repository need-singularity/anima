// tests/test_hexad_closure.hexa — verifier smoke for Hexad 6-cat closure
//
// SCENARIO: actual-tree
//   - runs tool/hexad_closure_verifier.hexa on the live anima-hexad/
//   - asserts a verdict line is emitted ∈ {CLOSED, LEAKY, INCOMPLETE}
//   - asserts all 6 categories (c, d, w, s, m, e) are reported
//   - asserts per-axiom line present for (a)(b)(c)(d)
//   - asserts verdict JSON file is written
//
// Deterministic: same tree → same verdict across runs.

let VERIFIER = "tool/hexad_closure_verifier.hexa"
let OUT_JSON = "shared/state/hexad_closure_verdict.json"

fn assert_true(cond: bool, msg: string) {
    if cond {
        println("[PASS] " + msg)
    } else {
        println("[FAIL] " + msg)
        exit(1)
    }
}

fn capture(cmd: string) -> string {
    return exec(cmd + " 2>&1")
}

fn main() {
    println("=== test_hexad_closure (actual-tree) ===")

    assert_true(file_exists(VERIFIER), "verifier exists at " + VERIFIER)

    // Resolve the self-hosted hexa binary (the /opt/homebrew/bin/hexa
    // is an older REPL without exec()).  Prefer HEXA env-var, then the
    // canonical self-host path, then fallback to PATH.
    let self_host = "/Users/ghost/Dev/hexa-lang/hexa"
    let hexa_bin = if file_exists(self_host) { self_host } else { "hexa" }
    let cmd = "HEXA_VAL_ARENA=0 " + hexa_bin + " " + VERIFIER
    let out = capture(cmd)
    println("--- verifier stdout ---")
    println(out)
    println("--- end stdout ---")

    // Verdict line emitted.
    assert_true(out.contains("closure_verdict ="),
                "verifier prints closure_verdict line")

    let v_closed     = out.contains("closure_verdict = CLOSED")
    let v_leaky      = out.contains("closure_verdict = LEAKY")
    let v_incomplete = out.contains("closure_verdict = INCOMPLETE")
    assert_true(v_closed || v_leaky || v_incomplete,
                "verdict ∈ {CLOSED, LEAKY, INCOMPLETE}")

    // All 6 CDESM labels reported.
    assert_true(out.contains("consciousness"), "reports c / consciousness")
    assert_true(out.contains("desire"),        "reports d / desire")
    assert_true(out.contains("will"),          "reports w / will")
    assert_true(out.contains("sense"),         "reports s / sense")
    assert_true(out.contains("memory"),        "reports m / memory")
    assert_true(out.contains("ethics"),        "reports e / ethics")

    // All 4 axioms reported.
    assert_true(out.contains("axiom(a) non-emptiness:"),
                "axiom (a) reported")
    assert_true(out.contains("axiom(b) morphism existence:"),
                "axiom (b) reported")
    assert_true(out.contains("axiom(c) composition closure:"),
                "axiom (c) reported")
    assert_true(out.contains("axiom(d) phantom absence:"),
                "axiom (d) reported")

    // Verdict JSON file landed.
    assert_true(file_exists(OUT_JSON),
                "verdict JSON written to " + OUT_JSON)

    println("")
    println("=== test_hexad_closure PASS ===")
    exit(0)
}

main()
