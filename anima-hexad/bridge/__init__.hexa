// bridge/__init__.hexa — Bridge module: ThalamicBridge + TensionBridge
// Port of bridge/__init__.py
//
// Re-exports bridge types from model.hexa (ThalamicBridge)
// TensionBridge is part of the trinity legacy, referenced for compat

pub use hexad.model.{ThalamicBridge, create_thalamic_bridge, thalamic_bridge_forward}

fn main() {
    let bridge = create_thalamic_bridge(128, 384, 8)
    print("bridge: c_dim=" + to_string(bridge.c_dim) + " d_model=" + to_string(bridge.d_model))
}
