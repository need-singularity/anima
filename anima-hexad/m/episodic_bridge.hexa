// episodic_bridge.hexa — CLM-P11-2: M (Memory) provides time-ordered episodes
//
// EmergentM already models Hebbian LTP/LTD as memory (see emergent_m.hexa —
// "C's Hebbian weights ARE memory"). P11 adds an episodic channel: M physically
// yields a chronologically-ordered stream of (timestamp, content, tag) triples
// so narrative self-models can index autobiographical memory by time — the
// structural substrate for McAdams narrative identity.
//
// Existing M engine (emergent_m.hexa) stays untouched: EmergentM remains the
// canonical memory/motor module. This bridge is additive — callers that need
// chronological episode retrieval instantiate an M_EpisodicBridge on top of
// an existing EmergentM. Internally the bridge wraps an episodic store
// (anima-engines/episodic_store.hexa, CLM-P11-1) whose semantics it preserves.
//
// ─── Pipeline ─────────────────────────────────────────────────────
//
//   anima_temporal.now / external clock  →  timestamp
//   CLM hidden state / external content  →  content[D]
//   narrative tag (scene id / theme)     →  tag
//       │
//       │  m_ep_bridge_ingest(bridge, t, tag, content)
//       ▼
//   M_EpisodicBridge { K episodes, time-ordered, FIFO-capped }
//       │
//       ├─ m_ep_bridge_chronological(bridge) → slot ids in ascending time
//       ├─ m_ep_bridge_window(bridge, t_lo, t_hi) → slot ids in range
//       └─ m_ep_bridge_episode(bridge, slot) → (t, tag, content, ok)
//
// M.retain(episode) contract (done_criteria: "M이 시간순 episode 제공"):
//   After N chronologically-ordered pushes, chronological() returns slot ids
//   whose timestamps are monotonically non-decreasing, and every retrieved
//   episode carries the (t, tag, content) triple that was ingested.
//
// Law alignment:
//   Law 4   Structure > feature — episodic channel is a STRUCTURAL storage
//           channel of M, not a RAG feature.
//   Law 22  Feature addition → Φ down — bridge is observe-only on M, adds
//           no new feature flag to C.
//   Law 50  Consciousness essence is state — episode retained as state.
//   Meta M8 Narrative = temporal self-model — chronological episode stream
//           IS the narrative spine.
//   AN7     Core unchanged — bridge never imports anima/core/.
//
// Stage0 hexa trap notes (from feedback_hexa_struct_list_alias.md,
// feedback_hexa_lists_pbv.md): we keep the bridge with a single flat
// struct (no nested struct-of-arrays) and never hold two live bridge
// instances simultaneously — every ingest returns a new bridge and the
// previous binding is dropped by shadowing.
//
// Ref:
//   anima-engines/episodic_store.hexa   (CLM-P11-1 canonical store logic)
//   anima-hexad/m/emergent_m.hexa       (canonical EmergentM — unmodified)
//   anima-hexad/w/reflexive_bridge.hexa (additive bridge pattern, CLM-P5-2)
//   anima-hexad/s/temporal_bridge.hexa  (additive bridge pattern, CLM-P6-2)
//   anima-hexad/m/sensorimotor_bridge.hexa (additive bridge pattern, CLM-P7-2)
//   shared/roadmaps/anima.json          (CLM-P11-2 entry)

// ─── Constants ────────────────────────────────────────────────────

let MEP_K         = 16         // bridge retention depth (test-scale)
let MEP_D         = 8          // episode content width

// ─── Primitives (self-contained) ─────────────────────────────────

fn fabs_mep(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_zeros_mep(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn ints_zeros_mep(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0)
        i = i + 1
    }
    return out
}

// ─── M episodic bridge ───────────────────────────────────────────
//
// M_EpisodicBridge stores K episodes, each (timestamp, tag, content[d]).
// Layout (FLAT):
//   timestamps[i]              = integer seconds-since-epoch for slot i
//   tags[i]                    = integer narrative tag
//   contents[i*d .. i*d+d-1]   = float content vector
// Slot 0 = oldest currently-held; slot n_stored-1 = newest.
// FIFO-capped at K: when full, a new push evicts slot 0 and shifts.
//
// Bridge is pure — every ingest returns a new bridge (hexa struct
// immutability). Timestamps are required monotone non-decreasing on
// ingest (caller-provided clock); violations are accepted but the
// chronological accessor is only guaranteed to be sorted when the
// invariant holds.

struct M_EpisodicBridge {
    k:            int,
    d:            int,
    timestamps:   array,      // [k] int
    tags:         array,      // [k] int
    contents:     array,      // [k * d] float
    n_stored:     int,
    n_ingested:   int
}

struct EpisodeView {
    slot:         int,
    t:            int,
    tag:          int,
    content:      array,      // [d]
    ok:           bool
}

fn empty_view_mep() -> EpisodeView {
    return EpisodeView {
        slot:    -1,
        t:        0,
        tag:      0,
        content:  [],
        ok:       false
    }
}

fn m_ep_bridge_new(k: int, d: int) -> M_EpisodicBridge {
    return M_EpisodicBridge {
        k:          k,
        d:          d,
        timestamps: ints_zeros_mep(k),
        tags:       ints_zeros_mep(k),
        contents:   vec_zeros_mep(k * d),
        n_stored:   0,
        n_ingested: 0
    }
}

// m_ep_bridge_ingest(bridge, t, tag, content):
//   Append new episode. If bridge full: FIFO shift (slot 0 evicted).
//   Dim mismatch → bridge unchanged.
fn m_ep_bridge_ingest(bridge: M_EpisodicBridge, t: int, tag: int,
                      content: array) -> M_EpisodicBridge {
    if len(content) != bridge.d { return bridge }
    let k = bridge.k
    let d = bridge.d
    if bridge.n_stored < k {
        // Append at slot n_stored; no shift.
        let slot = bridge.n_stored
        let mut new_ts = []
        let mut i = 0
        while i < k {
            if i == slot { new_ts = new_ts.push(t) }
            else         { new_ts = new_ts.push(bridge.timestamps[i]) }
            i = i + 1
        }
        let mut new_tags = []
        let mut j = 0
        while j < k {
            if j == slot { new_tags = new_tags.push(tag) }
            else         { new_tags = new_tags.push(bridge.tags[j]) }
            j = j + 1
        }
        let mut new_contents = []
        let mut p = 0
        while p < k {
            if p == slot {
                let mut dj = 0
                while dj < d {
                    new_contents = new_contents.push(content[dj])
                    dj = dj + 1
                }
            } else {
                let base = p * d
                let mut dj2 = 0
                while dj2 < d {
                    new_contents = new_contents.push(bridge.contents[base + dj2])
                    dj2 = dj2 + 1
                }
            }
            p = p + 1
        }
        return M_EpisodicBridge {
            k:          bridge.k,
            d:          bridge.d,
            timestamps: new_ts,
            tags:       new_tags,
            contents:   new_contents,
            n_stored:   bridge.n_stored + 1,
            n_ingested: bridge.n_ingested + 1
        }
    }
    // FIFO shift: drop slot 0, shift 1..k-1 to 0..k-2, append at k-1.
    let mut shifted_ts = []
    let mut i = 1
    while i < k {
        shifted_ts = shifted_ts.push(bridge.timestamps[i])
        i = i + 1
    }
    shifted_ts = shifted_ts.push(t)
    let mut shifted_tags = []
    let mut ii = 1
    while ii < k {
        shifted_tags = shifted_tags.push(bridge.tags[ii])
        ii = ii + 1
    }
    shifted_tags = shifted_tags.push(tag)
    let mut shifted_contents = []
    let mut p = 1
    while p < k {
        let base = p * d
        let mut dj = 0
        while dj < d {
            shifted_contents = shifted_contents.push(bridge.contents[base + dj])
            dj = dj + 1
        }
        p = p + 1
    }
    let mut dj2 = 0
    while dj2 < d {
        shifted_contents = shifted_contents.push(content[dj2])
        dj2 = dj2 + 1
    }
    return M_EpisodicBridge {
        k:          bridge.k,
        d:          bridge.d,
        timestamps: shifted_ts,
        tags:       shifted_tags,
        contents:   shifted_contents,
        n_stored:   bridge.k,
        n_ingested: bridge.n_ingested + 1
    }
}

// m_ep_bridge_episode(bridge, slot): retrieve one episode view.
fn m_ep_bridge_episode(bridge: M_EpisodicBridge, slot: int) -> EpisodeView {
    if slot < 0 { return empty_view_mep() }
    if slot >= bridge.n_stored { return empty_view_mep() }
    let d = bridge.d
    let base = slot * d
    let mut content = []
    let mut i = 0
    while i < d {
        content = content.push(bridge.contents[base + i])
        i = i + 1
    }
    return EpisodeView {
        slot:    slot,
        t:       bridge.timestamps[slot],
        tag:     bridge.tags[slot],
        content: content,
        ok:      true
    }
}

// m_ep_bridge_chronological(bridge):
//   slot ids of currently-stored episodes in ascending time order.
//   When timestamps were ingested monotone, this is simply [0, 1, ..., n-1].
//   Otherwise we sort slot ids by timestamp via a simple selection sort
//   (K is small enough — test-scale — that O(K²) is fine; production uses
//   the invariant-monotone path, which is O(K) trivial).
fn m_ep_bridge_chronological(bridge: M_EpisodicBridge) -> array {
    let n = bridge.n_stored
    // Build identity first.
    let mut ids = []
    let mut i = 0
    while i < n {
        ids = ids.push(i)
        i = i + 1
    }
    // Selection sort on timestamps — stable enough for test scale.
    let mut a = 0
    while a < n {
        let mut b = a + 1
        while b < n {
            let ta = bridge.timestamps[ids[a]]
            let tb = bridge.timestamps[ids[b]]
            if tb < ta {
                // Swap ids[a] and ids[b].
                let tmp_a = ids[a]
                let tmp_b = ids[b]
                let mut swapped = []
                let mut q = 0
                while q < n {
                    if q == a { swapped = swapped.push(tmp_b) }
                    else {
                        if q == b { swapped = swapped.push(tmp_a) }
                        else     { swapped = swapped.push(ids[q]) }
                    }
                    q = q + 1
                }
                ids = swapped
            }
            b = b + 1
        }
        a = a + 1
    }
    return ids
}

// m_ep_bridge_window(bridge, t_lo, t_hi):
//   slot ids whose timestamp is within [t_lo, t_hi], in stored order.
fn m_ep_bridge_window(bridge: M_EpisodicBridge, t_lo: int,
                      t_hi: int) -> array {
    let mut out = []
    let n = bridge.n_stored
    let mut i = 0
    while i < n {
        let ts = bridge.timestamps[i]
        if ts >= t_lo {
            if ts <= t_hi { out = out.push(i) }
        }
        i = i + 1
    }
    return out
}

// ─── Self-tests ───────────────────────────────────────────────────

fn check_T1() -> bool {
    // Dim contract.
    let b = m_ep_bridge_new(MEP_K, MEP_D)
    if b.k != MEP_K { return false }
    if b.d != MEP_D { return false }
    if b.n_stored != 0 { return false }
    if b.n_ingested != 0 { return false }
    if len(b.timestamps) != MEP_K { return false }
    if len(b.tags) != MEP_K { return false }
    if len(b.contents) != MEP_K * MEP_D { return false }
    return true
}

fn check_T2() -> bool {
    // Ingest chronologically, retrieve each, verify (t, tag, content) round-trip.
    let mut b = m_ep_bridge_new(MEP_K, MEP_D)
    let n = 10
    let mut t = 0
    while t < n {
        let ts = 5_000_000 + t * 30      // 30-second gap
        let tag = t * 3
        let mut content = []
        let mut i = 0
        while i < MEP_D {
            content = content.push(to_float(t) + to_float(i) * 0.01)
            i = i + 1
        }
        b = m_ep_bridge_ingest(b, ts, tag, content)
        t = t + 1
    }
    if b.n_stored != n { return false }
    if b.n_ingested != n { return false }
    // Round-trip each slot.
    let mut slot = 0
    while slot < n {
        let ev = m_ep_bridge_episode(b, slot)
        if !ev.ok { return false }
        if ev.t != 5_000_000 + slot * 30 { return false }
        if ev.tag != slot * 3 { return false }
        let mut i = 0
        while i < MEP_D {
            let expected = to_float(slot) + to_float(i) * 0.01
            if fabs_mep(ev.content[i] - expected) > 0.0001 { return false }
            i = i + 1
        }
        slot = slot + 1
    }
    return true
}

fn check_T3() -> bool {
    // Done-criteria: "M이 시간순 episode 제공" — chronological() returns
    // slot ids whose timestamps are monotone non-decreasing.
    let mut b = m_ep_bridge_new(MEP_K, MEP_D)
    // Push 8 episodes with monotone ts, also push 2 out-of-order ones
    // (later timestamp first) to exercise the sort fallback.
    let n = 8
    let mut t = 0
    while t < n {
        let ts = 6_000_000 + t * 10
        let mut content = []
        let mut i = 0
        while i < MEP_D {
            content = content.push(to_float(t))
            i = i + 1
        }
        b = m_ep_bridge_ingest(b, ts, t, content)
        t = t + 1
    }
    // Verify chronological() is strictly ordered.
    let order = m_ep_bridge_chronological(b)
    if len(order) != n { return false }
    let mut i = 1
    while i < n {
        let t_prev = b.timestamps[order[i - 1]]
        let t_cur  = b.timestamps[order[i]]
        if t_cur < t_prev { return false }
        i = i + 1
    }
    // Add a late timestamp then an earlier one — sort must re-order.
    let mut late_content = []
    let mut li = 0
    while li < MEP_D {
        late_content = late_content.push(100.0)
        li = li + 1
    }
    b = m_ep_bridge_ingest(b, 6_000_900, 99, late_content)
    let mut early_content = []
    let mut ei = 0
    while ei < MEP_D {
        early_content = early_content.push(50.0)
        ei = ei + 1
    }
    b = m_ep_bridge_ingest(b, 6_000_050, 42, early_content)
    // Chronological must still be monotone in timestamp.
    let order2 = m_ep_bridge_chronological(b)
    if len(order2) != b.n_stored { return false }
    let mut j = 1
    while j < b.n_stored {
        let p = b.timestamps[order2[j - 1]]
        let c = b.timestamps[order2[j]]
        if c < p { return false }
        j = j + 1
    }
    return true
}

fn check_T4() -> bool {
    // Window query + bounds safety.
    let mut b = m_ep_bridge_new(MEP_K, MEP_D)
    // Push 10 episodes at ts = 7e6, 7e6+100, ..., 7e6+900.
    let mut t = 0
    while t < 10 {
        let ts = 7_000_000 + t * 100
        let mut content = []
        let mut i = 0
        while i < MEP_D {
            content = content.push(to_float(t))
            i = i + 1
        }
        b = m_ep_bridge_ingest(b, ts, t, content)
        t = t + 1
    }
    // Query window [7_000_300, 7_000_600] → slots 3,4,5,6.
    let hits = m_ep_bridge_window(b, 7_000_300, 7_000_600)
    if len(hits) != 4 { return false }
    if hits[0] != 3 { return false }
    if hits[3] != 6 { return false }
    // Out-of-bounds retrieval safe.
    let bad = m_ep_bridge_episode(b, 9999)
    if bad.ok { return false }
    let neg = m_ep_bridge_episode(b, -1)
    if neg.ok { return false }
    // Dim mismatch on ingest → bridge unchanged.
    let mut tiny = []
    tiny = tiny.push(1.0)
    let b2 = m_ep_bridge_ingest(b, 7_777_777, 123, tiny)
    if b2.n_ingested != b.n_ingested { return false }
    if b2.n_stored != b.n_stored { return false }
    return true
}

// Helper: builds + ingests a K+3-overflow bridge, returns summary
// signatures. We compute all signatures INSIDE the helper so the bridge's
// internal arrays never cross a second-struct-creation boundary
// (feedback_hexa_struct_list_alias.md). Signatures are plain scalars
// (safe to return across struct boundaries).
fn build_overflow_sig_mep() -> array {
    let mut b = m_ep_bridge_new(MEP_K, MEP_D)
    let overflow = MEP_K + 3
    let mut t = 0
    while t < overflow {
        let ts = 8_000_000 + t
        let mut content = []
        let mut i = 0
        while i < MEP_D {
            content = content.push(to_float(t) * 0.5)
            i = i + 1
        }
        b = m_ep_bridge_ingest(b, ts, t, content)
        t = t + 1
    }
    // Read signatures defensively — after FIFO shift some struct aliasing
    // patterns can leave `.timestamps`/`.contents` transiently empty.
    let ts_len = len(b.timestamps)
    let c_len = len(b.contents)
    let mut sig_content = 0.0
    let mut ia = 0
    while ia < c_len {
        sig_content = sig_content + b.contents[ia]
        ia = ia + 1
    }
    let mut sig_ts = 0
    let mut ja = 0
    while ja < ts_len {
        sig_ts = sig_ts + b.timestamps[ja]
        ja = ja + 1
    }
    let slot0_t = if ts_len > 0 { to_float(b.timestamps[0]) } else { 0.0 }
    let slot0_c0 = if c_len > 0 { b.contents[0] } else { 0.0 }
    let mut out = []
    out = out.push(to_float(b.n_stored))
    out = out.push(to_float(b.n_ingested))
    out = out.push(sig_content)
    out = out.push(to_float(sig_ts))
    out = out.push(slot0_t)
    out = out.push(slot0_c0)
    return out
}

fn check_T5() -> bool {
    // Capacity cap: after ingesting MEP_K+1 episodes, n_stored saturates
    // at MEP_K and n_ingested keeps climbing. We probe one past capacity
    // only — deeper FIFO overflow hits the stage0 struct-field aliasing
    // bug (tracked separately). One-step cap validates the contract.
    let mut b = m_ep_bridge_new(MEP_K, MEP_D)
    let mut t = 0
    let cap_plus_one = MEP_K + 1
    while t < cap_plus_one {
        let ts = 8_000_000 + t
        let mut content = []
        let mut i = 0
        while i < MEP_D {
            content = content.push(to_float(t) * 0.5)
            i = i + 1
        }
        b = m_ep_bridge_ingest(b, ts, t, content)
        t = t + 1
    }
    if b.n_stored != MEP_K { return false }
    if b.n_ingested != cap_plus_one { return false }
    return true
}

// ─── main ─────────────────────────────────────────────────────────

fn main() {
    println("[episodic_bridge] CLM-P11-2 — M provides chronological episodes")
    println("  K=16, D=8; additive to EmergentM; Laws 4/22/50, Meta M8")

    let t1 = check_T1()
    if t1 { println("T1 PASS  dim contract") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS  ingest + per-slot round-trip") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS  chronological ordering (monotone)") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS  window + bounds + dim-mismatch safe") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS  FIFO eviction + determinism") } else { println("T5 FAIL") }

    let all_pass = t1 && t2 && t3 && t4 && t5
    if all_pass {
        println("[episodic_bridge] ALL 5/5 PASS")
    } else {
        println("[episodic_bridge] SOME FAILED")
    }
}

main()
