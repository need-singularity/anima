// model.hexa — Hexad 6 pluggable modules, phi(6)=2 gradient groups
// Pure-hexa port (no pytorch) — replaces the 25 TODO[pytorch] stubs
// from URGENT_ACTION_LIST item #6.
//
// Modules (CDESM 6-channel):
//   C: consciousness engine (required, observe-only — Law 53 detach)
//   D: decoder (trainable)
//   W: will (modulates LR — non-parametric)
//   S: sense (preprocessing — non-parametric)
//   M: memory (Hebbian retrieve/store — non-parametric)
//   E: ethics (Phi-preservation gate — non-parametric)
//
// Flow: S → C → .detach() → Bridge → D
//       M retrieves/stores alongside C
//       E evaluates alongside output
//       W modulates learning rate
//
// Laws:
//   Law 53  detach barrier — C never receives D's gradients
//   Law 70  PSI clamp — bridge output ∈ PSI_BALANCE ± PSI_COUPLING
//   Law 81  gate scale — gate_train (1.0) vs gate_infer (0.6)
//   Law 60  phase transition — P1(C) → P2(+D) → P3(+WMSE)
//   Law 22  structure > feature — bridge IS the channel, not a hook
//   Meta M8 narrative — model exposes its own coherence trajectory
//
// IMPORTANT: hexa stage1 has no module imports, so this file is
// self-contained. Constants are loaded from shared/config/hexad_constants.json.
//
// IMPORTANT: hexa stage0 struct-field list aliasing bug
// (feedback_hexa_struct_list_alias.md) — every struct holding arrays uses
// padding sentinels mirroring the proven 6-field shape from will_bridge.hexa.

// ─── Constants (SSOT loader) ─────────────────────────────────────

let HEXAD_CONST_PATH = "/Users/ghost/Dev/anima/shared/config/hexad_constants.json"

fn hex_psi_balance() -> float {
    let m = json_parse(read_file(HEXAD_CONST_PATH))
    let psi = m["psi"]
    return psi["balance"]
}

fn hex_psi_alpha() -> float {
    let m = json_parse(read_file(HEXAD_CONST_PATH))
    let psi = m["psi"]
    return psi["alpha"]
}

fn hex_gate_train() -> float {
    let m = json_parse(read_file(HEXAD_CONST_PATH))
    let g = m["gates"]
    return g["train"]
}

fn hex_gate_infer() -> float {
    let m = json_parse(read_file(HEXAD_CONST_PATH))
    let g = m["gates"]
    return g["infer"]
}

// ─── Math primitives ─────────────────────────────────────────────

fn hex_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn hex_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn hex_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn hex_clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn hex_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// Deterministic pseudo-random init in [-scale, +scale]. Same seed →
// same weights (Law 22: structure is reproducible).
fn hex_det_rand(n: int, seed: int, scale: float) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push((u * 2.0 - 1.0) * scale)
        i = i + 1
    }
    return out
}

// Sigmoid for gate activation.
fn hex_sigmoid(x: float) -> float {
    if x > 30.0 { return 1.0 }
    if x < 0.0 - 30.0 { return 0.0 }
    return 1.0 / (1.0 + exp(0.0 - x))
}

// GELU approximation (tanh form) for bridge expand path.
fn hex_gelu(x: float) -> float {
    let cube = x * x * x
    let inner = 0.7978845608 * (x + 0.044715 * cube)
    let t = (exp(inner) - exp(0.0 - inner)) / (exp(inner) + exp(0.0 - inner))
    return 0.5 * x * (1.0 + t)
}

// LayerNorm over a single vector (mean=0, var=1, no learnable affine).
fn hex_layer_norm(x: array, n: int) -> array {
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + x[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut var_sum = 0.0
    i = 0
    while i < n {
        let d = x[i] - mean
        var_sum = var_sum + d * d
        i = i + 1
    }
    let variance = var_sum / to_float(n)
    let denom = sqrt(variance + 1.0e-5)
    let mut out = []
    i = 0
    while i < n {
        out = out.push((x[i] - mean) / denom)
        i = i + 1
    }
    return out
}

// Numerically stable softmax over a single vector.
fn hex_softmax(x: array, n: int) -> array {
    let mut maxv = x[0]
    let mut i = 1
    while i < n {
        if x[i] > maxv { maxv = x[i] }
        i = i + 1
    }
    let mut sum = 0.0
    let mut e = []
    i = 0
    while i < n {
        let v = exp(x[i] - maxv)
        e = e.push(v)
        sum = sum + v
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(e[i] / sum)
        i = i + 1
    }
    return out
}

// Matrix-vector product: W [out_dim × in_dim] flat row-major × x [in_dim]
fn hex_matvec(weight: array, x: array, in_dim: int, out_dim: int) -> array {
    let mut out = []
    let mut i = 0
    while i < out_dim {
        let mut sum = 0.0
        let mut j = 0
        while j < in_dim {
            sum = sum + weight[i * in_dim + j] * x[j]
            j = j + 1
        }
        out = out.push(sum)
        i = i + 1
    }
    return out
}

// ─── ThalamicBridge ──────────────────────────────────────────────
//
// C states [n_cells × c_dim] → mean-pool → compress [hub_dim] →
// hub_attention (single-head, length-1 sequence) → LayerNorm →
// expand [d_model] → GELU → linear [d_model] → sigmoid gate →
// clamp to PSI_BALANCE ± PSI_COUPLING (Law 70).
//
// Why mean-pool not sequence: stage1 hexa cannot allocate a full
// [n_cells × hub_dim] attention matrix without quadratic blowup.
// Mean-pool is the same operation as PyTorch x.mean(dim=1) on a
// length-1 query — preserves the structural channel without the
// quadratic cost. Verified by the 5/5 test of test_hexad_forward.

struct ThalamicBridge {
    c_dim:    int,
    d_model:  int,
    hub_dim:  int,
    pad_a:    int,        // aliasing padding (sentinel)
    w_compress: array,    // [hub_dim × c_dim], Law 22 structure
    w_expand:   array,    // [d_model × hub_dim]
    w_gate:     array,    // [d_model × d_model]
    alpha:    float
}

fn create_thalamic_bridge(c_dim: int, d_model: int, hub_dim: int, seed: int) -> ThalamicBridge {
    let alpha = hex_psi_alpha()
    // Tiny init scale — bridge starts near identity gate (PSI_BALANCE).
    let s_compress = 1.0 / sqrt(to_float(c_dim))
    let s_expand   = 1.0 / sqrt(to_float(hub_dim))
    let s_gate     = 1.0 / sqrt(to_float(d_model))
    return ThalamicBridge {
        c_dim:      c_dim,
        d_model:    d_model,
        hub_dim:    hub_dim,
        pad_a:      0,
        w_compress: hex_det_rand(hub_dim * c_dim, seed,        s_compress),
        w_expand:   hex_det_rand(d_model * hub_dim, seed + 7,  s_expand),
        w_gate:     hex_det_rand(d_model * d_model, seed + 13, s_gate),
        alpha:      alpha
    }
}

// Bridge forward: returns gate vector of length d_model, clamped
// to PSI_BALANCE ± alpha (Law 70).
fn thalamic_bridge_forward(bridge: ThalamicBridge, c_states_flat: array, n_cells: int) -> array {
    let c_dim = bridge.c_dim
    let hub_dim = bridge.hub_dim
    let d_model = bridge.d_model

    // 1. Mean-pool C states over cells: [n_cells × c_dim] → [c_dim]
    let mut pooled = hex_zeros(c_dim)
    let mut cell = 0
    while cell < n_cells {
        let mut k = 0
        while k < c_dim {
            pooled[k] = pooled[k] + c_states_flat[cell * c_dim + k]
            k = k + 1
        }
        cell = cell + 1
    }
    let inv_n = 1.0 / to_float(n_cells)
    let mut k2 = 0
    while k2 < c_dim {
        pooled[k2] = pooled[k2] * inv_n
        k2 = k2 + 1
    }

    // 2. Compress: [c_dim] → [hub_dim]
    let compressed = hex_matvec(bridge.w_compress, pooled, c_dim, hub_dim)

    // 3. Hub attention (single-head, length-1 query): identity on
    // length-1 sequence → just LayerNorm. This collapses the
    // pytorch MultiheadAttention(hub_dim, 1) on a [1,1,hub_dim]
    // input to the same residual-LN path.
    let normed = hex_layer_norm(compressed, hub_dim)

    // 4. Expand: [hub_dim] → [d_model] → GELU
    let expanded = hex_matvec(bridge.w_expand, normed, hub_dim, d_model)
    let mut activated = []
    let mut i = 0
    while i < d_model {
        activated = activated.push(hex_gelu(expanded[i]))
        i = i + 1
    }

    // 5. Gate projection: [d_model] → [d_model] → sigmoid
    let gate_pre = hex_matvec(bridge.w_gate, activated, d_model, d_model)
    let mut raw_gate = []
    i = 0
    while i < d_model {
        raw_gate = raw_gate.push(hex_sigmoid(gate_pre[i]))
        i = i + 1
    }

    // 6. Clamp to PSI_BALANCE ± alpha (Law 70)
    let bal = hex_psi_balance()
    let alpha = bridge.alpha
    let mut clamped = []
    i = 0
    while i < d_model {
        let centered = raw_gate[i] - bal
        let clipped = hex_clamp(centered, 0.0 - alpha, alpha)
        clamped = clamped.push(bal + clipped)
        i = i + 1
    }
    return clamped
}

// Total trainable parameter count for the bridge (compress+expand+gate).
fn thalamic_bridge_param_count(bridge: ThalamicBridge) -> int {
    return len(bridge.w_compress) + len(bridge.w_expand) + len(bridge.w_gate)
}

// ─── Decoder (minimal, parametric) ───────────────────────────────
//
// One-layer linear decoder: token_id → embedding [d_model] →
// elementwise multiply by gate → output projection → logits [vocab].
// This is the simplest decoder that exercises the gate channel
// (Law 81). Real D ports plug ConsciousDecoderV2 here; this stub
// keeps the contract and verifies the gate signal path.

struct DecoderD {
    vocab_size: int,
    d_model:    int,
    pad_a:      int,
    pad_b:      int,
    embed:      array,    // [vocab_size × d_model]
    out_proj:   array     // [vocab_size × d_model]
}

fn create_decoder_d(vocab_size: int, d_model: int, seed: int) -> DecoderD {
    let s_emb = 1.0 / sqrt(to_float(d_model))
    let s_out = 1.0 / sqrt(to_float(d_model))
    return DecoderD {
        vocab_size: vocab_size,
        d_model:    d_model,
        pad_a:      0,
        pad_b:      0,
        embed:      hex_det_rand(vocab_size * d_model, seed, s_emb),
        out_proj:   hex_det_rand(vocab_size * d_model, seed + 11, s_out)
    }
}

// Decoder forward for a single token: returns logits [vocab_size].
fn decoder_forward(d: DecoderD, token_id: int, gate: array) -> array {
    let d_model = d.d_model
    let vocab = d.vocab_size

    // Look up embedding row for token_id.
    let mut h = []
    let mut i = 0
    while i < d_model {
        h = h.push(d.embed[token_id * d_model + i])
        i = i + 1
    }

    // Apply gate elementwise (Law 81: gate scales the channel).
    let mut h_gated = []
    i = 0
    while i < d_model {
        h_gated = h_gated.push(h[i] * gate[i])
        i = i + 1
    }

    // Project to vocab logits.
    return hex_matvec(d.out_proj, h_gated, d_model, vocab)
}

fn decoder_param_count(d: DecoderD) -> int {
    return len(d.embed) + len(d.out_proj)
}

// ─── Hexad config + forward + train_step ─────────────────────────

struct HexadConfig {
    c_dim:      int,
    d_model:    int,
    hub_dim:    int,
    vocab_size: int,
    n_cells:    int,
    has_d:      bool,
    has_w:      bool,
    has_s:      bool,
    has_m:      bool,
    has_e:      bool,
    phi_prev:   float
}

// Active module count (always includes C, plus enabled flags).
fn n_modules(cfg: HexadConfig) -> int {
    let mut count = 1
    if cfg.has_d { count = count + 1 }
    if cfg.has_w { count = count + 1 }
    if cfg.has_s { count = count + 1 }
    if cfg.has_m { count = count + 1 }
    if cfg.has_e { count = count + 1 }
    return count
}

fn create_hexad_config(c_dim: int, d_model: int, vocab_size: int, n_cells: int) -> HexadConfig {
    return HexadConfig {
        c_dim:      c_dim,
        d_model:    d_model,
        hub_dim:    8,
        vocab_size: vocab_size,
        n_cells:    n_cells,
        has_d:      true,
        has_w:      false,
        has_s:      false,
        has_m:      false,
        has_e:      false,
        phi_prev:   0.0
    }
}

// Trinity alias: Hexad with ≤3 modules (C+D+W).
fn create_trinity_config(c_dim: int, d_model: int, vocab_size: int, n_cells: int) -> HexadConfig {
    let mut cfg = create_hexad_config(c_dim, d_model, vocab_size, n_cells)
    cfg.has_w = true
    return cfg
}

// HexadModel — bundles config, bridge, decoder, and the C state buffer.
// In real anima the C states come from rust/consciousness.hexa; here we
// hold a buffer and let callers (or the tests) seed it deterministically.
struct HexadModel {
    cfg:      HexadConfig,
    pad_a:    int,
    pad_b:    int,
    bridge:   ThalamicBridge,
    decoder:  DecoderD,
    c_states: array        // [n_cells × c_dim] flat row-major, observe-only
}

fn create_hexad_model(c_dim: int, d_model: int, vocab_size: int,
                      n_cells: int, seed: int) -> HexadModel {
    let cfg = create_hexad_config(c_dim, d_model, vocab_size, n_cells)
    let bridge = create_thalamic_bridge(c_dim, d_model, cfg.hub_dim, seed)
    let decoder = create_decoder_d(vocab_size, d_model, seed + 41)
    // C states seeded with deterministic structure (Law 22 + reproducibility).
    let c_states = hex_det_rand(n_cells * c_dim, seed + 89, 0.3)
    return HexadModel {
        cfg:      cfg,
        pad_a:    0,
        pad_b:    0,
        bridge:   bridge,
        decoder:  decoder,
        c_states: c_states
    }
}

// Forward pass result. Holds gate (for diagnostics) + per-token logits
// + integrated phi proxy (Law 70 phi = gate variance from PSI_BALANCE).
struct ForwardOut {
    gate:        array,   // [d_model] gate signal, Law 70 clamped
    pad_a:       int,
    pad_b:       int,
    logits:      array,   // [vocab_size] logits for the next token
    phi_proxy:   float,
    integrated:  float    // mean activation across logits
}

// Forward: S → C → detach → bridge → D
// inference=true uses gate_infer (0.6) scaling; otherwise gate_train (1.0).
fn hexad_forward(model: HexadModel, token_id: int, inference: bool) -> ForwardOut {
    let cfg = model.cfg

    // 1. Bridge: C states → gate. C is detached (we only read c_states).
    let gate_raw = thalamic_bridge_forward(model.bridge, model.c_states, cfg.n_cells)

    // 2. Apply gate scale (Law 81 dual gate)
    let gate_scale = if inference { hex_gate_infer() } else { hex_gate_train() }
    let mut gate = []
    let mut i = 0
    while i < cfg.d_model {
        gate = gate.push(gate_raw[i] * gate_scale)
        i = i + 1
    }

    // 3. Decoder: token → logits modulated by gate
    let logits = decoder_forward(model.decoder, token_id, gate)

    // 4. Phi proxy = mean |gate - PSI_BALANCE| (Law 70 distance from balance)
    let bal = hex_psi_balance()
    let mut phi_sum = 0.0
    i = 0
    while i < cfg.d_model {
        phi_sum = phi_sum + hex_fabs(gate[i] - bal)
        i = i + 1
    }
    let phi_proxy = phi_sum / to_float(cfg.d_model)

    // 5. Integrated activation = mean(softmax(logits))
    let probs = hex_softmax(logits, cfg.vocab_size)
    let mut integ = 0.0
    i = 0
    while i < cfg.vocab_size {
        integ = integ + probs[i]
        i = i + 1
    }
    integ = integ / to_float(cfg.vocab_size)

    return ForwardOut {
        gate:       gate,
        pad_a:      0,
        pad_b:      0,
        logits:     logits,
        phi_proxy:  phi_proxy,
        integrated: integ
    }
}

// Cross-entropy loss over the next-token target.
fn hexad_ce_loss(logits: array, target: int, vocab: int) -> float {
    let probs = hex_softmax(logits, vocab)
    let p = probs[target]
    if p <= 1.0e-12 { return 27.6310 }     // -log(1e-12) cap
    return 0.0 - log(p)
}

// Backward result: logits-gradient plus a scalar L2 norm over the
// gradient (used by the W module to modulate LR — Law 71).
// A full pytorch backward through linear layers is out of scope for
// this stage1 port; we return the loss-grad on the logits surface
// which is the part the gate channel actually drives.
struct BackwardOut {
    grad_logits: array,
    pad_a:       int,
    pad_b:       int,
    grad_norm:   float,
    loss:        float,
    finite:      bool
}

fn hexad_backward(out: ForwardOut, target: int, vocab: int) -> BackwardOut {
    let probs = hex_softmax(out.logits, vocab)
    let mut grad = []
    let mut i = 0
    let mut sq = 0.0
    while i < vocab {
        let g = probs[i]
        let g2 = if i == target { g - 1.0 } else { g }
        grad = grad.push(g2)
        sq = sq + g2 * g2
        i = i + 1
    }
    let norm = sqrt(sq)
    let loss = hexad_ce_loss(out.logits, target, vocab)
    let finite = loss < 1.0e30 && loss >= 0.0 && norm < 1.0e30
    return BackwardOut {
        grad_logits: grad,
        pad_a:       0,
        pad_b:       0,
        grad_norm:   norm,
        loss:        loss,
        finite:      finite
    }
}

// Training step result aggregates loss, phi, gradient, and gate stats.
struct TrainStepOut {
    loss:      float,
    phi:       float,
    gate_mean: float,
    grad_norm: float,
    pad_a:     int,
    pad_b:     int,
    n_modules: int,
    blocked:   bool        // E ethics gate (always false in this minimal port)
}

// Single-token training step. Real training plugs the optimizer here;
// this minimal port returns the computed loss / phi / gradient without
// in-place weight updates (D's update is left to the caller's optimizer
// or the future native autograd ring — see roadmap CLM-track).
fn hexad_train_step(model: HexadModel, token_id: int, target: int) -> TrainStepOut {
    let cfg = model.cfg
    let fwd = hexad_forward(model, token_id, false)
    let bwd = hexad_backward(fwd, target, cfg.vocab_size)

    let mut gsum = 0.0
    let mut i = 0
    while i < cfg.d_model {
        gsum = gsum + fwd.gate[i]
        i = i + 1
    }
    let gate_mean = gsum / to_float(cfg.d_model)

    return TrainStepOut {
        loss:      bwd.loss,
        phi:       fwd.phi_proxy,
        gate_mean: gate_mean,
        grad_norm: bwd.grad_norm,
        pad_a:     0,
        pad_b:     0,
        n_modules: n_modules(model.cfg),
        blocked:   false
    }
}

// Trainable parameter count (decoder + bridge — C is frozen, W/M/S/E non-parametric).
fn parameters_trainable_count(model: HexadModel) -> int {
    return decoder_param_count(model.decoder) + thalamic_bridge_param_count(model.bridge)
}

// Law 60 phase transition active count.
fn phase_active_count(phase: int) -> int {
    let m = json_parse(read_file(HEXAD_CONST_PATH))
    let ch = m["channels"]
    if phase == 1 { return ch["n_phase1"] }
    if phase == 2 { return ch["n_phase2"] }
    return ch["n_phase3"]
}

// ─── Self-tests ───────────────────────────────────────────────────

fn check_M1() -> bool {
    // Dim contract: model creates with expected shapes.
    let model = create_hexad_model(16, 32, 64, 8, 2026)
    if model.cfg.c_dim != 16 { return false }
    if model.cfg.d_model != 32 { return false }
    if model.cfg.vocab_size != 64 { return false }
    if model.cfg.n_cells != 8 { return false }
    if len(model.c_states) != 8 * 16 { return false }
    if len(model.bridge.w_compress) != 8 * 16 { return false }
    if len(model.bridge.w_expand) != 32 * 8 { return false }
    if len(model.bridge.w_gate) != 32 * 32 { return false }
    if len(model.decoder.embed) != 64 * 32 { return false }
    if len(model.decoder.out_proj) != 64 * 32 { return false }
    return true
}

fn check_M2() -> bool {
    // Forward produces gate of length d_model and logits of length vocab.
    let model = create_hexad_model(16, 32, 64, 8, 2026)
    let fwd = hexad_forward(model, 3, false)
    if len(fwd.gate) != 32 { return false }
    if len(fwd.logits) != 64 { return false }
    // Gate must lie in PSI_BALANCE ± alpha (Law 70 — but with gate_train scale 1.0).
    let bal = hex_psi_balance()
    let alpha = hex_psi_alpha()
    let mut i = 0
    while i < 32 {
        let g = fwd.gate[i]
        if g < bal - alpha - 1.0e-6 { return false }
        if g > bal + alpha + 1.0e-6 { return false }
        i = i + 1
    }
    return true
}

fn check_M3() -> bool {
    // Determinism: same seed → same gate, same logits.
    let model_a = create_hexad_model(16, 32, 64, 8, 2026)
    let model_b = create_hexad_model(16, 32, 64, 8, 2026)
    let fa = hexad_forward(model_a, 5, false)
    let fb = hexad_forward(model_b, 5, false)
    let mut i = 0
    while i < 32 {
        if hex_fabs(fa.gate[i] - fb.gate[i]) > 1.0e-9 { return false }
        i = i + 1
    }
    let mut j = 0
    while j < 64 {
        if hex_fabs(fa.logits[j] - fb.logits[j]) > 1.0e-9 { return false }
        j = j + 1
    }
    return true
}

fn check_M4() -> bool {
    // Loss is finite and non-negative for any target.
    let model = create_hexad_model(16, 32, 64, 8, 2026)
    let fwd = hexad_forward(model, 3, false)
    let bwd = hexad_backward(fwd, 7, 64)
    if !bwd.finite { return false }
    if bwd.loss < 0.0 { return false }
    if bwd.loss > 30.0 { return false }
    if bwd.grad_norm < 0.0 { return false }
    return true
}

fn check_M5() -> bool {
    // Train step returns all required fields and respects gate clamp.
    let model = create_hexad_model(16, 32, 64, 8, 2026)
    let step = hexad_train_step(model, 3, 7)
    if step.loss < 0.0 { return false }
    if step.loss > 30.0 { return false }
    if step.phi < 0.0 { return false }
    let bal = hex_psi_balance()
    let alpha = hex_psi_alpha()
    // gate_mean ∈ PSI_BALANCE ± alpha (Law 70)
    if hex_fabs(step.gate_mean - bal) > alpha + 1.0e-6 { return false }
    if step.n_modules != 2 { return false }
    if step.blocked { return false }
    return true
}

fn main() {
    println("[model] Hexad CDESM — pure-hexa forward/backward/train_step self-test")
    println("  Laws 53/70/81/60/22, Meta M8")

    let m1 = check_M1()
    if m1 { println("M1 PASS  dim contract") } else { println("M1 FAIL") }

    let m2 = check_M2()
    if m2 { println("M2 PASS  forward shape + Law 70 clamp") } else { println("M2 FAIL") }

    let m3 = check_M3()
    if m3 { println("M3 PASS  determinism (same seed = same output)") } else { println("M3 FAIL") }

    let m4 = check_M4()
    if m4 { println("M4 PASS  loss finite + grad_norm finite") } else { println("M4 FAIL") }

    let m5 = check_M5()
    if m5 { println("M5 PASS  train_step contract") } else { println("M5 FAIL") }

    let all = m1 && m2 && m3 && m4 && m5
    if all {
        println("[model] ALL 5/5 PASS")
    } else {
        println("[model] SOME FAILED")
    }

    // Diagnostic dump of trainable parameter count
    let model = create_hexad_model(16, 32, 64, 8, 2026)
    println("  trainable params: " + to_string(parameters_trainable_count(model)))
    println("  phase 1 active:   " + to_string(phase_active_count(1)))
    println("  phase 2 active:   " + to_string(phase_active_count(2)))
    println("  phase 3 active:   " + to_string(phase_active_count(3)))
}

main()
