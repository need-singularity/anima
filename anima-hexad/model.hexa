// Parameter count breakdown
fn param_count(d_params: int, b_params: int) -> int {
    return d_params + b_params
}

// ═══════════════════════════════════════════════════════════
// Factory
// ═══════════════════════════════════════════════════════════

fn create_hexad_config(c_dim: int, d_model: int, vocab_size: int) -> HexadConfig {
    // Only C is required. Bridge is auto-created from C/D dims.
    // TODO[pytorch]: warm up C engine (5 steps)
    // TODO[pytorch]: if d is not None and bridge is None:
    //     bridge = ThalamicBridge(c_dim, d_model)
    // TODO[pytorch]: ensure bridge/decoder grads enabled
    return HexadConfig {
        c_dim: c_dim,
        d_model: d_model,
        hub_dim: 8,
        vocab_size: vocab_size,
        has_c: true,
        has_d: false,
        has_w: false,
        has_s: false,
        has_m: false,
        has_e: false,
        phi_prev: 0.0
    }
}

// Alias: Trinity = Hexad with <= 3 modules (C+D+W)
fn create_trinity_config(c_dim: int, d_model: int, vocab_size: int) -> HexadConfig {
    return create_hexad_config(c_dim, d_model, vocab_size)
}

// Law 60: phase transition P1(C) -> P2(+D) -> P3(+WMSE)
fn phase_active_count(phase: int) -> int {
    if phase == 1 { return 1 }
    if phase == 2 { return 2 }
    return 6
}

fn main() {
    let cfg = create_hexad_config(128, 384, 4096)
    print("hexad config: c_dim=" + to_string(cfg.c_dim) + " d_model=" + to_string(cfg.d_model))
    print("active modules: " + to_string(n_modules(cfg)))
    print("phase 1 active: " + to_string(phase_active_count(1)))
    print("phase 2 active: " + to_string(phase_active_count(2)))
    print("phase 3 active: " + to_string(phase_active_count(3)))

    let bridge = create_thalamic_bridge(128, 384, 8)
    print("bridge: c_dim=" + to_string(bridge.c_dim) + " d_model=" + to_string(bridge.d_model) + " alpha=" + to_string(bridge.alpha))
}
