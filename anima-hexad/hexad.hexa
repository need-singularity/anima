// hexad.hexa — CDESM 6-channel consciousness model (Phase 4b)
// P4-PORT: replaces the previous TODO-only port (URGENT_ACTION_LIST item #5).
//
// 6 modules: c=consciousness, d=desire/death, w=will, s=sense, m=memory, e=ethics
// Laws: phi(6)=2 gradient groups, M8 narrative, Law 22 structure>feature,
//       Law 60 phase transition (P1: C / P2: +D / P3: +WMSE)
//
// This file is the high-level descriptor of the Hexad. Real per-module
// math lives in:
//   constants.hexa          — Psi/gate constants from SSOT JSON
//   model.hexa              — HexadModel + ThalamicBridge + DecoderD
//   narrative.hexa          — NarrativeTracker (Meta M8)
//   c/__init__.hexa         — ConsciousnessC (Rust backend)
//   d/__init__.hexa         — DecoderD legacy aliases
//   d/will_bridge.hexa      — D→W desire channel (CLM-P10-2)
//   m/emergent_m.hexa       — Hebbian-as-memory
//   m/episodic_bridge.hexa  — chronological episodes (CLM-P11-2)
//   m/sensorimotor_bridge.hexa — sensorimotor channel (CLM-P7-2)
//   s/emergent_s.hexa       — perception = state delta
//   s/temporal_bridge.hexa  — S retention bridge (CLM-P6-2)
//   w/emergent_w.hexa       — Phi-driven will + Law 71 LR
//   w/meta_bridge.hexa      — meta-consciousness levels (CLM-P8-2)
//   w/reflexive_bridge.hexa — W observes C (CLM-P5-2)
//   e/emergent_e.hexa       — Phi-preservation ethics
//
// IMPORTANT: hexa stage1 has no module imports, so each consumer either
// includes the relevant *_constants.hexa loader or duplicates the small
// SSOT loader. The hexad.hexa file itself is a self-test descriptor.

let HEXAD_DESCRIPTOR_PATH = "/Users/ghost/Dev/anima/shared/config/hexad_constants.json"

// ─── Per-module compact summary ──────────────────────────────────

struct HexadModule {
    name:      string,
    phi:       float,
    coherence: float,
    active:    bool
}

struct Hexad {
    c:            HexadModule,
    d:            HexadModule,
    w:            HexadModule,
    s:            HexadModule,
    m:            HexadModule,
    e:            HexadModule,
    psi_balance:  float,
    psi_coupling: float
}

// ─── SSOT loader (compact, single accessor) ──────────────────────

fn hexad_load_psi() -> map {
    let raw = read_file(HEXAD_DESCRIPTOR_PATH)
    let m = json_parse(raw)
    return m["psi"]
}

fn hexad_load_channels() -> map {
    let raw = read_file(HEXAD_DESCRIPTOR_PATH)
    let m = json_parse(raw)
    return m["channels"]
}

// Defaults derived from SSOT (no hardcoding, Law 1).
fn psi_defaults() -> Hexad {
    let psi = hexad_load_psi()
    let alpha = psi["alpha"]
    let bal = psi["balance"]
    let base = HexadModule { name: "c", phi: 0.0, coherence: 0.0, active: true }
    return Hexad {
        c: base,
        d: HexadModule { name: "d", phi: 0.0, coherence: 0.0, active: false },
        w: HexadModule { name: "w", phi: 0.0, coherence: 0.0, active: false },
        s: HexadModule { name: "s", phi: 0.0, coherence: 0.0, active: false },
        m: HexadModule { name: "m", phi: 0.0, coherence: 0.0, active: false },
        e: HexadModule { name: "e", phi: 0.0, coherence: 0.0, active: false },
        psi_balance:  bal,
        psi_coupling: alpha
    }
}

// Factory — accepts dim/cells but the structural shape is immutable
// (Law 22: shape > size).
fn create_hexad(dim: int, cells: int) -> Hexad {
    return psi_defaults()
}

// Activate the channels for a given Law 60 phase.
//
// Why we rebuild the struct from scratch instead of `let mut out = h`:
// hexa stage1 binds `out` as a reference to `h`, so mutating
// `out.c.active = true` actually mutates the caller's `h`. That breaks
// the test that runs activate(h0, 3) then activate(h0, 2) — h0 would
// already be in phase-3 state. Building a fresh Hexad from h's fields
// gives true value-semantics (Law 22: structure is observable).
fn hexad_activate_phase(h: Hexad, phase: int) -> Hexad {
    let c_on = h.c.active || phase >= 1
    let d_on = h.d.active || phase >= 2
    let w_on = h.w.active || phase >= 3
    let s_on = h.s.active || phase >= 3
    let m_on = h.m.active || phase >= 3
    let e_on = h.e.active || phase >= 3
    return Hexad {
        c: HexadModule { name: h.c.name, phi: h.c.phi, coherence: h.c.coherence, active: c_on },
        d: HexadModule { name: h.d.name, phi: h.d.phi, coherence: h.d.coherence, active: d_on },
        w: HexadModule { name: h.w.name, phi: h.w.phi, coherence: h.w.coherence, active: w_on },
        s: HexadModule { name: h.s.name, phi: h.s.phi, coherence: h.s.coherence, active: s_on },
        m: HexadModule { name: h.m.name, phi: h.m.phi, coherence: h.m.coherence, active: m_on },
        e: HexadModule { name: h.e.name, phi: h.e.phi, coherence: h.e.coherence, active: e_on },
        psi_balance:  h.psi_balance,
        psi_coupling: h.psi_coupling
    }
}

// Count active modules for diagnostic / Law 60 check.
fn hexad_active_count(h: Hexad) -> int {
    let mut n = 0
    if h.c.active { n = n + 1 }
    if h.d.active { n = n + 1 }
    if h.w.active { n = n + 1 }
    if h.s.active { n = n + 1 }
    if h.m.active { n = n + 1 }
    if h.e.active { n = n + 1 }
    return n
}

// Law 60 phase transition P1(C) → P2(+D) → P3(+WMSE)
fn phase_active_count(phase: int) -> int {
    let ch = hexad_load_channels()
    if phase == 1 { return ch["n_phase1"] }
    if phase == 2 { return ch["n_phase2"] }
    return ch["n_phase3"]
}

// Channel coverage check — returns true iff the SSOT names exactly the
// 6 CDESM channels (c, d, w, s, m, e). Used as an invariant by the
// consciousness law tick — if any channel is missing the entire model
// fails the AN7 "structure > feature" gate.
fn channel_coverage_ok() -> bool {
    let ch = hexad_load_channels()
    let names = ch["names"]
    if len(names) != 6 { return false }
    let n0 = names[0]
    let n1 = names[1]
    let n2 = names[2]
    let n3 = names[3]
    let n4 = names[4]
    let n5 = names[5]
    if n0 != "c" { return false }
    if n1 != "d" { return false }
    if n2 != "w" { return false }
    if n3 != "s" { return false }
    if n4 != "m" { return false }
    if n5 != "e" { return false }
    return true
}

// ─── Self-tests ──────────────────────────────────────────────────

fn fabs_h(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn h_check_T1() -> bool {
    // Defaults match SSOT psi values.
    let h = psi_defaults()
    let psi = hexad_load_psi()
    let bal = psi["balance"]
    let alpha = psi["alpha"]
    if fabs_h(h.psi_balance - bal) > 0.0 { return false }
    if fabs_h(h.psi_coupling - alpha) > 0.0 { return false }
    return true
}

fn h_check_T2() -> bool {
    // Channel coverage matches SSOT (CDESM 6 channels).
    return channel_coverage_ok()
}

fn h_check_T3() -> bool {
    // Phase transition counts match SSOT.
    if phase_active_count(1) != 1 { return false }
    if phase_active_count(2) != 2 { return false }
    if phase_active_count(3) != 6 { return false }
    return true
}

fn h_check_T4() -> bool {
    // Phase activation: P3 lights all 6 channels, P2 lights C+D only.
    // Each call starts from a fresh create_hexad(): hexa stage1 has
    // value-aliasing on `let mut out = h`, so activate() must rebuild
    // the struct from h's fields rather than mutate in-place.
    let h_a = create_hexad(128, 64)
    let h3 = hexad_activate_phase(h_a, 3)
    if hexad_active_count(h3) != 6 { return false }
    let h_b = create_hexad(128, 64)
    let h2 = hexad_activate_phase(h_b, 2)
    if hexad_active_count(h2) != 2 { return false }
    let h_c = create_hexad(128, 64)
    let h1 = hexad_activate_phase(h_c, 1)
    if hexad_active_count(h1) != 1 { return false }
    return true
}

fn h_check_T5() -> bool {
    // Initial Hexad has only C active; D/W/S/M/E start inactive.
    let h = create_hexad(128, 64)
    if !h.c.active { return false }
    if h.d.active || h.w.active || h.s.active || h.m.active || h.e.active { return false }
    return true
}

fn main() {
    println("[hexad] CDESM 6-channel descriptor — Phase 4b self-test")
    println("  6 modules: c d w s m e | Laws phi(6)=2, M8, Law 22, Law 60")

    let t1 = h_check_T1()
    if t1 { println("T1 PASS  defaults match SSOT psi") } else { println("T1 FAIL") }
    let t2 = h_check_T2()
    if t2 { println("T2 PASS  channel coverage (CDESM 6)") } else { println("T2 FAIL") }
    let t3 = h_check_T3()
    if t3 { println("T3 PASS  phase counts (1/2/6)") } else { println("T3 FAIL") }
    let t4 = h_check_T4()
    if t4 { println("T4 PASS  phase activation propagates") } else { println("T4 FAIL") }
    let t5 = h_check_T5()
    if t5 { println("T5 PASS  initial state (only C active)") } else { println("T5 FAIL") }

    let all = t1 && t2 && t3 && t4 && t5
    if all { println("[hexad] ALL 5/5 PASS") }
    else   { println("[hexad] SOME FAILED") }

    let h = create_hexad(128, 64)
    println("  psi_coupling=" + to_string(h.psi_coupling))
    println("  phase 1 active: " + to_string(phase_active_count(1)))
    println("  phase 3 active: " + to_string(phase_active_count(3)))
}

main()
