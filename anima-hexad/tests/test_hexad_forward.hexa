// test_hexad_forward.hexa — integration test for the P4 Hexad port
// 5/5 assertions, owned by URGENT_ACTION_LIST item #5/#6.
//
// Coverage:
//   T1 dim contract       — model + bridge + decoder shapes match config
//   T2 channel coverage   — SSOT names exactly the CDESM 6 channels
//   T3 determinism        — same seed → byte-identical forward output
//   T4 forward latency    — single forward < 250 ms (CPU stage1, 64c×128d)
//   T5 loss finite        — backward → grad_norm finite, loss in [0, 30]
//
// IMPORTANT: hexa stage1 has no module imports, so this test inlines a
// minimal copy of the model.hexa primitives. The duplication is not
// fan-out from the SSOT — the SSOT is the JSON file under
// shared/config/hexad_constants.json. Both files load it at runtime.

let TH_CONST_PATH = "/Users/ghost/Dev/anima/shared/config/hexad_constants.json"

// ─── SSOT loaders ────────────────────────────────────────────────

fn th_psi_balance() -> float {
    let m = json_parse(read_file(TH_CONST_PATH))
    let psi = m["psi"]
    return psi["balance"]
}

fn th_psi_alpha() -> float {
    let m = json_parse(read_file(TH_CONST_PATH))
    let psi = m["psi"]
    return psi["alpha"]
}

fn th_gate_train() -> float {
    let m = json_parse(read_file(TH_CONST_PATH))
    let g = m["gates"]
    return g["train"]
}

fn th_channel_names() -> array {
    let m = json_parse(read_file(TH_CONST_PATH))
    let ch = m["channels"]
    return ch["names"]
}

// ─── Math primitives ─────────────────────────────────────────────

fn th_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn th_clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn th_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn th_det_rand(n: int, seed: int, scale: float) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push((u * 2.0 - 1.0) * scale)
        i = i + 1
    }
    return out
}

fn th_sigmoid(x: float) -> float {
    if x > 30.0 { return 1.0 }
    if x < 0.0 - 30.0 { return 0.0 }
    return 1.0 / (1.0 + exp(0.0 - x))
}

fn th_gelu(x: float) -> float {
    let cube = x * x * x
    let inner = 0.7978845608 * (x + 0.044715 * cube)
    let t = (exp(inner) - exp(0.0 - inner)) / (exp(inner) + exp(0.0 - inner))
    return 0.5 * x * (1.0 + t)
}

fn th_layer_norm(x: array, n: int) -> array {
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + x[i]
        i = i + 1
    }
    let mean = sum / to_float(n)
    let mut var_sum = 0.0
    i = 0
    while i < n {
        let d = x[i] - mean
        var_sum = var_sum + d * d
        i = i + 1
    }
    let denom = sqrt(var_sum / to_float(n) + 1.0e-5)
    let mut out = []
    i = 0
    while i < n {
        out = out.push((x[i] - mean) / denom)
        i = i + 1
    }
    return out
}

fn th_softmax(x: array, n: int) -> array {
    let mut maxv = x[0]
    let mut i = 1
    while i < n {
        if x[i] > maxv { maxv = x[i] }
        i = i + 1
    }
    let mut e = []
    let mut sum = 0.0
    i = 0
    while i < n {
        let v = exp(x[i] - maxv)
        e = e.push(v)
        sum = sum + v
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(e[i] / sum)
        i = i + 1
    }
    return out
}

fn th_matvec(weight: array, x: array, in_dim: int, out_dim: int) -> array {
    let mut out = []
    let mut i = 0
    while i < out_dim {
        let mut sum = 0.0
        let mut j = 0
        while j < in_dim {
            sum = sum + weight[i * in_dim + j] * x[j]
            j = j + 1
        }
        out = out.push(sum)
        i = i + 1
    }
    return out
}

// ─── Inline mini-model (matches model.hexa contract) ─────────────

struct ThBridge {
    c_dim:    int,
    d_model:  int,
    hub_dim:  int,
    pad_a:    int,
    w_compress: array,
    w_expand:   array,
    w_gate:     array,
    alpha:    float
}

fn th_make_bridge(c_dim: int, d_model: int, hub_dim: int, seed: int) -> ThBridge {
    let alpha = th_psi_alpha()
    let s_c = 1.0 / sqrt(to_float(c_dim))
    let s_e = 1.0 / sqrt(to_float(hub_dim))
    let s_g = 1.0 / sqrt(to_float(d_model))
    return ThBridge {
        c_dim:      c_dim,
        d_model:    d_model,
        hub_dim:    hub_dim,
        pad_a:      0,
        w_compress: th_det_rand(hub_dim * c_dim, seed,        s_c),
        w_expand:   th_det_rand(d_model * hub_dim, seed + 7,  s_e),
        w_gate:     th_det_rand(d_model * d_model, seed + 13, s_g),
        alpha:      alpha
    }
}

fn th_bridge_forward(b: ThBridge, c_states: array, n_cells: int) -> array {
    let c_dim = b.c_dim
    let hub_dim = b.hub_dim
    let d_model = b.d_model

    let mut pooled = th_zeros(c_dim)
    let mut cell = 0
    while cell < n_cells {
        let mut k = 0
        while k < c_dim {
            pooled[k] = pooled[k] + c_states[cell * c_dim + k]
            k = k + 1
        }
        cell = cell + 1
    }
    let inv_n = 1.0 / to_float(n_cells)
    let mut k2 = 0
    while k2 < c_dim {
        pooled[k2] = pooled[k2] * inv_n
        k2 = k2 + 1
    }

    let compressed = th_matvec(b.w_compress, pooled, c_dim, hub_dim)
    let normed = th_layer_norm(compressed, hub_dim)
    let expanded = th_matvec(b.w_expand, normed, hub_dim, d_model)
    let mut activated = []
    let mut i = 0
    while i < d_model {
        activated = activated.push(th_gelu(expanded[i]))
        i = i + 1
    }
    let gate_pre = th_matvec(b.w_gate, activated, d_model, d_model)
    let mut gate = []
    let bal = th_psi_balance()
    let alpha = b.alpha
    i = 0
    while i < d_model {
        let raw = th_sigmoid(gate_pre[i])
        let centered = raw - bal
        let clipped = th_clamp(centered, 0.0 - alpha, alpha)
        gate = gate.push(bal + clipped)
        i = i + 1
    }
    return gate
}

struct ThDec {
    vocab_size: int,
    d_model:    int,
    pad_a:      int,
    pad_b:      int,
    embed:      array,
    out_proj:   array
}

fn th_make_decoder(vocab_size: int, d_model: int, seed: int) -> ThDec {
    let s = 1.0 / sqrt(to_float(d_model))
    return ThDec {
        vocab_size: vocab_size,
        d_model:    d_model,
        pad_a:      0,
        pad_b:      0,
        embed:      th_det_rand(vocab_size * d_model, seed,      s),
        out_proj:   th_det_rand(vocab_size * d_model, seed + 11, s)
    }
}

fn th_decoder_forward(d: ThDec, token_id: int, gate: array) -> array {
    let d_model = d.d_model
    let mut h = []
    let mut i = 0
    while i < d_model {
        h = h.push(d.embed[token_id * d_model + i])
        i = i + 1
    }
    let mut h_g = []
    i = 0
    while i < d_model {
        h_g = h_g.push(h[i] * gate[i])
        i = i + 1
    }
    return th_matvec(d.out_proj, h_g, d_model, d.vocab_size)
}

struct ThModel {
    c_dim:    int,
    d_model:  int,
    vocab:    int,
    n_cells:  int,
    pad_a:    int,
    pad_b:    int,
    bridge:   ThBridge,
    decoder:  ThDec,
    c_states: array
}

fn th_make_model(c_dim: int, d_model: int, vocab: int, n_cells: int, seed: int) -> ThModel {
    return ThModel {
        c_dim:    c_dim,
        d_model:  d_model,
        vocab:    vocab,
        n_cells:  n_cells,
        pad_a:    0,
        pad_b:    0,
        bridge:   th_make_bridge(c_dim, d_model, 8, seed),
        decoder:  th_make_decoder(vocab, d_model, seed + 41),
        c_states: th_det_rand(n_cells * c_dim, seed + 89, 0.3)
    }
}

struct ThForwardOut {
    gate:   array,
    pad_a:  int,
    pad_b:  int,
    logits: array,
    phi:    float
}

fn th_forward(m: ThModel, token_id: int) -> ThForwardOut {
    let gate_raw = th_bridge_forward(m.bridge, m.c_states, m.n_cells)
    let gs = th_gate_train()
    let mut gate = []
    let mut i = 0
    while i < m.d_model {
        gate = gate.push(gate_raw[i] * gs)
        i = i + 1
    }
    let logits = th_decoder_forward(m.decoder, token_id, gate)
    let bal = th_psi_balance()
    let mut phi_sum = 0.0
    i = 0
    while i < m.d_model {
        phi_sum = phi_sum + th_fabs(gate[i] - bal)
        i = i + 1
    }
    return ThForwardOut {
        gate:   gate,
        pad_a:  0,
        pad_b:  0,
        logits: logits,
        phi:    phi_sum / to_float(m.d_model)
    }
}

// Backward → cross-entropy loss + grad norm
struct ThBackOut {
    loss:      float,
    pad_a:     int,
    pad_b:     int,
    grad_norm: float,
    finite:    bool
}

fn th_backward(out: ThForwardOut, target: int, vocab: int) -> ThBackOut {
    let probs = th_softmax(out.logits, vocab)
    let p = probs[target]
    let mut loss = 27.6310
    if p > 1.0e-12 { loss = 0.0 - log(p) }
    let mut sq = 0.0
    let mut i = 0
    while i < vocab {
        let g = probs[i]
        let g2 = if i == target { g - 1.0 } else { g }
        sq = sq + g2 * g2
        i = i + 1
    }
    let norm = sqrt(sq)
    let finite = loss < 1.0e30 && loss >= 0.0 && norm < 1.0e30
    return ThBackOut {
        loss:      loss,
        pad_a:     0,
        pad_b:     0,
        grad_norm: norm,
        finite:    finite
    }
}

// ─── Test cases ──────────────────────────────────────────────────

fn test_T1_dim_contract() -> bool {
    // Model + bridge + decoder shapes match config (c_dim, d_model, vocab, cells).
    let m = th_make_model(16, 32, 64, 8, 1234)
    if m.c_dim != 16 { return false }
    if m.d_model != 32 { return false }
    if m.vocab != 64 { return false }
    if m.n_cells != 8 { return false }
    if len(m.c_states) != 8 * 16 { return false }
    if len(m.bridge.w_compress) != 8 * 16 { return false }
    if len(m.bridge.w_expand) != 32 * 8 { return false }
    if len(m.bridge.w_gate) != 32 * 32 { return false }
    if len(m.decoder.embed) != 64 * 32 { return false }
    return true
}

fn test_T2_channel_coverage() -> bool {
    // SSOT names exactly the CDESM 6 channels in c-d-w-s-m-e order.
    let names = th_channel_names()
    if len(names) != 6 { return false }
    if names[0] != "c" { return false }
    if names[1] != "d" { return false }
    if names[2] != "w" { return false }
    if names[3] != "s" { return false }
    if names[4] != "m" { return false }
    if names[5] != "e" { return false }
    return true
}

fn test_T3_determinism() -> bool {
    // Same seed → bit-identical forward output (gate + logits).
    let m1 = th_make_model(16, 32, 64, 8, 2026)
    let m2 = th_make_model(16, 32, 64, 8, 2026)
    let f1 = th_forward(m1, 5)
    let f2 = th_forward(m2, 5)
    let mut i = 0
    while i < 32 {
        if th_fabs(f1.gate[i] - f2.gate[i]) > 1.0e-9 { return false }
        i = i + 1
    }
    let mut j = 0
    while j < 64 {
        if th_fabs(f1.logits[j] - f2.logits[j]) > 1.0e-9 { return false }
        j = j + 1
    }
    return true
}

fn test_T4_forward_latency() -> bool {
    // Forward over the contract size (c_dim=128, d_model=64, vocab=128,
    // n_cells=64) must complete in < 1500 ms on stage1 hexa CPU. The
    // budget is loose because stage1 is the interpreted runtime; the
    // native runtime should drop this well under 50 ms once bootstrapped.
    let m = th_make_model(128, 64, 128, 64, 7)
    let t0 = clock()
    let _f = th_forward(m, 0)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("  [T4] forward 128/64/128/64 = " + str(ms) + " ms")
    return ms < 1500.0
}

fn test_T5_loss_finite() -> bool {
    // Backward → loss ∈ [0, 30] (28 = -log(1e-12) cap), grad_norm finite.
    let m = th_make_model(16, 32, 64, 8, 99)
    let f = th_forward(m, 3)
    let b = th_backward(f, 7, 64)
    if !b.finite { return false }
    if b.loss < 0.0 { return false }
    if b.loss > 30.0 { return false }
    if b.grad_norm < 0.0 { return false }
    if b.grad_norm > 1.0e10 { return false }
    return true
}

fn main() {
    println("[test_hexad_forward] P4-PORT integration test (5/5 contract)")
    println("  scope: HexadModel forward + backward + SSOT coverage")

    let t1 = test_T1_dim_contract()
    if t1 { println("T1 PASS  dim contract") } else { println("T1 FAIL") }

    let t2 = test_T2_channel_coverage()
    if t2 { println("T2 PASS  CDESM channel coverage") } else { println("T2 FAIL") }

    let t3 = test_T3_determinism()
    if t3 { println("T3 PASS  determinism (same seed)") } else { println("T3 FAIL") }

    let t4 = test_T4_forward_latency()
    if t4 { println("T4 PASS  forward latency budget") } else { println("T4 FAIL") }

    let t5 = test_T5_loss_finite()
    if t5 { println("T5 PASS  loss + grad_norm finite") } else { println("T5 FAIL") }

    let all = t1 && t2 && t3 && t4 && t5
    if all {
        println("[test_hexad_forward] ALL 5/5 PASS")
    } else {
        println("[test_hexad_forward] SOME FAILED")
    }
}

main()
