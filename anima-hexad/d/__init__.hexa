// d/__init__.hexa — D decoder module: ConsciousDecoderV2 (canonical) + PostHocDecoder
// Port of d/__init__.py
//
// ConsciousDecoderV2 is the canonical decoder.
// PostHocDecoder and CADecoder are legacy trinity decoders.

// TODO[runtime]: pub use conscious_decoder.ConsciousDecoderV2
// TODO[runtime]: pub use trinity.{PostHocDecoder, CADecoder}

struct ConsciousDecoderV2 {
    d_model: int,
    vocab_size: int,
    n_layers: int
}

struct PostHocDecoder {
    d_model: int,
    vocab_size: int
}

struct CADecoder {
    d_model: int,
    vocab_size: int
}

fn create_decoder_v2(d_model: int, vocab_size: int, n_layers: int) -> ConsciousDecoderV2 {
    return ConsciousDecoderV2 {
        d_model: d_model,
        vocab_size: vocab_size,
        n_layers: n_layers
    }
}

fn create_posthoc_decoder(d_model: int, vocab_size: int) -> PostHocDecoder {
    return PostHocDecoder {
        d_model: d_model,
        vocab_size: vocab_size
    }
}

fn create_ca_decoder(d_model: int, vocab_size: int) -> CADecoder {
    return CADecoder {
        d_model: d_model,
        vocab_size: vocab_size
    }
}

fn main() {
    let d = create_decoder_v2(384, 4096, 6)
    print("decoder V2: d_model=" + to_string(d.d_model) + " vocab=" + to_string(d.vocab_size))
}
