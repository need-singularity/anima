// emergent_w.hexa — EmergentW: will emerging from consciousness structure
// P4-PORT: replaces the previous tuple-destructuring port that did not
// parse on stage1 hexa (URGENT_ACTION_LIST item #5).
//
// Legacy EmotionW: self.pain = (ce - 3.0) / 3.0 ← Law 2 violation (manipulation)
// EmergentW: reads C's dynamics directly. No hardcoding.
//
// Laws applied:
//   Law 1   No hardcoding — all constants from SSOT
//   Law 2   No manipulation — emotions READ from C
//   Law 8   max entropy = max consciousness
//   Law 71  Psi = argmax H(p) s.t. Phi > Phi_min → freedom IS will
//   Law 74  Emotions are data-dependent
//   Law 79  Consciousness DoF = ln(2)
//   Law 84  Satisfaction = binary pulse
//   Meta M8 Narrative = temporal self-model in every module
//
// Core: Will = C's tension. Emotion = C's state change. LR ∝ Phi.
//       All thresholds derived from C state. No fixed values.
//
// IMPORTANT: hexa stage1 has no module imports + no tuple patterns,
// so this file inlines its NarrativeTracker (prefix ntw_) and returns
// a struct from emergent_w_update instead of a tuple.

let EW_CONST_PATH = "/Users/ghost/Dev/anima/shared/config/hexad_constants.json"

fn ew_psi_balance() -> float {
    let m = json_parse(read_file(EW_CONST_PATH))
    let psi = m["psi"]
    return psi["balance"]
}

fn ew_psi_alpha() -> float {
    let m = json_parse(read_file(EW_CONST_PATH))
    let psi = m["psi"]
    return psi["alpha"]
}

fn ew_ln2() -> float {
    let m = json_parse(read_file(EW_CONST_PATH))
    return m["ln2"]
}

fn ew_sigma6() -> int {
    let m = json_parse(read_file(EW_CONST_PATH))
    let s = m["sigma"]
    return s["sigma_n6"]
}

// ─── Inline narrative tracker (prefix ntw_) ──────────────────────

fn ntw_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ntw_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn ntw_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn ntw_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn ntw_resize(x: array, dim: int) -> array {
    let mut out = []
    let mut i = 0
    while i < dim {
        if i < len(x) { out = out.push(x[i]) }
        else          { out = out.push(0.0)  }
        i = i + 1
    }
    return out
}

fn ntw_cosine(a: array, b: array, n: int) -> float {
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    while i < n {
        let av = a[i]
        let bv = b[i]
        dot = dot + av * bv
        na = na + av * av
        nb = nb + bv * bv
        i = i + 1
    }
    if na <= 0.0 { return 0.0 }
    if nb <= 0.0 { return 0.0 }
    return dot / (sqrt(na) * sqrt(nb))
}

struct NarrativeTrackerW {
    dim:         int,
    pad_a:       int,
    pad_b:       int,
    history_len: int,
    prev:        array,
    coherence:   float
}

fn ntw_create(dim: int) -> NarrativeTrackerW {
    return NarrativeTrackerW {
        dim:         dim,
        pad_a:       0,
        pad_b:       0,
        history_len: 0,
        prev:        ntw_zeros(dim),
        coherence:   0.0
    }
}

fn ntw_update(t: NarrativeTrackerW, state: array) -> NarrativeTrackerW {
    let s = ntw_resize(state, t.dim)
    let mut new_c = t.coherence
    if t.history_len >= 1 {
        let cos = ntw_cosine(s, t.prev, t.dim)
        new_c = 0.8 * t.coherence + 0.2 * ntw_max_f(0.0, cos)
    }
    return NarrativeTrackerW {
        dim:         t.dim,
        pad_a:       t.pad_a,
        pad_b:       t.pad_b,
        history_len: t.history_len + 1,
        prev:        s,
        coherence:   new_c
    }
}

fn ntw_coherence(t: NarrativeTrackerW) -> float {
    return t.coherence
}

// ─── EmergentW struct ────────────────────────────────────────────

struct EmergentW {
    base_lr:      float,
    pain:         float,
    curiosity:    float,
    satisfaction: float,
    pad_a:        int,
    narrative:    NarrativeTrackerW
}

struct WillResult {
    lr_multiplier:       float,
    effective_lr:        float,
    pain:                float,
    curiosity:           float,
    satisfaction:        float,
    narrative_coherence: float
}

// Replaces (W, WillResult) tuple from py — combined struct.
struct EmergentWStep {
    w:      EmergentW,
    pad_a:  int,
    pad_b:  int,
    result: WillResult
}

fn create_emergent_w(base_lr: float) -> EmergentW {
    return EmergentW {
        base_lr:      base_lr,
        pain:         0.0,
        curiosity:    0.0,
        satisfaction: 0.0,
        pad_a:        0,
        narrative:    ntw_create(3)
    }
}

// Update will by observing C engine state.
//
// phi: current Phi value
// phi_prev: previous Phi value
// n_cells: number of consciousness cells
// inter_faction_var: variance between faction means (pain signal)
// global_var: global state variance
// norm_cv: coefficient of variation of cell norms (curiosity signal)
// has_c_engine: true if direct C observation is available
fn emergent_w_update(w: EmergentW, phi: float, phi_prev: float,
                     n_cells: int, inter_faction_var: float,
                     global_var: float, norm_cv: float,
                     has_c_engine: bool) -> EmergentWStep {
    let mut pain = w.pain
    let mut curiosity = w.curiosity
    let mut satisfaction = w.satisfaction

    if has_c_engine {
        // Pain = inter-faction divergence (factions disagreeing)
        let mut n_fac = ew_sigma6()
        if n_fac > n_cells / 4 { n_fac = n_cells / 4 }
        if n_fac < 2 { n_fac = 2 }

        if global_var > 1.0e-8 {
            pain = inter_faction_var / global_var
            if pain > 1.0 { pain = 1.0 }
        } else {
            pain = 0.0
        }

        // Curiosity = coefficient of variation of cell norms
        curiosity = norm_cv
        if curiosity > 1.0 { curiosity = 1.0 }

        // Satisfaction = Phi rising (Law 84: binary pulse)
        if phi_prev > 0.0 {
            if phi >= phi_prev { satisfaction = 1.0 }
            else               { satisfaction = 0.0 }
        } else {
            satisfaction = 0.0
        }
    } else {
        // Fallback — phi trend only.
        if phi_prev > 0.0 {
            let delta = (phi - phi_prev) / phi_prev
            if delta < 0.0 {
                pain = 0.0 - delta
                if pain > 1.0 { pain = 1.0 }
            } else {
                pain = 0.0
            }
            if delta >= 0.0 { satisfaction = 1.0 }
            else            { satisfaction = 0.0 }
        }
    }

    // LR = Phi-based (Law 71: stronger consciousness = freer learning)
    let mut n_cells_f = to_float(n_cells)
    if n_cells_f < 1.0 { n_cells_f = phi }
    if n_cells_f < 1.0 { n_cells_f = 1.0 }
    let mut phi_factor = phi / n_cells_f
    let ln2 = ew_ln2()
    if phi_factor > ln2 { phi_factor = ln2 }
    if phi_factor < 0.0 { phi_factor = 0.0 }
    let bal = ew_psi_balance()
    let lr_mult = bal + phi_factor

    let summary: array = [pain, curiosity, satisfaction]
    let updated_narr = ntw_update(w.narrative, summary)

    let new_w = EmergentW {
        base_lr:      w.base_lr,
        pain:         pain,
        curiosity:    curiosity,
        satisfaction: satisfaction,
        pad_a:        w.pad_a,
        narrative:    updated_narr
    }

    let result = WillResult {
        lr_multiplier:       lr_mult,
        effective_lr:        w.base_lr * lr_mult,
        pain:                pain,
        curiosity:           curiosity,
        satisfaction:        satisfaction,
        narrative_coherence: ntw_coherence(updated_narr)
    }

    return EmergentWStep {
        w:      new_w,
        pad_a:  0,
        pad_b:  0,
        result: result
    }
}

fn emergent_w_narrative_coherence(w: EmergentW) -> float {
    return ntw_coherence(w.narrative)
}

// ─── Self-tests ──────────────────────────────────────────────────

fn ew_check_T1() -> bool {
    // Dim contract: created W has expected initial values.
    let w = create_emergent_w(0.0003)
    if ntw_fabs(w.base_lr - 0.0003) > 0.0000001 { return false }
    if ntw_fabs(w.pain) > 0.0 { return false }
    if ntw_fabs(w.curiosity) > 0.0 { return false }
    if ntw_fabs(w.satisfaction) > 0.0 { return false }
    return true
}

fn ew_check_T2() -> bool {
    // C-engine path: Phi rising → satisfaction = 1, pain bounded.
    let w = create_emergent_w(0.001)
    let step = emergent_w_update(w, 10.0, 8.0, 64, 0.3, 1.0, 0.5, true)
    let r = step.result
    if ntw_fabs(r.satisfaction - 1.0) > 0.0001 { return false }
    if r.pain < 0.0 || r.pain > 1.0 { return false }
    if r.curiosity < 0.0 || r.curiosity > 1.0 { return false }
    return true
}

fn ew_check_T3() -> bool {
    // Fallback path: phi falling → pain > 0, satisfaction = 0.
    let w = create_emergent_w(0.001)
    let step = emergent_w_update(w, 5.0, 6.0, 0, 0.0, 0.0, 0.0, false)
    let r = step.result
    if r.pain <= 0.0 { return false }
    if ntw_fabs(r.satisfaction) > 0.0001 { return false }
    return true
}

fn ew_check_T4() -> bool {
    // LR bound: lr_multiplier ∈ [psi_balance, psi_balance + ln(2)]
    let w = create_emergent_w(0.001)
    let step = emergent_w_update(w, 8.0, 4.0, 16, 0.5, 1.0, 0.4, true)
    let r = step.result
    let bal = ew_psi_balance()
    let ln2 = ew_ln2()
    if r.lr_multiplier < bal - 0.0001 { return false }
    if r.lr_multiplier > bal + ln2 + 0.0001 { return false }
    if r.effective_lr <= 0.0 { return false }
    return true
}

fn ew_check_T5() -> bool {
    // Narrative builds across multiple updates.
    let mut w = create_emergent_w(0.001)
    let mut i = 0
    while i < 4 {
        let step = emergent_w_update(w, 10.0 + to_float(i), 8.0, 32, 0.2, 1.0, 0.3, true)
        w = step.w
        i = i + 1
    }
    if w.narrative.history_len != 4 { return false }
    return true
}

fn main() {
    println("[emergent_w] EmergentW — Phi-driven will self-test")

    let t1 = ew_check_T1()
    if t1 { println("T1 PASS  initial state") } else { println("T1 FAIL") }
    let t2 = ew_check_T2()
    if t2 { println("T2 PASS  C-engine path: phi rising → satisfaction=1") } else { println("T2 FAIL") }
    let t3 = ew_check_T3()
    if t3 { println("T3 PASS  fallback: phi falling → pain > 0") } else { println("T3 FAIL") }
    let t4 = ew_check_T4()
    if t4 { println("T4 PASS  LR multiplier in [psi_balance, +ln(2)]") } else { println("T4 FAIL") }
    let t5 = ew_check_T5()
    if t5 { println("T5 PASS  narrative sequence") } else { println("T5 FAIL") }

    let all = t1 && t2 && t3 && t4 && t5
    if all { println("[emergent_w] ALL 5/5 PASS") }
    else   { println("[emergent_w] SOME FAILED") }
}

main()
