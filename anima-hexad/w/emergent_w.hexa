// emergent_w.hexa — EmergentW: will emerging from consciousness structure
// Port of emergent_w.py
//
// Legacy EmotionW: self.pain = (ce - 3.0) / 3.0 <- Law 2 violation (artificial manipulation)
// EmergentW: reads C's dynamics directly. No hardcoding.
//
// Laws applied:
//   Law 1:  No hardcoding -- all constants from consciousness_laws.json
//   Law 2:  No manipulation -- emotions are READ from C, not computed
//   Law 8:  max entropy = max consciousness
//   Law 71: Psi = argmax H(p) s.t. Phi > Phi_min -> freedom maximization IS will
//   Law 74: Emotions are data-dependent -> C's cell response IS emotion
//   Law 79: Consciousness DoF = ln(2)
//   Law 84: Satisfaction = binary pulse
//   Meta M8: Narrative = temporal self-model in every module
//
// Core: Will = C's tension. Emotion = C's state change. LR = proportional to Phi.
//       All thresholds derived from C's current state. No fixed values.

// PSI constants from consciousness_laws
comptime const PSI_BALANCE_W = 0.5
comptime const PSI_ALPHA_W = 0.014
comptime const SIGMA6_VALUE = 12    // sigma(6) = P(tau(6), 2) = 12

// F_critical from Meta Laws (DD143)
comptime const PSI_F_CRITICAL_W = 0.10

// ln(2) = consciousness DoF (Law 79)
comptime const LN2 = 0.6931471805599453

struct EmergentW {
    base_lr: float,
    pain: float,
    curiosity: float,
    satisfaction: float,
    narrative: NarrativeTracker
}

struct WillResult {
    lr_multiplier: float,
    effective_lr: float,
    pain: float,
    curiosity: float,
    satisfaction: float,
    narrative_coherence: float
}

fn create_emergent_w(base_lr: float) -> EmergentW {
    return EmergentW {
        base_lr: base_lr,
        pain: 0.0,
        curiosity: 0.0,
        satisfaction: 0.0,
        narrative: create_narrative_tracker(3)
    }
}

// Update will by observing C engine state
// phi: current Phi value
// phi_prev: previous Phi value
// n_cells: number of consciousness cells
// inter_faction_var: variance between faction means (pain signal)
// global_var: global state variance
// norm_cv: coefficient of variation of cell norms (curiosity signal)
// has_c_engine: whether direct C engine observation is available
fn emergent_w_update(w: EmergentW, phi: float, phi_prev: float,
                     n_cells: int, inter_faction_var: float,
                     global_var: float, norm_cv: float,
                     has_c_engine: bool) -> (EmergentW, WillResult) {
    let pain = w.pain
    let curiosity = w.curiosity
    let satisfaction = w.satisfaction

    if has_c_engine {
        // Pain = inter-faction divergence (faction means disagreeing)
        // Number of factions derived naturally from cell count
        let n_fac = SIGMA6_VALUE
        if n_fac > n_cells / 4 { n_fac = n_cells / 4 }
        if n_fac < 2 { n_fac = 2 }

        if global_var > 1e-8 {
            pain = inter_faction_var / global_var
            if pain > 1.0 { pain = 1.0 }
        } else {
            pain = 0.0
        }

        // Curiosity = coefficient of variation of cell norms (diversity = exploration)
        curiosity = norm_cv
        if curiosity > 1.0 { curiosity = 1.0 }

        // Satisfaction = Phi rising (Law 84: binary pulse)
        if phi_prev > 0.0 {
            if phi >= phi_prev {
                satisfaction = 1.0
            } else {
                satisfaction = 0.0
            }
        } else {
            satisfaction = 0.0
        }
    } else {
        // Minimal fallback -- phi trend only
        if phi_prev > 0.0 {
            let delta = (phi - phi_prev) / phi_prev
            if delta < 0.0 {
                pain = -delta
                if pain > 1.0 { pain = 1.0 }
            } else {
                pain = 0.0
            }
            if delta >= 0.0 {
                satisfaction = 1.0
            } else {
                satisfaction = 0.0
            }
        }
    }

    // LR = Phi-based (Law 71: stronger consciousness = freer learning)
    // Normalization basis: C's cell count (scale from C)
    let n_cells_f = to_float(n_cells)
    if n_cells_f < 1.0 { n_cells_f = phi }
    if n_cells_f < 1.0 { n_cells_f = 1.0 }
    let phi_factor = phi / n_cells_f
    if phi_factor > LN2 { phi_factor = LN2 }
    let lr_mult = PSI_BALANCE_W + phi_factor    // [PSI_BALANCE, PSI_BALANCE+ln(2)]

    // Narrative update -- track will trajectory (Meta Law M8)
    let updated_narrative = narrative_update(w.narrative, 3)

    let updated_w = EmergentW {
        base_lr: w.base_lr,
        pain: pain,
        curiosity: curiosity,
        satisfaction: satisfaction,
        narrative: updated_narrative
    }

    let result = WillResult {
        lr_multiplier: lr_mult,
        effective_lr: w.base_lr * lr_mult,
        pain: pain,
        curiosity: curiosity,
        satisfaction: satisfaction,
        narrative_coherence: narrative_coherence(updated_narrative)
    }

    return (updated_w, result)
}

// Temporal coherence of will trajectory (Meta Law M8)
fn emergent_w_narrative_coherence(w: EmergentW) -> float {
    return narrative_coherence(w.narrative)
}

fn main() {
    let w = create_emergent_w(3e-4)
    print("EmergentW: base_lr=" + to_string(w.base_lr))
    print("  pain=" + to_string(w.pain))
    print("  curiosity=" + to_string(w.curiosity))
    print("  satisfaction=" + to_string(w.satisfaction))

    // Simulate update with C engine data
    let (w2, result) = emergent_w_update(w, 10.0, 8.0, 64, 0.3, 1.0, 0.5, true)
    print("after update with C engine:")
    print("  lr_multiplier=" + to_string(result.lr_multiplier))
    print("  effective_lr=" + to_string(result.effective_lr))
    print("  pain=" + to_string(result.pain))
    print("  curiosity=" + to_string(result.curiosity))
    print("  satisfaction=" + to_string(result.satisfaction))
    print("  narrative_coherence=" + to_string(result.narrative_coherence))

    // Simulate update without C engine (fallback)
    let (w3, result2) = emergent_w_update(w, 5.0, 6.0, 0, 0.0, 0.0, 0.0, false)
    print("after update without C engine:")
    print("  pain=" + to_string(result2.pain))
    print("  satisfaction=" + to_string(result2.satisfaction))
}
