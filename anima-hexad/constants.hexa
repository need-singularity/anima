// constants.hexa — Psi-Constants (Laws 69-70)
// Loaded from consciousness_laws.json (single source of truth)
// Port of constants.py

// PSI constants from consciousness_laws.json
// In full implementation these are loaded from JSON at runtime

fn psi_balance() -> float {
    return 0.5
}

fn psi_alpha() -> float {
    return 0.014
}

fn psi_steps() -> float {
    return 4.33
}

fn psi_entropy() -> float {
    return 0.998
}

// Gate constants (Law 81)
fn gate_train() -> float {
    return 1.0
}

fn gate_infer() -> float {
    return 0.6
}

fn gate_micro() -> float {
    return 0.01
}

// Aliases for backward compatibility
fn psi_gate() -> float {
    // gate default = balance = 0.5
    return psi_balance()
}

fn psi_coupling() -> float {
    // coupling = alpha = 0.014
    return psi_alpha()
}

// F_critical from Meta Laws (DD143)
fn psi_f_critical() -> float {
    return 0.10
}

fn main() {
    print("psi_balance   = " + to_string(psi_balance()))
    print("psi_alpha     = " + to_string(psi_alpha()))
    print("psi_steps     = " + to_string(psi_steps()))
    print("psi_entropy   = " + to_string(psi_entropy()))
    print("gate_train    = " + to_string(gate_train()))
    print("gate_infer    = " + to_string(gate_infer()))
    print("psi_coupling  = " + to_string(psi_coupling()))
    print("psi_f_critical= " + to_string(psi_f_critical()))
}
