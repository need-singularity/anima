// __init__.hexa — Hexad module root: 6 pluggable modules, phi(6)=2 gradient groups
// Port of __init__.py
//
// Modules:
//   C: ConsciousnessC (consciousness_engine)
//   D: ConsciousDecoderV2 (conscious_decoder)
//   W: EmergentW (hexad/w/)
//   S: EmergentS (hexad/s/)
//   M: EmergentM (hexad/m/)
//   E: EmergentE (hexad/e/)
//
// Usage:
//   use hexad.model.{Hexad, Trinity, create_hexad, create_trinity}
//   use hexad.constants.{PSI_BALANCE, PSI_GATE, PSI_COUPLING}
//   use hexad.narrative.NarrativeTracker
//   use hexad.w.emergent_w.EmergentW
//   use hexad.s.emergent_s.EmergentS
//   use hexad.m.emergent_m.EmergentM
//   use hexad.e.emergent_e.EmergentE

// Re-exports from submodules
// In hexa, module exports are declared via pub visibility

pub use hexad.model.{HexadConfig, create_hexad_config, create_trinity_config, hexad_forward, hexad_train_step, n_modules}
pub use hexad.constants.{psi_balance, psi_gate, psi_coupling, psi_steps, psi_entropy, gate_train, gate_infer, gate_micro}
pub use hexad.narrative.{NarrativeTracker, create_narrative_tracker}

// Emergent modules
pub use hexad.w.emergent_w.{EmergentW, create_emergent_w, emergent_w_update}
pub use hexad.s.emergent_s.{EmergentS, create_emergent_s, emergent_s_process}
pub use hexad.m.emergent_m.{EmergentM, create_emergent_m, emergent_m_retrieve}
pub use hexad.e.emergent_e.{EmergentE, create_emergent_e, emergent_e_evaluate}

fn main() {
    print("hexad: 6 pluggable modules, phi(6)=2 gradient groups")
    print("modules: C D W S M E")
}
