// neural_vocoder.hexa — HEXA-SPEAK Mk.I: Neural Vocoder
//
// Purpose:
//   Decode RVQ latents → 24kHz PCM waveform, streaming-capable.
//   Target: ≤ 6 kbps reconstruction, < 30ms algorithmic latency.
//
// n=6 parameters:
//   sample_rate = 24000                   (24 kHz, speech-optimal)
//   frame_hz    = 100                     (10ms hop, matches predictor)
//   hop         = 240 = 24000 / 100
//   bitrate_kbps_target = 6
//   upsample_stages = 6                   (n=6 transposed convs: 2·2·2·3·5·?)
//   ch_base     = 384 = 64 * 6            (base channel dim)
//
// BT reference: BT-SPEAK-04 (waveform synthesis), HiFi-GAN/Vocos lineage
// Mk stage:     Mk.I (skeleton, emits silent PCM count)
// Upstream:     rvq_codebook.decode()
// Downstream:   audio output sink (speaker / rtp / file)

let SAMPLE_RATE = 24000
let FRAME_HZ = 100
let HOP = 240
let UPSAMPLE_STAGES = 6
let CH_BASE = 384

// TODO(Mk.II): Vocos-style ISTFT head or HiFi-GAN MRF blocks
// TODO(Mk.II): causal convs only (streaming), lookahead ≤ 20ms
// TODO(Mk.II): loudness normalization, DC filter, dither
fn decode_wave(latents: str, n_frames: int) -> str {
    // Mk.I dummy: return synthesized sample count
    let n_samples = n_frames * HOP
    return "pcm[sr=" + to_string(SAMPLE_RATE) + ",samples=" + to_string(n_samples) + ",src=" + latents + "]"
}

fn main() {
    println("neural_vocoder Mk.I — sr=" + to_string(SAMPLE_RATE) + " hop=" + to_string(HOP) + " upsample=" + to_string(UPSAMPLE_STAGES))
    let wav = decode_wave("latent[demo]", 10)
    println("wave(100ms): " + wav)
}

main()
