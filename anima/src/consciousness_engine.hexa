// ─── ConsciousnessC wrapper for Trinity/Hexad ───

struct ConsciousnessC {
    engine: ConsciousnessEngine,
    training: bool,
    gate: float
}

fn consciousness_c_new(max_cells: int) -> ConsciousnessC {
    let eng = consciousness_engine_new(64, 128, 2, max_cells, 12, true, 0.3, 0.01, false, false)
    ConsciousnessC {
        engine: eng,
        training: true,
        gate: PSI_GATE_TRAIN
    }
}

fn consciousness_c_step(cc: ConsciousnessC, text: string) -> ConsciousnessC {
    let new_eng = consciousness_engine_step(cc.engine, text)
    ConsciousnessC {
        engine: new_eng,
        training: cc.training,
        gate: if cc.training { PSI_GATE_TRAIN } else { PSI_GATE_INFER }
    }
}
