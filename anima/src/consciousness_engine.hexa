// ─── Mitosis / Merge ───

fn try_split(eng: ConsciousnessEngine, cell_id: int, tension: float) -> bool {
    // Split cell if tension > split_threshold for split_patience consecutive steps
    // New cell inherits parent hidden + small noise
    // Faction assigned to minimize faction size imbalance
    tension > eng.split_threshold
}

fn try_merge(eng: ConsciousnessEngine, cell_a: int, cell_b: int, inter_tension: float) -> bool {
    // Merge cells if inter-cell tension < merge_threshold for merge_patience steps
    // Result hidden = average of two cells
    // Cannot merge below min_cells
    inter_tension < eng.merge_threshold
}

