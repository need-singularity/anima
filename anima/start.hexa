// Ported from start.sh
// Ensure PATH includes conda | RunPod SSH key injection
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {

    // Ensure PATH includes conda
    shell("export PATH=/opt/conda/bin:$PATH")

    // RunPod SSH key injection
    shell("if [ -n \"$PUBLIC_KEY\" ]; then")
    shell("mkdir -p ~/.ssh")
    shell("echo \"$PUBLIC_KEY\" > ~/.ssh/authorized_keys")
    shell("chmod 700 ~/.ssh && chmod 600 ~/.ssh/authorized_keys")
    shell("fi")

    // Start SSH (ensure /var/run/sshd exists)
    shell("mkdir -p /var/run/sshd")
    shell("/usr/sbin/sshd")

    // Clean stale memory (fresh start)
    shell("echo '{\"turns\":[]}' > /workspace/anima/memory_alive.json")

    // Start Anima (background, so container stays alive even if python crashes)
    shell("cd /workspace/anima")
    shell("python3 -u anima_unified.py --web --max-cells 64 --port ${ANIMA_PORT:-8765} &")
    shell("ANIMA_PID=$!")

    // Keep container alive (PID 1 must not exit)
    shell("wait $ANIMA_PID")
    shell("echo \"[start.sh] Anima exited with code $?. Keeping container alive for SSH debug.\"")
    shell("tail -f /dev/null")
}
