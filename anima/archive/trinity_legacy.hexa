struct MitosisC {
    dim: int,
    hidden: int,
    max_cells: int,
    mechanism: string,
    step_count: int
}

fn mitosis_c_new(dim: int, hidden: int, max_cells: int, mechanism: string) -> MitosisC {
    // DEPRECATED: emits warning at construction
    MitosisC {
        dim: dim,
        hidden: hidden,
        max_cells: max_cells,
        mechanism: mechanism,
        step_count: 0
    }
}

fn mitosis_c_step(mc: MitosisC) -> MitosisC {
    // TODO[python-sdk]: MitosisEngine.process() + CambrianDiversity.step() + OscillatorQW.step()
