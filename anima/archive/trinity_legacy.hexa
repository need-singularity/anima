// ─── TransformerDecoder (LEGACY) ───
// Use ConsciousDecoderV2 (models/decoder.hexa) instead.

struct TransformerDecoder {
    d_model: int,
    n_layers: int,
    n_heads: int,
    vocab_size: int,
    max_seq: int
}

fn transformer_decoder_new(d_model: int, n_layers: int, n_heads: int, vocab_size: int, max_seq: int) -> TransformerDecoder {
    // DEPRECATED: Use ConsciousDecoderV2
    let nh = if n_heads <= 0 {
        if d_model % 6 == 0 { 6 }
        else if d_model % 4 == 0 { 4 }
        else if d_model % 8 == 0 { 8 }
        else { 2 }
    } else {
        n_heads
    }
    TransformerDecoder {
        d_model: d_model,
        n_layers: n_layers,
        n_heads: nh,
        vocab_size: vocab_size,
        max_seq: max_seq
    }
}

fn transformer_decoder_forward(td: TransformerDecoder, tokens: string, gate_signal: string) -> string {
    // TODO[pytorch]: nn.Embedding + pos_embed + TransformerEncoder + LayerNorm + head
    // Forward: embed(tokens) + pos_embed * gate_signal -> transformer -> ln_f -> head
    "logits_placeholder"
}
