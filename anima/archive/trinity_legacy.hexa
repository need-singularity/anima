        dim: mc.dim,
        hidden: mc.hidden,
        max_cells: mc.max_cells,
        mechanism: mc.mechanism,
        step_count: mc.step_count + 1
    }
}

fn mitosis_c_measure_phi(mc: MitosisC) -> float {
    // TODO[python-sdk]: phi_rs.compute_phi(states, 16, prev_s, curr_s, tensions)
    0.0
}

