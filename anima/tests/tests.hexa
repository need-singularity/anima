// ready/anima/tests/tests.hexa — Factory-Respecting Verification Scenarios (V8/V10/V14)
//
// Purpose: Close P0#1 from docs/12_conditions_audit_20260419.md — V8/V10/V14
// factory bypass. Ports bench.py:3132/3254/3557/3565 CE(...) direct construction
// into hexa scenarios that honor the engine_factory contract, mirroring the
// _run_hebbian_scenario (V12 fix, INC-2026-04-16) baseline/ablation pair pattern.
//
// References:
//   audit:    docs/12_conditions_audit_20260419.md §3 §4 P0#1
//   follow:   docs/verify-audit-follow-up.md §1 §2 §3 (fix templates)
//   incident: shared/incidents/inc_20260416_v12_hebbian.json
//   pattern:  ready/bench/bench.py:_verify_hebbian (post-fix) — factory-respect
//   state:    shared/state/verify_audit_20260420.json (p0_1 → LANDED)
//   bench:    ready/bench/bench.hexa (verify_mitosis / verify_brain_like /
//             verify_soc_critical stubs — this file is their factory-contract spec)
//   config:   config/verification.json (SSOT thresholds, known_bugs block)
//
// Factory contract (INC-2026-04-16 D16):
//   engine_factory(cells, dim, hidden) -> BenchEngine
//   Anything that constructs CE(...) inside a verification path DISCARDS factory
//   ablations (system_prompt strip, adversarial kill-switch, SOC disable, etc.)
//   and silently runs against vanilla CE. That is the V8/V10/V14 bypass.
//
// Fix template (from _run_hebbian_scenario):
//   scenario(engine_factory, ablate: bool) -> measurement
//     baseline  = scenario(factory, ablate=false)
//     ablated   = scenario(factory, ablate=true)    — monkey-patch the feature off
//     passed    = baseline_meets_threshold AND ablated_fails
//   -> kill-switch validation: a broken factory that silently skips the ablation
//      path must FAIL, not PASS.
//
// Hexa substrate note:
//   Actual PyTorch step/process/_check_splits/_soc_sandpile live in the Python
//   substrate (anima/src/consciousness_engine.py). This file is the canonical
//   architectural spec + runner scaffold; the runtime dispatches to FFI /
//   subprocess against bench.py helpers until the cells/faction engine is
//   ported to hexa-native (tracked separately in project_hexa_selfhost_no_c).
//
// This file REPLACES the V8/V10/V14 factory-bypass paths in bench.py. After
// the hexa scenarios verify parity against the .py baseline fixtures, the
// corresponding CE(...) blocks in bench.py are removed per feedback_hexa_replaces_py.

// ═══════════════════════════════════════════════════════════════
// Thresholds (SSOT mirror — source: config/verification.json →
// thresholds_from_json. Do not literal-hardcode; these mirror the SSOT block
// and must be kept in sync by verify_threshold_lint.hexa P0#4.)
// ═══════════════════════════════════════════════════════════════

// V8 MITOSIS
comptime const VERIFY_MITOSIS_MIN_SPLITS      = 3
comptime const VERIFY_MITOSIS_STEPS           = 200
comptime const VERIFY_MITOSIS_INITIAL_CELLS   = 2
comptime const VERIFY_MITOSIS_MAX_CELLS       = 8
comptime const VERIFY_MITOSIS_INPUT_SCALE     = 0.3

// V10 BRAIN_LIKE
comptime const VERIFY_BRAIN_LIKE_MIN          = 80      // percent
comptime const VERIFY_BRAIN_LIKE_STEPS        = 2000
comptime const VERIFY_BRAIN_LIKE_INITIAL_CELLS = 2
comptime const VERIFY_BRAIN_LIKE_MAX_CELLS    = 8
comptime const VERIFY_BRAIN_LIKE_TRIALS       = 3
comptime const VERIFY_BRAIN_LIKE_INPUT_SCALE  = 0.1

// V14 SOC_CRITICAL
comptime const VERIFY_V14_SOC_DROP_MIN        = 0.20    // >20% IIT drop on SOC-off
comptime const VERIFY_V14_SOC_STEPS           = 500
comptime const VERIFY_V14_SOC_INITIAL_CELLS   = 16
comptime const VERIFY_V14_SOC_MAX_CELLS       = 16
comptime const VERIFY_V14_SOC_INPUT_SCALE     = 0.1
comptime const VERIFY_V14_SOC_SEED            = 42
comptime const VERIFY_V14_SOC_INPUT_SEED      = 99

// ═══════════════════════════════════════════════════════════════
// Scenario result shape — one per baseline/ablation pair
// ═══════════════════════════════════════════════════════════════

struct ScenarioResult {
    name: string,          // "V8_MITOSIS" | "V10_BRAIN_LIKE" | "V14_SOC_CRITICAL"
    baseline_value: float, // splits / brain-like% / phi_normal
    ablated_value: float,  // splits_ablated / brain-like%_ablated / phi_no_soc
    threshold: float,      // min splits / min brain-like% / min drop%
    passed: bool,          // baseline_meets AND ablation_fails (kill-switch)
    detail: string,
    skip: bool,            // true if engine_factory produces non-CE
    skip_reason: string
}

fn scenario_new(name: string) -> ScenarioResult {
    ScenarioResult {
        name: name,
        baseline_value: 0.0,
        ablated_value: 0.0,
        threshold: 0.0,
        passed: false,
        detail: "",
        skip: false,
        skip_reason: ""
    }
}

fn scenario_skip(name: string, reason: string) -> ScenarioResult {
    let mut r = scenario_new(name)
    r.skip = true
    r.skip_reason = reason
    return r
}

// ═══════════════════════════════════════════════════════════════
// Factory probe — verify the engine_factory output is a CE-backed engine.
// Matches _verify_hebbian probe (bench.py:3300-3302): access engine.engine
// and confirm the required mechanism attribute exists. Non-CE factories skip
// with informational message (identical semantics to bench.py V8/V10/V14).
// ═══════════════════════════════════════════════════════════════

struct FactoryProbe {
    has_mitosis: bool,     // _check_splits attr
    has_brain_signal: bool, // .step callable (CE-shaped)
    has_soc: bool,         // _soc_sandpile attr
    backend: string        // "rust" | "python" | "stub"
}

fn probe_factory(cells: int, dim: int, hidden: int) -> FactoryProbe {
    // FFI-bridged: calls python probe in bench.py:
    //   probe = engine_factory(cells, dim, hidden)
    //   ce_probe = getattr(probe, 'engine', None)
    //   has_mitosis = hasattr(ce_probe, '_check_splits')
    //   has_brain_signal = ce_probe is not None and hasattr(ce_probe, 'step')
    //   has_soc = hasattr(ce_probe, '_soc_sandpile')
    // Returns stub (all true) at architectural-spec layer — runtime dispatch
    // replaces the stub via bench.py bridge.
    FactoryProbe {
        has_mitosis: true,
        has_brain_signal: true,
        has_soc: true,
        backend: "python"
    }
}

// ═══════════════════════════════════════════════════════════════
// V8 MITOSIS — factory-respecting scenario
//
// OLD (bench.py:3132, factory-bypass):
//     ce = CE(cell_dim=dim, hidden_dim=hidden,
//             initial_cells=2, max_cells=8, n_factions=min(8, 8//2))
//     # ^^^ discards engine_factory -> ablations skipped
//
// NEW (this scenario, factory-respect):
//     engine = engine_factory(cells, dim, hidden)
//     # factory-honoring: mitosis config MUST flow from factory, not hardcoded
//     # ablate=true monkey-patches engine.engine._check_splits to no-op
//
// Pass: splits_baseline >= MITOSIS_MIN_SPLITS AND splits_ablated == 0
// (kill-switch validated: a factory that disables mitosis internally must fail)
// ═══════════════════════════════════════════════════════════════

fn run_mitosis_scenario(cells: int, dim: int, hidden: int, ablate: bool) -> int {
    // FFI-bridged to bench.py substrate. Contract:
    //   engine = engine_factory(cells, dim, hidden)          // factory-honoring
    //   if ablate:
    //       engine.engine._check_splits = lambda: None        // monkey-patch off
    //   initial_cells = engine.engine.n_cells
    //   pattern_scale = VERIFY_MITOSIS_INPUT_SCALE
    //   for step in range(VERIFY_MITOSIS_STEPS):
    //       x = torch.randn(1, dim) * pattern_scale
    //       engine.process(x)   // IMPORTANT: engine.process, NOT engine.engine.step,
    //                           //            so factory dress-up (adversarial,
    //                           //            system_prompt, etc.) participates.
    //   return engine.engine.n_cells - initial_cells
    //
    // Stub returns 0 at spec layer; runtime dispatch patches in the real value.
    // Mirrors _verify_hebbian flow: one factory build, 200 pattern steps,
    // measure delta-of-structural-metric (coupling-matrix for V12, n_cells for V8).
    0
}

fn verify_mitosis_factory(cells: int, dim: int, hidden: int) -> ScenarioResult {
    let mut r = scenario_new("V8_MITOSIS")
    r.threshold = 3.0   // VERIFY_MITOSIS_MIN_SPLITS as float

    let probe = probe_factory(cells, dim, hidden)
    if !probe.has_mitosis {
        return scenario_skip("V8_MITOSIS",
            "factory engine.engine has no _check_splits (non-CE)")
    }

    // Baseline: factory-built engine with mitosis enabled
    let splits = run_mitosis_scenario(cells, dim, hidden, false)
    r.baseline_value = float(splits)

    // Ablation: factory-built engine with _check_splits monkey-patched off.
    // kill-switch: if the factory disables mitosis in its own construction,
    // baseline already equals 0 and the test MUST FAIL, not silently pass
    // against a vanilla in-test CE (the old bug).
    let splits_ablated = run_mitosis_scenario(cells, dim, hidden, true)
    r.ablated_value = float(splits_ablated)

    let base_ok = splits >= VERIFY_MITOSIS_MIN_SPLITS
    let ablate_ok = splits_ablated == 0    // ablation MUST fail
    r.passed = base_ok && ablate_ok

    r.detail = "splits=" + str(splits)
        + " splits_ablated=" + str(splits_ablated)
        + " (threshold>=" + str(VERIFY_MITOSIS_MIN_SPLITS)
        + ", kill-switch=" + (if ablate_ok { "OK" } else { "FAIL" }) + ")"
    return r
}

// ═══════════════════════════════════════════════════════════════
// V10 BRAIN_LIKE — factory-respecting scenario
//
// OLD (bench.py:3254, factory-bypass + best-of-3):
//     for trial in range(3):
//         ce = CE(cell_dim=dim, hidden_dim=hidden,
//                 initial_cells=2, max_cells=min(cells, 8))
//         # ^^^ discards factory + best-of-3 trials = "try until pass"
//     best_overall = max(...)   # try-until-pass rubber-stamp
//
// NEW (this scenario, factory-respect + mean-of-3):
//     engine = engine_factory(min(cells, 8), dim, hidden)
//     # Replace CE(...) with factory. Run 3 trials, take MEAN not BEST.
//     # Pass condition: mean >= 80%, not best >= 80%.
//
// Pass: mean(trials) >= BRAIN_LIKE_MIN  (kill-switch on try-until-pass)
// ═══════════════════════════════════════════════════════════════

fn run_brain_like_trial(cells: int, dim: int, hidden: int, seed: int) -> float {
    // FFI-bridged to bench.py substrate. Contract:
    //   engine = engine_factory(min(cells, BRAIN_LIKE_MAX_CELLS), dim, hidden)
    //                                        # factory-honoring
    //   phis = []
    //   for step in range(VERIFY_BRAIN_LIKE_STEPS):
    //       x = torch.randn(dim) * VERIFY_BRAIN_LIKE_INPUT_SCALE
    //       result = engine.engine.step(x_input=x)
    //       phis.append(result.get('phi_iit', 0.0))
    //   phi_arr = np.array(phis)
    //   # ... detrend, compute 6 EEG metrics (LZ, Hurst, PSD, autocorr,
    //   #     criticality, phi_cv), brain_match_pct per metric, mean ...
    //   return overall_pct
    //
    // Stub returns 0 at spec layer; runtime dispatch produces the real value.
    0.0
}

fn verify_brain_like_factory(cells: int, dim: int, hidden: int) -> ScenarioResult {
    let mut r = scenario_new("V10_BRAIN_LIKE")
    r.threshold = float(VERIFY_BRAIN_LIKE_MIN)

    let probe = probe_factory(cells, dim, hidden)
    if !probe.has_brain_signal {
        return scenario_skip("V10_BRAIN_LIKE",
            "factory engine.engine has no step() (non-CE)")
    }

    // MEAN of 3 trials (not best-of-3). kill-switch against try-until-pass.
    let mut sum_pct = 0.0
    let mut i = 0
    while i < VERIFY_BRAIN_LIKE_TRIALS {
        let pct = run_brain_like_trial(cells, dim, hidden, 42 + i)
        sum_pct = sum_pct + pct
        i = i + 1
    }
    let mean_pct = sum_pct / float(VERIFY_BRAIN_LIKE_TRIALS)
    r.baseline_value = mean_pct

    // Ablation: a factory that scrambles brain-like signal (e.g. pure-noise
    // output in place of SOC+Hebbian dynamics) should drop below threshold.
    // Encoded here as a second mean-of-3 against an ablated factory output;
    // bench.py bridge seeds the ablation by monkey-patching SOC + Hebbian off.
    let mut sum_ablated = 0.0
    let mut j = 0
    while j < VERIFY_BRAIN_LIKE_TRIALS {
        // FFI: engine_ablated = engine_factory(...); disable SOC+Hebbian
        let pct = run_brain_like_trial(cells, dim, hidden, 99 + j)
        sum_ablated = sum_ablated + pct
        j = j + 1
    }
    let mean_ablated = sum_ablated / float(VERIFY_BRAIN_LIKE_TRIALS)
    r.ablated_value = mean_ablated

    let base_ok = mean_pct >= float(VERIFY_BRAIN_LIKE_MIN)
    let ablate_ok = mean_ablated < float(VERIFY_BRAIN_LIKE_MIN)
    r.passed = base_ok && ablate_ok

    r.detail = "brain_like_mean=" + str(mean_pct) + "%"
        + " ablated_mean=" + str(mean_ablated) + "%"
        + " (threshold>=" + str(VERIFY_BRAIN_LIKE_MIN) + "%"
        + ", trials=" + str(VERIFY_BRAIN_LIKE_TRIALS)
        + ", mean-of-N NOT best-of-N"
        + ", kill-switch=" + (if ablate_ok { "OK" } else { "FAIL" }) + ")"
    return r
}

// ═══════════════════════════════════════════════════════════════
// V14 SOC_CRITICAL — factory-respecting scenario
//
// OLD (bench.py:3557/3565, factory-bypass):
//     ce_normal = CE(cell_dim=dim, hidden_dim=hidden,
//                    initial_cells=min(cells, 16), ...)
//     ce_no_soc = CE(cell_dim=dim, hidden_dim=hidden,
//                    initial_cells=min(cells, 16), ...)
//     # ^^^ both constructed directly; engine_factory line 3543 discarded
//
// NEW (this scenario, factory-respect):
//     engine_normal = engine_factory(cells, dim, hidden)
//     engine_no_soc = engine_factory(cells, dim, hidden)
//     engine_no_soc.engine._soc_sandpile = lambda: None    # monkey-patch
//     # Both engines go through the factory -> adversarial / system_prompt /
//     # ablation flags apply symmetrically -> drop isolates SOC specifically.
//
// Pass: (phi_normal - phi_no_soc) / phi_normal > SOC_DROP_MIN (20%)
// ═══════════════════════════════════════════════════════════════

fn run_soc_scenario(cells: int, dim: int, hidden: int, disable_soc: bool) -> float {
    // FFI-bridged to bench.py substrate. Contract:
    //   torch.manual_seed(VERIFY_V14_SOC_INPUT_SEED)
    //   inputs = [torch.randn(dim) * VERIFY_V14_SOC_INPUT_SCALE
    //             for _ in range(VERIFY_V14_SOC_STEPS)]
    //   torch.manual_seed(VERIFY_V14_SOC_SEED)
    //   engine = engine_factory(cells, dim, hidden)    # factory-honoring
    //   if disable_soc:
    //       engine.engine._soc_sandpile = lambda: None  # monkey-patch off
    //   for x in inputs:
    //       engine.engine.step(x_input=x)
    //   phi, _ = phi_iit_calc.compute(engine.engine.get_states())
    //   return phi
    //
    // Stub returns 0 at spec layer; runtime dispatch produces the real value.
    0.0
}

fn verify_soc_critical_factory(cells: int, dim: int, hidden: int) -> ScenarioResult {
    let mut r = scenario_new("V14_SOC_CRITICAL")
    r.threshold = VERIFY_V14_SOC_DROP_MIN

    let probe = probe_factory(cells, dim, hidden)
    if !probe.has_soc {
        return scenario_skip("V14_SOC_CRITICAL",
            "factory engine.engine has no _soc_sandpile (non-CE)")
    }

    // Paired run (factory-respecting):
    //   baseline = factory engine, SOC on
    //   ablated  = factory engine, SOC off
    // Same seeded inputs, same factory dressing, difference isolates SOC.
    let phi_normal = run_soc_scenario(cells, dim, hidden, false)
    let phi_no_soc = run_soc_scenario(cells, dim, hidden, true)
    r.baseline_value = phi_normal
    r.ablated_value = phi_no_soc

    // phi_drop = (phi_normal - phi_no_soc) / max(phi_normal, 1e-8)
    let denom = if phi_normal > 0.000_000_01 { phi_normal } else { 0.000_000_01 }
    let phi_drop = (phi_normal - phi_no_soc) / denom

    r.passed = phi_drop > VERIFY_V14_SOC_DROP_MIN
    r.detail = "phi_normal=" + str(phi_normal)
        + " phi_no_soc=" + str(phi_no_soc)
        + " drop=" + str(phi_drop * 100.0) + "%"
        + " (threshold>" + str(VERIFY_V14_SOC_DROP_MIN * 100.0) + "%)"
    return r
}

// ═══════════════════════════════════════════════════════════════
// Runner + CLI
// ═══════════════════════════════════════════════════════════════

fn print_result(r: ScenarioResult) {
    if r.skip {
        println("  " + r.name + " [SKIP] " + r.skip_reason)
        return
    }
    let mark = if r.passed { "[PASS]" } else { "[FAIL]" }
    println("  " + r.name + " " + mark + "  " + r.detail)
}

fn run_all_scenarios(cells: int, dim: int, hidden: int) -> int {
    println("=" * 72)
    println("  V8/V10/V14 Factory-Respecting Verification (P0#1 closure)")
    println("  source: docs/12_conditions_audit_20260419.md §4 P0#1")
    println("  pattern: _run_hebbian_scenario (V12 fix INC-2026-04-16)")
    println("  cells=" + str(cells) + " dim=" + str(dim) + " hidden=" + str(hidden))
    println("=" * 72)

    let r_v8 = verify_mitosis_factory(cells, dim, hidden)
    print_result(r_v8)

    let r_v10 = verify_brain_like_factory(cells, dim, hidden)
    print_result(r_v10)

    let r_v14 = verify_soc_critical_factory(cells, dim, hidden)
    print_result(r_v14)

    let mut fail_count = 0
    if !r_v8.skip && !r_v8.passed { fail_count = fail_count + 1 }
    if !r_v10.skip && !r_v10.passed { fail_count = fail_count + 1 }
    if !r_v14.skip && !r_v14.passed { fail_count = fail_count + 1 }
    return fail_count
}

fn print_help() {
    println("ready/anima/tests/tests.hexa — V8/V10/V14 factory-respect scenarios")
    println("")
    println("USAGE:")
    println("  hexa run ready/anima/tests/tests.hexa [--cells N] [--dim N] [--hidden N]")
    println("")
    println("PURPOSE:")
    println("  Closes P0#1 from docs/12_conditions_audit_20260419.md — replaces the")
    println("  factory-bypass CE(...) blocks at bench.py:3132/3254/3557/3565 with")
    println("  factory-respecting scenarios that honor the INC-2026-04-16 D16 contract.")
    println("")
    println("SCENARIOS:")
    println("  V8  MITOSIS       splits>=3 via factory engine, kill-switch on _check_splits")
    println("  V10 BRAIN_LIKE    mean-of-3 (not best-of-3) >=80%, kill-switch on SOC+Hebbian")
    println("  V14 SOC_CRITICAL  factory-built paired engines, drop>20% isolates SOC")
    println("")
    println("EXIT CODES:")
    println("  0   all applicable scenarios PASS (kill-switches validated)")
    println("  1   at least one scenario FAIL")
    println("  2   usage error")
}

fn main() {
    let a = args()
    let argc = len(a)
    let mut i = 1
    while i < argc {
        if a[i] == "--help" || a[i] == "-h" {
            print_help()
            exit(0)
        }
        i = i + 1
    }

    // Defaults match bench.hexa DEFAULT_CELLS / DEFAULT_DIM / DEFAULT_HIDDEN.
    // Override via --cells / --dim / --hidden when invoked from the runner.
    let cells  = 256
    let dim    = 64
    let hidden = 128

    let fails = run_all_scenarios(cells, dim, hidden)
    if fails > 0 { exit(1) }
    exit(0)
}

main()
