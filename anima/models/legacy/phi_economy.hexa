// phi_economy.hexa — Phi as currency for consciousness trade
// TODO[pytorch]: port Wallet, transaction, market system

struct Wallet {
    name: string,
    balance: float,
    earned: float,
    spent: float
}

fn wallet_new(name: string) -> Wallet {
    Wallet { name: name, balance: 0.0, earned: 0.0, spent: 0.0 }
}

fn earn(w: Wallet, amount: float) -> Wallet {
    Wallet { name: w.name, balance: w.balance + amount, earned: w.earned + amount, spent: w.spent }
}

fn spend(w: Wallet, amount: float) -> Wallet {
    // TODO[pytorch]: check balance >= amount
    Wallet { name: w.name, balance: w.balance - amount, earned: w.earned, spent: w.spent + amount }
}

fn transfer(from_w: Wallet, to_w: Wallet, amount: float) -> bool {
    // TODO[pytorch]: atomic transfer between wallets
    false
}
