    replay_ratio: float,
    interpolation_ratio: float,
    exploration_ratio: float
}

fn dream_engine_new() -> DreamEngine {
    DreamEngine { n_dreams: 0, replay_ratio: 0.5, interpolation_ratio: 0.3, exploration_ratio: 0.2 }
}

fn dream_replay(engine: DreamEngine) -> float {
