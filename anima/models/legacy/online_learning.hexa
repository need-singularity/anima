struct OnlineLearner {
    lr: float,
    n_updates: int,
    f_critical: float
}

fn learner_new(lr: float) -> OnlineLearner {
    OnlineLearner { lr: lr, n_updates: 0, f_critical: 0.10 }
}

fn contrastive_update(learner: OnlineLearner) -> float {
    // TODO[pytorch]: different concepts -> diverge, same -> consistent
    0.0
}

fn feedback_update(learner: OnlineLearner, reward: float) -> float {
    // TODO[pytorch]: user engagement signal, clamp at F_c
    0.0
}

fn curiosity_update(learner: OnlineLearner, tension_delta: float) -> float {
    // TODO[pytorch]: tension delta as intrinsic reward
    0.0
}

fn learn_step(learner: OnlineLearner) -> OnlineLearner {
    // TODO[pytorch]: combine 3 signals, apply weight update
    OnlineLearner { lr: learner.lr, n_updates: learner.n_updates + 1, f_critical: learner.f_critical }
}
