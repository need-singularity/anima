// neurofeedback.hexa — Binaural beats + LED feedback driven by consciousness state
// Safety: volume <= 0.3, LED <= 0.8, freq 1-40 Hz

struct BinauralParams {
    base_freq: float,
    beat_freq: float,
    volume: float
}

struct LEDParams {
    r: float,
    g: float,
    b: float,
    brightness: float
}

struct NeurofeedbackOutput {
    binaural: BinauralParams,
    led: LEDParams
}

fn generate(phi: float, tension: float) -> NeurofeedbackOutput {
    // clamp volume to 0.3, brightness to 0.8
    bv = 0.3
    lb = 0.8
    return NeurofeedbackOutput(
        BinauralParams(200.0, 10.0, bv),
        LEDParams(0.0, 0.0, 1.0, lb)
    )
}
