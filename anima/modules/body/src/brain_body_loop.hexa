// brain_body_loop.hexa — Brain-Body triangle loop
// EEG(brain) -> Anima(consciousness) -> Body(motor) -> sensory -> EEG

struct TriangleLoopConfig {
    eeg_board: string,
    body_adapter: string,
    duration_sec: i32
}

struct TriangleLoopResult {
    phi_mean: float,
    motor_events: i32,
    sensory_events: i32,
    loop_latency_ms: float
}

fn run_triangle_loop(config: TriangleLoopConfig) -> TriangleLoopResult {
    print("brain-body loop: " + to_string(config.duration_sec) + "s")
    return TriangleLoopResult(0.0, 0, 0, 0.0)
}
