fn print_architecture() {
    println("────────────────────────────────────────────────────────────")
    println(" Streaming Architecture:")
    println("")
    println("   ConsciousnessEngine (10ms ticks)")
    println("         |")
    println("         v")
    println("   ┌─────────────────────────────────────────────┐")
    println("   │  StreamingSession                           │")
    println("   │                                             │")
    println("   │  ┌──────────┐   ┌────────────────────────┐  │")
    println("   │  │ VAD FSM  │   │ ChunkScheduler         │  │")
    println("   │  │          │   │                        │  │")
    println("   │  │ SILENCE  │   │ IDLE -> PREFILL (60ms) │  │")
    println("   │  │    |     │   │   -> FIRST_EMIT(100ms) │  │")
    println("   │  │ SP_START │   │   -> STREAMING (120ms) │  │")
    println("   │  │    |     │   └────────────────────────┘  │")
    println("   │  │ SPEAKING │              |                │")
    println("   │  │    |     │              v                │")
    println("   │  │ SP_END   │   ┌────────────────────────┐  │")
    println("   │  │    |     │   │ RingBuffer (36 chunks)  │  │")
    println("   │  │ SILENCE  │   │ write -> [||||||||] -> read│")
    println("   │  └──────────┘   └────────────────────────┘  │")
    println("   │       |                    |                │")
    println("   │       v                    v                │")
    println("   │  ┌─────────────────────────────────────┐    │")
    println("   │  │ BackpressureController              │    │")
    println("   │  │ NORMAL <-> THROTTLE (high/low mark) │    │")
    println("   │  └─────────────────────────────────────┘    │")
    println("   └─────────────────────────────────────────────┘")
    println("         |")
    println("         v")
    println("   Audio Sink (speaker / rtp / file)")
    println("")
    println("   First packet: 100ms budget")
    println("   ├── 0-60ms:   prefill (vocoder lookahead)")
    println("   ├── 60-100ms: generate + emit first packet")
    println("   └── 120ms+:   normal 12-frame chunk stream")
    println("")
    println("   Hangover: " + to_string(VAD_HANGOVER_FRAMES * 1000 / FRAME_HZ) + "ms (prevents mid-word cutoff)")
    println("   Backpressure: throttle at " + to_string(BACKPRESSURE_HIGH) + "/" + to_string(RING_CAPACITY) + " chunks, resume at " + to_string(BACKPRESSURE_LOW) + "/" + to_string(RING_CAPACITY))
    println("")
}

