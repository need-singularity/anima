    println("  Prefill:     " + to_string(PREFILL_FRAMES) + " frames = " + to_string(compute_prefill_budget_ms()) + "ms (vocoder lookahead)")
    println("  Generation:  " + to_string(compute_generation_budget_ms()) + "ms (remaining for first packet)")
    println("  First emit:  " + to_string(FIRST_PACKET_FRAMES) + " frames = " + to_string(FIRST_PACKET_FRAMES * 1000 / FRAME_HZ) + "ms audio")
    println("  Then:        " + to_string(CHUNK_FRAMES) + "-frame chunks = " + to_string(CHUNK_FRAMES * 1000 / FRAME_HZ) + "ms each")
    println("")
    println("  Timeline:")
    println("    t=0ms         consciousness intent arrives")
    println("    t=0-60ms      prefill " + to_string(PREFILL_FRAMES) + " frames (vocoder warmup)")
    println("    t=60-100ms    generate remaining frames")
    println("    t=100ms       FIRST PACKET EMITTED (deadline)")
    println("    t=120ms+      normal " + to_string(CHUNK_FRAMES) + "-frame chunk streaming")
    println("")
}

