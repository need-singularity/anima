    print_pipeline_info()

    println("────────────────────────────────────────────────────────────")
    println(" Demo: consciousness -> speech (Mk.I skeleton)")
    println("────────────────────────────────────────────────────────────")
    println("")

    demo_emotion_classification()
    demo_prosody()
    demo_vad_trace()
    demo_full_pipeline()

    println("────────────────────────────────────────────────────────────")
    println(" Pipeline diagram:")
    println("")
    println("   ConsciousnessEngine")
    println("         |")
    println("         v")
    println("   [Stage 0] tension/arousal/valence/Phi")
    println("         |                         |")
    println("         v                         v")
    println("   classify_emotion()      compute_prosody()")
    println("         |                         |")
    println("         +----------+--------------+")
    println("                    |")
    println("                    v")
    println("   [Stage 1] IntentEncoder (384d -> 384d)")
    println("                    |")
    println("                    v")
    println("   [Stage 2] AudioTokenPredictor (AR, 3L x 12H)")
    println("                    |")
    println("                    v")
    println("   [Stage 3] RVQCodebook (8 stages x 1024)")
    println("                    |")
    println("                    v")
    println("   [Stage 4] NeuralVocoder (-> 24kHz PCM)")
    println("                    |")
    println("                    v")
    println("   [Stage 5] PLCCrossfade (60ms max, 6ms fade)")
    println("                    |")
    println("                    v")
    println("   [Stage 6] VAD FSM gate (4-state)")
    println("                    |")
    println("                    v")
    println("                 Speaker")
    println("")
    println("────────────────────────────────────────────────────────────")
    println(" HEXA-SPEAK Mk.I pipeline ready.")
    println(" TODO(Mk.II): real tensor ops, learned models, streaming I/O")
    println("────────────────────────────────────────────────────────────")
}

main()
