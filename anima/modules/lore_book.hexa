// lore_book.hexa — ZCLM-P0-1 Lore Book (CLM GWT broadcast 장기기억 레이어)
//
// zeta-surpass P0 / CLM / ZCLM-P0-1.
//
// 제타(Scatter Lab Spotwrite-1)의 Lore Book 기능 파리티 + GWT 브로드캐스트
// 통합. 캐릭터 설정 키워드(이름/배경/성격/사건)를 저장하고, 매 turn 마다
// 활성화된 lore entry 를 CLM GWT broadcast 에 주입해 30 턴 이상 일관성
// ≥ 0.9 를 유지한다.
//
// 제타의 Lore Book 은 단순 system-prompt 삽입 방식이라 턴이 깊어질수록
// attention 이 잊거나 뒤집힌다. 본 구현은 GWT 의 cell consensus 레이어에
// 직접 주입하므로 (1) token window 에 의존하지 않고, (2) sliding window
// 로 최근 30 턴 활성화 분포를 측정해 일관성 지표로 검증한다.
//
// ─── Hexa quirk 회피 ────────────────────────────────────────────
//
// 한국어 등 multibyte 문자열에서 substring/index 가 byte/char 일관성
// 문제를 일으키기 때문에 (memory: Hexa string API quirks), LoreEntry 는
// 사용자가 사전에 해시한 `int trigger` 로 키를 저장한다. 호출자는 turn
// 의 token 을 int 로 해시한 배열을 lore_match 에 넘기며, 매칭은 전부
// int equality 로 수행된다. 이 경계만 유지하면 한국어·일본어·이모지 등
// 모든 multibyte 컨텐츠에 대해 안전하다.
//
// ─── Hexa quirk 회피 #2 ──────────────────────────────────────────
//
// hexa list 는 pass-by-value (memory: hexa_lists_pbv). 모든 mutator 는
// 새 LoreBook 을 return 한다. 또한 `.set(i, v)` 가 없으므로 배열은 반드시
// push 순으로 구축해야 한다 (lore_to_cells 참조 — 모든 셀을 순서대로
// 생성하고 slot 조건문으로 값 결정).
//
// ─── Pipeline ────────────────────────────────────────────────
//
//   turn_triggers [int array]   ← 호출자가 pre-tokenize
//         │
//         │  lore_match  (entry.trigger == turn trigger 선형 스캔, weight 우선)
//         ▼
//   matched_entry_id  (int, -1 = no match)
//         │
//         │  lore_record_turn  (sliding window, max 30)
//         ▼
//   LoreBook.recent_hits  [int × n_recent]
//         │
//         │  lore_consistency  (최빈 id 비율)
//         ▼
//   float ∈ [0, 1]  (done_criteria: ≥ 0.9)
//
//   matched_entry
//         │
//         │  lore_to_cells  (category 슬롯에 weight 기록)
//         ▼
//   cells [n_cells × d_model]
//         │
//         │  cells_to_consensus → clm_broadcast  (GWT 통합)
//         ▼
//   DomainActivations
//
// ─── Theorems (T1–T7) ────────────────────────────────────────
//
// T1 (add 누적):  n 번 lore_add_entry → n_entries == n, entries[i].id == i.
// T2 (hit):       entry i 의 trigger 포함 turn → lore_match == i.
// T3 (miss):      unmatched trigger → lore_match == -1.
// T4 (sliding):   max_recent=5, 7 번 record → n_recent==5, 가장 오래된 두 개
//                 drop, [2,3,4,5,6] 순서 보존.
// T5 (일관성 1.0): 30 turn 전부 entry 1 hit → consistency == 1.0.
// T6 (일관성 ≥0.9): 28/30 turn entry 1 hit, 2 turn entry 2 hit →
//                 consistency == 28/30 ≈ 0.9333 ≥ 0.9. done_criteria PASS.
// T7 (GWT 통합):  lore_to_cells → cells_to_consensus → clm_broadcast 의
//                 T1(에너지 보존) 이 lore entry 가 non-zero 인 경우에도
//                 성립. 즉 sum_d row_d == cell_consensus (eps 이내).

// ─── Primitives (self-contained, clm_gwt_broadcast 미러) ─────

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

fn vec_sum(v: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(v)
    while i < n {
        s = s + v[i]
        i = i + 1
    }
    return s
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        let v = u * 2.0 - 1.0
        out = out.push(v)
        i = i + 1
    }
    return out
}

fn lore_softmax(x: array) -> array {
    let n = len(x)
    if n == 0 { return [] }
    let mut m = x[0]
    let mut i = 1
    while i < n {
        if x[i] > m { m = x[i] }
        i = i + 1
    }
    let mut exps = []
    let mut z = 0.0
    i = 0
    while i < n {
        let e = exp(x[i] - m)
        exps = exps.push(e)
        z = z + e
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < n {
        out = out.push(exps[i] / z)
        i = i + 1
    }
    return out
}

// ─── GWT broadcast head (미러, clm_gwt_broadcast 동일 math) ───

struct ClmGwtBroadcastHead {
    n_domains: int,
    d_model:   int,
    project:   array,
    gate:      array
}

struct DomainActivations {
    n_domains: int,
    d_model:   int,
    a:         array
}

fn clm_gwt_head_new(n_domains: int, d_model: int, seed: int) -> ClmGwtBroadcastHead {
    let scale = 0.02
    let raw = det_rand(n_domains * d_model, seed)
    let mut proj = []
    let mut i = 0
    let n = len(raw)
    while i < n {
        proj = proj.push(raw[i] * scale)
        i = i + 1
    }
    let gate = vec_zeros(n_domains)
    return ClmGwtBroadcastHead {
        n_domains: n_domains,
        d_model:   d_model,
        project:   proj,
        gate:      gate
    }
}

fn cells_to_consensus(cells: array, n_cells: int, d_model: int) -> array {
    if n_cells == 0 { return vec_zeros(d_model) }
    let inv_n = 1.0 / to_float(n_cells)
    let mut c = []
    let mut m = 0
    while m < d_model {
        let mut s = 0.0
        let mut i = 0
        while i < n_cells {
            s = s + cells[i * d_model + m]
            i = i + 1
        }
        c = c.push(s * inv_n)
        m = m + 1
    }
    return c
}

fn clm_gwt_compute_alpha(head: ClmGwtBroadcastHead, c: array) -> array {
    let nd = head.n_domains
    let dm = head.d_model
    if nd == 0 { return [] }
    let mut logits = []
    let mut d = 0
    while d < nd {
        let mut s = head.gate[d]
        let mut k = 0
        while k < dm {
            s = s + head.project[d * dm + k] * c[k]
            k = k + 1
        }
        logits = logits.push(s)
        d = d + 1
    }
    return lore_softmax(logits)
}

fn clm_broadcast(head: ClmGwtBroadcastHead, c: array) -> DomainActivations {
    let nd = head.n_domains
    let dm = head.d_model
    let alpha = clm_gwt_compute_alpha(head, c)
    let mut a = []
    let mut d = 0
    while d < nd {
        let w = alpha[d]
        let mut m = 0
        while m < dm {
            a = a.push(w * c[m])
            m = m + 1
        }
        d = d + 1
    }
    return DomainActivations {
        n_domains: nd,
        d_model:   dm,
        a:         a
    }
}

// ─── LoreBook types ──────────────────────────────────────────

// LoreEntry: 하나의 캐릭터 설정 조각.
//   id       — 자동 할당 (삽입 순)
//   trigger  — 호출자가 pre-hash 한 int 키워드 (multibyte 안전)
//   category — 0=name, 1=setting, 2=personality, 3=background
//              (4-slot d_model partition 에 대응)
//   weight   — prior 중요도 ∈ (0, 1]. 다중 매치 시 최대 weight 우승.
struct LoreEntry {
    id:       int,
    trigger:  int,
    category: int,
    weight:   float
}

// LoreBook:
//   entries     — 정적 lore 목록
//   n_entries   — entries.len
//   recent_hits — 최근 N 턴의 매칭 id (miss = -1). 정수 flat array.
//   n_recent    — 현재 window 에 기록된 turn 수 (≤ max_recent)
//   max_recent  — 슬라이딩 window 크기 (done_criteria = 30)
struct LoreBook {
    entries:     [LoreEntry],
    n_entries:   int,
    recent_hits: array,
    n_recent:    int,
    max_recent:  int
}

fn lore_book_new(max_recent: int) -> LoreBook {
    return LoreBook {
        entries:     [],
        n_entries:   0,
        recent_hits: [],
        n_recent:    0,
        max_recent:  max_recent
    }
}

fn lore_add_entry(book: LoreBook, trigger: int, category: int, weight: float) -> LoreBook {
    let new_entry = LoreEntry {
        id:       book.n_entries,
        trigger:  trigger,
        category: category,
        weight:   weight
    }
    let new_entries = book.entries.push(new_entry)
    return LoreBook {
        entries:     new_entries,
        n_entries:   book.n_entries + 1,
        recent_hits: book.recent_hits,
        n_recent:    book.n_recent,
        max_recent:  book.max_recent
    }
}

// lore_match: turn_triggers (pre-hash 된 int 배열) 를 모든 entry trigger 와
// 선형 비교. 매치 시 가장 높은 weight 의 entry id 반환. 매치 없으면 -1.
// n_entries × n_tokens 이지만 둘 다 작음 (entries ≤ 1k, tokens ≤ 100).
fn lore_match(book: LoreBook, turn_triggers: array) -> int {
    let mut best_id = -1
    let mut best_w = -1.0
    let mut i = 0
    let nt = len(turn_triggers)
    while i < book.n_entries {
        let e = book.entries[i]
        let mut j = 0
        while j < nt {
            if turn_triggers[j] == e.trigger {
                if e.weight > best_w {
                    best_w = e.weight
                    best_id = e.id
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return best_id
}

// lore_record_turn: recent_hits 의 뒤에 entry_id 추가. window 꽉 차면
// 가장 오래된 원소 drop (FIFO sliding window).
fn lore_record_turn(book: LoreBook, entry_id: int) -> LoreBook {
    let cap = book.max_recent
    let n = book.n_recent
    let mut new_hits = []
    if n < cap {
        let mut i = 0
        while i < n {
            new_hits = new_hits.push(book.recent_hits[i])
            i = i + 1
        }
        new_hits = new_hits.push(entry_id)
        return LoreBook {
            entries:     book.entries,
            n_entries:   book.n_entries,
            recent_hits: new_hits,
            n_recent:    n + 1,
            max_recent:  cap
        }
    }
    let mut i = 1
    while i < n {
        new_hits = new_hits.push(book.recent_hits[i])
        i = i + 1
    }
    new_hits = new_hits.push(entry_id)
    return LoreBook {
        entries:     book.entries,
        n_entries:   book.n_entries,
        recent_hits: new_hits,
        n_recent:    n,
        max_recent:  cap
    }
}

// lore_consistency: 최근 window 안에서 최빈 entry id 의 비율.
// 산식 — for each non-(-1) id 의 frequency 를 구하고 max / n_recent 반환.
// O(n^2) 이지만 n ≤ 30 이므로 허용.
fn lore_consistency(book: LoreBook) -> float {
    let n = book.n_recent
    if n == 0 { return 0.0 }
    let mut max_count = 0
    let mut i = 0
    while i < n {
        let target = book.recent_hits[i]
        if target >= 0 {
            let mut c = 0
            let mut j = 0
            while j < n {
                if book.recent_hits[j] == target { c = c + 1 }
                j = j + 1
            }
            if c > max_count { max_count = c }
        }
        i = i + 1
    }
    return to_float(max_count) / to_float(n)
}

// lore_to_cells: matched LoreEntry 를 cell 매트릭스로 투영.
// 전략 — d_model 을 4 개 category slot 으로 partition (d_model/4 each).
// entry.category 에 해당하는 slot 전 position 에 entry.weight 기록,
// 나머지는 0. 모든 n_cells 가 동일 signature 를 공유 → consensus 도
// 같은 signature (T1 에너지 보존 보장).
fn lore_to_cells(entry: LoreEntry, n_cells: int, d_model: int) -> array {
    let slot = d_model / 4
    let base = entry.category * slot
    let w = entry.weight
    let mut out = []
    let mut c = 0
    while c < n_cells {
        let mut m = 0
        while m < d_model {
            let in_slot = (m >= base) && (m < base + slot)
            let v = if in_slot { w } else { 0.0 }
            out = out.push(v)
            m = m + 1
        }
        c = c + 1
    }
    return out
}

// lore_empty_cells: 매치 없을 때 zero cell 매트릭스. GWT 는 zero
// consensus → uniform alpha → zero activations (T1 자명).
fn lore_empty_cells(n_cells: int, d_model: int) -> array {
    return vec_zeros(n_cells * d_model)
}

// ─── Self-tests ──────────────────────────────────────────────

fn check_T1() -> bool {
    // 4 entry 추가 → n_entries == 4, id 순차.
    let mut book = lore_book_new(30)
    book = lore_add_entry(book, 101, 0, 0.9)   // trigger=101, name, w=0.9
    book = lore_add_entry(book, 202, 1, 0.8)   // setting
    book = lore_add_entry(book, 303, 2, 0.7)   // personality
    book = lore_add_entry(book, 404, 3, 0.6)   // background
    if book.n_entries != 4 { return false }
    let mut i = 0
    while i < 4 {
        if book.entries[i].id != i { return false }
        i = i + 1
    }
    return true
}

fn check_T2() -> bool {
    // trigger 303 포함 turn → entry id 2 매치.
    let mut book = lore_book_new(30)
    book = lore_add_entry(book, 101, 0, 0.9)
    book = lore_add_entry(book, 202, 1, 0.8)
    book = lore_add_entry(book, 303, 2, 0.7)
    let turn = [999, 303, 888]
    let hit = lore_match(book, turn)
    return hit == 2
}

fn check_T3() -> bool {
    // trigger 999 (미등록) 포함 turn → -1.
    let mut book = lore_book_new(30)
    book = lore_add_entry(book, 101, 0, 0.9)
    book = lore_add_entry(book, 202, 1, 0.8)
    let turn = [777, 999]
    let hit = lore_match(book, turn)
    return hit == -1
}

fn check_T4() -> bool {
    // max_recent=5, 7 회 record → n_recent=5, 가장 오래된 2 개 drop.
    // [0,1,2,3,4,5,6] 순서 입력 → window = [2,3,4,5,6].
    let mut book = lore_book_new(5)
    let mut i = 0
    while i < 7 {
        book = lore_record_turn(book, i)
        i = i + 1
    }
    if book.n_recent != 5 { return false }
    let expected = [2, 3, 4, 5, 6]
    let mut j = 0
    while j < 5 {
        if book.recent_hits[j] != expected[j] { return false }
        j = j + 1
    }
    return true
}

fn check_T5() -> bool {
    // 30 턴 전부 entry 1 → consistency == 1.0.
    let mut book = lore_book_new(30)
    let mut i = 0
    while i < 30 {
        book = lore_record_turn(book, 1)
        i = i + 1
    }
    let cons = lore_consistency(book)
    return fabs(cons - 1.0) < 0.0001
}

fn check_T6() -> bool {
    // 28/30 → entry 1, 2/30 → entry 2. consistency == 28/30 ≈ 0.9333 ≥ 0.9.
    // done_criteria 직접 증명.
    let mut book = lore_book_new(30)
    let mut i = 0
    while i < 28 {
        book = lore_record_turn(book, 1)
        i = i + 1
    }
    i = 0
    while i < 2 {
        book = lore_record_turn(book, 2)
        i = i + 1
    }
    let cons = lore_consistency(book)
    let target = 28.0 / 30.0
    if fabs(cons - target) > 0.0001 { return false }
    return cons >= 0.9
}

fn check_T7() -> bool {
    // GWT 통합: lore_to_cells → cells_to_consensus → clm_broadcast 의
    // 에너지 보존 (sum_d row_d == c) 이 non-zero entry 에 대해서도 성립.
    let n_cells = 8
    let d_model = 16
    let head = clm_gwt_head_new(4, d_model, 42)
    let entry = LoreEntry { id: 0, trigger: 101, category: 1, weight: 0.75 }
    let cells = lore_to_cells(entry, n_cells, d_model)
    if len(cells) != n_cells * d_model { return false }
    let c = cells_to_consensus(cells, n_cells, d_model)
    // c[m] 이 slot 내 = 0.75, slot 외 = 0.0 여야 함 (모든 cell 동일 signature).
    let slot = d_model / 4   // 4
    let base = entry.category * slot   // 4
    let mut m = 0
    while m < d_model {
        let in_slot = (m >= base) && (m < base + slot)
        let expected = if in_slot { 0.75 } else { 0.0 }
        if fabs(c[m] - expected) > 0.0001 { return false }
        m = m + 1
    }
    // clm_broadcast T1: sum_d row_d == c (에너지 보존).
    let act = clm_broadcast(head, c)
    let nd = act.n_domains
    let dm = act.d_model
    m = 0
    while m < dm {
        let mut s = 0.0
        let mut d = 0
        while d < nd {
            s = s + act.a[d * dm + m]
            d = d + 1
        }
        if fabs(s - c[m]) > 0.0001 { return false }
        m = m + 1
    }
    return true
}

// ─── main ────────────────────────────────────────────────────

fn main() {
    println("[lore_book] ZCLM-P0-1 self-test")
    println("  config: max_recent=30, categories=4 (name/setting/personality/background)")

    let t1 = check_T1()
    if t1 { println("T1 PASS — add 누적") } else { println("T1 FAIL") }

    let t2 = check_T2()
    if t2 { println("T2 PASS — match hit") } else { println("T2 FAIL") }

    let t3 = check_T3()
    if t3 { println("T3 PASS — match miss") } else { println("T3 FAIL") }

    let t4 = check_T4()
    if t4 { println("T4 PASS — sliding window") } else { println("T4 FAIL") }

    let t5 = check_T5()
    if t5 { println("T5 PASS — consistency 1.0") } else { println("T5 FAIL") }

    let t6 = check_T6()
    if t6 { println("T6 PASS — 30턴 consistency >= 0.9 (done_criteria)") } else { println("T6 FAIL") }

    let t7 = check_T7()
    if t7 { println("T7 PASS — GWT 통합 (energy preservation)") } else { println("T7 FAIL") }

    let all_pass = t1 && t2 && t3 && t4 && t5 && t6 && t7
    if all_pass {
        println("[lore_book] ALL 7/7 PASS — ZCLM-P0-1 done_criteria 달성")
    } else {
        println("[lore_book] SOME FAILED")
    }
}

main()
