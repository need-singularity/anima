// Ported from launch.sh
// Anima Launch — 전부 한 방에 | Load environment variables
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "launch.sh"

    // Anima Launch — 전부 한 방에

    shell("ANIMA_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"")
    shell("cd \"$ANIMA_DIR\"")

    shell("export KMP_DUPLICATE_LIB_OK=TRUE")

    // Load environment variables
    shell("[ -f \"$ANIMA_DIR/.local/.env\" ] && set -a && source \"$ANIMA_DIR/.local/.env\" && set +a")
    shell("[ -f \"$ANIMA_DIR/.env\" ] && set -a && source \"$ANIMA_DIR/.env\" && set +a")

    shell("echo \"==================================================\"")
    shell("echo \"  Anima — Full Launch\"")
    shell("echo \"==================================================\"")

    // ─── Dependency Check ───
    shell("echo \"\"")
    shell("echo \"  Checking dependencies...\"")
    shell("FAIL=0")

    shell("check() {")
    shell("if python3 -c \"$2\" 2>/dev/null; then")
    shell("echo \"  [OK] $1\"")
    shell("else")
    shell("echo \"  [!!] $1 — $3\"")
    shell("FAIL=1")
    shell("fi")
    shell("}")

    shell("check \"torch\"      \"import torch\"           \"pip3 install --break-system-packages torch\"")
    shell("check \"websockets\" \"import websockets\"       \"pip3 install --break-system-packages websockets\"")
    shell("check \"numpy\"      \"import numpy\"            \"brew install numpy && brew link --overwrite numpy\"")
    shell("check \"cv2\"        \"import cv2\"              \"brew reinstall opencv\"")

    // CLI tools
    shell("for cmd in claude whisper-cli; do")
    shell("if command -v $cmd &>/dev/null; then")
    shell("echo \"  [OK] $cmd\"")
    shell("else")
    shell("echo \"  [!!] $cmd — not found\"")
    shell("FAIL=1")
    shell("fi")
    shell("done")

    // Camera test
    shell("CAM=$(python3 -c \"")
    shell("import cv2")
    shell("cap = cv2.VideoCapture(0)")
    shell("print('ok' if cap.isOpened() else 'denied')")
    shell("cap.release()")
    shell("\" 2>/dev/null || echo \"fail\")")

    // R2 Cloud
    shell("if [ -n \"$ANIMA_R2_ENDPOINT\" ]; then")
    shell("echo \"  [OK] R2 cloud ($ANIMA_R2_BUCKET)\"")
    shell("else")
    shell("echo \"  [--] R2 cloud (ANIMA_R2_* 환경변수 없음)\"")
    shell("fi")

    shell("if [ \"$CAM\" = \"ok\" ]; then")
    shell("echo \"  [OK] camera\"")
    shell("else")
    shell("echo \"  [!!] camera — 시스템 설정 → 개인정보 → 카메라 → Terminal 허용\"")
    shell("fi")

    // Whisper model
    shell("MODEL=\"/tmp/ggml-base.bin\"")
    shell("if [ -f \"$MODEL\" ]; then")
    shell("echo \"  [OK] whisper model\"")
    shell("else")
    shell("echo \"  [DL] whisper model downloading...\"")
    shell("curl -sL \"https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.bin\" -o \"$MODEL\"")
    shell("echo \"  [OK] whisper model\"")
    shell("fi")

    shell("if [ \"$FAIL\" -eq 1 ]; then")
    shell("echo \"\"")
    shell("echo \"  Fix the issues above, then re-run.\"")
    shell("exit 1")
    shell("fi")

    // ─── Rust VAD build (if not built) ───
    shell("if [ -d \"$ANIMA_DIR/vad-rs\" ]; then")
    shell("if [ ! -f \"$ANIMA_DIR/vad-rs/target/release/anima-vad\" ]; then")
    shell("echo \"\"")
    shell("echo \"  Building Rust VAD...\"")
    shell("(cd \"$ANIMA_DIR/vad-rs\" && cargo build --release 2>/dev/null) &")
    shell("VAD_PID=$!")
    shell("fi")
    shell("fi")

    // ─── Launch ───
    shell("echo \"\"")
    shell("echo \"  Launching Anima (all modules)...\"")
    shell("echo \"  Web:  http://localhost:8765\"")
    shell("echo \"  Voice: always listening\"")
    shell("echo \"  Camera: active\"")
    shell("echo \"  Press Ctrl+C to stop\"")
    shell("echo \"==================================================\"")
    shell("echo \"\"")

    shell("exec python3 \"$ANIMA_DIR/anima_unified.py\" --all \"$@\"")
}
