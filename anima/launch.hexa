// anima/launch.hexa — Anima Full Launch (hexa-native, no shell trampoline)
//
// Usage:
//   $HEXA anima/launch.hexa [args...]
//
// Single hexa-native entrypoint that loads env, verifies deps, then runs
// anima/core/runtime/anima_runtime.hexa --all.

fn main() {
    let args = get_args()
    let args_str = args.join(" ")

    println("==================================================")
    println("  Anima — Full Launch (hexa-native)")
    println("==================================================")

    // ─── Environment ───
    let anima_dir = env_get("ANIMA_DIR", pwd())
    env_set("KMP_DUPLICATE_LIB_OK", "TRUE")

    // Load .env files if present (hexa-native dotenv)
    load_dotenv(anima_dir + "/.local/.env")
    load_dotenv(anima_dir + "/.env")

    // ─── Dependency check (hexa runtime + binaries) ───
    println("")
    println("  Checking dependencies...")
    var fail = false

    // Hexa runtime self-check
    let hexa_bin = env_get("HEXA", "/usr/local/bin/hexa")
    if !file_exists(hexa_bin) {
        println("  [!!] hexa binary missing at " + hexa_bin)
        fail = true
    } else {
        println("  [OK] hexa")
    }

    // External CLI tools
    for cmd in ["claude", "whisper-cli"] {
        if !command_exists(cmd) {
            println("  [!!] " + cmd + " — not found")
            fail = true
        } else {
            println("  [OK] " + cmd)
        }
    }

    // R2 cloud
    if env_get("ANIMA_R2_ENDPOINT", "") != "" {
        println("  [OK] R2 cloud (" + env_get("ANIMA_R2_BUCKET", "") + ")")
    } else {
        println("  [--] R2 cloud (ANIMA_R2_* unset)")
    }

    // Whisper model (cached)
    let model = "/tmp/ggml-base.bin"
    if !file_exists(model) {
        println("  [DL] whisper model downloading...")
        http_download("https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.bin", model)
    }
    println("  [OK] whisper model")

    if fail {
        println("")
        println("  Fix the issues above, then re-run.")
        exit(1)
    }

    // ─── Launch ───
    println("")
    println("  Launching Anima (all modules)...")
    println("  Web:    http://localhost:8765")
    println("  Voice:  always listening")
    println("  Camera: active")
    println("  Press Ctrl+C to stop")
    println("==================================================")
    println("")

    // Hexa-native runtime is the single entrypoint
    exec(hexa_bin, [anima_dir + "/anima/core/runtime/anima_runtime.hexa", "--all"] ++ args)
}
