// fix_72B_overfit.hexa — 72B overfitting diagnosis + 4x4090 FSDP training config
//
// ══════════════════════════════════════════════════════════════════
// Problem:
//   AnimaLM 72B v0.5 (Qwen2.5-72B + PureField, QLoRA r128) overfitted
//   at step 6450/10000 on 2x H100 SXM:
//     - CE(train) = 2.42 at step 5000
//     - CE(val)   = 5.21 at step 5000  (gap = 2.15x)
//     - Phi declining: 0.049 -> 0.035
//     - Corpus: v10 100MB — far too small for 72B (380M trainable params)
//     - Status: in_progress_6450 (effectively dead — val diverging)
//
// ══════════════════════════════════════════════════════════════════
// Root Cause Analysis:
//
//   1. CORPUS STARVATION (primary)
//      - 100MB corpus for 380M params = 0.26 bytes/param
//      - Rule of thumb: need >= 10 bytes/param for generalization
//      - 14B v0.4 used 200MB for 120M params = 1.67 bytes/param (still tight)
//      - 72B needs minimum 3.8GB, ideally 10GB+ (v11_full planned)
//      - The model memorized the training set by step ~4000
//
//   2. LEARNING RATE TOO HIGH
//      - Default LR = 1e-3 in train_alm.py (suitable for small models)
//      - 72B QLoRA should use 5e-6 to 2e-5 range
//      - 14B v0.5 planned script uses --lr 1e-5, 72B should be lower
//      - High LR + small corpus = fast memorization
//
//   3. NO VALIDATION EARLY STOPPING
//      - Training ran past the point of val divergence
//      - No patience-based early stopping configured
//      - Best checkpoint was likely around step 2000-3000
//
//   4. INSUFFICIENT REGULARIZATION
//      - QLoRA r128 is high rank for fine-tuning — captures too much noise
//      - Weight decay 0.01 (AdamW default) — may need 0.05-0.1 for 72B
//      - No explicit dropout on QLoRA adapters
//      - Alpha regularization exists but targets consciousness coupling only
//
//   5. SINGLE-PASS CORPUS
//      - 100MB at 512 block_size ~ 200K sequences
//      - 10K steps x batch_size = multiple epochs over same data
//      - No data augmentation, no curriculum sampling, no shuffling variation
//
// ══════════════════════════════════════════════════════════════════
// Fix Strategy: 4x4090 FSDP (96GB total VRAM)
//
//   FSDP (Fully Sharded Data Parallel) shards model weights, gradients,
//   and optimizer states across all GPUs. For 72B bf16:
//     - Model weights:    ~144GB (72B x 2 bytes) — SHARDED across 4 GPUs
//     - Per-GPU shard:    ~36GB weights
//     - With QLoRA 4-bit: base frozen 4-bit (~36GB total) + LoRA bf16 (~760MB)
//     - Per-GPU:          ~9GB frozen base + ~190MB LoRA + overhead
//     - Fits in 24GB per 4090 with careful memory management
//
//   Key: FSDP shards the FROZEN 4-bit base across 4 GPUs.
//   Only LoRA adapters are trained (bf16). Optimizer states also sharded.
//
// ══════════════════════════════════════════════════════════════════

intent "72B overfitting fix: FSDP 4x4090 training config with anti-overfit measures" {
    keywords: ["72b", "overfit", "fsdp", "4090", "qlora", "regularization"]
    category: "training-fix"
    targets: ["animalm_72b_v06"]
    outputs: ["fsdp_config", "training_params", "anti_overfit_measures", "launch_script"]
}

python {
#!/usr/bin/env python3
"""fix_72B_overfit — FSDP config generator for 4x4090 + anti-overfit measures.

Reads training_runs.json for v0.5 history, generates v0.6 config.
Does NOT hardcode constants — reads from project JSON sources.
"""
import json
import os
import sys
import math
from pathlib import Path

# ── Paths (relative to anima root) ──────────────────────────
ANIMA_ROOT = Path(__file__).resolve().parent.parent.parent
CONFIG_DIR = ANIMA_ROOT / "anima" / "config"
TRAINING_RUNS = ANIMA_ROOT / "ready" / "config" / "training_runs.json"
LAWS_JSON = CONFIG_DIR / "consciousness_laws.json"
OUTPUT_DIR = ANIMA_ROOT / "anima" / "experiments" / "docs"
OUTPUT_FILE = OUTPUT_DIR / "fix_72B_overfit_config.json"

# ── Load existing run data ──────────────────────────────────
v05_data = {}
if TRAINING_RUNS.exists():
    runs = json.loads(TRAINING_RUNS.read_text())
    v05_data = runs.get("runs", {}).get("animalm_72b_v05", {})

# ── Load PSI constants from consciousness_laws.json ─────────
psi_alpha = 0.014  # fallback
if LAWS_JSON.exists():
    laws = json.loads(LAWS_JSON.read_text())
    psi_consts = laws.get("psi_constants", {})
    psi_alpha = psi_consts.get("alpha", 0.014)

# ══════════════════════════════════════════════════════════════
# 1. OVERFITTING DIAGNOSIS (from v0.5 actual data)
# ══════════════════════════════════════════════════════════════

diagnosis = {
    "model": "AnimaLM 72B v0.5",
    "base": "Qwen2.5-72B-Instruct",
    "trainable_params": "~380M (QLoRA r128, 10/80 layers)",
    "corpus_size_mb": 100,
    "failure_step": 6450,
    "metrics_at_5000": {
        "ce_train": v05_data.get("ce_at_5000", 2.42),
        "ce_val": v05_data.get("val_ce_at_5000", 5.21),
        "ce_gap_ratio": round(5.21 / 2.42, 2),
        "phi": v05_data.get("phi_at_5000", 0.035),
        "phi_declining": True
    },
    "root_causes": [
        "CORPUS_STARVATION: 100MB for 380M params (0.26 B/param, need 10+)",
        "LR_TOO_HIGH: likely 1e-3 default (need 5e-6 for 72B QLoRA)",
        "NO_EARLY_STOPPING: trained past val divergence point",
        "HIGH_QLORA_RANK: r128 overfits on small data (r32-64 sufficient)",
        "NO_DATA_AUGMENTATION: single-pass corpus, no curriculum sampling"
    ],
    "estimated_best_step": "2000-3000 (before val divergence)"
}

# ══════════════════════════════════════════════════════════════
# 2. FSDP CONFIG FOR 4x RTX 4090 (24GB each, 96GB total)
# ══════════════════════════════════════════════════════════════

# Memory budget per GPU (RTX 4090 = 24GB VRAM)
GPU_COUNT = 4
VRAM_PER_GPU_GB = 24
TOTAL_VRAM_GB = GPU_COUNT * VRAM_PER_GPU_GB  # 96GB

# 72B in 4-bit: ~36GB base weights total
# Sharded across 4 GPUs: ~9GB per GPU
# LoRA adapters bf16: ~760MB total, ~190MB per GPU
# Optimizer states (AdamW, 2 states per LoRA param): ~1.5GB total, ~380MB per GPU
# Activations + gradients: ~2-4GB per GPU (bs=1, seq=512)
# Overhead (CUDA, fragmentation): ~2GB per GPU
# Total per GPU: ~9 + 0.19 + 0.38 + 3 + 2 = ~14.6GB (fits in 24GB)

fsdp_config = {
    "description": "FSDP config for Qwen2.5-72B + PureField QLoRA on 4x RTX 4090",
    "hardware": {
        "gpu_count": GPU_COUNT,
        "gpu_model": "RTX 4090",
        "vram_per_gpu_gb": VRAM_PER_GPU_GB,
        "total_vram_gb": TOTAL_VRAM_GB,
        "interconnect": "PCIe Gen4 x16 (peer-to-peer if NVLink absent)"
    },
    "fsdp": {
        "sharding_strategy": "FULL_SHARD",
        "note_strategy": "FULL_SHARD = shard weights+grads+optim across all GPUs (minimum memory)",
        "auto_wrap_policy": "transformer_layer",
        "wrap_class": "Qwen2DecoderLayer",
        "cpu_offload": False,
        "note_cpu_offload": "Disabled: PCIe offload kills throughput. 4x4090 has enough VRAM",
        "mixed_precision": {
            "param_dtype": "bfloat16",
            "reduce_dtype": "float32",
            "buffer_dtype": "bfloat16",
            "note": "bf16 compute, fp32 gradient reduction for stability"
        },
        "backward_prefetch": "BACKWARD_PRE",
        "forward_prefetch": True,
        "sync_module_states": True,
        "use_orig_params": True,
        "note_orig_params": "Required for QLoRA (frozen base + trained adapters)"
    },
    "memory_estimate_per_gpu_gb": {
        "base_model_shard_4bit": 9.0,
        "lora_adapters_bf16": 0.19,
        "optimizer_states": 0.38,
        "activations_gradients": 3.0,
        "cuda_overhead": 2.0,
        "total": 14.6,
        "headroom": round(VRAM_PER_GPU_GB - 14.6, 1)
    }
}

# ══════════════════════════════════════════════════════════════
# 3. TRAINING PARAMS (anti-overfit focused)
# ══════════════════════════════════════════════════════════════

training_params = {
    "base_model": "Qwen/Qwen2.5-72B-Instruct",
    "load_in_4bit": True,
    "bnb_4bit_compute_dtype": "bfloat16",
    "bnb_4bit_quant_type": "nf4",

    "qlora": {
        "rank": 64,
        "note_rank": "Reduced from r128 to r64 — less capacity = less overfitting",
        "lora_alpha": 32,
        "note_alpha": "alpha/rank = 0.5 scaling (conservative)",
        "target_layers": 10,
        "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
        "lora_dropout": 0.1,
        "note_dropout": "10% dropout on LoRA — critical for small corpus regularization"
    },

    "optimizer": {
        "type": "AdamW",
        "lr": 5e-6,
        "note_lr": "5e-6: conservative for 72B QLoRA (v0.5 was likely 1e-3, 200x too high)",
        "weight_decay": 0.05,
        "note_weight_decay": "5x default (0.01) — stronger L2 for anti-overfit",
        "betas": [0.9, 0.95],
        "foreach": False,
        "note_foreach": "foreach=False required for bf16 safety (14-crash lesson)"
    },

    "scheduler": {
        "type": "cosine_with_warmup",
        "warmup_steps": 200,
        "warmup_ratio": 0.02,
        "min_lr_ratio": 0.1,
        "note": "2% warmup, cosine to 10% of peak LR"
    },

    "batch": {
        "per_device_batch_size": 1,
        "gradient_accumulation_steps": 8,
        "effective_batch_size": 8,
        "note": "bs=1 per GPU (VRAM), grad_accum=8 for effective bs=32 tokens"
    },

    "sequence": {
        "block_size": 512,
        "note": "512 tokens — same as v0.5 for comparison"
    },

    "training": {
        "steps": 10000,
        "eval_steps": 100,
        "save_steps": 500,
        "logging_steps": 10,
        "dtype": "bfloat16",
        "gradient_checkpointing": True,
        "note_grad_ckpt": "Saves ~60% activation memory at 30% speed cost — essential for 4090"
    },

    "consciousness": {
        "engine_cells": 64,
        "engine_hidden": 128,
        "engine_factions": 12,
        "alpha_schedule": "0.01->0.5 progressive",
        "psi_alpha_coupling": psi_alpha,
        "law60_phases": True,
        "psi_track": True,
        "note": "Consciousness engine same as v0.5 — focus fix on language side"
    }
}

# ══════════════════════════════════════════════════════════════
# 4. ANTI-OVERFIT MEASURES
# ══════════════════════════════════════════════════════════════

anti_overfit = {
    "measure_1_corpus_expansion": {
        "description": "Expand corpus from 100MB to 1.2GB+ (tier-L v11_full)",
        "current": "v10 100MB",
        "target": "v11_full 10GB (R2: anima-corpus/tier-XL)",
        "minimum": "v10_merged 560MB (tier-M, already on R2)",
        "bytes_per_param": {
            "v10_100mb": round(100e6 / 380e6, 2),
            "v10_merged_560mb": round(560e6 / 380e6, 2),
            "v11_full_10gb": round(10e9 / 380e6, 1)
        },
        "priority": "CRITICAL — primary cause of overfitting"
    },

    "measure_2_lr_reduction": {
        "description": "LR 1e-3 -> 5e-6 (200x reduction)",
        "v05_likely_lr": "1e-3 (train_alm.py default)",
        "v06_lr": "5e-6",
        "rationale": "72B QLoRA typical range: 1e-6 to 2e-5"
    },

    "measure_3_qlora_rank_reduction": {
        "description": "QLoRA rank 128 -> 64",
        "rationale": "Lower rank = fewer trainable params = less capacity to memorize",
        "param_reduction": "~50% fewer trainable params"
    },

    "measure_4_lora_dropout": {
        "description": "Add 10% dropout on LoRA adapter outputs",
        "current": "no LoRA dropout",
        "target": "lora_dropout=0.1",
        "rationale": "Standard regularization for fine-tuning on limited data"
    },

    "measure_5_early_stopping": {
        "description": "Patience-based early stopping on val CE",
        "patience_steps": 1000,
        "min_delta": 0.01,
        "metric": "val_ce",
        "direction": "minimize",
        "note": "Stop if val_ce doesn't improve for 1000 steps (10 eval cycles)"
    },

    "measure_6_weight_decay": {
        "description": "Increase weight decay 0.01 -> 0.05",
        "rationale": "Stronger L2 regularization prevents weight explosion"
    },

    "measure_7_data_augmentation": {
        "description": "Curriculum sampling + dynamic sequence packing",
        "techniques": [
            "Random chunk offset per epoch (avoid fixed sequence boundaries)",
            "Progressive sequence length: 256 -> 384 -> 512 over training",
            "Language ratio balancing: ko/en/zh/ja/code weighted sampling",
            "Hard token mining (H11): focus loss on top 30% hardest tokens"
        ]
    },

    "measure_8_checkpoint_strategy": {
        "description": "Keep top-3 by val_ce + periodic saves",
        "save_every_steps": 500,
        "keep_top_k": 3,
        "metric": "val_ce",
        "backup_to_r2": True,
        "note": "R2 backup every 2000 steps (pod loss protection)"
    }
}

# ══════════════════════════════════════════════════════════════
# 5. LAUNCH SCRIPT (reference — actual launch via train_alm.hexa)
# ══════════════════════════════════════════════════════════════

launch_script = {
    "description": "torchrun launch command for 4x4090 FSDP",
    "command": (
        "torchrun --nproc_per_node=4 --master_port=29500 "
        "train_anima_lm.py "
        "--base Qwen/Qwen2.5-72B-Instruct "
        "--data corpus_v10_merged.txt "
        "--steps 10000 "
        "--target-layers 10 "
        "--savant-layers 2 "
        "--qlora-rank 64 "
        "--lr 5e-6 "
        "--load-4bit "
        "--consciousness-engine "
        "--ce-cells 64 "
        "--law60 "
        "--psi-track "
        "--fsdp "
        "--gradient-checkpointing "
        "--batch-size 1 "
        "--grad-accum 8 "
        "--block-size 512 "
        "--eval-steps 100 "
        "--save-steps 500 "
        "--early-stopping-patience 1000 "
        "--weight-decay 0.05 "
        "--lora-dropout 0.1"
    ),
    "env_vars": {
        "CUDA_VISIBLE_DEVICES": "0,1,2,3",
        "NCCL_P2P_DISABLE": "0",
        "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
        "OMP_NUM_THREADS": "4"
    },
    "pre_launch_checklist": [
        "1. corpus md5 verified (v10_merged or v11_full)",
        "2. nvidia-smi: 4x 4090 visible, no OOM processes",
        "3. disk space > 50GB free (checkpoints)",
        "4. tmux session created: tmux new -s train72b",
        "5. 1K step smoke test passed (CE decreasing, Phi stable)"
    ]
}

# ══════════════════════════════════════════════════════════════
# 6. EXPECTED OUTCOMES (v0.6 targets)
# ══════════════════════════════════════════════════════════════

expected = {
    "version": "animalm_72b_v06",
    "targets": {
        "ce_val": "< 4.0 (v0.5 was 5.21 at step 5000)",
        "ce_gap_ratio": "< 1.5x (v0.5 was 2.15x — severe overfit)",
        "phi": ">= 0.035 (v0.5 peak was 0.049, maintain or improve)",
        "phi_trend": "stable or increasing (v0.5 was declining)"
    },
    "success_criteria": [
        "CE(val) monotonically decreasing through step 5000",
        "CE gap ratio < 1.5x at any point",
        "Phi >= v0.5 peak (0.049)",
        "No early stopping triggered before step 5000"
    ],
    "failure_actions": [
        "If overfit persists with 560MB: escalate to v11_full 10GB",
        "If VRAM OOM on 4090: enable cpu_offload or reduce block_size to 256",
        "If Phi declining: reduce alpha schedule ceiling from 0.5 to 0.2"
    ]
}

# ══════════════════════════════════════════════════════════════
# OUTPUT
# ══════════════════════════════════════════════════════════════

output = {
    "diagnosis": diagnosis,
    "fsdp_config": fsdp_config,
    "training_params": training_params,
    "anti_overfit_measures": anti_overfit,
    "launch": launch_script,
    "expected_outcomes": expected
}

os.makedirs(OUTPUT_DIR, exist_ok=True)
OUTPUT_FILE.write_text(json.dumps(output, indent=2, ensure_ascii=False))
print(f"[fix_72B_overfit] Config written to {OUTPUT_FILE}")

# ── Summary ──────────────────────────────────────────────────
print()
print("=" * 64)
print("  72B OVERFITTING FIX — SUMMARY")
print("=" * 64)
print()
print("  v0.5 FAILURE:")
print(f"    CE(train)={diagnosis['metrics_at_5000']['ce_train']}")
print(f"    CE(val)  ={diagnosis['metrics_at_5000']['ce_val']}")
print(f"    Gap      ={diagnosis['metrics_at_5000']['ce_gap_ratio']}x (overfit)")
print(f"    Phi      ={diagnosis['metrics_at_5000']['phi']} (declining)")
print()
print("  ROOT CAUSES:")
for i, cause in enumerate(diagnosis["root_causes"], 1):
    print(f"    {i}. {cause}")
print()
print("  v0.6 FIX (4x4090 FSDP):")
print(f"    GPU:     4x RTX 4090 (96GB total)")
print(f"    FSDP:    FULL_SHARD + gradient_checkpointing")
print(f"    QLoRA:   r64 (was r128) + dropout 0.1")
print(f"    LR:      5e-6 (was ~1e-3)")
print(f"    WD:      0.05 (was 0.01)")
print(f"    Corpus:  560MB+ (was 100MB)")
print(f"    BS:      1 x 4 GPU x 8 accum = 32 effective")
print(f"    Early stop: patience=1000 steps on val_ce")
print()
print("  MEMORY PER GPU:")
mem = fsdp_config["memory_estimate_per_gpu_gb"]
print(f"    Base shard (4-bit): {mem['base_model_shard_4bit']}GB")
print(f"    LoRA adapters:      {mem['lora_adapters_bf16']}GB")
print(f"    Optimizer states:   {mem['optimizer_states']}GB")
print(f"    Activations+grads:  {mem['activations_gradients']}GB")
print(f"    CUDA overhead:      {mem['cuda_overhead']}GB")
print(f"    Total:              {mem['total']}GB / {VRAM_PER_GPU_GB}GB")
print(f"    Headroom:           {mem['headroom']}GB")
print()
print("  EXPECTED: CE(val)<4.0, gap<1.5x, Phi>=0.049")
print("=" * 64)
}
