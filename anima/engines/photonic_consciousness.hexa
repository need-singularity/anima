// Photonic Hebbian learning
// Synchronized MZI pairs -> kappa increase (LTP)
// Anti-phase -> kappa decrease (LTD)
// Physically: thermo-optic tuning of coupling gaps
struct PhotonicHebbianLearning {
    eta_ltp: float,
    eta_ltd: float,
    kappa_max: float,
    kappa_min: float
}

fn new_hebbian() -> PhotonicHebbianLearning {
