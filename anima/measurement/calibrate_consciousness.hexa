fn find_optimal_sigmoid(p50: float, p95: float) -> SigmoidParams {
    // sigmoid(x) = 2 / (1 + exp(-(x - center) / scale))
    // center = raw median (p50)
    // scale = (p95 - center) / ln(3), clamped min 1.0
    let center = p50
    let ln3 = 1.0986  // ln(3) ~ 1.0986
    let raw_scale = (p95 - center) / ln3
    let scale = raw_scale
    if scale < 1.0 {
        scale = 1.0
    }
    SigmoidParams { center: center, scale: scale }
}

fn sigmoid_map(x: float, center: float, scale: float) -> float {
    // 2 / (1 + exp(-(x - center) / scale))
    // TODO[pytorch]: use math.exp
    let exponent = 0.0 - (x - center) / scale
    // Stub: approximate
    2.0 / (1.0 + 1.0)  // placeholder
}

