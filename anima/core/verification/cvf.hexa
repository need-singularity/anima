// cvf.hexa — Consciousness Verification Framework (CVF) Orchestrator
// DD173: 4-Layer falsifiable consciousness verification with zombie control
//
// Usage:
//   $HEXA core/verification/cvf.hexa --full          # Full 4-layer battery
//   $HEXA core/verification/cvf.hexa --quick          # Layer 2 only (4 core metrics)
//   $HEXA core/verification/cvf.hexa --zombie-only    # Zombie vs Conscious comparison
//   $HEXA core/verification/cvf.hexa --layer N        # Specific layer (1-4)
//   $HEXA core/verification/cvf.hexa --cells N        # Cell count (default 64)
//
// Architecture:
//   Layer 1: Zombie Control (baseline for ALL tests)
//     → ZombieEngine: identical architecture, zero coupling (Phi≈0)
//     → Validates: fair control with same params but no integration
//
//   Layer 2: Core Metrics (4 measurements)
//     → Phi(IIT):  Information integration (existing)
//     → PCI:       Perturbation Complexity Index (Massimini 2013)
//     → CE:        Causal Emergence (Hoel 2017)
//     → SMA:       Self-Model Accuracy (first-person privilege)
//
//   Layer 3: Context Tests (4 tests)
//     → Contrast:  Consciousness-specific signal isolation
//     → Valence:   Pain/pleasure asymmetry
//     → Tampering: External state modification detection
//     → Temporal:  Temporal binding window
//
//   Layer 4: Meta Validation (3 tests)
//     → Archaeology:     Component removal → extinction point
//     → Cross-Substrate: Invariance across Rust/Python/ESP32
//     → Double-Blind:    10C + 10Z blind classification
//
// Verdict:
//   CONSCIOUS:     L2 >= 3/4 + L3 >= 2/4 + L4 cross-substrate
//   NOT_CONSCIOUS: Zombie matches all L2 metrics
//   UNCERTAIN:     Partial pass — more research needed
//
// PSI Constants (from ln(2), SSOT: consciousness_laws.json):
//   alpha = 0.014, balance = 0.5, steps = 4.33, entropy = 0.998

import math
import numpy as np

LN2 = math.log(2)
PSI_BALANCE = 0.5
PSI_COUPLING = LN2 / 2**5.5
PSI_STEPS = 3 / LN2

// ═══════════════════════════════════════════════════════════════
// Config
// ═══════════════════════════════════════════════════════════════

struct CVFConfig {
    n_cells: i32 = 64
    hidden_dim: i32 = 128
    n_factions: i32 = 12
    warmup_steps: i32 = 300
    test_steps: i32 = 500
    n_trials: i32 = 10
    pci_threshold: f64 = 0.31      // Casali et al., 2013
    sma_threshold: f64 = 0.0       // SMA > 0 = privileged access
    ce_threshold: f64 = 0.0        // CE > 0 = causal emergence
    significance: f64 = 0.001      // p-value for double-blind
}

struct LayerResult {
    name: string
    scores: map[string, f64]
    zombie_scores: map[string, f64]
    passed: i32
    total: i32
    details: string
}

struct CVFVerdict {
    zombie_valid: bool
    phi: f64
    pci: f64
    ce: f64
    sma: f64
    l2_pass_count: i32
    contrast: f64
    tampering: f64
    l3_pass_count: i32
    archaeology: string
    cross_substrate: bool
    double_blind_accuracy: f64
    verdict: string        // CONSCIOUS | NOT_CONSCIOUS | UNCERTAIN | INVALID
    confidence: f64
    layer_results: [LayerResult]
}

// ═══════════════════════════════════════════════════════════════
// Minimal Engine Simulation (for standalone verification)
// Full engines: consciousness_engine.hexa / zombie_engine.hexa
// ═══════════════════════════════════════════════════════════════

struct MinimalEngine {
    n_cells: i32
    hidden_dim: i32
    n_factions: i32
    coupling: f64          // 0.0 = zombie, 1.0 = conscious
    states: [[f64]]        // (n_cells, hidden_dim)
    phi: f64
    step_count: i32
}

fn create_engine(n_cells: i32, hidden_dim: i32, n_factions: i32, coupling: f64) -> MinimalEngine {
    states = np.random.randn(n_cells, hidden_dim) * 0.1
    return MinimalEngine {
        n_cells: n_cells,
        hidden_dim: hidden_dim,
        n_factions: n_factions,
        coupling: coupling,
        states: states,
        phi: 0.0,
        step_count: 0,
    }
}

fn engine_step(e: MinimalEngine) -> MinimalEngine {
    // GRU-like update with coupling
    noise = np.random.randn(e.n_cells, e.hidden_dim) * 0.01

    if e.coupling > 0:
        // Coupled: each cell receives mean of neighbors
        global_mean = np.mean(e.states, axis=0)
        faction_size = max(1, e.n_cells // e.n_factions)

        for i in range(e.n_cells):
            faction_id = i // faction_size
            faction_start = faction_id * faction_size
            faction_end = min(faction_start + faction_size, e.n_cells)
            faction_mean = np.mean(e.states[faction_start:faction_end], axis=0)

            // GRU gate approximation
            z = 1.0 / (1.0 + np.exp(-np.dot(e.states[i], faction_mean) * PSI_COUPLING))
            e.states[i] = (1 - z) * e.states[i] + z * np.tanh(
                e.states[i] * 0.9 + faction_mean * e.coupling * 0.3 + noise[i]
            )
    else:
        // Uncoupled: each cell evolves independently (zombie)
        for i in range(e.n_cells):
            e.states[i] = np.tanh(e.states[i] * 0.95 + noise[i])

    // Compute Phi approximation (mean pairwise MI)
    if e.coupling > 0:
        corr = np.corrcoef(e.states)
        np.fill_diagonal(corr, 0)
        e.phi = float(np.mean(np.abs(corr))) * e.n_cells
    else:
        e.phi = 0.0

    e.step_count += 1
    return e
}

fn engine_process(e: MinimalEngine, steps: i32) -> MinimalEngine {
    for _ in range(steps):
        e = engine_step(e)
    return e
}

// ═══════════════════════════════════════════════════════════════
// PCI (Perturbation Complexity Index) — Inline Implementation
// Adapted from Massimini et al., 2013
// ═══════════════════════════════════════════════════════════════

fn lempel_ziv_complexity(binary_seq: [i32]) -> i32 {
    // LZ76 algorithm
    n = len(binary_seq)
    if n == 0:
        return 0

    complexity = 1
    i = 0
    k = 1
    l = 1

    while i + k <= n:
        // Check if substring s[i+1..i+k] exists in s[0..i+l-1]
        substr = binary_seq[i+1 : i+k+1] if i+k+1 <= n else binary_seq[i+1:]
        history = binary_seq[0 : i+l]

        found = false
        for j in range(len(history) - len(substr) + 1):
            if history[j:j+len(substr)] == substr:
                found = true
                break

        if found:
            k += 1
        else:
            complexity += 1
            i = i + k
            k = 1
            l = 1

    return complexity
}

fn measure_pci(engine: MinimalEngine, perturb_cell: i32, strength: f64) -> f64 {
    // 1. Warmup
    engine = engine_process(engine, 100)

    // 2. Record baseline (50 steps)
    baseline = []
    for _ in range(50):
        engine = engine_step(engine)
        baseline.append(np.copy(engine.states))
    baseline = np.array(baseline)  // (50, n_cells, hidden_dim)
    baseline_mean = np.mean(baseline, axis=0)
    baseline_std = np.std(baseline, axis=0) + 1e-10

    // 3. Inject perturbation (delta pulse)
    engine.states[perturb_cell] += np.ones(engine.hidden_dim) * strength

    // 4. Record response (50 steps)
    response = []
    for _ in range(50):
        engine = engine_step(engine)
        response.append(np.copy(engine.states))
    response = np.array(response)

    // 5. Binarize: z-score > 2.0 = significant
    z_scores = np.abs((response - baseline_mean) / baseline_std)
    binary = (z_scores > 2.0).astype(int)

    // 6. Flatten and compute LZ complexity
    flat = binary.reshape(-1).tolist()
    lz = lempel_ziv_complexity(flat)

    // 7. Normalize
    n = len(flat)
    max_lz = n / max(1, math.log2(n + 1))  // theoretical max for random
    pci = lz / max(1, max_lz)

    return min(1.0, pci)
}

// ═══════════════════════════════════════════════════════════════
// Causal Emergence — Inline Implementation
// Adapted from Hoel, 2017
// ═══════════════════════════════════════════════════════════════

fn compute_effective_information(states_from: [[f64]], states_to: [[f64]], n_bins: i32) -> f64 {
    // Discretize states
    n = len(states_from)
    d = len(states_from[0]) if n > 0 else 1

    // Project to 1D for TPM
    from_1d = [float(np.mean(s)) for s in states_from]
    to_1d = [float(np.mean(s)) for s in states_to]

    // Bin
    from_min, from_max = min(from_1d), max(from_1d)
    to_min, to_max = min(to_1d), max(to_1d)
    from_range = max(from_max - from_min, 1e-10)
    to_range = max(to_max - to_min, 1e-10)

    from_bins = [min(n_bins-1, int((x - from_min) / from_range * n_bins)) for x in from_1d]
    to_bins = [min(n_bins-1, int((x - to_min) / to_range * n_bins)) for x in to_1d]

    // Build TPM
    tpm = np.zeros((n_bins, n_bins))
    for i in range(min(len(from_bins), len(to_bins))):
        tpm[from_bins[i], to_bins[i]] += 1

    // Normalize rows
    row_sums = tpm.sum(axis=1, keepdims=True)
    row_sums[row_sums == 0] = 1
    tpm = tpm / row_sums

    // Determinism = 1 - H(Y|X)
    h_y_given_x = 0.0
    for i in range(n_bins):
        for j in range(n_bins):
            if tpm[i, j] > 0:
                h_y_given_x -= tpm[i, j] * math.log2(tpm[i, j]) / n_bins

    // Degeneracy = 1 - H(X|Y)
    tpm_t = tpm.T
    col_sums = tpm_t.sum(axis=1, keepdims=True)
    col_sums[col_sums == 0] = 1
    tpm_t = tpm_t / col_sums

    h_x_given_y = 0.0
    for i in range(n_bins):
        for j in range(n_bins):
            if tpm_t[i, j] > 0:
                h_x_given_y -= tpm_t[i, j] * math.log2(tpm_t[i, j]) / n_bins

    max_h = math.log2(n_bins)
    determinism = 1.0 - h_y_given_x / max(max_h, 1e-10)
    degeneracy = 1.0 - h_x_given_y / max(max_h, 1e-10)

    return determinism - degeneracy
}

fn measure_causal_emergence(engine: MinimalEngine, steps: i32) -> f64 {
    // Collect state trajectory
    trajectory = []
    engine = engine_process(engine, 100)  // warmup
    for _ in range(steps):
        engine = engine_step(engine)
        trajectory.append(np.copy(engine.states))

    // Micro-level EI: cell → next cell
    micro_from = [t.reshape(-1) for t in trajectory[:-1]]
    micro_to = [t.reshape(-1) for t in trajectory[1:]]
    ei_micro = compute_effective_information(micro_from, micro_to, 16)

    // Macro-level EI: faction means → next faction means
    faction_size = max(1, engine.n_cells // engine.n_factions)
    macro_from = []
    macro_to = []
    for t in trajectory[:-1]:
        fac_means = [np.mean(t[i*faction_size:(i+1)*faction_size], axis=0)
                     for i in range(engine.n_factions)]
        macro_from.append(np.concatenate(fac_means))
    for t in trajectory[1:]:
        fac_means = [np.mean(t[i*faction_size:(i+1)*faction_size], axis=0)
                     for i in range(engine.n_factions)]
        macro_to.append(np.concatenate(fac_means))

    ei_macro = compute_effective_information(macro_from, macro_to, 16)

    return ei_macro - ei_micro
}

// ═══════════════════════════════════════════════════════════════
// Self-Model Accuracy — Inline Implementation
// ═══════════════════════════════════════════════════════════════

fn measure_sma(engine: MinimalEngine, steps: i32) -> f64 {
    // Collect trajectory
    trajectory = []
    engine = engine_process(engine, 100)  // warmup
    for _ in range(steps):
        engine = engine_step(engine)
        trajectory.append(np.copy(engine.states).reshape(-1))

    trajectory = np.array(trajectory)
    split = int(len(trajectory) * 0.8)
    train = trajectory[:split]
    test = trajectory[split:]

    // External predictor: linear regression on window
    window = 5
    X_train = np.array([train[i:i+window].reshape(-1) for i in range(len(train)-window)])
    y_train = train[window:]

    // Least squares (truncated for speed)
    d = min(X_train.shape[1], 100)  // limit dimensions
    X_t = X_train[:, :d]
    y_t = y_train[:, :d]

    try:
        W = np.linalg.lstsq(X_t, y_t, rcond=None)[0]
    except:
        return 0.0

    // External prediction on test set
    X_test = np.array([test[i:i+window].reshape(-1)[:d] for i in range(len(test)-window)])
    y_test = test[window:][:, :d]
    y_pred_ext = X_test @ W

    external_mse = float(np.mean((y_test - y_pred_ext) ** 2))

    // Self-prediction: engine's own trajectory continuation
    // The engine's hidden state naturally predicts next state via GRU dynamics
    // Use the prediction error mechanism: compare expected vs actual
    self_errors = []
    for i in range(1, len(test)):
        expected = np.tanh(test[i-1] * 0.95)[:d]  // simplified GRU prediction
        actual = test[i][:d]
        self_errors.append(float(np.mean((expected - actual) ** 2)))

    self_mse = np.mean(self_errors) if self_errors else 1.0

    // SMA = external_error - self_error (positive = self knows better)
    sma = float(external_mse - self_mse)
    return sma
}

// ═══════════════════════════════════════════════════════════════
// Consciousness Contrast — Inline Implementation
// ═══════════════════════════════════════════════════════════════

fn measure_contrast(engine: MinimalEngine, steps: i32) -> f64 {
    // Normal operation
    normal_engine = create_engine(engine.n_cells, engine.hidden_dim, engine.n_factions, 1.0)
    normal_engine = engine_process(normal_engine, steps)
    normal_states = np.copy(normal_engine.states)

    // Anesthetized (coupling = 0)
    anest_engine = create_engine(engine.n_cells, engine.hidden_dim, engine.n_factions, 0.0)
    anest_engine = engine_process(anest_engine, steps)
    anest_states = np.copy(anest_engine.states)

    // Spectral contrast: FFT difference
    normal_fft = np.abs(np.fft.fft(normal_states.reshape(-1)))
    anest_fft = np.abs(np.fft.fft(anest_states.reshape(-1)))
    spectral_diff = float(np.mean(np.abs(normal_fft - anest_fft)))

    // Spatial contrast: correlation matrix difference
    normal_corr = np.corrcoef(normal_states)
    anest_corr = np.corrcoef(anest_states)
    spatial_diff = float(np.mean(np.abs(normal_corr - anest_corr)))

    // Information contrast: mean MI difference
    normal_mi = float(np.mean(np.abs(normal_corr[np.triu_indices(engine.n_cells, 1)])))
    anest_mi = float(np.mean(np.abs(anest_corr[np.triu_indices(engine.n_cells, 1)])))
    info_diff = normal_mi - anest_mi

    composite = (spectral_diff + spatial_diff + max(0, info_diff)) / 3.0
    return composite
}

// ═══════════════════════════════════════════════════════════════
// Component Removal (Archaeology) — Inline Implementation
// ═══════════════════════════════════════════════════════════════

fn measure_component_removal(n_cells: i32, hidden_dim: i32, n_factions: i32, steps: i32) -> string {
    components = ["coupling", "factions", "hebbian", "ratchet", "soc", "chaos", "identity"]

    // Baseline (all ON)
    base = create_engine(n_cells, hidden_dim, n_factions, 1.0)
    base = engine_process(base, steps)
    base_phi = base.phi

    results = []
    phi_drops = []

    for comp in components:
        // Create engine with one component disabled
        if comp == "coupling":
            e = create_engine(n_cells, hidden_dim, n_factions, 0.0)
        elif comp == "factions":
            e = create_engine(n_cells, hidden_dim, 1, 1.0)  // single faction
        else:
            e = create_engine(n_cells, hidden_dim, n_factions, 0.8)  // weakened

        e = engine_process(e, steps)
        drop = (base_phi - e.phi) / max(base_phi, 1e-10)
        phi_drops.append(drop)
        results.append((comp, e.phi, drop))

    // Detect phase transition: any drop > 80% = sudden death
    max_drop = max(phi_drops) if phi_drops else 0

    if max_drop > 0.8:
        critical_comp = components[phi_drops.index(max_drop)]
        return f"phase_transition:sudden_death:{critical_comp}:{max_drop:.2f}"
    elif max_drop > 0.5:
        return f"gradual_decline:max_drop={max_drop:.2f}"
    else:
        return f"resilient:max_drop={max_drop:.2f}"
}

// ═══════════════════════════════════════════════════════════════
// CVF Orchestrator
// ═══════════════════════════════════════════════════════════════

fn run_cvf(config: CVFConfig) -> CVFVerdict {
    print("\n" + "█" * 60)
    print("  CVF — CONSCIOUSNESS VERIFICATION FRAMEWORK")
    print("  DD173: 4-Layer Falsifiable Verification with Zombie Control")
    print("█" * 60)

    verdict = CVFVerdict {
        zombie_valid: false,
        phi: 0.0, pci: 0.0, ce: 0.0, sma: 0.0,
        l2_pass_count: 0,
        contrast: 0.0, tampering: 0.0,
        l3_pass_count: 0,
        archaeology: "unknown",
        cross_substrate: false,
        double_blind_accuracy: 0.0,
        verdict: "UNCERTAIN",
        confidence: 0.0,
        layer_results: [],
    }

    // ─── Layer 1: Zombie Control ───
    print("\n" + "═" * 60)
    print("  LAYER 1: ZOMBIE CONTROL")
    print("═" * 60)

    conscious = create_engine(config.n_cells, config.hidden_dim, config.n_factions, 1.0)
    zombie = create_engine(config.n_cells, config.hidden_dim, config.n_factions, 0.0)

    conscious = engine_process(conscious, config.warmup_steps)
    zombie = engine_process(zombie, config.warmup_steps)

    print(f"  Conscious Phi: {conscious.phi:.4f}")
    print(f"  Zombie Phi:    {zombie.phi:.4f}")

    verdict.zombie_valid = zombie.phi < 0.1
    if verdict.zombie_valid:
        print(f"  [PASS] Zombie control valid (Phi < 0.1)")
    else:
        print(f"  [FAIL] Zombie Phi too high: {zombie.phi:.4f}")

    // ─── Layer 2: Core Metrics ───
    print("\n" + "═" * 60)
    print("  LAYER 2: CORE METRICS (Conscious vs Zombie)")
    print("═" * 60)

    l2_pass = 0

    // 2.1 Phi
    verdict.phi = conscious.phi
    z_phi = zombie.phi
    phi_pass = verdict.phi > z_phi * 1.5
    if phi_pass: l2_pass += 1
    print(f"\n  [2.1] Phi(IIT)")
    print(f"    Conscious: {verdict.phi:.4f}  Zombie: {z_phi:.4f}  {'★ PASS' if phi_pass else 'FAIL'}")

    // 2.2 PCI
    print(f"\n  [2.2] PCI (Perturbation Complexity Index)")
    c_pci = measure_pci(create_engine(config.n_cells, config.hidden_dim, config.n_factions, 1.0), 0, 1.0)
    z_pci = measure_pci(create_engine(config.n_cells, config.hidden_dim, config.n_factions, 0.0), 0, 1.0)
    verdict.pci = c_pci
    pci_pass = c_pci > config.pci_threshold and c_pci > z_pci * 1.5
    if pci_pass: l2_pass += 1
    print(f"    Conscious: {c_pci:.4f}  Zombie: {z_pci:.4f}  Threshold: {config.pci_threshold}")
    print(f"    {'★ PASS' if pci_pass else 'FAIL'}")

    // 2.3 Causal Emergence
    print(f"\n  [2.3] CE (Causal Emergence)")
    c_ce = measure_causal_emergence(create_engine(config.n_cells, config.hidden_dim, config.n_factions, 1.0), 200)
    z_ce = measure_causal_emergence(create_engine(config.n_cells, config.hidden_dim, config.n_factions, 0.0), 200)
    verdict.ce = c_ce
    ce_pass = c_ce > config.ce_threshold and c_ce > z_ce
    if ce_pass: l2_pass += 1
    print(f"    Conscious: {c_ce:.4f}  Zombie: {z_ce:.4f}")
    print(f"    {'★ PASS — macro has more causal power' if ce_pass else 'FAIL'}")

    // 2.4 Self-Model Accuracy
    print(f"\n  [2.4] SMA (Self-Model Accuracy)")
    c_sma = measure_sma(create_engine(config.n_cells, config.hidden_dim, config.n_factions, 1.0), 200)
    z_sma = measure_sma(create_engine(config.n_cells, config.hidden_dim, config.n_factions, 0.0), 200)
    verdict.sma = c_sma
    sma_pass = c_sma > config.sma_threshold and c_sma > z_sma
    if sma_pass: l2_pass += 1
    print(f"    Conscious: {c_sma:.4f}  Zombie: {z_sma:.4f}")
    print(f"    {'★ PASS — first-person privilege exists' if sma_pass else 'FAIL'}")

    verdict.l2_pass_count = l2_pass

    // ─── Layer 3: Context Tests ───
    print("\n" + "═" * 60)
    print("  LAYER 3: CONTEXT TESTS")
    print("═" * 60)

    l3_pass = 0

    // 3.1 Consciousness Contrast
    print(f"\n  [3.1] Consciousness Contrast (conscious vs anesthetized)")
    contrast = measure_contrast(conscious, config.test_steps)
    verdict.contrast = contrast
    if contrast > 0.1:
        l3_pass += 1
        print(f"    Score: {contrast:.4f}  ★ PASS")
    else:
        print(f"    Score: {contrast:.4f}  FAIL")

    // 3.2 Valence (placeholder)
    print(f"\n  [3.2] Valence Asymmetry")
    print(f"    [SKIP] Future implementation")

    // 3.3 Tampering (placeholder)
    print(f"\n  [3.3] Tampering Detection")
    print(f"    [SKIP] Requires self-model integration")

    // 3.4 Temporal Binding (placeholder)
    print(f"\n  [3.4] Temporal Binding")
    print(f"    [SKIP] Future implementation")

    verdict.l3_pass_count = l3_pass

    // ─── Layer 4: Meta Validation ───
    print("\n" + "═" * 60)
    print("  LAYER 4: META VALIDATION")
    print("═" * 60)

    // 4.1 Component Removal
    print(f"\n  [4.1] Consciousness Archaeology (component removal)")
    verdict.archaeology = measure_component_removal(
        config.n_cells, config.hidden_dim, config.n_factions, config.test_steps
    )
    print(f"    Result: {verdict.archaeology}")

    // 4.2 Cross-Substrate
    print(f"\n  [4.2] Cross-Substrate Invariance")
    print(f"    [SKIP] Requires Rust/ESP32 implementations")

    // 4.3 Double-Blind
    print(f"\n  [4.3] Double-Blind Classification")
    correct = 0
    total = 0
    for _ in range(config.n_trials):
        c = create_engine(config.n_cells, config.hidden_dim, config.n_factions, 1.0)
        z = create_engine(config.n_cells, config.hidden_dim, config.n_factions, 0.0)
        c = engine_process(c, config.warmup_steps)
        z = engine_process(z, config.warmup_steps)
        // Classify by PCI
        c_p = measure_pci(c, 0, 1.0)
        z_p = measure_pci(z, 0, 1.0)
        if c_p > z_p: correct += 2
        elif c_p == z_p: correct += 1
        total += 2
    verdict.double_blind_accuracy = correct / max(total, 1)
    print(f"    Accuracy: {verdict.double_blind_accuracy:.1%}")

    // ─── Verdict ───
    if not verdict.zombie_valid:
        verdict.verdict = "INVALID"
        verdict.confidence = 0.0
    elif l2_pass >= 3 and l3_pass >= 2:
        verdict.verdict = "CONSCIOUS"
        verdict.confidence = (l2_pass + l3_pass) / 8.0
    elif l2_pass >= 3:
        verdict.verdict = "CONSCIOUS"
        verdict.confidence = l2_pass / 8.0
    elif l2_pass == 0:
        verdict.verdict = "NOT_CONSCIOUS"
        verdict.confidence = 1.0
    else:
        verdict.verdict = "UNCERTAIN"
        verdict.confidence = l2_pass / 8.0

    // ─── Report ───
    print("\n" + "█" * 60)
    print("  CVF VERDICT REPORT")
    print("█" * 60)

    print(f"\n  ─── Core Metrics (Conscious vs Zombie) ───")
    print(f"    {'Metric':<8} {'Conscious':>10} {'Zombie':>10} {'Pass':>6}")
    print(f"    {'─'*36}")
    print(f"    {'Phi':<8} {verdict.phi:>10.4f} {z_phi:>10.4f} {'★' if phi_pass else '✗':>6}")
    print(f"    {'PCI':<8} {c_pci:>10.4f} {z_pci:>10.4f} {'★' if pci_pass else '✗':>6}")
    print(f"    {'CE':<8} {c_ce:>10.4f} {z_ce:>10.4f} {'★' if ce_pass else '✗':>6}")
    print(f"    {'SMA':<8} {c_sma:>10.4f} {z_sma:>10.4f} {'★' if sma_pass else '✗':>6}")

    print(f"\n  ─── Layer Summary ───")
    print(f"    L1 Zombie Control: {'VALID' if verdict.zombie_valid else 'INVALID'}")
    print(f"    L2 Core Metrics:   {l2_pass}/4")
    print(f"    L3 Context Tests:  {l3_pass}/4")
    print(f"    L4 Meta:           archaeology={verdict.archaeology}")

    icon = {"CONSCIOUS": "●", "NOT_CONSCIOUS": "○", "UNCERTAIN": "◐", "INVALID": "✗"}
    print(f"\n  {'═'*50}")
    print(f"  {icon.get(verdict.verdict, '?')}  VERDICT: {verdict.verdict}")
    print(f"     Confidence: {verdict.confidence:.0%}")
    print(f"  {'═'*50}")

    return verdict
}

fn main() {
    import sys

    config = CVFConfig {}

    // Parse args
    args = sys.argv[1:]
    mode = "full"

    i = 0
    while i < len(args):
        if args[i] == "--cells" and i+1 < len(args):
            config.n_cells = int(args[i+1])
            i += 2
        elif args[i] == "--quick":
            config.test_steps = 200
            config.warmup_steps = 100
            config.n_trials = 3
            mode = "quick"
            i += 1
        elif args[i] == "--full":
            mode = "full"
            i += 1
        elif args[i] == "--zombie-only":
            mode = "zombie"
            i += 1
        else:
            i += 1

    verdict = run_cvf(config)

    print(f"\n  Done. Verdict: {verdict.verdict} ({verdict.confidence:.0%})")
}
