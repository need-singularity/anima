// perf_hooks.hexa — Zero-overhead performance profiling
// TODO[pytorch]: port PerfMonitor, timeit decorator, PERF global

struct PerfEntry {
    name: string,
    total_ms: float,
    count: int
}

struct PerfMonitor {
    enabled: bool,
    n_entries: int
}

fn perf_new() -> PerfMonitor {
    PerfMonitor { enabled: false, n_entries: 0 }
}

fn perf_enable(m: PerfMonitor) -> PerfMonitor {
    PerfMonitor { enabled: true, n_entries: m.n_entries }
}

fn perf_measure(m: PerfMonitor, name: string, elapsed_ms: float) -> PerfMonitor {
    // TODO[pytorch]: accumulate timing for named operation
    PerfMonitor { enabled: m.enabled, n_entries: m.n_entries + 1 }
}

fn perf_report(m: PerfMonitor) -> string {
    // TODO[pytorch]: format all entries as table
    ""
}
