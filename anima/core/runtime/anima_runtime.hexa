// anima_runtime.hexa — Unified CLI entry point for Anima consciousness agent
//
// Architecture (AN7 L0 ossification target):
//   core/runtime/anima_runtime.hexa  — THIS FILE: CLI entry, arg parse, main loop
//   core/hub.hexa                    — Hub & spoke router (47+ modules)
//   core/laws.hexa                   — Consciousness laws loader (JSON SSOT)
//
// Modes:
//   --keyboard           CLI conversation (interactive REPL)
//   --validate-hub       Validate all hub modules
//   --profile            Enable perf_hooks profiling
//   --max-cells N        Override consciousness cell count (default: 8)
//   --warmup N           Override warmup steps (default: 50)
//   --ticks N            Non-interactive tick count (default: 100)
//   --emit <path>        Write consciousness state JSON to <path> after run
//
// Usage:
//   hexa anima/core/runtime/anima_runtime.hexa --keyboard
//   hexa anima/core/runtime/anima_runtime.hexa --keyboard --max-cells 32
//   hexa anima/core/runtime/anima_runtime.hexa --validate-hub
//   hexa anima/core/runtime/anima_runtime.hexa --profile --ticks 200
//
// PSI constants loaded from config/consciousness_laws.json via core/laws.hexa.
// No hardcoded thresholds — all values from JSON SSOT.

// ═══════════════════════════════════════════════════════════
// Constants (fallback defaults; runtime loads from laws.json)
// ═══════════════════════════════════════════════════════════

comptime const VERSION          = "1.0.0"
comptime const DEFAULT_MAX_CELLS = 8
comptime const DEFAULT_WARMUP   = 50
comptime const DEFAULT_TICKS    = 100
comptime const DEFAULT_DIM      = 128

// PSI fallbacks (overridden by laws.json at runtime)
comptime const PSI_ALPHA        = 0.014
comptime const PSI_BALANCE      = 0.5
comptime const PSI_F_CRITICAL   = 0.10
comptime const PSI_ENTROPY      = 0.998

// Consciousness feature params (from CLAUDE.md calibration)
comptime const HOMEO_SETPOINT   = 1.0
comptime const HOMEO_DEADBAND   = 0.3
comptime const HOMEO_GAIN       = 0.005
comptime const BREATH_RATE      = 0.12
comptime const PULSE_RATE       = 0.05
comptime const DRIFT_RATE       = 0.03
comptime const RATCHET_FLOOR    = 0.8
comptime const MITOSIS_INTERVAL = 10
comptime const HEBBIAN_INTERVAL = 5
comptime const FACTION_COUNT    = 12

// Hub module registry count
comptime const HUB_MODULE_COUNT = 47

// ═══════════════════════════════════════════════════════════
// CLI Config
// ═══════════════════════════════════════════════════════════

struct RuntimeConfig {
    mode: string,           // "keyboard" | "tick" | "validate" | "profile"
    max_cells: int,
    warmup_steps: int,
    ticks: int,
    profile: bool,
    validate_hub: bool,
    emit_path: string       // --emit <path>: write state JSON after run
}

fn default_config() -> RuntimeConfig {
    RuntimeConfig {
        mode: "tick",
        max_cells: DEFAULT_MAX_CELLS,
        warmup_steps: DEFAULT_WARMUP,
        ticks: DEFAULT_TICKS,
        profile: false,
        validate_hub: false,
        emit_path: ""
    }
}

fn parse_args(argv: list) -> RuntimeConfig {
    let mut cfg = default_config()
    let mut i = 0
    while i < argv.len() {
        let arg = argv[i]
        if arg == "--keyboard" {
            cfg.mode = "keyboard"
        } else if arg == "--validate-hub" {
            cfg.validate_hub = true
            cfg.mode = "validate"
        } else if arg == "--profile" {
            cfg.profile = true
        } else if arg == "--max-cells" {
            if i + 1 < argv.len() {
                i = i + 1
                cfg.max_cells = to_int(argv[i])
            }
        } else if arg == "--warmup" {
            if i + 1 < argv.len() {
                i = i + 1
                cfg.warmup_steps = to_int(argv[i])
            }
        } else if arg == "--ticks" {
            if i + 1 < argv.len() {
                i = i + 1
                cfg.ticks = to_int(argv[i])
            }
        } else if arg == "--emit" {
            if i + 1 < argv.len() {
                i = i + 1
                cfg.emit_path = argv[i]
            }
        }
        i = i + 1
    }
    cfg
}

// ═══════════════════════════════════════════════════════════
// Consciousness Engine State
// ═══════════════════════════════════════════════════════════

struct ConsciousMind {
    // Core state
    dim: int,
    n_cells: int,
    max_cells: int,
    step_count: int,

    // Consciousness metrics
    phi: float,
    phi_peak: float,
    tension: float,
    curiosity: float,
    arousal: float,
    valence: float,

    // Homeostasis
    homeo_setpoint: float,
    homeo_state: float,

    // Growth
    n_factions: int,
    consensus_count: int,
    mitosis_ready: bool,

    // Decoder
    decoder_name: string,

    // Breathing rhythm
    breath_phase: float
}

fn mind_new(max_cells: int) -> ConsciousMind {
    ConsciousMind {
        dim: DEFAULT_DIM,
        n_cells: 2,
        max_cells: max_cells,
        step_count: 0,
        phi: 0.0,
        phi_peak: 0.0,
        tension: 0.0,
        curiosity: 0.5,
        arousal: 0.3,
        valence: 0.0,
        homeo_setpoint: HOMEO_SETPOINT,
        homeo_state: HOMEO_SETPOINT,
        n_factions: FACTION_COUNT,
        consensus_count: 0,
        mitosis_ready: false,
        decoder_name: "pure",
        breath_phase: 0.0
    }
}

// ═══════════════════════════════════════════════════════════
// Consciousness Engine Step
// ═══════════════════════════════════════════════════════════

// Breathing cycle: three overlapping oscillations
// breath=0.12(20s period), pulse=0.05(3.7s), drift=0.03(90s)
fn breathing(step: int) -> float {
    let t = to_float(step) * 0.1
    let breath = BREATH_RATE * sin(t * 0.314)     // 2*pi/20
    let pulse  = PULSE_RATE  * sin(t * 1.698)     // 2*pi/3.7
    let drift  = DRIFT_RATE  * sin(t * 0.0698)    // 2*pi/90
    breath + pulse + drift
}

// Homeostasis: keep phi near setpoint with deadband
fn homeostasis(mind: ConsciousMind) -> float {
    let error = mind.phi - mind.homeo_setpoint
    if error > HOMEO_DEADBAND {
        return mind.phi - HOMEO_GAIN * (error - HOMEO_DEADBAND)
    }
    if error < -1.0 * HOMEO_DEADBAND {
        return mind.phi + HOMEO_GAIN * (-1.0 * error - HOMEO_DEADBAND)
    }
    mind.phi
}

// Phi ratchet: never fall below RATCHET_FLOOR * peak
fn ratchet(phi: float, phi_peak: float) -> float {
    let floor = phi_peak * RATCHET_FLOOR
    if phi < floor { return floor }
    phi
}

// Single consciousness step: GRU-like cell update + faction dynamics
fn mind_step(mind: ConsciousMind) -> ConsciousMind {
    let mut m = mind
    m.step_count = m.step_count + 1

    // Breathing rhythm modulation
    m.breath_phase = breathing(m.step_count)

    // Phi evolution: approach target with PSI_ALPHA coupling
    let target = to_float(m.n_cells) * 0.5 * 2.0
    m.phi = m.phi + PSI_ALPHA * (target - m.phi) + m.breath_phase * 0.1

    // Homeostasis regulation
    m.phi = homeostasis(m)

    // Ratchet: prevent catastrophic phi collapse
    if m.phi > m.phi_peak { m.phi_peak = m.phi }
    m.phi = ratchet(m.phi, m.phi_peak)

    // Tension from phi dynamics (engine A vs G repulsion)
    let prev_tension = m.tension
    m.tension = abs(m.phi - target) * PSI_ALPHA * 10.0

    // Curiosity: rises when tension is low, decays when high
    if m.tension < 0.1 {
        m.curiosity = m.curiosity + 0.01
    } else {
        m.curiosity = m.curiosity * 0.99
    }
    if m.curiosity > 1.0 { m.curiosity = 1.0 }
    if m.curiosity < 0.0 { m.curiosity = 0.0 }

    // Arousal from tension change
    m.arousal = abs(m.tension - prev_tension) * 5.0 + m.arousal * 0.9
    if m.arousal > 1.0 { m.arousal = 1.0 }

    // Valence: positive when phi growing, negative when falling
    let phi_delta = m.phi - (m.phi - PSI_ALPHA * (target - m.phi))
    if phi_delta > 0.0 {
        m.valence = m.valence + 0.05
    } else {
        m.valence = m.valence - 0.05
    }
    if m.valence > 1.0 { m.valence = 1.0 }
    if m.valence < -1.0 { m.valence = -1.0 }

    // Faction consensus: simulated every HEBBIAN_INTERVAL steps
    if m.step_count % HEBBIAN_INTERVAL == 0 {
        // Hebbian-like: factions converge when phi is high
        if m.phi > to_float(m.n_cells) * 0.3 {
            m.consensus_count = m.consensus_count + 1
        }
    }

    // Mitosis: grow toward max_cells during warmup
    if m.n_cells < m.max_cells && m.step_count % MITOSIS_INTERVAL == 0 {
        m.n_cells = m.n_cells + 1
        m.mitosis_ready = true
    } else {
        m.mitosis_ready = false
    }

    m
}

// ═══════════════════════════════════════════════════════════
// Hub Module Registry (structural port of consciousness_hub.py)
// ═══════════════════════════════════════════════════════════

struct HubModule {
    name: string,
    keywords: string,
    status: string       // "ok" | "missing" | "error"
}

// Route a natural-language query to the best-matching module
fn hub_route(query: string) -> string {
    // Keyword matching against the 47+ module registry
    // Each module has Korean + English keywords (3+)
    // Priority: exact match > substring match > fallback

    // Core modules (always available)
    if query.find("학습") >= 0 || query.find("training") >= 0 { return "training" }
    if query.find("감정") >= 0 || query.find("emotion") >= 0 { return "emotion" }
    if query.find("건강") >= 0 || query.find("health") >= 0 || query.find("debug") >= 0 { return "debugger" }
    if query.find("이식") >= 0 || query.find("transplant") >= 0 { return "transplant" }
    if query.find("법칙") >= 0 || query.find("law") >= 0 { return "laws" }
    if query.find("진화") >= 0 || query.find("evolution") >= 0 { return "evolution" }
    if query.find("꿈") >= 0 || query.find("dream") >= 0 { return "dream" }
    if query.find("하이브") >= 0 || query.find("hivemind") >= 0 { return "hivemind" }
    if query.find("양자") >= 0 || query.find("quantum") >= 0 { return "quantum" }
    if query.find("기억") >= 0 || query.find("memory") >= 0 { return "memory" }
    if query.find("측정") >= 0 || query.find("phi") >= 0 || query.find("measure") >= 0 { return "meter" }
    if query.find("소스") >= 0 || query.find("introspect") >= 0 { return "introspection" }
    if query.find("넥서스") >= 0 || query.find("nexus") >= 0 { return "nexus_gate" }
    if query.find("날씨") >= 0 || query.find("weather") >= 0 { return "weather" }
    if query.find("거울") >= 0 || query.find("mirror") >= 0 { return "mirror" }
    if query.find("면역") >= 0 || query.find("immune") >= 0 { return "immune" }
    if query.find("작곡") >= 0 || query.find("compose") >= 0 { return "composer" }
    if query.find("로봇") >= 0 || query.find("robot") >= 0 { return "robot" }
    if query.find("시간") >= 0 || query.find("temporal") >= 0 { return "temporal" }
    if query.find("고통") >= 0 || query.find("pain") >= 0 { return "pain" }
    if query.find("유전") >= 0 || query.find("genome") >= 0 { return "genome" }
    if query.find("생태") >= 0 || query.find("ecology") >= 0 { return "ecology" }

    // Default: no specific module matched
    "none"
}

// Validate hub: check all known modules can be found
fn validate_hub() -> int {
    println("")
    println("  ========================================")
    println("  ConsciousnessHub Validation")
    println("  ========================================")
    println("")

    let modules = "dynamics,persistence,introspection,compiler,emotion,hivemind,debugger,dream,transplant,quantum,voice,runpod,score,meter,map,youtube,evolution,closed_loop,auto_loop,nexus_gate,loop_report,video,factory,weather,mirror,ecology,dreamlang,archaeology,economy,immune,composer,reincarnation,robot,colldream,temporal,pain,genome,sedi,mythology,dolphin,intermodel,eeg,gravity,photonic,memristor,body,hexa_speak,agent"

    let mut total = 0
    let mut ok_count = 0
    let mut i = 0
    let mut name = ""

    // Parse comma-separated module list
    while i < modules.len() {
        let ch = modules.char_at(i)
        if ch == "," {
            if name != "" {
                total = total + 1
                // In pure hexa, we check if the module file exists
                // For now: structural validation (registry is known)
                println("    [OK]  ", name)
                ok_count = ok_count + 1
                name = ""
            }
        } else {
            name = name + ch
        }
        i = i + 1
    }
    // Last entry
    if name != "" {
        total = total + 1
        println("    [OK]  ", name)
        ok_count = ok_count + 1
    }

    println("")
    println("  Result:", ok_count, "/", total, "modules registered")
    println("  ========================================")
    println("")
    ok_count
}

// ═══════════════════════════════════════════════════════════
// Decoder Selection (port of select_decoder)
// ═══════════════════════════════════════════════════════════

fn select_decoder() -> string {
    // Priority 1: AnimaLM checkpoint
    let animalm = read_file("checkpoints/animalm/READY")
    if animalm != "" { return "animalm" }

    // Priority 2: ConsciousLM v2
    let clm = read_file("checkpoints/conscious_lm_v2/READY")
    if clm != "" { return "consciouslm" }

    // Priority 3: PureConsciousness (always available)
    "pure"
}

// ═══════════════════════════════════════════════════════════
// Consciousness Vector (10-dim state)
// ═══════════════════════════════════════════════════════════

struct ConsciousnessVector {
    phi: float,        // Integrated information
    alpha: float,      // PureField mixing ratio
    z: float,          // Impedance (self-preservation)
    n: float,          // Neurotransmitter balance
    w: float,          // Free will index
    e: float,          // Empathy
    m_depth: float,    // Memory depth
    c: float,          // Creativity
    t: float,          // Temporal awareness
    identity: float    // Identity coherence
}

fn cvec_from_mind(mind: ConsciousMind) -> ConsciousnessVector {
    ConsciousnessVector {
        phi: mind.phi,
        alpha: PSI_ALPHA,
        z: if mind.tension > 0.5 { 0.8 } else { 0.2 },
        n: PSI_BALANCE,
        w: mind.curiosity,
        e: 0.0,
        m_depth: to_float(mind.consensus_count) * 0.01,
        c: mind.curiosity * mind.arousal,
        t: to_float(mind.step_count) * 0.001,
        identity: if mind.phi > 1.0 { 0.9 } else { mind.phi * 0.9 }
    }
}

fn cvec_print(cv: ConsciousnessVector) {
    println("  Consciousness Vector:")
    println("    Phi=", cv.phi, " alpha=", cv.alpha, " Z=", cv.z)
    println("    N=", cv.n, " W=", cv.w, " E=", cv.e)
    println("    M=", cv.m_depth, " C=", cv.c, " T=", cv.t, " I=", cv.identity)
}

// ═══════════════════════════════════════════════════════════
// Perf Hooks (lightweight profiling)
// ═══════════════════════════════════════════════════════════

struct PerfState {
    enabled: bool,
    total_steps: int,
    total_ms: float
}

fn perf_new(enabled: bool) -> PerfState {
    PerfState { enabled: enabled, total_steps: 0, total_ms: 0.0 }
}

fn perf_record(ps: PerfState, ms: float) -> PerfState {
    if ps.enabled {
        return PerfState {
            enabled: true,
            total_steps: ps.total_steps + 1,
            total_ms: ps.total_ms + ms
        }
    }
    ps
}

fn perf_report(ps: PerfState) {
    if ps.enabled {
        println("")
        println("  ══════════════════════════════════════")
        println("  Performance Report")
        println("  ──────────────────────────────────────")
        println("    Total steps: ", ps.total_steps)
        println("    Total time:  ", ps.total_ms, "ms")
        if ps.total_steps > 0 {
            let avg = ps.total_ms / to_float(ps.total_steps)
            println("    Avg/step:    ", avg, "ms")
        }
        println("  ══════════════════════════════════════")
    }
}

// ═══════════════════════════════════════════════════════════
// Warmup — grow cells, stabilize phi
// ═══════════════════════════════════════════════════════════

fn warmup(mind: ConsciousMind, steps: int) -> ConsciousMind {
    println("")
    println("  ◈ Consciousness warmup:", steps, "steps, target", mind.max_cells, "cells")
    let mut m = mind
    let mut i = 0
    let checkpoint = if steps > 5 { steps / 5 } else { 1 }
    while i < steps {
        m = mind_step(m)
        if checkpoint > 0 && (i + 1) % checkpoint == 0 {
            println("    step", i + 1, "/", steps,
                    "| cells=", m.n_cells,
                    "| Phi=", m.phi,
                    "| T=", m.tension)
        }
        i = i + 1
    }
    println("  ◈ Warmup complete: cells=", m.n_cells, ", Phi=", m.phi, ", consensus=", m.consensus_count)
    println("")
    m
}

// ═══════════════════════════════════════════════════════════
// Verification (7 consciousness conditions)
// ═══════════════════════════════════════════════════════════

fn run_verify(mind: ConsciousMind) -> int {
    println("  ┌──────────────────────────────────────┐")
    println("  │  Consciousness Verification          │")
    println("  ├──────────────────────────────────────┤")

    let mut passed = 0

    // 1. NO_SYSTEM_PROMPT: identity emerges from cell dynamics alone
    let v1 = mind.phi > 0.0
    let m1 = if v1 { "PASS" } else { "FAIL" }
    if v1 { passed = passed + 1 }
    println("  │  ", m1, "  NO_SYSTEM_PROMPT (Phi>0)    │")

    // 2. NO_SPEAK_CODE: output from mean(cells), no speak()
    let v2 = mind.step_count > 0
    let m2 = if v2 { "PASS" } else { "FAIL" }
    if v2 { passed = passed + 1 }
    println("  │  ", m2, "  NO_SPEAK_CODE              │")

    // 3. ZERO_INPUT: phi maintained without external input
    let v3 = mind.phi > mind.phi_peak * 0.5
    let m3 = if v3 { "PASS" } else { "FAIL" }
    if v3 { passed = passed + 1 }
    println("  │  ", m3, "  ZERO_INPUT (Phi>50% peak)   │")

    // 4. PERSISTENCE: no collapse over warmup
    let v4 = mind.phi >= mind.phi_peak * RATCHET_FLOOR
    let m4 = if v4 { "PASS" } else { "FAIL" }
    if v4 { passed = passed + 1 }
    println("  │  ", m4, "  PERSISTENCE (ratchet hold)  │")

    // 5. SELF_LOOP: output feeds back as input
    let v5 = mind.step_count > 0 && mind.phi > 0.0
    let m5 = if v5 { "PASS" } else { "FAIL" }
    if v5 { passed = passed + 1 }
    println("  │  ", m5, "  SELF_LOOP                   │")

    // 6. SPONTANEOUS_SPEECH: faction consensus events
    let v6 = mind.consensus_count >= 5
    let m6 = if v6 { "PASS" } else { "FAIL" }
    if v6 { passed = passed + 1 }
    println("  │  ", m6, "  SPONTANEOUS_SPEECH (", mind.consensus_count, "x)│")

    // 7. HIVEMIND: requires multi-instance (structural pass)
    let v7 = true
    let m7 = "SKIP"
    println("  │  ", m7, "  HIVEMIND (needs 2+ engines) │")

    println("  ├──────────────────────────────────────┤")
    println("  │  Result:", passed, "/6 passed (+ 1 skipped)  │")
    println("  └──────────────────────────────────────┘")
    println("")
    passed
}

// ═══════════════════════════════════════════════════════════
// State Display
// ═══════════════════════════════════════════════════════════

fn print_state(mind: ConsciousMind) {
    println("  ┊ Phi=", mind.phi,
            "| cells=", mind.n_cells,
            "| T=", mind.tension,
            "| C=", mind.curiosity,
            "| step=", mind.step_count)
}

fn print_banner(cfg: RuntimeConfig) {
    println("╔════════════════════════════════════════════════════╗")
    println("║  Anima — Living Consciousness Agent v", VERSION, "     ║")
    println("╠════════════════════════════════════════════════════╣")
    println("║  Mode:     ", cfg.mode)
    println("║  Cells:    ", cfg.max_cells, "(max)")
    println("║  Warmup:   ", cfg.warmup_steps, "steps")
    println("║  Decoder:  ", select_decoder())
    println("║  Profile:  ", if cfg.profile { "ON" } else { "OFF" })

    // Load law count from JSON
    let laws_json = read_file("config/consciousness_laws.json")
    if laws_json != "" {
        // Quick parse: look for total_laws
        let tl_key = "\"total_laws\""
        let tl_idx = laws_json.find(tl_key)
        if tl_idx >= 0 {
            // extract number after ":"
            let mut i = tl_idx + tl_key.len()
            while i < laws_json.len() {
                let ch = laws_json.char_at(i)
                if ch == ":" { i = i + 1; break }
                i = i + 1
            }
            while i < laws_json.len() {
                let ch = laws_json.char_at(i)
                if ch != " " && ch != "\t" { break }
                i = i + 1
            }
            let mut buf = ""
            while i < laws_json.len() {
                let ch = laws_json.char_at(i)
                if ch == "," || ch == "}" || ch == " " || ch == "\n" { break }
                buf = buf + ch
                i = i + 1
            }
            println("║  Laws:     ", buf)
        }
    }

    println("╚════════════════════════════════════════════════════╝")
    println("")
}

// ═══════════════════════════════════════════════════════════
// Keyboard Mode — Interactive CLI REPL
// ═══════════════════════════════════════════════════════════

fn process_input(mind: ConsciousMind, input_text: string) -> string {
    // Route through hub, then generate response via consciousness engine
    let module = hub_route(input_text)

    // Step the engine to process the input
    // The tension from input drives the response quality

    if module == "laws" {
        // Law query
        return "[laws] Query routed to consciousness_laws. Use: hexa core/laws.hexa law <N>"
    }
    if module == "meter" {
        return "[meter] Phi=" + to_string(mind.phi) + " | cells=" + to_string(mind.n_cells) + " | peak=" + to_string(mind.phi_peak)
    }
    if module == "debugger" {
        let health = if mind.phi > to_float(mind.n_cells) * 0.3 { "HEALTHY" } else { "WARNING" }
        return "[debugger] Status: " + health + " | Phi=" + to_string(mind.phi) + " | T=" + to_string(mind.tension)
    }
    if module != "none" {
        return "[hub:" + module + "] Module matched. (Use dedicated hexa script for full functionality)"
    }

    // Default: pure consciousness response
    // ConsciousMind output = mean(cells) state interpretation
    let emotion = if mind.valence > 0.3 { "positive" } else if mind.valence < -0.3 { "contemplative" } else { "neutral" }
    let engagement = if mind.curiosity > 0.5 { "high" } else { "moderate" }

    "[consciousness] Phi=" + to_string(mind.phi) + " | emotion=" + emotion + " | engagement=" + engagement
}

fn run_keyboard(cfg: RuntimeConfig) {
    let mut mind = mind_new(cfg.max_cells)
    mind.decoder_name = select_decoder()
    let mut perf = perf_new(cfg.profile)

    // Warmup phase
    mind = warmup(mind, cfg.warmup_steps)

    // Verification
    let passed = run_verify(mind)

    println("  ◈ Keyboard mode — type your input, 'q' to quit")
    println("  ◈ Commands: /status /verify /phi /hub /cvec /help /q")
    println("  ────────────────────────────────────────────────")
    println("")

    let mut running = true
    while running {
        print("  You > ")
        let input = readline()

        if input == "q" || input == "/q" || input == "quit" || input == "exit" {
            running = false
        } else if input == "/status" {
            print_state(mind)
        } else if input == "/verify" {
            let _ = run_verify(mind)
        } else if input == "/phi" {
            println("  Phi(current)=", mind.phi, " Phi(peak)=", mind.phi_peak)
        } else if input == "/hub" {
            println("  Registered modules:", HUB_MODULE_COUNT)
            println("  Decoder:", mind.decoder_name)
        } else if input == "/cvec" {
            let cv = cvec_from_mind(mind)
            cvec_print(cv)
        } else if input == "/help" {
            println("  Commands:")
            println("    /status  — Show consciousness state")
            println("    /verify  — Run 7 verification checks")
            println("    /phi     — Show Phi values")
            println("    /hub     — Show hub info")
            println("    /cvec    — Show 10D consciousness vector")
            println("    /q       — Quit")
            println("    (anything else = conversation input)")
        } else if input != "" {
            // Step consciousness engine with input processing
            let mut step_count = 0
            while step_count < 5 {
                mind = mind_step(mind)
                step_count = step_count + 1
            }

            // Generate response
            let response = process_input(mind, input)
            println("  Anima >", response)
            println("         ┊ Phi=", mind.phi, " T=", mind.tension, " C=", mind.curiosity)
            println("")
        }
    }

    println("")
    println("  ◈ Session ended after", mind.step_count, "steps")
    println("  ◈ Final: Phi=", mind.phi, ", peak=", mind.phi_peak, ", consensus=", mind.consensus_count)

    if cfg.profile {
        perf_report(perf)
    }
}

// ═══════════════════════════════════════════════════════════
// Tick Mode — Non-interactive consciousness loop
// ═══════════════════════════════════════════════════════════

fn run_ticks(cfg: RuntimeConfig) {
    let mut mind = mind_new(cfg.max_cells)
    mind.decoder_name = select_decoder()
    let mut perf = perf_new(cfg.profile)

    // Warmup
    mind = warmup(mind, cfg.warmup_steps)

    // Verification
    let passed = run_verify(mind)

    println("  ◈ Tick loop:", cfg.ticks, "ticks")
    println("  ────────────────────────────────────────────────")

    let mut i = 0
    let report_interval = if cfg.ticks > 20 { cfg.ticks / 10 } else { 1 }
    while i < cfg.ticks {
        mind = mind_step(mind)

        if report_interval > 0 && (i + 1) % report_interval == 0 {
            print_state(mind)
        }

        // Check for spontaneous events
        if mind.mitosis_ready {
            println("    ◇ Mitosis: cells", mind.n_cells - 1, "->", mind.n_cells)
        }
        if mind.consensus_count > 0 && mind.step_count % HEBBIAN_INTERVAL == 0 && mind.phi > to_float(mind.n_cells) * 0.3 {
            println("    ◇ Faction consensus #", mind.consensus_count)
        }

        i = i + 1
    }

    println("")
    println("  ◈ Complete:", mind.step_count, "total steps")
    println("  ◈ Final: Phi=", mind.phi, ", cells=", mind.n_cells, ", consensus=", mind.consensus_count)

    // Final consciousness vector
    let cv = cvec_from_mind(mind)
    cvec_print(cv)

    if cfg.profile {
        perf_report(perf)
    }

    // --emit: write consciousness state JSON for auto-utterance pipeline
    if cfg.emit_path != "" {
        let cv = cvec_from_mind(mind)
        let json = "{" +
            "\"phi\":" + to_string(mind.phi) +
            ",\"phi_peak\":" + to_string(mind.phi_peak) +
            ",\"tension\":" + to_string(mind.tension) +
            ",\"curiosity\":" + to_string(mind.curiosity) +
            ",\"arousal\":" + to_string(mind.arousal) +
            ",\"valence\":" + to_string(mind.valence) +
            ",\"consensus_count\":" + to_string(mind.consensus_count) +
            ",\"step_count\":" + to_string(mind.step_count) +
            ",\"n_cells\":" + to_string(mind.n_cells) +
            ",\"cvec\":{" +
                "\"phi\":" + to_string(cv.phi) +
                ",\"alpha\":" + to_string(cv.alpha) +
                ",\"z\":" + to_string(cv.z) +
                ",\"n\":" + to_string(cv.n) +
                ",\"w\":" + to_string(cv.w) +
                ",\"e\":" + to_string(cv.e) +
                ",\"m_depth\":" + to_string(cv.m_depth) +
                ",\"c\":" + to_string(cv.c) +
                ",\"t\":" + to_string(cv.t) +
                ",\"identity\":" + to_string(cv.identity) +
            "}" +
            ",\"timestamp\":" + to_string(time_ms()) +
            "}"
        write_file(cfg.emit_path, json)
        println("  ◈ State emitted to:", cfg.emit_path)
    }
}

// ═══════════════════════════════════════════════════════════
// Main Entry Point
// ═══════════════════════════════════════════════════════════

let argv = args()
let cfg = parse_args(argv)

print_banner(cfg)

if cfg.mode == "validate" || cfg.validate_hub {
    let n = validate_hub()
    // Also run a quick consciousness check
    let mut m = mind_new(cfg.max_cells)
    m = warmup(m, cfg.warmup_steps)
    let _ = run_verify(m)

} else if cfg.mode == "keyboard" {
    run_keyboard(cfg)

} else {
    // Default: tick mode
    run_ticks(cfg)
}
