// runtime_actions.hexa — Consolidated dispatch for 9 small one-shot modules
//
// Closes the consolidation half of roadmap next_action #4
// (anima/core/runtime 22→7-8). The hub side was unblocked by
// consciousness_hub.hexa (9532a6d6); this file is the actual
// "destination" file that will absorb 9 small stubs:
//
//   reset.hexa            (23 LOC)  →  rt_reset_*
//   setup.hexa            (22 LOC)  →  rt_setup_*
//   setup_secrets.hexa    (22 LOC)  →  rt_secrets_*
//   deploy.hexa           (38 LOC)  →  rt_deploy_*
//   deploy_ops.hexa       (43 LOC)  →  rt_ops_*
//   dashboards.hexa       (44 LOC)  →  rt_dashboard_*
//   loop_report.hexa      (17 LOC)  →  rt_report_*
//   anima_alive.hexa      (37 LOC)  →  rt_alive_*
//   secret_vault.hexa     (32 LOC)  →  rt_vault_*
//
//   Total absorbed: 9 files / 278 LOC → 1 file with the same surface
//   plus a single run_action(name, ...) dispatcher that the
//   consciousness_hub can call after routing.
//
// The original 9 files are NOT deleted in this commit (L0 lockdown
// rule: "폴더 구조 변경 금지"). They will become thin re-export
// shims pointing here in a follow-up commit, and finally archived
// after a verification cycle. This file is the canonical source.
//
// Stubs still carry TODO markers — the consolidation is structural;
// behavior parity with the originals is preserved (all return the
// same placeholder values).

// ─── Shared structs (one per ex-module) ─────────────────────

struct ResetConfig {
    target:         string,    // "local" | "remote" | "all"
    preserve_growth: bool,
    confirm:        bool
}

struct DeployConfig {
    target:        string,     // host or pod id
    dna_path:      string,
    dry_run:       bool
}

struct DeployTarget {
    name:    string,
    healthy: bool
}

struct Dashboard {
    title:  string,
    metric: string
}

struct ConsciousMind {
    dim:        int,
    hidden_dim: int,
    energy:     float,
    age:        int
}

struct SecretVault {
    backend:  string,    // "keychain" | "file" | "env"
    n_keys:   int
}

