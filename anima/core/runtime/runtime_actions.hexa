// ─── §10 Master dispatch ─────────────────────────────────────
//
// run_action(name, arg) — string-keyed dispatch for the
// consciousness_hub. The hub's hub_route() returns a canonical
// name; the host can pass that name through here for ops that
// don't need a typed payload.
//
// This is the single entry point that lets the hub treat all
// ex-modules uniformly. Returns a status string for display.

fn run_action(name: string, arg: string) -> string {
    if name == "reset" {
        let cfg = ResetConfig { target: arg, preserve_growth: true, confirm: true }
        let _ = rt_reset(cfg)
        return "[runtime] reset → " + arg
    }
    if name == "setup" {
        let _ = rt_setup_interactive()
        return "[runtime] setup → " + rt_setup_status()
    }
    if name == "setup_secrets" || name == "secrets" {
        let _ = rt_secrets_load_from_env(arg)
        return "[runtime] secrets loaded from " + arg
    }
    if name == "deploy" {
        let cfg = rt_deploy_config_new(arg)
        let _ = rt_deploy(cfg)
        return "[runtime] deploy → " + arg
    }
    if name == "ops" {
        let _ = rt_ops_sync_r2(arg)
        return "[runtime] ops sync → " + arg
    }
    if name == "dashboard" {
        let d = Dashboard { title: arg, metric: "phi" }
        rt_dashboard_render(d)
        return "[runtime] dashboard → " + arg
    }
    if name == "report" {
        return rt_report_short()
    }
    if name == "alive" {
        let m = rt_alive_new(384, 768)
        let _ = rt_alive_process_input(m, arg)
        return "[runtime] alive ← " + arg
    }
    if name == "vault" {
        let v = rt_vault_new()
        let _ = rt_vault_get(v, arg)
        return "[runtime] vault[" + arg + "]"
    }
    return "[runtime] unknown action: " + name
}

// ─── Self-test ───────────────────────────────────────────────

println("[runtime_actions] consolidated 9 modules / 278 LOC → 1 file")

// Sanity sweep: every action key from the dispatcher
let _actions = ["reset", "setup", "secrets", "deploy", "ops", "dashboard", "report", "alive", "vault"]
let mut i = 0
while i < len(_actions) {
    let r = run_action(_actions[i], "test")
    println(r)
    i = i + 1
}
