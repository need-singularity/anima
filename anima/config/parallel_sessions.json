      "owner": "학습 세션",
      "note": "H100 학습 관련. 체크포인트 회수/모니터링."
    },
    "agent": {
      "files": ["../anima-agent/**"],
      "owner": "에이전트 세션",
      "note": "트레이딩, 텔레그램, MCP 등."
    },
    "benchmarks": {
      "files": ["benchmarks/bench.py", "config/verification.json"],
      "owner": "연구 세션",
      "note": "검증 조건 수정은 연구 세션에서만."
    },
    "docs": {
      "files": ["docs/**"],
      "owner": "누구나 (번호 충돌 주의)",
      "note": "DD 번호는 experiments.json에서 다음 번호 확인 후 사용."
    },
    "scripts": {
      "files": ["../scripts/**"],
      "owner": "누구나",
      "note": "인프라 스크립트. 충돌 위험 낮음."
    }
  },
  "protocols": {
    "law_registration": {
      "steps": [
        "1. git pull (최신 상태)",
        "2. python3 -c 로 consciousness_laws.json에서 max law number 확인",
        "3. 즉시 등록 + commit + push (예약 금지)",
        "4. 번호 충돌 시: 높은 번호가 우선, 낮은 번호 재할당"
      ]
    },
    "experiment_numbering": {
      "steps": [
        "1. experiments.json에서 다음 DD 번호 확인",
        "2. 'in_progress'로 즉시 등록 + commit",
        "3. 실험 완료 후 'complete'로 업데이트"
      ]
    },
    "engine_modification": {
      "steps": [
        "1. MEMORY.md에 '엔진 수정 중: [세션ID]' 표시",
        "2. 수정 완료 후 즉시 commit + push",
        "3. MEMORY.md에서 표시 제거",
        "4. 다른 세션은 이 표시 있으면 엔진 건드리지 않기"
      ]
    },
    "h100_sync": {
      "steps": [
        "1. 학습 세션만 h100_sync.sh 실행",
        "2. sync 전 git pull 필수",
        "3. 학습 중 엔진 파일 교체 금지 (다음 학습부터)"
      ]
    },
    "git_workflow": {
      "steps": [
        "1. 작업 시작 시 git pull",
        "2. 변경 즉시 commit (long-running uncommitted 금지)",
        "3. push 전 git pull --rebase",
        "4. conflict 시: 자기 존 우선, 남의 존은 상대방 버전 유지"
      ]
    }
  },
  "session_templates": {
    "연구": {
      "zone": ["engine", "benchmarks", "docs"],
      "typical_work": "법칙 발견, SOC 튜닝, 검증 조건, 폐쇄 루프"
    },
    "학습": {
      "zone": ["training", "scripts"],
      "typical_work": "H100 모니터링, 체크포인트 회수, corpus 전송"
    },
    "에이전트": {
      "zone": ["agent"],
      "typical_work": "트레이딩, 텔레그램, MCP, provider"
    },
    "인프라": {
      "zone": ["scripts", "docs"],
      "typical_work": "CI, RunPod, 배포, 문서"
    }
  }
}
