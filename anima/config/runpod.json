{
  "_meta": {
    "description": "RunPod H100 운영 설정 — 학습/배포 시 참조",
    "updated": "2026-03-31"
  },
  "pod": {
    "id": "6rkqqlaxfwzix0",
    "name": "v13-train",
    "gpu": "H100 SXM 80GB",
    "cost_per_hr": 2.69,
    "image": "dancindocker/anima:v2",
    "volume_gb": 50
  },
  "ssh": {
    "key": "~/.runpod/ssh/RunPod-Key-Go",
    "command": "ssh -i ~/.runpod/ssh/RunPod-Key-Go -o StrictHostKeyChecking=no root@216.243.220.230 -p 18038"
  },
  "paths": {
    "python": "/opt/conda/bin/python3",
    "workspace": "/workspace",
    "checkpoints": "/workspace/checkpoints",
    "data": "/workspace/data",
    "note": "모든 src 파일은 /workspace/ 플랫 구조 (서브디렉토리 없음)"
  },
  "known_issues": {
    "tmux_death": {
      "symptom": "tmux 세션이 무작위로 종료, GPU 0%",
      "cause": "RunPod container 네트워크 끊김 또는 OOM",
      "fix": "--resume <best.pt> 로 재시작, watchdog cron 설정",
      "prevention": "scripts/h100_watchdog.sh cron 등록"
    },
    "disk_quota": {
      "symptom": "scp/write 실패: Disk quota exceeded",
      "cause": "volume_gb=50 한도, 체크포인트 누적",
      "fix": "구 체크포인트 삭제 (v14_federated, v2d2 등)",
      "prevention": "학습 완료 후 즉시 로컬 회수 + 서버 삭제"
    },
    "python_not_found": {
      "symptom": "python3: command not found",
      "cause": "/opt/conda/bin이 PATH에 없음",
      "fix": "export PATH=/opt/conda/bin:$PATH"
    },
    "file_sync": {
      "symptom": "H100에서 구버전 코드 실행",
      "cause": "로컬 수정 후 전송 누락",
      "fix": "bash scripts/h100_sync.sh 또는 ssh pipe (cat | ssh cat >)",
      "prevention": "학습 발사 전 반드시 md5 비교 (scripts/h100_retrieve.sh status)"
    }
  },
  "env_vars": {
    "PYTHONUNBUFFERED": "1",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True",
    "CUDA_LAUNCH_BLOCKING": "0",
    "PATH": "/opt/conda/bin:$PATH"
  },
  "scripts": {
    "sync": "bash scripts/h100_sync.sh",
    "retrieve": "bash scripts/h100_retrieve.sh [v14|v3|both|poll|status]",
    "manage": "bash scripts/runpod_manage.sh [status|stop|start|cost]",
    "watchdog": "bash scripts/h100_watchdog.sh (cron: */5 * * * *)",
    "launch": "bash scripts/launch_h100.sh"
  },
  "checkpoint_backup": {
    "protocol": "R2 (Cloudflare)",
    "bucket": "anima",
    "r2_prefix": "checkpoints/",
    "local_script": "python3 scripts/r2_upload.py --checkpoint <version>",
    "local_shell": "bash scripts/r2_backup.sh --version <version>",
    "list": "python3 scripts/r2_upload.py --list --prefix checkpoints/",
    "prune": "python3 scripts/r2_upload.py --prune --keep 3",
    "download": "python3 scripts/r2_upload.py --download checkpoints/<version>/best_final.pt",
    "h100_to_r2": "On H100: scp checkpoints to local first, then run r2_upload.py locally",
    "workflow": [
      "1. Training completes on H100 -> best_final.pt saved",
      "2. Retrieve to local: bash scripts/h100_retrieve.sh v14",
      "3. Upload to R2: python3 scripts/r2_upload.py --checkpoint v14_128c_final",
      "4. Verify: python3 scripts/r2_upload.py --list --prefix checkpoints/v14",
      "5. Prune old versions: python3 scripts/r2_upload.py --prune --keep 3"
    ],
    "retention": "Keep latest 3 versions in R2, prune older",
    "note": "R2 credentials in anima/.env and anima/.local/.env"
  },
  "checklist_before_launch": [
    "1. h100_sync.sh 로 최신 코드 전송",
    "2. md5 비교로 동기화 확인",
    "3. 구 체크포인트 정리 (du -sh /workspace/checkpoints/)",
    "4. corpus 존재 확인 (ls /workspace/data/corpus_v*.txt)",
    "5. GPU 사용 중인 프로세스 확인 (nvidia-smi)",
    "6. tmux 세션 시작 (SSH 끊겨도 유지)",
    "7. watchdog cron 등록 확인",
    "8. 이전 학습 체크포인트 R2 백업 확인 (python3 scripts/r2_upload.py --list)"
  ]
}
