// ── Pipeline config ──

struct PipelineConfig {
    steps: int,
    max_cells: int,
    dim: int,
    hidden_dim: int,
    seed: int
}

pure fn default_pipeline_config() -> PipelineConfig {
    PipelineConfig {
        steps: 1000,
        max_cells: 64,
        dim: 64,
        hidden_dim: 128,
        seed: 42
    }
}

// ── Main pipeline ──

struct PipelineResult {
    total_steps: int,
    corpus_lines: int,
    corpus_bytes: int,
    phi_min: float,
    phi_max: float,
    phi_final: float,
    tension_mean: float,
    cells_final: int,
    total_splits: int,
    total_merges: int,
    total_ratchets: int,
    total_consensus: int,
    elapsed_sec: float
}

