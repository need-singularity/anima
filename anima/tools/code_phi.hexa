// ── Code Phi Analyzer ──

struct CodePhiConfig {
    n_cells: int,
    hidden_dim: int,
    input_dim: int
}

pure fn default_code_phi_config() -> CodePhiConfig {
    CodePhiConfig {
        n_cells: 32,
        hidden_dim: 128,
        input_dim: 64
    }
}

struct PhiResult {
    phi_iit: float,
    phi_proxy: float,
    tension_avg: float,
    tension_var: float,
    phi_growth: float,
    steps: int,
    n_bytes: int,
    has_error: bool
}

pure fn empty_phi_result() -> PhiResult {
    PhiResult {
        phi_iit: 0.0,
        phi_proxy: 0.0,
        tension_avg: 0.0,
        tension_var: 0.0,
        phi_growth: 0.0,
        steps: 0,
        n_bytes: 0,
        has_error: false
    }
}

// ── Byte conversion ──

// TODO[pytorch]: Convert file bytes to normalized float tensors
// Each chunk of input_dim bytes -> tensor in [-1, 1] via b / 127.5 - 1.0
fn bytes_to_tensor_count(data_len: int, chunk_size: int) -> int {
    if data_len < chunk_size {
        return 0
    }
    return (data_len - chunk_size) / chunk_size
}

