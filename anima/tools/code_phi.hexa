// ── Rating ──

pure fn rate_phi(phi: float) -> int {
    // 0 = strong structure (>30), 1 = good (>20), 2 = normal (>10), 3 = weak
    if phi > 30.0 { return 0 }
    if phi > 20.0 { return 1 }
    if phi > 10.0 { return 2 }
    return 3
}

