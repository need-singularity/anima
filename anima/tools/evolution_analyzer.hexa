// ── Data structures ──

struct EvolutionInfo {
    generation: int,
    elapsed: float,
    avg_per_gen: float,
    unique: int,
    cross_validated: int,
    pending: int,
    total_observations: int,
    hit_rate: float,
    n_registered_laws: int,
    n_active_mods: int,
    timestamp: int,
    version: int
}

struct PatternEntry {
    fingerprint_len: int,
    formula_len: int,
    count: int,
    first_gen: int,
    last_gen: int,
    registered: bool
}

struct ActiveMod {
    law_id: int,
    target_len: int,
    mod_type_len: int,
    confidence: float
}

// ── Load and validate ──

// TODO[json]: Load evolution_state.json and validate structure
fn load_state(path_len: int) -> bool {
    // Check 'registry' and 'seen' keys exist
    true
}

// ── Duration formatting ──

pure fn format_duration_kind(seconds: float) -> int {
    // 0 = seconds, 1 = minutes, 2 = hours
    if seconds < 60.0 {
        return 0
    }
    if seconds < 3600.0 {
        return 1
    }
    return 2
}

// ── Analysis ──

// TODO[json]: Extract all statistics from state data
fn analyze(generation: int, elapsed: float, n_seen: int, n_registered: int) -> EvolutionInfo {
    let pending = n_seen - n_registered
    let hit_rate = if n_seen > 0 { 100.0 * (n_registered as float) / (n_seen as float) } else { 0.0 }
    let avg = if generation > 0 { elapsed / (generation as float) } else { 0.0 }
    EvolutionInfo {
        generation: generation,
        elapsed: elapsed,
        avg_per_gen: avg,
        unique: n_seen,
        cross_validated: n_registered,
        pending: pending,
        total_observations: 0,
        hit_rate: hit_rate,
        n_registered_laws: n_registered,
        n_active_mods: 0,
        timestamp: 0,
        version: 1
    }
}

// ── ASCII bar ──

pure fn ascii_bar_len(value: int, max_value: int, width: int) -> int {
    if max_value <= 0 {
        return 0
    }
    let len = value * width / max_value
    if len < 1 {
        return 1
    }
    return len
}

