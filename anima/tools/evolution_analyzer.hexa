// Cross-validation timeline: estimate promotion gen as first_gen + 2
pure fn estimate_promotion_gen(first_gen: int, max_gen: int) -> int {
    let promo = first_gen + 2
    if promo > max_gen {
        return max_gen
    }
    return promo
}

fn main() {
    // TODO: argparse equivalent
    // --file / -f : path to evolution_state.json
    // --compare / -c : compare two state files
