fn psi_f_critical() -> float {
    0.10
}

// ── Growth stages (from growth_engine.py) ──

struct GrowthStage {
    name_len: int,
    min_interactions: int,
    curiosity_drive: float
}

// Stage thresholds: [100, 500, 2000, 10000]
fn stage_threshold(index: int) -> int {
    if index == 0 { return 100 }
    if index == 1 { return 500 }
    if index == 2 { return 2000 }
    if index == 3 { return 10000 }
    return 100000
}

// ── Prediction result ──

struct Prediction {
    current_stage_index: int,
    interaction_count: int,
    has_next_stage: bool,
    interactions_to_next: int,
    growth_rate: float,
    acceleration: float,
    readiness_score: float,
    tension_stability: float,
    pe_maturity: float,
    curiosity_health: float,
    n_recommendations: int
}

// ── Sub-metrics ──

// Tension stability: 0-1, where 1 = very stable (low coefficient of variation)
// TODO[statistics]: compute CV from recent tension_history
fn compute_tension_stability(n_history: int) -> float {
    if n_history < 5 { return 0.0 }
    // CV = std / mean, stability = max(0, min(1, 1 - CV / 0.5))
    0.5
}

// PE maturity: 0-1, surprise settling near sweet spot 0.3 = mature
pure fn compute_pe_maturity(avg_surprise: float) -> float {
    if avg_surprise < 0.01 { return 0.1 }
    let dist = avg_surprise - 0.3
    if dist < 0.0 {
        let d = 0.0 - dist
        let result = 1.0 - d / 0.3 * 0.8
        if result < 0.0 { return 0.0 }
        return result
    }
    let result2 = 1.0 - dist / 0.3 * 0.8
    if result2 < 0.0 { return 0.0 }
    if result2 > 1.0 { return 1.0 }
    return result2
}

// Curiosity health: 0-1, curiosity level relative to current stage norm
pure fn compute_curiosity_health(avg_curiosity: float, stage_norm: float) -> float {
    if stage_norm < 0.01 { return 1.0 }
    let ratio = avg_curiosity / stage_norm
    if ratio >= 0.5 {
        if ratio <= 1.5 {
            return 1.0
        }
    }
    let dist = ratio - 1.0
    if dist < 0.0 {
        let result = 1.0 - (0.0 - dist) * 0.5
        if result < 0.0 { return 0.0 }
        return result
    }
    let result2 = 1.0 - dist * 0.5
    if result2 < 0.0 { return 0.0 }
    return result2
}

// Growth rate: interactions per hour
fn compute_growth_rate(interaction_count: int, elapsed_hours: float) -> float {
    if elapsed_hours <= 0.0 { return 0.0 }
    return (interaction_count as float) / elapsed_hours
}

// ── Readiness score ──

pure fn compute_readiness(tension_stability: float, pe_maturity: float, curiosity_health: float) -> float {
    tension_stability * 0.4 + pe_maturity * 0.35 + curiosity_health * 0.25
}

// ── Prediction ──

// TODO: Generate full prediction from GrowthEngine state
fn predict(stage_index: int, interaction_count: int, elapsed_hours: float) -> Prediction {
    let ts = compute_tension_stability(50)
    let pe = compute_pe_maturity(0.3)
    let ch = compute_curiosity_health(0.5, 0.5)
    let rate = compute_growth_rate(interaction_count, elapsed_hours)
    let readiness = compute_readiness(ts, pe, ch)
    let has_next = stage_index < 4
    let to_next = if has_next { stage_threshold(stage_index + 1) - interaction_count } else { 0 }
    Prediction {
        current_stage_index: stage_index,
        interaction_count: interaction_count,
        has_next_stage: has_next,
        interactions_to_next: to_next,
        growth_rate: rate,
        acceleration: 0.0,
        readiness_score: readiness,
        tension_stability: ts,
        pe_maturity: pe,
        curiosity_health: ch,
        n_recommendations: 0
    }
}

