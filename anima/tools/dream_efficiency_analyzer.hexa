fn psi_f_critical() -> float {
    0.10
}

// ── Constants ──

fn efficient_roi() -> float { 0.5 }
fn wasteful_roi() -> float { 0.1 }
fn good_consolidation() -> float { 0.6 }
fn bad_consolidation() -> float { 0.2 }
fn good_stability_gain() -> float { 0.05 }

// ── Data structures ──

struct DreamAnalysis {
    total_cycles: int,
    total_patterns: int,
    replay_ratio: float,
    interpolate_ratio: float,
    explore_ratio: float,
    consolidate_ratio: float,
    tension_stability_before: float,
    tension_stability_after: float,
    learning_gain: float,
    avg_gain_per_cycle: float,
    consolidation_attempted: int,
    consolidation_succeeded: int,
    consolidation_rate: float,
    compute_cost: float,
    dream_roi: float,
    coherence_before: float,
    coherence_after: float,
    coherence_delta: float,
    health: int,
    n_recommendations: int
}

pure fn empty_analysis() -> DreamAnalysis {
    DreamAnalysis {
        total_cycles: 0,
        total_patterns: 0,
        replay_ratio: 0.0,
        interpolate_ratio: 0.0,
        explore_ratio: 0.0,
        consolidate_ratio: 0.0,
        tension_stability_before: 0.0,
        tension_stability_after: 0.0,
        learning_gain: 0.0,
        avg_gain_per_cycle: 0.0,
        consolidation_attempted: 0,
        consolidation_succeeded: 0,
        consolidation_rate: 0.0,
        compute_cost: 0.0,
        dream_roi: 0.0,
        coherence_before: 0.0,
        coherence_after: 0.0,
        coherence_delta: 0.0,
        health: 1,
        n_recommendations: 0
    }
}

// ── Analysis sub-functions ──

// Count total cycles and patterns
fn count_cycles(n_cycles: int, n_patterns: int) -> int {
    n_cycles
}

// Type distribution: replay, interpolate, explore, consolidate
fn compute_type_ratios(replay: int, interpolate: int, explore: int, consolidate: int) -> float {
    let total = replay + interpolate + explore + consolidate
    if total == 0 { return 0.0 }
    return to_float(replay) / to_float(total)
}

// Learning metrics: tension stability comparison (early vs late half)
// TODO[statistics]: stdev of first half vs second half of tension history
fn compute_learning_gain(stability_before: float, stability_after: float) -> float {
    let gain = stability_before - stability_after
    if gain < 0.0 { return 0.0 }
    return gain
}

// Consolidation rate
pure fn compute_consolidation_rate(attempted: int, succeeded: int) -> float {
    if attempted == 0 { return 0.0 }
    return to_float(succeeded) / to_float(attempted)
}

// Memory coherence: smoothness of tension trajectory (early vs late thirds)
// TODO[statistics]: 1.0 / (1.0 + mean(|t[i+1] - t[i]|))
fn compute_coherence(n_tensions: int) -> float {
    1.0
}

// Dream ROI = (learning_gain + coherence_delta * 0.5) / (compute_cost / 100)
pure fn compute_roi(learning_gain: float, coherence_delta: float, compute_cost: float) -> float {
    if compute_cost <= 0.0 { return 0.0 }
    return (learning_gain + coherence_delta * 0.5) / (compute_cost / 100.0)
}

// ── Health classification ──

// 0 = EFFICIENT, 1 = NEUTRAL, 2 = WASTEFUL
fn classify_health(roi: float, consol_rate: float, learning_gain: float, coherence_delta: float, consol_attempted: int) -> int {
    let s = 0.0
    if roi >= 0.5 {
        s = s + 2.0
    } else {
        if roi >= 0.1 {
            s = s + 1.0
        }
    }
    if consol_attempted > 0 {
        if consol_rate >= 0.6 {
            s = s + 2.0
        } else {
            if consol_rate >= 0.2 {
                s = s + 1.0
            }
        }
    }
    if learning_gain >= 0.05 {
        s = s + 1.5
    } else {
        if learning_gain > 0.0 {
            s = s + 0.5
        }
    }
    if coherence_delta > 0.02 {
        s = s + 1.0
    }
    if s >= 4.0 { return 0 }
    if s >= 2.0 { return 1 }
    return 2
}

// ── Recommendations ──

fn generate_recommendations(analysis: DreamAnalysis) -> int {
    // Returns number of recommendations generated
    let count = 0
    if analysis.replay_ratio < 0.4 {
        count = count + 1
    }
    if analysis.replay_ratio > 0.6 {
        count = count + 1
    }
    if analysis.explore_ratio < 0.1 {
        count = count + 1
    }
    if analysis.consolidation_attempted > 0 {
        if analysis.consolidation_rate < 0.3 {
            count = count + 1
        }
    }
    if analysis.learning_gain < 0.01 {
        if analysis.total_cycles > 5 {
            count = count + 1
        }
    }
    if analysis.coherence_delta < -0.02 {
        count = count + 1
    }
    return count
}

