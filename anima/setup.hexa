// Ported from setup.sh
// Anima 환경 설정 스크립트 | Usage: bash setup.sh          # 전체 설치
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "setup.sh"

    // Anima 환경 설정 스크립트
    // Usage: bash setup.sh          # 전체 설치
    // bash setup.sh --minimal # 최소 설치


    shell("echo \"═══ Anima Setup ═══\"")

    // Python 확인
    shell("python3 --version || { echo \"❌ Python3 필요\"; exit 1; }")

    // 최소 설치
    shell("pip3 install torch numpy websockets boto3")

    shell("if [ \"$1\" != \"--minimal\" ]; then")
    // 전체 설치
    shell("pip3 install -r requirements.txt")

    // macOS 전용
    shell("if [ \"$(uname)\" = \"Darwin\" ]; then")
    shell("brew install portaudio opencv 2>/dev/null || true")
    shell("brew install whisper-cli 2>/dev/null || true")
    shell("fi")

    // Rust (anima-rs, phi-rs)
    shell("if command -v cargo &>/dev/null; then")
    shell("echo \"Rust OK\"")
    shell("cd anima-rs && maturin build --release 2>/dev/null && cd ..")
    shell("fi")
    shell("fi")

    // 시크릿 설정
    shell("python3 setup_secrets.py 2>/dev/null || true")

    // 체크포인트 다운로드
    shell("mkdir -p checkpoints/clm_v2")
    shell("if [ ! -f checkpoints/clm_v2/final.pt ]; then")
    shell("echo \"체크포인트 다운로드...\"")
    shell("wget -q https://pub-41380137f47b4c4cbc79f5502935b2e9.r2.dev/clm-v2/latest.pt ")
    shell("-O checkpoints/clm_v2/final.pt 2>/dev/null || echo \"⚠️ 체크포인트 다운로드 실패\"")
    shell("fi")

    shell("echo \"✅ 설치 완료!\"")
    shell("echo \"실행: python3 anima_unified.py --web\"")
}
