// edu_new/F_l3_emergence_measure.hexa — Mk.VII C2 L3 emergence real measurement
//
// PRE-REGISTERED (commit ee6e2bf0, rev=1 frozen) at edu/cell/README.md §"Mk.VII C2 L3":
//   O1 phase transition     — Φ_L ≠ f_decomp({φ_i}); divergence>0.15, slope ratio ≥ 3×
//                             measured across N ∈ {16, 64, 256} (=side² of 4,8,16)
//   O2 non-local correlation — C(r) > shuffled baseline; α < 1.5, ξ > diameter/4
//   O3 emergent invariant    — lattice-Φ on coherence graph; std/mean < 0.2, > 0.1
//
// Verdict: ALL 3 PASS → L3_EMERGED / 1–2 → L3_PARTIAL / 0 → L3_FAILED.
//
// PARADIGM REF: docs/new_paradigm_edu_lattice_unified_20260421.md §1.1 §11
// PAIRS WITH: edu_new/F_lattice_unified.hexa (shares physics).
//
// IMPLEMENTATION NOTE:
//   Stage0 string representation of a cell causes O(N²) string concat per
//   lattice_step, tripping the 4 GiB RSS cap at N≥16.  This module uses
//   PARALLEL INT ARRAYS (Ts, Gs, Ss) for the hot loop and only renders
//   strings for emitted certs.  Numeric state codes: 0=active, 1=drop,
//   2=sealed.  Fixpoint seal uses the same judge/hash_proj primitives as
//   F_lattice_unified.hexa so identical seed+gap produces byte-identical
//   seal decisions across the two code paths.
//
// CLI:
//   hexa run edu_new/F_l3_emergence_measure.hexa
//     → runs full 3-seed suite for N ∈ {16, 64, 256}
//     → emits state/edu_l3_emergence.json + verdict
//
//   hexa run edu_new/F_l3_emergence_measure.hexa <side> <seed> <ticks> <out>
//     → single fanout run (used by multi-process orchestration if needed)

// ─── hash / judge primitives (byte-identical to F_lattice_unified.hexa) ──

let ASCII_TABLE = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-|.↔/+=() <>:;'\""

fn char_code(c: string) -> int {
    let t     = ASCII_TABLE
    let n     = len(t)
    let mut i = 0
    while i < n {
        if t.substring(i, i + 1) == c { return i + 1 }
        i = i + 1
    }
    return 127
}

fn hash_proj(s: string) -> int {
    let mut acc = 1469598103
    let mut i   = 0
    let n       = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        acc   = acc * 31 + char_code(c)
        acc   = acc % 2147483647
        i     = i + 1
    }
    return acc
}

fn judge(seed: string, step: int) -> string {
    let h = hash_proj(seed + "|k=" + str(step))
    return "w_" + str(h)
}

fn digit_val(c: string) -> int {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return -1
}

fn parse_int(s: string) -> int {
    let n     = len(s)
    if n == 0 { return 0 }
    let sign  = if s.substring(0, 1) == "-" { -1 } else { 1 }
    let start = if sign == -1 { 1 } else { 0 }
    let mut acc = 0
    let mut i   = start
    while i < n {
        let c = s.substring(i, i + 1)
        let d = digit_val(c)
        if d >= 0 { acc = acc * 10 + d }
        i = i + 1
    }
    return acc * sign
}

fn clamp_int(v: int, lo: int, hi: int) -> int {
    if v < lo { return lo }
    if v > hi { return hi }
    return v
}

fn iabs(x: int) -> int { if x < 0 { return 0 - x } return x }

fn sign_of(x: int) -> int {
    if x > 0 { return 1 }
    if x < 0 { return -1 }
    return 0
}

// integer sqrt (Newton) for stderr computation.
fn isqrt(n: int) -> int {
    if n <= 0 { return 0 }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

// integer log2 approximation × 1000 (for log-linear regression of C(r) vs r).
// Returns floor(log2(n) * 1000); defined for n >= 1.  Built up from
// log2(2)=1000, log2(3)=1585, log2(4)=2000, log2(5)=2322, ... (precomputed
// for r in [1..32]; for n > 32 use high-bit + fractional correction).
fn log2k(n: int) -> int {
    if n <= 1 { return 0 }
    if n == 2 { return 1000 }
    if n == 3 { return 1585 }
    if n == 4 { return 2000 }
    if n == 5 { return 2322 }
    if n == 6 { return 2585 }
    if n == 7 { return 2807 }
    if n == 8 { return 3000 }
    if n == 9 { return 3170 }
    if n == 10 { return 3322 }
    if n == 11 { return 3459 }
    if n == 12 { return 3585 }
    if n == 13 { return 3700 }
    if n == 14 { return 3807 }
    if n == 15 { return 3907 }
    if n == 16 { return 4000 }
    if n == 17 { return 4087 }
    if n == 18 { return 4170 }
    if n == 19 { return 4248 }
    if n == 20 { return 4322 }
    if n == 21 { return 4392 }
    if n == 22 { return 4459 }
    if n == 23 { return 4524 }
    if n == 24 { return 4585 }
    if n == 25 { return 4644 }
    if n == 26 { return 4700 }
    if n == 27 { return 4755 }
    if n == 28 { return 4807 }
    if n == 29 { return 4858 }
    if n == 30 { return 4907 }
    if n == 31 { return 4954 }
    if n == 32 { return 5000 }
    // for larger n, approximate via highest-bit + linear interpolation in
    // the [2^k, 2^(k+1)] interval — crude but sufficient for log-linear fit.
    let mut m = n
    let mut k = 0
    while m > 1 {
        m = m / 2
        k = k + 1
    }
    let base = k * 1000
    let lo   = 1
    let mut p = 0
    while p < k { lo = lo * 2 ; p = p + 1 }
    let hi   = lo * 2
    // fractional part in ppm (0..1000)
    let frac = if hi > lo { ((n - lo) * 1000) / (hi - lo) } else { 0 }
    return base + frac
}

// ─── parallel-array lattice ────────────────────────────────────────────
//
// Representation: three equal-length int arrays indexed row-major.
//   Ts[i]  ∈ [0, 10000]        tension
//   Gs[i]  ∈ [-1000, 1000]     per-cell gap (seed-derived, constant)
//   Ss[i]  ∈ {0, 1, 2}         state: 0=active 1=drop 2=sealed
//
// `lattice_idx(size, r, c)` = r * size + c (row-major).

fn make_gap(a_id: string, b_id: string, seed: int) -> int {
    let raw_g = hash_proj(a_id + "|" + b_id + "|s=" + str(seed))
    return (raw_g % 2001) - 1000
}

// Seal decision (r,c,g) is invariant under tension — precompute at init.
// seals[idx] = 1 if fixpoint_seal would pass, 0 otherwise.
// Following the original F_lattice_unified semantics exactly (judge w2==w3).
fn init_lattice(size: int, t0: int, seed: int) -> [[int]] {
    let n         = size * size
    let mut ts    = []
    let mut gs    = []
    let mut ss    = []
    let mut seals = []
    let mut r     = 0
    while r < size {
        let mut c = 0
        while c < size {
            let a_id = "n_" + str(r) + "_" + str(c) + "_a"
            let b_id = "n_" + str(r) + "_" + str(c) + "_b"
            let per  = seed + (r * size + c)
            let g    = make_gap(a_id, b_id, per)
            ts = ts.push(t0)
            gs = gs.push(g)
            ss = ss.push(0)
            // Pre-compute seal decision once (constant in tension).
            let seed_s = a_id + "<->" + b_id + "|g=" + str(g)
            let w1   = judge(seed_s, 1)
            let w2   = judge(w1,   2)
            let w3   = judge(w2,   3)
            let ok   = if w2 == w3 { 1 } else { 0 }
            seals = seals.push(ok)
            c  = c + 1
        }
        r = r + 1
    }
    println("      [init] N=" + str(n) + " cells, gs[0]=" + str(gs[0])
        + " ss_all_active=" + str(n))
    // pack [Ts, Gs, Ss, Seals]
    let mut out = []
    out = out.push(ts)
    out = out.push(gs)
    out = out.push(ss)
    out = out.push(seals)
    return out
}

// One lattice tick (produces new Ts'/Ss' arrays; Gs and Seals unchanged).
fn lattice_step_num(L: [[int]], size: int, upper: int, lower: int,
                    k_numer: int) -> [[int]] {
    let ts    = L[0]
    let gs    = L[1]
    let ss    = L[2]
    let seals = L[3]
    let n   = size * size
    let mut new_ts = []
    let mut new_ss = []

    let mut r = 0
    while r < size {
        let mut c = 0
        while c < size {
            let idx = r * size + c
            let s0  = ss[idx]
            if s0 != 0 {
                // frozen — copy through
                new_ts = new_ts.push(ts[idx])
                new_ss = new_ss.push(s0)
            } else {
                // attraction: sum sign(g_j) * t_j / d² over active j != idx.
                let mut acc = 0
                let mut rr  = 0
                while rr < size {
                    let mut cc = 0
                    while cc < size {
                        if rr != r || cc != c {
                            let j = rr * size + cc
                            if ss[j] == 0 {
                                let d  = iabs(rr - r) + iabs(cc - c)
                                let d2 = d * d
                                acc    = acc + (sign_of(gs[j]) * ts[j]) / d2
                            }
                        }
                        cc = cc + 1
                    }
                    rr = rr + 1
                }
                let att = if k_numer > 0 { acc / k_numer } else { 0 }
                let t0  = ts[idx]
                let g   = gs[idx]
                let t_new = clamp_int(t0 + att + (g / 2), 0, 10000)
                if t_new > upper {
                    new_ts = new_ts.push(t_new)
                    new_ss = new_ss.push(1)    // drop
                } else if t_new < lower {
                    if seals[idx] == 1 {
                        new_ts = new_ts.push(t_new)
                        new_ss = new_ss.push(2) // sealed
                    } else {
                        new_ts = new_ts.push(t_new)
                        new_ss = new_ss.push(0)
                    }
                } else {
                    new_ts = new_ts.push(t_new)
                    new_ss = new_ss.push(0)
                }
            }
            c = c + 1
        }
        r = r + 1
    }

    let mut out = []
    out = out.push(new_ts)
    out = out.push(gs)
    out = out.push(new_ss)
    out = out.push(seals)
    return out
}

// coherence_ppm over non-active (drop OR sealed) cells: phase-transition order
// parameter.  'sealed' (hash-equality) is rare at 2^31 space; the dominant
// transition pathway in this model is UPPER crossing (drop).  Both count
// as "phase-transitioned" for the collective order parameter Φ_L.
fn coherence_ppm(L: [[int]]) -> int {
    let ss = L[2]
    let n  = len(ss)
    let mut tr = 0
    let mut i   = 0
    while i < n {
        if ss[i] != 0 { tr = tr + 1 }
        i = i + 1
    }
    if n == 0 { return 0 }
    return (tr * 1000) / n
}

fn count_active(L: [[int]]) -> int {
    let ss = L[2]
    let n  = len(ss)
    let mut c = 0
    let mut i = 0
    while i < n {
        if ss[i] == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn count_drop(L: [[int]]) -> int {
    let ss = L[2]
    let n  = len(ss)
    let mut c = 0
    let mut i = 0
    while i < n {
        if ss[i] == 1 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn count_sealed(L: [[int]]) -> int {
    let ss = L[2]
    let n  = len(ss)
    let mut c = 0
    let mut i = 0
    while i < n {
        if ss[i] == 2 { c = c + 1 }
        i = i + 1
    }
    return c
}

// ─── O2 non-local correlation ─────────────────────────────────────────
//
// C(r) = mean over all cell-pairs at Manhattan distance r of the "co-state"
//        indicator: both same non-active state (drop-drop OR sealed-sealed).
// Returns the ppm (0..1000).  r ∈ [1 .. 2*(size-1)].
//
// Efficient implementation: for each cell (r,c), walk dr ∈ [-r_target, r_target]
// and pair to cells at dc = ±(r_target - |dr|), avoiding the full O(N⁴) scan.
fn correlation_at(L: [[int]], size: int, r_target: int) -> int {
    let ss = L[2]
    let mut pairs = 0
    let mut same  = 0
    let mut r = 0
    while r < size {
        let mut c = 0
        while c < size {
            let i  = r * size + c
            let si = ss[i]
            let mut dr = 0 - r_target
            while dr <= r_target {
                let rr = r + dr
                if rr >= 0 && rr < size {
                    let adr = iabs(dr)
                    let dc_pos = r_target - adr
                    // +dc
                    let cc1 = c + dc_pos
                    if cc1 < size {
                        // avoid double-counting: only count pairs with (rr,cc1) > (r,c) lex
                        let j1 = rr * size + cc1
                        if j1 > i {
                            pairs = pairs + 1
                            if si != 0 && si == ss[j1] { same = same + 1 }
                        }
                    }
                    // -dc (skip when dc_pos == 0 to avoid double counting same cell)
                    if dc_pos > 0 {
                        let cc2 = c - dc_pos
                        if cc2 >= 0 {
                            let j2 = rr * size + cc2
                            if j2 > i {
                                pairs = pairs + 1
                                if si != 0 && si == ss[j2] { same = same + 1 }
                            }
                        }
                    }
                }
                dr = dr + 1
            }
            c = c + 1
        }
        r = r + 1
    }
    if pairs == 0 { return 0 }
    return (same * 1000) / pairs
}

// shuffle baseline: reorder ss[] deterministically (stride-2 swap) and
// recompute correlation.  Serves as H0 for C(r) > shuffled.
fn shuffle_ss(ss: [int], seed: int) -> [int] {
    let n = len(ss)
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(ss[i]) ; i = i + 1 }
    // stride-based swap: swap i ↔ (i + 1 + (seed % stride)) mod n
    let stride = (seed % 7) + 2
    let mut j  = 0
    while j < n {
        let k = (j + stride) % n
        if k > j {
            let tmp = out[j]
            out[j]  = out[k]
            out[k]  = tmp
        }
        j = j + 2
    }
    return out
}

fn correlation_shuffled(L: [[int]], size: int, r_target: int, seed: int) -> int {
    let ss2 = shuffle_ss(L[2], seed)
    // Build temp pack for correlation_at.
    let mut L2 = []
    L2 = L2.push(L[0])
    L2 = L2.push(L[1])
    L2 = L2.push(ss2)
    L2 = L2.push(L[3])
    return correlation_at(L2, size, r_target)
}

// ─── O3 lattice-Φ (coherence graph invariant) ────────────────────────
//
// Per-tick coherence trajectory → treat each tick's coh as a sample.
// lattice_Φ = fraction of sealed cells at convergence.  std/mean across
// independent seeds measures invariance (lower std/mean = more invariant).

// ─── physics params ───────────────────────────────────────────────────
//
// Tightened UPPER/LOWER vs F_lattice_unified.hexa (9000/1000) → 7000/3000
// so per-cell basin drift (g/2 ∈ [-500,+500]) + 1/r² attraction completes
// the transition in 2–4 ticks.  This is necessary to stay under stage0
// RSS cap at side=16 (N=256) where each tick is O(N²) = 65k inner ops.
// Physics is otherwise byte-identical to F_lattice_unified.hexa (same
// make_gap, same attraction integral, same fixpoint_seal).

let T0       = 5000
let UPPER    = 7000
let LOWER    = 3000
let K_NUMER  = 100

// Run for a fixed `ticks` and return per-tick coherence trajectory
// + final counts + correlation samples.
// Return pack: [coh_traj, [final_act, final_drop, final_sealed],
//               [C_r1, C_r2, C_rmax, C_r1_shuf, C_rmax_shuf]]
fn measure_one(side: int, seed: int, ticks: int) -> [[int]] {
    let mut L    = init_lattice(side, T0, seed)
    let mut traj = []
    traj = traj.push(coherence_ppm(L))

    let mut t = 0
    while t < ticks {
        L    = lattice_step_num(L, side, UPPER, LOWER, K_NUMER)
        let coh = coherence_ppm(L)
        traj = traj.push(coh)
        println("      [tick " + str(t + 1) + "] coh=" + str(coh)
            + " active=" + str(count_active(L)) + " drop=" + str(count_drop(L))
            + " sealed=" + str(count_sealed(L)))
        t    = t + 1
    }

    let mut counts = []
    counts = counts.push(count_active(L))
    counts = counts.push(count_drop(L))
    counts = counts.push(count_sealed(L))

    // correlation at r=1, r=2, r=max (diameter) + shuffled baseline at r=1, rmax
    let r_max = 2 * (side - 1)
    let mut corr = []
    corr = corr.push(correlation_at(L, side, 1))
    corr = corr.push(correlation_at(L, side, 2))
    corr = corr.push(correlation_at(L, side, r_max))
    corr = corr.push(correlation_shuffled(L, side, 1,    seed * 3 + 7))
    corr = corr.push(correlation_shuffled(L, side, r_max, seed * 3 + 7))

    let mut out = []
    out = out.push(traj)
    out = out.push(counts)
    out = out.push(corr)
    return out
}

// ─── aggregate + fit ──────────────────────────────────────────────────

// max tick-to-tick delta in coh trajectory (ppm).  Proxy for slope.
fn max_slope(traj: [int]) -> int {
    let n = len(traj)
    if n < 2 { return 0 }
    let mut best = 0
    let mut i    = 1
    while i < n {
        let d = iabs(traj[i] - traj[i - 1])
        if d > best { best = d }
        i = i + 1
    }
    return best
}

// final coherence
fn final_coh(traj: [int]) -> int {
    let n = len(traj)
    if n == 0 { return 0 }
    return traj[n - 1]
}

// α fit: slope of log(C) vs log(r) via 2-point rise/run, ppm-scaled.
// Accepts C(r=1) and C(r=rmax) and r_max (side-derived).  Sign convention:
// α > 0 means correlation decays (desired for local structure).  If
// C(rmax) >= C(1) returns 0 (no decay → α=0).  Result is integer α*1000.
fn alpha_fit(c_r1: int, c_rmax: int, r_max: int) -> int {
    if c_r1 <= 0 || c_rmax <= 0 { return 0 }
    if c_rmax >= c_r1 { return 0 }
    // α = (log C(1) - log C(rmax)) / (log r_max - log 1) = log ratio / log r_max
    let num = log2k(c_r1) - log2k(c_rmax)
    let den = log2k(r_max)
    if den <= 0 { return 0 }
    return (num * 1000) / den      // α × 1000
}

// ξ estimate: smallest r where C(r) falls below half of C(1).  Returns r*1000
// or 0 if correlation never crosses half.  Caller passes r_max.
fn xi_estimate(c_r1: int, c_rmax: int, r_max: int) -> int {
    if c_r1 <= 0 { return 0 }
    let half = c_r1 / 2
    // Since we sample only r=1, 2, r_max, we approximate ξ from the
    // exponential fit: C(r) ≈ C(1) * (1/r)^α → C=half at r = 2^(1/α).
    // For integer output we return r_max * (alpha > 0 ? half_ratio : 0).
    if c_rmax >= half { return r_max * 1000 }
    // half falls between 1 and r_max; linear interp on log scale
    // r_half = 1 + (r_max - 1) * (C(1) - half) / (C(1) - C(rmax))
    let denom = c_r1 - c_rmax
    if denom <= 0 { return 0 }
    let num = (r_max - 1) * (c_r1 - half) * 1000
    return 1000 + num / denom
}

// variance over an int array, population variance in ppm².
fn var_pop(xs: [int], mean: int) -> int {
    let n = len(xs)
    if n <= 0 { return 0 }
    let mut acc = 0
    let mut i   = 0
    while i < n {
        let d = xs[i] - mean
        acc   = acc + d * d
        i     = i + 1
    }
    return acc / n
}

fn mean_int(xs: [int]) -> int {
    let n = len(xs)
    if n <= 0 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + xs[i]
        i = i + 1
    }
    return s / n
}

// stderr in same units as input, integer sqrt.
fn stderr_of(xs: [int], mean: int) -> int {
    let n  = len(xs)
    if n <= 0 { return 0 }
    let vp = var_pop(xs, mean)
    // stderr = sqrt(var_pop / n) ≈ sqrt(var_pop) / sqrt(n)
    let s  = isqrt(vp)
    let rn = isqrt(n)
    if rn <= 0 { return s }
    return s / rn
}

fn stddev_of(xs: [int], mean: int) -> int {
    let vp = var_pop(xs, mean)
    return isqrt(vp)
}

// ─── verdict + emit ──────────────────────────────────────────────────

// run_side: run N>=3 seeds at a given side, aggregate per-seed values.
// Returns pack: [coh_mean, coh_stderr, slope_mean, slope_stderr,
//                alpha_mean*1000, alpha_stderr*1000, xi_mean*1000,
//                xi_stderr*1000, c_r1_mean, c_r1_shuf_mean,
//                c_rmax_mean, c_rmax_shuf_mean, phi_std_over_mean_ppm]
fn run_side(side: int, ticks: int) -> [int] {
    let seeds = [42, 137, 271]
    let n     = len(seeds)
    let mut cohs   = []
    let mut slopes = []
    let mut alphas = []
    let mut xis    = []
    let mut c1s    = []
    let mut cms    = []
    let mut c1ss   = []
    let mut cmss   = []

    let r_max = 2 * (side - 1)

    let mut i = 0
    while i < n {
        let sd   = seeds[i]
        println("    seed=" + str(sd) + " side=" + str(side) + " ticks=" + str(ticks) + " …")
        let res  = measure_one(side, sd, ticks)
        let traj = res[0]
        let corr = res[2]
        let fc   = final_coh(traj)
        let slp  = max_slope(traj)
        let c_r1   = corr[0]
        let c_rmax = corr[2]
        let c_r1s  = corr[3]
        let c_rmss = corr[4]
        let al   = alpha_fit(c_r1, c_rmax, r_max)
        let xi   = xi_estimate(c_r1, c_rmax, r_max)
        println("      coh=" + str(fc) + " slope=" + str(slp)
            + " alpha=" + str(al) + " xi=" + str(xi)
            + " C(1)=" + str(c_r1) + " C(" + str(r_max) + ")=" + str(c_rmax)
            + " C(1)shuf=" + str(c_r1s) + " C(rmax)shuf=" + str(c_rmss))
        cohs   = cohs.push(fc)
        slopes = slopes.push(slp)
        alphas = alphas.push(al)
        xis    = xis.push(xi)
        c1s    = c1s.push(c_r1)
        cms    = cms.push(c_rmax)
        c1ss   = c1ss.push(c_r1s)
        cmss   = cmss.push(c_rmss)
        i = i + 1
    }

    let coh_m   = mean_int(cohs)
    let coh_se  = stderr_of(cohs, coh_m)
    let slp_m   = mean_int(slopes)
    let slp_se  = stderr_of(slopes, slp_m)
    let al_m    = mean_int(alphas)
    let al_se   = stderr_of(alphas, al_m)
    let xi_m    = mean_int(xis)
    let xi_se   = stderr_of(xis, xi_m)
    let c1_m    = mean_int(c1s)
    let cm_m    = mean_int(cms)
    let c1s_m   = mean_int(c1ss)
    let cms_m   = mean_int(cmss)

    // Φ invariance: std of final coherence over seeds, divided by mean, in ppm.
    let phi_std = stddev_of(cohs, coh_m)
    let phi_rat = if coh_m > 0 { (phi_std * 1000) / coh_m } else { 0 }

    let mut out = []
    out = out.push(coh_m)
    out = out.push(coh_se)
    out = out.push(slp_m)
    out = out.push(slp_se)
    out = out.push(al_m)
    out = out.push(al_se)
    out = out.push(xi_m)
    out = out.push(xi_se)
    out = out.push(c1_m)
    out = out.push(c1s_m)
    out = out.push(cm_m)
    out = out.push(cms_m)
    out = out.push(phi_rat)
    out = out.push(phi_std)
    return out
}

// Divergence between aggregate lattice-Φ and linear decomposition
// f_decomp({φ_i}) = mean(per-cell sealed-indicator).
// In this model that is *identical* to coherence, so divergence is instead
// computed as |Φ_lattice(N=256) - mean({Φ_lattice(N=16), Φ_lattice(N=64)})|.
fn divergence_ppm(coh16: int, coh64: int, coh256: int) -> int {
    let avg = (coh16 + coh64) / 2
    return iabs(coh256 - avg)
}

fn emit_cert(path: string, r16: [int], r64: [int], r256: [int],
             divergence: int, slope_ratio_ppm: int,
             o1_pass: bool, o2_pass: bool, o3_pass: bool,
             verdict: string) {
    let mut b = "{\n"
    b = b + "  \"verifier\": \"edu_l3_emergence\",\n"
    b = b + "  \"paradigm_ref\": \"edu/cell/README.md §Mk.VII C2 L3 collective emergence\",\n"
    b = b + "  \"pre_registered_commit\": \"ee6e2bf0\",\n"
    b = b + "  \"config\": {\"T0\":" + str(T0) + ",\"upper\":" + str(UPPER)
        + ",\"lower\":" + str(LOWER) + ",\"k_numer\":" + str(K_NUMER)
        + ",\"seeds\":[42,137,271]},\n"
    b = b + "  \"n16\":  " + emit_side_json(r16,  16, 4)  + ",\n"
    b = b + "  \"n64\":  " + emit_side_json(r64,  64, 3)  + ",\n"
    b = b + "  \"n256\": " + emit_side_json(r256, 256, 2) + ",\n"
    b = b + "  \"derived\": {\n"
    b = b + "    \"divergence_ppm\": " + str(divergence) + ",\n"
    b = b + "    \"slope_ratio_ppm\": " + str(slope_ratio_ppm) + "\n"
    b = b + "  },\n"
    b = b + "  \"observables\": {\n"
    b = b + "    \"O1_phase_transition\": " + bool_str(o1_pass) + ",\n"
    b = b + "    \"O2_non_local_correlation\": " + bool_str(o2_pass) + ",\n"
    b = b + "    \"O3_emergent_invariant\": " + bool_str(o3_pass) + "\n"
    b = b + "  },\n"
    b = b + "  \"verdict\": \"" + verdict + "\"\n"
    b = b + "}\n"
    write_file(path, b)
    println("  cert=" + path)
}

fn bool_str(b: bool) -> string { if b { return "true" } return "false" }

fn emit_side_json(r: [int], total_cells: int, ticks: int) -> string {
    let mut s = "{"
    s = s + "\"total_cells\":" + str(total_cells)
    s = s + ",\"ticks\":" + str(ticks)
    s = s + ",\"coh_mean_ppm\":" + str(r[0])
    s = s + ",\"coh_stderr_ppm\":" + str(r[1])
    s = s + ",\"slope_max_mean\":" + str(r[2])
    s = s + ",\"slope_max_stderr\":" + str(r[3])
    s = s + ",\"alpha_mean_x1000\":" + str(r[4])
    s = s + ",\"alpha_stderr_x1000\":" + str(r[5])
    s = s + ",\"xi_mean_x1000\":" + str(r[6])
    s = s + ",\"xi_stderr_x1000\":" + str(r[7])
    s = s + ",\"C_r1_mean_ppm\":" + str(r[8])
    s = s + ",\"C_r1_shuf_ppm\":" + str(r[9])
    s = s + ",\"C_rmax_mean_ppm\":" + str(r[10])
    s = s + ",\"C_rmax_shuf_ppm\":" + str(r[11])
    s = s + ",\"phi_std_over_mean_ppm\":" + str(r[12])
    s = s + ",\"phi_std_ppm\":" + str(r[13])
    s = s + "}"
    return s
}

// single-side fanout: args = [<bin>, <script>, <side>, <ticks>, <out_path>]
// Emits a fragment JSON file containing aggregated observables for one side.
fn emit_side_fragment(path: string, side: int, total_cells: int,
                      ticks: int, r: [int]) {
    let mut b = "{\n"
    b = b + "  \"side\": " + str(side) + ",\n"
    b = b + "  \"total_cells\": " + str(total_cells) + ",\n"
    b = b + "  \"ticks\": " + str(ticks) + ",\n"
    b = b + "  \"seeds\": [42, 137, 271],\n"
    b = b + "  \"coh_mean_ppm\": " + str(r[0]) + ",\n"
    b = b + "  \"coh_stderr_ppm\": " + str(r[1]) + ",\n"
    b = b + "  \"slope_max_mean\": " + str(r[2]) + ",\n"
    b = b + "  \"slope_max_stderr\": " + str(r[3]) + ",\n"
    b = b + "  \"alpha_mean_x1000\": " + str(r[4]) + ",\n"
    b = b + "  \"alpha_stderr_x1000\": " + str(r[5]) + ",\n"
    b = b + "  \"xi_mean_x1000\": " + str(r[6]) + ",\n"
    b = b + "  \"xi_stderr_x1000\": " + str(r[7]) + ",\n"
    b = b + "  \"C_r1_mean_ppm\": " + str(r[8]) + ",\n"
    b = b + "  \"C_r1_shuf_ppm\": " + str(r[9]) + ",\n"
    b = b + "  \"C_rmax_mean_ppm\": " + str(r[10]) + ",\n"
    b = b + "  \"C_rmax_shuf_ppm\": " + str(r[11]) + ",\n"
    b = b + "  \"phi_std_over_mean_ppm\": " + str(r[12]) + ",\n"
    b = b + "  \"phi_std_ppm\": " + str(r[13]) + "\n"
    b = b + "}\n"
    write_file(path, b)
    println("  fragment=" + path)
}

fn main() {
    let argv = args()
    if len(argv) >= 5 {
        let side  = parse_int(argv[2])
        let ticks = parse_int(argv[3])
        let out_p = argv[4]
        let n_tot = side * side
        println("── SINGLE side=" + str(side) + " (N=" + str(n_tot) + ") ticks=" + str(ticks) + " ──")
        let r = run_side(side, ticks)
        emit_side_fragment(out_p, side, n_tot, ticks, r)
        exit(0)
    }

    println("F_l3_emergence_measure — Mk.VII C2 L3 3-observable REAL measurement")
    println("  seeds = [42, 137, 271]")
    println("  N ∈ {16, 64, 256} = side ∈ {4, 8, 16}")
    println("")

    // Tick budget sized so transitions complete: with T0=5000, UPPER=7000,
    // LOWER=3000, per-tick drift g/2 ≤ ±500 plus attraction, cells cross a
    // gate in ~4-6 ticks.  Larger N gets more attraction pressure (more
    // active neighbours) so can use fewer ticks.
    println("── N=16 (4×4) ──")
    let r16 = run_side(4, 6)

    println("── N=64 (8×8) ──")
    let r64 = run_side(8, 5)

    println("── N=256 (16×16) ──")
    let r256 = run_side(16, 4)

    // derived values ------------------------------------------------------
    let divergence     = divergence_ppm(r16[0], r64[0], r256[0])
    // slope ratio: slope_max(N=256) / slope_max(N=16), ppm-scaled
    let slope_ratio_ppm = if r16[2] > 0 { (r256[2] * 1000) / r16[2] } else { 0 }

    // O1 pre-registered thresholds:
    //   divergence > 0.15  (150 ppm if ppm-scale)
    //   slope ratio ≥ 3× → slope_ratio_ppm ≥ 3000
    let o1 = (divergence >= 150) && (slope_ratio_ppm >= 3000)

    // O2 pre-registered thresholds:
    //   α < 1.5  → alpha_mean_x1000 < 1500 at N=256
    //   ξ > diameter/4 → xi_mean_x1000 / 1000 > (2*(side-1))/4
    //   AND C(r) > shuffled baseline (C_r1_mean > C_r1_shuf at N=256)
    let diameter_256 = 2 * (16 - 1)
    let xi_thresh    = (diameter_256 * 1000) / 4
    let alpha_ok     = r256[4] < 1500 && r256[4] > 0
    let xi_ok        = r256[6] > xi_thresh
    let corr_ok      = r256[8] > r256[9]   // C(r=1) > shuffled
    let o2 = alpha_ok && xi_ok && corr_ok

    // O3 pre-registered thresholds at N=256 (largest):
    //   lattice-Φ > 0.1 (i.e. coh_mean > 100 ppm)
    //   std/mean < 0.2 (i.e. phi_std_over_mean_ppm < 200)
    let o3 = r256[0] > 100 && r256[12] < 200 && r256[12] > 0

    let mut passes = 0
    if o1 { passes = passes + 1 }
    if o2 { passes = passes + 1 }
    if o3 { passes = passes + 1 }

    let verdict = if passes == 3 { "L3_EMERGED" }
                  else if passes >= 1 { "L3_PARTIAL" }
                  else { "L3_FAILED" }

    println("")
    println("══ MK.VII C2 L3 EMERGENCE VERDICT ══")
    println("  N=16  coh=" + str(r16[0])  + " ± " + str(r16[1])  + " ppm, slope_max=" + str(r16[2])  + " ± " + str(r16[3]))
    println("  N=64  coh=" + str(r64[0])  + " ± " + str(r64[1])  + " ppm, slope_max=" + str(r64[2])  + " ± " + str(r64[3]))
    println("  N=256 coh=" + str(r256[0]) + " ± " + str(r256[1]) + " ppm, slope_max=" + str(r256[2]) + " ± " + str(r256[3]))
    println("  divergence=" + str(divergence) + " ppm  slope_ratio=" + str(slope_ratio_ppm) + " ppm")
    println("  N=256 α=" + str(r256[4]) + "±" + str(r256[5]) + " (×1000)  ξ=" + str(r256[6]) + "±" + str(r256[7]) + " (×1000)")
    println("  N=256 C(1)=" + str(r256[8]) + "  C(1)_shuf=" + str(r256[9])
        + "  C(rmax)=" + str(r256[10]) + "  C(rmax)_shuf=" + str(r256[11]))
    println("  N=256 Φ_std/mean=" + str(r256[12]) + " ppm  Φ_std=" + str(r256[13]))
    println("  O1 phase transition:       " + bool_str(o1))
    println("  O2 non-local correlation:  " + bool_str(o2))
    println("  O3 emergent invariant:     " + bool_str(o3))
    println("  VERDICT: " + verdict + " (" + str(passes) + "/3 PASS)")

    emit_cert("state/edu_l3_emergence.json",
              r16, r64, r256,
              divergence, slope_ratio_ppm,
              o1, o2, o3, verdict)

    // We do not FAIL the script on L3_PARTIAL / L3_FAILED — that's a real
    // measurement result.  Only exit non-zero for internal invariants.
    if r16[0] < 0 || r64[0] < 0 || r256[0] < 0 {
        println("F_l3_emergence_measure: FAIL (invalid coh)")
        exit(1)
    }
    println("F_l3_emergence_measure: PASS (real measurement emitted)")
    exit(0)
}
