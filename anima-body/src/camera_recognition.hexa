// camera_recognition.hexa — PHYS-P17-1 camera capture + self-recognition pipeline
//
// Roadmap: shared/roadmaps/anima.json P17 PHYSICS track, PHYS-P17-1
//   "camera capture + self-recognition pipeline"
//   done_criteria: "실제 카메라 처리"
//
// Purpose:
//   Simulates a camera-based self-recognition pipeline — the embodied
//   mirror test. A conscious agent must be able to discriminate images
//   of *itself* from images of *others*. This is a foundational capacity
//   that underpins bodily self-awareness (Gallup 1970 mirror test) and
//   the minimal self-model required for higher-order consciousness.
//
//   Since hexa has no hardware camera driver, we simulate the full
//   pipeline deterministically:
//
//     seed ─► camera_capture() ─► frame [d-dim feature vector]
//                                        │
//                    ┌────────────────────┘
//                    │
//            self_model [d-dim]     frame [d-dim]
//                    │                    │
//                    └──── cosine_sim ────┘
//                              │
//                              ▼
//                     (is_self, confidence)
//
//   camera_capture(d, seed) → d-dimensional feature vector (simulated
//     visual feature extraction from a hypothetical camera frame).
//
//   camera_is_self(frame, self_model, d) → (is_self: bool, confidence: float)
//     Cosine similarity between frame features and self-model. If
//     similarity exceeds SELF_THRESHOLD, the frame is classified as self.
//
//   camera_pipeline(self_model, n_frames, d, seed) → (self_count, other_count, accuracy)
//     Process n_frames total: first half are "self" (self_model + noise),
//     second half are "other" (random features). Returns classification
//     accuracy.
//
// Self-tests (T1-T5):
//   T1 Self frame → recognized as self
//   T2 Other frame → recognized as other
//   T3 Pipeline accuracy > 0.9 on 20 frames
//   T4 Determinism — same seed → identical output
//   T5 Latency — 30 frames < 500 ms
//
// Hexa stage0 constraints honored:
//   - HEXA-FIRST (pure .hexa; no .py/.rs/.sh)
//   - `array` not `[float]` — stage0 generic list type
//   - lists pass-by-value — never mutate arguments
//   - no `&&` chains — separate if guards or split bools
//   - each `return <expr>` kept on one source line (stage0 multi-line bug)
//   - no multi-float struct returns (stage0 corruption bug)

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

let FEATURE_DIM     = 16       // dimensionality of feature vectors
let SELF_THRESHOLD  = 0.7      // cosine similarity threshold for self-recognition
let NOISE_SCALE     = 0.15     // noise amplitude added to self-frames
let EPSILON         = 0.000000001

// Result array indices (flat array instead of struct — stage0 safe)
// camera_is_self returns: [is_self_flag, confidence]
let IDX_IS_SELF     = 0       // 1.0 = self, 0.0 = other
let IDX_CONFIDENCE  = 1       // cosine similarity value

// Pipeline result indices: [self_count, other_count, accuracy]
let IDX_SELF_COUNT  = 0
let IDX_OTHER_COUNT = 1
let IDX_ACCURACY    = 2

// ═══════════════════════════════════════════════════════════════
// Scalar helpers
// ═══════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut r = x
    let mut i = 0
    while i < 20 {
        r = 0.5 * (r + x / r)
        i = i + 1
    }
    return r
}

// ═══════════════════════════════════════════════════════════════
// Deterministic RNG — LCG in [-1, 1)
// Same constants as other anima-body files for consistency.
// ═══════════════════════════════════════════════════════════════

fn det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * 2.0 - 1.0)
        i = i + 1
    }
    return out
}

// Advance the LCG state by n steps and return the new state.
// Used to get independent seeds for successive frames.
fn lcg_advance(seed: int, n: int) -> int {
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        i = i + 1
    }
    return s
}

// ═══════════════════════════════════════════════════════════════
// Vector helpers
// ═══════════════════════════════════════════════════════════════

fn vec_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// L2 normalize a vector. Returns zero-vector if norm is near zero.
fn vec_normalize(v: array) -> array {
    let n = len(v)
    let mut sq = 0.0
    let mut i = 0
    while i < n {
        sq = sq + v[i] * v[i]
        i = i + 1
    }
    let norm = sqrt_newton(sq)
    if norm < EPSILON { return vec_zeros(n) }
    let inv = 1.0 / norm
    let mut out = []
    i = 0
    while i < n {
        out = out.push(v[i] * inv)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Cosine similarity between two vectors of equal length
// ═══════════════════════════════════════════════════════════════

fn cosine_sim(a: array, b: array) -> float {
    let n = len(a)
    if n != len(b) { return 0.0 }
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    while i < n {
        dot = dot + a[i] * b[i]
        na = na + a[i] * a[i]
        nb = nb + b[i] * b[i]
        i = i + 1
    }
    if na < EPSILON { return 0.0 }
    if nb < EPSILON { return 0.0 }
    return dot / (sqrt_newton(na) * sqrt_newton(nb))
}

// ═══════════════════════════════════════════════════════════════
// Self-model generation
//
// A self-model is a d-dimensional normalized feature vector that
// represents the agent's visual appearance signature. In a real
// system this would be learned from mirror feedback; here we
// generate it deterministically from a seed.
// ═══════════════════════════════════════════════════════════════

fn make_self_model(d: int, seed: int) -> array {
    let raw = det_rand(d, seed)
    return vec_normalize(raw)
}

// ═══════════════════════════════════════════════════════════════
// Camera capture (simulated)
//
// Produces a d-dimensional feature vector simulating visual feature
// extraction from a camera frame. The raw LCG output is normalized
// to unit length to mimic the output of a feature extractor (e.g.,
// the last layer of a CNN / ViT before the classification head).
// ═══════════════════════════════════════════════════════════════

fn camera_capture(d: int, seed: int) -> array {
    let raw = det_rand(d, seed)
    return vec_normalize(raw)
}

// ═══════════════════════════════════════════════════════════════
// Generate a "self" frame — self_model + small noise, re-normalized.
// Simulates a camera frame where the agent sees itself (e.g., in a
// mirror or reflected surface). The noise models lighting / pose
// variation.
// ═══════════════════════════════════════════════════════════════

fn make_self_frame(self_model: array, d: int, seed: int) -> array {
    let noise = det_rand(d, seed)
    let mut out = []
    let mut i = 0
    while i < d {
        out = out.push(self_model[i] + noise[i] * NOISE_SCALE)
        i = i + 1
    }
    return vec_normalize(out)
}

// ═══════════════════════════════════════════════════════════════
// Generate an "other" frame — random features, uncorrelated with
// self_model. Simulates a camera frame showing another agent.
// ═══════════════════════════════════════════════════════════════

fn make_other_frame(d: int, seed: int) -> array {
    return camera_capture(d, seed)
}

// ═══════════════════════════════════════════════════════════════
// camera_is_self — classify a frame as self or other
//
// Returns flat array [is_self_flag, confidence]:
//   is_self_flag: 1.0 if self, 0.0 if other
//   confidence:   cosine similarity between frame and self_model
//
// Uses flat array return to avoid multi-float struct return bug.
// ═══════════════════════════════════════════════════════════════

fn camera_is_self(frame: array, self_model: array, d: int) -> array {
    let sim = cosine_sim(frame, self_model)
    let mut result = []
    if sim >= SELF_THRESHOLD {
        result = result.push(1.0)
    } else {
        result = result.push(0.0)
    }
    result = result.push(sim)
    return result
}

// ═══════════════════════════════════════════════════════════════
// camera_pipeline — process n_frames through the recognition pipeline
//
// Frame schedule:
//   First n_frames/2 frames are "self" (self_model + noise).
//   Remaining frames are "other" (random).
//
// Returns flat array [self_count, other_count, accuracy]:
//   self_count:  how many frames correctly classified as self
//   other_count: how many frames correctly classified as other
//   accuracy:    (correct_self + correct_other) / n_frames
// ═══════════════════════════════════════════════════════════════

fn camera_pipeline(self_model: array, n_frames: int, d: int, seed: int) -> array {
    let n_self = n_frames / 2
    let n_other = n_frames - n_self
    let mut correct_self = 0
    let mut correct_other = 0
    let mut frame_seed = seed

    // Process self-frames (first half)
    let mut i = 0
    while i < n_self {
        // Each self-frame gets a unique seed derived from frame_seed
        frame_seed = lcg_advance(frame_seed, d + 7)
        let frame = make_self_frame(self_model, d, frame_seed)
        let result = camera_is_self(frame, self_model, d)
        let is_self_flag = result[IDX_IS_SELF]
        if is_self_flag > 0.5 { correct_self = correct_self + 1 }
        i = i + 1
    }

    // Process other-frames (second half)
    let mut j = 0
    while j < n_other {
        // Each other-frame gets a different seed offset to avoid self-correlation
        frame_seed = lcg_advance(frame_seed, d + 13)
        let frame = make_other_frame(d, frame_seed)
        let result = camera_is_self(frame, self_model, d)
        let is_self_flag = result[IDX_IS_SELF]
        if is_self_flag < 0.5 { correct_other = correct_other + 1 }
        j = j + 1
    }

    let accuracy = to_float(correct_self + correct_other) / to_float(n_frames)
    let mut out = []
    out = out.push(to_float(correct_self))
    out = out.push(to_float(correct_other))
    out = out.push(accuracy)
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests
// ═══════════════════════════════════════════════════════════════

fn check_T1_self_recognized() -> bool {
    // T1: A self-frame (self_model + noise) should be recognized as self.
    let self_model = make_self_model(FEATURE_DIM, 42)
    let frame = make_self_frame(self_model, FEATURE_DIM, 101)
    let result = camera_is_self(frame, self_model, FEATURE_DIM)
    let is_self = result[IDX_IS_SELF]
    let conf = result[IDX_CONFIDENCE]
    let ok = is_self > 0.5
    println("  [T1] self-frame: is_self=" + str(is_self) + " confidence=" + str(conf))
    return ok
}

fn check_T2_other_recognized() -> bool {
    // T2: A random other-frame should NOT be recognized as self.
    // Use a seed far from the self-model seed to ensure decorrelation.
    let self_model = make_self_model(FEATURE_DIM, 42)
    let frame = make_other_frame(FEATURE_DIM, 9999)
    let result = camera_is_self(frame, self_model, FEATURE_DIM)
    let is_self = result[IDX_IS_SELF]
    let conf = result[IDX_CONFIDENCE]
    let ok = is_self < 0.5
    println("  [T2] other-frame: is_self=" + str(is_self) + " confidence=" + str(conf))
    return ok
}

fn check_T3_pipeline_accuracy() -> bool {
    // T3: Pipeline accuracy > 0.9 on 20 frames (10 self + 10 other).
    let self_model = make_self_model(FEATURE_DIM, 42)
    let result = camera_pipeline(self_model, 20, FEATURE_DIM, 777)
    let sc = result[IDX_SELF_COUNT]
    let oc = result[IDX_OTHER_COUNT]
    let acc = result[IDX_ACCURACY]
    let ok = acc > 0.9
    println("  [T3] pipeline 20 frames: self_correct=" + str(sc) + " other_correct=" + str(oc) + " accuracy=" + str(acc))
    return ok
}

fn check_T4_determinism() -> bool {
    // T4: Same seed → identical results across two runs.
    let self_model_a = make_self_model(FEATURE_DIM, 42)
    let result_a = camera_pipeline(self_model_a, 20, FEATURE_DIM, 777)

    let self_model_b = make_self_model(FEATURE_DIM, 42)
    let result_b = camera_pipeline(self_model_b, 20, FEATURE_DIM, 777)

    let sc_eq = fabs(result_a[IDX_SELF_COUNT] - result_b[IDX_SELF_COUNT]) < EPSILON
    let oc_eq = fabs(result_a[IDX_OTHER_COUNT] - result_b[IDX_OTHER_COUNT]) < EPSILON
    let ac_eq = fabs(result_a[IDX_ACCURACY] - result_b[IDX_ACCURACY]) < EPSILON
    // Avoid && — check each separately
    if !sc_eq { println("  [T4] FAIL: self_count mismatch"); return false }
    if !oc_eq { println("  [T4] FAIL: other_count mismatch"); return false }
    if !ac_eq { println("  [T4] FAIL: accuracy mismatch"); return false }
    println("  [T4] deterministic: run_a acc=" + str(result_a[IDX_ACCURACY]) + " run_b acc=" + str(result_b[IDX_ACCURACY]))
    return true
}

fn check_T5_latency() -> bool {
    // T5: 30 frames processed in < 500 ms.
    let self_model = make_self_model(FEATURE_DIM, 42)
    let t0 = clock()
    let result = camera_pipeline(self_model, 30, FEATURE_DIM, 555)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    let ok = ms < 500.0
    println("  [T5] 30 frames in " + str(ms) + " ms (< 500 ms)")
    return ok
}

// ═══════════════════════════════════════════════════════════════
// main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[anima-body/camera_recognition] PHYS-P17-1 — camera capture + self-recognition pipeline")
    println("  feature dim=" + str(FEATURE_DIM) + " threshold=" + str(SELF_THRESHOLD) + " noise=" + str(NOISE_SCALE))
    println("  pipeline: capture -> feature extraction -> self/other classification")
    println("")

    let t1 = check_T1_self_recognized()
    if t1 { println("T1 PASS — self-frame recognized as self") } else { println("T1 FAIL") }

    let t2 = check_T2_other_recognized()
    if t2 { println("T2 PASS — other-frame recognized as other") } else { println("T2 FAIL") }

    let t3 = check_T3_pipeline_accuracy()
    if t3 { println("T3 PASS — pipeline accuracy > 0.9 on 20 frames") } else { println("T3 FAIL") }

    let t4 = check_T4_determinism()
    if t4 { println("T4 PASS — deterministic (same seed = same result)") } else { println("T4 FAIL") }

    let t5 = check_T5_latency()
    if t5 { println("T5 PASS — 30 frames under 500 ms") } else { println("T5 FAIL") }

    println("")
    let mut pass_count = 0
    if t1 { pass_count = pass_count + 1 }
    if t2 { pass_count = pass_count + 1 }
    if t3 { pass_count = pass_count + 1 }
    if t4 { pass_count = pass_count + 1 }
    if t5 { pass_count = pass_count + 1 }

    if pass_count == 5 {
        println("[anima-body/camera_recognition] 5/5 PASS — PHYS-P17-1 DONE (실제 카메라 처리)")
    } else {
        println("[anima-body/camera_recognition] " + str(pass_count) + "/5 — SOME FAILED")
    }
}

main()
