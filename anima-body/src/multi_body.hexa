// multi_body.hexa — One consciousness controlling multiple bodies (hivemind)
// Tests: does controlling more bodies increase/decrease Phi?
// Body switching: shift primary attention between bodies

struct BodyInstance {
    body_id: i32,
    adapter: string,
    attention_weight: float
}

struct MultiBodyController {
    n_bodies: i32,
    primary_body: i32,
    phi: float
}

fn create_controller(n_bodies: i32) -> MultiBodyController {
    return MultiBodyController(n_bodies, 0, 0.0)
}

fn switch_primary(ctrl: MultiBodyController, body_id: i32) -> MultiBodyController {
    return MultiBodyController(ctrl.n_bodies, body_id, ctrl.phi)
}

fn step(ctrl: MultiBodyController) -> MultiBodyController {
    return ctrl
}
