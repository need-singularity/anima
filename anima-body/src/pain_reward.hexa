// pain_reward.hexa — Pain/reward system: nociceptor model + hedonic tone
// Pain: joint limit, collision, overheating, overcurrent
// Reward: goal achievement, exploration, social interaction

struct PainSignal {
    source: string,
    intensity: float,
    location: string
}

struct RewardSignal {
    source: string,
    magnitude: float
}

struct HedonicState {
    pain_level: float,
    reward_level: float,
    hedonic_tone: float,
    sensitized: bool
}

fn process_pain(signal: PainSignal) -> HedonicState {
    return HedonicState(signal.intensity, 0.0, 0.0 - signal.intensity, false)
}

fn process_reward(signal: RewardSignal) -> HedonicState {
    return HedonicState(0.0, signal.magnitude, signal.magnitude, false)
}

fn should_stop(state: HedonicState) -> bool {
    return state.pain_level > 0.8
}
