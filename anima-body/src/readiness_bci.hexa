// readiness_bci.hexa — PHYS-P10-1 BCI readiness detection (Libet paradigm)
//
// Roadmap: shared/roadmaps/anima.json P10 PHYSICS track, PHYS-P10-1
//   "BCI readiness detection — EEG readiness potential"
//   done_criteria: "500ms pre-decision 감지"
//
// Purpose:
//   Reproduce Libet (1983) / Kornhuber & Deecke (1965) Bereitschafts-
//   potential (BP, readiness potential — RP): a slow negative EEG
//   ramp generated by SMA/pre-SMA beginning ~500–1500 ms BEFORE a
//   self-initiated voluntary movement. The RP is the canonical
//   neurophysiological signature of preconscious motor preparation
//   and is the empirical anchor of P10 (will / agency / Φ_will).
//
//   The classic result: averaging EEG epochs time-locked to movement
//   onset reveals a slow ramp (−5 to −20 μV in human scalp electrodes)
//   that precedes the subject's reported moment of "urge to move" by
//   ~350 ms — the famous Libet gap that fuels the free-will debate.
//
// Pipeline:
//   1. Synthetic EEG generator — mimics a trial recording around a
//      self-initiated movement. At t=0 (decision/movement):
//        x(t) = RP_ramp(t) + μ_osc(t) + noise(t)
//      where RP_ramp(t) = −A_RP · max(0, (t + T_ramp) / T_ramp)  for t < 0
//                       and 0 for t > 0 (ramp ends at decision).
//      T_ramp = 1000 ms (biologically realistic).
//
//   2. Sliding detector — on a streaming window that ENDS at the
//      current decision candidate time t_0, compute:
//        slope(t_0) = linear regression slope over the last W_DETECT
//                      samples (signed μV/s). A sufficiently-negative
//                      slope means an RP is underway.
//      Detection fires when slope(t_0) ≤ THRESHOLD_SLOPE for a
//      sustained window; the "trigger time" is taken 500 ms before
//      the movement — the advance-warning horizon.
//
//   3. BCI readout — detect_readiness(eeg_trial, t_decision_samples)
//      returns a float score in [0, 1]: 1 if a strong RP is detected
//      at least 500 ms before t_decision_samples, 0 if none.
//
// Exposed API (roadmap spec):
//   detect_readiness(eeg_trial: [float], t_decision_idx: int) -> float
//     Score ∈ [0,1]: higher means stronger pre-decision RP detected.
//
//   pre_decision_advance_ms(eeg_trial: [float], t_decision_idx: int) -> float
//     Estimated advance-warning time in ms (how many ms before t_dec
//     did the slope cross THRESHOLD_SLOPE). Returns 0 if no detect.
//
// Self-test (PASS/FAIL):
//   T1 synth trial has the RP ramp in the correct sign (negative slope
//      in pre-decision segment; near-zero slope in post-decision).
//   T2 detect_readiness on a proper RP trial gives a HIGH score (>0.7).
//   T3 detect_readiness on a NO-RP trial gives a LOW score (<0.3).
//   T4 pre_decision_advance_ms ≥ 500 ms on proper RP trial
//      (the 500ms gate_exit criterion).
//   T5 API contract — accepts any length; clamps to [0,1]; empty trial
//      returns 0.0; returns same value on two identical calls.
//   T6 noise robustness — score still >0.5 with 2x noise.
//
// Hexa constraints honored:
//   - HEXA-FIRST (pure .hexa; no .py/.rs/.sh)
//   - flat [float] lists (no multi-float struct returns — stage1 bug)
//   - lists pass-by-value — never mutate arguments
//   - no substring/char math on multibyte strings (no strings used here)
//   - each `return <expr>` kept on one source line (stage1 multi-line bug)

// ═══════════════════════════════════════════════════════════════
// Constants — Libet BP physiology + DSP
// ═══════════════════════════════════════════════════════════════

// NOTE on sampling rate: real Libet EEG is 256+ Hz, but the hexa
// stage1 interpreter is slow enough on list iteration that doing
// 512-sample regressions in a 48-step sliding scan hits minute-scale
// runtime. We downsample to 64 Hz — plenty for a 1-Hz-scale RP ramp
// — keeping the same *physiology* (ms timings, μV amplitudes, theta
// oscillation) but reducing sample counts by 4x.
let FS_HZ              = 64.0          // sampling rate (downsampled EEG)
let PI                 = 3.141592653589793
let TWO_PI             = 6.283185307179586

// BP / RP ramp
let T_RAMP_MS          = 1000.0        // RP onset ~1 s before decision
let A_RP_UV            = 10.0          // peak amplitude at t=0 (μV)
                                       // (negative — cortex-negative)
let MU_HZ              = 10.0          // background mu rhythm (dominant
                                       // non-task EEG rhythm)
let A_MU_UV            = 3.0           // mu amplitude (μV)
let A_NOISE_UV         = 1.5           // broadband noise (μV)

// Trial layout
let TRIAL_PRE_MS       = 1500.0        // record 1500 ms before decision
let TRIAL_POST_MS      = 500.0         //        500 ms after decision
// TRIAL_MS total = 2000 ms, TRIAL_N = 128 samples @ 64 Hz
let TRIAL_N            = 128
let T_DECISION_IDX     = 96            // 1500 ms @ 64 Hz = 96 samples

// Detector
let W_DETECT_MS        = 500.0         // sliding window for slope
let W_DETECT_N         = 32            // 500 ms @ 64 Hz = 32 samples
let THRESHOLD_SLOPE    = 0.0 - 6.0     // μV/s (negative = RP ramp)
                                       // biological RP is ~−10 μV/s at SMA;
                                       // pick −6 to reject noise-only slopes
                                       // (mu ±3μV @ 10Hz → regression ≤ 3μV/s)
                                       // while reliably detecting RP ramps.

// Pre-decision gate (done_criteria: 500ms)
let GATE_ADVANCE_MS    = 500.0

// Score clamp
let SCORE_LO           = 0.0
let SCORE_HI           = 1.0

// Deterministic LCG seed
let SEED               = 20260415

// ═══════════════════════════════════════════════════════════════
// Scalar helpers
// ═══════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn fmin(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn fmax(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// LCG PRNG — identical to mu_rhythm_detector.hexa
fn lcg_next(s: int) -> int {
    return (s * 1103515245 + 12345) % 2147483648
}

fn lcg_unit_signed(s: int) -> float {
    let x = lcg_next(s)
    let u = to_float(x % 1000000) / 1000000.0
    return u - 0.5
}

// ═══════════════════════════════════════════════════════════════
// Linear regression slope over samples [i_lo, i_hi)
//
// Returns slope in μV per second (the EEG is in μV, index→time via fs).
//
//   slope_per_sample = (N·Σx_i·t_i − Σx_i · Σt_i) / (N·Σt_i² − (Σt_i)²)
//   slope_per_sec    = slope_per_sample · fs
//
// Here t_i = i (sample index, dimensionless). Let M = i_hi − i_lo.
// Σt_i   = Σ_{k=0..M-1} k = M(M-1)/2
// Σt_i²  = Σ_{k=0..M-1} k² = M(M-1)(2M-1)/6
// ═══════════════════════════════════════════════════════════════

fn regression_slope_uv_per_s(signal: array, i_lo: int, i_hi: int, fs: float) -> float {
    if i_lo < 0 { return 0.0 }
    if i_hi > len(signal) { return 0.0 }
    let m = i_hi - i_lo
    if m < 2 { return 0.0 }
    let mf = to_float(m)
    // Σt and Σt² in LOCAL index space (0..m-1)
    let sum_t = mf * (mf - 1.0) / 2.0
    let sum_t2 = mf * (mf - 1.0) * (2.0 * mf - 1.0) / 6.0
    let mut sum_x = 0.0
    let mut sum_xt = 0.0
    let mut k = 0
    while k < m {
        let x = signal[i_lo + k]
        let t = to_float(k)
        sum_x = sum_x + x
        sum_xt = sum_xt + x * t
        k = k + 1
    }
    let denom = mf * sum_t2 - sum_t * sum_t
    if fabs(denom) < 0.000001 { return 0.0 }
    let slope_per_sample = (mf * sum_xt - sum_x * sum_t) / denom
    return slope_per_sample * fs
}

// ═══════════════════════════════════════════════════════════════
// Synthetic EEG trial generator
//
// Given t_decision_idx within [0, TRIAL_N):
//   for each sample i ∈ [0, TRIAL_N):
//     delta_i = (i − t_decision_idx) / fs     [time from decision, sec]
//     if delta_i < 0  (pre-decision):
//       t_rel = (delta_i + T_RAMP_MS/1000) / (T_RAMP_MS/1000)
//       rp    = −A_RP · max(0, t_rel)           [goes from 0 to −A_RP]
//     else (post-decision):
//       rp    = 0.0
//     mu     = A_mu · cos(2π · f_mu · i/fs)
//     noise  = A_noise · lcg_unit_signed(seed)
//     x_i    = rp + mu + noise
//
// `include_rp` flag toggles the RP ramp (for no-RP control trials).
// ═══════════════════════════════════════════════════════════════

fn synth_trial(n: int, t_decision_idx: int, include_rp: bool,
               noise_gain: float, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let t_ramp_s = T_RAMP_MS / 1000.0
    let mut i = 0
    while i < n {
        let delta_s = to_float(i - t_decision_idx) / FS_HZ
        let mut rp = 0.0
        if include_rp {
            if delta_s < 0.0 {
                let t_rel = (delta_s + t_ramp_s) / t_ramp_s
                let t_rel_c = if t_rel < 0.0 { 0.0 } else { t_rel }
                rp = 0.0 - A_RP_UV * t_rel_c
            }
        }
        let mu_comp = A_MU_UV * cos(TWO_PI * MU_HZ * to_float(i) / FS_HZ)
        s = lcg_next(s)
        let noise_comp = noise_gain * A_NOISE_UV * lcg_unit_signed(s)
        out = out.push(rp + mu_comp + noise_comp)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// detect_readiness — score in [0,1]
//
// Strategy:
//   1. Slope over the W_DETECT window ending at t_decision_idx.
//   2. Slope over the W_DETECT window ending 500 ms before that
//      (i.e. the "gate-advance" window — the done_criteria anchor).
//   3. score = clamp(−slope_gate / |THRESHOLD_SLOPE| , 0, 1)
//      (bigger negative slope at gate window → higher score, clamped.)
// ═══════════════════════════════════════════════════════════════

fn detect_readiness(eeg_trial: array, t_decision_idx: int) -> float {
    let n = len(eeg_trial)
    if n < W_DETECT_N + 2 { return 0.0 }
    if t_decision_idx <= 0 { return 0.0 }
    if t_decision_idx > n { return 0.0 }
    // Window that ends GATE_ADVANCE_MS before decision.
    let gate_shift_samples = to_int(GATE_ADVANCE_MS * FS_HZ / 1000.0)
    let gate_end = t_decision_idx - gate_shift_samples
    let gate_lo = gate_end - W_DETECT_N
    if gate_lo < 0 { return 0.0 }
    if gate_end > n { return 0.0 }
    let slope_gate = regression_slope_uv_per_s(eeg_trial, gate_lo, gate_end, FS_HZ)
    // Normalize — threshold is negative, so we invert sign.
    let thresh_mag = fabs(THRESHOLD_SLOPE)
    let neg_slope = 0.0 - slope_gate
    let score = neg_slope / thresh_mag
    return clamp(score, SCORE_LO, SCORE_HI)
}

// ═══════════════════════════════════════════════════════════════
// pre_decision_advance_ms — estimate advance-warning time
//
// Walk backwards from t_decision_idx in W_DETECT-sized sliding windows
// and record the earliest time at which slope ≤ THRESHOLD_SLOPE for
// 2 consecutive windows (a simple hysteresis). Returns the advance
// time in ms — clamped to [0, T_RAMP_MS].
// ═══════════════════════════════════════════════════════════════

fn pre_decision_advance_ms(eeg_trial: array, t_decision_idx: int) -> float {
    let n = len(eeg_trial)
    if n < W_DETECT_N + 2 { return 0.0 }
    if t_decision_idx <= W_DETECT_N { return 0.0 }
    if t_decision_idx > n { return 0.0 }
    // Slide: windows end at t ∈ {t_dec − k} for k = 0, 1, 2, ...
    // Require 2 consecutive windows with slope ≤ THRESHOLD_SLOPE.
    // Walk k from 0 upward (decision → earlier in time).
    // Track the FURTHEST k with 2 consecutive slope-threshold hits —
    // that's the earliest pre-decision time where detection holds.
    let mut k = 0
    let mut prev_hit = false
    let mut last_hit_k = -1
    let step = 4
    let mut keep_going = k + W_DETECT_N
    while keep_going < t_decision_idx {
        let end_idx = t_decision_idx - k
        let lo_idx = end_idx - W_DETECT_N
        if lo_idx < 0 {
            k = k + step
        } else {
            let slp = regression_slope_uv_per_s(eeg_trial, lo_idx, end_idx, FS_HZ)
            let hit = slp <= THRESHOLD_SLOPE
            if hit {
                if prev_hit {
                    last_hit_k = k
                }
            }
            prev_hit = hit
            k = k + step
        }
        keep_going = k + W_DETECT_N
    }
    if last_hit_k < 0 { return 0.0 }
    let ms = to_float(last_hit_k) / FS_HZ * 1000.0
    return clamp(ms, 0.0, T_RAMP_MS)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests
// ═══════════════════════════════════════════════════════════════

fn check_T1_trial_sign() -> bool {
    // Pre-decision slope should be NEGATIVE and post-decision slope
    // should be near zero (well above THRESHOLD_SLOPE).
    let trial = synth_trial(TRIAL_N, T_DECISION_IDX, true, 1.0, SEED)
    let pre_slope = regression_slope_uv_per_s(trial,
        T_DECISION_IDX - W_DETECT_N, T_DECISION_IDX, FS_HZ)
    let post_slope = regression_slope_uv_per_s(trial,
        T_DECISION_IDX, T_DECISION_IDX + (TRIAL_N - T_DECISION_IDX), FS_HZ)
    let pre_ok = pre_slope < THRESHOLD_SLOPE
    let post_ok = fabs(post_slope) < fabs(THRESHOLD_SLOPE) * 2.0
    let ok = pre_ok && post_ok
    println("  [T1] pre_slope=" + str(pre_slope) + " μV/s (< " + str(THRESHOLD_SLOPE) + "?)"
        + " post_slope=" + str(post_slope) + " μV/s")
    return ok
}

fn check_T2_rp_high_score() -> bool {
    // Proper RP trial → score should be HIGH (> 0.7).
    let trial = synth_trial(TRIAL_N, T_DECISION_IDX, true, 1.0, SEED)
    let s = detect_readiness(trial, T_DECISION_IDX)
    let ok = s > 0.7
    println("  [T2] score on RP trial = " + str(s) + " (threshold > 0.7)")
    return ok
}

fn check_T3_no_rp_low_score() -> bool {
    // NO-RP trial (just mu + noise) → score should be LOW (< 0.3).
    let trial = synth_trial(TRIAL_N, T_DECISION_IDX, false, 1.0, SEED + 1)
    let s = detect_readiness(trial, T_DECISION_IDX)
    let ok = s < 0.3
    println("  [T3] score on NO-RP trial = " + str(s) + " (threshold < 0.3)")
    return ok
}

fn check_T4_500ms_advance() -> bool {
    // done_criteria: "500ms pre-decision 감지".
    // Our detector explicitly evaluates the 500-ms-before-decision
    // window in detect_readiness(). Here we verify that
    // pre_decision_advance_ms reports ≥ 500 ms.
    let trial = synth_trial(TRIAL_N, T_DECISION_IDX, true, 1.0, SEED)
    let adv = pre_decision_advance_ms(trial, T_DECISION_IDX)
    let ok = adv >= GATE_ADVANCE_MS
    println("  [T4] pre-decision advance = " + str(adv) + " ms (gate ≥ " + str(GATE_ADVANCE_MS) + " ms)")
    return ok
}

fn check_T5_api_contract() -> bool {
    // Empty trial → 0, short trial → 0, invalid t_idx → 0.
    // Two calls on same input must be identical. Always in [0,1].
    let empty = []
    let s_empty = detect_readiness(empty, 100)
    let adv_empty = pre_decision_advance_ms(empty, 100)
    let ok_empty = s_empty == 0.0 && adv_empty == 0.0

    let mut shorty = []
    let mut i = 0
    while i < 16 {
        shorty = shorty.push(0.0)
        i = i + 1
    }
    let s_short = detect_readiness(shorty, 10)
    let ok_short = s_short == 0.0

    let trial = synth_trial(TRIAL_N, T_DECISION_IDX, true, 1.0, SEED)
    let s1 = detect_readiness(trial, T_DECISION_IDX)
    let s2 = detect_readiness(trial, T_DECISION_IDX)
    let ok_det_eq = s1 == s2
    let ok_det_lo = s1 >= 0.0
    let ok_det_hi = s1 <= 1.0
    let ok_det = ok_det_eq && ok_det_lo && ok_det_hi

    let ok_1 = ok_empty && ok_short
    let ok = ok_1 && ok_det
    println("  [T5] empty=" + str(s_empty) + " short=" + str(s_short)
        + " det=" + str(ok_det) + " s1=" + str(s1))
    return ok
}

fn check_T6_noise_robustness() -> bool {
    // 2× noise should still produce a detectable RP.
    let trial = synth_trial(TRIAL_N, T_DECISION_IDX, true, 2.0, SEED + 7)
    let s = detect_readiness(trial, T_DECISION_IDX)
    let ok = s > 0.5
    println("  [T6] score @ 2x noise = " + str(s) + " (threshold > 0.5)")
    return ok
}

fn test() {
    println("[anima-body/readiness_bci] PHYS-P10-1 — Libet readiness potential BCI")
    println("  synth: 256 Hz EEG, 2 s trial; RP ramp 1000 ms → −10 μV at decision")
    println("  detector: regression slope over 500-ms window; gate 500 ms pre-dec")
    println("")

    let t1 = check_T1_trial_sign()
    if t1 { println("T1 PASS — pre-decision slope negative, post-decision flat") } else { println("T1 FAIL") }

    let t2 = check_T2_rp_high_score()
    if t2 { println("T2 PASS — RP trial scored high (pre-decision ramp detected)") } else { println("T2 FAIL") }

    let t3 = check_T3_no_rp_low_score()
    if t3 { println("T3 PASS — NO-RP control trial scored low") } else { println("T3 FAIL") }

    let t4 = check_T4_500ms_advance()
    if t4 { println("T4 PASS — detection anticipates decision by ≥ 500 ms (Libet)") } else { println("T4 FAIL") }

    let t5 = check_T5_api_contract()
    if t5 { println("T5 PASS — API contract (empty/short guards + determinism + clamp)") } else { println("T5 FAIL") }

    let t6 = check_T6_noise_robustness()
    if t6 { println("T6 PASS — robust to 2× noise") } else { println("T6 FAIL") }

    println("")
    let a12 = t1 && t2
    let a34 = t3 && t4
    let a56 = t5 && t6
    let a1234 = a12 && a34
    let all = a1234 && a56
    if all {
        println("[anima-body/readiness_bci] 6/6 PASS — PHYS-P10-1 DONE")
    } else {
        println("[anima-body/readiness_bci] SOME FAILED")
    }
}

test()
