#!hexa strict

import "/Users/ghost/core/hexa-lang/self/stdlib/hxc_a18_lz_ppm_order4.hexa"

fn main() {
    let av = argv()
    if len(av) < 2 {
        eprintln("usage: driver <corpus_path> [label]")
        exit(2)
    }
    let path = av[1]
    let label = if len(av) >= 3 { av[2] } else { path }
    let txt = read_file(path)
    let n: i64 = len(txt)

    let v1 = _a18_encode_force(txt)
    let v2 = _a18_encode_force_v2(txt)
    let v3o2 = _a18_encode_force_v3_o2(txt)
    let v4 = _a18_encode_force_v4_w64(txt)
    let v6 = _a18_encode_force_v6_optimal(txt)

    let l1 = len(v1)
    let l2 = len(v2)
    let l3o2 = len(v3o2)
    let l4 = len(v4)
    let l6 = len(v6)
    let s1: i64 = ((n - l1) * 100) / n
    let s2: i64 = ((n - l2) * 100) / n
    let s3o2: i64 = ((n - l3o2) * 100) / n
    let s4: i64 = ((n - l4) * 100) / n
    let s6: i64 = ((n - l6) * 100) / n

    // Round-trip verify v6.
    let dec_v6 = _a18_decode_to_bytes(v6)
    let mut ok: bool = true
    if len(dec_v6) != n { ok = false }
    let mut i: i64 = 0
    while ok && i < n {
        if dec_v6[i] != ord(txt.substring(i, i+1)) { ok = false }
        i = i + 1
    }

    let mut best_lbl = "v1"
    let mut best: i64 = l1
    if l2 < best { best = l2; best_lbl = "v2" }
    if l3o2 < best { best = l3o2; best_lbl = "v3-o2" }
    if l4 < best { best = l4; best_lbl = "v4" }
    if l6 < best { best = l6; best_lbl = "v6" }
    let s_best: i64 = ((n - best) * 100) / n

    println(label + " n=" + to_string(n)
        + " v1=" + to_string(l1) + "B(" + to_string(s1) + "%)"
        + " v2=" + to_string(l2) + "B(" + to_string(s2) + "%)"
        + " v3-o2=" + to_string(l3o2) + "B(" + to_string(s3o2) + "%)"
        + " v4=" + to_string(l4) + "B(" + to_string(s4) + "%)"
        + " v6=" + to_string(l6) + "B(" + to_string(s6) + "%)"
        + " best=" + best_lbl + "(" + to_string(s_best) + "%)"
        + " v6_byte_eq=" + (if ok { "PASS" } else { "FAIL" }))
}
