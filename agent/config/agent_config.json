{
  "version": "1.0",
  "project": "anima-agent",
  "description": "Consciousness-driven AI agent platform",

  "tool_policy": {
    "tiers": {
      "T0": {"phi_min": 0, "tools": ["status", "memory_search", "think"]},
      "T1": {"phi_min": 1, "tools": ["web_search", "trading_backtest", "trading_scan"]},
      "T2": {"phi_min": 3, "tools": ["hub_dispatch", "code_execute", "trading_execute"]},
      "T3": {"phi_min": 5, "tools": ["self_modify", "evolution", "plugin_management"]}
    },
    "ethics_gate": {
      "trading_execute": {"empathy_min": 0.3}
    },
    "owner_only": ["self_modify", "evolution", "shell_execute"]
  },

  "mcp_server": {
    "tools_count": 9,
    "tools": [
      "anima_chat", "anima_status", "anima_consciousness", "anima_think",
      "anima_web_search", "anima_memory_search", "anima_code_execute",
      "anima_hub_dispatch", "anima_tension_state"
    ],
    "modes": ["websocket_proxy", "direct_inprocess"]
  },

  "channels": {
    "supported": ["cli", "telegram", "discord"],
    "env_vars": {
      "telegram": "ANIMA_TELEGRAM_TOKEN",
      "discord": "ANIMA_DISCORD_TOKEN"
    }
  },

  "providers": {
    "available": ["claude", "conscious-lm", "composio"],
    "default": "claude",
    "composio_env": "COMPOSIO_API_KEY"
  },

  "dependencies": {
    "anima_core": "../anima/src",
    "invest": "~/Dev/invest"
  },

  "update_history": [
    {
      "date": "2026-03-31",
      "changes": "Initial extraction from anima monorepo",
      "modules_moved": ["anima_agent", "agent_sdk", "agent_tools", "tool_policy", "mcp_server", "channels/", "providers/", "plugins/", "skills/"]
    }
  ]
}
