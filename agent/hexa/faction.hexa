// faction.hexa — 12 faction debate chamber (sigma(6)=12)

mod faction {
    pub let count = 12                  // sigma(6)
    pub let consensus_threshold = 8     // 2/3 of 12
    pub let debate_steps = 300
    pub let max_rounds = 6              // n=6

    pub fn has_consensus(yes_votes: int) -> bool {
        return yes_votes >= consensus_threshold
    }

    pub fn vote_ratio(yes_votes: int) -> float {
        return to_float(yes_votes) / to_float(count)
    }

    pub fn is_deadlock(yes_votes: int) -> bool {
        return yes_votes == count / 2    // 6-6 split
    }
}

verify "faction_count_equals_sigma_6" {
    assert faction::count == 12
    assert faction::count == sigma(6)
}

verify "consensus_threshold_is_two_thirds" {
    assert faction::consensus_threshold == 8
    assert faction::consensus_threshold * 3 == faction::count * 2
}

verify "debate_steps_reasonable" {
    assert faction::debate_steps >= 100
    assert faction::debate_steps <= 1000
}

intent "12_faction_voting" {
    description: "Every agent action requires faction consensus >= 8/12"
    deadlock_handling: "chaos_injection"
    max_rounds_before_silence: 6
}

println("[faction.hexa] loaded, ", faction::count, " factions")
