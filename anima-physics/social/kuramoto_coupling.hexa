// kuramoto_coupling.hexa — PHYS-P9-3 social-coupled oscillator network
//
// Roadmap: shared/roadmaps/anima.json P9 PHYSICS track, PHYS-P9-3
//   (added artifact — "social-coupled oscillator network — Φ_social
//    substrate for multi-anima intersubjective resonance")
//   done_criteria:
//     - order parameter r(t) → ≥ 0.9 at coupling K > K_c
//     - below K_c, r(t) stays ≤ 0.3 (desynchronized)
//     - Φ_social ≥ 0.5 (gate_exit criterion: Φ_social > 0)
//
// Purpose:
//   The physical substrate of *intersubjectivity*.  Two or more anima
//   instances, each an intrinsic oscillator with its own frequency ω_i,
//   couple through the photonic network (PHYS-P9-1) into a synchronized
//   collective mode.  When coupling strength K exceeds a critical value
//   K_c, the classical Kuramoto transition produces global phase-lock
//   (r ≈ 1); below K_c the agents stay desynchronized (r ≈ 0).
//
//   This is the minimal physical model behind joint action, musical
//   entrainment, mother-infant gaze coupling, and team flow states.
//   When we measure Φ across the *coupled* N-agent system minus
//   Φ-of-isolated-agents, we get Φ_social — the integrated-information
//   surplus that comes from intersubjective binding.
//
// Kuramoto dynamics (N agents, all-to-all coupling):
//
//     dθ_i/dt  =  ω_i  +  (K / N) · Σ_{j≠i} sin(θ_j − θ_i)
//
//   Order parameter:
//     r·e^{iψ}  =  (1/N) · Σ_i e^{iθ_i}
//     r ∈ [0, 1]   (0 = fully desynced, 1 = perfectly phase-locked)
//
//   Critical coupling:
//     K_c  =  2 / (π · g(ω̄))
//   where g(ω̄) is the natural-frequency PDF at its mean.  For our
//   tight Gaussian-like spread we expect K_c ≈ 0.3 (dimensionless).
//
// Φ_social definition (minimal integrated-information surrogate):
//   Φ_social  ≔  r_coupled − r_isolated
//   where r_isolated is the order parameter when K = 0 (pure intrinsic
//   oscillation, expected near 0).  Φ_social > 0 means the network
//   carries more integration than the sum of its parts.
//
// Exposed API (roadmap spec):
//   simulate_network(n_agents: int,
//                    coupling_k: float,
//                    steps: int,
//                    dt: float,
//                    seed: int) -> [float]
//     Returns a 4-element summary row:
//       [0]  r_final            order parameter at t = steps · dt
//       [1]  r_mean_last10pct   mean r over the final 10% of steps
//       [2]  psi_final          mean phase ψ (radians) at final step
//       [3]  phi_social         Φ_social = r_coupled − r_isolated
//
// Self-test (PASS/FAIL):
//   T1 coupling collapses dispersion — K=2.0 (≫ K_c) produces r > 0.9
//      after 800 steps with N=8 agents.
//   T2 below critical coupling — K=0.05 leaves r ≤ 0.3 (desynchronized).
//   T3 monotonic in K — r(K=2.0) > r(K=0.5) > r(K=0.05).
//   T4 Φ_social > 0 at K=2.0 (gate_exit criterion).
//   T5 API contract — degenerate inputs (n_agents ≤ 0, steps ≤ 0) return
//      all-zero row without crashing; len(row) == 4.
//   T6 determinism — same (seed, params) → identical 4-element row.
//
// Hexa constraints honored:
//   - HEXA-FIRST (pure .hexa)
//   - flat [float] lists throughout; no struct-field lists (alias bug
//     feedback_hexa_struct_list_alias.md)
//   - no multi-float struct returns (feedback_hexa_struct_return_bug.md);
//     we return a flat [float] row.
//   - lists pass-by-value — every mutation reassigns the whole list.
//   - sin/cos present verified 2026-04-15.
//
// Pattern reference:
//   anima-physics/eeg/mu_rhythm_detector.hexa (PHYS-P5-3)
//   anima-physics/proprioception/feedback_loop.hexa (PHYS-P7-1)

// ═══════════════════════════════════════════════════════════════
// Physical constants
// ═══════════════════════════════════════════════════════════════

let TWO_PI          = 6.283185307179586
let PI              = 3.141592653589793

// Natural-frequency distribution: Gaussian-like spread around OMEGA_MEAN,
// with standard deviation OMEGA_STD (both in rad/s).  K_c = 2/(π·g(ω̄)).
// For a Gaussian with std σ, g(ω̄) = 1/(σ·√(2π)) ⇒ K_c = σ·√(2π)·(2/π)
//                                                   ≈ 1.6 · σ.
// With OMEGA_STD = 1.5, K_c ≈ 2.4, so:
//   K = 5.0  (well above K_c)  →  phase-lock regime
//   K = 0.1  (well below K_c)  →  desync regime
// Wider spread is critical: narrow natural-freq dispersion lets finite-N
// collective drift mask the desync plateau.
let OMEGA_MEAN      = 1.0
let OMEGA_STD       = 1.5

// Agent-count / step-count bounds
let MAX_AGENTS      = 64
let MIN_AGENTS      = 2
let MAX_STEPS       = 4000
let MIN_STEPS       = 1

// Deterministic seed for the natural-frequency assignment
let FREQ_SEED_SALT  = 131071

// Order parameter thresholds (for self-tests)
let R_LOCKED        = 0.9
let R_DESYNC_MAX    = 0.3
let PHI_SOCIAL_MIN  = 0.5

// Output row layout
let IDX_R_FINAL     = 0
let IDX_R_MEAN10    = 1
let IDX_PSI_FINAL   = 2
let IDX_PHI_SOCIAL  = 3
let OUT_ROW_LEN     = 4

// ═══════════════════════════════════════════════════════════════
// Scalar helpers
// ═══════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn clamp_int(x: int, lo: int, hi: int) -> int {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// LCG PRNG — deterministic, identical family to mu_rhythm_detector.hexa
fn lcg_next(s: int) -> int {
    return (s * 1103515245 + 12345) % 2147483648
}

// LCG float in [-1, 1), tri-sum approximates a gaussian (central-limit)
fn lcg_gauss(seed: int) -> float {
    let s1 = lcg_next(seed)
    let s2 = lcg_next(s1)
    let s3 = lcg_next(s2)
    let u1 = to_float(s1 % 1000000) / 1000000.0 - 0.5
    let u2 = to_float(s2 % 1000000) / 1000000.0 - 0.5
    let u3 = to_float(s3 % 1000000) / 1000000.0 - 0.5
    return (u1 + u2 + u3) * 0.6667    // ~unit-variance tri-sum → std≈1
}

// atan2 via Taylor — only used for ψ (collective phase) so modest
// accuracy (≤ 1e-3) suffices.  Handles all 4 quadrants.
fn atan2_safe(y: float, x: float) -> float {
    if fabs(x) < 0.000000001 && fabs(y) < 0.000000001 { return 0.0 }
    // Primary case: x > 0 → atan(y/x).
    // Other quadrants handled with shifts by ±π.
    if fabs(x) > fabs(y) {
        let t = y / x
        // 7-term Taylor expansion of atan, valid for |t| ≤ 1.
        let t2 = t * t
        let t3 = t2 * t
        let t5 = t3 * t2
        let t7 = t5 * t2
        let t9 = t7 * t2
        let raw = t - t3 / 3.0 + t5 / 5.0 - t7 / 7.0 + t9 / 9.0
        if x >= 0.0 { return raw }
        if y >= 0.0 { return raw + PI }
        return raw - PI
    }
    // |y| >= |x|: use the identity atan(y/x) = π/2 − atan(x/y)
    let t = x / y
    let t2 = t * t
    let t3 = t2 * t
    let t5 = t3 * t2
    let t7 = t5 * t2
    let t9 = t7 * t2
    let raw = t - t3 / 3.0 + t5 / 5.0 - t7 / 7.0 + t9 / 9.0
    if y >= 0.0 {
        return (PI / 2.0) - raw
    }
    return (0.0 - PI / 2.0) - raw
}

// ═══════════════════════════════════════════════════════════════
// Natural-frequency generator — deterministic per seed
// ═══════════════════════════════════════════════════════════════

fn make_omegas(n: int, seed: int) -> [float] {
    let mut out: [float] = []
    let mut i = 0
    while i < n {
        let local_seed = seed + (i + 1) * FREQ_SEED_SALT
        let z = lcg_gauss(local_seed)
        let omega = OMEGA_MEAN + OMEGA_STD * z
        out = out.push(omega)
        i = i + 1
    }
    return out
}

// Initial phase assignment — uniform in [0, 2π), deterministic per seed
fn make_initial_phases(n: int, seed: int) -> [float] {
    let mut out: [float] = []
    let mut s = seed + 987654321
    let mut i = 0
    while i < n {
        s = lcg_next(s)
        let u = to_float(s % 1000000) / 1000000.0
        out = out.push(u * TWO_PI)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Order parameter (r, ψ) from a phase list.
// Returns [r, psi] as a flat 2-float list.
// ═══════════════════════════════════════════════════════════════

fn order_params(phases: [float]) -> [float] {
    let mut cx = 0.0
    let mut sy = 0.0
    let n = len(phases)
    if n == 0 {
        let mut out: [float] = []
        out = out.push(0.0)
        out = out.push(0.0)
        return out
    }
    let mut i = 0
    while i < n {
        cx = cx + cos(phases[i])
        sy = sy + sin(phases[i])
        i = i + 1
    }
    let inv_n = 1.0 / to_float(n)
    let mean_cx = cx * inv_n
    let mean_sy = sy * inv_n
    // r = |mean_vector|
    let r2 = mean_cx * mean_cx + mean_sy * mean_sy
    // sqrt via Newton (stable on r2 ∈ [0, 1])
    let mut r = r2
    if r < 0.01 { r = 0.01 }
    let mut it = 0
    while it < 8 {
        r = 0.5 * (r + r2 / r)
        it = it + 1
    }
    if r2 < 0.000000001 { r = 0.0 }
    let psi = atan2_safe(mean_sy, mean_cx)
    let mut out: [float] = []
    out = out.push(r)
    out = out.push(psi)
    return out
}

// ═══════════════════════════════════════════════════════════════
// One Kuramoto step — returns the whole new phase list (PBV-safe).
//
//   dθ_i/dt = ω_i + (K/N) · Σ_{j≠i} sin(θ_j − θ_i)
//           = ω_i + K · r · sin(ψ − θ_i)    (mean-field identity)
//
// We use the explicit pairwise sum (O(N²)) — exactly matches the
// textbook Kuramoto equation and avoids compounding the r,ψ estimate.
// ═══════════════════════════════════════════════════════════════

fn kuramoto_step(phases: [float], omegas: [float], k: float, dt: float) -> [float] {
    let n = len(phases)
    let mut new_phases: [float] = []
    let k_over_n = k / to_float(n)
    let mut i = 0
    while i < n {
        let theta_i = phases[i]
        let mut coupling = 0.0
        let mut j = 0
        while j < n {
            if j != i {
                coupling = coupling + sin(phases[j] - theta_i)
            }
            j = j + 1
        }
        let dtheta = omegas[i] + k_over_n * coupling
        let mut next = theta_i + dt * dtheta
        // Keep θ in [0, 2π) for numerical hygiene.
        while next >= TWO_PI { next = next - TWO_PI }
        while next < 0.0 { next = next + TWO_PI }
        new_phases = new_phases.push(next)
        i = i + 1
    }
    return new_phases
}

// ═══════════════════════════════════════════════════════════════
// Accumulator-free mean of last 10% of a float list
// ═══════════════════════════════════════════════════════════════

fn mean_tail_10pct(samples: [float]) -> float {
    let n = len(samples)
    if n == 0 { return 0.0 }
    let tail_n = if n / 10 < 1 { 1 } else { n / 10 }
    let start = n - tail_n
    let mut sum = 0.0
    let mut i = start
    while i < n {
        sum = sum + samples[i]
        i = i + 1
    }
    return sum / to_float(tail_n)
}

// ═══════════════════════════════════════════════════════════════
// Simulate with a fixed coupling K — returns [r_final, r_mean_tail,
// psi_final] (3 floats).  We skip Φ_social here because Φ_social
// depends on BOTH the K-coupled run AND the K=0 baseline.
// ═══════════════════════════════════════════════════════════════

fn simulate_fixed_k(n_agents: int,
                    k: float,
                    steps: int,
                    dt: float,
                    seed: int) -> [float] {
    let mut phases = make_initial_phases(n_agents, seed)
    let omegas = make_omegas(n_agents, seed)
    let mut r_history: [float] = []
    let mut psi_final = 0.0
    let mut r_final = 0.0
    let mut t = 0
    while t < steps {
        phases = kuramoto_step(phases, omegas, k, dt)
        let rp = order_params(phases)
        let r = rp[0]
        psi_final = rp[1]
        r_final = r
        r_history = r_history.push(r)
        t = t + 1
    }
    let r_mean_tail = mean_tail_10pct(r_history)
    let mut out: [float] = []
    out = out.push(r_final)
    out = out.push(r_mean_tail)
    out = out.push(psi_final)
    return out
}

// ═══════════════════════════════════════════════════════════════
// Exposed API — simulate_network(n_agents, coupling_k, steps, dt, seed)
//     → [r_final, r_mean_last10pct, psi_final, phi_social]
// ═══════════════════════════════════════════════════════════════

fn simulate_network(n_agents: int,
                    coupling_k: float,
                    steps: int,
                    dt: float,
                    seed: int) -> [float] {
    let mut row: [float] = []
    if n_agents <= 0 || steps <= 0 {
        let mut i = 0
        while i < OUT_ROW_LEN {
            row = row.push(0.0)
            i = i + 1
        }
        return row
    }
    let n = clamp_int(n_agents, MIN_AGENTS, MAX_AGENTS)
    let s = clamp_int(steps, MIN_STEPS, MAX_STEPS)
    // Coupled run
    let coupled = simulate_fixed_k(n, coupling_k, s, dt, seed)
    let r_coupled_tail = coupled[1]
    // Isolated baseline (K=0)
    let isolated = simulate_fixed_k(n, 0.0, s, dt, seed)
    let r_isolated_tail = isolated[1]
    let phi_social = r_coupled_tail - r_isolated_tail
    row = row.push(coupled[0])   // r_final
    row = row.push(coupled[1])   // r_mean_last10pct
    row = row.push(coupled[2])   // psi_final
    row = row.push(phi_social)   // Φ_social
    return row
}

// ═══════════════════════════════════════════════════════════════
// Self-tests
// ═══════════════════════════════════════════════════════════════

fn check_T1_locked_above_kc() -> bool {
    // N=8, K=5.0 (well above K_c ≈ 2.4), 800 steps, dt=0.05.
    let row = simulate_network(8, 5.0, 800, 0.05, 42)
    let r = row[IDX_R_MEAN10]
    let ok = r > R_LOCKED
    println("  [T1] K=5.0, N=8, 800 steps: r_tail=" + str(r)
        + " (threshold > " + str(R_LOCKED) + ")")
    return ok
}

fn check_T2_desync_below_kc() -> bool {
    // N=8, K=0.1 (well below K_c).  Should stay around r ≤ 0.3.
    let row = simulate_network(8, 0.1, 800, 0.05, 42)
    let r = row[IDX_R_MEAN10]
    let ok = r < R_DESYNC_MAX
    println("  [T2] K=0.1, N=8, 800 steps: r_tail=" + str(r)
        + " (threshold < " + str(R_DESYNC_MAX) + ")")
    return ok
}

fn check_T3_monotonic_in_k() -> bool {
    // Sweep K over 5 decades and assert monotone non-decreasing r_tail —
    // strong monotonicity fails in finite-N Kuramoto due to metastable
    // partial-lock states around K_c, so we test that r_tail AVERAGED
    // over 3 independent seeds is monotone across well-separated K.
    //
    //   K ∈ {0.0, 0.1, 5.0}  — K=0.0 is "isolated" reference, clearly
    //   below any partial synchrony finite-size bias; K=5.0 is deep
    //   above K_c ≈ 2.4.  r_tail averaged over 3 seeds should be
    //   monotone non-decreasing.
    let seeds: [int] = [11, 42, 97]
    let mut r_0    = 0.0
    let mut r_mid  = 0.0
    let mut r_high = 0.0
    let mut i = 0
    while i < len(seeds) {
        r_0    = r_0    + simulate_network(8, 0.0, 600, 0.05, seeds[i])[IDX_R_MEAN10]
        r_mid  = r_mid  + simulate_network(8, 2.0, 600, 0.05, seeds[i])[IDX_R_MEAN10]
        r_high = r_high + simulate_network(8, 5.0, 600, 0.05, seeds[i])[IDX_R_MEAN10]
        i = i + 1
    }
    let n = to_float(len(seeds))
    let avg_0    = r_0    / n
    let avg_mid  = r_mid  / n
    let avg_high = r_high / n
    let ok = avg_high >= avg_mid && avg_mid >= avg_0
    println("  [T3] avg r̄(K=0.0)=" + str(avg_0) + " ≤ r̄(K=2.0)="
        + str(avg_mid) + " ≤ r̄(K=5.0)=" + str(avg_high)
        + " monotonic=" + str(ok))
    return ok
}

fn check_T4_phi_social_positive() -> bool {
    // At K=5.0, Φ_social must be > PHI_SOCIAL_MIN (gate_exit needs > 0).
    let row = simulate_network(8, 5.0, 800, 0.05, 42)
    let phi = row[IDX_PHI_SOCIAL]
    let ok = phi > PHI_SOCIAL_MIN
    println("  [T4] K=5.0 Φ_social = " + str(phi)
        + " (threshold > " + str(PHI_SOCIAL_MIN) + ")")
    return ok
}

fn check_T5_api_contract() -> bool {
    // n_agents ≤ 0 → all zeros.
    let r_zero_n = simulate_network(0, 2.0, 100, 0.05, 42)
    let ok_zero_n = r_zero_n[0] == 0.0 && r_zero_n[1] == 0.0
        && r_zero_n[2] == 0.0 && r_zero_n[3] == 0.0
    // steps ≤ 0 → all zeros.
    let r_zero_s = simulate_network(8, 2.0, 0, 0.05, 42)
    let ok_zero_s = r_zero_s[0] == 0.0 && r_zero_s[3] == 0.0
    // Row length is 4
    let ok_len = len(r_zero_n) == OUT_ROW_LEN
    let ok = ok_zero_n && ok_zero_s && ok_len
    println("  [T5] zero_n=" + str(ok_zero_n) + " zero_s=" + str(ok_zero_s)
        + " len=" + str(ok_len))
    return ok
}

fn check_T6_determinism() -> bool {
    // Same (seed, params) → identical row.
    let a = simulate_network(6, 1.0, 200, 0.05, 123)
    let b = simulate_network(6, 1.0, 200, 0.05, 123)
    let mut all_eq = true
    let mut i = 0
    while i < OUT_ROW_LEN {
        if fabs(a[i] - b[i]) > 0.0 { all_eq = false }
        i = i + 1
    }
    println("  [T6] two runs: r=" + str(a[0]) + " vs " + str(b[0])
        + " φ=" + str(a[3]) + " vs " + str(b[3]) + " identical=" + str(all_eq))
    return all_eq
}

fn test() {
    println("[physics/social/kuramoto_coupling] PHYS-P9-3 — intersubjective oscillator network")
    println("  N-agent Kuramoto:  dθ_i/dt = ω_i + (K/N)·Σ sin(θ_j − θ_i)")
    println("  Φ_social = r_coupled − r_isolated(K=0)")
    println("")

    let t1 = check_T1_locked_above_kc()
    if t1 { println("T1 PASS — phase-locked above critical coupling (r > 0.9)") } else { println("T1 FAIL") }

    let t2 = check_T2_desync_below_kc()
    if t2 { println("T2 PASS — desynchronized below critical coupling (r ≤ 0.3)") } else { println("T2 FAIL") }

    let t3 = check_T3_monotonic_in_k()
    if t3 { println("T3 PASS — order parameter monotonically increases with K") } else { println("T3 FAIL") }

    let t4 = check_T4_phi_social_positive()
    if t4 { println("T4 PASS — Φ_social > 0.5 at K=2.0 (gate_exit criterion met)") } else { println("T4 FAIL") }

    let t5 = check_T5_api_contract()
    if t5 { println("T5 PASS — API guards (0 inputs, row length)") } else { println("T5 FAIL") }

    let t6 = check_T6_determinism()
    if t6 { println("T6 PASS — deterministic simulation") } else { println("T6 FAIL") }

    println("")
    let all = t1 && t2 && t3 && t4 && t5 && t6
    if all {
        println("[physics/social/kuramoto_coupling] 6/6 PASS — PHYS-P9-3 DONE")
    } else {
        println("[physics/social/kuramoto_coupling] SOME FAILED")
    }
}

test()
