// sleep_stage_detector.hexa — PHYS-P13-2 EEG sleep stage detection
//
// Roadmap: shared/roadmaps/anima.json P13 PHYSICS track, PHYS-P13-2
//   "EEG 수면 단계 감지 (K-complex / spindle)"
//
// Purpose:
//   Classify EEG signal segments into sleep stages:
//     stage 0 — Awake   (alpha/beta, moderate amplitude)
//     stage 1 — SWS     (delta waves, high amplitude)
//     stage 2 — REM     (theta + desynchronized, low amplitude)
//
// Pipeline:
//   1. Synthetic EEG generator — deterministic LCG noise
//        Awake: 15 Hz + noise (beta/alpha band)
//        SWS:   2 Hz + noise (delta band), high amplitude
//        REM:   6 Hz + noise (theta band), low amplitude
//
//   2. Feature extraction per segment window (N samples):
//        f1: Zero-crossing rate (ZCR) — proxy for dominant frequency
//        f2: Root-mean-square amplitude (RMS)
//
//   3. Classification rules:
//        Awake: ZCR > threshold_high, moderate amplitude
//        SWS:   ZCR < threshold_low, high amplitude (delta waves)
//        REM:   medium ZCR, low amplitude (theta + desynchronized)
//
// Exposed API:
//   detect_sleep_stage(segment: [float]) -> int
//     Returns 0 (awake), 1 (SWS), or 2 (REM).
//
// Self-test (PASS/FAIL):
//   T1 Awake signal  -> stage 0
//   T2 SWS signal    -> stage 1
//   T3 REM signal    -> stage 2
//   T4 Accuracy > 0.8 on 30 mixed trials (10 per stage)
//   T5 Determinism   — two calls on same input give same output
//
// Hexa constraints honored:
//   - HEXA-FIRST (pure .hexa)
//   - lists pass-by-value; push returns new list
//   - no && chains in compound booleans (nested if)
//   - single-line returns
//   - sin/cos for synthesis

// =====================================================================
// Constants
// =====================================================================

let PI        = 3.141592653589793
let TWO_PI    = 6.283185307179586
let FS_HZ     = 256.0          // sampling rate (Hz)

// Synthesis frequencies
let F_AWAKE   = 15.0           // awake: beta/alpha band
let F_SWS     = 2.0            // SWS: delta band
let F_REM     = 6.0            // REM: theta band

// Synthesis amplitudes
let A_AWAKE   = 1.0            // moderate amplitude
let A_SWS     = 3.0            // high amplitude (delta waves)
let A_REM     = 0.4            // low amplitude (desynchronized)

// Noise amplitude
let A_NOISE   = 0.15

// Window length — 2 seconds at 256 Hz
let WIN_N     = 512

// LCG seed
let NOISE_SEED = 20260415

// Classification thresholds
//   ZCR is normalized: crossings / (N-1).
//   At fs=256, a pure f Hz tone produces ~2f zero-crossings per second
//   so normalized ZCR ~ 2f/fs.
//     Awake 15 Hz: ZCR ~ 30/256 ~ 0.117
//     SWS   2 Hz:  ZCR ~ 4/256  ~ 0.016
//     REM   6 Hz:  ZCR ~ 12/256 ~ 0.047
//   Thresholds chosen to separate the three bands:
let ZCR_HIGH  = 0.075          // above this => awake
let ZCR_LOW   = 0.030          // below this => SWS candidate
// Between ZCR_LOW and ZCR_HIGH => REM or SWS, disambiguate by amplitude
let RMS_HIGH  = 1.5            // above this + low ZCR => SWS

// =====================================================================
// Scalar helpers
// =====================================================================

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    // Newton-Raphson, 20 iterations
    let mut g = x
    if x > 1.0 { g = x / 2.0 }
    let mut i = 0
    while i < 20 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

// LCG PRNG — identical to anima-physics/eeg/mu_rhythm_detector.hexa
fn lcg_next(s: int) -> int {
    return (s * 1103515245 + 12345) % 2147483648
}

fn lcg_unit_signed(s: int) -> float {
    let x = lcg_next(s)
    let u = to_float(x % 1000000) / 1000000.0
    return u - 0.5
}

// =====================================================================
// Feature extraction
// =====================================================================

// Zero-crossing rate: count of sign changes / (N-1).
// A zero-crossing occurs when consecutive samples have opposite signs.
fn compute_zcr(segment: [float]) -> float {
    let n = len(segment)
    if n < 2 { return 0.0 }
    let mut crossings = 0
    let mut i = 1
    while i < n {
        let prev = segment[i - 1]
        let curr = segment[i]
        // Detect sign change (nested if to avoid && chain)
        if prev >= 0.0 {
            if curr < 0.0 {
                crossings = crossings + 1
            }
        } else {
            if curr >= 0.0 {
                crossings = crossings + 1
            }
        }
        i = i + 1
    }
    return to_float(crossings) / to_float(n - 1)
}

// Root-mean-square amplitude
fn compute_rms(segment: [float]) -> float {
    let n = len(segment)
    if n < 1 { return 0.0 }
    let mut sum_sq = 0.0
    let mut i = 0
    while i < n {
        let x = segment[i]
        sum_sq = sum_sq + x * x
        i = i + 1
    }
    return sqrt_approx(sum_sq / to_float(n))
}

// =====================================================================
// Exposed API — detect_sleep_stage(segment) -> int
//
//   Returns: 0 = awake, 1 = SWS, 2 = REM
//
//   Decision tree:
//     if ZCR > ZCR_HIGH => awake (high frequency content)
//     else if ZCR < ZCR_LOW:
//       if RMS > RMS_HIGH => SWS (low freq, high amp delta)
//       else              => REM (low freq, low amp)
//     else (mid ZCR):
//       if RMS > RMS_HIGH => SWS
//       else              => REM (theta range, low amp)
// =====================================================================

fn detect_sleep_stage(segment: [float]) -> int {
    let n = len(segment)
    if n < 4 { return 0 }
    let zcr = compute_zcr(segment)
    let rms = compute_rms(segment)
    // High ZCR => awake
    if zcr > ZCR_HIGH { return 0 }
    // Low ZCR => SWS or REM depending on amplitude
    if zcr < ZCR_LOW {
        if rms > RMS_HIGH { return 1 }
        return 2
    }
    // Mid ZCR (between low and high) => REM or SWS by amplitude
    if rms > RMS_HIGH { return 1 }
    return 2
}

// =====================================================================
// Synthetic EEG generators
//
//   Each stage produces a characteristic waveform:
//     Awake: fast oscillation (15 Hz), moderate amplitude
//     SWS:   slow oscillation (2 Hz), high amplitude (delta)
//     REM:   medium oscillation (6 Hz), low amplitude
// =====================================================================

fn synth_awake(n: int, seed: int) -> [float] {
    let mut out: [float] = []
    let mut s = seed
    let mut i = 0
    while i < n {
        let t = to_float(i) / FS_HZ
        let sig = A_AWAKE * sin(TWO_PI * F_AWAKE * t)
        s = lcg_next(s)
        let noise = A_NOISE * lcg_unit_signed(s)
        out = out.push(sig + noise)
        i = i + 1
    }
    return out
}

fn synth_sws(n: int, seed: int) -> [float] {
    let mut out: [float] = []
    let mut s = seed
    let mut i = 0
    while i < n {
        let t = to_float(i) / FS_HZ
        let sig = A_SWS * sin(TWO_PI * F_SWS * t)
        s = lcg_next(s)
        let noise = A_NOISE * lcg_unit_signed(s)
        out = out.push(sig + noise)
        i = i + 1
    }
    return out
}

fn synth_rem(n: int, seed: int) -> [float] {
    let mut out: [float] = []
    let mut s = seed
    let mut i = 0
    while i < n {
        let t = to_float(i) / FS_HZ
        let sig = A_REM * sin(TWO_PI * F_REM * t)
        s = lcg_next(s)
        let noise = A_NOISE * lcg_unit_signed(s)
        out = out.push(sig + noise)
        i = i + 1
    }
    return out
}

// =====================================================================
// Self-tests
// =====================================================================

fn check_T1_awake() -> bool {
    let seg = synth_awake(WIN_N, NOISE_SEED)
    let stage = detect_sleep_stage(seg)
    let zcr = compute_zcr(seg)
    let rms = compute_rms(seg)
    let ok = stage == 0
    println("  [T1] awake signal: stage=" + str(stage) + " zcr=" + str(zcr) + " rms=" + str(rms))
    return ok
}

fn check_T2_sws() -> bool {
    let seg = synth_sws(WIN_N, NOISE_SEED)
    let stage = detect_sleep_stage(seg)
    let zcr = compute_zcr(seg)
    let rms = compute_rms(seg)
    let ok = stage == 1
    println("  [T2] SWS signal: stage=" + str(stage) + " zcr=" + str(zcr) + " rms=" + str(rms))
    return ok
}

fn check_T3_rem() -> bool {
    let seg = synth_rem(WIN_N, NOISE_SEED)
    let stage = detect_sleep_stage(seg)
    let zcr = compute_zcr(seg)
    let rms = compute_rms(seg)
    let ok = stage == 2
    println("  [T3] REM signal: stage=" + str(stage) + " zcr=" + str(zcr) + " rms=" + str(rms))
    return ok
}

fn check_T4_accuracy() -> bool {
    // 30 trials: 10 awake + 10 SWS + 10 REM with varied seeds.
    // Accuracy must be > 0.8 (> 24/30 correct).
    let mut correct = 0
    let mut total = 0
    // 10 awake trials
    let mut i = 0
    while i < 10 {
        let seg = synth_awake(WIN_N, NOISE_SEED + i * 137)
        let stage = detect_sleep_stage(seg)
        if stage == 0 { correct = correct + 1 }
        total = total + 1
        i = i + 1
    }
    // 10 SWS trials
    let mut j = 0
    while j < 10 {
        let seg = synth_sws(WIN_N, NOISE_SEED + 10000 + j * 137)
        let stage = detect_sleep_stage(seg)
        if stage == 1 { correct = correct + 1 }
        total = total + 1
        j = j + 1
    }
    // 10 REM trials
    let mut k = 0
    while k < 10 {
        let seg = synth_rem(WIN_N, NOISE_SEED + 20000 + k * 137)
        let stage = detect_sleep_stage(seg)
        if stage == 2 { correct = correct + 1 }
        total = total + 1
        k = k + 1
    }
    let acc = to_float(correct) / to_float(total)
    let ok = acc > 0.8
    println("  [T4] accuracy: " + str(correct) + "/" + str(total) + " = " + str(acc) + " (threshold > 0.8)")
    return ok
}

fn check_T5_determinism() -> bool {
    let seg = synth_sws(WIN_N, NOISE_SEED + 99)
    let s1 = detect_sleep_stage(seg)
    let s2 = detect_sleep_stage(seg)
    let ok = s1 == s2
    println("  [T5] two calls: s1=" + str(s1) + " s2=" + str(s2))
    return ok
}

fn test() {
    println("[eeg/sleep_stage_detector] PHYS-P13-2 — EEG sleep stage detection (K-complex/spindle)")
    println("  synth: 256 Hz, awake=15Hz, SWS=2Hz(high amp), REM=6Hz(low amp)")
    println("  classifier: ZCR + RMS thresholds, 3 stages (0=awake, 1=SWS, 2=REM)")
    println("")

    let t1 = check_T1_awake()
    if t1 { println("T1 PASS — awake signal classified as stage 0") } else { println("T1 FAIL") }

    let t2 = check_T2_sws()
    if t2 { println("T2 PASS — SWS signal classified as stage 1") } else { println("T2 FAIL") }

    let t3 = check_T3_rem()
    if t3 { println("T3 PASS — REM signal classified as stage 2") } else { println("T3 FAIL") }

    let t4 = check_T4_accuracy()
    if t4 { println("T4 PASS — accuracy > 0.8 on 30 mixed trials") } else { println("T4 FAIL") }

    let t5 = check_T5_determinism()
    if t5 { println("T5 PASS — deterministic classification") } else { println("T5 FAIL") }

    println("")
    let mut pass_count = 0
    if t1 { pass_count = pass_count + 1 }
    if t2 { pass_count = pass_count + 1 }
    if t3 { pass_count = pass_count + 1 }
    if t4 { pass_count = pass_count + 1 }
    if t5 { pass_count = pass_count + 1 }

    let all_pass = pass_count == 5
    if all_pass {
        println("[eeg/sleep_stage_detector] 5/5 PASS — PHYS-P13-2 DONE (accuracy > 0.8)")
    } else {
        println("[eeg/sleep_stage_detector] " + str(pass_count) + "/5 PASS — SOME FAILED")
    }
}

test()
