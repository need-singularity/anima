// ════════════════════════════════════════════════════════════════════════════
//  anima-physics/tool/mk_xii_substrate_witness_ledger_aggregator_v3.hexa
//  @resolver-bypass(reason="aggregator runs locally on Mac; reads marker.json files via host fs — does not need docker container semantics")
//
//  v2 → v3 DELTA
//    + 12th manifest row: trapped_ion / poc_trapped_ion_braket_ionq
//      (AWS Braket IonQ Forte 1, gate-based, 4-qubit GHZ).  10th distinct
//      substrate platform.  superconducting tier marker now carries
//      DEPRECATED verdict (Rigetti retired upstream 2026-04-27); G5 LIVE
//      promotion comes from analog (QuEra) + trapped_ion (IonQ Forte 1)
//      LIVE_PASS markers, not from superconducting.
//    + TARGET_SUBSTRATES extended: 9 → 10 (trapped_ion appended).
//    = aggregator logic identical to v2; only manifest + targets grow.
//      Forward-compat env vars (LEDGER_VERSION, LEDGER_OUT,
//      LEDGER_SUPERSEDES_OVERRIDE, MARKER_OUT) preserved.
//    = v2 (witness_ledger_v2.json) PRESERVED, NOT modified — supersession
//      ≠ deletion (memory feedback_silent_land_marker_protocol).
//
//  PURPOSE
//    Mk.XII INTEGRATION multi-substrate witness ledger v3 aggregator.
//    Forward-compatible successor to v1 (witness_ledger_v1.json,
//    fingerprint=470781997, body_sha=264f5cf7…).  Absorbs 3 race-landed
//    sibling markers (cmos / fpga / arduino) + introduces G5
//    LIVE_HW_WITNESS_RATE gate measuring fraction of markers that called
//    real cloud hardware (currently expected = 0/11; auto-promotes upon
//    IBM Q signup → Phase 2 PASS).
//
//    Mk.XII INTEGRATION coordinate
//      .own #2 triad (b) PC empirical-max axis = substrate-multiplicity
//      ledger.  Cross-substrate Φ comparison NOT valid (axes differ:
//      quantum entanglement entropy ≠ photonic Fock entropy ≠ memristor
//      hysteresis area ≠ cmos period jitter ≠ fpga LFSR Shannon H ≠
//      arduino NE555 duty drift).  Ledger aggregates COVER-COUNT +
//      per-substrate gate verdicts + LIVE-hardware witness rate only.
//
//  5 frozen ledger gates (v1 G1-G4 + new G5)
//    G1 LEDGER_COVERAGE          n_landed_full + n_prep_only ≥ 6 / 9
//    G2 LEDGER_HONESTY           every marker entry preserved (no
//                                cherry-pick, all 6 verdict tiers kept)
//    G3 LEDGER_BYTE_IDENTICAL    aggregator 2-run sha256 identical
//                                (timestamp excluded)
//    G4 LEDGER_FINGERPRINT_FNV32 chained FNV-32 over 11-input sha sequence
//                                (distinct hash space from v1's 8-input
//                                fingerprint = 470781997)
//    G5 LIVE_HW_WITNESS_RATE     measure-only (no threshold).  Counts
//                                markers whose verdict matches strict
//                                live-hardware patterns:
//                                  ^PASS_REAL_QUANTUM_HARDWARE$
//                                  ^LIVE_PASS$
//                                  ^PHASE2_PASS_REAL.*$
//                                Currently expected 0/11.  IBM Q signup
//                                or AWS Braket Rigetti credential add →
//                                automatic 1+/11 on next aggregation.
//
//  USAGE
//    HEXA_RESOLVER_NO_REROUTE=1 hexa run \
//        anima-physics/tool/mk_xii_substrate_witness_ledger_aggregator_v2.hexa
//
//  ENV
//    LEDGER_OUT          output JSON path
//                        (default: state/v10_anima_physics_cloud_facade/
//                                  integration_ledger/witness_ledger_<VERSION>.json
//                         where <VERSION> = LEDGER_VERSION env (default v2))
//    LEDGER_BASE_DIR     base dir of substrate markers
//                        (default: state/v10_anima_physics_cloud_facade)
//    LEDGER_TARGET_TOTAL expected distinct substrate count
//                        (default: 9 = quantum/photonic/neuromorphic/
//                         superconducting/analog/memristor/cmos/fpga/arduino;
//                         quantum has 2 markers POC+Phase2, integration is
//                         a meta-row not counted in the 9-target enum)
//    LEDGER_VERSION              ledger schema version label (default "v2";
//                                emit body field ledger_version, sidecar
//                                ledger_version, fnv32_chained_<VERSION> tag)
//    LEDGER_CYCLE_ID_OVERRIDE    cycle_id override (default
//                                "mk_xii_substrate_witness_ledger_<VERSION>")
//    LEDGER_SUPERSEDES_OVERRIDE  supersedes string (default v1 chain;
//                                v3+ caller MUST set this to "v2 (...)")
//    MARKER_OUT                  optional path; when non-empty, emits a
//                                top-level marker file mirroring marker_v2
//                                schema with G5-tier verdict
//                                (LEDGER_LIVE_INITIAL/BROAD/FULL when
//                                ledger_version != "v2" and n_live > 0;
//                                LEDGER_LANDED_<VERSION> otherwise)
//
//  v2 BYTE-IDENTICAL GUARANTEE
//    All env vars above default-fallback to v2 frozen values.  Invocation
//    with NO env vars produces byte-identical witness_ledger_v2.json body
//    (sha256 df545c5e15404539cea6f1b61c8d46565089f6d266277234b50a124d066e49ba).
//    Setting LEDGER_VERSION=v3 (+ LEDGER_OUT, MARKER_OUT, LEDGER_SUPERSEDES_OVERRIDE)
//    activates v3 mode WITHOUT modifying v2 artifacts (supersession ≠ deletion).
//
//  RAW
//    raw#9 · hexa-only strict · raw#37 .py / .sh FORBIDDEN · LLM=none
//    GPU=none · deterministic · aggregator-only (no probe, no measurement,
//    no network)
//
//  v1 → v2 DIFF
//    + 3 manifest rows: cmos / fpga / arduino (marker.json)
//    + G5 LIVE_HW_WITNESS_RATE (measurement-only, no threshold)
//    + schema fields: ledger_version=v2, supersedes, n_marker_total,
//      live_hw_witness{}, phi_proxy_cross_comparable=false (explicit),
//      fnv32_chained_v2 (renamed for distinct hash space tag),
//      ledger_fingerprint_sha256 (canonical body sha exposed in JSON)
//    = v1 (witness_ledger_v1.json) PRESERVED, NOT modified
// ════════════════════════════════════════════════════════════════════════════

// ─── v3 schema defaults (env-overridable) ─────────────────────────────────
let DEFAULT_LEDGER_VERSION     = "v3"
let DEFAULT_LEDGER_SUPERSEDES  = "v2 (witness_ledger_v2.json, fingerprint+body_sha preserved at integration_ledger/witness_ledger_v2.json.meta) — supersession ≠ deletion"
let DEFAULT_LEDGER_CYCLE_PREFIX= "mk_xii_substrate_witness_ledger_"
let DEFAULT_BASE_DIR           = "state/v10_anima_physics_cloud_facade"
let DEFAULT_OUT_DIR            = "state/v10_anima_physics_cloud_facade/integration_ledger"
let DEFAULT_TARGET_TOTAL_X1000 = 10000  // 10 distinct substrate platforms × 1000 fixed-pt

// G1 LEDGER_COVERAGE: ≥ 6 / 10 (×1000 fixed-point => 6000) — same absolute
// threshold as v2 (6 covered substrates min); denominator grew 9→10 with
// trapped_ion add but min coverage count unchanged for v2 → v3 continuity.
let G1_COVERAGE_MIN_X1000      = 6000

// FNV-32 constants (G4 fingerprint)
let M32                = 4294967296
let FNV_PRIME          = 16777619
let FNV_OFFSET_BASIS   = 2166136261

// 11 marker manifest — substrate / marker-relpath / group_substrate_alias
// Order is deterministic + frozen (G3 byte-identical guarantee).
//
// Each entry: [substrate, sub_dir, group_substrate_alias]
//   group_substrate_alias = canonical substrate key for "by_substrate"
//   grouping (quantum POC + ibmq_runtime both group under "quantum" but
//   emit 2 entries; integration = meta-row not in 9-target enum).
//
// v1 → v2: 3 rows appended at tail (cmos/fpga/arduino) preserving v1
// determinism; v2 fingerprint (FNV) is distinct from v1 by construction.
// v2 → v3: 1 row appended at tail (trapped_ion) preserving v2 row order;
// v3 fingerprint distinct from v2 by construction.
let MANIFEST_SUBSTRATE = [
    "quantum",        "poc_quantum_qiskit_aer",            "quantum",
    "quantum",        "phase2_ibmq_runtime",               "quantum",
    "photonic",       "poc_photonic_strawberryfields",     "photonic",
    "neuromorphic",   "poc_neuromorphic_akida_cloud",      "neuromorphic",
    "superconducting","poc_superconducting_braket_rigetti","superconducting",
    "analog",         "poc_analog_braket_quera",           "analog",
    "memristor",      "poc_memristor_local_ngspice",       "memristor",
    "integration",    "integration_physics_hexa",          "integration",
    "cmos",           "poc_cmos_local_ngspice",            "cmos",
    "fpga",           "poc_fpga_local_verilator",          "fpga",
    "arduino",        "poc_arduino_local_ngspice",         "arduino",
    "trapped_ion",    "poc_trapped_ion_braket_ionq",       "trapped_ion"
]
let MANIFEST_ROW_STRIDE = 3
// 10-target enumeration (v3: trapped_ion added as 10th distinct platform)
let TARGET_SUBSTRATES = [
    "quantum","photonic","neuromorphic","superconducting","analog",
    "memristor","cmos","fpga","arduino","trapped_ion"
]

// ─── helpers ───────────────────────────────────────────────────────────────
fn _str(x) {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn fexists(p) {
    return _str(exec("test -f " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn dexists(p) {
    return _str(exec("test -d " + p + " && echo 1 || echo 0")).trim() == "1"
}

fn ensure_dir(d) {
    if !dexists(d) { let _ = exec("mkdir -p " + d) }
}

fn now_utc() {
    return _str(exec("date -u +%FT%TZ")).trim()
}

fn sha256_file(p) {
    if !fexists(p) { return "" }
    return _str(exec("shasum -a 256 " + p + " 2>/dev/null | awk '{print $1}'")).trim()
}

fn atomic_write(path, body) {
    let pid = _str(exec("printf %s $$")).trim()
    let tmp = path + ".tmp." + pid
    write_file(tmp, body)
    let _ = exec("mv -f " + tmp + " " + path)
}

fn jq_get(marker_path, expr) {
    if !fexists(marker_path) { return "" }
    return _str(exec("jq -r '" + expr + " // \"\"' " + marker_path + " 2>/dev/null")).trim()
}

fn json_escape(s) {
    let a = _str(s).replace("\\", "\\\\")
    let b = a.replace("\"", "\\\"")
    let c = b.replace("\n", "\\n")
    return c
}

// ─── FNV-32 chained fingerprint (G4) ───────────────────────────────────────
fn fnv_step(h, byte) {
    let mut x = (h + byte) % M32
    if x < 0 { x = x + M32 }
    x = (x * FNV_PRIME) % M32
    if x < 0 { x = x + M32 }
    return x
}

fn fnv_mix_str(seed, s) {
    let mut h = seed
    let n = _str(s).len()
    let mut i = 0
    while i < n {
        let ch = _str(s).substring(i, i + 1)
        let b = ascii_byte(ch)
        h = fnv_step(h, b)
        i = i + 1
    }
    return h
}

fn ascii_byte(ch) {
    if ch == "0" { return 48 }
    if ch == "1" { return 49 }
    if ch == "2" { return 50 }
    if ch == "3" { return 51 }
    if ch == "4" { return 52 }
    if ch == "5" { return 53 }
    if ch == "6" { return 54 }
    if ch == "7" { return 55 }
    if ch == "8" { return 56 }
    if ch == "9" { return 57 }
    if ch == "a" { return 97 }
    if ch == "b" { return 98 }
    if ch == "c" { return 99 }
    if ch == "d" { return 100 }
    if ch == "e" { return 101 }
    if ch == "f" { return 102 }
    return 0
}

fn fnv_chained_fingerprint(sha_list) {
    let mut h = FNV_OFFSET_BASIS
    let mut i = 0
    while i < len(sha_list) {
        h = fnv_mix_str(h, _str(sha_list[i]))
        i = i + 1
    }
    return h
}

// ─── verdict classification ────────────────────────────────────────────────
// Returns: 0 = full-pass, 1 = prep-only/degraded, 2 = unknown
fn classify_verdict(verdict) {
    let v = _str(verdict)
    if v == "PASS"                                 { return 0 }
    if v == "INTEGRATED_PASS"                      { return 0 }
    if v == "PASS_DEGRADED_SDK_FALLBACK"           { return 0 }
    if v == "LIVE_PASS"                            { return 0 }
    if v == "PASS_REAL_QUANTUM_HARDWARE"           { return 0 }
    if v == "PHASE2_DEGRADED_NO_TOKEN"             { return 1 }
    if v == "PREP_READY_AWAITING_USER_SIGNUP"      { return 1 }
    if v == "PREP_NO_CREDS_DEGRADED"               { return 1 }
    if v == "PREP_DRY_RUN_PASS"                    { return 1 }
    if v == "PREP_DEPRECATED_RIGETTI_RETIRED"      { return 1 }
    return 2
}

// ─── G5 LIVE_HW_WITNESS strict pattern matcher ─────────────────────────────
// Strict equality / prefix patterns to avoid false-positive substring match
// (e.g., "PHASE2_DEGRADED_NO_TOKEN" must NOT match "PASS").
//
//   live=true iff verdict ∈ {
//       "PASS_REAL_QUANTUM_HARDWARE",
//       "LIVE_PASS",
//       starts_with "PHASE2_PASS_REAL"
//   }
//
// Returns: 1 if live, 0 otherwise.
fn classify_live_hw(verdict) {
    let v = _str(verdict)
    if v == "PASS_REAL_QUANTUM_HARDWARE" { return 1 }
    if v == "LIVE_PASS"                  { return 1 }
    // strict prefix "PHASE2_PASS_REAL"
    if v.len() >= 16 {
        let pre = v.substring(0, 16)
        if pre == "PHASE2_PASS_REAL" { return 1 }
    }
    return 0
}

// ─── per-marker entry build ────────────────────────────────────────────────
struct MarkerEntry {
    substrate:                 string,
    sub_dir:                   string,
    marker_path:               string,
    verdict:                   string,
    verdict_class:             int,    // 0 full-pass, 1 prep-only, 2 unknown
    backend_name:              string,
    gate_pass_count:           int,
    gate_total:                int,
    g1_pass:                   int,
    g2_pass:                   int,
    g3_pass:                   int,
    g4_pass:                   int,
    byte_identical_sha:        string,
    byte_identical_match:      string,
    user_action_required:      string,
    marker_sha256:             string,
    live_hw_called:            int     // 0/1, G5 input
}

fn build_marker_entry(substrate, sub_dir, base_dir) {
    let path = base_dir + "/" + sub_dir + "/marker.json"
    let mut e = MarkerEntry {
        substrate:               substrate,
        sub_dir:                 sub_dir,
        marker_path:             path,
        verdict:                 "MISSING",
        verdict_class:           2,
        backend_name:            "",
        gate_pass_count:         0,
        gate_total:              4,
        g1_pass:                 0,
        g2_pass:                 0,
        g3_pass:                 0,
        g4_pass:                 0,
        byte_identical_sha:      "",
        byte_identical_match:    "",
        user_action_required:    "",
        marker_sha256:           "",
        live_hw_called:          0
    }
    if !fexists(path) { return e }

    e.verdict       = jq_get(path, ".verdict")
    e.verdict_class = classify_verdict(e.verdict)
    e.backend_name  = jq_get(path, ".backend_name")
    e.live_hw_called = classify_live_hw(e.verdict)

    // Gates: ibmq_runtime uses G3="NOT_APPLICABLE_REAL_HW" (string, not bool).
    // integration_physics_hexa uses G1_BACKWARD_COMPAT etc named keys.
    let mut g_cnt = [0, 0, 0, 0]
    let g1 = jq_get(path, ".gates.G1")
    let g2 = jq_get(path, ".gates.G2")
    let g3 = jq_get(path, ".gates.G3")
    let g4 = jq_get(path, ".gates.G4")
    let g1b = jq_get(path, ".gates.G1_BACKWARD_COMPAT")
    let g2b = jq_get(path, ".gates.G2_DISPATCH_ROUTES")
    let g3b = jq_get(path, ".gates.G3_OPERATIONAL_CALL_SITE")
    let g4b = jq_get(path, ".gates.G4_ENUM_CANONICAL")

    if g1 == "true" { g_cnt[0] = 1 } else { if g1b == "true" { g_cnt[0] = 1 } }
    if g2 == "true" { g_cnt[1] = 1 } else { if g2b == "true" { g_cnt[1] = 1 } }
    if g3 == "true" { g_cnt[2] = 1 } else { if g3b == "true" { g_cnt[2] = 1 } }
    if g4 == "true" { g_cnt[3] = 1 } else { if g4b == "true" { g_cnt[3] = 1 } }

    e.g1_pass = g_cnt[0]
    e.g2_pass = g_cnt[1]
    e.g3_pass = g_cnt[2]
    e.g4_pass = g_cnt[3]
    e.gate_pass_count = g_cnt[0] + g_cnt[1] + g_cnt[2] + g_cnt[3]

    e.byte_identical_sha   = jq_get(path, ".byte_identical_run1_sha")
    e.byte_identical_match = jq_get(path, ".byte_identical_match")
    e.user_action_required = jq_get(path, ".user_action_required")
    e.marker_sha256        = sha256_file(path)
    return e
}

// ─── main ──────────────────────────────────────────────────────────────────
@manual_main
fn main() {
    let mut argv = []
    let base_dir       = if env("LEDGER_BASE_DIR") != "" { _str(env("LEDGER_BASE_DIR")) } else { DEFAULT_BASE_DIR }
    let ledger_version = if env("LEDGER_VERSION")  != "" { _str(env("LEDGER_VERSION"))  } else { DEFAULT_LEDGER_VERSION }
    let default_out    = DEFAULT_OUT_DIR + "/witness_ledger_" + ledger_version + ".json"
    let out_path       = if env("LEDGER_OUT")      != "" { _str(env("LEDGER_OUT"))      } else { default_out }
    let ledger_supers  = if env("LEDGER_SUPERSEDES_OVERRIDE") != "" { _str(env("LEDGER_SUPERSEDES_OVERRIDE")) } else { DEFAULT_LEDGER_SUPERSEDES }
    let ledger_cycle   = if env("LEDGER_CYCLE_ID_OVERRIDE")   != "" { _str(env("LEDGER_CYCLE_ID_OVERRIDE"))   } else { DEFAULT_LEDGER_CYCLE_PREFIX + ledger_version }
    let marker_out     = _str(env("MARKER_OUT"))
    let target_tot = 10

    // ─── Step A: build entries (deterministic order) ──────────────────────
    let n_rows = len(MANIFEST_SUBSTRATE) / MANIFEST_ROW_STRIDE
    let mut entries = []
    let mut sha_chain = []
    let mut i = 0
    while i < n_rows {
        let substrate = _str(MANIFEST_SUBSTRATE[i * MANIFEST_ROW_STRIDE + 0])
        let sub_dir   = _str(MANIFEST_SUBSTRATE[i * MANIFEST_ROW_STRIDE + 1])
        let _alias    = _str(MANIFEST_SUBSTRATE[i * MANIFEST_ROW_STRIDE + 2])
        let e = build_marker_entry(substrate, sub_dir, base_dir)
        entries = entries + [e]
        if e.marker_sha256 != "" {
            sha_chain = sha_chain + [e.marker_sha256]
        }
        i = i + 1
    }

    // ─── Step B: aggregate counts (substrate-grouped) ─────────────────────
    let mut subs_full = []
    let mut subs_prep = []
    let mut subs_seen = []
    let mut g1_pass_n = 0
    let mut g2_pass_n = 0
    let mut g3_pass_n = 0
    let mut g4_pass_n = 0
    let mut total_entries_with_gates = 0
    let mut user_actions = []
    let mut n_live_hw = 0
    let mut backend_chip_ids = []

    let mut k = 0
    while k < len(entries) {
        let e = entries[k]
        if e.verdict != "MISSING" {
            let mut already_seen = false
            let mut s = 0
            while s < len(subs_seen) {
                if _str(subs_seen[s]) == e.substrate { already_seen = true }
                s = s + 1
            }
            if !already_seen { subs_seen = subs_seen + [e.substrate] }

            if e.verdict_class == 0 {
                let mut already_full = false
                let mut s2 = 0
                while s2 < len(subs_full) {
                    if _str(subs_full[s2]) == e.substrate { already_full = true }
                    s2 = s2 + 1
                }
                if !already_full { subs_full = subs_full + [e.substrate] }
            }
            if e.verdict_class == 1 {
                let mut already_prep = false
                let mut s3 = 0
                while s3 < len(subs_prep) {
                    if _str(subs_prep[s3]) == e.substrate { already_prep = true }
                    s3 = s3 + 1
                }
                if !already_prep { subs_prep = subs_prep + [e.substrate] }
            }
            g1_pass_n = g1_pass_n + e.g1_pass
            g2_pass_n = g2_pass_n + e.g2_pass
            g3_pass_n = g3_pass_n + e.g3_pass
            g4_pass_n = g4_pass_n + e.g4_pass
            total_entries_with_gates = total_entries_with_gates + 1

            if e.user_action_required != "" {
                user_actions = user_actions + [e.user_action_required]
            }
            if e.live_hw_called == 1 {
                n_live_hw = n_live_hw + 1
                if e.backend_name != "" {
                    backend_chip_ids = backend_chip_ids + [e.backend_name]
                }
            }
        }
        k = k + 1
    }

    // Subtract substrate from prep if it also has full-pass entry
    let mut subs_prep_only = []
    let mut p = 0
    while p < len(subs_prep) {
        let sp = _str(subs_prep[p])
        let mut in_full = false
        let mut q = 0
        while q < len(subs_full) {
            if _str(subs_full[q]) == sp { in_full = true }
            q = q + 1
        }
        if !in_full { subs_prep_only = subs_prep_only + [sp] }
        p = p + 1
    }

    // Filter target-9 enum (integration is meta-row, not in 9-target)
    let mut subs_full_target = []
    let mut tf = 0
    while tf < len(subs_full) {
        let sf = _str(subs_full[tf])
        let mut in_target = false
        let mut tt = 0
        while tt < len(TARGET_SUBSTRATES) {
            if _str(TARGET_SUBSTRATES[tt]) == sf { in_target = true }
            tt = tt + 1
        }
        if in_target { subs_full_target = subs_full_target + [sf] }
        tf = tf + 1
    }

    let n_landed_full = len(subs_full_target)
    let n_prep_only   = len(subs_prep_only)
    let n_missing     = target_tot - n_landed_full - n_prep_only
    let n_covered     = n_landed_full + n_prep_only
    let n_marker_total = total_entries_with_gates  // 11 expected

    // ─── Step C: ledger gates ─────────────────────────────────────────────
    let g1_coverage_pass = (n_covered * 1000) >= G1_COVERAGE_MIN_X1000
    let g2_honesty_pass = true   // every manifest row entry preserved

    // G4 FNV chained fingerprint (over 11-input sha sequence)
    let fnv_h_v2 = fnv_chained_fingerprint(sha_chain)

    // G5 LIVE_HW_WITNESS_RATE (measure-only, no threshold)
    let denom_live = if n_marker_total == 0 { 1 } else { n_marker_total }
    let live_rate_x1000 = (n_live_hw * 1000) / denom_live
    let n_simulator_or_surrogate = n_marker_total - n_live_hw

    // ─── Step D: aggregate gate rates (×1000) ─────────────────────────────
    let denom = if total_entries_with_gates == 0 { 1 } else { total_entries_with_gates }
    let g1_rate_x1000 = (g1_pass_n * 1000) / denom
    let g2_rate_x1000 = (g2_pass_n * 1000) / denom
    let g3_rate_x1000 = (g3_pass_n * 1000) / denom
    let g4_rate_x1000 = (g4_pass_n * 1000) / denom

    // ─── Step E: emit JSON (timestamp-free body for sha) ──────────────────
    ensure_dir(_str(exec("dirname " + out_path + " 2>/dev/null")).trim())

    let mut body = "{\n"
    body = body + "  \"ledger_version\": \"" + ledger_version + "\",\n"
    body = body + "  \"supersedes\": \"" + json_escape(ledger_supers) + "\",\n"
    body = body + "  \"cycle_id\": \"" + ledger_cycle + "\",\n"
    body = body + "  \"n_substrate_total\": " + str(target_tot) + ",\n"
    body = body + "  \"n_marker_total\": " + str(n_marker_total) + ",\n"
    body = body + "  \"n_substrate_landed_full_pass\": " + str(n_landed_full) + ",\n"
    body = body + "  \"n_substrate_prep_only\": " + str(n_prep_only) + ",\n"
    body = body + "  \"n_substrate_missing\": " + str(n_missing) + ",\n"
    body = body + "  \"n_substrate_covered\": " + str(n_covered) + ",\n"
    body = body + "  \"phi_proxy_cross_comparable\": false,\n"

    // by_substrate array
    body = body + "  \"by_substrate\": [\n"
    let mut j = 0
    while j < len(entries) {
        let e = entries[j]
        body = body + "    {\n"
        body = body + "      \"substrate\": \""           + json_escape(e.substrate)            + "\",\n"
        body = body + "      \"sub_dir\": \""             + json_escape(e.sub_dir)              + "\",\n"
        body = body + "      \"verdict\": \""             + json_escape(e.verdict)              + "\",\n"
        body = body + "      \"verdict_class\": "         + str(e.verdict_class)                + ",\n"
        body = body + "      \"backend_name\": \""        + json_escape(e.backend_name)         + "\",\n"
        body = body + "      \"gate_pass_count\": "       + str(e.gate_pass_count)              + ",\n"
        body = body + "      \"gate_total\": "            + str(e.gate_total)                   + ",\n"
        body = body + "      \"g1_pass\": "               + str(e.g1_pass)                      + ",\n"
        body = body + "      \"g2_pass\": "               + str(e.g2_pass)                      + ",\n"
        body = body + "      \"g3_pass\": "               + str(e.g3_pass)                      + ",\n"
        body = body + "      \"g4_pass\": "               + str(e.g4_pass)                      + ",\n"
        body = body + "      \"live_hw_called\": "        + str(e.live_hw_called)               + ",\n"
        body = body + "      \"byte_identical_sha\": \""  + json_escape(e.byte_identical_sha)   + "\",\n"
        body = body + "      \"byte_identical_match\": \""+ json_escape(e.byte_identical_match) + "\",\n"
        body = body + "      \"user_action_required\": \""+ json_escape(e.user_action_required) + "\",\n"
        body = body + "      \"marker_path\": \""         + json_escape(e.marker_path)          + "\",\n"
        body = body + "      \"marker_sha256\": \""       + json_escape(e.marker_sha256)        + "\"\n"
        body = body + "    }"
        if j < len(entries) - 1 { body = body + "," }
        body = body + "\n"
        j = j + 1
    }
    body = body + "  ],\n"

    // aggregate gates (per-entry pass rate)
    body = body + "  \"aggregate_gates\": {\n"
    body = body + "    \"G1_positive_entropy_pass_rate_x1000\": " + str(g1_rate_x1000) + ",\n"
    body = body + "    \"G2_sign_flip_pass_rate_x1000\": "        + str(g2_rate_x1000) + ",\n"
    body = body + "    \"G3_byte_identical_pass_rate_x1000\": "   + str(g3_rate_x1000) + ",\n"
    body = body + "    \"G4_backend_contract_pass_rate_x1000\": " + str(g4_rate_x1000) + ",\n"
    body = body + "    \"denom_entries\": " + str(total_entries_with_gates) + "\n"
    body = body + "  },\n"

    // ledger gates (5 frozen)
    body = body + "  \"ledger_gates\": {\n"
    body = body + "    \"G1_LEDGER_COVERAGE\": "       + (if g1_coverage_pass { "true" } else { "false" }) + ",\n"
    body = body + "    \"G1_min_required_x1000\": "    + str(G1_COVERAGE_MIN_X1000) + ",\n"
    body = body + "    \"G1_actual_x1000\": "          + str(n_covered * 1000) + ",\n"
    body = body + "    \"G2_LEDGER_HONESTY\": "        + (if g2_honesty_pass { "true" } else { "false" }) + ",\n"
    body = body + "    \"G3_LEDGER_BYTE_IDENTICAL\": \"VERIFY_VIA_2_RUN\",\n"
    body = body + "    \"G4_LEDGER_FINGERPRINT_FNV32\": " + str(fnv_h_v2) + ",\n"
    body = body + "    \"G5_LIVE_HW_WITNESS_RATE\": \"MEASURE_ONLY_NO_THRESHOLD\",\n"
    body = body + "    \"G5_live_rate_x1000\": " + str(live_rate_x1000) + "\n"
    body = body + "  },\n"

    // live_hw_witness section
    body = body + "  \"live_hw_witness\": {\n"
    body = body + "    \"rate_x1000\": " + str(live_rate_x1000) + ",\n"
    body = body + "    \"n_live\": " + str(n_live_hw) + ",\n"
    body = body + "    \"n_simulator_or_surrogate\": " + str(n_simulator_or_surrogate) + ",\n"
    body = body + "    \"n_marker_total\": " + str(n_marker_total) + ",\n"
    body = body + "    \"strict_pattern_set\": [\"^PASS_REAL_QUANTUM_HARDWARE$\", \"^LIVE_PASS$\", \"^PHASE2_PASS_REAL.*$\"],\n"
    body = body + "    \"actual_backend_chip_ids\": [\n"
    let mut bc = 0
    while bc < len(backend_chip_ids) {
        body = body + "      \"" + json_escape(_str(backend_chip_ids[bc])) + "\""
        if bc < len(backend_chip_ids) - 1 { body = body + "," }
        body = body + "\n"
        bc = bc + 1
    }
    body = body + "    ],\n"
    body = body + "    \"auto_promotion_paths\": [\n"
    body = body + "      \"IBM Quantum signup + IBM_QUANTUM_TOKEN env → phase2_ibmq_runtime verdict shifts to PHASE2_PASS_REAL_<BACKEND> → live_rate 0/11 → 1/11 on next aggregation\",\n"
    body = body + "      \"AWS Braket creds + budget cap → poc_superconducting_braket_rigetti or poc_analog_braket_quera verdict shifts to LIVE_PASS → live_rate 0/11 → 1/11 or 2/11\",\n"
    body = body + "      \"BrainChip Akida Cloud signup + BRAINCHIP_AKIDA_TOKEN env → poc_neuromorphic_akida_cloud verdict shifts to LIVE_PASS → live_rate +1/11\"\n"
    body = body + "    ]\n"
    body = body + "  },\n"

    // user_action_pending
    body = body + "  \"user_action_pending\": [\n"
    let mut u = 0
    while u < len(user_actions) {
        body = body + "    \"" + json_escape(_str(user_actions[u])) + "\""
        if u < len(user_actions) - 1 { body = body + "," }
        body = body + "\n"
        u = u + 1
    }
    body = body + "  ],\n"

    // missing substrates list (target-9 minus seen)
    body = body + "  \"missing_substrates\": [\n"
    let mut m = 0
    let mut emitted = 0
    while m < len(TARGET_SUBSTRATES) {
        let target = _str(TARGET_SUBSTRATES[m])
        let mut found = false
        let mut s4 = 0
        while s4 < len(subs_seen) {
            if _str(subs_seen[s4]) == target { found = true }
            s4 = s4 + 1
        }
        if !found {
            if emitted > 0 { body = body + ",\n" }
            body = body + "    \"" + json_escape(target) + "\""
            emitted = emitted + 1
        }
        m = m + 1
    }
    if emitted > 0 { body = body + "\n" }
    body = body + "  ],\n"

    // raw10_honest_aggregate
    body = body + "  \"raw10_honest_aggregate\": [\n"
    body = body + "    \"v2 = aggregator only, fundamentally unchanged from v1 (3 marker rows + G5 measure gate added; substrate Φ axis still NOT cross-comparable)\",\n"
    body = body + "    \"phi_proxy_cross_comparable=false explicit: quantum entanglement entropy ≠ photonic Fock entropy ≠ memristor hysteresis area ≠ cmos period jitter ≠ fpga LFSR Shannon H ≠ arduino NE555 duty drift\",\n"
    body = body + "    \"verdict definitions span 6 tiers (PASS / INTEGRATED_PASS / PASS_DEGRADED_SDK_FALLBACK / PHASE2_DEGRADED_NO_TOKEN / PREP_READY_AWAITING_USER_SIGNUP / PREP_NO_CREDS_DEGRADED) — v2 preserves all (G2 honesty), no cherry-pick\",\n"
    body = body + "    \"v2 covers 11 markers across 9 distinct substrate platforms; v1 (8 markers / 6 platforms) PRESERVED, NOT modified — supersession ≠ deletion\",\n"
    body = body + "    \"G5 LIVE_HW_WITNESS_RATE = 0/11 expected at v2 land (all simulator/surrogate); strict pattern set guards against false-positive substring match (e.g., 'PHASE2_DEGRADED_NO_TOKEN' MUST NOT match 'PASS')\",\n"
    body = body + "    \"forward-compatible schema: v3+ auto-absorbs LIVE column when IBM Q / AWS Braket / Akida creds added; same aggregator re-run flips one or more verdicts → live_rate auto-promotes\",\n"
    body = body + "    \"Mk.XII INTEGRATION .own #2 (b) PC empirical-max axis = substrate-multiplicity, distinct from multi-EEG cohort axis\",\n"
    body = body + "    \"raw#37 .py / .sh helper count in v2 aggregator = 0 (strict raw#9 hexa-only); 7 sibling probe scripts under scripts/ are referenced honestly via marker outputs but not invoked by aggregator\"\n"
    body = body + "  ],\n"

    body = body + "  \"sha_chain_input_count\": " + str(len(sha_chain)) + ",\n"
    body = body + "  \"fnv32_chained_" + ledger_version + "\": " + str(fnv_h_v2) + ",\n"
    body = body + "  \"ledger_fingerprint_fnv32\": " + str(fnv_h_v2) + "\n"
    body = body + "}\n"

    // ─── Step F: compute ledger sha (timestamp-free), then atomic-write ──
    let pid = _str(exec("printf %s $$")).trim()
    let body_tmp = "/tmp/_ledger_v2_body_" + pid + ".json"
    write_file(body_tmp, body)
    let body_sha = _str(exec("shasum -a 256 " + body_tmp + " 2>/dev/null | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + body_tmp)

    atomic_write(out_path, body)

    // sidecar (timestamp + body sha)
    let sidecar_path = out_path + ".meta"
    let sidecar = "{\n" +
        "  \"ledger_path\": \"" + json_escape(out_path) + "\",\n" +
        "  \"ledger_version\": \"" + ledger_version + "\",\n" +
        "  \"supersedes\": \"" + json_escape(ledger_supers) + "\",\n" +
        "  \"body_sha256\": \"" + body_sha + "\",\n" +
        "  \"fnv32_chained_" + ledger_version + "\": " + str(fnv_h_v2) + ",\n" +
        "  \"emitted_at\": \"" + now_utc() + "\"\n" +
        "}\n"
    atomic_write(sidecar_path, sidecar)

    // ─── Step F2: G5-tier verdict (v3+ activates threshold; v2 measure-only) ──
    // L1 LIVE_INITIAL  : n_live ≥ 1
    // L2 LIVE_BROAD    : n_live ≥ 3
    // L3 LIVE_FULL     : n_live ≥ 9 (effective 4/4 cloud-eligible)
    // v2 default      : LEDGER_LANDED_V2 (no threshold)
    // version label uppercase (v2 → V2) for verdict suffix consistency
    let version_upper = "V" + ledger_version.substring(1, ledger_version.len())
    let mut tier_verdict = "LEDGER_LANDED_" + version_upper
    if !(g1_coverage_pass && g2_honesty_pass) {
        tier_verdict = "LEDGER_INCOMPLETE_" + version_upper
    }
    if ledger_version != "v2" {
        if n_live_hw >= 9 { tier_verdict = "LEDGER_LIVE_FULL" }
        else { if n_live_hw >= 3 { tier_verdict = "LEDGER_LIVE_BROAD" }
        else { if n_live_hw >= 1 { tier_verdict = "LEDGER_LIVE_INITIAL" }
        else { tier_verdict = "LEDGER_LIVE_NONE_DETECTED" } } }
    }

    // ─── Step F3: optional marker emission (when MARKER_OUT set) ──────────
    // Mirrors marker_v2.json schema; tier verdict from G5 thresholds.
    if marker_out != "" {
        let mut mb = "{\n"
        mb = mb + "  \"schema\": \"anima_physics/cloud_facade_integration_ledger/" + ledger_version + "\",\n"
        mb = mb + "  \"cycle\": \"" + ledger_cycle + "\",\n"
        mb = mb + "  \"supersedes\": \"" + json_escape(ledger_supers) + "\",\n"
        mb = mb + "  \"verdict\": \"" + tier_verdict + "\",\n"
        mb = mb + "  \"ledger_path\": \"" + json_escape(out_path) + "\",\n"
        mb = mb + "  \"ledger_sidecar_path\": \"" + json_escape(sidecar_path) + "\",\n"
        mb = mb + "  \"n_marker_total\": " + str(n_marker_total) + ",\n"
        mb = mb + "  \"n_substrate_total\": " + str(target_tot) + ",\n"
        mb = mb + "  \"n_substrate_landed_full_pass\": " + str(n_landed_full) + ",\n"
        mb = mb + "  \"n_substrate_prep_only\": " + str(n_prep_only) + ",\n"
        mb = mb + "  \"n_substrate_missing\": " + str(n_missing) + ",\n"
        mb = mb + "  \"n_substrate_covered\": " + str(n_covered) + ",\n"
        mb = mb + "  \"live_hw_witness_rate_x1000\": " + str(live_rate_x1000) + ",\n"
        mb = mb + "  \"n_live_hw\": " + str(n_live_hw) + ",\n"
        mb = mb + "  \"n_simulator_or_surrogate\": " + str(n_simulator_or_surrogate) + ",\n"
        mb = mb + "  \"fnv32_chained_" + ledger_version + "\": " + str(fnv_h_v2) + ",\n"
        mb = mb + "  \"ledger_fingerprint_sha256_" + ledger_version + "\": \"" + body_sha + "\",\n"
        mb = mb + "  \"gates\": {\n"
        mb = mb + "    \"G1_LEDGER_COVERAGE\": "       + (if g1_coverage_pass { "true" } else { "false" }) + ",\n"
        mb = mb + "    \"G2_LEDGER_HONESTY\": "        + (if g2_honesty_pass  { "true" } else { "false" }) + ",\n"
        mb = mb + "    \"G3_LEDGER_BYTE_IDENTICAL\": \"VERIFY_VIA_2_RUN\",\n"
        mb = mb + "    \"G4_LEDGER_FINGERPRINT_FNV32_EMITTED\": true,\n"
        mb = mb + "    \"G5_LIVE_HW_WITNESS_RATE_MEASURED\": true,\n"
        mb = mb + "    \"G5_threshold_active\": " + (if ledger_version != "v2" { "true" } else { "false" }) + ",\n"
        mb = mb + "    \"G5_tier_verdict\": \"" + tier_verdict + "\"\n"
        mb = mb + "  },\n"
        mb = mb + "  \"actual_backend_chip_ids\": [\n"
        let mut bm = 0
        while bm < len(backend_chip_ids) {
            mb = mb + "    \"" + json_escape(_str(backend_chip_ids[bm])) + "\""
            if bm < len(backend_chip_ids) - 1 { mb = mb + "," }
            mb = mb + "\n"
            bm = bm + 1
        }
        mb = mb + "  ],\n"
        mb = mb + "  \"phi_proxy_cross_comparable\": false,\n"
        mb = mb + "  \"raw37_py_used\": false,\n"
        mb = mb + "  \"raw37_sh_used\": false,\n"
        mb = mb + "  \"timestamp\": \"" + now_utc() + "\"\n"
        mb = mb + "}\n"
        ensure_dir(_str(exec("dirname " + marker_out + " 2>/dev/null")).trim())
        atomic_write(marker_out, mb)
    }

    // ─── Step G: print summary to stdout ─────────────────────────────────
    println("─── Mk.XII substrate witness ledger " + ledger_version + " aggregator ───")
    println("base_dir:                      " + base_dir)
    println("out_path:                      " + out_path)
    println("sidecar:                       " + sidecar_path)
    if marker_out != "" { println("marker_out:                    " + marker_out) }
    println("ledger_version:                " + ledger_version)
    println("cycle_id:                      " + ledger_cycle)
    println("supersedes:                    " + ledger_supers)
    println("n_entries (markers):           " + str(len(entries)))
    println("n_substrate_total:             " + str(target_tot))
    println("n_marker_total:                " + str(n_marker_total))
    println("n_substrate_landed_full:       " + str(n_landed_full))
    println("n_substrate_prep_only:         " + str(n_prep_only))
    println("n_substrate_missing:           " + str(n_missing))
    println("n_substrate_covered:           " + str(n_covered))
    println("G1_LEDGER_COVERAGE:            " + (if g1_coverage_pass { "PASS" } else { "FAIL" }))
    println("G2_LEDGER_HONESTY:             " + (if g2_honesty_pass  { "PASS" } else { "FAIL" }))
    println("G3_LEDGER_BYTE_IDENTICAL:      body_sha=" + body_sha + " (verify via 2-run)")
    println("G4_LEDGER_FINGERPRINT_FNV32:   " + str(fnv_h_v2))
    println("G5_LIVE_HW_WITNESS_RATE:       " + str(n_live_hw) + "/" + str(n_marker_total) + " (rate_x1000=" + str(live_rate_x1000) + ", measure-only)")
    println("G1_pass_rate_x1000:            " + str(g1_rate_x1000))
    println("G2_pass_rate_x1000:            " + str(g2_rate_x1000))
    println("G3_pass_rate_x1000:            " + str(g3_rate_x1000))
    println("G4_pass_rate_x1000:            " + str(g4_rate_x1000))
    println("phi_proxy_cross_comparable:    false (explicit)")
    let v2_diff_vs_v1 = if fnv_h_v2 == 470781997 { "FAIL_IDENTICAL" } else { "DISTINCT_OK" }
    println("v2_vs_v1_fingerprint_diff:     " + v2_diff_vs_v1 + " (v1=470781997, current=" + str(fnv_h_v2) + ")")
    println("VERDICT:                       " + tier_verdict)
}

main()
