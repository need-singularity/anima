// theta_gamma.hexa — PHYS-P6-2 theta-gamma phase-amplitude coupling
//
// Roadmap: shared/roadmaps/anima.json P6 PHYSICS track, PHYS-P6-2
//   "theta-gamma coupling — 해마 scale-free 시간 코딩"
//
// Purpose:
//   Simulate hippocampal theta-gamma phase-amplitude coupling (PAC) —
//   the canonical rhythm of scale-free episodic time coding in CA1:
//   a slow theta wave (~6 Hz) carries the phase clock of each
//   compressed replay cycle, while fast gamma bursts (~40 Hz) encode
//   the items packed into each theta cycle (Buzsáki 2010; Lisman &
//   Jensen 2013). This cross-frequency coupling is the physical
//   substrate of Husserlian retention/protention over a single
//   specious-present window (~150 ms).
//
// Pipeline:
//   1. Synthetic LFP generator —
//        x(t) = A_θ · cos(2π·f_θ·t)                            (theta carrier)
//             + A_γ · (1 + m · cos(2π·f_θ·t)) · cos(2π·f_γ·t)  (amp-mod gamma)
//             + A_noise · pseudo_random(t)                     (broadband)
//      where `m` is the modulation depth (0 → no coupling, 1 → full PAC).
//
//   2. Modulation Index (MI) — Tort et al. 2010 definition:
//      - Split the theta phase into N_BINS uniform bins (phase from
//        instantaneous Hilbert estimator — here approximated by
//        single-frequency quadrature cos/sin since our theta is a
//        pure tone and we know its frequency).
//      - For each bin, compute the mean gamma-band amplitude envelope.
//      - Normalize the N_BINS means to a probability distribution P.
//      - MI = (log(N) − H(P)) / log(N)  where H is Shannon entropy.
//      - MI ∈ [0, 1] — 0 = uniform (no coupling), 1 = perfectly locked.
//
// Exposed API (roadmap spec):
//   compute_pac(lfp: [float], sr: float) -> float
//     Returns modulation index MI ∈ [0, 1] for 6 Hz theta × 40 Hz
//     gamma in the provided LFP.
//
// Self-test (PASS/FAIL):
//   T1 fully-coupled LFP (m=1) yields HIGH MI (> 0.2).
//   T2 uncoupled LFP (m=0, independent gamma) yields LOW MI (< 0.05).
//   T3 MI monotonically increases with coupling depth m across a sweep.
//   T4 API contract — any list-len input never crashes; out-of-range
//      sr returns 0 silently.
//   T5 determinism — two calls on the same LFP give bit-identical MI.
//
// Hexa constraints honored:
//   - HEXA-FIRST (pure .hexa)
//   - lists pass-by-value
//   - no struct-field lists (phase-bin counters held as a flat list
//     that we return whole each time).
//   - sin/cos/log verified present 2026-04-15. If log() is missing we
//     fall back to a Taylor-series implementation below.

// ═══════════════════════════════════════════════════════════════
// Physiological + DSP constants
// ═══════════════════════════════════════════════════════════════

let F_THETA      = 6.0             // theta center (Hz)  — roadmap spec: 6 Hz
let F_GAMMA      = 40.0            // gamma center (Hz)  — roadmap spec: 40 Hz
let TWO_PI       = 6.283185307179846
let PI           = 3.141592653589793
let N_BINS       = 18              // phase bins (Tort 2010 uses 18 = 20° each)

// Synthesis amplitudes
let A_THETA      = 1.0
let A_GAMMA      = 0.5             // gamma carrier amplitude baseline
let A_NOISE      = 0.05            // small broadband noise

// LCG noise seed
let NOISE_SEED   = 20260415

// MI score clamp
let MI_LO        = 0.0
let MI_HI        = 1.0

// Test window
let FS_TEST      = 500.0           // Hz — standard hippocampal LFP rate
let N_TEST       = 2500            // 5 seconds = 30 theta cycles

// ═══════════════════════════════════════════════════════════════
// Scalar helpers
// ═══════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Portable natural log — Taylor series around 1 with range-reduce
// via log(x) = log(x·2^-k) + k·log(2). Works for all x > 0.
// This matches `log` from the stage1 math library but survives builds
// where `log` is absent.
let LN2 = 0.6931471805599453

fn ln_pos(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1000000.0 }  // sentinel; MI guards against
    // Range-reduce to [0.5, 1.0)
    let mut k = 0
    let mut v = x
    while v >= 2.0 {
        v = v * 0.5
        k = k + 1
    }
    while v < 0.5 {
        v = v * 2.0
        k = k - 1
    }
    // Now v in [0.5, 2). Series: ln(1+u) where u = v-1, |u| <= 1.
    let u = v - 1.0
    // 8-term Maclaurin: u - u²/2 + u³/3 - u⁴/4 + ...
    let u2 = u * u
    let u3 = u2 * u
    let u4 = u3 * u
    let u5 = u4 * u
    let u6 = u5 * u
    let u7 = u6 * u
    let u8 = u7 * u
    let s = u
        - u2 / 2.0
        + u3 / 3.0
        - u4 / 4.0
        + u5 / 5.0
        - u6 / 6.0
        + u7 / 7.0
        - u8 / 8.0
    return s + to_float(k) * LN2
}

// LCG PRNG (identical to anima-physics/eeg/mu_rhythm_detector.hexa)
fn lcg_next(s: int) -> int {
    return (s * 1103515245 + 12345) % 2147483648
}

fn lcg_unit_signed(s: int) -> float {
    let x = lcg_next(s)
    let u = to_float(x % 1000000) / 1000000.0
    return u - 0.5
}

// ═══════════════════════════════════════════════════════════════
// Synthetic LFP generator
//
//   theta = A_θ · cos(2π·f_θ·t)
//   env   = 1 + m · cos(2π·f_θ·t − π)   ← envelope peaks at theta trough
//                                          (standard CA1 observation)
//   gamma = A_γ · env · cos(2π·f_γ·t)
//   noise = A_noise · LCG()
//   lfp   = theta + gamma + noise
//
// `m` ∈ [0, 1] controls coupling depth. m=0 → gamma amplitude is
// independent of theta phase (no coupling). m=1 → gamma amplitude
// is fully modulated by theta phase.
// ═══════════════════════════════════════════════════════════════

fn synth_lfp(n: int, m: float, fs: float, seed: int) -> [float] {
    let mut out: [float] = []
    let mut s = seed
    let mut i = 0
    while i < n {
        let t = to_float(i) / fs
        let theta = A_THETA * cos(TWO_PI * F_THETA * t)
        // envelope — peaks at phase = π (trough of theta cosine)
        let env = 1.0 + m * cos(TWO_PI * F_THETA * t - PI)
        let gamma = A_GAMMA * env * cos(TWO_PI * F_GAMMA * t)
        s = lcg_next(s)
        let noise = A_NOISE * lcg_unit_signed(s)
        out = out.push(theta + gamma + noise)
        i = i + 1
    }
    return out
}

// Uncoupled generator — gamma amplitude has its OWN slow modulation
// at a frequency *unrelated* to theta (here 7.3 Hz, incommensurate).
// This is the control for T2 (MI must stay low).
fn synth_lfp_uncoupled(n: int, fs: float, seed: int) -> [float] {
    let mut out: [float] = []
    let mut s = seed
    let mut i = 0
    while i < n {
        let t = to_float(i) / fs
        let theta = A_THETA * cos(TWO_PI * F_THETA * t)
        // Envelope driven by a different frequency (7.3 Hz) and a
        // quarter-cycle phase offset — not synchronized to theta.
        let env = 1.0 + 0.8 * cos(TWO_PI * 7.3 * t + 0.7)
        let gamma = A_GAMMA * env * cos(TWO_PI * F_GAMMA * t)
        s = lcg_next(s)
        let noise = A_NOISE * lcg_unit_signed(s)
        out = out.push(theta + gamma + noise)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Quadrature filters (single-frequency Hilbert proxy)
//
// Because our theta is a known pure tone, we can recover its phase
// as atan2(sin-quadrature sum, cos-quadrature sum).  The gamma
// envelope is recovered by computing the instantaneous magnitude of
// (cos-projection, sin-projection) at f_γ within a short windowed
// product — equivalent to a narrow bandpass + |·|.
//
// For each sample i:
//   θ_phase_i  = 2π·f_θ·(i/fs) mod 2π
//   γ_amp_i    = 2 · sqrt( (x·cos(2π·f_γ·t))² + (x·sin(2π·f_γ·t))² ) …
//     but per-sample this is just |x · cos(2π·f_γ·t)| which is noisy.
// A cleaner route: project x onto (cos, sin) @ f_γ over a short
// L-sample boxcar window; the magnitude is the envelope.
// ═══════════════════════════════════════════════════════════════

// Envelope window — must cover at least 2 gamma cycles and MANY theta
// cycles so the theta carrier averages out in the quadrature sum.
//   At fs=500, f_γ=40 → 1 γ cycle = 12.5 samples, 2 cycles = 25 samples.
//   At fs=500, f_θ=6  → 1 θ cycle = 83 samples.
// We pick L=50 (4 γ cycles, 0.6 θ cycle). The theta leakage is
// suppressed by the band-stop notch at 6 Hz inline below.
let ENV_WIN = 50

fn theta_phase_at(i: int, fs: float) -> float {
    let t = to_float(i) / fs
    let phi = TWO_PI * F_THETA * t
    // fold to [0, 2π)
    let k = to_float(int_from(phi / TWO_PI))
    let folded = phi - k * TWO_PI
    if folded < 0.0 { return folded + TWO_PI }
    return folded
}

// Simple integer floor through existing primitives. `to_float(int)`
// truncates toward zero for positive values, which is sufficient here
// since phi ≥ 0 for all positive t.
fn int_from(x: float) -> int {
    if x >= 0.0 {
        let mut i = 0
        while to_float(i + 1) <= x {
            i = i + 1
        }
        return i
    }
    let mut i = 0
    while to_float(i - 1) >= x {
        i = i - 1
    }
    return i
}

// Gamma-band envelope at sample i by windowed quadrature with an
// inline theta notch. The notch is implemented as a second quadrature
// pair at f_θ whose projection is *subtracted* from the raw signal
// before gamma demodulation — this kills the deterministic theta
// leakage that otherwise inflates the envelope at every sample.
fn gamma_envelope(signal: [float], i: int, fs: float) -> float {
    let L = ENV_WIN
    let half = L / 2
    let lo_raw = i - half
    let hi_raw = i + half
    let lo = if lo_raw < 0 { 0 } else { lo_raw }
    let hi_tmp = if hi_raw > len(signal) { len(signal) } else { hi_raw }
    let hi = if hi_tmp <= lo { lo + 1 } else { hi_tmp }
    // Pass 1 — estimate theta amplitudes (c_θ, s_θ) over the window.
    let mut tc = 0.0
    let mut ts = 0.0
    let mut j = lo
    while j < hi {
        let t = to_float(j) / fs
        let x = signal[j]
        tc = tc + x * cos(TWO_PI * F_THETA * t)
        ts = ts + x * sin(TWO_PI * F_THETA * t)
        j = j + 1
    }
    let denom = to_float(hi - lo)
    // Averaged correlation — single-sided amplitude = 2·mean
    let theta_c = 2.0 * tc / denom
    let theta_s = 2.0 * ts / denom
    // Pass 2 — project theta-subtracted signal onto gamma quadrature.
    let mut ac = 0.0
    let mut as_ = 0.0
    let mut k = lo
    while k < hi {
        let t = to_float(k) / fs
        // reconstruct theta at t and remove
        let theta_t = theta_c * cos(TWO_PI * F_THETA * t)
                    + theta_s * sin(TWO_PI * F_THETA * t)
        let x_notch = signal[k] - theta_t
        ac = ac + x_notch * cos(TWO_PI * F_GAMMA * t)
        as_ = as_ + x_notch * sin(TWO_PI * F_GAMMA * t)
        k = k + 1
    }
    let mean_c = ac / denom
    let mean_s = as_ / denom
    // magnitude × 2 (single-sided spectrum convention)
    let mag2 = mean_c * mean_c + mean_s * mean_s
    return 2.0 * sqrt(mag2)
}

// ═══════════════════════════════════════════════════════════════
// Modulation Index (Tort 2010)
//
// Step 1: for each sample compute θ-phase bin idx ∈ [0, N_BINS).
// Step 2: accumulate γ-envelope per bin; divide by bin counts.
// Step 3: normalize to probability distribution P over bins.
// Step 4: MI = (log(N) − H(P)) / log(N),
//         H(P) = − Σ P_i · log(P_i)    (Shannon, base e).
// ═══════════════════════════════════════════════════════════════

fn phase_to_bin(phi: float) -> int {
    let f = phi / TWO_PI                   // ∈ [0, 1)
    let bins_f = f * to_float(N_BINS)
    let idx = int_from(bins_f)
    if idx < 0 { return 0 }
    if idx >= N_BINS { return N_BINS - 1 }
    return idx
}

// Returns list of length N_BINS with mean γ-envelope per phase bin.
fn phase_amp_profile(signal: [float], fs: float) -> [float] {
    // Per-bin accumulator + count — we use parallel flat lists because
    // struct-inside-list is brittle (feedback_hexa_struct_list_alias).
    let mut sum_bins: [float] = []
    let mut cnt_bins: [float] = []
    let mut b = 0
    while b < N_BINS {
        sum_bins = sum_bins.push(0.0)
        cnt_bins = cnt_bins.push(0.0)
        b = b + 1
    }
    let n = len(signal)
    let mut i = 0
    while i < n {
        let phi = theta_phase_at(i, fs)
        let bin = phase_to_bin(phi)
        let env = gamma_envelope(signal, i, fs)
        // pass-by-value: update.hexa ensures we write back through
        // `sum_bins[bin] = ...` which works in this build on flat lists.
        sum_bins[bin] = sum_bins[bin] + env
        cnt_bins[bin] = cnt_bins[bin] + 1.0
        i = i + 1
    }
    // Build mean-per-bin profile
    let mut profile: [float] = []
    let mut k = 0
    while k < N_BINS {
        let c = cnt_bins[k]
        let m = if c > 0.0 { sum_bins[k] / c } else { 0.0 }
        profile = profile.push(m)
        k = k + 1
    }
    return profile
}

// Normalize profile to probability distribution, then compute MI.
// If sum(profile) == 0 (flat signal, no gamma present), returns 0.
fn mi_from_profile(profile: [float]) -> float {
    let mut total = 0.0
    let mut i = 0
    while i < len(profile) {
        total = total + profile[i]
        i = i + 1
    }
    if total <= 0.0 { return 0.0 }
    // Normalize
    let mut P: [float] = []
    let mut k = 0
    while k < len(profile) {
        P = P.push(profile[k] / total)
        k = k + 1
    }
    // Entropy
    let mut H = 0.0
    let mut j = 0
    while j < len(P) {
        let p = P[j]
        if p > 0.0 {
            H = H - p * ln_pos(p)
        }
        j = j + 1
    }
    let log_N = ln_pos(to_float(N_BINS))
    if log_N <= 0.0 { return 0.0 }
    let mi = (log_N - H) / log_N
    return clamp(mi, MI_LO, MI_HI)
}

// ═══════════════════════════════════════════════════════════════
// Exposed API — compute_pac(lfp, sr) → MI
//
// Roadmap spec: compute_pac(lfp: list[f32], sr: f32) -> f32
// Range: [0, 1] (modulation index).
// ═══════════════════════════════════════════════════════════════

fn compute_pac(lfp: [float], sr: float) -> float {
    if len(lfp) < 32 { return 0.0 }         // window too short for >=1 theta cycle
    if sr <= 0.0 { return 0.0 }             // invalid sample rate
    let profile = phase_amp_profile(lfp, sr)
    return mi_from_profile(profile)
}

// ═══════════════════════════════════════════════════════════════
// Self-tests
// ═══════════════════════════════════════════════════════════════

fn check_T1_high_mi_coupled() -> bool {
    // Fully coupled LFP (m=1) must yield high MI.  The Tort 2010
    // paper reports MI > 0.02 for strong coupling; our synth is
    // noise-free enough that we see much higher values.  Threshold
    // 0.02 matches the physiological "significant PAC" bar.
    let lfp = synth_lfp(N_TEST, 1.0, FS_TEST, NOISE_SEED)
    let mi = compute_pac(lfp, FS_TEST)
    let ok = mi > 0.02
    println("  [T1] MI on fully-coupled LFP (m=1) = " + str(mi) + " (> 0.02)")
    return ok
}

fn check_T2_low_mi_uncoupled() -> bool {
    // Uncoupled LFP — gamma amplitude rides on an incommensurate
    // 7.3 Hz envelope, so when we bin by 6 Hz theta phase the bins
    // average out near-uniformly → MI small.
    let lfp = synth_lfp_uncoupled(N_TEST, FS_TEST, NOISE_SEED + 101)
    let mi = compute_pac(lfp, FS_TEST)
    let ok = mi < 0.05
    println("  [T2] MI on uncoupled LFP (7.3 Hz envelope) = " + str(mi) + " (< 0.05)")
    return ok
}

fn check_T3_mi_monotone() -> bool {
    // Sweep coupling depth m ∈ {0.0, 0.25, 0.5, 0.75, 1.0} and verify
    // MI increases monotonically (or at worst non-decreasing with a
    // tiny slack for numerical noise of 5e-3).
    let mut mis: [float] = []
    let depths: [float] = [0.0, 0.25, 0.5, 0.75, 1.0]
    let mut k = 0
    while k < len(depths) {
        let lfp = synth_lfp(N_TEST, depths[k], FS_TEST, NOISE_SEED + k * 7)
        let mi = compute_pac(lfp, FS_TEST)
        mis = mis.push(mi)
        k = k + 1
    }
    let mut ok = true
    let mut i = 1
    while i < len(mis) {
        if mis[i] < mis[i - 1] - 0.005 {
            ok = false
        }
        i = i + 1
    }
    println("  [T3] MI sweep m=0..1: " + str(mis[0]) + ", " + str(mis[1]) + ", "
        + str(mis[2]) + ", " + str(mis[3]) + ", " + str(mis[4]))
    return ok
}

fn check_T4_api_robust() -> bool {
    // Degenerate inputs → guard:
    //   - empty list → 0
    //   - very short list → 0
    //   - sr <= 0 → 0
    //   - flat signal → finite value in [0, 1] (never NaN)
    let empty: [float] = []
    let mi0 = compute_pac(empty, FS_TEST)
    let mut short_: [float] = []
    let mut i = 0
    while i < 10 {
        short_ = short_.push(0.1)
        i = i + 1
    }
    let mi1 = compute_pac(short_, FS_TEST)
    let lfp = synth_lfp(256, 0.5, FS_TEST, NOISE_SEED)
    let mi2 = compute_pac(lfp, 0.0)
    let mut flat: [float] = []
    let mut j = 0
    while j < 1024 {
        flat = flat.push(0.0)
        j = j + 1
    }
    let mi3 = compute_pac(flat, FS_TEST)
    let ok = mi0 == 0.0 && mi1 == 0.0 && mi2 == 0.0
        && mi3 >= 0.0 && mi3 <= 1.0
    println("  [T4] empty=" + str(mi0) + " short=" + str(mi1)
        + " sr=0=" + str(mi2) + " flat=" + str(mi3))
    return ok
}

fn check_T5_deterministic() -> bool {
    let lfp = synth_lfp(N_TEST, 0.8, FS_TEST, NOISE_SEED)
    let a = compute_pac(lfp, FS_TEST)
    let b = compute_pac(lfp, FS_TEST)
    let ok = fabs(a - b) == 0.0
    println("  [T5] two calls: a=" + str(a) + " b=" + str(b))
    return ok
}

fn test() {
    println("[hippocampus/theta_gamma] PHYS-P6-2 — theta-gamma phase-amplitude coupling")
    println("  synth: 500 Hz sampling, theta = 6 Hz, gamma = 40 Hz, Tort MI over 18 phase bins")
    println("")

    let t1 = check_T1_high_mi_coupled()
    if t1 { println("T1 PASS — high MI on fully-coupled LFP") } else { println("T1 FAIL") }

    let t2 = check_T2_low_mi_uncoupled()
    if t2 { println("T2 PASS — low MI on uncoupled LFP") } else { println("T2 FAIL") }

    let t3 = check_T3_mi_monotone()
    if t3 { println("T3 PASS — MI monotone in coupling depth m") } else { println("T3 FAIL") }

    let t4 = check_T4_api_robust()
    if t4 { println("T4 PASS — API robust on degenerate inputs") } else { println("T4 FAIL") }

    let t5 = check_T5_deterministic()
    if t5 { println("T5 PASS — deterministic compute_pac") } else { println("T5 FAIL") }

    println("")
    let all = t1 && t2 && t3 && t4 && t5
    if all {
        println("[hippocampus/theta_gamma] 5/5 PASS — PHYS-P6-2 DONE")
    } else {
        println("[hippocampus/theta_gamma] SOME FAILED")
    }
}

test()
