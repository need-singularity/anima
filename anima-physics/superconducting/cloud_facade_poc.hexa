// anima-physics/superconducting/cloud_facade_poc.hexa
// Cloud-facade superconducting substrate POC — AWS Braket Rigetti backend.
// raw#9 hexa-only strict (exec(awk/sha/python3) allowed; no exec("head") fileread).
// raw#37 transient: scripts/anima_physics_braket_rigetti_probe.py (helper, not library).
//
// PURPOSE
//   AWS Braket 1 account = 5 substrate (Rigetti·IQM·IonQ·AQT·QuEra) cover.
//   본 cycle = Rigetti (gate-based superconducting) Phase 1 prep.
//   DRY_RUN default — real hardware call requires explicit ANIMA_BRAKET_DRY_RUN=0.
//
// VERDICT TIER
//   PREP_DRY_RUN_PASS         : creds + SDK + dry-run path verified, api_call_count=0
//   PREP_NO_CREDS_DEGRADED    : no AWS creds; code path stub-ready, honest skip-pass
//   LIVE_PASS                 : explicit live run + 4-gate PASS (this cycle 미수행)
//   LIVE_FAIL_<reason>        : explicit live run failed
//
// PROBE = 4-qubit GHZ on Rigetti Ankaa-3 (us-west-1).
//   ghz       → marginal{00,11}=50/50 → H ≈ ln(2) (G1, 0.05 tol dry-run / 0.15 real)
//   random    → broader marginal     → H < ghz                       (G2)
//   shots     = 100 (cost-conscious)
//   backend   == aws_braket_rigetti_<actual>  (G4)
//
// USAGE
//   hexa run anima-physics/superconducting/cloud_facade_poc.hexa
//   hexa run anima-physics/superconducting/cloud_facade_poc.hexa --selftest
//   ANIMA_BRAKET_DRY_RUN=0 hexa run anima-physics/superconducting/cloud_facade_poc.hexa
//
// PAIRS
//   anima-physics/quantum/cloud_facade_poc.hexa            sibling Phase 1 (qiskit-aer)
//   anima-physics/quantum/cloud_real_ibm_q_facade.hexa     sibling Phase 2 (IBM Q)
//   anima-physics/analog/cloud_facade_poc.hexa             sibling QuEra Aquila (this cycle)
//   anima-physics/docs/aws_braket_signup_guide.md          AWS account 가입 가이드
//
// raw#9 hexa-only strict / raw#37 transient helper / raw#15 SSOT this file

let SCHEMA            = "anima_physics/cloud_facade_superconducting/1_braket_rigetti"
let BACKEND_PREFIX    = "aws_braket_rigetti_"
let SCRIPT_PATH       = "scripts/anima_physics_braket_rigetti_probe.py"
let VENV_PYTHON       = "anima-physics/.venv/bin/python3"
let SEED              = 42
let N_QUBITS          = 4
let SHOTS             = 100
let DEFAULT_DEVICE_ARN = "arn:aws:braket:us-west-1::device/qpu/rigetti/Ankaa-3"

// G1 — GHZ marginal entropy thresholds
let G1_LN2            = 0.693147180559945
let G1_TOL_DRY_RUN    = 0.05
let G1_MIN_DRY_RUN    = 0.643147180559945
let G1_TOL_REAL_HW    = 0.15
let G1_MIN_REAL_HW    = 0.543147180559945

// Verdict literals
let V_DRY_RUN_PASS    = "PREP_DRY_RUN_PASS"
let V_NO_CREDS        = "PREP_NO_CREDS_DEGRADED"
let V_LIVE_PASS       = "LIVE_PASS"
let V_LIVE_FAIL       = "LIVE_FAIL"
let V_DEG_OTHER       = "PREP_DEGRADED_OTHER"

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

fn invoke_probe(circuit_kind: string, seed: int) -> string {
    let cmd = VENV_PYTHON + " " + SCRIPT_PATH + " --circuit " + circuit_kind + " --seed " + to_string(seed)
    let out = exec(cmd)
    return out.trim()
}

fn sha256_hex(s: string) -> string {
    let cmd = "printf '%s' " + shell_escape(s) + " | shasum -a 256 | cut -c1-64"
    return exec(cmd).trim()
}

fn extract_float(json_line: string, key: string) -> float {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\"; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); m=match(rest, /-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?/); if (m==0) { print \"\"; exit } print substr(rest, m, RLENGTH) }'"
    let r = exec(cmd).trim()
    if r == "" { return -999999.0 }
    return to_float(r)
}

fn extract_string(json_line: string, key: string) -> string {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\" q; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); m=index(rest, q); if (m==0) { print \"\"; exit } print substr(rest, 1, m-1) }'"
    return exec(cmd).trim()
}

fn extract_bool(json_line: string, key: string) -> string {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\"; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); if (substr(rest,1,4)==\"true\") { print \"true\"; exit } if (substr(rest,1,5)==\"false\") { print \"false\"; exit } print \"\" }'"
    return exec(cmd).trim()
}

fn bool_str(b: bool) -> string {
    if b { return "true" }
    return "false"
}

fn run_facade() -> bool {
    println("[braket_rigetti] device=" + DEFAULT_DEVICE_ARN + " seed=" + to_string(SEED) + " n_qubits=" + to_string(N_QUBITS))

    // 1. GHZ probe
    let ghz_run1 = invoke_probe("ghz", SEED)
    let ghz_creds = extract_bool(ghz_run1, "credentials_present")
    let ghz_dryrun = extract_bool(ghz_run1, "dry_run")
    let ghz_degraded = extract_bool(ghz_run1, "degraded")
    let ghz_entropy = extract_float(ghz_run1, "entropy_bipartition_nat")
    let ghz_circuit_sha = extract_string(ghz_run1, "sha256_circuit")
    let ghz_backend = extract_string(ghz_run1, "backend_name")
    let ghz_actual = extract_string(ghz_run1, "actual_backend")
    let ghz_error = extract_string(ghz_run1, "error")
    let ghz_api_calls = extract_float(ghz_run1, "api_call_count")
    let ghz_arn = extract_string(ghz_run1, "device_arn")

    println("[ghz] credentials_present=" + ghz_creds + " dry_run=" + ghz_dryrun + " degraded=" + ghz_degraded)
    println("[ghz] backend=" + ghz_backend + " actual=" + ghz_actual)
    println("[ghz] device_arn=" + ghz_arn)
    println("[ghz] api_call_count=" + to_string(ghz_api_calls))
    println("[ghz] entropy_marginal_nat=" + to_string(ghz_entropy))
    if ghz_error != "" { println("[ghz] error=" + ghz_error) }

    let creds_present = ghz_creds == "true"
    let is_dry_run = ghz_dryrun == "true"
    let is_degraded = ghz_degraded == "true"

    // Branch A: NO CREDENTIALS — honest degraded marker.
    if creds_present == false {
        println("[braket_rigetti] NO AWS CREDENTIALS — honest degraded path (PREP_NO_CREDS_DEGRADED)")
        write_marker(false, true, true, ghz_backend, "", ghz_entropy, 0.0, 0, ghz_circuit_sha, ghz_run1, "", V_NO_CREDS, ghz_error, false, false, false, false, 0)
        return true
    }

    // Branch B: DRY_RUN — credentials present, default cost-safe path.
    if is_dry_run == true {
        println("[braket_rigetti] DRY_RUN mode — no cloud call (set ANIMA_BRAKET_DRY_RUN=0 for live)")
        // Verify api_call_count == 0 (DRY_RUN integrity)
        let dry_run_integrity = ghz_api_calls < 0.5
        if dry_run_integrity {
            println("[dry_run] api_call_count=0 — DRY_RUN integrity verified")
        } else {
            println("[dry_run] WARNING api_call_count=" + to_string(ghz_api_calls) + " — DRY_RUN integrity FAILED")
        }
        // backend_name should == BACKEND_PREFIX + "DRY_RUN"
        let g4_dry = ghz_backend == (BACKEND_PREFIX + "DRY_RUN")
        if g4_dry { println("G4 PASS — backend=" + ghz_backend + " (DRY_RUN tag)") }
        let v = V_DRY_RUN_PASS
        if dry_run_integrity == false { v = V_DEG_OTHER }
        write_marker(true, true, false, ghz_backend, ghz_actual, ghz_entropy, 0.0, 0, ghz_circuit_sha, ghz_run1, "", v, ghz_error, dry_run_integrity, false, false, g4_dry, 0)
        return dry_run_integrity
    }

    // Branch C: LIVE path. Token + creds + non-dry-run.
    if is_degraded == true {
        println("[braket_rigetti] LIVE mode but degraded — error=" + ghz_error)
        let v = V_LIVE_FAIL + "_" + ghz_backend
        write_marker(true, false, true, ghz_backend, ghz_actual, ghz_entropy, 0.0, 0, ghz_circuit_sha, ghz_run1, "", v, ghz_error, false, false, false, false, 0)
        return false
    }

    // Run negative baseline (random)
    let rnd_run1 = invoke_probe("random", SEED)
    let rnd_entropy = extract_float(rnd_run1, "entropy_bipartition_nat")
    let rnd_degraded = extract_bool(rnd_run1, "degraded")
    let rnd_api = extract_float(rnd_run1, "api_call_count")
    println("[random] entropy_marginal_nat=" + to_string(rnd_entropy) + " degraded=" + rnd_degraded)

    if rnd_degraded == "true" {
        let rnd_error = extract_string(rnd_run1, "error")
        let v = V_LIVE_FAIL + "_RANDOM_FAIL"
        write_marker(true, false, true, ghz_backend, ghz_actual, ghz_entropy, rnd_entropy, SHOTS, ghz_circuit_sha, ghz_run1, rnd_run1, v, rnd_error, false, false, false, false, 1)
        return false
    }

    // 4-gate evaluation (real HW path)
    let g1 = ghz_entropy >= G1_MIN_REAL_HW
    let g2 = rnd_entropy < ghz_entropy
    let g3 = false  // NOT_APPLICABLE_REAL_HW (shot noise)
    let g4 = ghz_backend == (BACKEND_PREFIX + ghz_actual)

    if g1 { println("G1 PASS — GHZ marginal=" + to_string(ghz_entropy) + " >= " + to_string(G1_MIN_REAL_HW)) } else { println("G1 FAIL") }
    if g2 { println("G2 PASS — random " + to_string(rnd_entropy) + " < ghz " + to_string(ghz_entropy)) } else { println("G2 FAIL") }
    println("G3 NOT_APPLICABLE_REAL_HW (shot noise)")
    if g4 { println("G4 PASS — backend=" + ghz_backend) } else { println("G4 FAIL") }

    let live_pass = g1 && g2 && g4
    let v = V_LIVE_FAIL + "_GATE_FAIL"
    if live_pass { v = V_LIVE_PASS }

    let total_api = 1 + 1
    write_marker(true, false, false, ghz_backend, ghz_actual, ghz_entropy, rnd_entropy, SHOTS, ghz_circuit_sha, ghz_run1, rnd_run1, v, "", g1, g2, false, g4, total_api)

    if live_pass {
        println("[braket_rigetti] LIVE 4-gate PASS — backend=" + ghz_actual)
        return true
    }
    println("[braket_rigetti] verdict=" + v)
    return false
}

fn write_marker(creds_present: bool, dry_run_mode: bool, degraded: bool, backend_name: string, actual_backend: string, ghz_h: float, rnd_h: float, shots_used: int, circuit_sha: string, raw_ghz: string, raw_rnd: string, verdict: string, error: string, g1: bool, g2: bool, g3: bool, g4: bool, api_calls_total: int) {
    let marker_dir = "state/v10_anima_physics_cloud_facade/poc_superconducting_braket_rigetti"
    let _ = exec("mkdir -p " + marker_dir)
    let marker_path = marker_dir + "/marker.json"
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()

    let raw_ghz_esc = raw_ghz.replace("\\", "\\\\").replace("\"", "\\\"")
    let raw_rnd_esc = raw_rnd.replace("\\", "\\\\").replace("\"", "\\\"")
    let error_esc = error.replace("\\", "\\\\").replace("\"", "\\\"")

    let mut g3_str = "false"
    if dry_run_mode == false && degraded == false && creds_present == true { g3_str = "\"NOT_APPLICABLE_REAL_HW\"" } else { g3_str = bool_str(g3) }

    let mut j = "{\n"
    j = j + "  \"schema\": \"" + SCHEMA + "\",\n"
    j = j + "  \"cycle\": \"anima_physics_cloud_facade_poc_superconducting_braket_rigetti\",\n"
    j = j + "  \"verdict\": \"" + verdict + "\",\n"
    j = j + "  \"substrate\": \"superconducting\",\n"
    j = j + "  \"provider\": \"aws_braket_rigetti\",\n"
    j = j + "  \"device_arn\": \"" + DEFAULT_DEVICE_ARN + "\",\n"
    j = j + "  \"backend_name\": \"" + backend_name + "\",\n"
    j = j + "  \"actual_backend\": \"" + actual_backend + "\",\n"
    j = j + "  \"credentials_present\": " + bool_str(creds_present) + ",\n"
    j = j + "  \"dry_run_mode\": " + bool_str(dry_run_mode) + ",\n"
    j = j + "  \"degraded\": " + bool_str(degraded) + ",\n"
    j = j + "  \"n_qubits\": " + to_string(N_QUBITS) + ",\n"
    j = j + "  \"seed\": " + to_string(SEED) + ",\n"
    j = j + "  \"shots\": " + to_string(shots_used) + ",\n"
    j = j + "  \"api_call_count\": " + to_string(api_calls_total) + ",\n"
    j = j + "  \"gates\": {\n"
    j = j + "    \"G1\": " + bool_str(g1) + ",\n"
    j = j + "    \"G2\": " + bool_str(g2) + ",\n"
    j = j + "    \"G3\": " + g3_str + ",\n"
    j = j + "    \"G4\": " + bool_str(g4) + "\n"
    j = j + "  },\n"
    j = j + "  \"ghz_entropy_nat\": " + to_string(ghz_h) + ",\n"
    j = j + "  \"random_entropy_nat\": " + to_string(rnd_h) + ",\n"
    j = j + "  \"ln2_reference\": " + to_string(G1_LN2) + ",\n"
    j = j + "  \"g1_min_dry_run\": " + to_string(G1_MIN_DRY_RUN) + ",\n"
    j = j + "  \"g1_min_real_hw\": " + to_string(G1_MIN_REAL_HW) + ",\n"
    j = j + "  \"circuit_sha256\": \"" + circuit_sha + "\",\n"
    j = j + "  \"raw_probe_stdout_ghz\": \"" + raw_ghz_esc + "\",\n"
    j = j + "  \"raw_probe_stdout_random\": \"" + raw_rnd_esc + "\",\n"
    j = j + "  \"error\": \"" + error_esc + "\",\n"
    j = j + "  \"files\": [\n"
    j = j + "    \"" + SCRIPT_PATH + "\",\n"
    j = j + "    \"anima-physics/superconducting/cloud_facade_poc.hexa\",\n"
    j = j + "    \"" + marker_path + "\"\n"
    j = j + "  ],\n"
    j = j + "  \"limits_raw_10_honest\": [\n"
    j = j + "    \"AWS Braket bills per shot + per task; DRY_RUN=1 default ensures zero-cost prep\",\n"
    j = j + "    \"DRY_RUN PASS verifies SDK + auth path only — NOT real quantum hardware result\",\n"
    j = j + "    \"4-qubit GHZ POC = substrate sanity check; Phi measurement weak (mirrors qiskit-aer POC limit)\",\n"
    j = j + "    \"Aspen-M-3 retired; Ankaa-3 current generation (us-west-1) per docs.aws.amazon.com 2026\",\n"
    j = j + "    \"G3 byte-identical NOT_APPLICABLE on real HW (shot noise); only dry-run path uses sha\",\n"
    j = j + "    \"physics.hexa superconducting_engine() dispatch site NOT modified (sibling cycle)\",\n"
    j = j + "    \"raw#9 strict respected via exec(awk/sha/python3); helper script raw#37 transient\"\n"
    j = j + "  ],\n"
    j = j + "  \"next_phase\": \"User signup AWS + budget cap $5 + ANIMA_BRAKET_DRY_RUN=0 → LIVE 4-gate evaluation\",\n"
    j = j + "  \"cost_usd\": 0.0,\n"
    j = j + "  \"timestamp\": \"" + ts + "\"\n"
    j = j + "}\n"

    write_file(marker_path, j)
    println("[marker] " + marker_path)
    println("[verdict] " + verdict)
}

fn cmd_selftest() {
    println("── braket_rigetti cloud_facade_poc selftest ──")
    let cmd = "test -f " + VENV_PYTHON + " && echo y || echo n"
    let venv_ok = exec(cmd).trim()
    println("venv_python_exists=" + venv_ok)
    let cmd2 = "test -f " + SCRIPT_PATH + " && echo y || echo n"
    let script_ok = exec(cmd2).trim()
    println("helper_script_exists=" + script_ok)
    if venv_ok == "y" {
        let bv = exec(VENV_PYTHON + " -c 'import braket, boto3; print(braket.__name__, boto3.__version__)' 2>&1").trim()
        println("braket_boto3=" + bv)
    }
    let cmd3 = VENV_PYTHON + " -c 'import os; t=bool((os.environ.get(\"AWS_ACCESS_KEY_ID\") and os.environ.get(\"AWS_SECRET_ACCESS_KEY\")) or os.path.isfile(os.path.expanduser(\"~/.aws/credentials\"))); print(\"aws_creds=\"+(\"true\" if t else \"false\"))'"
    let cred = exec(cmd3).trim()
    println(cred)
    let dry = exec("echo dry_run=${ANIMA_BRAKET_DRY_RUN:-1}").trim()
    println(dry)
    println("selftest=ok")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest {
        cmd_selftest()
        exit(0)
    }
    let ok = run_facade()
    if ok { exit(0) }
    exit(1)
}

main()
