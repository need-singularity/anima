// anima-physics/superconducting/cloud_facade_poc.hexa
// Cloud-facade superconducting substrate POC — DEPRECATED (Rigetti retired).
// raw#9 hexa-only strict (exec(awk/sha/python3) allowed; no exec("head") fileread).
// raw#10 honest — no silent skip, explicit deprecation verdict.
// raw#104 means-end-decoupling — substrate goal preserved, provider option ladder.
//
// 2026-04-27 STATUS: AWS Braket Rigetti path RETIRED (Ankaa-3 + all Rigetti
// models off Braket catalog, Aspen-M-3 already retired prior).  No
// superconducting QPU currently in AWS Braket us-east-1/us-west-2/eu-west-2.
//
// VERDICT TIER (post-2026-04-27 deprecation)
//   PREP_DEPRECATED_RIGETTI_RETIRED : provider retired upstream, no probe call,
//                                     honest skip-pass with option ladder
//
// Historical (pre-2026-04-27) — preserved for ledger continuity:
//   PREP_DRY_RUN_PASS         : creds + SDK + dry-run path verified
//   PREP_NO_CREDS_DEGRADED    : no AWS creds; honest skip-pass
//   LIVE_PASS / LIVE_FAIL_*   : real-HW gate evaluation (never reached;
//                               retired before live cycle)
//
// OPTION LADDER (raw#104)
//   (i)   IonQ Forte 1 / Forte Enterprise 1 — gate-based trapped-ion,
//         us-east-1 ONLINE 2026-04-27.  4-qubit GHZ logic is provider-agnostic;
//         a sibling .hexa under anima-physics/trapped_ion/ would carry this.
//   (ii)  Wait for Rigetti Ankaa-4 (rumored, no Braket catalog entry).
//   (iii) Quantinuum H1/H2 (trapped-ion, separate cloud) — out of AWS scope.
//   (iv)  IBM Q via qiskit-runtime — superconducting; sibling cycle exists at
//         anima-physics/quantum/cloud_real_ibm_q_facade.hexa.
//
// USAGE
//   hexa run anima-physics/superconducting/cloud_facade_poc.hexa
//   hexa run anima-physics/superconducting/cloud_facade_poc.hexa --selftest
//
// PAIRS
//   anima-physics/quantum/cloud_facade_poc.hexa            sibling Phase 1 (qiskit-aer)
//   anima-physics/quantum/cloud_real_ibm_q_facade.hexa     sibling Phase 2 (IBM Q)
//   anima-physics/analog/cloud_facade_poc.hexa             sibling QuEra Aquila (LIVE-ready)
//   anima-physics/docs/aws_braket_signup_guide.md          AWS account 가입 가이드
//
// raw#9 hexa-only strict / raw#15 SSOT this file / raw#10 honest deprecation

let SCHEMA            = "anima_physics/cloud_facade_superconducting/1_braket_rigetti_deprecated"
let BACKEND_PREFIX    = "aws_braket_rigetti_"
let DEFAULT_DEVICE_ARN = "arn:aws:braket:us-west-1::device/qpu/rigetti/Ankaa-3"
let DEPRECATION_DATE   = "2026-04-27"

// Verdict literal
let V_DEPRECATED      = "PREP_DEPRECATED_RIGETTI_RETIRED"

fn bool_str(b: bool) -> string {
    if b { return "true" }
    return "false"
}

fn run_facade() -> bool {
    println("[braket_rigetti] DEPRECATED — Rigetti retired from AWS Braket catalog (" + DEPRECATION_DATE + ")")
    println("[braket_rigetti] device_arn (historical)=" + DEFAULT_DEVICE_ARN)
    println("[braket_rigetti] verdict=" + V_DEPRECATED)
    println("[braket_rigetti] option_ladder:")
    println("[braket_rigetti]   (i)   IonQ Forte 1 / Forte Enterprise 1 (us-east-1 ONLINE) — trapped-ion substitute")
    println("[braket_rigetti]   (ii)  Wait for Rigetti Ankaa-4 (no catalog entry yet)")
    println("[braket_rigetti]   (iii) Quantinuum H1/H2 (separate cloud, out of AWS scope)")
    println("[braket_rigetti]   (iv)  IBM Q qiskit-runtime — sibling cycle anima-physics/quantum/cloud_real_ibm_q_facade.hexa")
    write_marker(V_DEPRECATED, "")
    return true
}

fn write_marker(verdict: string, error: string) {
    let marker_dir = "state/v10_anima_physics_cloud_facade/poc_superconducting_braket_rigetti"
    let _ = exec("mkdir -p " + marker_dir)
    let marker_path = marker_dir + "/marker.json"
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()

    let error_esc = error.replace("\\", "\\\\").replace("\"", "\\\"")

    let mut j = "{\n"
    j = j + "  \"schema\": \"" + SCHEMA + "\",\n"
    j = j + "  \"cycle\": \"anima_physics_cloud_facade_poc_superconducting_braket_rigetti\",\n"
    j = j + "  \"verdict\": \"" + verdict + "\",\n"
    j = j + "  \"substrate\": \"superconducting\",\n"
    j = j + "  \"provider\": \"aws_braket_rigetti_DEPRECATED\",\n"
    j = j + "  \"deprecation_date\": \"" + DEPRECATION_DATE + "\",\n"
    j = j + "  \"deprecation_reason\": \"Rigetti Ankaa-3 + all Rigetti models retired from AWS Braket catalog 2026-04-27 (Aspen-M-3 retired prior). No superconducting QPU currently on Braket us-east-1/us-west-2/eu-west-2.\",\n"
    j = j + "  \"device_arn_historical\": \"" + DEFAULT_DEVICE_ARN + "\",\n"
    j = j + "  \"backend_name\": \"" + BACKEND_PREFIX + "DEPRECATED\",\n"
    j = j + "  \"actual_backend\": \"\",\n"
    j = j + "  \"credentials_present\": true,\n"
    j = j + "  \"dry_run_mode\": true,\n"
    j = j + "  \"degraded\": true,\n"
    j = j + "  \"shots\": 0,\n"
    j = j + "  \"api_call_count\": 0,\n"
    j = j + "  \"gates\": {\n"
    j = j + "    \"G1\": false,\n"
    j = j + "    \"G2\": false,\n"
    j = j + "    \"G3\": false,\n"
    j = j + "    \"G4\": false\n"
    j = j + "  },\n"
    j = j + "  \"error\": \"" + error_esc + "\",\n"
    j = j + "  \"files\": [\n"
    j = j + "    \"anima-physics/superconducting/cloud_facade_poc.hexa\",\n"
    j = j + "    \"" + marker_path + "\"\n"
    j = j + "  ],\n"
    j = j + "  \"option_ladder_raw_104\": [\n"
    j = j + "    \"(i) IonQ Forte 1 / Forte Enterprise 1 (us-east-1 ONLINE 2026-04-27) — gate-based trapped-ion; 4-qubit GHZ probe is provider-agnostic; sibling .hexa anima-physics/trapped_ion/ would carry this\",\n"
    j = j + "    \"(ii) Wait for Rigetti Ankaa-4 (rumored, no Braket catalog entry as of 2026-04-27)\",\n"
    j = j + "    \"(iii) Quantinuum H1/H2 — trapped-ion, separate cloud (Honeywell), out of AWS Braket scope\",\n"
    j = j + "    \"(iv) IBM Q qiskit-runtime — superconducting; sibling cycle anima-physics/quantum/cloud_real_ibm_q_facade.hexa preserves the substrate axis\"\n"
    j = j + "  ],\n"
    j = j + "  \"limits_raw_10_honest\": [\n"
    j = j + "    \"raw#10 honest — Rigetti retired upstream; no LIVE_HW probe possible on this cycle\",\n"
    j = j + "    \"raw#104 means-end-decoupling — substrate goal (gate-based superconducting cover) preserved via option ladder above\",\n"
    j = j + "    \"witness ledger v2 G5 LIVE_HW_WITNESS_RATE remains 0/11 — DRY_RUN/DEPRECATED do not promote G5\",\n"
    j = j + "    \"physics.hexa superconducting_engine() dispatch site NOT modified (no provider available)\",\n"
    j = j + "    \"raw#9 strict respected — no probe .py needed (deprecation does not require SDK call)\"\n"
    j = j + "  ],\n"
    j = j + "  \"next_phase\": \"Choose option (i) IonQ-Forte trapped-ion route or (iv) IBM Q superconducting route; current cycle does NOT block sibling cycles\",\n"
    j = j + "  \"cost_usd\": 0.0,\n"
    j = j + "  \"timestamp\": \"" + ts + "\"\n"
    j = j + "}\n"

    write_file(marker_path, j)
    println("[marker] " + marker_path)
    println("[verdict] " + verdict)
}

fn cmd_selftest() {
    println("── braket_rigetti cloud_facade_poc selftest (DEPRECATED) ──")
    println("provider_status=retired_2026_04_27")
    println("verdict_tier=" + V_DEPRECATED)
    println("option_ladder_count=4")
    println("selftest=ok")
    println("DONE")
}

@manual_main
fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest {
        cmd_selftest()
        exit(0)
    }
    let ok = run_facade()
    if ok { exit(0) }
    exit(1)
}

main()
