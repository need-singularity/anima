// anima-physics/trapped_ion/cloud_facade_poc.hexa
// @resolver-bypass(reason="invokes Mac-host venv python3 (homebrew aarch64 not bind-mounted into hexa-exec docker container) — must run on bare Mac")
// Cloud-facade trapped-ion substrate POC — AWS Braket IonQ Forte 1 (gate-based).
// raw#9 hexa-only strict (exec(awk/sha/python3) allowed; no exec("head") fileread).
// raw#37 transient: scripts/anima_physics_braket_ionq_probe.py (helper, not library).
//
// PURPOSE
//   AWS Braket "trapped-ion" first cover. IonQ Forte 1 = up to 36-qubit gate-based.
//   본 cycle 은 4-qubit GHZ entanglement probe.
//   DRY_RUN default — real hardware call requires explicit ANIMA_BRAKET_DRY_RUN=0.
//
// VERDICT TIER
//   PREP_DRY_RUN_PASS         : creds + SDK + dry-run path verified, api_call_count=0
//   PREP_NO_CREDS_DEGRADED    : no AWS creds; code path stub-ready, honest skip-pass
//   LIVE_PASS                 : explicit live run + 4-gate PASS
//   LIVE_FAIL_<reason>        : explicit live run failed
//
// PROBE = 4-qubit GHZ on IonQ Forte 1 (us-east-1).
//   ghz          → H(0) + CNOT(0,1) + CNOT(1,2) + CNOT(2,3) → |0000>+|1111>
//                  Shannon entropy of 100-shot bitstring distribution ≥ 0.5 nat (G1)
//   unentangled  → H(0) only; product state — distribution Shannon H differs (G2)
//   shots        = 100
//   backend      == aws_braket_ionq_<actual>                                  (G4)
//
// USAGE
//   hexa run anima-physics/trapped_ion/cloud_facade_poc.hexa
//   hexa run anima-physics/trapped_ion/cloud_facade_poc.hexa --selftest
//   ANIMA_BRAKET_DRY_RUN=0 hexa run anima-physics/trapped_ion/cloud_facade_poc.hexa
//
// PAIRS
//   anima-physics/analog/cloud_facade_poc.hexa           sibling Braket QuEra (analog Rydberg)
//   anima-physics/superconducting/cloud_facade_poc.hexa  DEPRECATED (Rigetti retired)
//   anima-physics/quantum/cloud_facade_poc.hexa          sibling qiskit-aer
//
// raw#9 hexa-only strict / raw#37 transient helper / raw#15 SSOT this file

let SCHEMA            = "anima_physics/cloud_facade_trapped_ion/1_braket_ionq_forte"
let BACKEND_PREFIX    = "aws_braket_ionq_"
let SCRIPT_PATH       = "anima-physics/scripts/anima_physics_braket_ionq_probe.py"
let VENV_PYTHON       = "anima-physics/.venv/bin/python3"
let SEED              = 42
let N_QUBITS          = 4
let SHOTS             = 100
let DEFAULT_DEVICE_ARN = "arn:aws:braket:us-east-1::device/qpu/ionq/Forte-1"

// G1 — GHZ pattern entropy threshold (gate noise floor; ideal ≈ ln(2) ≈ 0.69 nat)
let G1_MIN_GHZ        = 0.5   // nat — conservative (allow noise smear)

// Verdict literals
let V_DRY_RUN_PASS    = "PREP_DRY_RUN_PASS"
let V_NO_CREDS        = "PREP_NO_CREDS_DEGRADED"
let V_LIVE_PASS       = "LIVE_PASS"
let V_LIVE_FAIL       = "LIVE_FAIL"
let V_DEG_OTHER       = "PREP_DEGRADED_OTHER"

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

fn invoke_probe(program_kind: string, seed: int) -> string {
    let cmd = VENV_PYTHON + " " + SCRIPT_PATH + " --program " + program_kind + " --seed " + to_string(seed)
    let out = exec(cmd)
    return out.trim()
}

fn sha256_hex(s: string) -> string {
    let cmd = "printf '%s' " + shell_escape(s) + " | shasum -a 256 | cut -c1-64"
    return exec(cmd).trim()
}

fn extract_float(json_line: string, key: string) -> float {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\"; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); m=match(rest, /-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?/); if (m==0) { print \"\"; exit } print substr(rest, m, RLENGTH) }'"
    let r = exec(cmd).trim()
    if r == "" { return -999999.0 }
    return to_float(r)
}

fn extract_string(json_line: string, key: string) -> string {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\" q; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); m=index(rest, q); if (m==0) { print \"\"; exit } print substr(rest, 1, m-1) }'"
    return exec(cmd).trim()
}

fn extract_bool(json_line: string, key: string) -> string {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\"; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); if (substr(rest,1,4)==\"true\") { print \"true\"; exit } if (substr(rest,1,5)==\"false\") { print \"false\"; exit } print \"\" }'"
    return exec(cmd).trim()
}

fn bool_str(b: bool) -> string {
    if b { return "true" }
    return "false"
}

fn run_facade() -> bool {
    println("[braket_ionq] device=" + DEFAULT_DEVICE_ARN + " seed=" + to_string(SEED) + " n_qubits=" + to_string(N_QUBITS))

    let ghz_run = invoke_probe("ghz", SEED)
    let ghz_creds = extract_bool(ghz_run, "credentials_present")
    let ghz_dryrun = extract_bool(ghz_run, "dry_run")
    let ghz_degraded = extract_bool(ghz_run, "degraded")
    let ghz_entropy = extract_float(ghz_run, "entropy_pattern_nat")
    let ghz_sha = extract_string(ghz_run, "sha256_program")
    let ghz_backend = extract_string(ghz_run, "backend_name")
    let ghz_actual = extract_string(ghz_run, "actual_backend")
    let ghz_error = extract_string(ghz_run, "error")
    let ghz_api = extract_float(ghz_run, "api_call_count")
    let ghz_arn = extract_string(ghz_run, "device_arn")
    let ghz_task_arn = extract_string(ghz_run, "task_arn")

    println("[ghz] credentials_present=" + ghz_creds + " dry_run=" + ghz_dryrun + " degraded=" + ghz_degraded)
    println("[ghz] backend=" + ghz_backend + " actual=" + ghz_actual)
    println("[ghz] device_arn=" + ghz_arn)
    println("[ghz] api_call_count=" + to_string(ghz_api))
    println("[ghz] entropy_pattern_nat=" + to_string(ghz_entropy))
    if ghz_task_arn != "" { println("[ghz] task_arn=" + ghz_task_arn) }
    if ghz_error != "" { println("[ghz] error=" + ghz_error) }

    let creds_present = ghz_creds == "true"
    let is_dry_run = ghz_dryrun == "true"
    let is_degraded = ghz_degraded == "true"

    // Branch A: NO CREDENTIALS
    if creds_present == false {
        println("[braket_ionq] NO AWS CREDENTIALS — honest degraded path (PREP_NO_CREDS_DEGRADED)")
        write_marker(false, true, true, ghz_backend, "", ghz_entropy, 0.0, 0, ghz_sha, ghz_run, "", V_NO_CREDS, ghz_error, false, false, false, false, 0, "", "")
        return true
    }

    // Branch B: DRY_RUN
    if is_dry_run == true {
        println("[braket_ionq] DRY_RUN mode — no cloud call (set ANIMA_BRAKET_DRY_RUN=0 for live)")
        let dry_integrity = ghz_api < 0.5
        if dry_integrity {
            println("[dry_run] api_call_count=0 — DRY_RUN integrity verified")
        } else {
            println("[dry_run] WARNING api_call_count=" + to_string(ghz_api))
        }
        let g4_dry = ghz_backend == (BACKEND_PREFIX + "DRY_RUN")
        if g4_dry { println("G4 PASS — backend=" + ghz_backend + " (DRY_RUN tag)") }
        let v = V_DRY_RUN_PASS
        if dry_integrity == false { v = V_DEG_OTHER }
        write_marker(true, true, false, ghz_backend, ghz_actual, ghz_entropy, 0.0, 0, ghz_sha, ghz_run, "", v, ghz_error, dry_integrity, false, false, g4_dry, 0, "", "")
        return dry_integrity
    }

    // Branch C: LIVE
    if is_degraded == true {
        println("[braket_ionq] LIVE but degraded — error=" + ghz_error)
        let v = V_LIVE_FAIL + "_" + ghz_backend
        write_marker(true, false, true, ghz_backend, ghz_actual, ghz_entropy, 0.0, 0, ghz_sha, ghz_run, "", v, ghz_error, false, false, false, false, 0, ghz_task_arn, "")
        return false
    }

    let unc_run = invoke_probe("unentangled", SEED)
    let unc_entropy = extract_float(unc_run, "entropy_pattern_nat")
    let unc_degraded = extract_bool(unc_run, "degraded")
    let unc_task_arn = extract_string(unc_run, "task_arn")
    println("[unentangled] entropy_pattern_nat=" + to_string(unc_entropy) + " degraded=" + unc_degraded)
    if unc_task_arn != "" { println("[unentangled] task_arn=" + unc_task_arn) }

    if unc_degraded == "true" {
        let unc_error = extract_string(unc_run, "error")
        let v = V_LIVE_FAIL + "_UNENTANGLED_FAIL"
        write_marker(true, false, true, ghz_backend, ghz_actual, ghz_entropy, unc_entropy, SHOTS, ghz_sha, ghz_run, unc_run, v, unc_error, false, false, false, false, 1, ghz_task_arn, unc_task_arn)
        return false
    }

    let g1 = ghz_entropy >= G1_MIN_GHZ
    // G2: unentangled (single H + identities) entropy distribution differs from
    // GHZ entanglement-induced bimodal pattern. We require unentangled < ghz
    // (sign-flip), matching analog G2 convention.
    let g2 = unc_entropy < ghz_entropy
    let g3 = false  // NOT_APPLICABLE_REAL_HW
    let g4 = ghz_backend == (BACKEND_PREFIX + ghz_actual)

    if g1 { println("G1 PASS — GHZ entropy=" + to_string(ghz_entropy) + " >= " + to_string(G1_MIN_GHZ)) } else { println("G1 FAIL") }
    if g2 { println("G2 PASS — unentangled " + to_string(unc_entropy) + " < ghz " + to_string(ghz_entropy)) } else { println("G2 FAIL") }
    println("G3 NOT_APPLICABLE_REAL_HW (ion gate noise)")
    if g4 { println("G4 PASS — backend=" + ghz_backend) } else { println("G4 FAIL") }

    let live_pass = g1 && g2 && g4
    let v = V_LIVE_FAIL + "_GATE_FAIL"
    if live_pass { v = V_LIVE_PASS }

    let total_api = 1 + 1
    write_marker(true, false, false, ghz_backend, ghz_actual, ghz_entropy, unc_entropy, SHOTS, ghz_sha, ghz_run, unc_run, v, "", g1, g2, false, g4, total_api, ghz_task_arn, unc_task_arn)

    if live_pass {
        println("[braket_ionq] LIVE 4-gate PASS — backend=" + ghz_actual)
        return true
    }
    println("[braket_ionq] verdict=" + v)
    return false
}

fn write_marker(creds_present: bool, dry_run_mode: bool, degraded: bool, backend_name: string, actual_backend: string, ghz_h: float, unc_h: float, shots_used: int, program_sha: string, raw_ghz: string, raw_unc: string, verdict: string, error: string, g1: bool, g2: bool, g3: bool, g4: bool, api_calls_total: int, ghz_task_arn: string, unc_task_arn: string) {
    let marker_dir = "state/v10_anima_physics_cloud_facade/poc_trapped_ion_braket_ionq"
    let _ = exec("mkdir -p " + marker_dir)
    let marker_path = marker_dir + "/marker.json"
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()

    let raw_ghz_esc = raw_ghz.replace("\\", "\\\\").replace("\"", "\\\"")
    let raw_unc_esc = raw_unc.replace("\\", "\\\\").replace("\"", "\\\"")
    let error_esc = error.replace("\\", "\\\\").replace("\"", "\\\"")

    let mut g3_str = "false"
    if dry_run_mode == false && degraded == false && creds_present == true { g3_str = "\"NOT_APPLICABLE_REAL_HW\"" } else { g3_str = bool_str(g3) }

    let mut j = "{\n"
    j = j + "  \"schema\": \"" + SCHEMA + "\",\n"
    j = j + "  \"cycle\": \"anima_physics_cloud_facade_poc_trapped_ion_braket_ionq\",\n"
    j = j + "  \"verdict\": \"" + verdict + "\",\n"
    j = j + "  \"substrate\": \"trapped_ion\",\n"
    j = j + "  \"provider\": \"aws_braket_ionq_forte_1\",\n"
    j = j + "  \"device_arn\": \"" + DEFAULT_DEVICE_ARN + "\",\n"
    j = j + "  \"backend_name\": \"" + backend_name + "\",\n"
    j = j + "  \"actual_backend\": \"" + actual_backend + "\",\n"
    j = j + "  \"credentials_present\": " + bool_str(creds_present) + ",\n"
    j = j + "  \"dry_run_mode\": " + bool_str(dry_run_mode) + ",\n"
    j = j + "  \"degraded\": " + bool_str(degraded) + ",\n"
    j = j + "  \"n_qubits\": " + to_string(N_QUBITS) + ",\n"
    j = j + "  \"seed\": " + to_string(SEED) + ",\n"
    j = j + "  \"shots\": " + to_string(shots_used) + ",\n"
    j = j + "  \"api_call_count\": " + to_string(api_calls_total) + ",\n"
    j = j + "  \"gates\": {\n"
    j = j + "    \"G1\": " + bool_str(g1) + ",\n"
    j = j + "    \"G2\": " + bool_str(g2) + ",\n"
    j = j + "    \"G3\": " + g3_str + ",\n"
    j = j + "    \"G4\": " + bool_str(g4) + "\n"
    j = j + "  },\n"
    j = j + "  \"ghz_entropy_nat\": " + to_string(ghz_h) + ",\n"
    j = j + "  \"unentangled_entropy_nat\": " + to_string(unc_h) + ",\n"
    j = j + "  \"g1_min_ghz\": " + to_string(G1_MIN_GHZ) + ",\n"
    j = j + "  \"program_sha256\": \"" + program_sha + "\",\n"
    j = j + "  \"task_arn_ghz\": \"" + ghz_task_arn + "\",\n"
    j = j + "  \"task_arn_unentangled\": \"" + unc_task_arn + "\",\n"
    j = j + "  \"raw_probe_stdout_ghz\": \"" + raw_ghz_esc + "\",\n"
    j = j + "  \"raw_probe_stdout_unentangled\": \"" + raw_unc_esc + "\",\n"
    j = j + "  \"error\": \"" + error_esc + "\",\n"
    j = j + "  \"files\": [\n"
    j = j + "    \"" + SCRIPT_PATH + "\",\n"
    j = j + "    \"anima-physics/trapped_ion/cloud_facade_poc.hexa\",\n"
    j = j + "    \"" + marker_path + "\"\n"
    j = j + "  ],\n"
    j = j + "  \"limits_raw_10_honest\": [\n"
    j = j + "    \"AWS Braket IonQ Forte 1 bills per shot + per task; DRY_RUN=1 default ensures zero-cost prep\",\n"
    j = j + "    \"DRY_RUN PASS verifies SDK + circuit build + auth path only — NOT real ion-gate dynamics\",\n"
    j = j + "    \"4-qubit GHZ POC = substrate sanity check; trapped-ion gate noise 진짜 hardware 만 reproduce\",\n"
    j = j + "    \"Forte 1 up to 36 qubits; this probe uses 4 — far below capability ceiling\",\n"
    j = j + "    \"G3 byte-identical NOT_APPLICABLE on real HW (gate decoherence + sampling noise)\",\n"
    j = j + "    \"physics.hexa trapped_ion dispatch site NOT modified (sibling cycle)\",\n"
    j = j + "    \"Forte 1 may have queue depth at LIVE submit time; device offline → DEGRADED honest\",\n"
    j = j + "    \"raw#9 strict respected via exec(awk/sha/python3); helper script raw#37 transient\"\n"
    j = j + "  ],\n"
    j = j + "  \"next_phase\": \"anima/.own own 5 authorizes concurrent LIVE on QuEra+IonQ; ANIMA_BRAKET_DRY_RUN=0 → LIVE 4-gate evaluation\",\n"
    j = j + "  \"cost_usd\": 0.0,\n"
    j = j + "  \"timestamp\": \"" + ts + "\"\n"
    j = j + "}\n"

    write_file(marker_path, j)
    println("[marker] " + marker_path)
    println("[verdict] " + verdict)
}

fn cmd_selftest() {
    println("── braket_ionq_forte_1 cloud_facade_poc selftest ──")
    let cmd = "test -f " + VENV_PYTHON + " && echo y || echo n"
    let venv_ok = exec(cmd).trim()
    println("venv_python_exists=" + venv_ok)
    let cmd2 = "test -f " + SCRIPT_PATH + " && echo y || echo n"
    let script_ok = exec(cmd2).trim()
    println("helper_script_exists=" + script_ok)
    if venv_ok == "y" {
        let bv = exec(VENV_PYTHON + " -c 'import braket; from braket.circuits import Circuit; import boto3; print(\"gate=ok\", boto3.__version__)' 2>&1").trim()
        println("braket_gate=" + bv)
    }
    let cmd3 = VENV_PYTHON + " -c 'import os; t=bool((os.environ.get(\"AWS_ACCESS_KEY_ID\") and os.environ.get(\"AWS_SECRET_ACCESS_KEY\")) or os.path.isfile(os.path.expanduser(\"~/.aws/credentials\"))); print(\"aws_creds=\"+(\"true\" if t else \"false\"))'"
    let cred = exec(cmd3).trim()
    println(cred)
    let dry = exec("echo dry_run=${ANIMA_BRAKET_DRY_RUN:-1}").trim()
    println(dry)
    println("selftest=ok")
    println("DONE")
}

@manual_main
fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest {
        cmd_selftest()
        exit(0)
    }
    let ok = run_facade()
    if ok { exit(0) }
    exit(1)
}

main()
