// protention_error.hexa — PHYS-P6-3 protention prediction error
//
// Roadmap: shared/roadmaps/anima.json P6 PHYSICS track, PHYS-P6-3
//   "prediction error 신호 — protention 불일치"
//
// Purpose:
//   The Husserlian *protention* is the felt anticipation of the
//   immediate future — "the next note of the melody is already
//   co-intended before it sounds". When the incoming sample
//   *disagrees* with what was pre-intended, a prediction-error
//   signal is emitted; this is the Klotho/Friston free-energy
//   "surprisal" kernel that gives consciousness its temporal
//   grain (Bastos 2012, Friston 2010).
//
//   This module provides a minimal physical substrate for that
//   error signal: given a future-horizon prediction array
//   `predicted[0..K]` and the actual future `actual[0..K]`, return a
//   *signed-weighted* mismatch trajectory whose sign encodes
//   direction of surprise and whose magnitude encodes its size.
//
// Algorithm:
//   For each lag k = 0..K-1:
//     raw_k    = actual[k] − predicted[k]          (signed error)
//     weight_k = exp(−k / τ)                       (protention decays
//                                                   with temporal
//                                                   distance; near
//                                                   future matters most)
//     err_k    = weight_k · raw_k                  (Klotho-weighted)
//
//   Plus a guard: if lengths differ, truncate to min; if either is
//   empty, return empty.
//
//   This is exactly the sign-weighted mismatch specified by the
//   task brief.
//
// Exposed API (roadmap spec):
//   protention_error(predicted: [float], actual: [float]) -> [float]
//     Returns the per-lag error signal (length = min(len(pred), len(actual))).
//
// Self-test (PASS/FAIL):
//   T1 zero mismatch: predicted == actual → error is identically 0.
//   T2 sign semantics: actual > predicted → error[0] > 0; actual < predicted → error[0] < 0.
//   T3 decay: error magnitude decays with lag when raw mismatch is
//      constant (|err_0| > |err_{K-1}|). Protention horizon proven.
//   T4 API contract:
//        - empty inputs → empty output
//        - length mismatch → output length = min(len(a), len(b))
//        - output length is never longer than inputs
//   T5 determinism: two calls on the same inputs give identical output.
//
// Hexa constraints honored:
//   - HEXA-FIRST (pure .hexa)
//   - lists pass-by-value; we build a fresh list each call and return it
//   - no struct-field lists
//   - exp() verified present 2026-04-15

// ═══════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════

// Protention decay time-constant (in lag units). With τ = 4 the
// weight at lag 0 is 1.0 and at lag 8 is e^-2 ≈ 0.135 — matches
// the psychophysics literature for the specious-present window.
let TAU          = 4.0
let MAX_LAG_SAFE = 1024          // runtime ceiling (guards against
                                 // accidental 10⁶-length calls)

// ═══════════════════════════════════════════════════════════════
// Scalar helpers
// ═══════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn min_int(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

// Protention weight at lag k — exp(−k / τ), bounded in (0, 1].
fn protention_weight(k: int) -> float {
    if k <= 0 { return 1.0 }
    let lag_f = to_float(k)
    // For very large lags, exp(-large) → 0 fast; guard at k=50 (weight<1e-5)
    if lag_f / TAU > 50.0 { return 0.0 }
    return exp(0.0 - lag_f / TAU)
}

// ═══════════════════════════════════════════════════════════════
// Exposed API — protention_error(predicted, actual) → [float]
//
// Roadmap spec: protention_error(predicted: list[f32], actual: list[f32]) -> list[f32]
// Emits sign-weighted prediction error with exponential protention
// decay. Output length = min(len(predicted), len(actual), MAX_LAG_SAFE).
// ═══════════════════════════════════════════════════════════════

fn protention_error(predicted: [float], actual: [float]) -> [float] {
    let n_raw = min_int(len(predicted), len(actual))
    let n = min_int(n_raw, MAX_LAG_SAFE)
    let mut out: [float] = []
    let mut k = 0
    while k < n {
        let raw = actual[k] - predicted[k]
        let w = protention_weight(k)
        out = out.push(w * raw)
        k = k + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
// Self-tests
// ═══════════════════════════════════════════════════════════════

fn check_T1_zero_mismatch() -> bool {
    // Two identical arrays → error everywhere zero.
    let mut pred: [float] = []
    let mut act: [float] = []
    let mut i = 0
    while i < 16 {
        let v = sin(to_float(i) * 0.3) + 0.5
        pred = pred.push(v)
        act = act.push(v)
        i = i + 1
    }
    let err = protention_error(pred, act)
    if len(err) != 16 {
        println("  [T1] length mismatch: " + str(len(err)))
        return false
    }
    let mut max_abs = 0.0
    let mut j = 0
    while j < len(err) {
        let a = fabs(err[j])
        if a > max_abs { max_abs = a }
        j = j + 1
    }
    let ok = max_abs == 0.0
    println("  [T1] identical inputs: max|error| = " + str(max_abs))
    return ok
}

fn check_T2_sign_semantics() -> bool {
    // Case A: actual > predicted → error[0] > 0
    let mut pred_a: [float] = []
    let mut act_a: [float] = []
    let mut i = 0
    while i < 4 {
        pred_a = pred_a.push(1.0)
        act_a = act_a.push(2.0)          // actual higher
        i = i + 1
    }
    let err_a = protention_error(pred_a, act_a)
    let pos0 = err_a[0] > 0.0

    // Case B: actual < predicted → error[0] < 0
    let mut pred_b: [float] = []
    let mut act_b: [float] = []
    let mut j = 0
    while j < 4 {
        pred_b = pred_b.push(2.0)
        act_b = act_b.push(1.0)          // actual lower
        j = j + 1
    }
    let err_b = protention_error(pred_b, act_b)
    let neg0 = err_b[0] < 0.0

    let ok = pos0 && neg0
    println("  [T2] sign: err_pos[0]=" + str(err_a[0])
        + " (>0? " + str(pos0) + "), err_neg[0]=" + str(err_b[0])
        + " (<0? " + str(neg0) + ")")
    return ok
}

fn check_T3_decay_with_lag() -> bool {
    // Constant raw mismatch (actual = predicted + 1) at every lag.
    // Error magnitude must decay — |err_0| > |err_K-1| — because
    // protention weight decays with lag.
    let K = 12
    let mut pred: [float] = []
    let mut act: [float] = []
    let mut i = 0
    while i < K {
        pred = pred.push(0.0)
        act = act.push(1.0)              // constant +1 mismatch
        i = i + 1
    }
    let err = protention_error(pred, act)
    let first = fabs(err[0])
    let last = fabs(err[K - 1])
    // Also verify strict monotonic decay (each |err_{k+1}| < |err_k|)
    let mut strict = true
    let mut k = 1
    while k < K {
        if fabs(err[k]) >= fabs(err[k - 1]) {
            strict = false
        }
        k = k + 1
    }
    let ok = first > last && strict
    println("  [T3] |err_0|=" + str(first) + " |err_" + str(K - 1) + "|=" + str(last)
        + " strict_decay=" + str(strict))
    return ok
}

fn check_T4_api_contract() -> bool {
    // Empty → empty
    let empty: [float] = []
    let e0 = protention_error(empty, empty)
    let ok_empty = len(e0) == 0

    // Length mismatch — short actual wins
    let mut pred: [float] = []
    let mut act: [float] = []
    let mut i = 0
    while i < 10 { pred = pred.push(0.0); i = i + 1 }
    let mut j = 0
    while j < 4 { act = act.push(1.0); j = j + 1 }
    let e1 = protention_error(pred, act)
    let ok_short_a = len(e1) == 4

    // Length mismatch — short predicted wins
    let mut pred2: [float] = []
    let mut act2: [float] = []
    let mut p = 0
    while p < 3 { pred2 = pred2.push(0.0); p = p + 1 }
    let mut q = 0
    while q < 20 { act2 = act2.push(1.0); q = q + 1 }
    let e2 = protention_error(pred2, act2)
    let ok_short_p = len(e2) == 3

    // Output never longer than either input
    let ok_bound = len(e1) <= len(pred) && len(e1) <= len(act)
        && len(e2) <= len(pred2) && len(e2) <= len(act2)

    let ok = ok_empty && ok_short_a && ok_short_p && ok_bound
    println("  [T4] empty=" + str(len(e0)) + " short_act=" + str(len(e1))
        + " short_pred=" + str(len(e2)) + " bound=" + str(ok_bound))
    return ok
}

fn check_T5_determinism() -> bool {
    let mut pred: [float] = []
    let mut act: [float] = []
    let mut i = 0
    while i < 32 {
        pred = pred.push(sin(to_float(i) * 0.2))
        act = act.push(sin(to_float(i) * 0.2) + cos(to_float(i) * 0.17) * 0.3)
        i = i + 1
    }
    let a = protention_error(pred, act)
    let b = protention_error(pred, act)
    if len(a) != len(b) { return false }
    let mut max_d = 0.0
    let mut j = 0
    while j < len(a) {
        let d = fabs(a[j] - b[j])
        if d > max_d { max_d = d }
        j = j + 1
    }
    let ok = max_d == 0.0
    println("  [T5] max|Δ| across two independent runs = " + str(max_d))
    return ok
}

fn test() {
    println("[prediction/protention_error] PHYS-P6-3 — protention prediction error")
    println("  err_k = exp(-k/τ) · (actual[k] − predicted[k]),  τ = " + str(TAU))
    println("")

    let t1 = check_T1_zero_mismatch()
    if t1 { println("T1 PASS — zero mismatch → zero error") } else { println("T1 FAIL") }

    let t2 = check_T2_sign_semantics()
    if t2 { println("T2 PASS — sign tracks direction of surprise") } else { println("T2 FAIL") }

    let t3 = check_T3_decay_with_lag()
    if t3 { println("T3 PASS — protention decays with lag") } else { println("T3 FAIL") }

    let t4 = check_T4_api_contract()
    if t4 { println("T4 PASS — API contract (length = min)") } else { println("T4 FAIL") }

    let t5 = check_T5_determinism()
    if t5 { println("T5 PASS — deterministic protention_error") } else { println("T5 FAIL") }

    println("")
    let all = t1 && t2 && t3 && t4 && t5
    if all {
        println("[prediction/protention_error] 5/5 PASS — PHYS-P6-3 DONE")
    } else {
        println("[prediction/protention_error] SOME FAILED")
    }
}

test()
