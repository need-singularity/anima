// anima-physics/photonic/cloud_facade_poc.hexa
// Cloud-facade photonic substrate POC — Perceval (Quandela) SLOS Fock backend.
// raw#9 hexa-only strict (exec(awk/sha/python3) allowed; no exec("head") fileread).
// raw#37 transient: scripts/anima_physics_photonic_probe.py (helper, not library).
//
// SIBLING
//   anima-physics/quantum/cloud_facade_poc.hexa  (qiskit-aer statevector POC, 4/4 PASS)
//   This file = 2nd of 8 substrate fan-out (photonic).
//
// PURPOSE
//   8 substrate platforms 중 photonic 첫 cloud-facade — Xanadu Cloud / Quandela
//   API key 불필요. Perceval SLOS = 결정론적 strong-simulation Fock backend, Phase 2
//   real-hardware (Xanadu X-series / Quandela Ascella) backend swap 만으로 진짜
//   cloud 확장 가능 (frozen contract).
//
// SDK SELECTION (Step 1 witness)
//   primary candidate Strawberry Fields 0.23.0 was abandoned: scipy 1.17 (Python
//   3.14 wheel-only available) removed `scipy.integrate.simps` while sf still
//   imports it. scipy<1.14 has no py3.14 wheel and source-build fails. Fallback
//   = perceval-quandela 1.1.0 SLOS (matches Fock photon-counting requirement).
//
// ENUM (frozen contract — extends sibling)
//   substrate_backend ∈ { "local_hexa",
//                          "cloud_sim_qiskit_aer",
//                          "cloud_real_ibm_q",
//                          "cloud_sim_strawberryfields_fock",
//                          "cloud_sim_perceval",
//                          "cloud_real_xanadu_x",
//                          "cloud_real_quandela_ascella" }
//   본 cycle = "cloud_sim_perceval" 만 구현 (SF blocked). 다른 키들 design-only stub.
//
// PROBE = 4-mode photon-number Fock distribution Shannon entropy.
//   positive |1,1,0,0> → 5-stage 50:50 BS cascade → 10 distinct Fock states,
//                        H ≈ 1.6233 nat (≥ 0.5 nat = G1)
//   vacuum   |0,0,0,0> → same circuit → stays |0,0,0,0>, H = 0 (G2 sign-flip)
//   SLOS strong-sim    → byte-identical 2-run sha (G3)
//   backend_name       == "perceval_slos_fock" (G4 facade contract)
//
// USAGE
//   hexa run anima-physics/photonic/cloud_facade_poc.hexa
//   hexa run anima-physics/photonic/cloud_facade_poc.hexa --selftest
//
// PAIRS
//   anima-physics/quantum/cloud_facade_poc.hexa   sibling A (quantum)
//   anima-physics/physics.hexa                    photonic_engine() stub site
//                                                 (this cycle = isolated POC; no edit)
//   tool/anima_train_ia3.hexa                     raw#9 emit-helper template
//
// raw#9 hexa-only strict / raw#37 transient helper / raw#15 SSOT this file

let SCHEMA            = "anima_physics/cloud_facade_photonic/1"
let BACKEND_NAME      = "perceval_slos_fock"
let SDK_PRIMARY       = "strawberryfields"
let SDK_USED          = "perceval"
let SCRIPT_PATH       = "scripts/anima_physics_photonic_probe.py"
let VENV_PYTHON       = "anima-physics/.venv/bin/python3"
let CUTOFF_DIM        = 4
let N_MODES           = 4

// G1 — positive entropy must be ≥ 0.5 nat (4-mode meaningful distribution)
let G1_MIN_ENTROPY    = 0.5

// G2 — vacuum entropy must be < 1e-9 (effectively zero)
let G2_VACUUM_TOL     = 0.000000001

// frozen substrate_backend enum (design-only — facade returns the chosen value).
let BACKEND_LOCAL     = "local_hexa"
let BACKEND_QSIM      = "cloud_sim_qiskit_aer"
let BACKEND_QREAL     = "cloud_real_ibm_q"
let BACKEND_PSF       = "cloud_sim_strawberryfields_fock"
let BACKEND_PERC      = "cloud_sim_perceval"
let BACKEND_XANADU    = "cloud_real_xanadu_x"
let BACKEND_QUANDELA  = "cloud_real_quandela_ascella"

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

// Run the raw#37 helper for one circuit kind. Returns the raw stdout JSON line.
fn invoke_probe(circuit_kind: string, cutoff_dim: int) -> string {
    let cmd = VENV_PYTHON + " " + SCRIPT_PATH +
              " --circuit " + circuit_kind +
              " --cutoff_dim " + to_string(cutoff_dim)
    let out = exec(cmd)
    return out.trim()
}

// Compute sha256 of a string via shell.
fn sha256_hex(s: string) -> string {
    let cmd = "printf '%s' " + shell_escape(s) + " | shasum -a 256 | cut -c1-64"
    return exec(cmd).trim()
}

// Extract a numeric field from JSON via awk (no python parse — keep raw#9 strict).
fn extract_float(json_line: string, key: string) -> float {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\"; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); m=match(rest, /-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?/); if (m==0) { print \"\"; exit } print substr(rest, m, RLENGTH) }'"
    let r = exec(cmd).trim()
    if r == "" { return -999999.0 }
    return to_float(r)
}

// Extract a string field from JSON via awk.
fn extract_string(json_line: string, key: string) -> string {
    let cmd = "printf '%s' " + shell_escape(json_line) +
        " | awk -v k=" + shell_escape(key) +
        " 'BEGIN{ q=\"\\\"\" } { s=$0; pat=q k q \":[ ]*\" q; n=match(s, pat); if (n==0) { print \"\"; exit } rest=substr(s, n+RLENGTH); m=index(rest, q); if (m==0) { print \"\"; exit } print substr(rest, 1, m-1) }'"
    return exec(cmd).trim()
}

fn fabs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn run_facade() -> bool {
    println("[cloud_facade_poc] backend=" + BACKEND_PERC +
            " sdk=" + SDK_USED +
            " cutoff_dim=" + to_string(CUTOFF_DIM) +
            " n_modes=" + to_string(N_MODES))

    // 1. positive probe (twice for byte-identical check)
    let pos_run1 = invoke_probe("positive", CUTOFF_DIM)
    let pos_run2 = invoke_probe("positive", CUTOFF_DIM)
    let pos_sha1 = sha256_hex(pos_run1)
    let pos_sha2 = sha256_hex(pos_run2)
    let pos_entropy = extract_float(pos_run1, "entropy_photon_number_nat")
    let pos_circuit_sha = extract_string(pos_run1, "sha256_circuit")
    let pos_backend = extract_string(pos_run1, "backend_name")
    let pos_sdk = extract_string(pos_run1, "sdk_used")
    let pos_sdk_ver = extract_string(pos_run1, "sdk_version")

    println("[positive] entropy_nat=" + to_string(pos_entropy))
    println("[positive] backend=" + pos_backend + " sdk=" + pos_sdk + " ver=" + pos_sdk_ver)
    println("[positive] circuit_sha256=" + pos_circuit_sha)
    println("[positive] run1_sha=" + pos_sha1)
    println("[positive] run2_sha=" + pos_sha2)

    // 2. vacuum baseline probe (negative falsify)
    let vac_run1 = invoke_probe("vacuum", CUTOFF_DIM)
    let vac_entropy = extract_float(vac_run1, "entropy_photon_number_nat")
    println("[vacuum] entropy_nat=" + to_string(vac_entropy))

    // 3. Gates
    let g1 = pos_entropy >= G1_MIN_ENTROPY
    let g2 = fabs_f(vac_entropy) < G2_VACUUM_TOL && vac_entropy < pos_entropy
    let g3 = pos_sha1 == pos_sha2
    let g4 = pos_backend == BACKEND_NAME

    if g1 { println("G1 PASS — positive entropy=" + to_string(pos_entropy) + " >= " + to_string(G1_MIN_ENTROPY)) } else { println("G1 FAIL — positive entropy=" + to_string(pos_entropy) + " < " + to_string(G1_MIN_ENTROPY)) }
    if g2 { println("G2 PASS — vacuum=" + to_string(vac_entropy) + " ≈ 0 (sign-flip vs positive=" + to_string(pos_entropy) + ")") } else { println("G2 FAIL — vacuum=" + to_string(vac_entropy) + " not zero or not < positive") }
    if g3 { println("G3 PASS — byte-identical sha=" + pos_sha1) } else { println("G3 FAIL — sha1=" + pos_sha1 + " sha2=" + pos_sha2) }
    if g4 { println("G4 PASS — backend=" + pos_backend + " == " + BACKEND_NAME) } else { println("G4 FAIL — backend=" + pos_backend + " != " + BACKEND_NAME) }

    let all_pass = g1 && g2 && g3 && g4

    // 4. Marker JSON
    let marker_dir = "state/v10_anima_physics_cloud_facade/poc_photonic_strawberryfields"
    let _ = exec("mkdir -p " + marker_dir)
    let marker_path = marker_dir + "/marker.json"

    let mut verdict = "FAIL"
    if all_pass { verdict = "PASS" }
    // SF was attempted but blocked; if Perceval ran successfully, mark verdict accordingly.
    let mut degraded_reason = ""
    if pos_sdk != SDK_PRIMARY {
        degraded_reason = "strawberryfields_blocked_py314_scipy_simps_removed_perceval_fallback"
    }
    if all_pass && degraded_reason != "" {
        verdict = "PASS_DEGRADED_SDK_FALLBACK"
    }

    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()

    let mut j = "{\n"
    j = j + "  \"schema\": \"" + SCHEMA + "\",\n"
    j = j + "  \"cycle\": \"anima_physics_cloud_facade_poc_photonic_strawberryfields\",\n"
    j = j + "  \"verdict\": \"" + verdict + "\",\n"
    j = j + "  \"sdk_primary_attempted\": \"" + SDK_PRIMARY + "\",\n"
    j = j + "  \"sdk_used\": \"" + pos_sdk + "\",\n"
    j = j + "  \"sdk_version\": \"" + pos_sdk_ver + "\",\n"
    j = j + "  \"sdk_fallback_reason\": \"" + degraded_reason + "\",\n"
    j = j + "  \"backend\": \"" + BACKEND_PERC + "\",\n"
    j = j + "  \"backend_name\": \"" + pos_backend + "\",\n"
    j = j + "  \"n_modes\": " + to_string(N_MODES) + ",\n"
    j = j + "  \"cutoff_dim\": " + to_string(CUTOFF_DIM) + ",\n"
    j = j + "  \"gates\": {\n"
    j = j + "    \"G1\": " + to_string(g1) + ",\n"
    j = j + "    \"G2\": " + to_string(g2) + ",\n"
    j = j + "    \"G3\": " + to_string(g3) + ",\n"
    j = j + "    \"G4\": " + to_string(g4) + "\n"
    j = j + "  },\n"
    j = j + "  \"positive_entropy\": " + to_string(pos_entropy) + ",\n"
    j = j + "  \"vacuum_entropy\": " + to_string(vac_entropy) + ",\n"
    j = j + "  \"g1_min_entropy_nat\": " + to_string(G1_MIN_ENTROPY) + ",\n"
    j = j + "  \"g2_vacuum_tol\": " + to_string(G2_VACUUM_TOL) + ",\n"
    j = j + "  \"circuit_sha256\": \"" + pos_circuit_sha + "\",\n"
    j = j + "  \"byte_identical_run1_sha\": \"" + pos_sha1 + "\",\n"
    j = j + "  \"byte_identical_run2_sha\": \"" + pos_sha2 + "\",\n"
    j = j + "  \"byte_identical_match\": " + to_string(g3) + ",\n"
    j = j + "  \"substrate_backend_enum\": [\"" + BACKEND_LOCAL + "\", \"" + BACKEND_QSIM + "\", \"" + BACKEND_QREAL + "\", \"" + BACKEND_PSF + "\", \"" + BACKEND_PERC + "\", \"" + BACKEND_XANADU + "\", \"" + BACKEND_QUANDELA + "\"],\n"
    j = j + "  \"files\": [\n"
    j = j + "    \"" + SCRIPT_PATH + "\",\n"
    j = j + "    \"anima-physics/photonic/cloud_facade_poc.hexa\",\n"
    j = j + "    \"" + marker_path + "\"\n"
    j = j + "  ],\n"
    j = j + "  \"limits_raw_10_honest\": [\n"
    j = j + "    \"perceval SLOS = ideal noiseless strong-simulation Fock backend; NOT real photonic hardware (Xanadu X-series / Quandela Ascella required for Phase 2)\",\n"
    j = j + "    \"strawberryfields was the primary SDK candidate but blocked: scipy 1.17 (only py3.14 wheel) removed scipy.integrate.simps while sf 0.23.0 still imports it; scipy<1.14 has no py3.14 wheel and source-build fails — fell back to perceval-quandela 1.1.0\",\n"
    j = j + "    \"cutoff_dim=4 truncates Fock space; |1,1,0,0> 5-stage BS cascade max occupation = 2 so cutoff 4 is non-binding here, but real-hardware non-Gaussian states would saturate fast\",\n"
    j = j + "    \"4-mode POC covers 2 of 8 substrate platforms (with sibling quantum); neuromorphic/fpga/cmos/memristor/superconducting/analog still TODO\",\n"
    j = j + "    \"substrate_backend enum = design only this cycle; physics.hexa photonic_engine() stub unmodified (isolated POC proof, sibling C boundary respected)\",\n"
    j = j + "    \"photon-number Shannon entropy is a Φ-relevant proxy (Fock-basis distribution diversity) but NOT IIT Φ proper — same caveat as sibling quantum bipartition entropy\",\n"
    j = j + "    \"raw#9 strict respected via exec(awk/sha/python3); helper script is raw#37 transient (main-only, no library)\"\n"
    j = j + "  ],\n"
    j = j + "  \"next_phase\": \"photonic real hardware (Xanadu Cloud X-series — API key required) OR neuromorphic substrate (Loihi 2 / SpiNNaker 2) POC fan-out\",\n"
    j = j + "  \"cost_usd\": 0.0,\n"
    j = j + "  \"timestamp\": \"" + ts + "\"\n"
    j = j + "}\n"

    write_file(marker_path, j)
    println("[marker] " + marker_path)

    if all_pass {
        println("[cloud_facade_poc] 4/4 PASS — POC photonic cloud-facade VERIFIED (sdk=" + pos_sdk + ")")
        return true
    }
    println("[cloud_facade_poc] verdict=" + verdict)
    return false
}

fn cmd_selftest() {
    println("── photonic cloud_facade_poc selftest ──")
    let cmd = "test -f " + VENV_PYTHON + " && echo y || echo n"
    let venv_ok = exec(cmd).trim()
    println("venv_python_exists=" + venv_ok)
    let cmd2 = "test -f " + SCRIPT_PATH + " && echo y || echo n"
    let script_ok = exec(cmd2).trim()
    println("helper_script_exists=" + script_ok)
    if venv_ok == "y" {
        let pv = exec(VENV_PYTHON + " -c 'import perceval; print(perceval.__version__)'").trim()
        println("perceval_version=" + pv)
    }
    println("selftest=ok")
    println("DONE")
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" { selftest = true; i = i + 1; continue }
        i = i + 1
    }
    if selftest {
        cmd_selftest()
        exit(0)
    }
    let ok = run_facade()
    if ok { exit(0) }
    exit(1)
}

main()
