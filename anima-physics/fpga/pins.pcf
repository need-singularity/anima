# pins.pcf — iCE40UP5K-B-EVN Pin Constraints
# Lattice iCE40UP5K in SG48 package
# Board: iCE40UP5K-B-EVN Evaluation Board
#
# Consciousness Ring: 8 cells, UART output, RGB LEDs

# ── UART ──
set_io pin_tx       4    # IOB_8a  — UART TX to host (directly on FTDI header)

# ── External Input (optional, tie to GND if unused) ──
set_io pin_in0      2    # IOB_6a
set_io pin_in1      46   # IOB_0a
set_io pin_in2      47   # IOB_2a
set_io pin_in3      44   # IOB_3b_G6
set_io pin_in4      48   # IOB_4a
set_io pin_in5      45   # IOB_5b
set_io pin_in6      6    # IOT_46b_G0
set_io pin_in7      9    # IOT_44b

# ── External Reset (active LOW, optional — internal POR handles reset) ──
set_io pin_rst      10   # IOT_42b

# ── RGB LED (iCE40UP5K-B-EVN has dedicated RGB LED driver pins) ──
set_io led_red      39   # RGB0
set_io led_green    40   # RGB1
set_io led_blue     41   # RGB2
