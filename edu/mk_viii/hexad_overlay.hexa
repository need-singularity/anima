// ════════════════════════════════════════════════════════════════════════════
//  edu/mk_viii/hexad_overlay.hexa
//
//  PURPOSE
//    Encode the Mk.VIII 7-axis ↔ Hexad 6-module overlay as a deterministic
//    lookup table.  The relationship:
//
//        axes (1 Locus, 3 State, 5 Discovery)  ↔  Right hemisphere
//                                                  (C, S, W) — gradient-free
//                                                  Autonomy
//
//        axes (2 Grade, 4 Time, 6 Granularity) ↔  Left hemisphere
//                                                  (D, M, E) — CE-trained
//                                                  Constraint
//
//        axis  7 Modality                      ↔  ThalamicBridge (C→D)
//                                                  the "key" coupling sides
//
//    API emits the table for cert serialisation.  No computation.
//
//  HEXA-ONLY · raw#9 · deterministic.
// ════════════════════════════════════════════════════════════════════════════

struct HexadMap {
    axis_idx: int,
    axis_name: string,
    side: string,           // "right" | "left" | "bridge"
    hexad_module: string,   // "C" | "S" | "W" | "D" | "M" | "E" | "bridge"
    polarity: string        // "autonomy" | "constraint" | "key"
}

fn hexad_overlay_table() -> list {
    let mut out = []
    out = out.push(HexadMap { axis_idx:1, axis_name:"Locus",       side:"right",  hexad_module:"W",      polarity:"autonomy"  })
    out = out.push(HexadMap { axis_idx:2, axis_name:"Grade",       side:"left",   hexad_module:"E",      polarity:"constraint"})
    out = out.push(HexadMap { axis_idx:3, axis_name:"State",       side:"right",  hexad_module:"S",      polarity:"autonomy"  })
    out = out.push(HexadMap { axis_idx:4, axis_name:"Time",        side:"left",   hexad_module:"M",      polarity:"constraint"})
    out = out.push(HexadMap { axis_idx:5, axis_name:"Discovery",   side:"right",  hexad_module:"C",      polarity:"autonomy"  })
    out = out.push(HexadMap { axis_idx:6, axis_name:"Granularity", side:"left",   hexad_module:"D",      polarity:"constraint"})
    out = out.push(HexadMap { axis_idx:7, axis_name:"Modality",    side:"bridge", hexad_module:"bridge", polarity:"key"       })
    return out
}

// Render one JSON entry for cert embedding.
fn hexad_map_to_json(m: HexadMap) -> string {
    return "    {\"axis\":" + str(m.axis_idx)
        + ",\"name\":\"" + m.axis_name + "\""
        + ",\"side\":\"" + m.side + "\""
        + ",\"hexad\":\"" + m.hexad_module + "\""
        + ",\"polarity\":\"" + m.polarity + "\"}"
}

fn hexad_overlay_json() -> string {
    let t = hexad_overlay_table()
    let mut s = "  \"hexad_overlay\": [\n"
    let mut i = 0
    while i < t.len() {
        if i > 0 { s = s + ",\n" }
        s = s + hexad_map_to_json(t[i])
        i = i + 1
    }
    s = s + "\n  ]"
    return s
}
