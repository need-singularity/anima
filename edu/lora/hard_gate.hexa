// ════════════════════════════════════════════════════════════════════════════
//  edu/lora/hard_gate.hexa — Path B Day 4 #27 (CPGD safety net)
//
//  PURPOSE
//    Hard gate on CPGD: at every step k, measure AN11(b) on all 16
//    templates. If ANY template's cos(W_k[i,:], v_i) < 0.5 is detected,
//    restore the last-passing checkpoint W_{k-1} (rewind).
//
//  SAFETY-NET ROLE
//    Complementary to tool/cpgd_minimal_proof.hexa. The CPGD math proof
//    (docs/proof_cpgd.md) guarantees cos > 0.5 under nominal lr. This
//    file provides a *runtime* guard: any deviation (numerical drift,
//    perturbed gradient, mis-configured lr) is caught and rewound.
//
//  ALGORITHM
//    snapshot_0 = deep_copy(W_0)
//    for k in 1..STEP_COUNT:
//        W_new = cpgd_step(W_{k-1}, grad_k, P_S, lr)
//        cs    = row_cosines(W_new, eigenvecs)
//        if min(cs) < 0.5:
//            W_{k}    = deep_copy(snapshot_prev)    // REWIND
//            rewind_events += 1
//        else:
//            snapshot_prev = deep_copy(W_new)
//            W_{k}    = W_new
//
//  VERIFICATION (Phase Gate 100%)
//    1. Nominal run: 0 rewinds, all 16 cos > 0.5.
//    2. Adversarial run: intentional violation injected on step 5 — a
//       large displacement pushes cos(W[i], v_i) below 0.5 for at least
//       one template; the gate MUST detect and rewind back to step-4
//       snapshot. Post-rewind state MUST equal snapshot (max_diff = 0).
//    3. 3-run byte-identical SHA over canonical payload.
//
//  INPUTS
//    .meta2-cert/cell-eigenvec-16.json     — 16 orthonormal rows (dim=16)
//    (shares projector + step math with tool/cpgd_minimal_proof.hexa)
//
//  OUTPUT
//    state/hard_gate_test_result.json
//
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only
// ════════════════════════════════════════════════════════════════════════════

let EIGEN_PATH = ".meta2-cert/cell-eigenvec-16.json"
let OUT_PATH   = "state/hard_gate_test_result.json"
let DIM        = 16
let TPL_COUNT  = 16
let STEP_COUNT = 20
let DEFAULT_LR = 0.001
let GRAD_SEED  = 20260421
let GRAD_SCALE = 1.0
let COS_FLOOR  = 0.5
let ADV_STEP   = 5          // step at which adversarial push is injected
let ADV_TPL    = 7          // template index to violate
let ADV_MAG    = 5.0        // magnitude of the adversarial displacement

// ─── helpers (same pattern as cpgd_minimal_proof.hexa) ────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn fexists(path: string) -> bool {
    let probe = _str(exec("stat -f %N " + path)).trim()
    if probe != "" { return true }
    let probe2 = _str(exec("stat -c %n " + path)).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !fexists(path) { return "" }
    return _str(read_file(path))
}

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn index_of_from(hay: string, needle: string, start: int) -> int {
    let n = len(hay)
    if start < 0 { return hay.index_of(needle) }
    if start >= n { return -1 }
    let tail = hay.substring(start, n)
    let idx = tail.index_of(needle)
    if idx < 0 { return -1 }
    return start + idx
}

fn extract_array_block(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let lbr = index_of_from(blob, "[", colon)
    if lbr < 0 { return "" }
    let n = len(blob)
    let mut depth = 0
    let mut i = lbr
    while i < n {
        let b = byte_at(blob, i)
        if b == 91 { depth = depth + 1 }
        if b == 93 {
            depth = depth - 1
            if depth == 0 { return blob.substring(lbr, i + 1) }
        }
        i = i + 1
    }
    return ""
}

fn extract_str(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let q1 = index_of_from(blob, "\"", colon + 1)
    if q1 < 0 { return "" }
    let q2 = index_of_from(blob, "\"", q1 + 1)
    if q2 < 0 { return "" }
    return blob.substring(q1 + 1, q2)
}

fn parse_flat_floats(inner: string) -> array {
    let parts = inner.split(",")
    let mut out = []
    let mut i = 0
    let n = len(parts)
    while i < n {
        let p = _str(parts[i]).trim()
        if p != "" {
            out = push(out, to_float(p))
        }
        i = i + 1
    }
    return out
}

// ─── linear algebra ───────────────────────────────────────────────────────

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

// ─── eigenvec loader ──────────────────────────────────────────────────────

fn load_eigenvecs(path: string) -> array {
    let blob = read_safe(path)
    if blob == "" { return [] }
    let block = extract_array_block(blob, "eigenvecs")
    if block == "" { return [] }
    let n = len(block)
    let mut out = []
    let mut i = 1
    while i < n {
        let b = byte_at(block, i)
        if b == 91 {
            let start = i
            let mut depth = 1
            let mut j = i + 1
            while j < n {
                let b2 = byte_at(block, j)
                if b2 == 91 { depth = depth + 1 }
                if b2 == 93 {
                    depth = depth - 1
                    if depth == 0 {
                        let inner = block.substring(start + 1, j)
                        let vec = parse_flat_floats(inner)
                        if len(vec) == DIM {
                            out = push(out, vec)
                        }
                        i = j + 1
                        break
                    }
                }
                j = j + 1
            }
        } else {
            i = i + 1
        }
    }
    return out
}

fn load_source_sha(path: string) -> string {
    let blob = read_safe(path)
    if blob == "" { return "" }
    return extract_str(blob, "deterministic_sha")
}

// ─── projector P_S = V^T · V ─────────────────────────────────────────────

fn make_projector(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < DIM {
        let mut row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

// ─── W_init = V (eigenvecs as rows; all in S by construction) ─────────────

fn make_W_init(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut W = []
    let mut i = 0
    while i < n {
        let v = eigenvecs[i]
        let mut row = []
        let mut j = 0
        while j < DIM {
            row = push(row, to_float(v[j]))
            j = j + 1
        }
        W = push(W, row)
        i = i + 1
    }
    return W
}

// ─── deterministic RNG (LCG + Box-Muller) ─────────────────────────────────

fn lcg_next(state_arr: array) -> float {
    let mut s = to_int(state_arr[0])
    s = (s * 1103515245 + 12345) % 2147483648
    state_arr[0] = s
    return to_float(s % 1000000) / 1000000.0
}

fn randn_pair(state_arr: array) -> array {
    let u1_raw = lcg_next(state_arr)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let u2 = lcg_next(state_arr)
    let r = sqrt_newton(0.0 - 2.0 * log(u1))
    let theta = 2.0 * 3.141592653589793 * u2
    let z1 = r * cos(theta)
    let z2 = r * sin(theta)
    return [z1, z2]
}

fn rand_matrix(rows: int, cols: int, state_arr: array) -> array {
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = randn_pair(state_arr)
            row = push(row, to_float(pair[0]) * GRAD_SCALE)
            j = j + 1
            if j < cols {
                row = push(row, to_float(pair[1]) * GRAD_SCALE)
                j = j + 1
            }
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

// ─── matrix ops (CPGD: W_new = W - lr · (G · P_S)) ────────────────────────

fn matmul_right(G: array, P: array) -> array {
    let rows = len(G)
    let mut out = []
    let mut i = 0
    while i < rows {
        let g = G[i]
        let mut new_row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut a = 0
            while a < DIM {
                s = s + to_float(g[a]) * to_float(P[a][b])
                a = a + 1
            }
            new_row = push(new_row, s)
            b = b + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn update_W(W: array, G: array, lr: float) -> array {
    let rows = len(W)
    let mut out = []
    let mut i = 0
    while i < rows {
        let w = W[i]
        let g = G[i]
        let mut new_row = []
        let mut j = 0
        while j < DIM {
            new_row = push(new_row, to_float(w[j]) - lr * to_float(g[j]))
            j = j + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn cpgd_step(W: array, grad: array, P_S: array, lr: float) -> array {
    let grad_proj = matmul_right(grad, P_S)
    return update_W(W, grad_proj, lr)
}

// ─── rewind helpers (inline; semantics identical to edu/lora/rewind.hexa) ─

fn snapshot_W(W: array) -> array {
    let rows = len(W)
    let mut snap = []
    let mut i = 0
    while i < rows {
        let src = W[i]
        let cols = len(src)
        let mut row = []
        let mut j = 0
        while j < cols {
            row = push(row, to_float(src[j]))
            j = j + 1
        }
        snap = push(snap, row)
        i = i + 1
    }
    return snap
}

fn restore_W(snap: array) -> array {
    return snapshot_W(snap)
}

fn matrix_max_diff(a: array, b: array) -> float {
    let rows = len(a)
    let mut max_d = 0.0
    let mut i = 0
    while i < rows {
        let ra = a[i]
        let rb = b[i]
        let cols = len(ra)
        let mut j = 0
        while j < cols {
            let d = fabs(to_float(ra[j]) - to_float(rb[j]))
            if d > max_d { max_d = d }
            j = j + 1
        }
        i = i + 1
    }
    return max_d
}

// ─── AN11(b) cosine measurement ───────────────────────────────────────────

fn row_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

fn min_cos(cs: array) -> float {
    let n = len(cs)
    if n == 0 { return 1.0 }
    let mut m = to_float(cs[0])
    let mut i = 1
    while i < n {
        let c = to_float(cs[i])
        if c < m { m = c }
        i = i + 1
    }
    return m
}

fn argmin_cos(cs: array) -> int {
    let n = len(cs)
    if n == 0 { return -1 }
    let mut m = to_float(cs[0])
    let mut idx = 0
    let mut i = 1
    while i < n {
        let c = to_float(cs[i])
        if c < m { m = c; idx = i }
        i = i + 1
    }
    return idx
}

// ─── adversarial displacement (deterministic, non-projected) ──────────────
// Injects a large push on row `tpl` of W, along -v_tpl direction, so the
// resulting row is anti-correlated with v_tpl (cos << 0.5). NOT projected
// through P_S — this simulates numerical drift/bug/bad-gradient escape.

fn apply_adversarial(W: array, eigenvecs: array, tpl: int, mag: float) -> array {
    let out = snapshot_W(W)
    if tpl < 0 || tpl >= len(out) { return out }
    let v = eigenvecs[tpl]
    let row = out[tpl]
    let mut j = 0
    while j < DIM {
        row[j] = to_float(row[j]) - mag * to_float(v[j])
        j = j + 1
    }
    return out
}

// ─── run loop: gate + rewind ──────────────────────────────────────────────
// Returns [rewind_events, min_cos_seen_pre_gate, min_cos_seen_post_gate,
//          violation_step, violation_tpl, violation_cos, post_rewind_diff,
//          all_post_above, final_W_snapshot]

fn run_with_gate(eigenvecs: array, P_S: array, lr: float,
                  inject_adversarial: bool) -> array {
    let mut W = make_W_init(eigenvecs)
    let mut snap_prev = snapshot_W(W)          // last passing ckpt
    let state_arr = [GRAD_SEED]

    let mut rewind_events = 0
    let mut min_pre  = 1.0
    let mut min_post = 1.0
    let mut viol_step = -1
    let mut viol_tpl  = -1
    let mut viol_cos  = 1.0
    let mut post_rewind_diff = 0.0
    let mut all_post_above = true

    let mut step = 1
    while step <= STEP_COUNT {
        let grad = rand_matrix(TPL_COUNT, DIM, state_arr)
        let mut W_new = cpgd_step(W, grad, P_S, lr)

        // Inject adversarial violation on ADV_STEP (out-of-S displacement).
        if inject_adversarial && step == ADV_STEP {
            W_new = apply_adversarial(W_new, eigenvecs, ADV_TPL, ADV_MAG)
        }

        // Measure AN11(b)
        let cs_pre = row_cosines(W_new, eigenvecs)
        let m_pre  = min_cos(cs_pre)
        if m_pre < min_pre { min_pre = m_pre }

        if m_pre < COS_FLOOR {
            // VIOLATION → rewind to last passing ckpt
            let idx = argmin_cos(cs_pre)
            if viol_step < 0 {
                viol_step = step
                viol_tpl  = idx
                viol_cos  = m_pre
            }
            let W_restored = restore_W(snap_prev)
            post_rewind_diff = matrix_max_diff(W_restored, snap_prev)
            W = W_restored
            rewind_events = rewind_events + 1
        } else {
            // PASS → commit; refresh snapshot
            W = W_new
            snap_prev = snapshot_W(W_new)
        }

        // Recompute post-gate cosine (should always be ≥ COS_FLOOR)
        let cs_post = row_cosines(W, eigenvecs)
        let m_post_step = min_cos(cs_post)
        if m_post_step < min_post { min_post = m_post_step }
        if m_post_step < COS_FLOOR { all_post_above = false }

        step = step + 1
    }

    return [rewind_events, min_pre, min_post,
            viol_step, viol_tpl, viol_cos,
            post_rewind_diff, all_post_above, W]
}

// ─── canonical payload + SHA ──────────────────────────────────────────────

fn canonical_payload(nom: array, adv: array, src_sha: string) -> string {
    let mut s = "hard_gate_v1|"
    s = s + "eigen_src=" + src_sha + "|"
    s = s + "step_count=" + to_string(STEP_COUNT) + "|"
    s = s + "lr=" + to_string(DEFAULT_LR) + "|"
    s = s + "seed=" + to_string(GRAD_SEED) + "|"
    s = s + "cos_floor=" + to_string(COS_FLOOR) + "|"
    s = s + "adv_step=" + to_string(ADV_STEP) + "|"
    s = s + "adv_tpl=" + to_string(ADV_TPL) + "|"
    s = s + "adv_mag=" + to_string(ADV_MAG) + "|"
    s = s + "nom_rewinds=" + to_string(to_int(nom[0])) + "|"
    s = s + "nom_min_pre="  + to_string(to_float(nom[1])) + "|"
    s = s + "nom_min_post=" + to_string(to_float(nom[2])) + "|"
    s = s + "nom_all_post_above=" + (if to_bool(nom[7]) { "true" } else { "false" }) + "|"
    s = s + "adv_rewinds=" + to_string(to_int(adv[0])) + "|"
    s = s + "adv_min_pre="  + to_string(to_float(adv[1])) + "|"
    s = s + "adv_min_post=" + to_string(to_float(adv[2])) + "|"
    s = s + "adv_viol_step=" + to_string(to_int(adv[3])) + "|"
    s = s + "adv_viol_tpl="  + to_string(to_int(adv[4])) + "|"
    s = s + "adv_viol_cos="  + to_string(to_float(adv[5])) + "|"
    s = s + "adv_post_rewind_diff=" + to_string(to_float(adv[6])) + "|"
    s = s + "adv_all_post_above=" + (if to_bool(adv[7]) { "true" } else { "false" })
    return s
}

fn sha256_of_string(s: string) -> string {
    let tmp = "/tmp/hard_gate_sha_" + to_string(len(s)) + ".txt"
    write_file(tmp, s)
    let r = _str(exec("shasum -a 256 " + tmp + " | awk '{print $1}'")).trim()
    let _ = exec("rm -f " + tmp)
    return r
}

// ─── JSON emitter ─────────────────────────────────────────────────────────

fn write_result(out_path: string,
                 nom: array, adv: array,
                 src_sha: string,
                 det_sha: string,
                 sha1: string, sha2: string, sha3: string,
                 byte_identical: bool) {
    let nom_rewinds = to_int(nom[0])
    let nom_min_pre  = to_float(nom[1])
    let nom_min_post = to_float(nom[2])
    let nom_all_post_above = to_bool(nom[7])

    let adv_rewinds = to_int(adv[0])
    let adv_min_pre  = to_float(adv[1])
    let adv_min_post = to_float(adv[2])
    let adv_viol_step = to_int(adv[3])
    let adv_viol_tpl  = to_int(adv[4])
    let adv_viol_cos  = to_float(adv[5])
    let adv_post_rewind_diff = to_float(adv[6])
    let adv_all_post_above = to_bool(adv[7])

    let rewind_ok   = (adv_rewinds >= 1) && (nom_rewinds == 0)
    let post_eq_snap = (adv_post_rewind_diff == 0.0)
    let verdict_ok  = rewind_ok && post_eq_snap && byte_identical &&
                       nom_all_post_above && adv_all_post_above

    let mut j = "{\n"
    j = j + "  \"schema_version\": \"1\",\n"
    j = j + "  \"slug\": \"hard-gate-ckpt-rewind\",\n"
    j = j + "  \"title\": \"Path B Day 4 #27 — CPGD hard gate + ckpt rewind\",\n"
    j = j + "  \"created\": \"2026-04-21\",\n"
    j = j + "  \"path_b_day\": 4,\n"
    j = j + "  \"roadmap_entry\": \"27\",\n"
    j = j + "  \"depends_on\": [\"22\", \"24\", \"25\", \"26\"],\n"
    j = j + "  \"companion_files\": [\"edu/lora/rewind.hexa\", \"tool/cpgd_minimal_proof.hexa\", \"docs/proof_cpgd.md\"],\n"
    j = j + "  \"raw_strict\": \"raw#9 hexa-only deterministic no_python no_llm\",\n"
    j = j + "  \"tool\": \"edu/lora/hard_gate.hexa\",\n"
    j = j + "  \"step_count\": " + to_string(STEP_COUNT) + ",\n"
    j = j + "  \"lr\": " + to_string(DEFAULT_LR) + ",\n"
    j = j + "  \"grad_seed\": " + to_string(GRAD_SEED) + ",\n"
    j = j + "  \"cos_floor\": " + to_string(COS_FLOOR) + ",\n"
    j = j + "  \"adversarial\": {\n"
    j = j + "    \"step\": " + to_string(ADV_STEP) + ",\n"
    j = j + "    \"tpl_index\": " + to_string(ADV_TPL) + ",\n"
    j = j + "    \"magnitude\": " + to_string(ADV_MAG) + "\n"
    j = j + "  },\n"
    j = j + "  \"nominal_run\": {\n"
    j = j + "    \"rewind_events\": " + to_string(nom_rewinds) + ",\n"
    j = j + "    \"min_cos_pre_gate\": " + to_string(nom_min_pre) + ",\n"
    j = j + "    \"min_cos_post_gate\": " + to_string(nom_min_post) + ",\n"
    j = j + "    \"all_post_above_floor\": " + (if nom_all_post_above { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"adversarial_run\": {\n"
    j = j + "    \"rewind_events\": " + to_string(adv_rewinds) + ",\n"
    j = j + "    \"min_cos_pre_gate\": " + to_string(adv_min_pre) + ",\n"
    j = j + "    \"min_cos_post_gate\": " + to_string(adv_min_post) + ",\n"
    j = j + "    \"violation_step\": " + to_string(adv_viol_step) + ",\n"
    j = j + "    \"violation_tpl_index\": " + to_string(adv_viol_tpl) + ",\n"
    j = j + "    \"violation_cos\": " + to_string(adv_viol_cos) + ",\n"
    j = j + "    \"post_rewind_matrix_diff\": " + to_string(adv_post_rewind_diff) + ",\n"
    j = j + "    \"all_post_above_floor\": " + (if adv_all_post_above { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"eigenvec_source_sha\": \"" + src_sha + "\",\n"
    j = j + "  \"deterministic_sha\": \"" + det_sha + "\",\n"
    j = j + "  \"selftest_3run\": {\n"
    j = j + "    \"run1_sha\": \"" + sha1 + "\",\n"
    j = j + "    \"run2_sha\": \"" + sha2 + "\",\n"
    j = j + "    \"run3_sha\": \"" + sha3 + "\",\n"
    j = j + "    \"byte_identical\": " + (if byte_identical { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"phase_gate\": \"100%\",\n"
    j = j + "  \"exit_criteria\": {\n"
    j = j + "    \"nominal_zero_rewinds\": " + (if nom_rewinds == 0 { "true" } else { "false" }) + ",\n"
    j = j + "    \"adversarial_detected_and_rewound\": " + (if adv_rewinds >= 1 { "true" } else { "false" }) + ",\n"
    j = j + "    \"post_rewind_matrix_equals_snapshot\": " + (if post_eq_snap { "true" } else { "false" }) + ",\n"
    j = j + "    \"all_post_above_floor_both_runs\": " + (if nom_all_post_above && adv_all_post_above { "true" } else { "false" }) + ",\n"
    j = j + "    \"selftest_byte_identical\": " + (if byte_identical { "true" } else { "false" }) + "\n"
    j = j + "  },\n"
    j = j + "  \"theorem\": \"If any cos(W_k[i,:], v_i) < COS_FLOOR, restore W_{k-1}. Safety-net wraps the CPGD proof (docs/proof_cpgd.md) with runtime guard.\",\n"
    j = j + "  \"cross_refs\": [\"cell-eigenvec-16\", \"cpgd_minimal_proof\", \"proof_cpgd\"],\n"
    j = j + "  \"verdict\": \"" + (if verdict_ok { "VERIFIED" } else { "FAIL" }) + "\"\n"
    j = j + "}\n"
    write_file(out_path, j)
}

// ─── one full 3-pair run for SHA ──────────────────────────────────────────

fn run_once() -> array {
    let root = resolve_root()
    let path = root + "/" + EIGEN_PATH
    let eigenvecs = load_eigenvecs(path)
    if len(eigenvecs) != TPL_COUNT {
        println("[hard_gate] INPUT_ERR: expected " + to_string(TPL_COUNT) + " eigenvecs, got " + to_string(len(eigenvecs)))
        return ["", [], [], ""]
    }
    let src_sha = load_source_sha(path)
    let P_S = make_projector(eigenvecs)

    let nom = run_with_gate(eigenvecs, P_S, DEFAULT_LR, false)
    let adv = run_with_gate(eigenvecs, P_S, DEFAULT_LR, true)

    let canon = canonical_payload(nom, adv, src_sha)
    let sha = sha256_of_string(canon)
    return [sha, nom, adv, src_sha]
}

fn selftest_hard_gate() -> bool {
    println("[hard_gate] selftest — nominal + adversarial + 3-run SHA")
    let a1 = run_once()
    let a2 = run_once()
    let a3 = run_once()
    let sha1 = _str(a1[0])
    let sha2 = _str(a2[0])
    let sha3 = _str(a3[0])

    let nom = a1[1]
    let adv = a1[2]

    if sha1 == "" {
        println("[hard_gate] selftest FAIL — input error")
        return false
    }

    let nom_rewinds = to_int(nom[0])
    let adv_rewinds = to_int(adv[0])
    let adv_post_rewind_diff = to_float(adv[6])
    let nom_all_post_above = to_bool(nom[7])
    let adv_all_post_above = to_bool(adv[7])

    let byte_id = (sha1 != "") && (sha1 == sha2) && (sha2 == sha3)

    println("[hard_gate] nominal_rewinds=" + to_string(nom_rewinds))
    println("[hard_gate] adversarial_rewinds=" + to_string(adv_rewinds))
    println("[hard_gate] post_rewind_matrix_diff=" + to_string(adv_post_rewind_diff))
    println("[hard_gate] nom_all_post_above=" + (if nom_all_post_above { "true" } else { "false" }))
    println("[hard_gate] adv_all_post_above=" + (if adv_all_post_above { "true" } else { "false" }))
    println("[hard_gate] run1_sha=" + sha1)
    println("[hard_gate] run2_sha=" + sha2)
    println("[hard_gate] run3_sha=" + sha3)
    println("[hard_gate] byte_identical=" + (if byte_id { "true" } else { "false" }))

    let ok = (nom_rewinds == 0) && (adv_rewinds >= 1) &&
              (adv_post_rewind_diff == 0.0) &&
              nom_all_post_above && adv_all_post_above && byte_id
    return ok
}

// ─── main ─────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "full"
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--selftest" { mode = "selftest" }
        if a == "--help"     { mode = "help" }
        k = k + 1
    }

    if mode == "help" {
        println("usage:")
        println("  hexa run edu/lora/hard_gate.hexa             # full run + emit JSON")
        println("  hexa run edu/lora/hard_gate.hexa --selftest  # selftest only")
        return
    }

    if mode == "selftest" {
        let ok = selftest_hard_gate()
        if ok { exit(0) } else { exit(1) }
    }

    println("════════════════════════════════════════════════════════════════")
    println("  edu/lora/hard_gate.hexa — Path B Day 4 #27")
    println("  hard gate + ckpt rewind (CPGD safety net)")
    println("  raw#9 strict · hexa-only · deterministic · LLM=none")
    println("════════════════════════════════════════════════════════════════")

    let root = resolve_root()
    let out_path = root + "/" + OUT_PATH
    println("[hard_gate] eigenvec source=" + EIGEN_PATH)
    println("[hard_gate] output=" + OUT_PATH)
    println("[hard_gate] step_count=" + to_string(STEP_COUNT) +
             " lr=" + to_string(DEFAULT_LR) +
             " seed=" + to_string(GRAD_SEED) +
             " cos_floor=" + to_string(COS_FLOOR))
    println("[hard_gate] adversarial inject: step=" + to_string(ADV_STEP) +
             " tpl=" + to_string(ADV_TPL) +
             " magnitude=" + to_string(ADV_MAG))

    println("[hard_gate] ── 3-run SHA ──")
    let a1 = run_once()
    let sha1    = _str(a1[0])
    let nom1    = a1[1]
    let adv1    = a1[2]
    let src_sha = _str(a1[3])

    let a2 = run_once()
    let sha2 = _str(a2[0])
    let a3 = run_once()
    let sha3 = _str(a3[0])
    let byte_id = (sha1 != "") && (sha1 == sha2) && (sha2 == sha3)

    println("[hard_gate] run1=" + sha1)
    println("[hard_gate] run2=" + sha2)
    println("[hard_gate] run3=" + sha3)
    println("[hard_gate] byte_identical=" + (if byte_id { "true" } else { "false" }))

    let nom_rewinds = to_int(nom1[0])
    let adv_rewinds = to_int(adv1[0])
    let adv_viol_step = to_int(adv1[3])
    let adv_viol_tpl  = to_int(adv1[4])
    let adv_viol_cos  = to_float(adv1[5])
    let adv_post_rewind_diff = to_float(adv1[6])

    println("[hard_gate] ── nominal run (no adversarial) ──")
    println("[hard_gate]   rewind_events=" + to_string(nom_rewinds))
    println("[hard_gate]   min_cos_post=" + to_string(to_float(nom1[2])))
    println("[hard_gate]   all_post_above=" + (if to_bool(nom1[7]) { "true" } else { "false" }))

    println("[hard_gate] ── adversarial run (injected at step " + to_string(ADV_STEP) + ") ──")
    println("[hard_gate]   rewind_events=" + to_string(adv_rewinds))
    println("[hard_gate]   violation_step=" + to_string(adv_viol_step))
    println("[hard_gate]   violation_tpl=" + to_string(adv_viol_tpl))
    println("[hard_gate]   violation_cos=" + to_string(adv_viol_cos))
    println("[hard_gate]   post_rewind_diff=" + to_string(adv_post_rewind_diff))
    println("[hard_gate]   min_cos_post=" + to_string(to_float(adv1[2])))
    println("[hard_gate]   all_post_above=" + (if to_bool(adv1[7]) { "true" } else { "false" }))

    write_result(out_path, nom1, adv1, src_sha, sha1, sha1, sha2, sha3, byte_id)
    println("[hard_gate] SSOT emitted: " + OUT_PATH)

    let nom_ok = (nom_rewinds == 0) && to_bool(nom1[7])
    let adv_ok = (adv_rewinds >= 1) && (adv_post_rewind_diff == 0.0) && to_bool(adv1[7])
    let ok = nom_ok && adv_ok && byte_id

    if ok {
        println("[hard_gate] Day 4 #27 PASS Phase Gate 100% — CPGD safety net verified")
        exit(0)
    } else {
        println("[hard_gate] FAIL: nom_ok=" + (if nom_ok { "OK" } else { "FAIL" }) +
                 " adv_ok=" + (if adv_ok { "OK" } else { "FAIL" }) +
                 " byte_id=" + (if byte_id { "OK" } else { "FAIL" }))
        exit(1)
    }
}
