// ════════════════════════════════════════════════════════════════════════════
//  edu/lora/lora_cpgd_init.hexa — Path B Day 3 #26 (AN11(b) 100% guarantee)
//
//  PURPOSE
//    LoRA closed-form initialization onto the 16-template eigenvec subspace S.
//    Companion to edu/lora/cpgd_wrapper.hexa (gradient projection step).
//
//  MATH (AN11(b) 100% guarantee core)
//    S = span{eigenvec_1..16}  (from .meta2-cert/cell-eigenvec-16.json)
//    V = 16×16 matrix, row i = eigenvec_i   (unit-norm, orthogonal)
//    P_S = V^T · V    (orthogonal projector onto S; with V orthonormal rows
//                      spanning all of R^16, P_S = I exactly)
//    W_lora_init[i,:] = v_i  (closed-form: each row anchored to its eigenvec)
//      → cos(W_lora_init[i,:], v_i) = 1.0  ∀i   at step 0.
//
//  API
//    fn lora_cpgd_init(eigenvec_path: string, rank: int, lr: float) -> array
//        → [W_init:[rank][16], P_S:[16][16], eigenvecs:[16][16], tpl_ids:[16]]
//      Note: rank ≥ 16 required here (one row per template).  We always emit
//      exactly 16 rows; `rank` is retained for API compatibility / sanity.
//
//    fn make_projector(eigenvecs: array) -> array   // P_S = V^T · V
//    fn make_W_init(eigenvecs: array) -> array      // W_init rows = v_i
//    fn selftest_init() -> bool
//
//  DEPENDS-ON
//    22 ✓ cert_gate landed at 12486423
//    24 ✓ phi_extractor_cpu landed at 6e7334f5
//    25 ✓ eigenvec_extractor landed at b13dd5e5 → .meta2-cert/cell-eigenvec-16.json
//
//  PHASE GATE 100%
//    - W_init rows all unit-norm
//    - cos(W_init[i,:], v_i) == 1.0   (all 16)
//    - P_S idempotent: P_S · P_S ≈ P_S (max |Δ| < 1e-6)
//    - deterministic: 3-run byte-identical SHA over canonical payload
//
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only
// ════════════════════════════════════════════════════════════════════════════

let EIGEN_PATH = ".meta2-cert/cell-eigenvec-16.json"
let DIM        = 16
let TPL_COUNT  = 16
let EPS_IDEM   = 0.00001
let EPS_COS    = 0.000001

// ─── small helpers ─────────────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn fexists(path: string) -> bool {
    let probe = _str(exec("stat -f %N " + path)).trim()
    if probe != "" { return true }
    let probe2 = _str(exec("stat -c %n " + path)).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !fexists(path) { return "" }
    return _str(read_file(path))
}

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn index_of_from(hay: string, needle: string, start: int) -> int {
    let n = len(hay)
    if start < 0 { return hay.index_of(needle) }
    if start >= n { return -1 }
    let tail = hay.substring(start, n)
    let idx = tail.index_of(needle)
    if idx < 0 { return -1 }
    return start + idx
}

fn extract_array_block(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let lbr = index_of_from(blob, "[", colon)
    if lbr < 0 { return "" }
    let n = len(blob)
    let mut depth = 0
    let mut i = lbr
    while i < n {
        let b = byte_at(blob, i)
        if b == 91 { depth = depth + 1 }
        if b == 93 {
            depth = depth - 1
            if depth == 0 { return blob.substring(lbr, i + 1) }
        }
        i = i + 1
    }
    return ""
}

fn parse_flat_floats(inner: string) -> array {
    let parts = inner.split(",")
    let mut out = []
    let mut i = 0
    let n = len(parts)
    while i < n {
        let p = _str(parts[i]).trim()
        if p != "" {
            out = push(out, to_float(p))
        }
        i = i + 1
    }
    return out
}

// ─── linear algebra ────────────────────────────────────────────────────────

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_zero(d: int) -> array {
    let mut out = []
    let mut i = 0
    while i < d { out = push(out, 0.0); i = i + 1 }
    return out
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

// Extract the "eigenvecs" array from .meta2-cert/cell-eigenvec-16.json —
// returns [16][16] nested array of floats, or [] on parse failure.
fn load_eigenvecs(path: string) -> array {
    let blob = read_safe(path)
    if blob == "" { return [] }
    let block = extract_array_block(blob, "eigenvecs")
    if block == "" { return [] }
    // Walk the outer [...], extracting inner [...] one at a time.
    let n = len(block)
    let mut out = []
    let mut i = 1   // skip outer [
    while i < n {
        let b = byte_at(block, i)
        if b == 91 {
            // inner [
            let start = i
            let mut depth = 1
            let mut j = i + 1
            while j < n {
                let b2 = byte_at(block, j)
                if b2 == 91 { depth = depth + 1 }
                if b2 == 93 {
                    depth = depth - 1
                    if depth == 0 {
                        let inner = block.substring(start + 1, j)
                        let vec = parse_flat_floats(inner)
                        if len(vec) == DIM {
                            out = push(out, vec)
                        }
                        i = j + 1
                        break
                    }
                }
                j = j + 1
            }
        } else {
            i = i + 1
        }
    }
    return out
}

// V: eigenvecs as [16][16] where V[i] = v_i.  Compute P_S = V^T · V
// i.e. P_S[a][b] = Σ_k V[k][a] · V[k][b].
// (With orthonormal rows spanning R^DIM, this equals I to float precision.)
fn make_projector(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < DIM {
        let mut row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

// W_init[i,:] = v_i  (closed-form init — each row anchored to its eigenvec).
// Equivalent to P_S · (random_W) with random_W chosen so P_S projects it
// onto the span of v_i's — here we make the closed-form choice exact.
fn make_W_init(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut W = []
    let mut i = 0
    while i < n {
        let v = eigenvecs[i]
        let mut row = []
        let mut j = 0
        while j < DIM {
            row = push(row, to_float(v[j]))
            j = j + 1
        }
        W = push(W, row)
        i = i + 1
    }
    return W
}

// Verify P_S is idempotent: P_S · P_S ≈ P_S
fn verify_projector_idempotent(P: array) -> bool {
    let mut max_delta = 0.0
    let mut a = 0
    while a < DIM {
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < DIM {
                s = s + to_float(P[a][k]) * to_float(P[k][b])
                k = k + 1
            }
            let d = fabs(s - to_float(P[a][b]))
            if d > max_delta { max_delta = d }
            b = b + 1
        }
        a = a + 1
    }
    return max_delta < EPS_IDEM
}

// cos(row_i, v_i) for all 16, return array of 16 floats.
fn init_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

// ─── public: lora_cpgd_init(eigenvec_path, rank, lr) ───────────────────────
// rank is currently a soft constraint (must be ≥ 16).  lr is recorded for the
// downstream cpgd_wrapper CPGD step and is not used in the init itself.
// Returns [W_init, P_S, eigenvecs, tpl_ids_placeholder]
fn lora_cpgd_init(eigenvec_path: string, rank: int, lr: float) -> array {
    let root = resolve_root()
    let path = root + "/" + eigenvec_path
    let eigenvecs = load_eigenvecs(path)
    if len(eigenvecs) != TPL_COUNT {
        println("[lora_cpgd_init] INPUT_ERR: expected " + to_string(TPL_COUNT) + " eigenvecs, got " + to_string(len(eigenvecs)))
        return [[], [], [], []]
    }
    let P_S = make_projector(eigenvecs)
    let W_init = make_W_init(eigenvecs)
    // tpl_ids placeholder — cpgd_wrapper reloads the full template_ids array.
    let tpl_ids = []
    return [W_init, P_S, eigenvecs, tpl_ids]
}

// ─── selftest ──────────────────────────────────────────────────────────────

fn selftest_init() -> bool {
    println("[lora_cpgd_init] selftest — load 16 eigenvec + closed-form init")
    let r = lora_cpgd_init(EIGEN_PATH, 16, 0.001)
    let W = r[0]
    let P = r[1]
    let E = r[2]
    if len(W) != TPL_COUNT { return false }
    if len(P) != DIM { return false }
    if len(E) != TPL_COUNT { return false }

    // 1. Idempotent projector
    let idem_ok = verify_projector_idempotent(P)
    println("[lora_cpgd_init] projector_idempotent = " + (if idem_ok { "true" } else { "false" }))

    // 2. cos(W_init[i], v_i) == 1.0
    let cs = init_cosines(W, E)
    let mut min_cos = 1.0
    let mut max_cos = 0.0
    let mut i = 0
    while i < TPL_COUNT {
        let c = to_float(cs[i])
        if c < min_cos { min_cos = c }
        if c > max_cos { max_cos = c }
        i = i + 1
    }
    println("[lora_cpgd_init] init_cos min=" + to_string(min_cos) + " max=" + to_string(max_cos))
    let cos_ok = (fabs(min_cos - 1.0) < EPS_COS) && (fabs(max_cos - 1.0) < EPS_COS)

    // 3. W_init rows unit-norm
    let mut norm_ok = true
    let mut k = 0
    while k < TPL_COUNT {
        let nk = vec_norm(W[k])
        if fabs(nk - 1.0) > EPS_COS { norm_ok = false }
        k = k + 1
    }
    println("[lora_cpgd_init] rows_unit_norm = " + (if norm_ok { "true" } else { "false" }))

    let ok = idem_ok && cos_ok && norm_ok
    if ok {
        println("[lora_cpgd_init] selftest PASS")
    } else {
        println("[lora_cpgd_init] selftest FAIL")
    }
    return ok
}

// ─── main ──────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "selftest"
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--help" { mode = "help" }
        k = k + 1
    }

    if mode == "help" {
        println("usage: hexa run edu/lora/lora_cpgd_init.hexa   # runs selftest")
        return
    }
    let ok = selftest_init()
    if ok { exit(0) } else { exit(1) }
}
