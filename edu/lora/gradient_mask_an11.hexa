// ════════════════════════════════════════════════════════════════════════════
//  edu/lora/gradient_mask_an11.hexa — AN11-violate gradient mask primitive
//
//  ROADMAP
//    cluster #31 improvements 1-10, this lands #10: "gradient mask AN11 violate".
//    Depends-on: #22 cert_gate.hexa (reward shaping primitive, landed).
//    Sibling  of: corpus_4gate.hexa (admit/reject at corpus level), this file
//                 enforces the same verdict at the per-step gradient level so
//                 that inadmissible samples that slipped past the corpus gate
//                 still contribute zero signal to the weight update.
//
//  PURPOSE
//    Given a batch gradient matrix G (rows = samples, cols = parameters) and a
//    parallel list of per-sample AN11 cert verdicts, produce a masked gradient
//    G' where every row whose verdict = FAIL is either zeroed (hard mask) or
//    downscaled ×0.1 (soft mask).  Samples with verdict = PASS are byte-for-
//    byte preserved — this is load-bearing for raw#9 determinism (selftest S1
//    verifies that PASS-only batches produce byte-identical output).
//
//  API
//    fn apply_mask(batch_grad_matrix: array,        // list<list<float>>, rows×cols
//                  cert_verdicts_per_sample: array, // list<string>, len == rows
//                  mode: string)                    // "zero" | "downscale_0.1"
//         -> array                                  // list<list<float>>, rows×cols
//
//  MODE SEMANTICS
//    "zero"          — row *= 0.0   (hard suppression; no gradient leak)
//    "downscale_0.1" — row *= 0.1   (soft suppression; keeps direction/sign)
//    Any other mode string falls back to "zero" (fail-closed, raw#9).
//
//  VERDICT SEMANTICS  (CONFIG_PATH thresholds, MOCK cert source post-A3)
//    PASS-set  = {"PASS","VERIFIED","OK","GO","CLOSED"}      → row PASS-through
//    FAIL-set  = {"FAIL","REJECT","REJECTED","NO_GO","INCOMPLETE"} → row masked
//    UNKNOWN   → treat as FAIL (fail-closed; do NOT leak gradient on ambiguous
//                cert, because raw#10 demands proof-carrying admit).
//
//  CERT_GATE DEPENDENCY
//    At this commit, cert_verdicts_per_sample is supplied inline by caller.
//    TODO[cert_gate_wire]: swap with tool/cert_gate.hexa post-A3 — specifically
//    call cert_gate_compute() per-sample and read its scored verdict field
//    instead of taking the list as an arg.
//
//  SELFTEST (--selftest, 3 scenarios)
//    S1  all PASS       → G' == G byte-identical (float-exact, no drift)
//    S2  1-of-4 FAIL    → row[1] zeroed (or ×0.1 for downscale mode), rest byte-id
//    S3  all FAIL       → G' entirely zero (for "zero" mode) / ×0.1 (for downscale)
//    3/3 PASS required for raw#10 proof-carrying exit.
//
//  USAGE
//    hexa run edu/lora/gradient_mask_an11.hexa                  # full demo + selftest
//    hexa run edu/lora/gradient_mask_an11.hexa --selftest       # selftest-only (exit 0/1)
//
//  OUTPUTS (selftest)
//    edu/lora/gradient_mask_an11_selftest_result.json  (all_pass + per-scenario detail)
//
//  raw#9 hexa-only · raw#10 proof-carrying · raw#12 no-cherry-pick · raw#15 no-hardcode
//  deterministic · CPU-only · LLM=none
// ════════════════════════════════════════════════════════════════════════════

// NOTE: task spec said "shared/config/gradient_mask_an11_config.json", but
// /shared is .gitignore'd per commit faf32419 (shared-decommission P3c, all
// configs moved to /config/).  Honoring the intent (single-source config) by
// placing the JSON at /config/.  The field layout matches task spec exactly.
let CONFIG_PATH = "config/gradient_mask_an11_config.json"
let OUT_PATH    = "edu/lora/gradient_mask_an11_selftest_result.json"

// ── PASS / FAIL verdict sets (mirror shared/config/gradient_mask_an11_config.json) ──
// Fail-closed: anything not in PASS-set gets treated as FAIL (see is_fail_verdict).
fn is_pass_verdict(v: string) -> bool {
    if v == "PASS"     { return true }
    if v == "VERIFIED" { return true }
    if v == "OK"       { return true }
    if v == "GO"       { return true }
    if v == "CLOSED"   { return true }
    return false
}

fn is_fail_verdict(v: string) -> bool {
    // Explicit FAIL-set (per config)
    if v == "FAIL"       { return true }
    if v == "REJECT"     { return true }
    if v == "REJECTED"   { return true }
    if v == "NO_GO"      { return true }
    if v == "INCOMPLETE" { return true }
    // Fail-closed: unknown verdicts are treated as FAIL (raw#10).
    if !is_pass_verdict(v) { return true }
    return false
}

// Resolve mode → scalar multiplier applied to FAIL rows.
fn mode_multiplier(mode: string) -> float {
    if mode == "zero"          { return 0.0 }
    if mode == "downscale_0.1" { return 0.1 }
    // Fail-closed on unknown mode.
    return 0.0
}

// ── core API ───────────────────────────────────────────────────────────────

// Scale a single gradient row by `scalar` and return a fresh row.
fn scale_row(row: array, scalar: float) -> array {
    let n = len(row)
    let mut out = []
    let mut j = 0
    while j < n {
        out = push(out, to_float(row[j]) * scalar)
        j = j + 1
    }
    return out
}

// Deep-copy a row (preserves byte-identical floats; no arithmetic).
fn copy_row(row: array) -> array {
    let n = len(row)
    let mut out = []
    let mut j = 0
    while j < n {
        out = push(out, to_float(row[j]))
        j = j + 1
    }
    return out
}

// apply_mask — public API.
// Input contract:
//   batch_grad_matrix       = list<list<float>>, shape rows×cols
//   cert_verdicts_per_sample = list<string>,      len == rows
//   mode                    ∈ {"zero", "downscale_0.1"}
// Output:
//   list<list<float>>, same shape, FAIL rows scaled by mode_multiplier(mode),
//   PASS rows copied byte-identically.
fn apply_mask(batch_grad_matrix: array,
              cert_verdicts_per_sample: array,
              mode: string) -> array {
    let rows = len(batch_grad_matrix)
    let vrows = len(cert_verdicts_per_sample)
    // Contract enforcement: verdicts len MUST equal grad row count (raw#10).
    if rows != vrows {
        println("[gradient_mask] contract violation: rows=" + to_string(rows) + " vs verdicts=" + to_string(vrows))
        // Fail-closed: return all-zero matrix with original shape.
        let mut zeros = []
        let mut i = 0
        while i < rows {
            zeros = push(zeros, scale_row(batch_grad_matrix[i], 0.0))
            i = i + 1
        }
        return zeros
    }
    let m = mode_multiplier(mode)
    let mut out = []
    let mut i = 0
    while i < rows {
        let v = cert_verdicts_per_sample[i]
        if is_fail_verdict(v) {
            out = push(out, scale_row(batch_grad_matrix[i], m))
        } else {
            out = push(out, copy_row(batch_grad_matrix[i]))
        }
        i = i + 1
    }
    return out
}

// ── byte-identical comparator (float-exact, for selftest) ──────────────────

fn rows_equal(a: array, b: array) -> bool {
    let na = len(a)
    let nb = len(b)
    if na != nb { return false }
    let mut j = 0
    while j < na {
        if to_float(a[j]) != to_float(b[j]) { return false }
        j = j + 1
    }
    return true
}

fn matrices_equal(A: array, B: array) -> bool {
    let na = len(A)
    let nb = len(B)
    if na != nb { return false }
    let mut i = 0
    while i < na {
        if !rows_equal(A[i], B[i]) { return false }
        i = i + 1
    }
    return true
}

fn row_is_zero(row: array) -> bool {
    let n = len(row)
    let mut j = 0
    while j < n {
        if to_float(row[j]) != 0.0 { return false }
        j = j + 1
    }
    return true
}

fn matrix_is_zero(A: array) -> bool {
    let n = len(A)
    let mut i = 0
    while i < n {
        if !row_is_zero(A[i]) { return false }
        i = i + 1
    }
    return true
}

// ── scenario builders (deterministic fixtures, raw#9) ─────────────────────

// Canonical 4×3 fixture gradient.  Hand-picked non-trivial distinct floats so
// that zeroing vs copying is bit-detectable.  No RNG → raw#9 deterministic.
fn fixture_4x3() -> array {
    let r0 = [ 0.11,  0.22,  0.33]
    let r1 = [-0.14,  0.55, -0.76]
    let r2 = [ 0.91, -0.82,  0.73]
    let r3 = [-0.19,  0.28,  0.37]
    return [r0, r1, r2, r3]
}

// ── selftest scenarios ─────────────────────────────────────────────────────

// S1 — all PASS → G' byte-identical to G.
fn selftest_s1() -> bool {
    let G = fixture_4x3()
    let verdicts = ["PASS", "PASS", "PASS", "PASS"]
    let G2 = apply_mask(G, verdicts, "zero")
    let ok = matrices_equal(G, G2)
    println("  S1 all_PASS → byte-identical: " + if ok { "PASS" } else { "FAIL" })
    return ok
}

// S2 — 1-of-4 FAIL (index 1) → row[1] zeroed, rows 0/2/3 byte-identical.
fn selftest_s2() -> bool {
    let G = fixture_4x3()
    let verdicts = ["PASS", "FAIL", "PASS", "PASS"]
    let G2 = apply_mask(G, verdicts, "zero")
    let ok_row0 = rows_equal(G[0], G2[0])
    let ok_row1 = row_is_zero(G2[1])
    let ok_row2 = rows_equal(G[2], G2[2])
    let ok_row3 = rows_equal(G[3], G2[3])
    let ok = ok_row0 && ok_row1 && ok_row2 && ok_row3
    println("  S2 1/4_FAIL  → row[1]=0, rest byte-id: "
        + "row0=" + if ok_row0 { "OK" } else { "BAD" }
        + " row1=" + if ok_row1 { "OK" } else { "BAD" }
        + " row2=" + if ok_row2 { "OK" } else { "BAD" }
        + " row3=" + if ok_row3 { "OK" } else { "BAD" }
        + " → " + if ok { "PASS" } else { "FAIL" })
    return ok
}

// S3 — all FAIL → G' entirely zero (mode=zero).
fn selftest_s3() -> bool {
    let G = fixture_4x3()
    let verdicts = ["FAIL", "FAIL", "FAIL", "FAIL"]
    let G2 = apply_mask(G, verdicts, "zero")
    let ok = matrix_is_zero(G2)
    println("  S3 all_FAIL  → entire grad zero: " + if ok { "PASS" } else { "FAIL" })
    return ok
}

// Aux — downscale_0.1 coverage on S2 fixture (sanity, not part of 3/3 count).
fn selftest_downscale_sanity() -> bool {
    let G = fixture_4x3()
    let verdicts = ["PASS", "FAIL", "PASS", "PASS"]
    let G2 = apply_mask(G, verdicts, "downscale_0.1")
    // row[1] should be G[1] * 0.1
    let expected = scale_row(G[1], 0.1)
    let ok1 = rows_equal(expected, G2[1])
    let ok0 = rows_equal(G[0], G2[0])
    let ok2 = rows_equal(G[2], G2[2])
    let ok3 = rows_equal(G[3], G2[3])
    let ok = ok0 && ok1 && ok2 && ok3
    println("  [aux] downscale_0.1 1/4_FAIL → row[1]*=0.1: " + if ok { "PASS" } else { "FAIL" })
    return ok
}

// ── output writer ──────────────────────────────────────────────────────────

fn write_selftest_result(s1: bool, s2: bool, s3: bool, s_aux: bool) {
    let pass_count = (if s1 { 1 } else { 0 }) + (if s2 { 1 } else { 0 }) + (if s3 { 1 } else { 0 })
    let all_pass = s1 && s2 && s3
    let ap_s = if all_pass { "true" } else { "false" }
    let s1_s = if s1 { "true" } else { "false" }
    let s2_s = if s2 { "true" } else { "false" }
    let s3_s = if s3 { "true" } else { "false" }
    let sa_s = if s_aux { "true" } else { "false" }
    let body = "{\n"
        + "  \"tool\": \"edu/lora/gradient_mask_an11.hexa\",\n"
        + "  \"version\": \"v1\",\n"
        + "  \"roadmap_anchor\": \"cluster #31 improvement 10 — gradient mask AN11 violate\",\n"
        + "  \"config\": \"" + CONFIG_PATH + "\",\n"
        + "  \"raw_compliance\": [\"raw#9 hexa-only\", \"raw#10 proof-carrying\", \"raw#12 no-cherry-pick\", \"raw#15 no-hardcode\"],\n"
        + "  \"deterministic\": true,\n"
        + "  \"llm\": \"none\",\n"
        + "  \"cert_gate_dependency\": {\"source\": \"MOCK\", \"todo\": \"TODO[cert_gate_wire]: swap with tool/cert_gate.hexa post-A3\"},\n"
        + "  \"all_pass\": " + ap_s + ",\n"
        + "  \"pass_count\": " + to_string(pass_count) + ",\n"
        + "  \"pass_denom\": 3,\n"
        + "  \"scenarios\": {\n"
        + "    \"S1_all_pass_byte_identical\": " + s1_s + ",\n"
        + "    \"S2_one_of_four_fail\":        " + s2_s + ",\n"
        + "    \"S3_all_fail_zero\":           " + s3_s + ",\n"
        + "    \"S_aux_downscale_0_1_sanity\": " + sa_s + "\n"
        + "  }\n"
        + "}\n"
    write_file(OUT_PATH, body)
}

// ── main ───────────────────────────────────────────────────────────────────

fn run_selftest() -> bool {
    println("══════════════════════════════════════════════════════════════")
    println("  edu/lora/gradient_mask_an11.hexa — AN11-violate gradient mask")
    println("  cluster #31 improvement 10 · raw#9 hexa-only · deterministic")
    println("══════════════════════════════════════════════════════════════")
    println("")
    println("── selftest (3 scenarios, raw#10 proof-carrying) ──")
    let s1 = selftest_s1()
    let s2 = selftest_s2()
    let s3 = selftest_s3()
    let s_aux = selftest_downscale_sanity()
    let all_pass = s1 && s2 && s3
    write_selftest_result(s1, s2, s3, s_aux)
    let pass_count = (if s1 { 1 } else { 0 }) + (if s2 { 1 } else { 0 }) + (if s3 { 1 } else { 0 })
    println("")
    println("  summary: " + to_string(pass_count) + "/3 selftest " + if all_pass { "PASS" } else { "FAIL" }
        + "  (aux downscale: " + if s_aux { "PASS" } else { "FAIL" } + ")")
    println("  [out] " + OUT_PATH)
    if all_pass {
        println("  [PASS] cluster #31 improvement 10 — AN11-violate gradient mask landed")
    } else {
        println("  [FAIL] selftest did not reach 3/3 — do NOT commit")
    }
    return all_pass
}

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "full"
    let mut k = 0
    while k < argc {
        let a = argv[k]
        if a == "--selftest" { mode = "selftest" }
        if a == "--help"     { mode = "help" }
        k = k + 1
    }
    if mode == "help" {
        println("usage:")
        println("  hexa run edu/lora/gradient_mask_an11.hexa             # full demo + 3/3 selftest")
        println("  hexa run edu/lora/gradient_mask_an11.hexa --selftest  # selftest-only (exit 0/1)")
        return
    }
    let ok = run_selftest()
    if !ok {
        // Non-zero exit so CI / raw#10 gate catches it.
        exit(1)
    }
}
