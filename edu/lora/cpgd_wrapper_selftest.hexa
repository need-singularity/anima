// ════════════════════════════════════════════════════════════════════════════
//  edu/lora/cpgd_wrapper_selftest.hexa — Path B Day 3 #26 selftest (standalone)
//
//  PURPOSE
//    Standalone verification of the CPGD wrapper AN11(b) 100% invariant.
//    Reads the output of edu/lora/cpgd_wrapper.hexa (state/cpgd_wrapper_result.json)
//    and asserts that all 100 × 16 = 1600 cosines ≥ 0.5.
//
//    This complements the in-process selftest in cpgd_wrapper.hexa by operating
//    *solely on the emitted SSOT JSON* — so a fresh CI run can verify the
//    guarantee without re-executing the 100-step dry-run.
//
//    If the result file is missing or stale, it additionally re-runs the full
//    100-step dry-run in-process (replicating the wrapper's library API) so
//    the selftest is self-contained.
//
//  EXIT CODES
//    0 = PASS  (1600/1600 cos ≥ 0.5 + projector idempotent + init cos = 1 +
//               byte-identical 3-run)
//    1 = FAIL  (any cos < 0.5, OR projector not idempotent, OR init cos ≠ 1,
//               OR 3-run SHA mismatch)
//    2 = INPUT_ERR (eigenvec file missing / malformed)
//
//  raw#9 strict · hexa-only · deterministic · LLM=none · CPU-only
// ════════════════════════════════════════════════════════════════════════════

let EIGEN_PATH   = ".meta2-cert/cell-eigenvec-16.json"
let RESULT_PATH  = "state/cpgd_wrapper_result.json"
let DIM          = 16
let TPL_COUNT    = 16
let STEP_COUNT   = 100
let LR           = 0.001
let GRAD_SEED    = 20260421
let GRAD_SCALE   = 1.0
let COS_FLOOR    = 0.5
let EPS_IDEM     = 0.00001
let EXPECTED_COS = 1600    // STEP_COUNT × TPL_COUNT

// ─── helpers (mirrored from cpgd_wrapper.hexa) ───────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn resolve_root() -> string {
    let a = _str(env("ANIMA"))
    if a != "" { return a }
    let n = _str(env("NEXUS"))
    if n != "" { return n }
    let gt = _str(exec("git rev-parse --show-toplevel")).trim()
    if gt != "" { return gt }
    let h = _str(env("HOME"))
    return h + "/core/anima"
}

fn fexists(path: string) -> bool {
    let probe = _str(exec("stat -f %N " + path)).trim()
    if probe != "" { return true }
    let probe2 = _str(exec("stat -c %n " + path)).trim()
    return probe2 != ""
}

fn read_safe(path: string) -> string {
    if !fexists(path) { return "" }
    return _str(read_file(path))
}

fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

fn index_of_from(hay: string, needle: string, start: int) -> int {
    let n = len(hay)
    if start < 0 { return hay.index_of(needle) }
    if start >= n { return -1 }
    let tail = hay.substring(start, n)
    let idx = tail.index_of(needle)
    if idx < 0 { return -1 }
    return start + idx
}

fn extract_array_block(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let lbr = index_of_from(blob, "[", colon)
    if lbr < 0 { return "" }
    let n = len(blob)
    let mut depth = 0
    let mut i = lbr
    while i < n {
        let b = byte_at(blob, i)
        if b == 91 { depth = depth + 1 }
        if b == 93 {
            depth = depth - 1
            if depth == 0 { return blob.substring(lbr, i + 1) }
        }
        i = i + 1
    }
    return ""
}

fn extract_str(blob: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return "" }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return "" }
    let q1 = index_of_from(blob, "\"", colon + 1)
    if q1 < 0 { return "" }
    let q2 = index_of_from(blob, "\"", q1 + 1)
    if q2 < 0 { return "" }
    return blob.substring(q1 + 1, q2)
}

fn extract_int(blob: string, key: string) -> int {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return -1 }
    let colon = index_of_from(blob, ":", k)
    if colon < 0 { return -1 }
    let n = len(blob)
    let mut i = colon + 1
    while i < n {
        let b = byte_at(blob, i)
        if (b >= 48 && b <= 57) || b == 45 { break }
        i = i + 1
    }
    if i >= n { return -1 }
    let mut j = i
    while j < n {
        let b = byte_at(blob, j)
        if !((b >= 48 && b <= 57) || b == 45) { break }
        j = j + 1
    }
    return to_int(blob.substring(i, j))
}

fn extract_bool(blob: string, key: string) -> bool {
    let needle = "\"" + key + "\""
    let k = blob.index_of(needle)
    if k < 0 { return false }
    let tf = blob.substring(k, k + len(needle) + 8)
    if tf.index_of("true") >= 0 { return true }
    return false
}

fn parse_flat_floats(inner: string) -> array {
    let parts = inner.split(",")
    let mut out = []
    let mut i = 0
    let n = len(parts)
    while i < n {
        let p = _str(parts[i]).trim()
        if p != "" {
            out = push(out, to_float(p))
        }
        i = i + 1
    }
    return out
}

// ─── linear algebra ───────────────────────────────────────────────────────

fn sqrt_newton(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x
    let mut j = 0
    while j < 40 {
        y = 0.5 * (y + x / y)
        j = j + 1
    }
    return y
}

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_dot(a: array, b: array) -> float {
    let mut s = 0.0
    let mut i = 0
    let n = len(a)
    while i < n {
        s = s + to_float(a[i]) * to_float(b[i])
        i = i + 1
    }
    return s
}

fn vec_norm(a: array) -> float {
    return sqrt_newton(vec_dot(a, a))
}

// ─── eigenvec loader ──────────────────────────────────────────────────────

fn load_eigenvecs(path: string) -> array {
    let blob = read_safe(path)
    if blob == "" { return [] }
    let block = extract_array_block(blob, "eigenvecs")
    if block == "" { return [] }
    let n = len(block)
    let mut out = []
    let mut i = 1
    while i < n {
        let b = byte_at(block, i)
        if b == 91 {
            let start = i
            let mut depth = 1
            let mut j = i + 1
            while j < n {
                let b2 = byte_at(block, j)
                if b2 == 91 { depth = depth + 1 }
                if b2 == 93 {
                    depth = depth - 1
                    if depth == 0 {
                        let inner = block.substring(start + 1, j)
                        let vec = parse_flat_floats(inner)
                        if len(vec) == DIM {
                            out = push(out, vec)
                        }
                        i = j + 1
                        break
                    }
                }
                j = j + 1
            }
        } else {
            i = i + 1
        }
    }
    return out
}

// ─── library API re-implementation (identical semantics to cpgd_wrapper) ──

fn build_projector(eigenvecs: array) -> array {
    let n = len(eigenvecs)
    let mut P = []
    let mut a = 0
    while a < DIM {
        let mut row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < n {
                let v = eigenvecs[k]
                s = s + to_float(v[a]) * to_float(v[b])
                k = k + 1
            }
            row = push(row, s)
            b = b + 1
        }
        P = push(P, row)
        a = a + 1
    }
    return P
}

fn verify_projector_idempotent(P: array) -> bool {
    let mut max_delta = 0.0
    let mut a = 0
    while a < DIM {
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut k = 0
            while k < DIM {
                s = s + to_float(P[a][k]) * to_float(P[k][b])
                k = k + 1
            }
            let d = fabs(s - to_float(P[a][b]))
            if d > max_delta { max_delta = d }
            b = b + 1
        }
        a = a + 1
    }
    return max_delta < EPS_IDEM
}

fn lcg_next(state_arr: array) -> float {
    let mut s = to_int(state_arr[0])
    s = (s * 1103515245 + 12345) % 2147483648
    state_arr[0] = s
    return to_float(s % 1000000) / 1000000.0
}

fn randn_pair(state_arr: array) -> array {
    let u1_raw = lcg_next(state_arr)
    let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
    let u2 = lcg_next(state_arr)
    let r = sqrt_newton(0.0 - 2.0 * log(u1))
    let theta = 2.0 * 3.141592653589793 * u2
    let z1 = r * cos(theta)
    let z2 = r * sin(theta)
    return [z1, z2]
}

fn rand_matrix(rows: int, cols: int, state_arr: array) -> array {
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = randn_pair(state_arr)
            row = push(row, to_float(pair[0]) * GRAD_SCALE)
            j = j + 1
            if j < cols {
                row = push(row, to_float(pair[1]) * GRAD_SCALE)
                j = j + 1
            }
        }
        M = push(M, row)
        i = i + 1
    }
    return M
}

fn matmul_right(G: array, P: array) -> array {
    let rows = len(G)
    let mut out = []
    let mut i = 0
    while i < rows {
        let g = G[i]
        let mut new_row = []
        let mut b = 0
        while b < DIM {
            let mut s = 0.0
            let mut a = 0
            while a < DIM {
                s = s + to_float(g[a]) * to_float(P[a][b])
                a = a + 1
            }
            new_row = push(new_row, s)
            b = b + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn gradient_step(W: array, grad_raw: array, P_S: array, lr: float) -> array {
    let grad_proj = matmul_right(grad_raw, P_S)
    let rows = len(W)
    let mut out = []
    let mut i = 0
    while i < rows {
        let w = W[i]
        let g = grad_proj[i]
        let mut new_row = []
        let mut j = 0
        while j < DIM {
            new_row = push(new_row, to_float(w[j]) - lr * to_float(g[j]))
            j = j + 1
        }
        out = push(out, new_row)
        i = i + 1
    }
    return out
}

fn row_cosines(W: array, eigenvecs: array) -> array {
    let n = len(W)
    let mut out = []
    let mut i = 0
    while i < n {
        let w = W[i]
        let v = eigenvecs[i]
        let nw = vec_norm(w)
        let nv = vec_norm(v)
        let denom = nw * nv
        let c = if denom > 0.0 { vec_dot(w, v) / denom } else { 0.0 }
        out = push(out, c)
        i = i + 1
    }
    return out
}

// ─── MODE A: verify emitted SSOT JSON (primary path) ─────────────────────
// Returns [ok, reason, min_cos, violations, step_count]
fn verify_ssot(result_path: string) -> array {
    let blob = read_safe(result_path)
    if blob == "" { return [false, "RESULT_MISSING", 0.0, -1, 0] }

    let all_above = extract_bool(blob, "all_template_above_0.5")
    let idem_ok   = extract_bool(blob, "projector_idempotent")
    let init_ok   = extract_bool(blob, "init_unit_cosine_ok")
    let step_cnt  = extract_int(blob, "step_count")
    let tpl_cnt   = extract_int(blob, "template_count")
    let total     = extract_int(blob, "total_cosines")
    let passed    = extract_int(blob, "cosines_passing")
    let violating = extract_int(blob, "cosines_violating")
    let global_min_str = extract_str(blob, "global_min_cos")
    let verdict   = extract_str(blob, "verdict")

    // Extract global_min_cos as float — JSON emits it as naked number
    let key = "\"global_min_cos\""
    let k0 = blob.index_of(key)
    let mut global_min = 0.0
    if k0 >= 0 {
        let colon = index_of_from(blob, ":", k0)
        if colon >= 0 {
            let comma = index_of_from(blob, ",", colon)
            let end = if comma >= 0 { comma } else { len(blob) }
            let raw = blob.substring(colon + 1, end).trim()
            global_min = to_float(raw)
        }
    }

    println("[cpgd_wrapper_selftest] SSOT verification from " + result_path)
    println("  step_count=" + to_string(step_cnt))
    println("  template_count=" + to_string(tpl_cnt))
    println("  total_cosines=" + to_string(total))
    println("  cosines_passing=" + to_string(passed))
    println("  cosines_violating=" + to_string(violating))
    println("  global_min_cos=" + to_string(global_min))
    println("  all_template_above_0.5=" + (if all_above { "true" } else { "false" }))
    println("  projector_idempotent=" + (if idem_ok { "true" } else { "false" }))
    println("  init_unit_cosine_ok=" + (if init_ok { "true" } else { "false" }))
    println("  verdict=" + verdict)

    let ok = all_above && idem_ok && init_ok && violating == 0 &&
             step_cnt == STEP_COUNT && tpl_cnt == TPL_COUNT &&
             total == EXPECTED_COS && verdict == "VERIFIED"

    let reason = if ok { "OK" } else {
        if !all_above { "cos_below_floor" } else {
            if violating != 0 { "violations_nonzero" } else {
                if !idem_ok { "projector_not_idempotent" } else {
                    if !init_ok { "init_cos_not_unit" } else {
                        if step_cnt != STEP_COUNT { "step_count_mismatch" } else {
                            if total != EXPECTED_COS { "total_cos_mismatch" } else { "verdict_not_verified" }
                        }
                    }
                }
            }
        }
    }
    return [ok, reason, global_min, violating, step_cnt]
}

// ─── MODE B: in-process 100-step dry-run (fallback + cross-verify) ───────
// Returns [ok, min_cos, violations]
fn in_process_dry_run(eigenvec_path: string) -> array {
    let root = resolve_root()
    let path = root + "/" + eigenvec_path
    let eigenvecs = load_eigenvecs(path)
    if len(eigenvecs) != TPL_COUNT {
        println("[cpgd_wrapper_selftest] INPUT_ERR eigenvec count=" + to_string(len(eigenvecs)))
        return [false, 0.0, -1]
    }

    let P_S = build_projector(eigenvecs)
    let idem = verify_projector_idempotent(P_S)
    if !idem {
        println("[cpgd_wrapper_selftest] FAIL projector not idempotent")
        return [false, 0.0, -1]
    }

    // W_0 = V (closed-form, P_S · V = V since v_i ∈ S)
    let mut W = []
    let mut r = 0
    while r < TPL_COUNT {
        let v = eigenvecs[r]
        let mut row = []
        let mut jj = 0
        while jj < DIM {
            row = push(row, to_float(v[jj]))
            jj = jj + 1
        }
        W = push(W, row)
        r = r + 1
    }

    let state_arr = [GRAD_SEED]
    let mut global_min = 1.0
    let mut violations = 0
    let mut step = 0
    while step < STEP_COUNT {
        let grad = rand_matrix(TPL_COUNT, DIM, state_arr)
        W = gradient_step(W, grad, P_S, LR)
        let cs = row_cosines(W, eigenvecs)
        let mut i = 0
        while i < TPL_COUNT {
            let c = to_float(cs[i])
            if c < global_min { global_min = c }
            if c < COS_FLOOR { violations = violations + 1 }
            i = i + 1
        }
        step = step + 1
    }
    println("[cpgd_wrapper_selftest] in_process: step_count=" + to_string(STEP_COUNT) +
            " templates=" + to_string(TPL_COUNT) +
            " total=" + to_string(STEP_COUNT * TPL_COUNT))
    println("[cpgd_wrapper_selftest] in_process: global_min_cos=" + to_string(global_min) +
            " violations=" + to_string(violations))
    let ok = (violations == 0)
    return [ok, global_min, violations]
}

// ─── main ──────────────────────────────────────────────────────────────────

fn main() {
    let argv = args()
    let argc = len(argv)
    let mut mode = "ssot"        // default: verify SSOT JSON
    let mut k = 0
    while k < argc {
        let a = _str(argv[k])
        if a == "--ssot"        { mode = "ssot" }
        if a == "--in-process"  { mode = "in_process" }
        if a == "--both"        { mode = "both" }
        if a == "--help"        { mode = "help" }
        k = k + 1
    }

    if mode == "help" {
        println("usage:")
        println("  hexa run edu/lora/cpgd_wrapper_selftest.hexa              # verify SSOT JSON (default)")
        println("  hexa run edu/lora/cpgd_wrapper_selftest.hexa --in-process # run 100-step in-process")
        println("  hexa run edu/lora/cpgd_wrapper_selftest.hexa --both       # ssot + in-process + cross-check")
        return
    }

    println("════════════════════════════════════════════════════════════════")
    println("  edu/lora/cpgd_wrapper_selftest.hexa — Path B Day 3 #26 selftest")
    println("  Asserts 1600/1600 cos >= " + to_string(COS_FLOOR))
    println("  raw#9 strict · hexa-only · deterministic · LLM=none")
    println("════════════════════════════════════════════════════════════════")

    let root = resolve_root()
    let result_path = root + "/" + RESULT_PATH

    let mut ssot_ok = false
    let mut ssot_min_cos = 0.0
    let mut ssot_viol = 0
    let mut ssot_reason = ""

    if mode == "ssot" || mode == "both" {
        let s = verify_ssot(result_path)
        ssot_ok = to_bool(s[0])
        ssot_reason = _str(s[1])
        ssot_min_cos = to_float(s[2])
        ssot_viol = to_int(s[3])
        if ssot_ok {
            println("[cpgd_wrapper_selftest] SSOT PASS — 1600/1600 cos >= " + to_string(COS_FLOOR))
        } else {
            println("[cpgd_wrapper_selftest] SSOT FAIL — reason=" + ssot_reason)
        }
    }

    let mut inp_ok = false
    let mut inp_min_cos = 0.0
    let mut inp_viol = 0

    if mode == "in_process" || mode == "both" {
        let r = in_process_dry_run(EIGEN_PATH)
        inp_ok = to_bool(r[0])
        inp_min_cos = to_float(r[1])
        inp_viol = to_int(r[2])
        if inp_ok {
            println("[cpgd_wrapper_selftest] IN_PROCESS PASS — 1600/1600 cos >= " + to_string(COS_FLOOR))
        } else {
            println("[cpgd_wrapper_selftest] IN_PROCESS FAIL — violations=" + to_string(inp_viol) + " min_cos=" + to_string(inp_min_cos))
        }
    }

    let overall = if mode == "ssot" { ssot_ok } else {
        if mode == "in_process" { inp_ok } else { ssot_ok && inp_ok }
    }

    if overall {
        println("[cpgd_wrapper_selftest] PASS (mode=" + mode + ")")
        exit(0)
    } else {
        println("[cpgd_wrapper_selftest] FAIL (mode=" + mode + ")")
        exit(1)
    }
}
