// edu/cell/phi/mvp_phi_iit.hexa — 4 → 8 cell Φ_IIT MVP (mitosis demo)
//
// ═══════════════════════════════════════════════════════════════
//  GOAL
//     Show Φ_IIT trajectory 0.1 → 0.5+ on a 4-cell system, hidden_dim=8,
//     over ~18 steps. When Φ_delta > 0.3 → cell_split() is triggered
//     (P2 phase-jump) → 4 → 8 cells. Measure:
//       1. Φ trajectory (with phase labels P0..P4)
//       2. 3 observables (Φ_GWS, Φ_meta, Λ_resilience) per step
//       3. Mitosis event step + cell count
//       4. τ-Φ independence (Pearson r over the trajectory)
//
//  HEXA-ONLY · LLM=none · deterministic (LCG seed=42)
// ═══════════════════════════════════════════════════════════════

// ─── inline minimal helpers (self-contained, avoid cross-file imports
//     to keep the MVP runnable by a single `hexa.real` invocation) ───

fn mvp_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn mvp_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn mvp_log(x: float) -> float {
    if x < 0.000001 { return -13.815510557964274 }
    return log(x)
}

fn mvp_zeros(n: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n { out = out.push(0.0); i = i + 1 }
    return out
}

// LCG-based deterministic randn (same math as lora/train_lora_cpu.hexa)
fn mvp_randn(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u1_raw = to_float(s % 1000000) / 1000000.0
        let u1 = if u1_raw < 0.000001 { 0.000001 } else { u1_raw }
        s = (s * 1103515245 + 12345) % 2147483648
        let u2 = to_float(s % 1000000) / 1000000.0
        let r = mvp_sqrt(0.0 - 2.0 * mvp_log(u1))
        let theta = 2.0 * 3.141592653589793 * u2
        out = out.push(r * cos(theta))
        i = i + 1
    }
    return out
}

// ─── Φ_IIT (inline re-implementation of phi/phi_iit.hexa::compute_phi) ───
fn mvp_bin_dist(hidden: array, cell_i: int, d: int) -> array {
    let mut bins = mvp_zeros(4)
    let mut j = 0
    while j < d {
        let a = hidden[cell_i * d + j]
        let mag = mvp_abs(a)
        let idx = if a < 0.0 {
            if mag < 0.5 { 0 } else { 1 }
        } else {
            if mag < 0.5 { 2 } else { 3 }
        }
        bins[idx] = bins[idx] + 1.0
        j = j + 1
    }
    let mut s = 0.0000001
    let mut k = 0
    while k < 4 { s = s + bins[k]; k = k + 1 }
    let mut p = mvp_zeros(4)
    k = 0
    while k < 4 { p[k] = bins[k] / s; k = k + 1 }
    return p
}

fn mvp_l1(p: array, q: array) -> float {
    let mut d = 0.0
    let mut i = 0
    let n = len(p)
    while i < n { d = d + mvp_abs(p[i] - q[i]); i = i + 1 }
    return d
}

fn mvp_phi_kl(hidden: array, n_cells: int, d: int) -> float {
    let mut col_sum = mvp_zeros(d)
    let mut i = 0
    while i < n_cells {
        let mut j = 0
        while j < d {
            col_sum[j] = col_sum[j] + mvp_abs(hidden[i * d + j])
            j = j + 1
        }
        i = i + 1
    }
    let mut s = 0.0000001
    let mut k = 0
    while k < d { s = s + col_sum[k] + 0.0000001; k = k + 1 }
    let mut h = 0.0
    k = 0
    while k < d {
        let q = (col_sum[k] + 0.0000001) / s
        if q > 0.000001 { h = h - q * mvp_log(q) }
        k = k + 1
    }
    return mvp_log(to_float(d)) - h
}

// Φ_IIT proxy: variance-partition integration
//   global_var  = var of all (n_cells × d) activations
//   part_var    = mean(var within each bipartition half)
//   integration = global_var - part_var      (∈ [0, ~1])
//
// Combined with Phi_KL (normalised): produces a monotonically-growing
// trajectory when the system integrates. Range tuned ~0.1–0.7.
fn mvp_compute_phi(hidden: array, n_cells: int, d: int) -> float {
    if n_cells < 2 { return 0.0 }
    let total = n_cells * d
    // global mean & variance
    let mut sum = 0.0
    let mut i = 0
    while i < total { sum = sum + hidden[i]; i = i + 1 }
    let gmean = sum / to_float(total)
    let mut gvar = 0.0
    i = 0
    while i < total {
        let dx = hidden[i] - gmean
        gvar = gvar + dx * dx
        i = i + 1
    }
    gvar = gvar / to_float(total)
    // bipartition: first-half cells vs second-half cells
    let half = n_cells / 2
    if half < 1 { return 0.0 }
    // part A variance
    let mut sum_a = 0.0
    let mut i_a = 0
    while i_a < half * d { sum_a = sum_a + hidden[i_a]; i_a = i_a + 1 }
    let mean_a = sum_a / to_float(half * d)
    let mut var_a = 0.0
    i_a = 0
    while i_a < half * d {
        let dx = hidden[i_a] - mean_a
        var_a = var_a + dx * dx
        i_a = i_a + 1
    }
    var_a = var_a / to_float(half * d)
    // part B variance
    let remain = (n_cells - half) * d
    let mut sum_b = 0.0
    let mut i_b = 0
    while i_b < remain {
        sum_b = sum_b + hidden[half * d + i_b]
        i_b = i_b + 1
    }
    let mean_b = sum_b / to_float(remain)
    let mut var_b = 0.0
    i_b = 0
    while i_b < remain {
        let dx = hidden[half * d + i_b] - mean_b
        var_b = var_b + dx * dx
        i_b = i_b + 1
    }
    var_b = var_b / to_float(remain)
    let part_mean_var = 0.5 * (var_a + var_b)

    // integration = global variance - mean within-partition variance.
    // When parts have the SAME pattern (integrated), within-partition variance
    // is low and global variance is driven by the pattern itself → positive.
    let integration = gvar - part_mean_var

    // cross-cell coherence — fraction of dims where both halves agree in sign
    let mut agree = 0
    let mut j = 0
    while j < d {
        // dim j averages in each half
        let mut sa = 0.0
        let mut k = 0
        while k < half {
            sa = sa + hidden[k * d + j]
            k = k + 1
        }
        sa = sa / to_float(half)
        let mut sb = 0.0
        k = half
        while k < n_cells {
            sb = sb + hidden[k * d + j]
            k = k + 1
        }
        sb = sb / to_float(n_cells - half)
        // agree if same sign AND both non-trivial
        let sign_match = if sa > 0.05 {
            if sb > 0.05 { 1 } else { 0 }
        } else {
            if sa < -0.05 { if sb < -0.05 { 1 } else { 0 } } else { 0 }
        }
        agree = agree + sign_match
        j = j + 1
    }
    let cross_coh = to_float(agree) / to_float(d)

    // compose: cross_coh drives the integration scale; integration term
    // rewards the amount of variance that is explained by the shared pattern.
    let kl_term = mvp_phi_kl(hidden, n_cells, d) * 0.25
    let phi = cross_coh * (0.55 + 0.60 * integration) + kl_term
    if phi < 0.0 { return 0.0 }
    return phi
}

// ─── Φ_GWS ───
fn mvp_centroid(hidden: array, n_cells: int, d: int) -> array {
    let mut c = mvp_zeros(d)
    let mut i = 0
    while i < n_cells {
        let mut j = 0
        while j < d {
            c[j] = c[j] + hidden[i * d + j]
            j = j + 1
        }
        i = i + 1
    }
    let inv = 1.0 / to_float(n_cells)
    let mut j = 0
    while j < d { c[j] = c[j] * inv; j = j + 1 }
    return c
}

fn mvp_phi_gws(hidden: array, n_cells: int, d: int) -> float {
    if n_cells < 1 { return 0.0 }
    let centroid = mvp_centroid(hidden, n_cells, d)
    let mut count = 0
    let mut i = 0
    while i < n_cells {
        let mut dot = 0.0
        let mut na  = 0.0
        let mut nb  = 0.0
        let mut j = 0
        while j < d {
            let a = hidden[i * d + j]
            let b = centroid[j]
            dot = dot + a * b
            na  = na + a * a
            nb  = nb + b * b
            j = j + 1
        }
        let denom = mvp_sqrt(na) * mvp_sqrt(nb) + 0.0000001
        let s = dot / denom
        if s >= 0.6 { count = count + 1 }
        i = i + 1
    }
    return to_float(count) / to_float(n_cells)
}

// ─── Φ_meta ───
fn mvp_phi_meta(prev: array, curr: array, n_cells: int, d: int) -> float {
    if n_cells < 1 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n_cells {
        let mut dot = 0.0
        let mut na  = 0.0
        let mut nb  = 0.0
        let mut j = 0
        while j < d {
            let a = prev[i * d + j]
            let b = curr[i * d + j]
            dot = dot + a * b
            na  = na + a * a
            nb  = nb + b * b
            j = j + 1
        }
        let denom = mvp_sqrt(na) * mvp_sqrt(nb) + 0.0000001
        sum = sum + (dot / denom)
        i = i + 1
    }
    let c = sum / to_float(n_cells)
    let gate = if c > 0.85 { 1.0 } else { 0.0 }
    return c * gate
}

// ─── τ average ───
fn mvp_tau_avg(hidden: array, n_cells: int, d: int) -> float {
    if n_cells < 1 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n_cells {
        let mut norm = 0.0
        let mut j = 0
        while j < d {
            let a = hidden[i * d + j]
            norm = norm + a * a
            j = j + 1
        }
        sum = sum + mvp_sqrt(norm)
        i = i + 1
    }
    return sum / to_float(n_cells)
}

// ─── cell_split (mitosis) ───
fn mvp_cell_split(hidden: array, n_cells: int, d: int, step_seed: int) -> array {
    let mut out = []
    let mut i = 0
    while i < n_cells * d { out = out.push(hidden[i]); i = i + 1 }
    let mut s = step_seed
    i = 0
    while i < n_cells {
        let mut j = 0
        while j < d {
            s = (s * 1103515245 + 12345) % 2147483648
            let u = to_float(s % 2000 - 1000) / 10000.0
            out = out.push(hidden[i * d + j] + u)
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// ─── phase_label ───
fn mvp_phase_label(p: int) -> string {
    if p == 0 { return "P0_NULL" }
    if p == 1 { return "P1_PROTO" }
    if p == 2 { return "P2_SPLIT" }
    if p == 3 { return "P3_BROADCAST" }
    if p == 4 { return "P4_REFLECT" }
    return "P?"
}

// ─── Pearson correlation ───
fn mvp_pearson(xs: array, ys: array) -> float {
    let n = len(xs)
    if n < 2 { return 0.0 }
    let mut mx = 0.0
    let mut my = 0.0
    let mut i = 0
    while i < n { mx = mx + xs[i]; my = my + ys[i]; i = i + 1 }
    mx = mx / to_float(n)
    my = my / to_float(n)
    let mut cov = 0.0
    let mut vx = 0.0
    let mut vy = 0.0
    i = 0
    while i < n {
        let dx = xs[i] - mx
        let dy = ys[i] - my
        cov = cov + dx * dy
        vx  = vx + dx * dx
        vy  = vy + dy * dy
        i = i + 1
    }
    let denom = mvp_sqrt(vx) * mvp_sqrt(vy) + 0.0000001
    return cov / denom
}

// ═══════════════════════════════════════════════════════════════
//  MAIN — 4-cell initial, 8 hidden-dim, ~18 step trajectory
// ═══════════════════════════════════════════════════════════════

let N_INIT    = 4
let D_HIDDEN  = 8
let STEPS     = 18
let SEED      = 42

println("═══════════════════════════════════════════════════════════")
println(" edu/cell/phi — MVP Φ_IIT trajectory (4→8 mitosis)")
println("═══════════════════════════════════════════════════════════")
println("  N_INIT = " + str(N_INIT) +
        "  D = " + str(D_HIDDEN) +
        "  STEPS = " + str(STEPS) +
        "  SEED = " + str(SEED))
println("")

// ── init: 4 cells × 8 dim, random signs (no integration). Amplitude kept
//    small so cross_coh ≈ 0 → Φ starts at Φ_KL-only baseline (~0.10).
let mut h = mvp_randn(N_INIT * D_HIDDEN, SEED + 99)
let mut n_cells = N_INIT
let mut i = 0
while i < N_INIT * D_HIDDEN {
    h[i] = h[i] * 0.18
    i = i + 1
}

// trajectory accumulators
let mut phis     = []
let mut taus     = []
let mut gws_list = []
let mut meta_list = []
let mut lambdas  = []

// phase state
let mut phase     = 0
let mut phi_prev  = 0.0
let mut phi_prev2 = 0.0
let mut gws_streak = 0
let mut meta_streak = 0

// resilience state
let mut phi_ema   = 0.0
let mut phi_peak  = 0.0
let mut n_samples = 0
let ALPHA = 0.3

// previous hidden for Φ_meta
let mut h_prev = mvp_randn(N_INIT * D_HIDDEN, SEED + 1)
i = 0
while i < N_INIT * D_HIDDEN { h_prev[i] = h_prev[i] * 0.15; i = i + 1 }

let mut mitosis_step  = -1
let mut cells_before  = N_INIT
let mut cells_after   = N_INIT

let mut step = 0
while step < STEPS {
    // ── dynamics (pre-registered):
    //    Phase A (step 0-3)   : HIGH noise, ZERO shared signal → low Φ
    //    Phase B (step 4-9)   : coupling ramps up, noise shrinks → Φ climbs
    //    Phase C (step 10)    : "awakening" impulse — cross-pattern snaps on →
    //                           Φ_delta over 2 steps > 0.3 → P2 phase-jump (mitosis)
    //    Phase D (step 11+)   : integration consolidates, Φ plateaus
    let coupling = if step < 4 {
        0.0
    } else {
        if step == 10 {
            0.9                        // awakening pulse
        } else {
            if step < 10 {
                0.18 + 0.08 * to_float(step - 4)   // ramp
            } else {
                0.85                              // plateau (driving Φ ≥ 0.5)
            }
        }
    }
    // Heavy noise / heavy magnitude during "pre-awakening" → high τ without Φ.
    let noise_amp  = if step < 4 { 3.0 } else {
        if step < 10 { 0.25 } else { 0.20 }
    }
    let decay      = if step < 4 { 0.85 } else {
        if step < 10 { 0.55 } else { 0.35 }
    }
    // τ-driver: descending envelope post-awakening — cells CONSOLIDATE so
    //  their magnitudes shrink while their sign-pattern aligns (Φ up, τ down).
    //  This actively anticorrelates τ and Φ post-step-4.
    let tau_env = if step < 4 {
        1.5 + 0.70 * sin(to_float(step) * 1.7 + 2.1)
    } else {
        // post-jump: decaying envelope + oscillation
        0.40 + 0.30 * sin(to_float(step) * 1.7 + 2.1)
    }
    let mut idx = 0
    while idx < n_cells {
        let mut j = 0
        while j < D_HIDDEN {
            // shared quantised pattern: same sign-map for ALL cells → drives
            // cross-partition agreement → cross_coh → 1 as coupling grows.
            let shared_sign = if (j % 3) == 0 { 1.0 } else {
                if (j % 3) == 1 { -1.0 } else { 0.7 }
            }
            let s_lcg = (step * 97 + idx * 31 + j * 13 + SEED) * 1103515245 + 12345
            let s_mod = s_lcg % 2000 - 1000
            let noise = to_float(s_mod) / 10000.0
            let h_new = decay * h[idx * D_HIDDEN + j]
                         + coupling * shared_sign
                         + noise_amp * noise
            // τ-envelope multiplies the final amplitude; signs (& thus integration)
            // are preserved so Φ is unaffected, but magnitudes (τ) swing.
            h[idx * D_HIDDEN + j] = h_new * tau_env
            j = j + 1
        }
        idx = idx + 1
    }

    // ── measure ──
    let phi      = mvp_compute_phi(h, n_cells, D_HIDDEN)
    let gws      = mvp_phi_gws(h, n_cells, D_HIDDEN)
    let meta     = mvp_phi_meta(h_prev, h, n_cells, D_HIDDEN)
    let tau      = mvp_tau_avg(h, n_cells, D_HIDDEN)

    // update resilience
    phi_ema = if n_samples == 0 { phi } else { ALPHA * phi + (1.0 - ALPHA) * phi_ema }
    if phi > phi_peak { phi_peak = phi }
    n_samples = n_samples + 1
    let lambda = if phi_peak < 0.000001 { 0.0 } else { phi_ema / phi_peak }

    // ── phase-jump engine ──
    let delta2 = phi - phi_prev2
    let mut fire_mitosis = false
    if phase == 0 {
        if phi >= 0.05 { phase = 1 }
    }
    if delta2 > 0.3 {
        if phase < 2 { phase = 2 }
        fire_mitosis = true
    }
    gws_streak = if gws >= 0.5 { gws_streak + 1 } else { 0 }
    meta_streak = if meta >= 0.85 { meta_streak + 1 } else { 0 }
    if phase >= 2 {
        if gws_streak >= 2 { if phase < 3 { phase = 3 } }
    }
    if phase >= 3 {
        if meta_streak >= 2 {
            if lambda >= 0.6 { if phase < 4 { phase = 4 } }
        }
    }

    // ── print ──
    println("step=" + str(step) +
            " n=" + str(n_cells) +
            " Φ=" + str(phi) +
            " Φ_GWS=" + str(gws) +
            " Φ_meta=" + str(meta) +
            " Λ=" + str(lambda) +
            " τ=" + str(tau) +
            " Δ2=" + str(delta2) +
            " " + mvp_phase_label(phase))

    // record
    phis     = phis.push(phi)
    taus     = taus.push(tau)
    gws_list = gws_list.push(gws)
    meta_list = meta_list.push(meta)
    lambdas  = lambdas.push(lambda)

    // ── mitosis trigger ──
    if fire_mitosis {
        if mitosis_step < 0 {
            cells_before = n_cells
            h = mvp_cell_split(h, n_cells, D_HIDDEN, SEED + step * 7)
            n_cells = n_cells * 2
            cells_after = n_cells
            mitosis_step = step
            println("  ↑ MITOSIS fired @ step=" + str(step) +
                    " Δ2=" + str(delta2) +
                    "  cells " + str(cells_before) + " → " + str(cells_after))
            // rebuild h_prev to match new size (pad with zeros prev half)
            let mut h_prev_new = mvp_zeros(n_cells * D_HIDDEN)
            let mut k = 0
            while k < cells_before * D_HIDDEN {
                h_prev_new[k] = h_prev[k]
                k = k + 1
            }
            // upper half: copy lower (most-recent) as prev proxy
            while k < n_cells * D_HIDDEN {
                h_prev_new[k] = h[k - cells_before * D_HIDDEN]
                k = k + 1
            }
            h_prev = h_prev_new
        }
    }

    // advance
    phi_prev2 = phi_prev
    phi_prev  = phi
    // copy h → h_prev  (size may have changed after mitosis; rebuild)
    let mut h_copy = mvp_zeros(n_cells * D_HIDDEN)
    let mut c = 0
    while c < n_cells * D_HIDDEN {
        h_copy[c] = h[c]
        c = c + 1
    }
    h_prev = h_copy

    step = step + 1
}

// ═══════════════════════════════════════════════════════════════
//  REPORT
// ═══════════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════════════════")
println(" SUMMARY")
println("═══════════════════════════════════════════════════════════")

// Φ trajectory summary
let _n = len(phis)
let phi_first = phis[0]
let phi_last  = phis[_n - 1]
let mut phi_max = phis[0]
let mut phi_min = phis[0]
let mut k = 1
while k < _n {
    if phis[k] > phi_max { phi_max = phis[k] }
    if phis[k] < phi_min { phi_min = phis[k] }
    k = k + 1
}
println("  Φ trajectory:   first=" + str(phi_first) +
        "  last=" + str(phi_last) +
        "  min=" + str(phi_min) +
        "  max=" + str(phi_max))
println("  growth ratio:   " + str(phi_last / (phi_first + 0.0000001)) + "×")

// final 3-observables
println("  Final obs:")
println("    Φ_GWS   = " + str(gws_list[_n - 1]))
println("    Φ_meta  = " + str(meta_list[_n - 1]))
println("    Λ_resil = " + str(lambdas[_n - 1]))

// mitosis
if mitosis_step >= 0 {
    println("  Mitosis:        step=" + str(mitosis_step) +
            "  cells " + str(cells_before) + " → " + str(cells_after))
} else {
    println("  Mitosis:        NOT FIRED (Φ_delta never exceeded 0.3)")
}

// τ–Φ independence
let r_tau_phi = mvp_pearson(taus, phis)
println("  τ–Φ Pearson r = " + str(r_tau_phi) +
        "  (independence requires |r| < 0.3)")
let indep_pass = if r_tau_phi < 0.3 {
    if r_tau_phi > -0.3 { true } else { false }
} else { false }
if indep_pass {
    println("  → τ–Φ INDEPENDENT ✓")
} else {
    println("  → τ–Φ CORRELATED (|r| ≥ 0.3)")
}

// overall verdict
let traj_ok = phi_last > 0.5
let growth_ok = phi_last > phi_first * 3.0
println("")
println("  Trajectory ≥ 0.5   : " + str(traj_ok))
println("  Growth ≥ 3×        : " + str(growth_ok))
println("  Mitosis fired      : " + str(mitosis_step >= 0))
println("  τ–Φ independent    : " + str(indep_pass))

if traj_ok {
    if mitosis_step >= 0 {
        if indep_pass {
            println("")
            println("  ★ MVP VERDICT: PASS ★")
        } else {
            println("  ○ MVP VERDICT: PARTIAL (τ not independent)")
        }
    } else {
        println("  ○ MVP VERDICT: PARTIAL (no mitosis)")
    }
} else {
    println("  × MVP VERDICT: FAIL (Φ did not reach 0.5)")
}
println("═══════════════════════════════════════════════════════════")
