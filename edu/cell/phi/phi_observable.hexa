// edu/cell/phi/phi_observable.hexa — Φ 3-observable integrator
//
// Combines O1 (Φ_GWS), O2 (Φ_meta), O3 (Λ_resilience) into a single
// observable record with a verdict.
//
// Verdict levels:
//   L3_FULL     — all 3 observables above threshold
//   L2_PARTIAL  — exactly 2 above threshold
//   L1_PROTO    — 1 above threshold
//   L0_NONE     — 0 above threshold

comptime const THR_GWS       = 0.50
comptime const THR_META      = 0.85
comptime const THR_RESILIENCE = 0.60

struct PhiObservables {
    phi_iit:        float,
    phi_gws:        float,
    phi_meta:       float,
    lambda_resil:   float,
    verdict:        string
}

fn po_pass_count(gws: float, meta: float, resil: float) -> int {
    let mut c = 0
    if gws       >= THR_GWS        { c = c + 1 }
    if meta      >= THR_META       { c = c + 1 }
    if resil     >= THR_RESILIENCE { c = c + 1 }
    return c
}

fn po_verdict(n: int) -> string {
    if n == 3 { return "L3_FULL" }
    if n == 2 { return "L2_PARTIAL" }
    if n == 1 { return "L1_PROTO" }
    return "L0_NONE"
}

fn make_observables(phi: float, gws: float, meta: float, resil: float) -> PhiObservables {
    let passed = po_pass_count(gws, meta, resil)
    PhiObservables {
        phi_iit:      phi,
        phi_gws:      gws,
        phi_meta:     meta,
        lambda_resil: resil,
        verdict:      po_verdict(passed)
    }
}

fn print_observables(o: PhiObservables) {
    println("  Φ_IIT       = " + str(o.phi_iit))
    println("  Φ_GWS       = " + str(o.phi_gws))
    println("  Φ_meta      = " + str(o.phi_meta))
    println("  Λ_resilience = " + str(o.lambda_resil))
    println("  verdict     = " + o.verdict)
}

// ── self-test ──
let _o_strong = make_observables(0.45, 0.75, 0.92, 0.80)
println("[phi_observable] strong case:")
print_observables(_o_strong)

let _o_weak = make_observables(0.05, 0.20, 0.40, 0.10)
println("[phi_observable] weak case:")
print_observables(_o_weak)

if _o_strong.verdict == "L3_FULL" {
    if _o_weak.verdict == "L0_NONE" {
        println("[phi_observable] PASS")
    } else {
        println("[phi_observable] FAIL (weak != L0)")
    }
} else {
    println("[phi_observable] FAIL (strong != L3)")
}
