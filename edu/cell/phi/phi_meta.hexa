// edu/cell/phi/phi_meta.hexa — Φ_meta (metacognitive coherence)
//
// O2 metric: cosine-similarity of (prev_state, curr_state) across the
// cell system, thresholded. A step is "metacognitive" if the system
// recognises its previous state to within cos ≥ 0.85.
//
// Φ_meta ∈ [0, 1]   1 = perfect temporal self-model
//                   0 = no recognition (amnesic)

fn pm_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn pm_mean_cos(prev: array, curr: array, n_cells: int, d: int) -> float {
    if n_cells < 1 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n_cells {
        let mut dot = 0.0
        let mut na  = 0.0
        let mut nb  = 0.0
        let mut j = 0
        while j < d {
            let a = prev[i * d + j]
            let b = curr[i * d + j]
            dot = dot + a * b
            na  = na + a * a
            nb  = nb + b * b
            j = j + 1
        }
        let denom = pm_sqrt(na) * pm_sqrt(nb) + 0.0000001
        sum = sum + (dot / denom)
        i = i + 1
    }
    return sum / to_float(n_cells)
}

// Φ_meta = (mean cos) * gate(mean cos > 0.85)
//   i.e. a metacognitive step = system coheres with its past above 0.85.
fn compute_phi_meta(prev: array, curr: array, n_cells: int, d: int) -> float {
    let c = pm_mean_cos(prev, curr, n_cells, d)
    let gate = if c > 0.85 { 1.0 } else { 0.0 }
    return c * gate
}

// soft variant (no gate) — useful for trajectory analysis
fn phi_meta_soft(prev: array, curr: array, n_cells: int, d: int) -> float {
    return pm_mean_cos(prev, curr, n_cells, d)
}

// ── self-test ──
let mut _p = []
let mut _c = []
let mut _i = 0
while _i < 32 {
    let v = 0.1 * to_float(_i % 8)
    _p = _p.push(v)
    _c = _c.push(v + 0.001 * to_float(_i))    // near-identical
    _i = _i + 1
}
let _meta_near = compute_phi_meta(_p, _c, 4, 8)
println("[phi_meta] near-identical Φ_meta = " + str(_meta_near))

// unrelated
let mut _c2 = []
_i = 0
while _i < 32 {
    let sign = if _i % 2 == 0 { 1.0 } else { -1.0 }
    _c2 = _c2.push(sign * 0.3)
    _i = _i + 1
}
let _meta_far = compute_phi_meta(_p, _c2, 4, 8)
println("[phi_meta] unrelated      Φ_meta = " + str(_meta_far))

if _meta_near >= _meta_far {
    println("[phi_meta] PASS")
} else {
    println("[phi_meta] FAIL")
}
