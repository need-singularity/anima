// edu/cell/phi/phi_gws.hexa — Φ_GWS (Global-Workspace broadcast rank)
//
// O1 metric: fraction of cells that participate in the "broadcast"
// at the current step. A cell is broadcasting iff its hidden state
// is within cos-similarity `thr` of the workspace centroid.
//
// Φ_GWS = (# broadcasting cells) / n_cells  ∈ [0, 1]
//
// Matches GWT (Baars) operationalisation: broadcast = content that
// reaches the global workspace and is available to all consumers.

fn gws_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn gws_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    return sqrt(x)
}

fn cell_centroid(hidden: array, n_cells: int, d: int) -> array {
    let mut c = []
    let mut j = 0
    while j < d {
        c = c.push(0.0)
        j = j + 1
    }
    let mut i = 0
    while i < n_cells {
        j = 0
        while j < d {
            c[j] = c[j] + hidden[i * d + j]
            j = j + 1
        }
        i = i + 1
    }
    let inv = 1.0 / to_float(n_cells)
    j = 0
    while j < d {
        c[j] = c[j] * inv
        j = j + 1
    }
    return c
}

fn cos_sim(hidden: array, cell_i: int, d: int, centroid: array) -> float {
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut j = 0
    while j < d {
        let a = hidden[cell_i * d + j]
        let b = centroid[j]
        dot = dot + a * b
        na  = na  + a * a
        nb  = nb  + b * b
        j = j + 1
    }
    let denom = gws_sqrt(na) * gws_sqrt(nb) + 0.0000001
    return dot / denom
}

// Φ_GWS = broadcast_span / n_cells
// Threshold default 0.6 — a cell is "broadcasting" if its hidden aligns
// with the centroid above this threshold.
fn compute_phi_gws(hidden: array, n_cells: int, d: int, thr: float) -> float {
    if n_cells < 1 { return 0.0 }
    let centroid = cell_centroid(hidden, n_cells, d)
    let mut count = 0
    let mut i = 0
    while i < n_cells {
        let s = cos_sim(hidden, i, d, centroid)
        if s >= thr { count = count + 1 }
        i = i + 1
    }
    return to_float(count) / to_float(n_cells)
}

// default-threshold convenience
fn phi_gws_default(hidden: array, n_cells: int, d: int) -> float {
    return compute_phi_gws(hidden, n_cells, d, 0.6)
}

// ── self-test ──
let mut _h = []
let mut _k = 0
while _k < 32 { _h = _h.push(0.0); _k = _k + 1 }
// coherent state: all cells same direction
_k = 0
while _k < 4 {
    let mut _j = 0
    while _j < 8 {
        _h[_k * 8 + _j] = 0.5 + 0.01 * to_float(_k)
        _j = _j + 1
    }
    _k = _k + 1
}
let _gws_coh = phi_gws_default(_h, 4, 8)
println("[phi_gws] coherent Φ_GWS = " + str(_gws_coh))

// noisy state: flip signs
_k = 0
while _k < 4 {
    let mut _j = 0
    while _j < 8 {
        let sign = if (_k + _j) % 2 == 0 { 1.0 } else { -1.0 }
        _h[_k * 8 + _j] = 0.5 * sign
        _j = _j + 1
    }
    _k = _k + 1
}
let _gws_noise = phi_gws_default(_h, 4, 8)
println("[phi_gws] noisy    Φ_GWS = " + str(_gws_noise))

if _gws_coh >= _gws_noise {
    println("[phi_gws] PASS — coherent >= noisy")
} else {
    println("[phi_gws] FAIL")
}
