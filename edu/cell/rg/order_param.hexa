// edu/cell/rg/order_param.hexa — order parameter φ + symmetry-breaking Δφ
//
// PARADIGM REF: docs/new_paradigm_edu_lattice_unified_20260421.md §11
// ROLE: per-faction order parameter φ_f and global φ_global;
//       Δφ = φ_per_faction_mean − φ_global  measures symmetry breaking.
//
// FACTION DEFINITION (4 factions, n=6 ÷ stride convention):
//   faction(r,c) = 2 * (r mod 2) + (c mod 2)  ∈ {0,1,2,3}
//   (quadrant-local 2×2 super-cell parity; aligns with Z2×Z2 ≤ Z4 sublattice)
//
// ORDER PARAMETER:
//   m(cell) = +1 if sealed, -1 if active, 0 if drop
//   φ_f     = mean(m) over cells in faction f
//   φ_global= mean(m) over all cells
//   Δφ      = mean_{f=0..3} |φ_f - φ_global|
//
// Δφ > 0 ⇒ Z4 symmetry broken (at least one faction deviates from ensemble).

fn op_ss_to_spin(s: int) -> int {
    if s == 2 { return 1 }
    if s == 0 { return 0 - 1 }
    return 0
}

fn op_iabs(x: int) -> int { if x < 0 { return 0 - x } return x }

// returns ppm-scaled φ_global = mean(spin) * 1000
fn phi_global_ppm(L: [[int]], side: int) -> int {
    let ss = L[2]
    let n  = len(ss)
    if n == 0 { return 0 }
    let mut acc = 0
    let mut i   = 0
    while i < n {
        acc = acc + op_ss_to_spin(ss[i])
        i = i + 1
    }
    return (acc * 1000) / n
}

// returns ppm-scaled φ_f for faction f ∈ {0,1,2,3}.
fn phi_faction_ppm(L: [[int]], side: int, f: int) -> int {
    let ss = L[2]
    let mut acc   = 0
    let mut count = 0
    let mut r = 0
    while r < side {
        let mut c = 0
        while c < side {
            let faction_id = 2 * (r % 2) + (c % 2)
            if faction_id == f {
                acc   = acc + op_ss_to_spin(ss[r * side + c])
                count = count + 1
            }
            c = c + 1
        }
        r = r + 1
    }
    if count == 0 { return 0 }
    return (acc * 1000) / count
}

// returns [phi_global_ppm, phi_f0_ppm, phi_f1_ppm, phi_f2_ppm, phi_f3_ppm, dphi_mean_ppm]
fn phi_pack(L: [[int]], side: int) -> [int] {
    let pg = phi_global_ppm(L, side)
    let p0 = phi_faction_ppm(L, side, 0)
    let p1 = phi_faction_ppm(L, side, 1)
    let p2 = phi_faction_ppm(L, side, 2)
    let p3 = phi_faction_ppm(L, side, 3)
    let d  = (op_iabs(p0 - pg) + op_iabs(p1 - pg) + op_iabs(p2 - pg) + op_iabs(p3 - pg)) / 4
    let mut out = []
    out = out.push(pg)
    out = out.push(p0)
    out = out.push(p1)
    out = out.push(p2)
    out = out.push(p3)
    out = out.push(d)
    return out
}

// ─── self-test ───────────────────────────────────────────────────────

fn op_assert(name: string, cond: bool) -> int {
    if cond { println("  OK  " + name) ; return 0 }
    println("  FAIL " + name) ; return 1
}

fn main() {
    println("order_param selftest")
    let mut fails = 0

    // all-sealed 4x4 → φ_global = +1000 ppm; all φ_f = 1000; Δφ = 0
    let mut ts = []
    let mut gs = []
    let mut ss = []
    let mut i = 0
    while i < 16 {
        ts = ts.push(5000)
        gs = gs.push(0)
        ss = ss.push(2)
        i = i + 1
    }
    let mut L = []
    L = L.push(ts)
    L = L.push(gs)
    L = L.push(ss)

    let pp = phi_pack(L, 4)
    fails = fails + op_assert("all-sealed phi_global = +1000", pp[0] == 1000)
    fails = fails + op_assert("all-sealed dphi = 0",           pp[5] == 0)

    // Z4-broken pattern: faction 0 sealed, factions 1/2/3 active.
    // faction(r,c) = 2*(r%2) + (c%2):
    //   (0,0)→0, (0,1)→1, (1,0)→2, (1,1)→3
    // So set (r even, c even) → sealed; others → active.
    let mut ss2 = []
    let mut r2 = 0
    while r2 < 4 {
        let mut c2 = 0
        while c2 < 4 {
            if (r2 % 2 == 0) && (c2 % 2 == 0) { ss2 = ss2.push(2) }
            else { ss2 = ss2.push(0) }
            c2 = c2 + 1
        }
        r2 = r2 + 1
    }
    let mut L2 = []
    L2 = L2.push(ts)
    L2 = L2.push(gs)
    L2 = L2.push(ss2)
    let pp2 = phi_pack(L2, 4)
    // f0 (4 cells) = +1, f1/f2/f3 = -1, mean = (4*1 + 12*(-1))/16 = -0.5 → -500
    fails = fails + op_assert("broken phi_global = -500",   pp2[0] == 0 - 500)
    fails = fails + op_assert("broken phi_f0 = +1000",      pp2[1] == 1000)
    fails = fails + op_assert("broken phi_f1 = -1000",      pp2[2] == 0 - 1000)
    fails = fails + op_assert("broken dphi > 0",            pp2[5] > 0)

    // determinism
    let pp_b = phi_pack(L, 4)
    fails = fails + op_assert("determinism phi_global", pp[0] == pp_b[0])

    if fails == 0 {
        println("order_param: PASS")
        exit(0)
    } else {
        println("order_param: FAIL (" + str(fails) + " assertions)")
        exit(1)
    }
}
