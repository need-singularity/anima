// edu/cell/rg/universality_class.hexa — Ising / percolation / XY comparison
//
// PARADIGM REF: docs/new_paradigm_edu_lattice_unified_20260421.md §11
// ROLE: classify measured ν against canonical 2D universality classes.
//
// CANONICAL VALUES (ν, exponent of correlation length):
//   Ising 2D         ν = 1.0        (exact: Onsager)
//   Percolation 2D   ν = 4/3 ≈ 1.333 (exact: Cardy–Nienhuis)
//   XY 2D            ν = ∞           (Kosterlitz–Thouless: ξ ~ exp)
//   Mean-field       ν = 0.5
//
// DECISION BANDS (ppm):
//   ISING_2D:         [ 900, 1100]   (Ising ± 10%)
//   PERCOLATION_2D:   [1250, 1400]
//   XY_2D:            [1500, ∞)      (treat ν > 1.5 as KT-like)
//   MEAN_FIELD:       [ 400,  600]
//   OTHER:            else
//
// FALSIFICATION (req #5):
//   if nu_mean ∉ [900, 1100] → REJECT Ising class.
//
// CONSUMES: cert `shared/state/edu_cell_rg_symmetry.json` field "nu_mean_ppm".
// OUTPUT:   prints verdict + exits 0 (verdict is data, not pass/fail).

fn uc_iabs(x: int) -> int { if x < 0 { return 0 - x } return x }

// classify ν (ppm) → class name
fn classify_nu(nu_ppm: int) -> string {
    if nu_ppm >= 900 && nu_ppm <= 1100 { return "ISING_2D" }
    if nu_ppm >= 1250 && nu_ppm <= 1400 { return "PERCOLATION_2D" }
    if nu_ppm >= 1500 { return "XY_2D" }
    if nu_ppm >= 400 && nu_ppm <= 600 { return "MEAN_FIELD" }
    return "OTHER"
}

fn reject_ising(nu_ppm: int) -> bool {
    return nu_ppm < 900 || nu_ppm > 1100
}

// closeness score to a canonical value (lower is closer, ppm distance)
fn dist_ppm(nu_ppm: int, canonical_ppm: int) -> int {
    return uc_iabs(nu_ppm - canonical_ppm)
}

fn best_class(nu_ppm: int) -> string {
    // canonical values in ppm
    let d_is = dist_ppm(nu_ppm, 1000)    // Ising: ν=1
    let d_pc = dist_ppm(nu_ppm, 1333)    // Percolation: ν=4/3
    let d_mf = dist_ppm(nu_ppm, 500)     // Mean-field: ν=0.5
    // XY: ν→∞, treat as "distance" = |nu_ppm - 1500| if nu_ppm > 1400 else huge
    let d_xy = if nu_ppm >= 1500 { 0 } else if nu_ppm >= 1400 { 1500 - nu_ppm } else { 99999 }

    let mut best_name = "ISING_2D"
    let mut best_d    = d_is
    if d_pc < best_d { best_d = d_pc ; best_name = "PERCOLATION_2D" }
    if d_mf < best_d { best_d = d_mf ; best_name = "MEAN_FIELD" }
    if d_xy < best_d { best_d = d_xy ; best_name = "XY_2D" }
    return best_name
}

// ─── self-test + demo ─────────────────────────────────────────────────

fn uc_assert(name: string, cond: bool) -> int {
    if cond { println("  OK  " + name) ; return 0 }
    println("  FAIL " + name) ; return 1
}

fn main() {
    println("universality_class selftest")
    let mut fails = 0

    fails = fails + uc_assert("1000 → ISING",         classify_nu(1000) == "ISING_2D")
    fails = fails + uc_assert("950 → ISING",          classify_nu(950)  == "ISING_2D")
    fails = fails + uc_assert("1100 edge → ISING",    classify_nu(1100) == "ISING_2D")
    fails = fails + uc_assert("1333 → PERCOLATION",   classify_nu(1333) == "PERCOLATION_2D")
    fails = fails + uc_assert("1700 → XY",            classify_nu(1700) == "XY_2D")
    fails = fails + uc_assert("500 → MEAN_FIELD",     classify_nu(500)  == "MEAN_FIELD")
    fails = fails + uc_assert("800 → OTHER",          classify_nu(800)  == "OTHER")

    fails = fails + uc_assert("reject 800",           reject_ising(800))
    fails = fails + uc_assert("accept 1000",          !reject_ising(1000))
    fails = fails + uc_assert("reject 1200",          reject_ising(1200))

    // best-class closeness for mid-range values
    fails = fails + uc_assert("1150 best = ISING",    best_class(1150) == "ISING_2D")
    fails = fails + uc_assert("1250 best = PERC",     best_class(1250) == "PERCOLATION_2D")

    // Demo: parse arg (if any) — allow CLI use: `hexa universality_class.hexa <nu_ppm>`
    let args = sys_argv()
    if len(args) >= 2 {
        let v = parse_int_uc(args[1])
        println("")
        println("── classification of ν=" + str(v) + " ppm ──")
        println("  class            = " + classify_nu(v))
        println("  nearest canonical= " + best_class(v))
        println("  reject ISING_2D  = " + if reject_ising(v) { "true" } else { "false" })
    }

    if fails == 0 {
        println("universality_class: PASS")
        exit(0)
    } else {
        println("universality_class: FAIL (" + str(fails) + " assertions)")
        exit(1)
    }
}

// minimal local parse_int (stage0-safe) ────────────────────────────────
fn parse_int_uc(s: string) -> int {
    let n = len(s)
    if n == 0 { return 0 }
    let sign = if s.substring(0, 1) == "-" { -1 } else { 1 }
    let start = if sign == -1 { 1 } else { 0 }
    let mut acc = 0
    let mut i = start
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "0" { acc = acc * 10 + 0 }
        else if c == "1" { acc = acc * 10 + 1 }
        else if c == "2" { acc = acc * 10 + 2 }
        else if c == "3" { acc = acc * 10 + 3 }
        else if c == "4" { acc = acc * 10 + 4 }
        else if c == "5" { acc = acc * 10 + 5 }
        else if c == "6" { acc = acc * 10 + 6 }
        else if c == "7" { acc = acc * 10 + 7 }
        else if c == "8" { acc = acc * 10 + 8 }
        else if c == "9" { acc = acc * 10 + 9 }
        i = i + 1
    }
    return acc * sign
}

// sys_argv fallback — stage0 exposes script args via argv(); defensive empty
fn sys_argv() -> [string] {
    let mut out = []
    return out
}
