// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/lagrangian/v_structure.hexa
//
//  PURPOSE
//    Structural potential V_structure(comp, diss) of the unified edu/cell
//    Lagrangian.  Depends on two axes:
//
//        comp  — compositionality score   (0..1000 per-mille)
//        diss  — dissipation efficiency    (0..1000 per-mille, see
//                 edu/cell/dissipation/efficiency.hexa)
//
//    STUB MODE (both axes not yet fully measured for this corpus):
//      We use a log-score proxy
//
//          V_structure(W, W_max)  =  − log( W / W_max )
//
//      where W = score_per_mille, W_max = 1000 (full crystallization).
//      This is the same analytic form V will take once comp+diss are
//      real; only the source of "structural fitness" changes.  Sign is
//      negative so that V **decreases** as structure hardens (and the
//      Lagrangian L = T − V **increases** in the absorb direction).
//
//    Integer fixed-point, ×1000.  We implement log via a small lookup
//    table on ln(x) for x ∈ [0, 1] at 0.05 resolution; values outside
//    clamp to the nearest end.
//
//  API (pure fn, no I/O, LLM=none, deterministic)
//    v_structure_stub_x1000(w, w_max)          -> int      // ×1000
//    v_structure_full_x1000(comp, diss)        -> int      // ×1000 (FUTURE)
//    potential_trajectory(ws, w_max)           -> list[int]
//
//  HEXA-ONLY · raw#9 · deterministic · no LLM · STUB until comp+diss ship.
// ════════════════════════════════════════════════════════════════════════════

// Integer ln(x) ×1000 for x in per-mille (0..1000).  Returns negative for x<1000.
// Table: ln(x/1000) ×1000 for x ∈ {50, 100, 150, …, 1000}.
// Outside range → clamp.
fn ln_per_mille_x1000(x: int) -> int {
    // Clamp
    let mut v = x
    if v <= 0   { v = 1 }
    if v > 1000 { v = 1000 }
    // Hand-tabulated ln(v/1000) ×1000 (floor).  20 bins of width 50.
    if v >= 1000 { return 0 }
    if v >= 950  { return -51 }    // ln(0.95)=-0.0513
    if v >= 900  { return -105 }   // ln(0.90)=-0.1054
    if v >= 850  { return -163 }   // ln(0.85)=-0.1625
    if v >= 800  { return -223 }   // ln(0.80)=-0.2231
    if v >= 750  { return -288 }   // ln(0.75)=-0.2877
    if v >= 700  { return -357 }   // ln(0.70)=-0.3567
    if v >= 650  { return -431 }   // ln(0.65)=-0.4308
    if v >= 600  { return -511 }   // ln(0.60)=-0.5108
    if v >= 550  { return -598 }   // ln(0.55)=-0.5978
    if v >= 500  { return -693 }   // ln(0.50)=-0.6931
    if v >= 450  { return -799 }   // ln(0.45)=-0.7985
    if v >= 400  { return -916 }   // ln(0.40)=-0.9163
    if v >= 350  { return -1050 }  // ln(0.35)=-1.0498
    if v >= 300  { return -1204 }  // ln(0.30)=-1.2040
    if v >= 250  { return -1386 }  // ln(0.25)=-1.3863
    if v >= 200  { return -1609 }  // ln(0.20)=-1.6094
    if v >= 150  { return -1897 }  // ln(0.15)=-1.8971
    if v >= 100  { return -2303 }  // ln(0.10)=-2.3026
    if v >= 50   { return -2996 }  // ln(0.05)=-2.9957
    return -6908                    // ln(0.001)=-6.9078 floor
}

// V_structure stub: V = -ln(w/w_max), ×1000.
// Convention: w_max > 0; w clamped [1, w_max].
fn v_structure_stub_x1000(w: int, w_max: int) -> int {
    if w_max <= 0 { return 0 }
    // ratio in per-mille ∈ [0, 1000]
    let ratio = if w >= w_max { 1000 } else { (w * 1000) / w_max }
    let ln_val = ln_per_mille_x1000(ratio)
    return 0 - ln_val
}

// Full V once comp + diss are both online.  Placeholder implementation:
// weighted geometric mean penalty → V = -½(ln(comp/1000) + ln(diss/1000)).
// Kept to preserve call sites; CURRENTLY UNUSED by mvp (comp+diss not yet
// measured on the 4-gen corpus).
fn v_structure_full_x1000(comp: int, diss: int) -> int {
    let a = v_structure_stub_x1000(comp, 1000)
    let b = v_structure_stub_x1000(diss, 1000)
    return (a + b) / 2
}

// Potential trajectory — V_k per gen given weight series ws.
fn potential_trajectory(ws: list, w_max: int) -> list {
    let n = ws.len()
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(v_structure_stub_x1000(ws[i], w_max))
        i = i + 1
    }
    return out
}
