// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/lagrangian/t_tension.hexa
//
//  PURPOSE
//    Kinetic-energy term T_tension of the unified edu/cell Lagrangian.
//
//        T_tension  =  (1/2) · (dW/dt)²                            (continuous)
//        T_tension  ≈  (1/2) · ΔW² / Δt                            (discrete)
//
//    where W is the generation-level "weight" proxy.  In the 4-gen
//    crystallize corpus (commit 58aa75eb) the natural W is
//    score_per_mille — the sealed fraction ×1000 — since it is the
//    only trainable quantity that persists across generations.
//
//    We treat each generation as one discrete time step (Δt = 1),
//    giving
//
//        T_k = (W_k − W_{k-1})² / 2              (per-mille² / 2)
//
//    Integer fixed-point: everything in (per-mille) units to match the
//    rest of edu/cell (score_per_mille, tl_boost_per_mille, …).  Output
//    of t_tension is scaled ×1000 so that later L_cell arithmetic stays
//    integer-only.
//
//  API (pure fn, no I/O, LLM=none, deterministic)
//    delta_w(w_k, w_prev)        -> int         // per-mille
//    t_tension_x1000(...)        -> int         // ×1000
//    kinetic_trajectory(ws)      -> list[int]   // ×1000 per gen (T_1 = 0)
//
//  HEXA-ONLY · raw#9 · deterministic · no LLM
// ════════════════════════════════════════════════════════════════════════════

// ΔW (per-mille).  Convention: W_k − W_{k-1}.
fn delta_w(w_k: int, w_prev: int) -> int {
    return w_k - w_prev
}

// Kinetic energy T_k = (ΔW²)/2, emitted ×1000 to preserve integer precision.
// Note: input w in per-mille (×1000) → ΔW in per-mille → ΔW² in per-mille²
// (×1_000_000).  We divide by 1000 once and halve once → final ×1000.
fn t_tension_x1000(w_k: int, w_prev: int) -> int {
    let dw = delta_w(w_k, w_prev)
    // dw*dw is per-mille² (×1_000_000).  /1000 brings back to ×1000.
    // /2 applies the (1/2) factor.  Order: /2 first to keep precision.
    let sq = dw * dw
    return (sq / 2) / 1000
}

// Trajectory: given ws (list of per-mille weights), returns T_k ×1000 per gen.
// T_1 ≡ 0 by convention (no predecessor).
fn kinetic_trajectory(ws: list) -> list {
    let n = ws.len()
    let mut out = []
    let mut i = 0
    while i < n {
        if i == 0 {
            out = out.push(0)
        } else {
            let w_k = ws[i]
            let w_p = ws[i - 1]
            out = out.push(t_tension_x1000(w_k, w_p))
        }
        i = i + 1
    }
    return out
}
