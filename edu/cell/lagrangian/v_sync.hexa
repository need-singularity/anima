// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/lagrangian/v_sync.hexa
//
//  PURPOSE
//    Phase-coherence potential V_sync(entrain) of the unified edu/cell
//    Lagrangian.  Kuramoto-style order parameter for lattice phases.
//
//        r  =  |  (1/N) Σ_j exp(i · θ_j) |                         (classic)
//        V_sync(entrain)  =  1 − r                                 (0..1)
//
//    "entrain" = the population phase-lock strength; V **decreases** as
//    coherence increases (same sign convention as V_structure).
//
//    STUB MODE.  Current 4-gen corpus does NOT expose per-cell phases
//    (only saturation enum {active, drop, sealed}).  We provide the
//    full API plus a proxy estimator using sealed_fraction as a lower
//    bound on r (every sealed cell is a phase-locked oscillator):
//
//        r_proxy  ≈  sealed / total   =  score_per_mille / 1000
//        V_sync_proxy  =  1000 − score_per_mille   (×1000)
//
//    The real Kuramoto v_sync_kuramoto_x1000() is wired for future use
//    once per-cell phase is exported from the lattice.
//
//  API (pure fn, no I/O, LLM=none, deterministic)
//    v_sync_proxy_x1000(score_per_mille)          -> int          // ×1000
//    v_sync_kuramoto_x1000(phases_x1000, N)       -> int          // FUTURE
//    sync_trajectory(scores)                      -> list[int]
//
//  HEXA-ONLY · raw#9 · deterministic · no LLM · STUB proxy.
// ════════════════════════════════════════════════════════════════════════════

// Proxy: V_sync = 1 − sealed_fraction, in ×1000.
// score_per_mille ∈ [0, 1000]; clamp defensively.
fn v_sync_proxy_x1000(score_per_mille: int) -> int {
    let mut s = score_per_mille
    if s < 0    { s = 0 }
    if s > 1000 { s = 1000 }
    return 1000 - s
}

// Integer cos(θ) ×1000 for θ in per-mille radians (mod 2π).
// Lookup on 24 bins of width π/12 ≈ 0.2618 rad (261 per-mille).
// CURRENTLY UNUSED — reserved for v_sync_kuramoto_x1000 once phases ship.
fn _cos_perm_x1000(theta_perm: int) -> int {
    // Wrap into [0, 6283] (2π ≈ 6.2832 rad → 6283 per-mille)
    let tau = 6283
    let mut t = theta_perm % tau
    if t < 0 { t = t + tau }
    // 24 bins of 262 per-mille.  Values: cos at π/12·k for k=0..23.
    if t < 131    { return 1000 }    // 0..π/12
    if t < 393    { return 966 }
    if t < 655    { return 866 }
    if t < 916    { return 707 }
    if t < 1178   { return 500 }
    if t < 1440   { return 259 }
    if t < 1702   { return 0 }
    if t < 1963   { return -259 }
    if t < 2225   { return -500 }
    if t < 2487   { return -707 }
    if t < 2749   { return -866 }
    if t < 3010   { return -966 }
    if t < 3272   { return -1000 }
    if t < 3534   { return -966 }
    if t < 3796   { return -866 }
    if t < 4057   { return -707 }
    if t < 4319   { return -500 }
    if t < 4581   { return -259 }
    if t < 4843   { return 0 }
    if t < 5104   { return 259 }
    if t < 5366   { return 500 }
    if t < 5628   { return 707 }
    if t < 5890   { return 866 }
    if t < 6151   { return 966 }
    return 1000
}

fn _sin_perm_x1000(theta_perm: int) -> int {
    // sin(θ) = cos(θ − π/2)  → shift by π/2 ≈ 1571 per-mille
    return _cos_perm_x1000(theta_perm - 1571)
}

// Full Kuramoto order parameter r = |1/N · Σ exp(i θ_j)|, ×1000.
// phases_x1000 is a list of per-mille radians (same convention as _cos_perm).
// FUTURE API — untriggered on current 4-gen corpus.
fn v_sync_kuramoto_x1000(phases_x1000: list, N: int) -> int {
    if N <= 0 { return 1000 }
    let mut sum_c = 0
    let mut sum_s = 0
    let mut i = 0
    while i < N {
        sum_c = sum_c + _cos_perm_x1000(phases_x1000[i])
        sum_s = sum_s + _sin_perm_x1000(phases_x1000[i])
        i = i + 1
    }
    // r² · N² · 1_000_000 = sum_c² + sum_s² (each term ×1000)
    let mag2 = sum_c * sum_c + sum_s * sum_s    // ×1_000_000 of N²·r²
    // r (×1000)  ≈ sqrt(mag2)/N; use Newton integer sqrt
    if mag2 <= 0 { return 1000 }
    let mut y = 1000
    let mut k = 0
    while k < 24 {
        if y == 0 { y = 1 }
        y = (y + mag2 / y) / 2
        k = k + 1
    }
    let r_x1000 = y / N
    let mut r = r_x1000
    if r > 1000 { r = 1000 }
    if r < 0 { r = 0 }
    return 1000 - r
}

// V_sync trajectory per gen using proxy (sealed-fraction lower bound).
fn sync_trajectory(scores: list) -> list {
    let n = scores.len()
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(v_sync_proxy_x1000(scores[i]))
        i = i + 1
    }
    return out
}
