// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/lagrangian/natural_gen5_min.hexa
//
//  Minimal driver: single seed (derived from 4-gen corpus base_seed=20260421),
//  runs 5 generations uniformly, emits W/T/V/L trajectory.
//
//  Stage0-friendly: avoids heavy string concat loops (lattice primitives
//  unavoidable; JSON emission is a small fixed-size tail).
//
//  For multi-seed reproducibility we rely on invoking this script 3x with
//  NG5_BASE_SEED env var override (see natural_gen5_sweep.hexa driver).
//
//  raw#9 · hexa-only · deterministic · no LLM.
// ════════════════════════════════════════════════════════════════════════════

let ASCII_TAB_NG5 = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-|.↔/+=() <>:;'\""

fn ccode_ng5(c: string) -> int {
    let t     = ASCII_TAB_NG5
    let n     = len(t)
    let mut i = 0
    while i < n {
        if t.substring(i, i + 1) == c { return i + 1 }
        i = i + 1
    }
    return 127
}

fn hash_ng5(s: string) -> int {
    let mut acc = 1469598103
    let mut i   = 0
    let n       = len(s)
    while i < n {
        let c = s.substring(i, i + 1)
        acc   = acc * 31 + ccode_ng5(c)
        acc   = acc % 2147483647
        i     = i + 1
    }
    return acc
}

// Encoded cell as tuple-int to avoid heavy string concat per-cell:
// We still need string form for compatibility with existing primitives —
// but we strip it down: single string = "t|g|s" (no a_id/b_id stored).
// Per-cell hash is computed from (row, col, gen_base_seed) directly.

struct Cell {
    rc: int,      // row*size + col (address)
    g: int,       // intrinsic gradient [-1000, 1000]
    t: int,       // tension (0..10000)
    s: int,       // state: 0=active, 1=sealed, 2=drop
}

fn clamp_i(v: int, lo: int, hi: int) -> int {
    if v < lo { return lo }
    if v > hi { return hi }
    return v
}

fn iabs_i(x: int) -> int { if x < 0 { return 0 - x } return x }
fn sign_i(x: int) -> int { if x > 0 { return 1 }  if x < 0 { return -1 }  return 0 }

// Per-cell initial gradient (byte-compatible with tool/edu_cell_4gen_crystallize
// make_cell_tl: uses hash_proj on a_id|b_id|s=seed+offset). We mimic the
// hash computation with synthesized identifiers.
fn init_g(rc: int, base_seed: int, tl: int) -> int {
    // a_id = "n_" + row + "_" + col + "_a"; b_id similar. We compute the
    // exact string to preserve byte-identity.
    let size = 3  // gen_size(>=4) = 3
    let row = rc / size
    let col = rc - row * size
    let a_id = "n_" + str(row) + "_" + str(col) + "_a"
    let b_id = "n_" + str(row) + "_" + str(col) + "_b"
    let per = base_seed + rc
    let key = a_id + "|" + b_id + "|s=" + str(per)
    let raw_g = hash_ng5(key)
    let base_g = (raw_g % 2001) - 1000
    let scaled = (base_g * (1000 - tl)) / 1000
    let biased = scaled - tl
    return clamp_i(biased, -1000, 1000)
}

// Per-cell seal probability (byte-compatible with fixpoint_seal_tl).
// Full key = a_id + "<->" + b_id + "|g=" + g + "|t=" + tick
fn seal_check(rc: int, size: int, g: int, tl: int, tick: int) -> bool {
    let row = rc / size
    let col = rc - row * size
    let a_id = "n_" + str(row) + "_" + str(col) + "_a"
    let b_id = "n_" + str(row) + "_" + str(col) + "_b"
    let key = a_id + "<->" + b_id + "|g=" + str(g) + "|t=" + str(tick)
    let h = hash_ng5(key)
    let tl_c = if tl > 1000 { 1000 } else { tl }
    let mut div = 12
    if tl_c >= 200 { div = 8 }
    if tl_c >= 500 { div = 5 }
    if tl_c >= 700 { div = 2 }
    if tl_c >= 950 { div = 1 }
    if div <= 1 { return true }
    return (h % div) == 0
}

fn make_lattice(size: int, t0: int, seed: int, tl: int) -> [Cell] {
    let mut out = []
    let tot = size * size
    let mut i = 0
    while i < tot {
        let g = init_g(i, seed, tl)
        out = out.push(Cell { rc: i, g: g, t: t0, s: 0 })
        i = i + 1
    }
    return out
}

// Attraction: sum over all OTHER active cells using Manhattan 1/r^2 (k_numer=100).
fn attr_at(lat: [Cell], size: int, rc: int, k_numer: int) -> int {
    let row = rc / size
    let col = rc - row * size
    let mut acc = 0
    let mut j = 0
    let tot = size * size
    while j < tot {
        if j != rc {
            let jc = lat[j]
            if jc.s == 0 {
                let jrow = j / size
                let jcol = j - jrow * size
                let d = iabs_i(jrow - row) + iabs_i(jcol - col)
                let d2 = d * d
                let contrib = (sign_i(jc.g) * jc.t) / d2
                acc = acc + contrib
            }
        }
        j = j + 1
    }
    if k_numer <= 0 { return 0 }
    return acc / k_numer
}

fn step_lattice(lat: [Cell], size: int, upper: int, lower: int, k_numer: int, tl: int, tick: int) -> [Cell] {
    let mut out = []
    let tot = size * size
    let mut i = 0
    while i < tot {
        let c = lat[i]
        if c.s != 0 {
            out = out.push(c)
        } else {
            let a = attr_at(lat, size, i, k_numer)
            let t_new = clamp_i(c.t + a + ((c.g * 3) / 4), 0, 10000)
            if t_new > upper {
                out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 2 })
            } else if t_new < lower {
                if seal_check(c.rc, size, c.g, tl, tick) {
                    out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 1 })
                } else {
                    out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 0 })
                }
            } else {
                out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 0 })
            }
        }
        i = i + 1
    }
    return out
}

fn count_state(lat: [Cell], target: int) -> int {
    let mut n = 0
    let mut i = 0
    while i < len(lat) {
        if lat[i].s == target { n = n + 1 }
        i = i + 1
    }
    return n
}

fn gen_sig(lat: [Cell]) -> int {
    let mut acc = 2166136261
    let mut i = 0
    while i < len(lat) {
        let c = lat[i]
        if c.s == 1 {
            // Byte-compat with original: hash("a_id|b_id|g="+g)
            let size_assumed = 3
            let row = c.rc / size_assumed
            let col = c.rc - row * size_assumed
            let key = "n_" + str(row) + "_" + str(col) + "_a" + "|" + "n_" + str(row) + "_" + str(col) + "_b" + "|g=" + str(c.g)
            acc = (acc * 31 + hash_ng5(key)) % 2147483647
        }
        i = i + 1
    }
    return acc
}

// ─── sim params (mirror tool/edu_cell_4gen_crystallize.hexa) ──────────────

let NGM_T0 = 5000
let NGM_UPPER = 9000
let NGM_LOWER = 1000
let NGM_K_NUMER = 100

fn gen_size_ng(gen_idx: int) -> int {
    if gen_idx == 1 { return 5 }
    if gen_idx == 2 { return 4 }
    if gen_idx == 3 { return 4 }
    return 3
}

fn gen_tl_ng(gen_idx: int) -> int {
    if gen_idx == 1 { return 0 }
    if gen_idx == 2 { return 300 }
    if gen_idx == 3 { return 550 }
    return 800
}

// Simpler size-aware init_g/seal: use passed-in size instead of hardcoded 3.
fn init_g_s(rc: int, size: int, base_seed: int, tl: int) -> int {
    let row = rc / size
    let col = rc - row * size
    let a_id = "n_" + str(row) + "_" + str(col) + "_a"
    let b_id = "n_" + str(row) + "_" + str(col) + "_b"
    let per = base_seed + rc
    let key = a_id + "|" + b_id + "|s=" + str(per)
    let raw_g = hash_ng5(key)
    let base_g = (raw_g % 2001) - 1000
    let scaled = (base_g * (1000 - tl)) / 1000
    let biased = scaled - tl
    return clamp_i(biased, -1000, 1000)
}

fn seal_check_s(rc: int, size: int, g: int, tl: int, tick: int) -> bool {
    let row = rc / size
    let col = rc - row * size
    let a_id = "n_" + str(row) + "_" + str(col) + "_a"
    let b_id = "n_" + str(row) + "_" + str(col) + "_b"
    let key = a_id + "<->" + b_id + "|g=" + str(g) + "|t=" + str(tick)
    let h = hash_ng5(key)
    let tl_c = if tl > 1000 { 1000 } else { tl }
    let mut div = 12
    if tl_c >= 200 { div = 8 }
    if tl_c >= 500 { div = 5 }
    if tl_c >= 700 { div = 2 }
    if tl_c >= 950 { div = 1 }
    if div <= 1 { return true }
    return (h % div) == 0
}

fn make_lattice_s(size: int, t0: int, seed: int, tl: int) -> [Cell] {
    let mut out = []
    let tot = size * size
    let mut i = 0
    while i < tot {
        let g = init_g_s(i, size, seed, tl)
        out = out.push(Cell { rc: i, g: g, t: t0, s: 0 })
        i = i + 1
    }
    return out
}

fn step_lattice_s(lat: [Cell], size: int, upper: int, lower: int, k_numer: int, tl: int, tick: int) -> [Cell] {
    let mut out = []
    let tot = size * size
    let mut i = 0
    while i < tot {
        let c = lat[i]
        if c.s != 0 {
            out = out.push(c)
        } else {
            let a = attr_at(lat, size, i, k_numer)
            let t_new = clamp_i(c.t + a + ((c.g * 3) / 4), 0, 10000)
            if t_new > upper {
                out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 2 })
            } else if t_new < lower {
                if seal_check_s(c.rc, size, c.g, tl, tick) {
                    out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 1 })
                } else {
                    out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 0 })
                }
            } else {
                out = out.push(Cell { rc: c.rc, g: c.g, t: t_new, s: 0 })
            }
        }
        i = i + 1
    }
    return out
}

fn gen_sig_s(lat: [Cell], size: int) -> int {
    let mut acc = 2166136261
    let mut i = 0
    while i < len(lat) {
        let c = lat[i]
        if c.s == 1 {
            let row = c.rc / size
            let col = c.rc - row * size
            let key = "n_" + str(row) + "_" + str(col) + "_a" + "|" + "n_" + str(row) + "_" + str(col) + "_b" + "|g=" + str(c.g)
            acc = (acc * 31 + hash_ng5(key)) % 2147483647
        }
        i = i + 1
    }
    return acc
}

struct GRes {
    gen: int,
    size: int,
    tl: int,
    seed: int,
    active: int,
    dropped: int,
    sealed: int,
    score_per_mille: int,
    sig: int,
}

fn run_one_gen(gen_idx: int, parent_sig: int, base_seed: int) -> GRes {
    let size = gen_size_ng(gen_idx)
    let tl = gen_tl_ng(gen_idx)
    let seed = if gen_idx == 1 { base_seed } else { (parent_sig * 13 + gen_idx * 17 + 101) % 2147483647 }
    let mut L = make_lattice_s(size, NGM_T0, seed, tl)
    let mut t = 0
    while t < 12 {
        L = step_lattice_s(L, size, NGM_UPPER, NGM_LOWER, NGM_K_NUMER, tl, t)
        t = t + 1
    }
    let act = count_state(L, 0)
    let drp = count_state(L, 2)
    let sld = count_state(L, 1)
    let tot = size * size
    let score = if tot > 0 { (sld * 1000) / tot } else { 0 }
    let sig = gen_sig_s(L, size)
    return GRes { gen: gen_idx, size: size, tl: tl, seed: seed, active: act, dropped: drp, sealed: sld, score_per_mille: score, sig: sig }
}

// Lagrangian primitives
fn t_tension_ng(w_k: int, w_prev: int) -> int {
    let dw = w_k - w_prev
    return (dw * dw / 2) / 1000
}

fn ln_perm_ng(x: int) -> int {
    let mut v = x
    if v <= 0   { v = 1 }
    if v > 1000 { v = 1000 }
    if v >= 1000 { return 0 }
    if v >= 950  { return -51 }
    if v >= 900  { return -105 }
    if v >= 850  { return -163 }
    if v >= 800  { return -223 }
    if v >= 750  { return -288 }
    if v >= 700  { return -357 }
    if v >= 650  { return -431 }
    if v >= 600  { return -511 }
    if v >= 550  { return -598 }
    if v >= 500  { return -693 }
    if v >= 450  { return -799 }
    if v >= 400  { return -916 }
    if v >= 350  { return -1050 }
    if v >= 300  { return -1204 }
    if v >= 250  { return -1386 }
    if v >= 200  { return -1609 }
    if v >= 150  { return -1897 }
    if v >= 100  { return -2303 }
    if v >= 50   { return -2996 }
    return -6908
}

fn v_struct_ng(w: int) -> int {
    if w >= 1000 { return 0 }
    return 0 - ln_perm_ng(w)
}

fn v_sync_ng(w: int) -> int {
    let mut s = w
    if s < 0 { s = 0 }
    if s > 1000 { s = 1000 }
    return 1000 - s
}

fn parse_arg_int(s: string, fallback: int) -> int {
    if len(s) == 0 { return fallback }
    let mut acc = 0
    let mut i = 0
    let sign = if s.substring(0, 1) == "-" { -1 } else { 1 }
    if sign == -1 { i = 1 }
    while i < len(s) {
        let ch = s.substring(i, i + 1)
        let d = if ch == "0" { 0 }
              else if ch == "1" { 1 }
              else if ch == "2" { 2 }
              else if ch == "3" { 3 }
              else if ch == "4" { 4 }
              else if ch == "5" { 5 }
              else if ch == "6" { 6 }
              else if ch == "7" { 7 }
              else if ch == "8" { 8 }
              else if ch == "9" { 9 }
              else { -1 }
        if d < 0 { return fallback }
        acc = acc * 10 + d
        i = i + 1
    }
    return acc * sign
}

fn main() {
    // Base seed from argv[2] or default 20260421.
    let av = argv()
    let base_seed = if len(av) >= 3 { parse_arg_int(av[2], 20260421) } else { 20260421 }

    println("=== natural_gen5_min  base_seed=" + str(base_seed) + " ===")

    let mut parent_sig = 0
    let mut ws = [0]  // gen 0 placeholder for T_1 computation
    let mut sigs = []
    let mut k = 1
    while k <= 5 {
        let r = run_one_gen(k, parent_sig, base_seed)
        println("gen=" + str(k) + " size=" + str(r.size) + " tl=" + str(r.tl) + " seed=" + str(r.seed) + " active=" + str(r.active) + " drop=" + str(r.dropped) + " sealed=" + str(r.sealed) + " score=" + str(r.score_per_mille) + " sig=" + str(r.sig))
        ws = ws.push(r.score_per_mille)
        sigs = sigs.push(r.sig)
        parent_sig = r.sig
        k = k + 1
    }

    // Lagrangian trajectory
    println("")
    println("─── Lagrangian trajectory ───")
    println("gen |    W |     T |   V_tot |       L")
    let mut ts = []
    let mut vs = []
    let mut ls = []
    let mut j = 1
    while j <= 5 {
        let w_curr = ws[j]
        let w_prev = ws[j - 1]
        let t = if j == 1 { 0 } else { t_tension_ng(w_curr, w_prev) }
        let v_total = v_struct_ng(w_curr) + v_sync_ng(w_curr)
        let l = t - v_total
        ts = ts.push(t)
        vs = vs.push(v_total)
        ls = ls.push(l)
        println(" " + str(j) + "  | " + str(w_curr) + " | " + str(t) + " | " + str(v_total) + " | " + str(l))
        j = j + 1
    }

    // Verdict
    let eps = 1
    let dw = iabs_i(ws[5] - ws[4])
    let t5 = ts[4]
    let v5 = vs[4]
    let verdict = if dw <= eps && t5 <= eps && v5 <= eps {
        "STATIONARY_AT_FIXPOINT"
    } else if dw <= eps {
        "STATIONARY_BOUNDARY"
    } else if ws[5] > ws[4] {
        "DESCENT_ONLY"
    } else {
        "NOT_YET"
    }

    println("")
    println("─── verdict ───")
    println("dW_{4->5} = " + str(ws[5] - ws[4]) + "   (|dW|=" + str(dw) + " eps=" + str(eps) + ")")
    println("T_5       = " + str(t5))
    println("V_5       = " + str(v5))
    println("L_5       = " + str(ls[4]))
    println("verdict   = " + verdict)

    // SHA proxy (signature fold)
    let mut sh = sigs[0]
    let mut i = 1
    while i < len(sigs) {
        sh = (sh * 31 + sigs[i]) % 2147483647
        i = i + 1
    }
    println("run_sha_proxy = " + str(sh))

    // Emit single-line JSON for aggregation by sweep driver
    let mut p = []
    p = p.push("{\"base_seed\":")
    p = p.push(str(base_seed))
    p = p.push(",\"ws\":[")
    let mut q = 1
    while q <= 5 {
        if q > 1 { p = p.push(",") }
        p = p.push(str(ws[q]))
        q = q + 1
    }
    p = p.push("],\"ts\":[")
    q = 0
    while q < 5 {
        if q > 0 { p = p.push(",") }
        p = p.push(str(ts[q]))
        q = q + 1
    }
    p = p.push("],\"vs\":[")
    q = 0
    while q < 5 {
        if q > 0 { p = p.push(",") }
        p = p.push(str(vs[q]))
        q = q + 1
    }
    p = p.push("],\"ls\":[")
    q = 0
    while q < 5 {
        if q > 0 { p = p.push(",") }
        p = p.push(str(ls[q]))
        q = q + 1
    }
    p = p.push("],\"dw_45\":")
    p = p.push(str(ws[5] - ws[4]))
    p = p.push(",\"t5\":")
    p = p.push(str(t5))
    p = p.push(",\"v5\":")
    p = p.push(str(v5))
    p = p.push(",\"l5\":")
    p = p.push(str(ls[4]))
    p = p.push(",\"verdict\":\"")
    p = p.push(verdict)
    p = p.push("\",\"run_sha_proxy\":")
    p = p.push(str(sh))
    p = p.push("}")
    println("JSON " + p.join(""))

    if verdict == "STATIONARY_AT_FIXPOINT" { exit(0) }
    exit(1)
}
