// edu/cell/information/core/compression.hexa
// ─────────────────────────────────────────────────────────────
// O1 compression ratio C = d_full / d_bottleneck.
//
// "Effective" bottleneck dim is estimated by participation-ratio
// (PR) of the per-dimension variance spectrum:
//     PR = (sum σ_j²)² / sum(σ_j^4)
// PR ∈ [1, d_full]. As the distribution concentrates on a
// subspace, PR→1 (max compression). We return d_full / PR.
//
// This is phase-jump sensitive: when IB bottleneck engages, a
// handful of dims carry almost all variance → PR drops sharply,
// C spikes. Threshold 0.4 on ΔC/C_prev flags the jump.
//
// API
//   compression_ratio(X, d_full)  -> float  (≥ 1)
//   participation_ratio(X)         -> float
//
// X is [n][d_full].
// ─────────────────────────────────────────────────────────────

fn col_mean(X: array, j: int) -> float {
    let n = X.len()
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + X[i][j]
        i = i + 1
    }
    return s / to_float(n)
}

fn col_variance(X: array, j: int) -> float {
    let n = X.len()
    if n < 2 { return 0.0 }
    let mu = col_mean(X, j)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = X[i][j] - mu
        s = s + d * d
        i = i + 1
    }
    return s / to_float(n - 1)
}

// Participation ratio of column variance spectrum:
//   PR = (Σ σ_j²)² / Σ σ_j^4   ∈ [1, d]
fn participation_ratio(X: array) -> float {
    let n = X.len()
    if n == 0 { return 1.0 }
    let d = X[0].len()
    if d == 0 { return 1.0 }
    let mut num = 0.0   // Σ σ²
    let mut den = 0.0   // Σ σ⁴
    let mut j = 0
    while j < d {
        let v = col_variance(X, j)
        num = num + v
        den = den + v * v
        j = j + 1
    }
    if den < 1.0e-12 { return 1.0 }
    let pr = (num * num) / den
    if pr < 1.0 { return 1.0 }
    return pr
}

// Compression ratio C = d_full / effective_bottleneck_dim.
fn compression_ratio(X: array, d_full: int) -> float {
    let pr = participation_ratio(X)
    if pr < 1.0e-9 { return to_float(d_full) }
    return to_float(d_full) / pr
}
