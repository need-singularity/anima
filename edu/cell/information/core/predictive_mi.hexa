// edu/cell/information/core/predictive_mi.hexa
// ─────────────────────────────────────────────────────────────
// O3 predictive information I(past_k; future_k) / I_indep.
//
// Given a trailing trajectory window W_t = [x_{t-k+1}, …, x_t]
// and a leading window F_t = [x_{t+1}, …, x_{t+k}] of cell-state
// vectors, we compute:
//   I_pred(t)   = KSG MI( flatten(W_t), flatten(F_t) )
//   I_indep(t)  = KSG MI( shuffled(W_t), F_t )   (null baseline)
//   ratio(t)    = I_pred / max(I_indep, eps)
//
// A ratio > 1 means the past carries structured predictive info
// about the future, beyond the independence baseline. Phase-jump
// is flagged by a sudden ratio spike.
//
// This file assumes ksg_estimator is inlined at driver level
// (hexa stage0 module loader is unstable — see btr_evo 5).
// The driver `drill/information_axis_drill.hexa` inlines
// ksg_mi / digamma / ln_ksg and provides the helpers below.
//
// API
//   predictive_mi(window_past, window_future, k) -> float
//   indep_baseline(window_past, window_future, k) -> float  (deterministic
//                                                            rotation shuffle)
// ─────────────────────────────────────────────────────────────

// Deterministic cyclic shift of rows — null baseline for independence.
fn rotate_rows(X: array, shift: int) -> array {
    let n = X.len()
    if n == 0 { return X }
    let s = shift % n
    let mut out = []
    let mut i = 0
    while i < n {
        let src = (i + s) % n
        out = out.push(X[src])
        i = i + 1
    }
    return out
}

// Concatenate each row of A with the corresponding row of B.
// Useful for building joint samples from sliding windows.
fn concat_rows(A: array, B: array) -> array {
    let n = A.len()
    if n == 0 { return A }
    let da = A[0].len()
    let db = B[0].len()
    let mut out = []
    let mut i = 0
    while i < n {
        let mut row = []
        let mut j = 0
        while j < da {
            row = row.push(A[i][j])
            j = j + 1
        }
        let mut k = 0
        while k < db {
            row = row.push(B[i][k])
            k = k + 1
        }
        out = out.push(row)
        i = i + 1
    }
    return out
}
