// edu/cell/consciousness/cell_observer.hexa — unified observer
//
// Observes Φ (consciousness axis) + τ (tension axis) + topology (cell
// count / connectivity) on every step. Pure snapshot function — no state,
// caller threads history.
//
// Snapshot returns a record:
//   { step, n_cells, phi, tau_avg, topology_hash, observables }

struct CellSnapshot {
    step:          int,
    n_cells:       int,
    phi_iit:       float,
    phi_gws:       float,
    phi_meta:      float,
    lambda_resil:  float,
    tau_avg:       float,
    topology_sig:  int,
    verdict:       string
}

// τ_avg — simple mean of per-cell L2 magnitudes (proxy for tension).
fn co_tau_average(hidden: array, n_cells: int, d: int) -> float {
    if n_cells < 1 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n_cells {
        let mut norm = 0.0
        let mut j = 0
        while j < d {
            let a = hidden[i * d + j]
            norm = norm + a * a
            j = j + 1
        }
        if norm > 0.0 { norm = sqrt(norm) }
        sum = sum + norm
        i = i + 1
    }
    return sum / to_float(n_cells)
}

// topology_sig — fnv-hash of (n_cells, d, sign pattern)
fn co_topology_sig(hidden: array, n_cells: int, d: int) -> int {
    let mut acc = 2166136261
    acc = (acc * 16777619 + n_cells) % 2147483647
    acc = (acc * 16777619 + d) % 2147483647
    let mut i = 0
    while i < n_cells {
        let mut j = 0
        while j < d {
            let a = hidden[i * d + j]
            let sign_code = if a < 0.0 { 1 } else { 0 }
            acc = (acc * 16777619 + sign_code) % 2147483647
            j = j + 1
        }
        i = i + 1
    }
    if acc < 0 { acc = acc + 2147483647 }
    return acc
}

fn make_snapshot(step: int, n_cells: int, phi_iit: float, phi_gws: float,
                 phi_meta: float, lambda_resil: float, tau_avg: float,
                 topo: int, verdict: string) -> CellSnapshot {
    CellSnapshot {
        step:         step,
        n_cells:      n_cells,
        phi_iit:      phi_iit,
        phi_gws:      phi_gws,
        phi_meta:     phi_meta,
        lambda_resil: lambda_resil,
        tau_avg:      tau_avg,
        topology_sig: topo,
        verdict:      verdict
    }
}

fn snapshot_line(s: CellSnapshot) -> string {
    "step=" + str(s.step) +
    " n=" + str(s.n_cells) +
    " Φ=" + str(s.phi_iit) +
    " Φ_GWS=" + str(s.phi_gws) +
    " Φ_meta=" + str(s.phi_meta) +
    " Λ=" + str(s.lambda_resil) +
    " τ=" + str(s.tau_avg) +
    " topo=" + str(s.topology_sig) +
    " verdict=" + s.verdict
}

// ── self-test ──
let _snap = make_snapshot(3, 4, 0.23, 0.75, 0.88, 0.65, 0.42, 12345678, "L2_PARTIAL")
println("[cell_observer] " + snapshot_line(_snap))
println("[cell_observer] PASS")
