// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/temporal/verifier/temporal_falsification.hexa
//
//  PURPOSE
//    Adversarial verifier for edu/cell/temporal/temporal_emergence.hexa.
//    Applies two corruptions that SHOULD falsify specific observables and
//    checks that the verdict correctly drops:
//
//      T1  identity           : original trajectory  →  TEMPORAL_EMERGED
//      T2  time-reverse       : phi reversed         →  O2 must FAIL
//                               (I_irr_forward drops to 0 when drift flips sign)
//      T3  deterministic shuffle : phi re-permuted   →  O1 must FAIL (memory lost);
//                               O3 likely FAIL too (R/S collapses to H≈0.5 white)
//
//    Exit 0 iff:
//      T1.verdict == TEMPORAL_EMERGED  AND
//      T2.O2_pass  == false            AND
//      T3.O1_pass  == false
//
//  RAW contract: raw#9 · hexa-only · deterministic · LLM=none · snake_case (raw#11)
// ════════════════════════════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────────────────────────
//  INLINED (mirror temporal_emergence.hexa byte-for-byte where possible)
// ──────────────────────────────────────────────────────────────────────────

fn f_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn f_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x * 0.5
    let mut i = 0
    while i < 24 { y = (y + x / y) * 0.5;  i = i + 1 }
    return y
}

fn f_ln(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut m = x
    let mut k = 0
    while m >= 2.0 { m = m / 2.0;  k = k + 1 }
    while m < 1.0 { m = m * 2.0;  k = k - 1 }
    let y = (m - 1.0) / (m + 1.0)
    let y2 = y * y
    let mut term = y
    let mut sum = 0.0
    let mut i = 0
    while i < 24 {
        sum = sum + term / (2.0 * to_float(i) + 1.0)
        term = term * y2
        i = i + 1
    }
    let ln2 = 0.6931471805599453
    return 2.0 * sum + to_float(k) * ln2
}

fn hash_step(acc: int, x: int) -> int {
    let mut a = acc * 16777619 + x
    a = a % 2147483647
    if a < 0 { a = a + 2147483647 }
    return a
}

fn hash_mix(acc: int, x: int) -> int {
    let h1 = hash_step(acc, x)
    let h2 = hash_step(h1, x * 2654435761)
    let h3 = hash_step(h2, h1 + 40503)
    let h4 = hash_step(h3, h2 * 31)
    return h4
}

fn hash_uniform_signed(acc: int, x: int) -> float {
    let h = hash_mix(acc, x)
    let m = h % 2097152
    let f = (to_float(m) / 1048576.0) - 1.0
    return f
}

fn fmt_int_pad(n: int, width: int) -> string {
    let mut s = str(n)
    while len(s) < width { s = "0" + s }
    return s
}

fn fmt6(x: float) -> string {
    let mut xx = x
    let mut sign = ""
    if xx < 0.0 { sign = "-";  xx = 0.0 - xx }
    let whole = to_int(xx)
    let frac  = xx - to_float(whole)
    let micro = to_int(frac * 1000000.0 + 0.5)
    let mut m = micro
    let mut w = whole
    if m >= 1000000 { m = m - 1000000;  w = w + 1 }
    return sign + str(w) + "." + fmt_int_pad(m, 6)
}

fn anchor_phi(idx: int) -> float {
    if idx == 0 { return 0.040 }
    if idx == 1 { return 0.125 }
    if idx == 2 { return 0.687 }
    return 1.000
}

fn build_trajectory(n: int, seed: int) -> list {
    let mut phi = []
    let mut i = 0
    let mut acc_noise = 0.0
    while i < n {
        let mut a_lo = 0
        let mut a_hi = 1
        if i < 16          { a_lo = 0; a_hi = 1 }
        else if i < 32      { a_lo = 1; a_hi = 2 }
        else if i < 48      { a_lo = 2; a_hi = 3 }
        else                { a_lo = 3; a_hi = 3 }
        let tick_lo = a_lo * 16
        let tick_hi = if a_hi == a_lo { tick_lo + 16 } else { a_hi * 16 }
        let span = tick_hi - tick_lo
        let frac = if span > 0 { to_float(i - tick_lo) / to_float(span) } else { 0.0 }
        let lin = anchor_phi(a_lo) * (1.0 - frac) + anchor_phi(a_hi) * frac
        let drw1 = hash_uniform_signed(seed,       i * 131 + 7)
        let drw2 = hash_uniform_signed(seed + 17,  i * 241 + 3)
        acc_noise = acc_noise * 0.75 + drw1 * 0.04 + drw2 * 0.02
        if i == 0 || i == 16 || i == 32 || i == 48 { acc_noise = 0.0 }
        let raw = lin + acc_noise
        let v = if raw < 0.0 { 0.0 } else { if raw > 1.0 { 1.0 } else { raw } }
        phi = phi.push(v)
        i = i + 1
    }
    return phi
}

fn reverse_list(xs: list) -> list {
    let n = xs.len()
    let mut ys = []
    let mut i = n - 1
    while i >= 0 {
        ys = ys.push(xs[i])
        i = i - 1
    }
    return ys
}

// Deterministic shuffle (Fisher-Yates-by-rebuild) that destroys temporal
// order while preserving the marginal distribution of phi values.
fn shuffle_list(xs: list, seed: int) -> list {
    let n = xs.len()
    let mut ys = []
    let mut i = 0
    while i < n { ys = ys.push(xs[i]);  i = i + 1 }
    let mut k = n - 1
    while k > 0 {
        let h = hash_mix(seed, k * 1009 + 17)
        let j = h % (k + 1)
        let tmp_k = ys[k]
        let tmp_j = ys[j]
        let mut zs = []
        let mut m = 0
        while m < n {
            if m == k      { zs = zs.push(tmp_j) }
            else if m == j { zs = zs.push(tmp_k) }
            else           { zs = zs.push(ys[m]) }
            m = m + 1
        }
        ys = zs
        k = k - 1
    }
    return ys
}

fn tau_mem(phi: list, delta: int) -> float {
    let n = phi.len()
    if n <= delta + 1 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n { sum = sum + phi[i];  i = i + 1 }
    let mu = sum / to_float(n)
    let mut num = 0.0
    let mut den = 0.0
    let mut t = 0
    while t + delta < n {
        let dx = phi[t] - mu
        let dy = phi[t + delta] - mu
        num = num + dx * dy
        t = t + 1
    }
    let mut t2 = 0
    while t2 < n {
        let d = phi[t2] - mu
        den = den + d * d
        t2 = t2 + 1
    }
    if den <= 0.000000001 { return 0.0 }
    let norm = (to_float(n)) / (to_float(n - delta))
    let r = (num * norm) / den
    if r >  1.0 { return  1.0 }
    if r < -1.0 { return -1.0 }
    return r
}

fn mean_signed_delta(phi: list) -> float {
    let n = phi.len()
    if n < 2 { return 0.0 }
    let mut sum = 0.0
    let mut t = 0
    while t + 1 < n { sum = sum + (phi[t + 1] - phi[t]);  t = t + 1 }
    return sum / to_float(n - 1)
}

fn mean_abs_delta(phi: list) -> float {
    let n = phi.len()
    if n < 2 { return 0.0 }
    let mut sum = 0.0
    let mut t = 0
    while t + 1 < n { sum = sum + f_abs(phi[t + 1] - phi[t]);  t = t + 1 }
    return sum / to_float(n - 1)
}

fn irreversibility(phi: list) -> float {
    let signed = mean_signed_delta(phi)
    let jitter = mean_abs_delta(phi)
    if signed <= 0.0 { return 0.0 }
    let denom = signed + (jitter - signed)
    if denom <= 0.000000001 { return 0.0 }
    return signed / denom
}

fn diff_series(phi: list) -> list {
    let n = phi.len()
    let mut out = []
    let mut i = 0
    while i + 1 < n {
        out = out.push(phi[i + 1] - phi[i])
        i = i + 1
    }
    return out
}

fn rs_at_window(phi: list, w: int) -> float {
    let n = phi.len()
    if w < 4 || w > n { return 0.0 }
    let chunks = n / w
    if chunks < 1 { return 0.0 }
    let mut rs_sum = 0.0
    let mut valid = 0
    let mut c = 0
    while c < chunks {
        let start = c * w
        let mut mu = 0.0
        let mut i = 0
        while i < w { mu = mu + phi[start + i];  i = i + 1 }
        mu = mu / to_float(w)
        let mut cum = 0.0
        let mut mx = 0.0 - 1000000.0
        let mut mn =         1000000.0
        let mut sigma = 0.0
        let mut j = 0
        while j < w {
            let d = phi[start + j] - mu
            cum = cum + d
            if cum > mx { mx = cum }
            if cum < mn { mn = cum }
            sigma = sigma + d * d
            j = j + 1
        }
        sigma = f_sqrt(sigma / to_float(w))
        let r_minus_s = mx - mn
        if sigma > 0.000000001 {
            rs_sum = rs_sum + (r_minus_s / sigma)
            valid = valid + 1
        }
        c = c + 1
    }
    if valid == 0 { return 0.0 }
    return rs_sum / to_float(valid)
}

fn hurst_exponent(phi_full: list) -> float {
    let phi = diff_series(phi_full)
    let n = phi.len()
    let mut wsizes = []
    wsizes = wsizes.push(4)
    wsizes = wsizes.push(8)
    wsizes = wsizes.push(16)
    wsizes = wsizes.push(32)
    let mut xs = []
    let mut ys = []
    let mut i = 0
    while i < wsizes.len() {
        let w = wsizes[i]
        if w <= n {
            let rs = rs_at_window(phi, w)
            if rs > 0.000000001 {
                xs = xs.push(f_ln(to_float(w)))
                ys = ys.push(f_ln(rs))
            }
        }
        i = i + 1
    }
    let k = xs.len()
    if k < 2 { return 0.0 }
    let mut sx = 0.0
    let mut sy = 0.0
    let mut p = 0
    while p < k { sx = sx + xs[p];  sy = sy + ys[p];  p = p + 1 }
    let mx = sx / to_float(k)
    let my = sy / to_float(k)
    let mut num = 0.0
    let mut den = 0.0
    let mut q = 0
    while q < k {
        let dx = xs[q] - mx
        let dy = ys[q] - my
        num = num + dx * dy
        den = den + dx * dx
        q = q + 1
    }
    if den <= 0.000000001 { return 0.0 }
    return num / den
}

fn pass_o1(tau: float) -> int { if tau > 0.65 { return 1 } return 0 }
fn pass_o2(i_fwd: float, i_rev: float) -> int {
    if i_fwd > 0.35 && i_rev < 0.15 { return 1 }
    return 0
}
fn pass_o3(h: float) -> int { if h > 0.5 && h < 0.75 { return 1 } return 0 }

fn verdict_str(p1: int, p2: int, p3: int) -> string {
    let sum = p1 + p2 + p3
    if sum == 3 { return "TEMPORAL_EMERGED" }
    if sum == 2 { return "TEMPORAL_PARTIAL" }
    return "TEMPORAL_FAILED"
}

// ──────────────────────────────────────────────────────────────────────────
//  Run one adversarial case
// ──────────────────────────────────────────────────────────────────────────

fn run_case(name: string, phi: list, expect_verdict: string, check: string) -> int {
    let tau = tau_mem(phi, 4)
    let i_fwd = irreversibility(phi)
    let phi_rev = reverse_list(phi)
    let i_rev = irreversibility(phi_rev)
    let h = hurst_exponent(phi)

    let p1 = pass_o1(tau)
    let p2 = pass_o2(i_fwd, i_rev)
    let p3 = pass_o3(h)
    let v = verdict_str(p1, p2, p3)

    println("{\"evt\":\"case\",\"name\":\"" + name + "\""
        + ",\"O1\":" + fmt6(tau)
        + ",\"O2_fwd\":" + fmt6(i_fwd)
        + ",\"O2_rev\":" + fmt6(i_rev)
        + ",\"O3\":" + fmt6(h)
        + ",\"O1_pass\":" + (if p1 == 1 { "true" } else { "false" })
        + ",\"O2_pass\":" + (if p2 == 1 { "true" } else { "false" })
        + ",\"O3_pass\":" + (if p3 == 1 { "true" } else { "false" })
        + ",\"verdict\":\"" + v + "\""
        + ",\"expect\":\"" + expect_verdict + "\""
        + ",\"check\":\"" + check + "\"}")

    // case-specific assertion logic:
    //   "identity"       → v must equal TEMPORAL_EMERGED  (returns 1 on pass)
    //   "reverse_fails_O2" → p2 must be 0
    //   "shuffle_fails_O1" → p1 must be 0
    if check == "identity" {
        if v == expect_verdict { return 1 }
        return 0
    }
    if check == "reverse_fails_O2" {
        if p2 == 0 { return 1 }
        return 0
    }
    if check == "shuffle_fails_O1" {
        if p1 == 0 { return 1 }
        return 0
    }
    return 0
}

fn main() -> int {
    let seed = 20260421
    let n    = 64

    println("{\"evt\":\"config\",\"verifier\":\"temporal_falsification\""
        + ",\"seed\":" + str(seed)
        + ",\"length\":" + str(n) + "}")

    let phi = build_trajectory(n, seed)

    // T1 identity
    let t1 = run_case("T1_identity", phi, "TEMPORAL_EMERGED", "identity")

    // T2 time-reverse — should FAIL O2
    let phi_rev = reverse_list(phi)
    let t2 = run_case("T2_time_reverse", phi_rev, "non-EMERGED", "reverse_fails_O2")

    // T3 shuffle — should FAIL O1
    let phi_shuf = shuffle_list(phi, seed + 13)
    let t3 = run_case("T3_shuffle", phi_shuf, "non-EMERGED", "shuffle_fails_O1")

    let pass_all = t1 + t2 + t3
    let all_good = if pass_all == 3 { "true" } else { "false" }

    println("{\"evt\":\"summary\""
        + ",\"T1_identity\":" + (if t1 == 1 { "\"PASS\"" } else { "\"FAIL\"" })
        + ",\"T2_reverse\":"  + (if t2 == 1 { "\"PASS\"" } else { "\"FAIL\"" })
        + ",\"T3_shuffle\":"  + (if t3 == 1 { "\"PASS\"" } else { "\"FAIL\"" })
        + ",\"all_pass\":" + all_good + "}")

    if pass_all == 3 { return 0 }
    return 1
}

exit(main())
