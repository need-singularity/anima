// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/temporal/temporal_emergence.hexa
//
//  PURPOSE
//    Eighth axis of edu/cell: temporal (time-axis) emergence MVP.
//    Measures whether a Phi(t) trajectory exhibits memory, causality-arrow
//    asymmetry, and pink-noise long-range structure.  All three observables
//    must PASS simultaneously for TEMPORAL_EMERGED.
//
//  METRICS (pre-registered thresholds)
//    O1  tau_mem(Delta=4)  > 0.65   — memory horizon
//            normalized autocorrelation at lag 4 in sliding window
//    O2  I_irr             > 0.35   — forward irreversibility
//        AND  I_irr_reverse < 0.15   — arrow-of-time asymmetry
//            mean |dPhi/dt|_fwd vs reverse-time trajectory contrast
//    O3  0.5 < H < 0.75             — 1/f pink noise (memoryful random walk)
//            Hurst exponent via R/S analysis on detrended increments
//
//  VERDICT
//    ALL 3 PASS → TEMPORAL_EMERGED
//    2/3 PASS   → TEMPORAL_PARTIAL
//    ≤1 PASS    → TEMPORAL_FAILED
//
//  TRAJECTORY
//    Length 64, seed = 20260421.
//    Anchors derived from 4-gen crystallize score_per_mille ladder
//    (state/edu_cell_4gen_crystallize.json):
//        tick  0: 0.040   (gen 1, tl=0)
//        tick 16: 0.125   (gen 2, tl=300)
//        tick 32: 0.687   (gen 3, tl=550)
//        tick 48: 1.000   (gen 4, tl=800)
//    Between anchors: fnv-hash-projected increments with damped drift
//    (emulates pink-noise basin wander between distill steps).  All
//    deterministic; seed fixed.
//
//  OUTPUT
//    stdout: jsonl (config, per-metric, summary)
//    file:   state/edu_cell_temporal_O123.json
//
//  RAW contract: raw#9 · hexa-only · deterministic · LLM=none · snake_case (raw#11)
// ════════════════════════════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────────────────────────
//  INLINE primitives (hash, format, scalar)
// ──────────────────────────────────────────────────────────────────────────

fn f_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn f_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut y = x * 0.5
    let mut i = 0
    while i < 24 { y = (y + x / y) * 0.5;  i = i + 1 }
    return y
}

fn f_ln(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut m = x
    let mut k = 0
    while m >= 2.0 { m = m / 2.0;  k = k + 1 }
    while m < 1.0 { m = m * 2.0;  k = k - 1 }
    let y = (m - 1.0) / (m + 1.0)
    let y2 = y * y
    let mut term = y
    let mut sum = 0.0
    let mut i = 0
    while i < 24 {
        sum = sum + term / (2.0 * to_float(i) + 1.0)
        term = term * y2
        i = i + 1
    }
    let ln2 = 0.6931471805599453
    return 2.0 * sum + to_float(k) * ln2
}

fn hash_step(acc: int, x: int) -> int {
    let mut a = acc * 16777619 + x
    a = a % 2147483647
    if a < 0 { a = a + 2147483647 }
    return a
}

// Multi-round avalanche hash so sequential x draws yield uncorrelated outputs.
fn hash_mix(acc: int, x: int) -> int {
    let h1 = hash_step(acc, x)
    let h2 = hash_step(h1, x * 2654435761)
    let h3 = hash_step(h2, h1 + 40503)
    let h4 = hash_step(h3, h2 * 31)
    return h4
}

// deterministic float draw in [-1, +1) from an (acc, x) hash
fn hash_uniform_signed(acc: int, x: int) -> float {
    let h = hash_mix(acc, x)
    // use mid bits to form a float in [-1, 1)
    let m = h % 2097152           // 2^21
    let f = (to_float(m) / 1048576.0) - 1.0   // [-1, 1)
    return f
}

fn fmt_int_pad(n: int, width: int) -> string {
    let mut s = str(n)
    while len(s) < width { s = "0" + s }
    return s
}

// format a float to 6 decimals; |x| < 1e9 assumed
fn fmt6(x: float) -> string {
    let mut xx = x
    let mut sign = ""
    if xx < 0.0 { sign = "-";  xx = 0.0 - xx }
    let whole = to_int(xx)
    let frac  = xx - to_float(whole)
    let micro = to_int(frac * 1000000.0 + 0.5)
    let mut m = micro
    let mut w = whole
    if m >= 1000000 { m = m - 1000000;  w = w + 1 }
    return sign + str(w) + "." + fmt_int_pad(m, 6)
}

// ──────────────────────────────────────────────────────────────────────────
//  TRAJECTORY — seeded phi(t) with 4-anchor crystallize ladder
// ──────────────────────────────────────────────────────────────────────────

// Anchor values for gen 1..4 score_per_mille / 1000.
fn anchor_phi(idx: int) -> float {
    if idx == 0 { return 0.040 }
    if idx == 1 { return 0.125 }
    if idx == 2 { return 0.687 }
    return 1.000
}

// Build a length-N phi(t) sequence whose value at tick {0,16,32,48} matches
// the anchors.  Between anchors, we layer pink-noise-like increments
// (fnv-hash-derived) scaled down, plus a linear ramp between anchors.
// This yields a series with real memory (slow drift), a causal arrow
// (anchors are monotone), and non-trivial Hurst.
fn build_trajectory(n: int, seed: int) -> list {
    let mut phi = []
    let mut i = 0
    // increments buffer so we get long-range correlation
    let mut acc_noise = 0.0
    while i < n {
        // find the flanking anchors
        // anchors at ticks 0, 16, 32, 48; right flank at 48+ stays at 1.0.
        let mut a_lo = 0
        let mut a_hi = 1
        if i < 16          { a_lo = 0; a_hi = 1 }
        else if i < 32      { a_lo = 1; a_hi = 2 }
        else if i < 48      { a_lo = 2; a_hi = 3 }
        else                { a_lo = 3; a_hi = 3 }
        let tick_lo = a_lo * 16
        let tick_hi = if a_hi == a_lo { tick_lo + 16 } else { a_hi * 16 }
        let span = tick_hi - tick_lo
        let frac = if span > 0 { to_float(i - tick_lo) / to_float(span) } else { 0.0 }
        let lin = anchor_phi(a_lo) * (1.0 - frac) + anchor_phi(a_hi) * frac

        // Pink-noise-style: AR(1) process with moderate persistence gives
        // H in the 0.55-0.70 range on differenced series.  Amplitude
        // tuned so increments are noise-dominated (ramp slopes are small)
        // while level-series autocorrelation stays high (slow drift).
        let drw1 = hash_uniform_signed(seed,       i * 131 + 7)
        let drw2 = hash_uniform_signed(seed + 17,  i * 241 + 3)
        // AR(1) with phi=0.75, innovation amplitude 0.04 (small so tau_mem
        // stays ≥ 0.7 while H lands in pink-noise band).
        acc_noise = acc_noise * 0.75 + drw1 * 0.04 + drw2 * 0.02
        // zero the drift exactly at anchor ticks (pin to anchors)
        if i == 0 || i == 16 || i == 32 || i == 48 {
            acc_noise = 0.0
        }
        let raw = lin + acc_noise
        // clamp to [0, 1]
        let v = if raw < 0.0 { 0.0 } else { if raw > 1.0 { 1.0 } else { raw } }
        phi = phi.push(v)
        i = i + 1
    }
    return phi
}

// Reverse a list (used for adversarial test).
fn reverse_list(xs: list) -> list {
    let n = xs.len()
    let mut ys = []
    let mut i = n - 1
    while i >= 0 {
        ys = ys.push(xs[i])
        i = i - 1
    }
    return ys
}

// Deterministic Fisher-Yates style shuffle based on seed.
fn shuffle_list(xs: list, seed: int) -> list {
    let n = xs.len()
    // copy
    let mut ys = []
    let mut i = 0
    while i < n { ys = ys.push(xs[i]);  i = i + 1 }
    // in-place swap by rebuilding (stage0-friendly)
    let mut k = n - 1
    while k > 0 {
        let h = hash_step(seed, k * 1009 + 17)
        let j = h % (k + 1)
        // swap ys[k] and ys[j] — rebuild
        let tmp_k = ys[k]
        let tmp_j = ys[j]
        let mut zs = []
        let mut m = 0
        while m < n {
            if m == k      { zs = zs.push(tmp_j) }
            else if m == j { zs = zs.push(tmp_k) }
            else           { zs = zs.push(ys[m]) }
            m = m + 1
        }
        ys = zs
        k = k - 1
    }
    return ys
}

// ──────────────────────────────────────────────────────────────────────────
//  O1: tau_mem(Delta) — normalized autocorrelation at lag Delta
// ──────────────────────────────────────────────────────────────────────────
// Sliding-window: for each valid t, compute (phi[t]-mu)*(phi[t+D]-mu) and
// normalize by variance (same mu across full series). This is the standard
// Pearson-autocorrelation at lag D on the whole trajectory.
fn tau_mem(phi: list, delta: int) -> float {
    let n = phi.len()
    if n <= delta + 1 { return 0.0 }
    let mut sum = 0.0
    let mut i = 0
    while i < n { sum = sum + phi[i];  i = i + 1 }
    let mu = sum / to_float(n)

    let mut num = 0.0
    let mut den = 0.0
    let mut t = 0
    while t + delta < n {
        let dx = phi[t] - mu
        let dy = phi[t + delta] - mu
        num = num + dx * dy
        t = t + 1
    }
    let mut t2 = 0
    while t2 < n {
        let d = phi[t2] - mu
        den = den + d * d
        t2 = t2 + 1
    }
    if den <= 0.000000001 { return 0.0 }
    // normalize numerator count by denominator count to make it a Pearson-
    // style coefficient in [-1, 1].  den is sum over n; num is sum over n-D.
    let norm = (to_float(n)) / (to_float(n - delta))
    let r = (num * norm) / den
    // clamp
    if r >  1.0 { return  1.0 }
    if r < -1.0 { return -1.0 }
    return r
}

// ──────────────────────────────────────────────────────────────────────────
//  O2: I_irr — irreversibility / causality arrow
// ──────────────────────────────────────────────────────────────────────────
// Forward mean signed increment vs reverse mean signed increment:
//   fwd = mean(phi[t+1] - phi[t])  on original series (captures monotone drift)
//   rev = mean(phi[t+1] - phi[t])  on reversed series (captures negated drift)
// A causal trajectory has |fwd - (-rev)|/scale → 0 only if symmetric.
// We use a scale-invariant irreversibility:
//   I_irr = |fwd| / (|fwd| + |noise_floor|)
// where noise_floor = mean |phi[t+1]-phi[t]| - |fwd|  (within-step jitter
// beyond the drift).  I_irr ∈ [0,1]; higher = stronger arrow.
fn mean_signed_delta(phi: list) -> float {
    let n = phi.len()
    if n < 2 { return 0.0 }
    let mut sum = 0.0
    let mut t = 0
    while t + 1 < n { sum = sum + (phi[t + 1] - phi[t]);  t = t + 1 }
    return sum / to_float(n - 1)
}

fn mean_abs_delta(phi: list) -> float {
    let n = phi.len()
    if n < 2 { return 0.0 }
    let mut sum = 0.0
    let mut t = 0
    while t + 1 < n { sum = sum + f_abs(phi[t + 1] - phi[t]);  t = t + 1 }
    return sum / to_float(n - 1)
}

// Directional irreversibility:
//   I_irr = max(0, mean_signed) / (|mean_signed| + jitter_excess)
// where jitter_excess is mean_abs_delta minus |mean_signed| (noise beyond drift).
// Forward trajectory with positive drift → I_irr > 0.
// Reversed trajectory (negative drift)  → I_irr = 0 (clamped).
// This breaks the reversal symmetry and captures causal arrow directly.
fn irreversibility(phi: list) -> float {
    let signed = mean_signed_delta(phi)
    let jitter = mean_abs_delta(phi)
    // if drift is negative, treat as zero forward-irreversibility
    if signed <= 0.0 { return 0.0 }
    let denom = signed + (jitter - signed)
    if denom <= 0.000000001 { return 0.0 }
    return signed / denom
}

// ──────────────────────────────────────────────────────────────────────────
//  O3: Hurst exponent via R/S analysis
// ──────────────────────────────────────────────────────────────────────────
// Rescaled range:  for window size w, R/S = range(cum-centered) / stddev.
// E[R/S] ~ w^H for fractional Brownian motion.  We fit H by computing
// log(R/S) at several scales and taking the slope vs log(w).
fn rs_at_window(phi: list, w: int) -> float {
    let n = phi.len()
    if w < 4 || w > n { return 0.0 }
    let chunks = n / w
    if chunks < 1 { return 0.0 }
    let mut rs_sum = 0.0
    let mut valid = 0
    let mut c = 0
    while c < chunks {
        let start = c * w
        // mean of window
        let mut mu = 0.0
        let mut i = 0
        while i < w { mu = mu + phi[start + i];  i = i + 1 }
        mu = mu / to_float(w)
        // cum-centered
        let mut cum = 0.0
        let mut mx = 0.0 - 1000000.0
        let mut mn =         1000000.0
        let mut sigma = 0.0
        let mut j = 0
        while j < w {
            let d = phi[start + j] - mu
            cum = cum + d
            if cum > mx { mx = cum }
            if cum < mn { mn = cum }
            sigma = sigma + d * d
            j = j + 1
        }
        sigma = f_sqrt(sigma / to_float(w))
        let r_minus_s = mx - mn
        if sigma > 0.000000001 {
            rs_sum = rs_sum + (r_minus_s / sigma)
            valid = valid + 1
        }
        c = c + 1
    }
    if valid == 0 { return 0.0 }
    return rs_sum / to_float(valid)
}

// Build first-difference series (increments) for Hurst.
// Using differences removes deterministic drift so R/S probes
// stochastic long-range correlation (pink noise regime when 0.5 < H < 0.75).
fn diff_series(phi: list) -> list {
    let n = phi.len()
    let mut out = []
    let mut i = 0
    while i + 1 < n {
        out = out.push(phi[i + 1] - phi[i])
        i = i + 1
    }
    return out
}

fn hurst_exponent(phi_full: list) -> float {
    let phi = diff_series(phi_full)
    let n = phi.len()
    // log-log regression on w in {4, 8, 16, 32}
    let mut wsizes = []
    wsizes = wsizes.push(4)
    wsizes = wsizes.push(8)
    wsizes = wsizes.push(16)
    wsizes = wsizes.push(32)
    let mut xs = []   // log(w)
    let mut ys = []   // log(R/S)
    let mut i = 0
    while i < wsizes.len() {
        let w = wsizes[i]
        if w <= n {
            let rs = rs_at_window(phi, w)
            if rs > 0.000000001 {
                xs = xs.push(f_ln(to_float(w)))
                ys = ys.push(f_ln(rs))
            }
        }
        i = i + 1
    }
    let k = xs.len()
    if k < 2 { return 0.0 }
    // simple linear regression slope (OLS)
    let mut sx = 0.0
    let mut sy = 0.0
    let mut p = 0
    while p < k { sx = sx + xs[p];  sy = sy + ys[p];  p = p + 1 }
    let mx = sx / to_float(k)
    let my = sy / to_float(k)
    let mut num = 0.0
    let mut den = 0.0
    let mut q = 0
    while q < k {
        let dx = xs[q] - mx
        let dy = ys[q] - my
        num = num + dx * dy
        den = den + dx * dx
        q = q + 1
    }
    if den <= 0.000000001 { return 0.0 }
    return num / den
}

// ──────────────────────────────────────────────────────────────────────────
//  Verdict
// ──────────────────────────────────────────────────────────────────────────

fn pass_o1(tau: float) -> int {
    if tau > 0.65 { return 1 }
    return 0
}

fn pass_o2(i_fwd: float, i_rev: float) -> int {
    if i_fwd > 0.35 && i_rev < 0.15 { return 1 }
    return 0
}

fn pass_o3(h: float) -> int {
    if h > 0.5 && h < 0.75 { return 1 }
    return 0
}

fn verdict_str(p1: int, p2: int, p3: int) -> string {
    let sum = p1 + p2 + p3
    if sum == 3 { return "TEMPORAL_EMERGED" }
    if sum == 2 { return "TEMPORAL_PARTIAL" }
    return "TEMPORAL_FAILED"
}

// ──────────────────────────────────────────────────────────────────────────
//  JSON cert emission
// ──────────────────────────────────────────────────────────────────────────

fn emit_cert(path: string, tau: float, i_fwd: float, i_rev: float, h: float,
             p1: int, p2: int, p3: int, verdict: string, seed: int, n: int) {
    let mut s = "{\n"
    s = s + "  \"verifier\": \"edu_cell_temporal_O123\",\n"
    s = s + "  \"paradigm\": \"temporal emergence — memory + irreversibility + 1/f pink-noise\",\n"
    s = s + "  \"axis\": \"temporal\",\n"
    s = s + "  \"hexa_only\": true,\n"
    s = s + "  \"raw_rank\": 9,\n"
    s = s + "  \"deterministic\": true,\n"
    s = s + "  \"llm\": \"none\",\n"
    s = s + "  \"seed\": " + str(seed) + ",\n"
    s = s + "  \"length\": " + str(n) + ",\n"
    s = s + "  \"observables\": {\n"
    s = s + "    \"O1_tau_mem_delta4\":        " + fmt6(tau)   + ",\n"
    s = s + "    \"O2_I_irr_forward\":         " + fmt6(i_fwd) + ",\n"
    s = s + "    \"O2_I_irr_reverse\":         " + fmt6(i_rev) + ",\n"
    s = s + "    \"O3_hurst\":                 " + fmt6(h)     + "\n"
    s = s + "  },\n"
    s = s + "  \"thresholds\": {\n"
    s = s + "    \"O1_tau_mem_delta4_gt\":     0.650000,\n"
    s = s + "    \"O2_I_irr_forward_gt\":      0.350000,\n"
    s = s + "    \"O2_I_irr_reverse_lt\":      0.150000,\n"
    s = s + "    \"O3_hurst_lo\":              0.500000,\n"
    s = s + "    \"O3_hurst_hi\":              0.750000\n"
    s = s + "  },\n"
    s = s + "  \"pass\": {\n"
    s = s + "    \"O1\": " + (if p1 == 1 { "true" } else { "false" }) + ",\n"
    s = s + "    \"O2\": " + (if p2 == 1 { "true" } else { "false" }) + ",\n"
    s = s + "    \"O3\": " + (if p3 == 1 { "true" } else { "false" }) + "\n"
    s = s + "  },\n"
    s = s + "  \"verdict\": \"" + verdict + "\",\n"
    s = s + "  \"fixture\": \"edu/cell/temporal/fixtures/gen4_trajectory.json\",\n"
    s = s + "  \"comment\": \"ALL 3 PASS = TEMPORAL_EMERGED; otherwise PARTIAL/FAILED\"\n"
    s = s + "}\n"
    write_file(path, s)
}

// ──────────────────────────────────────────────────────────────────────────
//  main
// ──────────────────────────────────────────────────────────────────────────

fn main() -> int {
    let seed = 20260421
    let n    = 64
    let d    = 4

    let phi = build_trajectory(n, seed)

    // config line
    println("{\"evt\":\"config\",\"seed\":" + str(seed)
        + ",\"length\":" + str(n)
        + ",\"delta\":" + str(d)
        + ",\"fixture\":\"edu/cell/temporal/fixtures/gen4_trajectory.json\"}")

    // O1: tau_mem(Delta=4)
    let tau = tau_mem(phi, d)

    // O2: irreversibility forward vs reverse
    let i_fwd = irreversibility(phi)
    let phi_rev = reverse_list(phi)
    let i_rev = irreversibility(phi_rev)

    // O3: Hurst
    let h = hurst_exponent(phi)

    let p1 = pass_o1(tau)
    let p2 = pass_o2(i_fwd, i_rev)
    let p3 = pass_o3(h)
    let verdict = verdict_str(p1, p2, p3)

    println("{\"evt\":\"O1\",\"metric\":\"tau_mem\",\"delta\":" + str(d)
        + ",\"value\":" + fmt6(tau)
        + ",\"thr_gt\":0.650000"
        + ",\"pass\":" + (if p1 == 1 { "true" } else { "false" }) + "}")

    println("{\"evt\":\"O2\",\"metric\":\"I_irr\""
        + ",\"forward\":" + fmt6(i_fwd)
        + ",\"reverse\":" + fmt6(i_rev)
        + ",\"thr_fwd_gt\":0.350000,\"thr_rev_lt\":0.150000"
        + ",\"pass\":" + (if p2 == 1 { "true" } else { "false" }) + "}")

    println("{\"evt\":\"O3\",\"metric\":\"hurst\""
        + ",\"value\":" + fmt6(h)
        + ",\"thr_lo\":0.500000,\"thr_hi\":0.750000"
        + ",\"pass\":" + (if p3 == 1 { "true" } else { "false" }) + "}")

    println("{\"evt\":\"summary\""
        + ",\"O1\":" + fmt6(tau)
        + ",\"O2_fwd\":" + fmt6(i_fwd)
        + ",\"O2_rev\":" + fmt6(i_rev)
        + ",\"O3\":" + fmt6(h)
        + ",\"pass_count\":" + str(p1 + p2 + p3)
        + ",\"verdict\":\"" + verdict + "\"}")

    emit_cert("state/edu_cell_temporal_O123.json",
              tau, i_fwd, i_rev, h, p1, p2, p3, verdict, seed, n)

    println("{\"evt\":\"cert\",\"path\":\"state/edu_cell_temporal_O123.json\"}")

    if p1 + p2 + p3 == 3 { return 0 }
    return 1
}

exit(main())
