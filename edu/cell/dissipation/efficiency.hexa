// ════════════════════════════════════════════════════════════════════════════
//  edu/cell/dissipation/efficiency.hexa
//
//  PURPOSE
//    Landauer-channel efficiency ratio for a single generation.
//
//        efficiency = useful_progress × log2(Ω_micro)  /  L_dissipated
//
//    • useful_progress       = score_per_mille / 1000  (sealed fraction)
//    • log2(Ω_micro)         = log2(2 · size²)         (tension × gap polarity)
//    • L_dissipated          = (sealed + drop) × ln(2) — cf. landauer_tracker
//
//    Ratio is clamped to [0, 1] (per-mille).  Values near 1.0 indicate the
//    generation extracted score proportional to the full-state reset floor
//    (maximally Landauer-efficient).  Values near 0 indicate wasteful
//    dissipation with little useful lattice crystallization.
//
//  Integer fixed-point: inputs in per-mille (×1000) where noted; outputs ×1000.
//
//  HEXA-ONLY · raw#9 · deterministic · no LLM
// ════════════════════════════════════════════════════════════════════════════

// Integer log2 ×1000 approximation via closed-form for small integers.
// Hardcoded table covers Ω_micro = 2·size² for size ∈ [2..8] which covers
// the 4-gen crystallize sweep (size ∈ {3, 4, 5}).
//   size=2 → Ω=8   → log2=3000
//   size=3 → Ω=18  → log2=4170  (log2 18 = 4.1699250014)
//   size=4 → Ω=32  → log2=5000
//   size=5 → Ω=50  → log2=5644  (log2 50 = 5.6438561898)
//   size=6 → Ω=72  → log2=6170
//   size=7 → Ω=98  → log2=6615
//   size=8 → Ω=128 → log2=7000
fn log2_omega_x1000(size: int) -> int {
    if size == 2 { return 3000 }
    if size == 3 { return 4170 }
    if size == 4 { return 5000 }
    if size == 5 { return 5644 }
    if size == 6 { return 6170 }
    if size == 7 { return 6615 }
    if size == 8 { return 7000 }
    // Fallback: crude integer log2 (no frac) of 2·size²
    let omega = 2 * size * size
    let mut v = 1
    let mut lg = 0
    while v < omega {
        v = v * 2
        lg = lg + 1
    }
    return lg * 1000
}

// min_physical_energy per gen = log2(Ω_micro) · ln(2) · kT, ×1000.
// (Full-state reset Landauer floor.)
fn min_physical_x1000(size: int) -> int {
    let log2o = log2_omega_x1000(size)
    // log2o is ×1000; ln2 is ×1000; product ×1000000 — divide by 1000 to keep ×1000.
    return (log2o * 693) / 1000
}

// useful_progress_x1000 = score_per_mille (identity — score already /1000).
fn useful_progress_x1000(score_per_mille: int) -> int {
    return score_per_mille
}

// efficiency_x1000 = (useful · log2Ω) / L_dissipated, clamped [0, 1000].
// All inputs/outputs per-mille.
fn efficiency_x1000(score_per_mille: int, size: int, sealed: int, drop_ct: int) -> int {
    let bits = sealed + drop_ct
    if bits <= 0 { return 0 }
    let log2o = log2_omega_x1000(size)
    // numerator: score (×1000) · log2o (×1000) = ×1000000
    // denominator: bits · ln2 (×1000) = ×1000
    // ratio = num / (den · 1000) to bring back to ×1000
    let num = score_per_mille * log2o
    let den = bits * 693
    if den <= 0 { return 0 }
    let ratio = num / den
    if ratio < 0 { return 0 }
    if ratio > 1000 { return 1000 }
    return ratio
}
