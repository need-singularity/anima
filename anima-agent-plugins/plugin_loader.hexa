// plugins/plugin_loader.hexa -- Plugin discovery and lifecycle management
// Port of plugins/plugin_loader.py

struct PluginLoader {
    plugins: map,
    plugin_dir: string,
}

fn new_plugin_loader() -> PluginLoader {
    PluginLoader {
        plugins: {},
        plugin_dir: "plugins",
    }
}

fn discover_plugins() -> map {
    // TODO[python-sdk]: scan plugins/ directory for PluginBase subclasses
    let mut found = {}
    let known = ["trading", "regime_bridge", "hypothesis_bridge", "sentiment_bridge"]
    for name in known {
        // TODO[python-sdk]: importlib.import_module("plugins." + name)
        // Find class with manifest attribute
    }
    found
}

fn loader_load_all(loader: &mut PluginLoader, hub: any) -> array {
    let plugins = discover_plugins()
    let mut loaded = []
    for name, plugin in plugins {
        loader.plugins[name] = plugin
        // TODO[python-sdk]: plugin.load(hub)
        append(loaded, name)
    }
    loaded
}

fn loader_load_one(loader: &mut PluginLoader, name: string, hub: any) -> bool {
    // TODO[python-sdk]: import and load single plugin
    false
}

fn loader_unload(loader: &mut PluginLoader, name: string, hub: any) -> bool {
    if has_key(loader.plugins, name) {
        // TODO[python-sdk]: plugin.unload(hub)
        remove_key(loader.plugins, name)
        return true
    }
    false
}

fn loader_list(loader: &PluginLoader) -> array {
    let mut result = []
    for name, plugin in loader.plugins {
        append(result, {"name": name, "loaded": true})
    }
    result
}

fn loader_get(loader: &PluginLoader, name: string) -> any {
    loader.plugins[name]
}

fn main() {
    println("plugins/plugin_loader.hexa loaded")
    let loader = new_plugin_loader()
    println("Known plugins: trading, regime_bridge, hypothesis_bridge, sentiment_bridge")
}
