// plugins/base.hexa -- Plugin base classes with manifest + lifecycle
// Port of plugins/base.py (71 lines)

struct PluginManifest {
    name: string,
    version: string,
    description: string,
    author: string,
    keywords: array,
    dependencies: array,
    hub_keywords: array,
}

fn new_manifest(name: string, description: string, keywords: array) -> PluginManifest {
    PluginManifest {
        name: name,
        version: "1.0.0",
        description: description,
        author: "",
        keywords: keywords,
        dependencies: [],
        hub_keywords: keywords,
    }
}

// PluginBase protocol:
//   manifest: PluginManifest
//   fn load(hub: any) -- register with ConsciousnessHub
//   fn unload(hub: any) -- deregister
//   fn act(intent: string, ...) -> map -- handle routed intent
//   fn status() -> map -- plugin status

struct PluginBase {
    manifest: PluginManifest,
    loaded: bool,
}

fn plugin_load(plugin: &mut PluginBase, hub: any) {
    plugin.loaded = true
    println("Plugin loaded: " + plugin.manifest.name)
}

fn plugin_unload(plugin: &mut PluginBase, hub: any) {
    plugin.loaded = false
    println("Plugin unloaded: " + plugin.manifest.name)
}

fn plugin_act(plugin: &PluginBase, intent: string) -> map {
    {"success": false, "error": "not implemented"}
}

fn plugin_status(plugin: &PluginBase) -> map {
    {"name": plugin.manifest.name, "loaded": plugin.loaded}
}

fn main() {
    println("plugins/base.hexa -- PluginBase + PluginManifest")
}
