// serving/style_switch.hexa — TCLM-P2-2 style_preset 런타임 스위칭
//
// Roadmap: shared/roadmaps/anima-train.json P2 / CLM / TCLM-P2-2.
//   "style_preset 런타임 스위칭 — serving/http_server.hexa 에 tone 파라미터 추가"
//   done_criteria: "톤 전환 < 50ms, 4 톤 블라인드 구분율 ≥ 0.8"
//
// ─── 아키텍처 (additive overlay) ───────────────────────────────
//
//   /generate                                  /generate (extended)
//   {                                          {
//     prompt: "...",                             prompt: "...",
//     max_tokens: 256,                           max_tokens: 256,
//     temperature: 0.8                           temperature: 0.8,
//     ...                                        tone: "romance"          ← NEW
//   }                                            tone_id: 0               ← OR (mutex)
//                                              }
//
//   http_server.hexa 의 handle_generate 진입에서:
//     let tone = parse_tone_field(body, default="daily")          ← 본 모듈
//     let probe = build_style_probe(tone, D_MODEL, seed)          ← 본 모듈
//     // probe 를 ServingRequest.style_probe 로 clm_lore_serve 에 forward
//
// 이 파일 자체는 http_server 를 직접 patch 하지 않는다 — 서빙 트랙은
// SERVING(track) 소관. 본 모듈은 (1) tone 파싱, (2) probe 생성, (3)
// switch 일관성 검증을 제공해 http_server (TSRV-P2-2 deploy 단계) 가
// import-and-call 하면 끝나도록 한다.
//
// ─── Hexa quirk 회피 ────────────────────────────────────────────
//
// - use "..." 금지 (memory: feedback_hexa_runtime). lore_serve 와 동일하게
//   StylePreset 타입 + 4 함수를 inline mirror.
// - a[i] = v no-op 회피 → push 재구축.
// - struct 안 list aliasing 회피 → 모든 mutator 가 새 struct return.
// - `let match = ...` 금지 → use m / found / hit 등 non-reserved 이름.
// - str.split / contains 최소화 — JSON tone 파싱은 fixed-marker scan.
//
// ─── Test plan (T1–T5) ──────────────────────────────────────────
//
// T1 parse_tone_field    — 4 톤 label 모두 정확히 추출 (tone_id reverse lookup)
// T2 fallback default    — 알려지지 않은 tone → "daily" (id=3) 로 graceful
// T3 latency < 50ms      — apply_tone_switch (parse + probe) 1 회 latency
// T4 blind classification — noisy probe 4×5 sample → ≥ 0.8 (done_criteria 직접)
// T5 deterministic switch — 동일 (tone, seed) → byte-identical probe vector
//
// 5/5 PASS 목표.

// ═══════════════════════════════════════════════════════════════
//  Section 1. Primitives (inline — style_preset.hexa mirror)
// ═══════════════════════════════════════════════════════════════

fn ss_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ss_det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        let v = u * 2.0 - 1.0
        out = out.push(v)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Section 2. StylePreset (mirror of anima/modules/style_preset.hexa)
// ═══════════════════════════════════════════════════════════════

struct StylePreset {
    id:        int,
    label:     string,
    valence:   float,
    reality:   float,
    intensity: float
}

fn ss_presets_default() -> [StylePreset] {
    let romance = StylePreset {
        id: 0, label: "romance",
        valence:  0.9, reality: -0.7, intensity:  0.0
    }
    let horror = StylePreset {
        id: 1, label: "horror",
        valence: -0.9, reality:  0.7, intensity:  0.0
    }
    let fantasy = StylePreset {
        id: 2, label: "fantasy",
        valence:  0.0, reality:  0.9, intensity:  0.7
    }
    let daily = StylePreset {
        id: 3, label: "daily",
        valence:  0.0, reality: -0.9, intensity: -0.7
    }
    let mut out = []
    out = out.push(romance)
    out = out.push(horror)
    out = out.push(fantasy)
    out = out.push(daily)
    return out
}

fn ss_style_to_bias(preset: StylePreset, d_model: int) -> array {
    let slot = d_model / 3
    let mut out = []
    let mut m = 0
    while m < d_model {
        let v = if m < slot {
            preset.valence
        } else {
            if m < 2 * slot {
                preset.reality
            } else {
                if m < 3 * slot { preset.intensity } else { 0.0 }
            }
        }
        out = out.push(v)
        m = m + 1
    }
    return out
}

fn ss_style_l2_sq(a: array, b: array) -> float {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = a[i] - b[i]
        s = s + d * d
        i = i + 1
    }
    return s
}

fn ss_style_classify(sample: array, presets: [StylePreset], d_model: int) -> int {
    let n = len(presets)
    if n == 0 { return -1 }
    let mut best_id = -1
    let mut best_d = -1.0
    let mut i = 0
    while i < n {
        let p_bias = ss_style_to_bias(presets[i], d_model)
        let d = ss_style_l2_sq(sample, p_bias)
        if best_id == -1 {
            best_id = presets[i].id
            best_d = d
        } else {
            if d < best_d {
                best_d = d
                best_id = presets[i].id
            }
        }
        i = i + 1
    }
    return best_id
}

fn ss_preset_by_id(presets: [StylePreset], id: int) -> StylePreset {
    let n = len(presets)
    let mut i = 0
    while i < n {
        if presets[i].id == id { return presets[i] }
        i = i + 1
    }
    // Fallback — daily 는 label=="daily", "무감정" 디폴트
    return StylePreset {
        id: 3, label: "daily",
        valence: 0.0, reality: 0.0 - 0.9, intensity: 0.0 - 0.7
    }
}

fn ss_preset_by_label(presets: [StylePreset], label: string) -> StylePreset {
    let n = len(presets)
    let mut i = 0
    while i < n {
        if presets[i].label == label { return presets[i] }
        i = i + 1
    }
    return ss_preset_by_id(presets, 3)
}

// ═══════════════════════════════════════════════════════════════
//  Section 3. Switch result types
// ═══════════════════════════════════════════════════════════════

// SwitchResult: 결과 = 톤 + probe vector + 메타데이터.
// fallback_used : true 면 입력에 없거나 unknown 톤이라 default 사용.
// fallback_reason : "missing"/"unknown_label"/"unknown_id"/"" (성공 시 빈 문자열)
struct SwitchResult {
    tone_id:         int,
    tone_label:      string,
    probe:           array,    // d_model float vector
    fallback_used:   bool,
    fallback_reason: string
}

// SwitchTimings: latency 측정용 (T3 검증).
struct SwitchTimings {
    parse_ms:  int,
    probe_ms:  int,
    total_ms:  int
}

// ═══════════════════════════════════════════════════════════════
//  Section 4. JSON tone field parsing (fixed-marker scan)
// ═══════════════════════════════════════════════════════════════

// JSON 안의 "tone": "<label>" 또는 "tone_id": <int> 마커를 파싱.
// 정식 JSON parser 를 회피하는 이유:
//   (1) hexa string API 의 multibyte 인덱싱 quirks (memory: hexa_string_api)
//   (2) http_server 에 이미 json_parse 가 있지만 본 모듈은 stand-alone
//       단위테스트가 가능해야 함
//   (3) tone 은 fixed-set ASCII label — 단순 marker 매칭으로 충분
//
// 우선순위: "tone_id" (int) → "tone" (string label) → missing.
//
// 반환:
//   matched_id   : 발견된 id, 없으면 -1
//   matched_label: 발견된 label, 없으면 ""

struct ToneFieldExtract {
    matched_id:    int,
    matched_label: string
}

// extract_tone_field: scan body for "tone_id":N or "tone":"label" markers.
//
// SAFETY: byte-only ASCII scan — multibyte safe (Korean prompt 가 body 에
// 포함되어도 marker 는 ASCII 라 byte index 가 char index 와 일치하는
// 영역에서만 매칭됨).
fn extract_tone_field(body: string) -> ToneFieldExtract {
    // 1) "tone_id": <int>
    let id_marker = "\"tone_id\""
    let id_pos = body.index_of(id_marker)
    let mut found_id = -1
    if id_pos >= 0 {
        // skip past `"tone_id"` then look for `:` then digits
        let after = body.substring(id_pos + len(id_marker), len(body))
        let colon = after.index_of(":")
        if colon >= 0 {
            let tail = after.substring(colon + 1, len(after))
            // skip whitespace, parse leading int
            let n = len(tail)
            let mut k = 0
            while k < n {
                let ch = tail.substring(k, k + 1)
                let cc = char_code(ch, 0)
                if cc == 32 || cc == 9 { k = k + 1 } else { break }
            }
            // accumulate digits (no negative tone_id supported)
            let start = k
            while k < n {
                let ch2 = tail.substring(k, k + 1)
                let cc2 = char_code(ch2, 0)
                if cc2 >= 48 && cc2 <= 57 { k = k + 1 } else { break }
            }
            if k > start {
                let id_str = tail.substring(start, k)
                let parsed = id_str.parse_int()
                found_id = parsed
            }
        }
    }

    // 2) "tone": "<label>"
    let label_marker = "\"tone\""
    let lbl_pos = body.index_of(label_marker)
    let mut found_label = ""
    if lbl_pos >= 0 {
        let after2 = body.substring(lbl_pos + len(label_marker), len(body))
        let colon2 = after2.index_of(":")
        if colon2 >= 0 {
            let tail2 = after2.substring(colon2 + 1, len(after2))
            // skip whitespace then opening quote
            let n2 = len(tail2)
            let mut k2 = 0
            while k2 < n2 {
                let ch3 = tail2.substring(k2, k2 + 1)
                let cc3 = char_code(ch3, 0)
                if cc3 == 32 || cc3 == 9 { k2 = k2 + 1 } else { break }
            }
            if k2 < n2 {
                let q = tail2.substring(k2, k2 + 1)
                if char_code(q, 0) == 34 {  // opening "
                    k2 = k2 + 1
                    let str_start = k2
                    while k2 < n2 {
                        let ch4 = tail2.substring(k2, k2 + 1)
                        let cc4 = char_code(ch4, 0)
                        if cc4 == 34 { break }   // closing "
                        k2 = k2 + 1
                    }
                    if k2 > str_start {
                        found_label = tail2.substring(str_start, k2)
                    }
                }
            }
        }
    }

    return ToneFieldExtract {
        matched_id:    found_id,
        matched_label: found_label
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 5. Public switch API (called by http_server adapter)
// ═══════════════════════════════════════════════════════════════

// build_style_probe: tone preset 의 bias vector 를 그대로 probe 로 사용.
// 노이즈 주입은 caller 가 결정 (deterministic 검증을 위해 본 함수는 clean).
fn build_style_probe(preset: StylePreset, d_model: int) -> array {
    return ss_style_to_bias(preset, d_model)
}

// resolve_tone: ToneFieldExtract → 최종 SwitchResult.
// 우선순위: matched_id 가 [0,3] 범위면 사용, 아니면 matched_label 사용,
// 아니면 default_label fallback.
fn resolve_tone(extract: ToneFieldExtract, default_label: string,
                presets: [StylePreset], d_model: int) -> SwitchResult {
    let n = len(presets)
    if n == 0 {
        // No presets — degenerate: empty probe + flag
        return SwitchResult {
            tone_id:         -1,
            tone_label:      "",
            probe:           [],
            fallback_used:   true,
            fallback_reason: "no_presets"
        }
    }

    // (1) tone_id path
    let id = extract.matched_id
    if id >= 0 && id < n {
        let p = ss_preset_by_id(presets, id)
        let probe = build_style_probe(p, d_model)
        return SwitchResult {
            tone_id:         p.id,
            tone_label:      p.label,
            probe:           probe,
            fallback_used:   false,
            fallback_reason: ""
        }
    }
    let id_was_present = extract.matched_id >= 0
    let id_invalid_reason = if id_was_present { "unknown_id" } else { "" }

    // (2) tone label path
    let label = extract.matched_label
    if len(label) > 0 {
        // Check label exists
        let mut i = 0
        let mut hit_idx = -1
        while i < n {
            if presets[i].label == label { hit_idx = i }
            i = i + 1
        }
        if hit_idx >= 0 {
            let p2 = presets[hit_idx]
            let probe2 = build_style_probe(p2, d_model)
            return SwitchResult {
                tone_id:         p2.id,
                tone_label:      p2.label,
                probe:           probe2,
                fallback_used:   false,
                fallback_reason: ""
            }
        }
        // label given but unknown
        let p3 = ss_preset_by_label(presets, default_label)
        let probe3 = build_style_probe(p3, d_model)
        return SwitchResult {
            tone_id:         p3.id,
            tone_label:      p3.label,
            probe:           probe3,
            fallback_used:   true,
            fallback_reason: "unknown_label"
        }
    }

    // (3) nothing in extract — default fallback
    let p4 = ss_preset_by_label(presets, default_label)
    let probe4 = build_style_probe(p4, d_model)
    let reason = if len(id_invalid_reason) > 0 { id_invalid_reason } else { "missing" }
    return SwitchResult {
        tone_id:         p4.id,
        tone_label:      p4.label,
        probe:           probe4,
        fallback_used:   true,
        fallback_reason: reason
    }
}

// apply_tone_switch: top-level entry point — 본 함수가 http_server 가
// 호출하는 단일 진입점. body 만 받아 SwitchResult + timings return.
//
// 사용 예 (http_server 통합 시):
//   let presets = ss_presets_default()
//   let r = apply_tone_switch(req.body, "daily", presets, D_MODEL)
//   if r.fallback_used { log("tone fallback: " + r.fallback_reason) }
//   // forward r.probe to clm_lore_serve as ServingRequest.style_probe
fn apply_tone_switch(body: string, default_label: string,
                     presets: [StylePreset], d_model: int) -> SwitchResult {
    let extract = extract_tone_field(body)
    return resolve_tone(extract, default_label, presets, d_model)
}

// apply_tone_switch_timed: T3 latency 검증용. timestamp() millisecond
// resolution 으로 parse / probe 단계 분리 측정.
fn apply_tone_switch_timed(body: string, default_label: string,
                           presets: [StylePreset], d_model: int) -> SwitchTimings {
    let t0 = timestamp()
    let extract = extract_tone_field(body)
    let t1 = timestamp()
    let _ = resolve_tone(extract, default_label, presets, d_model)
    let t2 = timestamp()
    return SwitchTimings {
        parse_ms: t1 - t0,
        probe_ms: t2 - t1,
        total_ms: t2 - t0
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 6. Self-tests (T1–T5)
// ═══════════════════════════════════════════════════════════════

fn ss_check_T1() -> bool {
    // 4 톤 label 모두 정확히 추출.
    let presets = ss_presets_default()
    let d_model = 12
    let labels = ["romance", "horror", "fantasy", "daily"]
    let expected_ids = [0, 1, 2, 3]
    let mut i = 0
    let n = len(labels)
    while i < n {
        let body = "{\"prompt\":\"hello\",\"tone\":\"" + labels[i] + "\"}"
        let r = apply_tone_switch(body, "daily", presets, d_model)
        if r.tone_id != expected_ids[i] { return false }
        if r.tone_label != labels[i] { return false }
        if r.fallback_used { return false }
        if len(r.probe) != d_model { return false }
        i = i + 1
    }
    return true
}

fn ss_check_T2() -> bool {
    // unknown tone → "daily" (id=3) fallback.
    let presets = ss_presets_default()
    let d_model = 12

    // (a) missing tone field
    let body_a = "{\"prompt\":\"hello\"}"
    let r_a = apply_tone_switch(body_a, "daily", presets, d_model)
    if r_a.tone_id != 3 { return false }
    if !r_a.fallback_used { return false }
    if r_a.fallback_reason != "missing" { return false }

    // (b) unknown label
    let body_b = "{\"prompt\":\"hello\",\"tone\":\"sci-fi\"}"
    let r_b = apply_tone_switch(body_b, "daily", presets, d_model)
    if r_b.tone_id != 3 { return false }
    if !r_b.fallback_used { return false }
    if r_b.fallback_reason != "unknown_label" { return false }

    // (c) out-of-range id
    let body_c = "{\"prompt\":\"hello\",\"tone_id\":99}"
    let r_c = apply_tone_switch(body_c, "daily", presets, d_model)
    if r_c.tone_id != 3 { return false }
    if !r_c.fallback_used { return false }
    if r_c.fallback_reason != "unknown_id" { return false }

    return true
}

fn ss_check_T3() -> bool {
    // Latency < 50ms (done_criteria). 평균 4 톤 × 25 회 = 100 측정.
    let presets = ss_presets_default()
    let d_model = 384  // production D_MODEL
    let labels = ["romance", "horror", "fantasy", "daily"]
    let mut sum_ms = 0
    let mut max_ms = 0
    let mut i = 0
    let n = len(labels)
    while i < n {
        let body = "{\"prompt\":\"hello\",\"tone\":\"" + labels[i] + "\"}"
        let mut k = 0
        while k < 25 {
            let t = apply_tone_switch_timed(body, "daily", presets, d_model)
            sum_ms = sum_ms + t.total_ms
            if t.total_ms > max_ms { max_ms = t.total_ms }
            k = k + 1
        }
        i = i + 1
    }
    let avg = sum_ms / 100
    println("  [T3] avg=" + to_string(avg) + "ms max=" + to_string(max_ms) + "ms")
    return max_ms < 50
}

fn ss_check_T4() -> bool {
    // Blind classification 정확도 ≥ 0.8 (done_criteria 직접 증명).
    // 4 톤 × 5 sample × noise_amp=0.4 → probe + noise → ss_style_classify.
    let presets = ss_presets_default()
    let d_model = 12
    let n_per = 5
    let noise_amp = 0.4
    let n_tones = len(presets)
    let mut correct = 0
    let mut total = 0
    let mut i = 0
    while i < n_tones {
        let body = "{\"tone\":\"" + presets[i].label + "\"}"
        let r = apply_tone_switch(body, "daily", presets, d_model)
        let clean = r.probe
        let mut k = 0
        while k < n_per {
            let seed = 2000 + i * 100 + k * 7
            let noise = ss_det_rand(d_model, seed)
            let mut noisy = []
            let mut m = 0
            while m < d_model {
                noisy = noisy.push(clean[m] + noise_amp * noise[m])
                m = m + 1
            }
            let hit = ss_style_classify(noisy, presets, d_model)
            if hit == presets[i].id { correct = correct + 1 }
            total = total + 1
            k = k + 1
        }
        i = i + 1
    }
    let acc = to_float(correct) / to_float(total)
    println("  [T4] blind acc = " + to_string(correct) + "/" + to_string(total) + " = " + to_string(acc))
    return acc >= 0.8
}

fn ss_check_T5() -> bool {
    // Deterministic switch — 동일 입력 → byte-identical probe.
    let presets = ss_presets_default()
    let d_model = 12
    let body = "{\"prompt\":\"hello\",\"tone\":\"fantasy\"}"
    let r1 = apply_tone_switch(body, "daily", presets, d_model)
    let r2 = apply_tone_switch(body, "daily", presets, d_model)
    if r1.tone_id != r2.tone_id { return false }
    if r1.tone_label != r2.tone_label { return false }
    if len(r1.probe) != len(r2.probe) { return false }
    let mut i = 0
    let n = len(r1.probe)
    while i < n {
        if ss_fabs(r1.probe[i] - r2.probe[i]) > 0.0 { return false }
        i = i + 1
    }
    return true
}

// ═══════════════════════════════════════════════════════════════
//  Section 7. main
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[style_switch] TCLM-P2-2 self-test")
    println("  4 톤 런타임 스위칭 — http_server.hexa tone 파라미터 어댑터")

    let t1 = ss_check_T1()
    if t1 { println("T1 PASS — 4 톤 label 추출") } else { println("T1 FAIL") }

    let t2 = ss_check_T2()
    if t2 { println("T2 PASS — unknown 톤 → daily fallback") } else { println("T2 FAIL") }

    let t3 = ss_check_T3()
    if t3 { println("T3 PASS — latency < 50ms (done_criteria)") } else { println("T3 FAIL") }

    let t4 = ss_check_T4()
    if t4 { println("T4 PASS — blind classification >= 0.8 (done_criteria)") } else { println("T4 FAIL") }

    let t5 = ss_check_T5()
    if t5 { println("T5 PASS — deterministic switch") } else { println("T5 FAIL") }

    let all_pass = t1 && t2 && t3 && t4 && t5
    if all_pass {
        println("[style_switch] ALL 5/5 PASS — TCLM-P2-2 done_criteria 달성")
    } else {
        println("[style_switch] SOME FAILED")
    }
}

main()
