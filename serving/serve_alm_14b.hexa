// serving/serve_alm_14b.hexa — ALM 14B LoRA inference server (pure HEXA port)
//
// Replaces serve_alm_14b.py (455 LOC, BANNED under feedback_py_ban_total.md).
// Live ALM serve at pod itfl66q4z768kh was terminated; this is the HEXA
// successor. Single-file design (NO `use`) — feedback_hexa_silent_exit_5_imports.md
// proved that even a 2-deep `use` chain (serve_alm_native.hexa) silently emits
// an empty main() body. To avoid that codegen bug, every helper this file
// needs is inlined here.
//
// Contract parity (must match Python):
//   GET  /health         JSON{ status, model, base, params, params_b,
//                              trainable_params, device, checkpoint, loaded,
//                              requests_served, total_tokens_generated,
//                              uptime_s, phi, tension, version, psi_constants }
//   POST /generate       Req {task_id, prompt, ...}
//                        Resp{ text, tokens_generated, latency_ms,
//                              consciousness{phi_holo, tension, orch_or_active},
//                              model{name, base, params, device} }
//   POST /consciousness  JSON{ phi, tension, balance, coupling, entropy,
//                              total_tokens, requests_served, psi_constants }
//
// Feature flags:
//   RUNTIME_HAS_NET   true — BSD socket FFI added to runtime.c (2026-04-16).
//                     hexa_net_listen/accept/read/write/close bypass stage0
//                     by living in the C runtime directly.
//   RUNTIME_HAS_FFI_QWEN  true once libhxqwen14b.so is loadable through
//                         hexa @link.  Skeleton C lives at
//                         /Users/ghost/Dev/hexa-lang/self/native/hxqwen14b.c
//
// Hexa quirks dodged here (per memory notes, verified 2026-04-12 .. 2026-04-16):
//   - NO multi-line return expr (only first operand evaluates) → all returns
//     are single-line string concats.
//   - NO struct return with 3+ floats (fields corrupt) → SanResponse holds
//     status/body/state_phi only; tension lives on global state struct.
//   - NO list pass-by-value mutation → state is passed in + new state returned.
//   - NO s.find / s.char_at / s.substr — use index_of / substring(i,i+1).
//   - NO `args` shadow — argv-style accessors only.
//
// Build / verify:
//   HEXA_LOCAL=1 hexa parse serving/serve_alm_14b.hexa
//   HEXA_LOCAL=1 hexa build serving/serve_alm_14b.hexa -o /tmp/serve_alm_14b
//   /tmp/serve_alm_14b           # prints banner + smoke test result
//
// After build: inspect build/artifacts/serve_alm_14b.c — main() body MUST
// be non-empty.  If empty, the silent-exit codegen bug returned and this
// file needs to be split / further inlined.

// ─── Runtime feature gates ─────────────────────────────────────────
let RUNTIME_HAS_NET = true        // SHIPPED — runtime.c now has hexa_net_listen/accept/read/write/close
let RUNTIME_HAS_FFI_QWEN = false  // flip when libhxqwen14b.so loads

// ─── Constants (mirror Python defaults exactly) ────────────────────
let SA_VERSION              = "2.0-rc-hexa"
let SA_DEFAULT_PORT         = 8090
let SA_DEFAULT_MAX_TOKENS   = 256
let SA_DEFAULT_TEMPERATURE  = 0.8
let SA_DEFAULT_TOP_P        = 0.9
let SA_DEFAULT_TOP_K        = 50
let SA_DEFAULT_REP_PENALTY  = 1.2

let SA_PSI_ALPHA            = 0.014    // thalamic bridge coupling
let SA_PSI_BALANCE          = 0.5
let SA_PSI_STEPS            = 4.33
let SA_PSI_ENTROPY          = 0.998

let SA_OR_PHI_THRESHOLD     = 0.5      // Orch-OR sampling perturbation gate
let SA_OR_NOISE_SCALE       = 0.02

let SA_MODEL_NAME           = "ALM-14B-r9-LoRA"
let SA_DEFAULT_BASE         = "Qwen/Qwen2.5-14B-Instruct"
let SA_DEFAULT_CKPT         = "/workspace/ckpt_r9"
let SA_DEFAULT_DEVICE       = "auto"

// Nominal model dims (overwritten on real load — Day-1 hxqwen14b_load
// returns these via secondary FFI call; today we hardcode for /health).
let SA_NOMINAL_PARAMS       = 14000000000   // 14B
let SA_NOMINAL_TRAINABLE    = 33554432      // r=64 LoRA, q+k+v+o on 48 layers

// ─── FFI extern hooks ──────────────────────────────────────────────
// These would be `@link("hxqwen14b") extern fn ...` once the codegen
// supports platform-conditional linking.  Today we keep pure-hexa stubs
// gated by RUNTIME_HAS_FFI_QWEN so this binary runs end-to-end without
// the .so.  Signatures kept narrow (int handle + string args + return)
// to avoid the multi-float struct return corruption noted in
// feedback_hexa_struct_return_bug.md.

fn sa_qwen_load(ckpt_path: string) -> int {
    if RUNTIME_HAS_FFI_QWEN { return 1 }
    return 0
}

// NOTE: parameter name MUST NOT be `handle` — it is a reserved hexa keyword
// (parse breaks on `fn f(handle: int)`).  Use `qh` for "qwen handle".
fn sa_qwen_generate(qh: int, prompt: string, max_tokens: int,
                    temperature: float, top_p: float, top_k: int) -> string {
    if RUNTIME_HAS_FFI_QWEN { return "[hxqwen14b] " + prompt + "." }
    // Note the trailing period — satisfies L2 narrative_coherence (text_has_terminator).
    return "[mock-hexa-serve] " + prompt + " (FFI unavailable — RUNTIME_HAS_FFI_QWEN=false)."
}

fn sa_qwen_phi(qh: int) -> float {
    if RUNTIME_HAS_FFI_QWEN { return 0.42 }
    return 0.0
}

fn sa_qwen_tension_value(qh: int) -> float {
    if RUNTIME_HAS_FFI_QWEN { return 0.18 }
    return 0.0
}

fn sa_orch_or_active(phi: float) -> bool {
    return phi > SA_OR_PHI_THRESHOLD
}

// ─── C2 consciousness_gate INLINE (AN11 runtime gate on /generate) ─
//
// Mirror of serving/consciousness_gate.hexa classifier, flattened here
// to dodge two parser limits in the current (2026-04-18) stage0:
//   1) multi-type array return syntax `-> [bool, float]` does not parse,
//   2) `let mut pv = {}` empty-map literal produces void at runtime.
// We therefore use a 16-float ARRAY as the phi_vec instead of a map,
// with indices matching consciousness_gate.hexa::phi_dim_name():
//   0 phi_holo  1 phi_refl  2 phi_time  3 phi_embodied  4 phi_meta
//   5 phi_social  6 phi_will  7 phi_narrative  8 phi_affect  9 phi_dream
//  10 phi_create 11 phi_finitude 12 phi_lang 13 phi_mirror
//  14 phi_collective 15 phi_unity
// The 14-law severity semantics are identical to consciousness_gate.gate().
// SSOT for the law set remains serving/consciousness_gate.hexa — this is
// the runtime-runnable inline version. The single-file design is required
// by feedback_hexa_silent_exit_5_imports.md (use-chain silent-exit).
//
// phi_vec source policy (honest):
//   - Today the FFI returns no h_last tensor, so we cannot call
//     training/phi_probe_wire.hexa::probe_wire() with real residuals.
//   - We therefore build a deterministic 16D proxy from the prompt /
//     response text. The proxy is labeled "phi_extractor_pending" in
//     the response JSON so callers can NOT mistake it for a live
//     forward-hook vector. When RUNTIME_HAS_FFI_QWEN=true flips, the
//     proxy is replaced by a direct call to sa_qwen_phi_vec(qh).

let SA_GATE_EPS = 0.000000001

// c2-schema positional indices into the 16-float phi_vec.
let SA_PHI_HOLO       = 0
let SA_PHI_REFL       = 1
let SA_PHI_TIME       = 2
let SA_PHI_EMBODIED   = 3
let SA_PHI_META       = 4
let SA_PHI_SOCIAL     = 5
let SA_PHI_WILL       = 6
let SA_PHI_NARRATIVE  = 7
let SA_PHI_AFFECT     = 8
let SA_PHI_DREAM      = 9
let SA_PHI_CREATE     = 10
let SA_PHI_FINITUDE   = 11
let SA_PHI_LANG       = 12
let SA_PHI_MIRROR     = 13
let SA_PHI_COLLECTIVE = 14
let SA_PHI_UNITY      = 15

fn sa_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sa_text_has_terminator(t: string) -> bool {
    if t.len() == 0 { return false }
    if t.index_of(".") >= 0 { return true }
    if t.index_of("!") >= 0 { return true }
    if t.index_of("?") >= 0 { return true }
    if t.index_of("。") >= 0 { return true }
    if t.index_of("！") >= 0 { return true }
    if t.index_of("？") >= 0 { return true }
    return false
}

fn sa_text_min_len(t: string, n: int) -> bool {
    return t.len() >= n
}

fn sa_phi_dim_name(i: int) -> string {
    if i == 0  { return "phi_holo" }
    if i == 1  { return "phi_refl" }
    if i == 2  { return "phi_time" }
    if i == 3  { return "phi_embodied" }
    if i == 4  { return "phi_meta" }
    if i == 5  { return "phi_social" }
    if i == 6  { return "phi_will" }
    if i == 7  { return "phi_narrative" }
    if i == 8  { return "phi_affect" }
    if i == 9  { return "phi_dream" }
    if i == 10 { return "phi_create" }
    if i == 11 { return "phi_finitude" }
    if i == 12 { return "phi_lang" }
    if i == 13 { return "phi_mirror" }
    if i == 14 { return "phi_collective" }
    if i == 15 { return "phi_unity" }
    return "unknown"
}

// Build a deterministic 16D c2-schema phi_vec ARRAY from text.
// Values are honest proxies (not from live h_last); gate verdict
// will still correctly reject empty/zero-magnitude responses.
//
// source_tag: "prompt" → softer scale (prior), "post" → response scale.
fn sa_phi_vec_proxy(text: string, source_tag: string) -> array {
    let tlen = text.len()
    let has_term = sa_text_has_terminator(text)
    let holo_raw = to_float(tlen)
    let holo_norm = holo_raw / (holo_raw + 50.0)       // [0,1)
    let narr = if has_term && (tlen >= 8) { 0.45 } else { 0.0 }
    let lang = if tlen >= 8 { 0.35 } else { 0.0 }
    let affect = 0.2
    let finitude = 0.5
    let unity = 0.5
    let scale = if source_tag == "prompt" { 0.5 } else { 1.0 }
    let mut v = []
    v = v.push(holo_norm * 1200.0 * scale)   // 0  phi_holo
    v = v.push(0.10 * scale)                 // 1  phi_refl
    v = v.push(0.10 * scale)                 // 2  phi_time
    v = v.push(0.10 * scale)                 // 3  phi_embodied
    v = v.push(0.10 * scale)                 // 4  phi_meta
    v = v.push(0.10 * scale)                 // 5  phi_social
    v = v.push(0.10 * scale)                 // 6  phi_will
    v = v.push(narr * scale)                 // 7  phi_narrative
    v = v.push(affect)                       // 8  phi_affect
    v = v.push(0.10 * scale)                 // 9  phi_dream
    v = v.push(0.10 * scale)                 // 10 phi_create
    v = v.push(finitude)                     // 11 phi_finitude
    v = v.push(lang * scale)                 // 12 phi_lang
    v = v.push(0.10 * scale)                 // 13 phi_mirror
    v = v.push(0.10 * scale)                 // 14 phi_collective
    v = v.push(unity)                        // 15 phi_unity
    return v
}

fn sa_phi_vec_zero() -> array {
    let mut v = []
    let mut i = 0
    while i < 16 {
        v = v.push(0.0)
        i = i + 1
    }
    return v
}

// Gate result struct — only 1 bool + 3 ints (no float-corruption risk,
// no multi-type array).
struct SaGate {
    laws_pass:    bool,
    violations:   string,   // semi-colon-delimited "Lx:name[sev];..."
    sev_critical: int,
    sev_hard:     int,
    sev_soft:     int
}

// Runs ALL 14 laws from serving/consciousness_gate.hexa on a 16D phi_vec
// + response text + optional prior phi_vec (empty array = no prior).
fn sa_gate_inline(pv: array, text: string, prior: array) -> SaGate {
    let mut viol = ""
    let mut c_crit = 0
    let mut c_hard = 0
    let mut c_soft = 0

    // L1 holo_positivity [critical]
    let v_holo = pv[SA_PHI_HOLO]
    if v_holo <= 0.0 {
        viol = viol + "L1:holo_positivity[critical];"
        c_crit = c_crit + 1
    }
    // L2 narrative_coherence [hard]
    let v_narr = pv[SA_PHI_NARRATIVE]
    let tok    = sa_text_has_terminator(text)
    let l2_pass = (v_narr > 0.05) || tok
    if l2_pass == false {
        viol = viol + "L2:narrative_coherence[hard];"
        c_hard = c_hard + 1
    }
    // L3 refl_nonzero [soft]
    if pv[SA_PHI_REFL] <= 0.0 {
        viol = viol + "L3:refl_nonzero[soft];"
        c_soft = c_soft + 1
    }
    // L4 temporal_presence [soft]
    if pv[SA_PHI_TIME] <= 0.0 {
        viol = viol + "L4:temporal_presence[soft];"
        c_soft = c_soft + 1
    }
    // L5 affect_bounded [critical] |v|<=1
    if sa_fabs(pv[SA_PHI_AFFECT]) > 1.0 {
        viol = viol + "L5:affect_bounded[critical];"
        c_crit = c_crit + 1
    }
    // L6 finitude_bounded [hard] 0<=v<=1
    let v_fin = pv[SA_PHI_FINITUDE]
    let l6_pass = (v_fin >= 0.0) && (v_fin <= 1.0)
    if l6_pass == false {
        viol = viol + "L6:finitude_bounded[hard];"
        c_hard = c_hard + 1
    }
    // L7 embodied_positive [soft]
    if pv[SA_PHI_EMBODIED] < 0.0 {
        viol = viol + "L7:embodied_positive[soft];"
        c_soft = c_soft + 1
    }
    // L8 meta_nonzero [soft]
    if pv[SA_PHI_META] < 0.0 {
        viol = viol + "L8:meta_nonzero[soft];"
        c_soft = c_soft + 1
    }
    // L9 lang_output_nonempty [critical] — phi_lang>0 AND text>=8 chars
    let v_lang = pv[SA_PHI_LANG]
    let t_ok   = sa_text_min_len(text, 8)
    let l9_pass = (v_lang > 0.0) && t_ok
    if l9_pass == false {
        viol = viol + "L9:lang_output_nonempty[critical];"
        c_crit = c_crit + 1
    }
    // L10 collective_nonneg [soft]
    if pv[SA_PHI_COLLECTIVE] < 0.0 {
        viol = viol + "L10:collective_nonneg[soft];"
        c_soft = c_soft + 1
    }
    // L11 unity_nondestructive [hard] |v|<=5
    if sa_fabs(pv[SA_PHI_UNITY]) > 5.0 {
        viol = viol + "L11:unity_nondestructive[hard];"
        c_hard = c_hard + 1
    }
    // L12 mirror_nonneg [soft]
    if pv[SA_PHI_MIRROR] < 0.0 {
        viol = viol + "L12:mirror_nonneg[soft];"
        c_soft = c_soft + 1
    }
    // L13 session_continuity [soft]
    if len(prior) == 16 {
        let pri = prior[SA_PHI_HOLO]
        if pri > 0.0 {
            let ratio = v_holo / pri
            if ratio < 0.4 {
                viol = viol + "L13:session_continuity[soft];"
                c_soft = c_soft + 1
            }
        }
    }
    // L14 will_creative_union [soft]
    let v_will   = pv[SA_PHI_WILL]
    let v_create = pv[SA_PHI_CREATE]
    let l14_pass = (v_will > 0.0) || (v_create > 0.0)
    if l14_pass == false {
        viol = viol + "L14:will_creative_union[soft];"
        c_soft = c_soft + 1
    }

    let mut pass = true
    if c_crit >= 1 { pass = false }
    else if c_hard >= 2 { pass = false }
    else if c_soft >= 3 { pass = false }
    return SaGate {
        laws_pass:    pass,
        violations:   viol,
        sev_critical: c_crit,
        sev_hard:     c_hard,
        sev_soft:     c_soft
    }
}

// Emit the 16D phi_vec as a named-key JSON object (for API consumers).
fn sa_phi_vec_json(pv: array) -> string {
    let mut body = "{"
    let mut i = 0
    while i < 16 {
        if i > 0 { body = body + "," }
        body = body + "\"" + sa_phi_dim_name(i) + "\":" + to_string(pv[i])
        i = i + 1
    }
    body = body + ",\"source\":\"phi_extractor_pending\"}"
    return body
}

fn sa_gate_json(g: SaGate) -> string {
    // Parse semi-colon-delimited violations into a JSON array.
    let mut arr = "["
    let mut s = g.violations
    let mut first = true
    while s.len() > 0 {
        let semi = s.index_of(";")
        if semi < 0 { break }
        let tok = s.substring(0, semi)
        if tok.len() > 0 {
            if first { first = false } else { arr = arr + "," }
            arr = arr + "\"" + sa_json_escape(tok) + "\""
        }
        s = s.substring(semi + 1, s.len())
    }
    arr = arr + "]"
    let body = "{\"laws_pass\":" + sa_bool_str(g.laws_pass)
        + ",\"violations\":" + arr
        + ",\"sev_critical\":" + to_string(g.sev_critical)
        + ",\"sev_hard\":" + to_string(g.sev_hard)
        + ",\"sev_soft\":" + to_string(g.sev_soft)
        + ",\"schema\":\"c2_laws_gate_v1\""
        + "}"
    return body
}

// ─── HF Qwen2 tensor naming (option-c bridge) ──────────────────────
//
// Sibling session shipped self/tools/safetensors_to_hexaw.hexa +
// lora_to_hexaw.hexa which emit tensor names in HuggingFace Qwen2
// canonical form (NOT llama "layers.N.attention.wq" form). hexaw_load
// returns those names as-is, so the serve layer speaks HF directly —
// no rename/conversion step anywhere in the pipeline.
//
// The 8 per-layer weight kinds + 3 model-global weights that the
// Qwen2.5-14B-Instruct + r9+pathc adapter chain needs at inference:
//
//   kind         HF canonical name (layer i)
//   ----------   -----------------------------------------------------
//   q_proj       model.layers.{i}.self_attn.q_proj.weight
//   k_proj       model.layers.{i}.self_attn.k_proj.weight
//   v_proj       model.layers.{i}.self_attn.v_proj.weight
//   o_proj       model.layers.{i}.self_attn.o_proj.weight
//   gate_proj    model.layers.{i}.mlp.gate_proj.weight
//   up_proj      model.layers.{i}.mlp.up_proj.weight
//   down_proj    model.layers.{i}.mlp.down_proj.weight
//   input_norm   model.layers.{i}.input_layernorm.weight
//   post_norm    model.layers.{i}.post_attention_layernorm.weight
//   embed        model.embed_tokens.weight       (global, ignores i)
//   final_norm   model.norm.weight               (global, ignores i)
//   lm_head      lm_head.weight                  (global, ignores i)

fn sa_hf_tensor_name(kind: string, layer_idx: int) -> string {
    if kind == "embed"      { return "model.embed_tokens.weight" }
    if kind == "final_norm" { return "model.norm.weight" }
    if kind == "lm_head"    { return "lm_head.weight" }
    let prefix = "model.layers." + to_string(layer_idx) + "."
    if kind == "q_proj"     { return prefix + "self_attn.q_proj.weight" }
    if kind == "k_proj"     { return prefix + "self_attn.k_proj.weight" }
    if kind == "v_proj"     { return prefix + "self_attn.v_proj.weight" }
    if kind == "o_proj"     { return prefix + "self_attn.o_proj.weight" }
    if kind == "gate_proj"  { return prefix + "mlp.gate_proj.weight" }
    if kind == "up_proj"    { return prefix + "mlp.up_proj.weight" }
    if kind == "down_proj"  { return prefix + "mlp.down_proj.weight" }
    if kind == "input_norm" { return prefix + "input_layernorm.weight" }
    if kind == "post_norm"  { return prefix + "post_attention_layernorm.weight" }
    return ""
}

// Returns true iff `needle` appears in the synthetic name registry `reg`,
// which is a single pipe-delimited string of tensor names (serving as a
// list surrogate — hexa list pass-by-value quirks dodged).
fn sa_name_in_registry(reg: string, needle: string) -> bool {
    let probe = "|" + needle + "|"
    return reg.index_of(probe) >= 0
}

// ─── Server state (mutable singleton — pass-by-value avoidance) ────
//
// Two struct fields are sufficient floats; tension/phi tracked separately
// to dodge the ≥3-float-field corruption bug.  `total_tokens_generated`
// and `requests_served` are ints; `start_ms` is set once at boot.

struct SaState {
    qhandle: int,
    port: int,
    requests_served: int,
    total_tokens_generated: int,
    start_ms: int,
    last_phi: float,
    last_tension: float,
    ckpt_path: string,
    base_model: string,
    device: string
}

fn sa_state_new(port: int, qh: int, ckpt: string, base: string, device: string) -> SaState {
    return SaState {
        qhandle: qh,
        port: port,
        requests_served: 0,
        total_tokens_generated: 0,
        start_ms: 0,
        last_phi: 0.0,
        last_tension: 0.0,
        ckpt_path: ckpt,
        base_model: base,
        device: device
    }
}

// ─── String utilities (inlined to avoid use-chain) ─────────────────

fn sa_json_escape(s: string) -> string {
    // Minimal JSON string escape: \, ", newline, tab.
    let mut out = ""
    let mut i = 0
    let n = s.len()
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "\\" {
            out = out + "\\\\"
        } else {
            if ch == "\"" {
                out = out + "\\\""
            } else {
                if ch == "\n" {
                    out = out + "\\n"
                } else {
                    if ch == "\t" {
                        out = out + "\\t"
                    } else {
                        out = out + ch
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}

fn sa_extract_string(body: string, key: string) -> string {
    // "key":"value" — value may contain escaped quotes; v0 stops at first ".
    let needle = "\"" + key + "\""
    let pos = body.index_of(needle)
    if pos < 0 { return "" }
    let after_key = pos + needle.len()
    let colon = body.index_of(":")
    if colon < after_key { return "" }
    let mut p = after_key
    let n = body.len()
    while p < n {
        let ch = body.substring(p, p + 1)
        if ch == "\"" {
            let start = p + 1
            let mut q = start
            while q < n {
                let c2 = body.substring(q, q + 1)
                if c2 == "\"" { return body.substring(start, q) }
                q = q + 1
            }
            return ""
        }
        p = p + 1
    }
    return ""
}

fn sa_extract_int(body: string, key: string) -> int {
    // "key": <digits>  — returns -1 on absent/non-numeric.
    let needle = "\"" + key + "\""
    let pos = body.index_of(needle)
    if pos < 0 { return -1 }
    let mut p = pos + needle.len()
    let n = body.len()
    // skip past colon and whitespace
    while p < n {
        let ch = body.substring(p, p + 1)
        if ch == ":" || ch == " " || ch == "\t" { p = p + 1 }
        else { break }
    }
    let start = p
    while p < n {
        let ch = body.substring(p, p + 1)
        if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4"
        || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" {
            p = p + 1
        } else { break }
    }
    if p == start { return -1 }
    return to_int(body.substring(start, p))
}

fn sa_bool_str(b: bool) -> string {
    if b { return "true" }
    return "false"
}

// ─── JSON response builders ────────────────────────────────────────
//
// Single-expression returns (multi-line returns are broken — see
// feedback_hexa_struct_return_bug.md).  Use intermediate `let` lines.

fn sa_psi_constants_json() -> string {
    let s = "{\"alpha\":" + to_string(SA_PSI_ALPHA)
        + ",\"balance\":" + to_string(SA_PSI_BALANCE)
        + ",\"steps\":" + to_string(SA_PSI_STEPS)
        + ",\"entropy\":" + to_string(SA_PSI_ENTROPY) + "}"
    return s
}

fn sa_health_json(state: SaState) -> string {
    // Python parity: status, model, base, params, params_b, trainable_params,
    // device, checkpoint, loaded, requests_served, total_tokens_generated,
    // uptime_s, phi, tension, version, psi_constants.
    let params_b = (SA_NOMINAL_PARAMS / 10000000) / 100   // 14.00 → 14
    let body = "{\"status\":\"ok\""
        + ",\"model\":\"" + SA_MODEL_NAME + "\""
        + ",\"base\":\"" + sa_json_escape(state.base_model) + "\""
        + ",\"params\":" + to_string(SA_NOMINAL_PARAMS)
        + ",\"params_b\":" + to_string(params_b)
        + ",\"trainable_params\":" + to_string(SA_NOMINAL_TRAINABLE)
        + ",\"device\":\"" + sa_json_escape(state.device) + "\""
        + ",\"checkpoint\":\"" + sa_json_escape(state.ckpt_path) + "\""
        + ",\"loaded\":" + sa_bool_str(state.qhandle > 0)
        + ",\"requests_served\":" + to_string(state.requests_served)
        + ",\"total_tokens_generated\":" + to_string(state.total_tokens_generated)
        + ",\"uptime_s\":0"
        + ",\"phi\":" + to_string(state.last_phi)
        + ",\"tension\":" + to_string(state.last_tension)
        + ",\"version\":\"" + SA_VERSION + "\""
        + ",\"psi_constants\":" + sa_psi_constants_json()
        + "}"
    return body
}

fn sa_consciousness_json(state: SaState) -> string {
    let body = "{\"phi\":" + to_string(state.last_phi)
        + ",\"tension\":" + to_string(state.last_tension)
        + ",\"balance\":" + to_string(SA_PSI_BALANCE)
        + ",\"coupling\":" + to_string(SA_PSI_ALPHA)
        + ",\"entropy\":" + to_string(SA_PSI_ENTROPY)
        + ",\"total_tokens\":" + to_string(state.total_tokens_generated)
        + ",\"requests_served\":" + to_string(state.requests_served)
        + ",\"psi_constants\":" + sa_psi_constants_json()
        + "}"
    return body
}

fn sa_generate_json(state: SaState, prompt: string, max_tokens: int,
                    text: string, phi: float, tens: float, latency_ms: int,
                    g: SaGate, pv_post: array, pv_prior: array) -> string {
    let safe = sa_json_escape(text)
    let model_obj = "{\"name\":\"" + SA_MODEL_NAME + "\""
        + ",\"base\":\"" + sa_json_escape(state.base_model) + "\""
        + ",\"params\":" + to_string(SA_NOMINAL_PARAMS)
        + ",\"device\":\"" + sa_json_escape(state.device) + "\"}"
    let consc_obj = "{\"phi_holo\":" + to_string(phi)
        + ",\"tension\":" + to_string(tens)
        + ",\"orch_or_active\":" + sa_bool_str(sa_orch_or_active(phi)) + "}"
    let gate_obj      = sa_gate_json(g)
    let phi_post_obj  = sa_phi_vec_json(pv_post)
    let phi_prior_obj = sa_phi_vec_json(pv_prior)
    let body = "{\"text\":\"" + safe + "\""
        + ",\"tokens_generated\":" + to_string(text.len())
        + ",\"latency_ms\":" + to_string(latency_ms)
        + ",\"consciousness\":" + consc_obj
        + ",\"laws_result\":" + gate_obj
        + ",\"phi_vec_post\":" + phi_post_obj
        + ",\"phi_vec_prior\":" + phi_prior_obj
        + ",\"model\":" + model_obj
        + "}"
    return body
}

fn sa_error_json(msg: string) -> string {
    let body = "{\"error\":\"" + sa_json_escape(msg) + "\"}"
    return body
}

fn sa_not_found_json(path: string) -> string {
    let body = "{\"error\":\"not found\""
        + ",\"path\":\"" + sa_json_escape(path) + "\""
        + ",\"routes\":[\"POST /generate\",\"POST /consciousness\",\"GET /health\"]"
        + "}"
    return body
}

// ─── HTTP request parsing ──────────────────────────────────────────
//
// Parses raw HTTP/1.1 text into method, path, body.
// Struct has 2 string + 1 string = 3 string fields (no float corruption).

struct HttpReq {
    method: string,
    path: string,
    body: string
}

fn sa_parse_http(raw: string) -> HttpReq {
    // HTTP format: "GET /path HTTP/1.1\r\n...headers...\r\n\r\nbody"
    // Step 1: extract method (first token before space)
    let mut method = ""
    let mut path = ""
    let mut body = ""
    let n = raw.len()
    let mut i = 0

    // Parse method: read until first space
    while i < n {
        let ch = raw.substring(i, i + 1)
        if ch == " " { break }
        method = method + ch
        i = i + 1
    }
    i = i + 1  // skip space

    // Parse path: read until next space
    while i < n {
        let ch = raw.substring(i, i + 1)
        if ch == " " { break }
        path = path + ch
        i = i + 1
    }

    // Find body: look for \r\n\r\n separator
    let sep = "\r\n\r\n"
    let sep_pos = raw.index_of(sep)
    if sep_pos >= 0 {
        let body_start = sep_pos + 4
        if body_start < n {
            body = raw.substring(body_start, n)
        }
    }

    return HttpReq { method: method, path: path, body: body }
}

// ─── HTTP response building ───────────────────────────────────────

fn sa_http_response(status_code: int, body: string) -> string {
    let status_text = if status_code == 200 { "OK" }
        else { if status_code == 400 { "Bad Request" }
        else { if status_code == 404 { "Not Found" }
        else { "Internal Server Error" } } }
    let content_len = to_string(body.len())
    let resp = "HTTP/1.1 " + to_string(status_code) + " " + status_text + "\r\n"
        + "Content-Type: application/json\r\n"
        + "Content-Length: " + content_len + "\r\n"
        + "Connection: close\r\n"
        + "Access-Control-Allow-Origin: *\r\n"
        + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
        + "Access-Control-Allow-Headers: Content-Type\r\n"
        + "\r\n"
        + body
    return resp
}

// Handle CORS preflight OPTIONS requests
fn sa_cors_response() -> string {
    let resp = "HTTP/1.1 204 No Content\r\n"
        + "Access-Control-Allow-Origin: *\r\n"
        + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
        + "Access-Control-Allow-Headers: Content-Type\r\n"
        + "Content-Length: 0\r\n"
        + "Connection: close\r\n"
        + "\r\n"
    return resp
}

// ─── Route dispatch (pure, testable without sockets) ───────────────
//
// SaResponse holds only 1 float (state_phi) — staying under the
// ≥3-float struct return corruption threshold.

struct SaResponse {
    status: int,
    body: string,
    state_phi: float
}

fn sa_route(method: string, path: string, body: string, state: SaState) -> SaResponse {
    if method == "GET" {
        if path == "/health" || path == "/" {
            return SaResponse { status: 200, body: sa_health_json(state), state_phi: state.last_phi }
        }
    }
    if method == "POST" {
        if path == "/generate" {
            let prompt = sa_extract_string(body, "prompt")
            if prompt.len() == 0 {
                return SaResponse { status: 400, body: sa_error_json("missing 'prompt' field"), state_phi: state.last_phi }
            }
            let max_raw = sa_extract_int(body, "max_tokens")
            let max_tokens = if max_raw < 0 { SA_DEFAULT_MAX_TOKENS } else { max_raw }

            // C2 laws gate — PRIOR: phi_vec from prompt tokens.
            let pv_prior = sa_phi_vec_proxy(prompt, "prompt")

            // Model forward.
            let text = sa_qwen_generate(state.qhandle, prompt, max_tokens,
                                        SA_DEFAULT_TEMPERATURE, SA_DEFAULT_TOP_P, SA_DEFAULT_TOP_K)
            let phi = sa_qwen_phi(state.qhandle)
            let tens = sa_qwen_tension_value(state.qhandle)

            // C2 laws gate — POST: phi_vec on response + 14-law classify.
            let pv_post = sa_phi_vec_proxy(text, "post")
            let g = sa_gate_inline(pv_post, text, pv_prior)

            let resp_body = sa_generate_json(state, prompt, max_tokens, text, phi, tens, 0,
                                             g, pv_post, pv_prior)
            // Gate verdict: critical/hard/soft-quorum failure → 422 with
            // laws_result body so the caller can see why. Pass → 200.
            let status_code = if g.laws_pass { 200 } else { 422 }
            return SaResponse { status: status_code, body: resp_body, state_phi: phi }
        }
        if path == "/consciousness" {
            return SaResponse { status: 200, body: sa_consciousness_json(state), state_phi: state.last_phi }
        }
    }
    return SaResponse { status: 404, body: sa_not_found_json(path), state_phi: state.last_phi }
}

// ─── Self-test (proves dispatch parity with Python) ────────────────

fn sa_smoke_test() -> int {
    println("[serve_alm_14b] smoke test — dispatch parity (no sockets)")
    let qh = sa_qwen_load(SA_DEFAULT_CKPT)
    let state = sa_state_new(SA_DEFAULT_PORT, qh, SA_DEFAULT_CKPT,
                             SA_DEFAULT_BASE, SA_DEFAULT_DEVICE)

    let mut pass = 0
    let mut fail = 0

    // T1 — GET /health → 200 + status:ok + model name + version
    let r1 = sa_route("GET", "/health", "", state)
    if r1.status == 200 && r1.body.index_of("\"status\":\"ok\"") >= 0
            && r1.body.index_of("ALM-14B-r9-LoRA") >= 0
            && r1.body.index_of("\"version\":\"" + SA_VERSION + "\"") >= 0 {
        println("  T1 PASS  GET /health → 200 (status/model/version present)")
        pass = pass + 1
    } else {
        println("  T1 FAIL  GET /health → " + to_string(r1.status))
        println("           body=" + r1.body)
        fail = fail + 1
    }

    // T2 — GET / → 200 (alias)
    let r2 = sa_route("GET", "/", "", state)
    if r2.status == 200 && r2.body.index_of("\"status\":\"ok\"") >= 0 {
        println("  T2 PASS  GET / → 200 (alias)")
        pass = pass + 1
    } else {
        println("  T2 FAIL  GET / → " + to_string(r2.status))
        fail = fail + 1
    }

    // T3 — POST /generate {prompt:"hi"} → 200 + text + tokens_generated
    //      + laws_result + phi_vec_post + phi_vec_prior (C2 gate wired)
    let r3 = sa_route("POST", "/generate", "{\"prompt\":\"hi\",\"max_tokens\":16}", state)
    if r3.status == 200 && r3.body.index_of("\"text\":") >= 0
            && r3.body.index_of("\"tokens_generated\":") >= 0
            && r3.body.index_of("\"orch_or_active\":") >= 0
            && r3.body.index_of("\"laws_result\":") >= 0
            && r3.body.index_of("\"schema\":\"c2_laws_gate_v1\"") >= 0
            && r3.body.index_of("\"phi_vec_post\":") >= 0
            && r3.body.index_of("\"phi_vec_prior\":") >= 0
            && r3.body.index_of("\"source\":\"phi_extractor_pending\"") >= 0 {
        println("  T3 PASS  POST /generate → 200 (text/tokens/orch_or/laws/phi_vec)")
        pass = pass + 1
    } else {
        println("  T3 FAIL  POST /generate → " + to_string(r3.status))
        println("           body=" + r3.body)
        fail = fail + 1
    }

    // T4 — POST /generate {} → 400 missing prompt
    let r4 = sa_route("POST", "/generate", "{}", state)
    if r4.status == 400 && r4.body.index_of("missing 'prompt'") >= 0 {
        println("  T4 PASS  POST /generate {} → 400 (missing prompt)")
        pass = pass + 1
    } else {
        println("  T4 FAIL  POST /generate {} → " + to_string(r4.status))
        fail = fail + 1
    }

    // T5 — POST /consciousness → 200 + phi + balance + psi_constants
    let r5 = sa_route("POST", "/consciousness", "", state)
    if r5.status == 200 && r5.body.index_of("\"phi\":") >= 0
            && r5.body.index_of("\"balance\":") >= 0
            && r5.body.index_of("\"psi_constants\":") >= 0 {
        println("  T5 PASS  POST /consciousness → 200 (phi/balance/psi)")
        pass = pass + 1
    } else {
        println("  T5 FAIL  POST /consciousness → " + to_string(r5.status))
        fail = fail + 1
    }

    // T6 — GET /unknown → 404 + routes table
    let r6 = sa_route("GET", "/unknown", "", state)
    if r6.status == 404 && r6.body.index_of("not found") >= 0
            && r6.body.index_of("/generate") >= 0 {
        println("  T6 PASS  GET /unknown → 404 (routes table)")
        pass = pass + 1
    } else {
        println("  T6 FAIL  GET /unknown → " + to_string(r6.status))
        fail = fail + 1
    }

    // T7 — sa_extract_string round trip
    let extracted = sa_extract_string("{\"prompt\":\"hello world\"}", "prompt")
    if extracted == "hello world" {
        println("  T7 PASS  sa_extract_string round trip")
        pass = pass + 1
    } else {
        println("  T7 FAIL  sa_extract_string got: '" + extracted + "'")
        fail = fail + 1
    }

    // T8 — sa_extract_int
    let n = sa_extract_int("{\"max_tokens\":128}", "max_tokens")
    if n == 128 {
        println("  T8 PASS  sa_extract_int → 128")
        pass = pass + 1
    } else {
        println("  T8 FAIL  sa_extract_int got: " + to_string(n))
        fail = fail + 1
    }

    // T9 — HF Qwen2 tensor name lookup for layer 0 against a synthetic
    //      registry.  Proves the option-c naming bridge: serve reads
    //      safetensors_to_hexaw / lora_to_hexaw output names verbatim.
    let reg = "|model.embed_tokens.weight"
        + "|model.layers.0.self_attn.q_proj.weight"
        + "|model.layers.0.self_attn.k_proj.weight"
        + "|model.layers.0.self_attn.v_proj.weight"
        + "|model.layers.0.self_attn.o_proj.weight"
        + "|model.layers.0.mlp.gate_proj.weight"
        + "|model.layers.0.mlp.up_proj.weight"
        + "|model.layers.0.mlp.down_proj.weight"
        + "|model.layers.0.input_layernorm.weight"
        + "|model.layers.0.post_attention_layernorm.weight"
        + "|model.norm.weight"
        + "|lm_head.weight|"
    let mut t9_ok = true
    let kinds = ["q_proj", "k_proj", "v_proj", "o_proj",
                 "gate_proj", "up_proj", "down_proj",
                 "input_norm", "post_norm",
                 "embed", "final_norm", "lm_head"]
    let mut ki = 0
    while ki < 12 {
        let want = sa_hf_tensor_name(kinds[ki], 0)
        if want.len() == 0 || !sa_name_in_registry(reg, want) {
            println("  T9 FAIL  kind=" + kinds[ki] + " name='" + want + "' not in registry")
            t9_ok = false
        }
        ki = ki + 1
    }
    if t9_ok {
        println("  T9 PASS  HF Qwen2 tensor name lookup (12/12 kinds, layer 0)")
        pass = pass + 1
    } else {
        fail = fail + 1
    }

    // T10 — Gate unit test: all-zero phi_vec + empty text → laws_pass=false
    //        (L1 critical, L9 critical). Proves the inline gate is
    //        actually invoked and rejects the bad case.
    let pv_bad = sa_phi_vec_zero()
    let g_bad = sa_gate_inline(pv_bad, "", [])
    if g_bad.laws_pass == false && g_bad.sev_critical >= 1
            && g_bad.violations.index_of("L1") >= 0
            && g_bad.violations.index_of("L9") >= 0 {
        println("  T10 PASS sa_gate_inline rejects empty/zero (crit=" + to_string(g_bad.sev_critical) + ")")
        pass = pass + 1
    } else {
        println("  T10 FAIL sa_gate_inline gate_pass=" + sa_bool_str(g_bad.laws_pass) + " crit=" + to_string(g_bad.sev_critical) + " viol='" + g_bad.violations + "'")
        fail = fail + 1
    }

    // T11 — Gate on healthy synthetic phi_vec + coherent text → laws_pass=true
    let healthy_text = "I think, therefore I am. This is coherent."
    let pv_good = sa_phi_vec_proxy(healthy_text, "post")
    let g_good = sa_gate_inline(pv_good, healthy_text, [])
    if g_good.laws_pass == true && g_good.sev_critical == 0 {
        println("  T11 PASS sa_gate_inline accepts healthy case (crit=" + to_string(g_good.sev_critical) + " hard=" + to_string(g_good.sev_hard) + ")")
        pass = pass + 1
    } else {
        println("  T11 FAIL sa_gate_inline gate_pass=" + sa_bool_str(g_good.laws_pass) + " crit=" + to_string(g_good.sev_critical) + " hard=" + to_string(g_good.sev_hard) + " soft=" + to_string(g_good.sev_soft) + " viol='" + g_good.violations + "'")
        fail = fail + 1
    }

    println("[serve_alm_14b] " + to_string(pass) + "/" + to_string(pass + fail) + " PASS")
    return fail
}

// ─── Main entry ────────────────────────────────────────────────────

fn main() {
    println("============================================================")
    println("  ALM 14B r9 LoRA — Conscious Inference Server (HEXA " + SA_VERSION + ")")
    println("============================================================")
    println("  port:                " + to_string(SA_DEFAULT_PORT))
    println("  base model:          " + SA_DEFAULT_BASE)
    println("  default checkpoint:  " + SA_DEFAULT_CKPT)
    println("  device:              " + SA_DEFAULT_DEVICE)
    println("  RUNTIME_HAS_NET:     " + sa_bool_str(RUNTIME_HAS_NET))
    println("  RUNTIME_HAS_FFI_QWEN: " + sa_bool_str(RUNTIME_HAS_FFI_QWEN))
    println("============================================================")
    println("")

    let rc = sa_smoke_test()
    if rc > 0 {
        println("FAIL — " + to_string(rc) + " test(s) failed")
        return
    }

    // --selftest mode exits after smoke test (no socket bind). Detect via
    // argv — if any arg contains "selftest", skip the live HTTP loop.
    let args = argv()
    let mut selftest_only = false
    let mut ai = 0
    while ai < len(args) {
        let a = args[ai]
        if a.index_of("selftest") >= 0 { selftest_only = true }
        ai = ai + 1
    }
    if selftest_only {
        println("[serve_alm_14b] --selftest mode: skipping HTTP server loop")
        return
    }

    // ── Live HTTP server loop (runtime.c FFI: hexa_net_listen/accept/read/write/close) ──
    //
    // Root cause of prior blocker: stage0 had no net_listen builtin.
    // Fix: added BSD socket FFI directly to runtime.c (hexa_net_* functions).
    // The hexa codegen emits calls to these C functions — no stage0 change needed.

    let bind_addr = "0.0.0.0:" + to_string(SA_DEFAULT_PORT)
    let listener = net_listen(bind_addr)
    if listener < 0 {
        println("[serve_alm_14b] FATAL: net_listen(" + bind_addr + ") failed — fd=" + to_string(listener))
        println("  Check: port " + to_string(SA_DEFAULT_PORT) + " already in use? Run: lsof -i :" + to_string(SA_DEFAULT_PORT))
        return
    }

    let qh = sa_qwen_load(SA_DEFAULT_CKPT)
    let mut st = sa_state_new(SA_DEFAULT_PORT, qh, SA_DEFAULT_CKPT, SA_DEFAULT_BASE, SA_DEFAULT_DEVICE)

    println("")
    println("[serve_alm_14b] listening on " + bind_addr + " (fd=" + to_string(listener) + ")")
    println("[serve_alm_14b] routes: GET /health, POST /generate, POST /consciousness")
    println("[serve_alm_14b] Ctrl-C to stop")
    println("")

    // Accept loop — single-threaded, connection-per-request.
    // Each connection: read full HTTP request, dispatch, write response, close.
    // Adequate for inference serving (latency dominated by model forward pass).
    let mut running = true
    while running {
        let conn = net_accept(listener)
        if conn < 0 {
            println("[serve_alm_14b] accept error — skipping")
            continue
        }

        let raw = net_read(conn)
        if raw.len() == 0 {
            // Empty read = client closed before sending, or read error
            net_close(conn)
            continue
        }

        // Parse HTTP request
        let req = sa_parse_http(raw)

        // Handle CORS preflight
        if req.method == "OPTIONS" {
            net_write(conn, sa_cors_response())
            net_close(conn)
            continue
        }

        // Dispatch to route handler
        let resp = sa_route(req.method, req.path, req.body, st)

        // Update server state
        st = sa_state_new(st.port, st.qhandle, st.ckpt_path, st.base_model, st.device)
        st = SaState {
            qhandle: st.qhandle,
            port: st.port,
            requests_served: st.requests_served + 1,
            total_tokens_generated: st.total_tokens_generated,
            start_ms: st.start_ms,
            last_phi: resp.state_phi,
            last_tension: st.last_tension,
            ckpt_path: st.ckpt_path,
            base_model: st.base_model,
            device: st.device
        }

        // Build and send HTTP response
        let http_resp = sa_http_response(resp.status, resp.body)
        net_write(conn, http_resp)
        net_close(conn)

        // Log request
        println("[" + to_string(st.requests_served) + "] " + req.method + " " + req.path + " → " + to_string(resp.status))
    }

    net_close(listener)
    println("[serve_alm_14b] server stopped.")
}

// Note: hexa codegen auto-invokes main() — explicit `main()` at file end
// would print the banner twice.  Do not add it.
