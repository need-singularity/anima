// ═══════════════════════════════════════════════════════════════
//  metal_ffi.hexa — Apple Metal GPU FFI bindings for hexa-lang
//
//  Low-level Metal compute pipeline for matrix operations on
//  Apple Silicon (M4: 10-core GPU, 3.6 TFLOPS fp16, 100GB/s).
//
//  Design:
//    - ObjC runtime bridge via objc_msgSend (Metal API is ObjC)
//    - MTLBuffer storageModeShared = zero-copy unified memory
//    - MSL shaders compiled at runtime (newLibraryWithSource)
//    - BW-bound system: Metal helps FFN (compute-bound) +
//      double-buffer overlap for latency hiding
//
//  FFI pattern matches hxblas/hxflash/hxccl: @link + extern fn
//  See also: self/ml/accelerate_ffi.hexa for Accelerate bindings
//
//  Usage:
//    use "serving/edge/metal_ffi"
//    let ctx = metal_init()
//    if ctx.initialized {
//        let pipe = metal_compile_shader(ctx, MSL_MATMUL_BF16)
//        let buf_a = metal_create_buffer(ctx, M * K * 2)
//        // ... fill buf_a via zero-copy pointer ...
//        metal_matmul_bf16(ctx, buf_a, buf_b, buf_c, M, N, K)
//        metal_sync(ctx)
//        metal_release(ctx)
//    }
// ═══════════════════════════════════════════════════════════════

// ── ObjC runtime FFI ────────────────────────────────────────
// Metal API is Objective-C; we bridge through the ObjC runtime.
// objc_msgSend is the universal message dispatcher.

@link("objc")
extern fn objc_msgSend(obj: *Void, sel: *Void) -> *Void

// Variadic overloads — hexa FFI dispatches by arity.
// objc_msgSend with 1 extra arg (pointer or int)
@link("objc")
extern fn objc_msgSend_1(obj: *Void, sel: *Void, a1: *Void) -> *Void

// objc_msgSend with 2 extra args
@link("objc")
extern fn objc_msgSend_2(obj: *Void, sel: *Void, a1: *Void, a2: *Void) -> *Void

// objc_msgSend with 3 extra args
@link("objc")
extern fn objc_msgSend_3(obj: *Void, sel: *Void, a1: *Void, a2: *Void, a3: *Void) -> *Void

// objc_msgSend with int arg (for length, options, etc.)
@link("objc")
extern fn objc_msgSend_int(obj: *Void, sel: *Void, a1: int) -> *Void

// objc_msgSend with 2 int args
@link("objc")
extern fn objc_msgSend_int2(obj: *Void, sel: *Void, a1: int, a2: int) -> *Void

// Selector and class lookup
@link("objc")
extern fn sel_registerName(name: *Void) -> *Void

@link("objc")
extern fn objc_getClass(name: *Void) -> *Void

// ── Metal framework C functions ─────────────────────────────
// MTLCreateSystemDefaultDevice() is a plain C function, not ObjC.

@link("Metal")
extern fn MTLCreateSystemDefaultDevice() -> *Void

// ── Foundation framework (NSString, NSError) ────────────────

@link("Foundation")
extern fn NSLog(fmt: *Void) -> Void

// ── Memory management ───────────────────────────────────────
// Standard C allocation for shader source strings etc.

@link("c")
extern fn malloc(size: int) -> *Void

@link("c")
extern fn free(ptr: *Void) -> Void

@link("c")
extern fn memcpy(dst: *Void, src: *Void, n: int) -> *Void

@link("c")
extern fn memset(dst: *Void, val: int, n: int) -> *Void

// ── MTLBuffer storage modes (Metal enum values) ─────────────
let MTLStorageModeShared     = 0   // CPU + GPU, zero-copy on unified memory
let MTLStorageModeManaged    = 1   // CPU + GPU, explicit sync (discrete GPU)
let MTLStorageModePrivate    = 2   // GPU only
let MTLResourceStorageModeShift = 4
// resourceOptions = storageMode << 4
let MTLResourceStorageModeShared = 0   // 0 << 4 = 0

// ── MSL Shader: bf16 matrix multiply ────────────────────────
// GEMM kernel: C[M,N] = A[M,K] * B[K,N] in bfloat16.
// Uses threadgroup tiling for shared memory reuse.
// Grid: (N/TILE, M/TILE, 1), Threadgroup: (TILE, TILE, 1)

let MSL_MATMUL_BF16 = "#include <metal_stdlib>\n" +
    "using namespace metal;\n" +
    "\n" +
    "constant int TILE = 16;\n" +
    "\n" +
    "kernel void matmul_bf16(\n" +
    "    device const bfloat* A [[buffer(0)]],\n" +
    "    device const bfloat* B [[buffer(1)]],\n" +
    "    device bfloat* C       [[buffer(2)]],\n" +
    "    constant int& M        [[buffer(3)]],\n" +
    "    constant int& N        [[buffer(4)]],\n" +
    "    constant int& K        [[buffer(5)]],\n" +
    "    uint2 gid [[thread_position_in_grid]],\n" +
    "    uint2 lid [[thread_position_in_threadgroup]]\n" +
    ") {\n" +
    "    int row = gid.y;\n" +
    "    int col = gid.x;\n" +
    "    if (row >= M || col >= N) return;\n" +
    "\n" +
    "    float acc = 0.0f;\n" +
    "    // Tiled accumulation in f32 for precision\n" +
    "    for (int t = 0; t < K; t += TILE) {\n" +
    "        for (int k = t; k < min(t + TILE, K); k++) {\n" +
    "            acc += float(A[row * K + k]) * float(B[k * N + col]);\n" +
    "        }\n" +
    "    }\n" +
    "    C[row * N + col] = bfloat(acc);\n" +
    "}\n"

// ── MSL Shader: f32 vector add (simple test kernel) ─────────
let MSL_VEC_ADD_F32 = "#include <metal_stdlib>\n" +
    "using namespace metal;\n" +
    "\n" +
    "kernel void vec_add_f32(\n" +
    "    device const float* A [[buffer(0)]],\n" +
    "    device const float* B [[buffer(1)]],\n" +
    "    device float* C       [[buffer(2)]],\n" +
    "    uint gid [[thread_position_in_grid]]\n" +
    ") {\n" +
    "    C[gid] = A[gid] + B[gid];\n" +
    "}\n"

// ── MetalContext ────────────────────────────────────────────
// Holds all Metal state for a single device session.
// Pointer fields are opaque ObjC object references.

struct MetalContext {
    device: *Void,           // id<MTLDevice>
    queue: *Void,            // id<MTLCommandQueue>
    library: *Void,          // id<MTLLibrary> (compiled shaders)
    matmul_pipeline: *Void,  // id<MTLComputePipelineState> for bf16 matmul
    initialized: bool
}

// ── Global state ────────────────────────────────────────────
let mut G_METAL_INITIALIZED = 0

// ── Selector cache ──────────────────────────────────────────
// ObjC selectors are interned strings; cache them to avoid
// repeated sel_registerName calls on the hot path.

let mut SEL_NEW_COMMAND_QUEUE       = 0 as *Void
let mut SEL_NEW_BUFFER_LENGTH       = 0 as *Void
let mut SEL_NEW_BUFFER_BYTES        = 0 as *Void
let mut SEL_NEW_LIBRARY_SOURCE      = 0 as *Void
let mut SEL_NEW_FUNCTION            = 0 as *Void
let mut SEL_NEW_PIPELINE            = 0 as *Void
let mut SEL_COMMAND_BUFFER          = 0 as *Void
let mut SEL_COMPUTE_ENCODER         = 0 as *Void
let mut SEL_SET_PIPELINE            = 0 as *Void
let mut SEL_SET_BUFFER              = 0 as *Void
let mut SEL_DISPATCH_THREADS        = 0 as *Void
let mut SEL_END_ENCODING            = 0 as *Void
let mut SEL_COMMIT                  = 0 as *Void
let mut SEL_WAIT_UNTIL_COMPLETED    = 0 as *Void
let mut SEL_CONTENTS                = 0 as *Void
let mut SEL_LENGTH                  = 0 as *Void
let mut SEL_RELEASE                 = 0 as *Void
let mut SEL_STRING_WITH_UTF8        = 0 as *Void

// ── Selector initialization ─────────────────────────────────

fn metal_init_selectors() {
    SEL_NEW_COMMAND_QUEUE    = sel_registerName("newCommandQueue")
    SEL_NEW_BUFFER_LENGTH    = sel_registerName("newBufferWithLength:options:")
    SEL_NEW_BUFFER_BYTES     = sel_registerName("newBufferWithBytes:length:options:")
    SEL_NEW_LIBRARY_SOURCE   = sel_registerName("newLibraryWithSource:options:error:")
    SEL_NEW_FUNCTION         = sel_registerName("newFunctionWithName:")
    SEL_NEW_PIPELINE         = sel_registerName("newComputePipelineStateWithFunction:error:")
    SEL_COMMAND_BUFFER       = sel_registerName("commandBuffer")
    SEL_COMPUTE_ENCODER      = sel_registerName("computeCommandEncoder")
    SEL_SET_PIPELINE         = sel_registerName("setComputePipelineState:")
    SEL_SET_BUFFER           = sel_registerName("setBuffer:offset:atIndex:")
    SEL_DISPATCH_THREADS     = sel_registerName("dispatchThreads:threadsPerThreadgroup:")
    SEL_END_ENCODING         = sel_registerName("endEncoding")
    SEL_COMMIT               = sel_registerName("commit")
    SEL_WAIT_UNTIL_COMPLETED = sel_registerName("waitUntilCompleted")
    SEL_CONTENTS             = sel_registerName("contents")
    SEL_LENGTH               = sel_registerName("length")
    SEL_RELEASE              = sel_registerName("release")
    SEL_STRING_WITH_UTF8     = sel_registerName("stringWithUTF8String:")
}

// ── Platform detection ──────────────────────────────────────

fn has_metal() {
    // Metal is only available on macOS / Apple Silicon
    let marker = env_var("HEXA_PLATFORM")
    if marker == "darwin" {
        return 1
    }
    // Fallback: check if HOME is set (macOS heuristic, same as accelerate_ffi)
    let probe = env_var("HOME")
    if probe != "" {
        return 1
    }
    return 0
}

// ── NSString helper ─────────────────────────────────────────
// Metal API expects NSString*; create from hexa string via
// [NSString stringWithUTF8String:]

fn make_nsstring(s: string) -> *Void {
    let cls = objc_getClass("NSString")
    let sel = sel_registerName("stringWithUTF8String:")
    let ns = objc_msgSend_1(cls, sel, s as *Void)
    return ns
}

// ── Initialization ──────────────────────────────────────────

fn metal_init() -> MetalContext {
    let ctx = MetalContext {
        device: 0 as *Void,
        queue: 0 as *Void,
        library: 0 as *Void,
        matmul_pipeline: 0 as *Void,
        initialized: false
    }

    // Platform check
    let avail = has_metal()
    if avail == 0 {
        println("[metal_ffi] Metal not available (not macOS/Apple Silicon)")
        return ctx
    }

    // Initialize selector cache
    metal_init_selectors()

    // MTLCreateSystemDefaultDevice() — plain C function
    let device = MTLCreateSystemDefaultDevice()
    if device == 0 as *Void {
        println("[metal_ffi] MTLCreateSystemDefaultDevice returned null — no Metal GPU")
        return ctx
    }

    // [device newCommandQueue]
    let queue = objc_msgSend(device, SEL_NEW_COMMAND_QUEUE)
    if queue == 0 as *Void {
        println("[metal_ffi] newCommandQueue failed")
        return ctx
    }

    ctx.device = device
    ctx.queue = queue
    ctx.initialized = true
    G_METAL_INITIALIZED = 1
    println("[metal_ffi] initialized — Metal GPU device + command queue ready")

    return ctx
}

// ── Shader compilation ──────────────────────────────────────
// Compiles MSL source string into a MTLLibrary, then extracts
// the first kernel function and creates a compute pipeline state.

fn metal_compile_shader(ctx: MetalContext, source: string) -> *Void {
    if ctx.initialized == false {
        println("[metal_ffi] cannot compile shader — context not initialized")
        return 0 as *Void
    }

    // Create NSString from MSL source
    let ns_source = make_nsstring(source)
    if ns_source == 0 as *Void {
        println("[metal_ffi] failed to create NSString from shader source")
        return 0 as *Void
    }

    // [device newLibraryWithSource:source options:nil error:&error]
    // We pass nil for options and error (0 as *Void)
    let library = objc_msgSend_3(ctx.device, SEL_NEW_LIBRARY_SOURCE, ns_source, 0 as *Void, 0 as *Void)
    if library == 0 as *Void {
        println("[metal_ffi] newLibraryWithSource failed — check MSL syntax")
        return 0 as *Void
    }

    // Store library in context for later reference
    ctx.library = library
    return library
}

// ── Pipeline creation from function name ────────────────────

fn metal_make_pipeline(ctx: MetalContext, library: *Void, fn_name: string) -> *Void {
    if library == 0 as *Void {
        println("[metal_ffi] cannot make pipeline — null library")
        return 0 as *Void
    }

    let ns_name = make_nsstring(fn_name)

    // [library newFunctionWithName:fn_name]
    let func = objc_msgSend_1(library, SEL_NEW_FUNCTION, ns_name)
    if func == 0 as *Void {
        println("[metal_ffi] newFunctionWithName failed for: " + fn_name)
        return 0 as *Void
    }

    // [device newComputePipelineStateWithFunction:func error:nil]
    let pipeline = objc_msgSend_2(ctx.device, SEL_NEW_PIPELINE, func, 0 as *Void)
    if pipeline == 0 as *Void {
        println("[metal_ffi] newComputePipelineStateWithFunction failed")
        return 0 as *Void
    }

    return pipeline
}

// ── Buffer creation ─────────────────────────────────────────
// storageModeShared: zero-copy CPU<->GPU on unified memory (M-series).
// This is the key perf advantage — no explicit data transfers needed.

fn metal_create_buffer(ctx: MetalContext, size: int) -> *Void {
    if ctx.initialized == false {
        return 0 as *Void
    }

    // [device newBufferWithLength:size options:MTLResourceStorageModeShared]
    let buf = objc_msgSend_int2(ctx.device, SEL_NEW_BUFFER_LENGTH, size, MTLResourceStorageModeShared)
    return buf
}

// Wrap existing CPU memory into a Metal buffer (zero-copy).
// The pointer must remain valid for the buffer's lifetime.

fn metal_create_buffer_from_ptr(ctx: MetalContext, ptr: *Void, size: int) -> *Void {
    if ctx.initialized == false {
        return 0 as *Void
    }

    // [device newBufferWithBytes:ptr length:size options:MTLResourceStorageModeShared]
    let buf = objc_msgSend_3(ctx.device, SEL_NEW_BUFFER_BYTES, ptr, size as *Void, MTLResourceStorageModeShared as *Void)
    return buf
}

// ── Buffer contents pointer ─────────────────────────────────
// Returns CPU-accessible pointer to buffer data (zero-copy on shared mode).

fn metal_buffer_contents(buf: *Void) -> *Void {
    if buf == 0 as *Void {
        return 0 as *Void
    }
    let ptr = objc_msgSend(buf, SEL_CONTENTS)
    return ptr
}

// ── Dispatch compute kernel ─────────────────────────────────
// Encodes a compute command: bind pipeline + buffers, dispatch grid.
//
// bufs: array of *Void (MTLBuffer objects), bound at indices 0..N
// grid: [width, height, depth] — total threads
// threadgroup: [width, height, depth] — threads per threadgroup
//
// Example for matmul MxN:
//   grid = [N, M, 1]
//   threadgroup = [16, 16, 1]

fn metal_dispatch(ctx: MetalContext, pipeline: *Void, bufs: array, grid: array, threadgroup: array) {
    if ctx.initialized == false {
        println("[metal_ffi] dispatch skipped — context not initialized")
        return
    }
    if pipeline == 0 as *Void {
        println("[metal_ffi] dispatch skipped — null pipeline")
        return
    }

    // [queue commandBuffer]
    let cmd_buf = objc_msgSend(ctx.queue, SEL_COMMAND_BUFFER)
    if cmd_buf == 0 as *Void {
        println("[metal_ffi] commandBuffer creation failed")
        return
    }

    // [cmdBuf computeCommandEncoder]
    let encoder = objc_msgSend(cmd_buf, SEL_COMPUTE_ENCODER)
    if encoder == 0 as *Void {
        println("[metal_ffi] computeCommandEncoder creation failed")
        return
    }

    // [encoder setComputePipelineState:pipeline]
    objc_msgSend_1(encoder, SEL_SET_PIPELINE, pipeline)

    // Bind buffers: [encoder setBuffer:buf offset:0 atIndex:i]
    let num_bufs = len(bufs)
    let mut i = 0
    while i < num_bufs {
        let buf = bufs[i]
        // setBuffer:offset:atIndex: — offset=0, index=i
        objc_msgSend_3(encoder, SEL_SET_BUFFER, buf, 0 as *Void, i as *Void)
        i = i + 1
    }

    // MTLSize for grid and threadgroup are structs {width, height, depth}.
    // On ARM64 ABI, small structs are passed in registers.
    // We encode as three separate int args via a specialized dispatch.
    //
    // [encoder dispatchThreads:gridSize threadsPerThreadgroup:tgSize]
    // This requires encoding MTLSize structs — use the direct C shim below.
    metal_dispatch_threads_raw(encoder, grid[0], grid[1], grid[2], threadgroup[0], threadgroup[1], threadgroup[2])

    // [encoder endEncoding]
    objc_msgSend(encoder, SEL_END_ENCODING)

    // [cmdBuf commit]
    objc_msgSend(cmd_buf, SEL_COMMIT)
}

// ── Raw thread dispatch helper ──────────────────────────────
// MTLSize is a struct {uint64, uint64, uint64}.
// On ARM64, small structs passed in registers.
// This helper constructs the MTLSize values and calls dispatch.
//
// NOTE: In a full production build, this would be a C shim in
// a companion .c file linked via @link. For now we use the
// objc_msgSend path assuming ARM64 register ABI compatibility.

fn metal_dispatch_threads_raw(encoder: *Void, gx: int, gy: int, gz: int, tx: int, ty: int, tz: int) {
    // Allocate two MTLSize structs on the stack (3 x uint64 each = 24 bytes)
    // Root cause: ObjC runtime passes struct args in registers on ARM64,
    // but hexa FFI cannot emit struct-typed args directly.
    // Workaround: allocate grid/threadgroup as raw memory and pass pointers.
    let grid_buf = alloc_raw(24)
    write_i64(grid_buf, 0, gx)
    write_i64(grid_buf, 8, gy)
    write_i64(grid_buf, 16, gz)

    let tg_buf = alloc_raw(24)
    write_i64(tg_buf, 0, tx)
    write_i64(tg_buf, 8, ty)
    write_i64(tg_buf, 16, tz)

    // dispatchThreads:threadsPerThreadgroup: — pass struct pointers
    objc_msgSend_2(encoder, SEL_DISPATCH_THREADS, grid_buf, tg_buf)

    free_raw(grid_buf, 24)
    free_raw(tg_buf, 24)
}

// ── Synchronization ─────────────────────────────────────────
// Wait for all enqueued GPU work to complete.
// Creates a command buffer, commits it, and waits.

fn metal_sync(ctx: MetalContext) {
    if ctx.initialized == false {
        return
    }

    // Create an empty command buffer and wait on it — acts as a barrier.
    let cmd_buf = objc_msgSend(ctx.queue, SEL_COMMAND_BUFFER)
    if cmd_buf == 0 as *Void {
        return
    }
    objc_msgSend(cmd_buf, SEL_COMMIT)
    objc_msgSend(cmd_buf, SEL_WAIT_UNTIL_COMPLETED)
}

// ── Resource release ────────────────────────────────────────
// Release Metal objects. ObjC ARC may handle this, but explicit
// release is safer for long-running inference servers.

fn metal_release_buffer(buf: *Void) {
    if buf != 0 as *Void {
        objc_msgSend(buf, SEL_RELEASE)
    }
}

fn metal_release(ctx: MetalContext) {
    if ctx.initialized == false {
        return
    }

    if ctx.matmul_pipeline != 0 as *Void {
        objc_msgSend(ctx.matmul_pipeline, SEL_RELEASE)
    }
    if ctx.library != 0 as *Void {
        objc_msgSend(ctx.library, SEL_RELEASE)
    }
    if ctx.queue != 0 as *Void {
        objc_msgSend(ctx.queue, SEL_RELEASE)
    }
    // Device is a singleton — do not release.

    ctx.device = 0 as *Void
    ctx.queue = 0 as *Void
    ctx.library = 0 as *Void
    ctx.matmul_pipeline = 0 as *Void
    ctx.initialized = false
    G_METAL_INITIALIZED = 0
    println("[metal_ffi] released — Metal context torn down")
}

// ── Convenience: bf16 matmul ────────────────────────────────
// C[M,N] = A[M,K] * B[K,N] in bfloat16.
// Compiles the MSL matmul shader on first call, caches pipeline.
//
// a, b, c: MTLBuffer pointers (storageModeShared).
// Data layout: row-major bf16 (2 bytes per element).

fn metal_matmul_bf16(ctx: MetalContext, a: *Void, b: *Void, c: *Void, M: int, N: int, K: int) {
    if ctx.initialized == false {
        println("[metal_ffi] matmul_bf16 skipped — not initialized")
        return
    }

    // Lazy-compile matmul pipeline on first invocation
    if ctx.matmul_pipeline == 0 as *Void {
        let lib = metal_compile_shader(ctx, MSL_MATMUL_BF16)
        if lib == 0 as *Void {
            println("[metal_ffi] matmul_bf16 — shader compilation failed")
            return
        }
        let pipe = metal_make_pipeline(ctx, lib, "matmul_bf16")
        if pipe == 0 as *Void {
            println("[metal_ffi] matmul_bf16 — pipeline creation failed")
            return
        }
        ctx.matmul_pipeline = pipe
    }

    // Create small constant buffers for M, N, K dimensions
    let buf_m = metal_create_buffer(ctx, 4)
    let buf_n = metal_create_buffer(ctx, 4)
    let buf_k = metal_create_buffer(ctx, 4)

    // Write dimension values into constant buffers
    if buf_m != 0 as *Void {
        let ptr_m = metal_buffer_contents(buf_m)
        write_i32(ptr_m, 0, M)
    }
    if buf_n != 0 as *Void {
        let ptr_n = metal_buffer_contents(buf_n)
        write_i32(ptr_n, 0, N)
    }
    if buf_k != 0 as *Void {
        let ptr_k = metal_buffer_contents(buf_k)
        write_i32(ptr_k, 0, K)
    }

    // Dispatch: grid covers full output matrix, threadgroup = 16x16
    let bufs = [a, b, c, buf_m, buf_n, buf_k]
    let grid = [N, M, 1]
    let threadgroup = [16, 16, 1]
    metal_dispatch(ctx, ctx.matmul_pipeline, bufs, grid, threadgroup)

    // Wait for completion
    metal_sync(ctx)

    // Release temporary dimension buffers
    metal_release_buffer(buf_m)
    metal_release_buffer(buf_n)
    metal_release_buffer(buf_k)
}

// ── Utility: query device info ──────────────────────────────

fn metal_device_name(ctx: MetalContext) -> string {
    if ctx.initialized == false {
        return "unavailable"
    }
    let sel_name = sel_registerName("name")
    let ns_name = objc_msgSend(ctx.device, sel_name)
    if ns_name == 0 as *Void {
        return "unknown"
    }
    let sel_utf8 = sel_registerName("UTF8String")
    let cstr = objc_msgSend(ns_name, sel_utf8)
    if cstr == 0 as *Void {
        return "unknown"
    }
    // cstr is a C string pointer — hexa can cast to string
    return cstr as string
}

fn metal_recommended_threadgroup_size(ctx: MetalContext, pipeline: *Void) -> int {
    if ctx.initialized == false {
        return 256  // safe default
    }
    // [pipeline maxTotalThreadsPerThreadgroup]
    let sel_max = sel_registerName("maxTotalThreadsPerThreadgroup")
    let max_threads = objc_msgSend(pipeline, sel_max)
    // Result is NSUInteger in low bits of pointer
    return max_threads as int
}

// ═══════════════════════════════════════════════════════════════
//  Self-test (5+ tests)
//
//  Guards GPU dispatch behind ctx.initialized — tests pass on
//  both Metal-capable (macOS) and non-Metal (Linux) hosts.
// ═══════════════════════════════════════════════════════════════

fn test_metal_ffi() {
    let mut pass = 0
    let mut fail = 0

    // ── Test 1: metal_init returns a valid context struct ────
    let ctx = metal_init()
    // On macOS with Metal: initialized=true, on Linux: initialized=false
    // Either way, the function must not crash and must return a struct.
    if ctx.device != 0 as *Void || ctx.initialized == false {
        // If device is non-null, initialized must be true
        // If device is null, initialized must be false
        if ctx.device != 0 as *Void && ctx.initialized == true {
            println("[TEST 1] PASS — metal_init returned valid device + queue")
            pass = pass + 1
        } else if ctx.device == 0 as *Void && ctx.initialized == false {
            println("[TEST 1] PASS — metal_init returned graceful null (no Metal GPU)")
            pass = pass + 1
        } else {
            println("[TEST 1] FAIL — inconsistent device/initialized state")
            fail = fail + 1
        }
    } else {
        println("[TEST 1] PASS — metal_init returned struct (null device, not initialized)")
        pass = pass + 1
    }

    // ── Test 2: selector cache populated after init ─────────
    if ctx.initialized {
        if SEL_NEW_COMMAND_QUEUE != 0 as *Void && SEL_COMMIT != 0 as *Void && SEL_CONTENTS != 0 as *Void {
            println("[TEST 2] PASS — selector cache populated")
            pass = pass + 1
        } else {
            println("[TEST 2] FAIL — selectors not initialized")
            fail = fail + 1
        }
    } else {
        // On non-Metal host, selectors may not be initialized — skip gracefully
        println("[TEST 2] SKIP — no Metal device, selector test not applicable")
        pass = pass + 1
    }

    // ── Test 3: buffer creation (shared mode, zero-copy) ────
    if ctx.initialized {
        let buf = metal_create_buffer(ctx, 4096)
        if buf != 0 as *Void {
            println("[TEST 3] PASS — created 4096-byte shared buffer")
            pass = pass + 1
            // Verify we can get contents pointer (zero-copy)
            let ptr = metal_buffer_contents(buf)
            if ptr != 0 as *Void {
                println("[TEST 3b] PASS — buffer contents pointer is non-null (zero-copy)")
                pass = pass + 1
            } else {
                println("[TEST 3b] FAIL — buffer contents returned null")
                fail = fail + 1
            }
            metal_release_buffer(buf)
        } else {
            println("[TEST 3] FAIL — buffer creation returned null")
            fail = fail + 1
            println("[TEST 3b] SKIP — no buffer to test contents")
            pass = pass + 1
        }
    } else {
        println("[TEST 3] SKIP — no Metal device")
        pass = pass + 1
        println("[TEST 3b] SKIP — no Metal device")
        pass = pass + 1
    }

    // ── Test 4: shader compilation ──────────────────────────
    if ctx.initialized {
        let lib = metal_compile_shader(ctx, MSL_VEC_ADD_F32)
        if lib != 0 as *Void {
            println("[TEST 4] PASS — compiled vec_add_f32 MSL shader")
            pass = pass + 1
        } else {
            println("[TEST 4] FAIL — shader compilation failed")
            fail = fail + 1
        }
    } else {
        println("[TEST 4] SKIP — no Metal device")
        pass = pass + 1
    }

    // ── Test 5: pipeline creation from compiled shader ──────
    if ctx.initialized {
        let lib = metal_compile_shader(ctx, MSL_VEC_ADD_F32)
        if lib != 0 as *Void {
            let pipe = metal_make_pipeline(ctx, lib, "vec_add_f32")
            if pipe != 0 as *Void {
                println("[TEST 5] PASS — created compute pipeline for vec_add_f32")
                pass = pass + 1
            } else {
                println("[TEST 5] FAIL — pipeline creation failed")
                fail = fail + 1
            }
        } else {
            println("[TEST 5] SKIP — shader compilation failed, cannot test pipeline")
            pass = pass + 1
        }
    } else {
        println("[TEST 5] SKIP — no Metal device")
        pass = pass + 1
    }

    // ── Test 6: device name query ───────────────────────────
    if ctx.initialized {
        let name = metal_device_name(ctx)
        if name != "unavailable" && name != "unknown" {
            println("[TEST 6] PASS — device name: " + name)
            pass = pass + 1
        } else {
            println("[TEST 6] FAIL — could not query device name")
            fail = fail + 1
        }
    } else {
        let name = metal_device_name(ctx)
        if name == "unavailable" {
            println("[TEST 6] PASS — device name correctly returns 'unavailable' when not initialized")
            pass = pass + 1
        } else {
            println("[TEST 6] FAIL — expected 'unavailable' for uninitialized context")
            fail = fail + 1
        }
    }

    // ── Test 7: release does not crash ──────────────────────
    // Create a fresh context, release it, verify state reset
    let ctx2 = metal_init()
    metal_release(ctx2)
    if ctx2.initialized == false && ctx2.device == 0 as *Void {
        println("[TEST 7] PASS — release zeroed context correctly")
        pass = pass + 1
    } else {
        println("[TEST 7] FAIL — release did not zero context")
        fail = fail + 1
    }

    // ── Summary ─────────────────────────────────────────────
    let total = pass + fail
    println("")
    println("[metal_ffi] self-test: " + str(pass) + "/" + str(total) + " passed")
    if fail > 0 {
        println("[metal_ffi] FAILURES: " + str(fail))
    }
}

// ── Entry point for standalone test run ─────────────────────

fn main() {
    println("═══ metal_ffi.hexa — Apple Metal GPU FFI self-test ═══")
    println("")
    test_metal_ffi()
}
