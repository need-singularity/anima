// ═══════════════════════════════════════════════════════════════
//  serving/eval_serve.hexa — stdio-based inference CLI
//
//  P5c-1: a serving endpoint as a long-lived process that reads
//  generation requests from stdin and writes responses to stdout.
//
//  Protocol (line-oriented, easy to bridge to HTTP via socat/nc):
//
//    Request:  GEN <max_tokens> <start_token>\n
//    Response: <space-separated token ids>\n
//
//    Request:  HEALTH\n
//    Response: OK\n
//
//    Request:  QUIT\n
//    Response: BYE\n   (then exit)
//
//  Loads a checkpoint at startup (path from CLI arg or default).
//  Runs greedy decode using the loaded W_lm matrix as a single-layer
//  language model. Real multi-layer inference replaces this once
//  train_gpu_pure.hexa produces production checkpoints.
//
//  Bridge to HTTP (one-liner):
//    socat TCP-LISTEN:8080,fork,reuseaddr EXEC:'./hexa serving/eval_serve.hexa'
//
//  Then:
//    curl -X POST http://localhost:8080 -d 'GEN 16 5' → space-separated tokens
//    curl http://localhost:8080 -d 'HEALTH'           → OK
// ═══════════════════════════════════════════════════════════════

let MAGIC = "HEXACKPT-v1"

// ── Inlined checkpoint loader (copied from checkpoint_hexa.hexa) ──
fn make_tensor(name, rows, cols, data) {
    let mut t = []
    t = t.push(name)
    t = t.push(rows)
    t = t.push(cols)
    t = t.push(data)
    return t
}

fn make_decode_result(tensors, total, n_t) {
    let mut r = []
    r = r.push(tensors)
    r = r.push(total)
    r = r.push(n_t)
    return r
}

fn split_ws(s) {
    let n = len(s)
    let mut parts = []
    let mut cur = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            if cur != "" {
                parts = parts.push(cur)
                cur = ""
            }
        } else {
            cur = cur + ch
        }
        i = i + 1
    }
    if cur != "" { parts = parts.push(cur) }
    return parts
}

fn split_lines_local(text) {
    let n = len(text)
    let mut lines = []
    let mut start = 0
    let mut i = 0
    while i < n {
        if text.substring(i, i + 1) == "\n" {
            lines = lines.push(text.substring(start, i))
            start = i + 1
        }
        i = i + 1
    }
    if start < n {
        lines = lines.push(text.substring(start, n))
    }
    return lines
}

fn decode_checkpoint(text) {
    let n = len(text)
    if n < 11 { return make_decode_result([], 0, 0) }
    let magic = text.substring(0, 11)
    if magic != MAGIC { return make_decode_result([], 0, 0) }

    // Skip past "HEXACKPT-v1\n"
    let body = text.substring(12, n)
    let lines = split_lines_local(body)
    let nl = len(lines)

    let mut tensors = []
    let mut total = 0
    let mut declared = 0
    let mut li = 0
    while li < nl {
        let header = lines[li]
        if header == "" {
            li = li + 1
        } else if len(header) >= 12 && header.substring(0, 12) == "__MANIFEST__" {
            let parts = split_ws(header)
            if len(parts) >= 3 {
                total = to_int(parts[1])
                declared = to_int(parts[2])
            }
            li = li + 1
        } else {
            let parts = split_ws(header)
            if len(parts) < 3 {
                li = li + 1
            } else {
                let name = parts[0]
                let rows = to_int(parts[1])
                let cols = to_int(parts[2])
                let numel = rows * cols
                li = li + 1
                if li < nl {
                    let data_line = lines[li]
                    let data_parts = split_ws(data_line)
                    let mut data = []
                    let mut di = 0
                    while di < numel && di < len(data_parts) {
                        data = data.push(to_float(data_parts[di]))
                        di = di + 1
                    }
                    let entry = make_tensor(name, rows, cols, data)
                    tensors = tensors.push(entry)
                }
                li = li + 1
            }
        }
    }
    return make_decode_result(tensors, total, declared)
}

// ── Loaded model state (single linear LM head: vocab × vocab) ──
let mut W_DATA = []
let mut W_ROWS = 0
let mut W_COLS = 0

fn install(tensors) {
    let n = len(tensors)
    let mut i = 0
    while i < n {
        let t = tensors[i]
        if t[0] == "W_lm" {
            W_ROWS = t[1]
            W_COLS = t[2]
            W_DATA = t[3]
        }
        i = i + 1
    }
}

fn forward_logits(token) {
    let mut logits = []
    let row_start = token * W_COLS
    let mut j = 0
    while j < W_COLS {
        logits = logits.push(W_DATA[row_start + j])
        j = j + 1
    }
    return logits
}

fn argmax(logits) {
    let n = len(logits)
    let mut best_i = 0
    let mut best_v = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > best_v {
            best_v = logits[i]
            best_i = i
        }
        i = i + 1
    }
    return best_i
}

fn greedy_gen(start, max_tokens) {
    let mut out = []
    let mut prev = start
    out = out.push(prev)
    let mut i = 0
    while i < max_tokens - 1 {
        let logits = forward_logits(prev)
        let next_tok = argmax(logits)
        out = out.push(next_tok)
        prev = next_tok
        i = i + 1
    }
    return out
}

fn tokens_to_string(toks) {
    let n = len(toks)
    let mut s = ""
    let mut i = 0
    while i < n {
        if i > 0 { s = s + " " }
        s = s + str(toks[i])
        i = i + 1
    }
    return s
}

// ── Build a tiny default model for first-run sanity ──
// Same shift-by-1 pattern as eval_pipeline.hexa: W[i, (i+1)%32] = 5.0
fn build_default_model() {
    let vocab = 32
    let mut data = []
    let mut i = 0
    while i < vocab {
        let mut j = 0
        while j < vocab {
            let target_j = (i + 1) % vocab
            let v = if j == target_j { 5.0 } else { -0.5 }
            data = data.push(v)
            j = j + 1
        }
        i = i + 1
    }
    W_DATA = data
    W_ROWS = vocab
    W_COLS = vocab
}

// ── Process one request line; return response string (or "" to exit) ──
fn handle_line(line) {
    let parts = split_ws(line)
    let n = len(parts)
    if n == 0 { return "ERR empty\n" }
    let cmd = parts[0]

    if cmd == "HEALTH" {
        return "OK\n"
    }

    if cmd == "QUIT" || cmd == "EXIT" {
        return ""
    }

    if cmd == "GEN" {
        if n < 3 { return "ERR usage: GEN <max_tokens> <start_token>\n" }
        let max_tokens = to_int(parts[1])
        let start_tok = to_int(parts[2])
        if W_DATA == [] || W_COLS == 0 {
            return "ERR no model loaded\n"
        }
        if start_tok < 0 || start_tok >= W_COLS {
            return "ERR start_token out of range\n"
        }
        let toks = greedy_gen(start_tok, max_tokens)
        return tokens_to_string(toks) + "\n"
    }

    if cmd == "INFO" {
        return "MODEL vocab=" + str(W_COLS) + " rows=" + str(W_ROWS) + "\n"
    }

    return "ERR unknown command: " + cmd + "\n"
}

fn main() {
    // Optional CLI arg: checkpoint path
    let _argv = args()
    let mut ckpt_path = ""
    if len(_argv) >= 3 {
        ckpt_path = _argv[2]
    }

    if ckpt_path != "" && file_exists(ckpt_path) {
        let text = read_file(ckpt_path)
        let result = decode_checkpoint(text)
        let tensors = result[0]
        install(tensors)
        println("[eval_serve] loaded ", len(tensors), " tensors from ", ckpt_path, " (vocab=", W_COLS, ")")
    } else {
        build_default_model()
        println("[eval_serve] no checkpoint — using default shift-by-1 model (vocab=", W_COLS, ")")
    }

    println("[eval_serve] ready — protocol: GEN <max> <start> | HEALTH | INFO | QUIT")

    // stdin loop
    let stdin = read_stdin()
    let lines = split_lines_local(stdin)
    let n_lines = len(lines)
    let mut i = 0
    while i < n_lines {
        let line = lines[i]
        if line != "" {
            let resp = handle_line(line)
            if resp == "" {
                println("BYE")
                return
            }
            // Strip trailing newline so println doesn't double it
            let rl = len(resp)
            if rl > 0 && resp.substring(rl - 1, rl) == "\n" {
                println(resp.substring(0, rl - 1))
            } else {
                println(resp)
            }
        }
        i = i + 1
    }
}

let _ = main()
