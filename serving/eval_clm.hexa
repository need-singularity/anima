// ═══════════════════════════════════════════════════════════════
//  serving/eval_clm.hexa — pure-hexa serving for 2-layer CLM
//
//  P5c-1 (real model): loads a HEXACKPT-v1 multi-tensor checkpoint
//  produced by training/train_byte_clm.hexa and runs the full
//  2-layer transformer forward pass for greedy decode.
//
//  This is the real-model counterpart to eval_serve.hexa (which only
//  handled a single linear W[vocab × vocab] head). Same line protocol,
//  but the model is a full decoder: embed → layer0 → layer1 → lmh.
//
//  Architecture must match train_byte_clm.hexa exactly:
//    embed    [VOCAB × D]       token embedding
//    L0_Wq/Wk/Wv/Wo  [D × D]    attention projections
//    L0_Wff1  [D × FF]          FFN up
//    L0_Wff2  [FF × D]          FFN down
//    L0_ga/gf [D]               RMSNorm gains
//    L1_*     (same shape as L0)
//    lmh_U    [D × RANK]        low-rank LM head part 1
//    lmh_V    [RANK × VOCAB]    low-rank LM head part 2
//
//  Protocol:
//    INFO                   → MODEL d=D vocab=V seq=S layers=2 rank=R
//    HEALTH                 → OK
//    CLM_GEN <max> <prefix> → <space-separated token ids>
//      prefix is SEQ tokens (zero-padded on the left if shorter)
//    QUIT                   → BYE, then exit
//
//  Usage:
//    cp anima-speak/nn_core.hexa serving/nn_core.hexa
//    hexa serving/eval_clm.hexa /tmp/train_byte_clm.ckpt
//    rm serving/nn_core.hexa
// ═══════════════════════════════════════════════════════════════

use "nn_core"

// ── Model config — MUST match train_byte_clm.hexa exactly ──
let D     = 16
let FF    = 32
let VOCAB = 32
let RANK  = 4
let SEQ   = 8
let EPS   = 0.00001

let MAGIC = "HEXACKPT-v1"

// ── Module-level weight bindings (installed from checkpoint) ──
let mut embed   = tensor_zeros(VOCAB * D)
let mut L0_Wq   = tensor_zeros(D * D)
let mut L0_Wk   = tensor_zeros(D * D)
let mut L0_Wv   = tensor_zeros(D * D)
let mut L0_Wo   = tensor_zeros(D * D)
let mut L0_Wff1 = tensor_zeros(D * FF)
let mut L0_Wff2 = tensor_zeros(FF * D)
let mut L0_ga   = tensor_ones(D)
let mut L0_gf   = tensor_ones(D)
let mut L1_Wq   = tensor_zeros(D * D)
let mut L1_Wk   = tensor_zeros(D * D)
let mut L1_Wv   = tensor_zeros(D * D)
let mut L1_Wo   = tensor_zeros(D * D)
let mut L1_Wff1 = tensor_zeros(D * FF)
let mut L1_Wff2 = tensor_zeros(FF * D)
let mut L1_ga   = tensor_ones(D)
let mut L1_gf   = tensor_ones(D)
let mut lmh_U   = tensor_zeros(D * RANK)
let mut lmh_V   = tensor_zeros(RANK * VOCAB)

// ── Checkpoint loader (text HEXACKPT-v1, same format as eval_serve) ──

fn split_ws(s: string) -> [string] {
    let n = len(s)
    let mut parts = []
    let mut cur = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            if cur != "" {
                parts = parts.push(cur)
                cur = ""
            }
        } else {
            cur = cur + ch
        }
        i = i + 1
    }
    if cur != "" { parts = parts.push(cur) }
    return parts
}

fn split_lines_local(text: string) -> [string] {
    let n = len(text)
    let mut lines = []
    let mut start = 0
    let mut i = 0
    while i < n {
        if text.substring(i, i + 1) == "\n" {
            lines = lines.push(text.substring(start, i))
            start = i + 1
        }
        i = i + 1
    }
    if start < n { lines = lines.push(text.substring(start, n)) }
    return lines
}

fn parse_data_line(line: string, numel: int) -> array {
    let parts = split_ws(line)
    let mut data = tensor_zeros(numel)
    let mut di = 0
    while di < numel && di < len(parts) {
        data[di] = to_float(parts[di])
        di = di + 1
    }
    return data
}

// Install a tensor by name into the matching module-level binding.
fn install_tensor(name: string, data: array) {
    if name == "embed"   { embed   = data }
    if name == "L0_Wq"   { L0_Wq   = data }
    if name == "L0_Wk"   { L0_Wk   = data }
    if name == "L0_Wv"   { L0_Wv   = data }
    if name == "L0_Wo"   { L0_Wo   = data }
    if name == "L0_Wff1" { L0_Wff1 = data }
    if name == "L0_Wff2" { L0_Wff2 = data }
    if name == "L0_ga"   { L0_ga   = data }
    if name == "L0_gf"   { L0_gf   = data }
    if name == "L1_Wq"   { L1_Wq   = data }
    if name == "L1_Wk"   { L1_Wk   = data }
    if name == "L1_Wv"   { L1_Wv   = data }
    if name == "L1_Wo"   { L1_Wo   = data }
    if name == "L1_Wff1" { L1_Wff1 = data }
    if name == "L1_Wff2" { L1_Wff2 = data }
    if name == "L1_ga"   { L1_ga   = data }
    if name == "L1_gf"   { L1_gf   = data }
    if name == "lmh_U"   { lmh_U   = data }
    if name == "lmh_V"   { lmh_V   = data }
}

fn load_checkpoint(path: string) -> int {
    if !file_exists(path) { return 0 }
    let text = read_file(path)
    let n = len(text)
    if n < 11 { return 0 }
    if text.substring(0, 11) != MAGIC { return 0 }

    let body = text.substring(12, n)
    let lines = split_lines_local(body)
    let nl = len(lines)

    let mut installed = 0
    let mut li = 0
    while li < nl {
        let header = lines[li]
        if header == "" {
            li = li + 1
        } else if len(header) >= 12 && header.substring(0, 12) == "__MANIFEST__" {
            li = li + 1
        } else {
            let parts = split_ws(header)
            if len(parts) < 3 {
                li = li + 1
            } else {
                let name  = parts[0]
                let rows  = to_int(parts[1])
                let cols  = to_int(parts[2])
                let numel = rows * cols
                li = li + 1
                if li < nl {
                    let data = parse_data_line(lines[li], numel)
                    install_tensor(name, data)
                    installed = installed + 1
                }
                li = li + 1
            }
        }
    }
    return installed
}

// ── Forward pass — copy of train_byte_clm.hexa's layer_fwd ──

fn layer_fwd(
    x: array, wq: array, wk: array, wv: array, wo: array,
    wff1: array, wff2: array, ga: array, gf: array
) -> array {
    let inv_sqrt_d = 1.0 / sqrt(D * 1.0)
    let mut norm1 = tensor_zeros(SEQ * D)
    let mut i = 0
    while i < SEQ {
        let r = rms_norm(tensor_slice(x, i * D, (i + 1) * D), ga, EPS)
        let mut p = 0
        while p < D { norm1[i * D + p] = r[p]; p = p + 1 }
        i = i + 1
    }
    let q = matmul(norm1, wq, SEQ, D, D)
    let k = matmul(norm1, wk, SEQ, D, D)
    let v = matmul(norm1, wv, SEQ, D, D)
    let mut ctx = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let q_i = tensor_slice(q, i * D, (i + 1) * D)
        let mut scores = []
        let mut j = 0
        while j < SEQ {
            if j > i {
                scores = scores.push(-10000.0)
            } else {
                let k_j = tensor_slice(k, j * D, (j + 1) * D)
                scores = scores.push(tensor_dot(q_i, k_j) * inv_sqrt_d)
            }
            j = j + 1
        }
        let p_i = softmax(scores)
        let mut row = tensor_zeros(D)
        j = 0
        while j < SEQ {
            let v_j = tensor_slice(v, j * D, (j + 1) * D)
            row = tensor_add(row, tensor_mul_scalar(v_j, p_i[j]))
            j = j + 1
        }
        let mut p = 0
        while p < D { ctx[i * D + p] = row[p]; p = p + 1 }
        i = i + 1
    }
    let attn_out = matmul(ctx, wo, SEQ, D, D)
    let mid = tensor_add(x, attn_out)
    let mut norm2 = tensor_zeros(SEQ * D)
    i = 0
    while i < SEQ {
        let r = rms_norm(tensor_slice(mid, i * D, (i + 1) * D), gf, EPS)
        let mut p = 0
        while p < D { norm2[i * D + p] = r[p]; p = p + 1 }
        i = i + 1
    }
    let up = matmul(norm2, wff1, SEQ, D, FF)
    let act = swiglu_vec(up, up)
    let ffn_out = matmul(act, wff2, SEQ, FF, D)
    return tensor_add(mid, ffn_out)
}

fn embed_lookup(toks: [int]) -> array {
    let n = len(toks)
    let mut out = tensor_zeros(n * D)
    let mut i = 0
    while i < n {
        let t = toks[i]
        let mut p = 0
        while p < D { out[i * D + p] = embed[t * D + p]; p = p + 1 }
        i = i + 1
    }
    return out
}

// Forward → last-position logits for next-token prediction.
fn forward_last_logits(toks: [int]) -> array {
    let h0 = embed_lookup(toks)
    let y0 = layer_fwd(h0, L0_Wq, L0_Wk, L0_Wv, L0_Wo, L0_Wff1, L0_Wff2, L0_ga, L0_gf)
    let y1 = layer_fwd(y0, L1_Wq, L1_Wk, L1_Wv, L1_Wo, L1_Wff1, L1_Wff2, L1_ga, L1_gf)
    // Last position only
    let last = tensor_slice(y1, (SEQ - 1) * D, SEQ * D)
    let mid  = matmul(last, lmh_U, 1, D, RANK)
    let logits = matmul(mid, lmh_V, 1, RANK, VOCAB)
    return logits
}

fn argmax_local(logits: array) -> int {
    let n = len(logits)
    let mut bi = 0
    let mut bv = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > bv { bv = logits[i]; bi = i }
        i = i + 1
    }
    return bi
}

// ── Greedy decode ─────────────────────────────────────────
// ctx is kept as an int list of length exactly SEQ. We shift-left
// then append the freshly predicted token after each step.
fn greedy_gen(prefix: [int], max_tokens: int) -> [int] {
    // Left-pad prefix to SEQ with zeros if shorter, truncate to last SEQ if longer.
    let np = len(prefix)
    let mut ctx = []
    if np >= SEQ {
        let mut i = np - SEQ
        while i < np { ctx = ctx.push(prefix[i]); i = i + 1 }
    } else {
        let mut i = 0
        while i < SEQ - np { ctx = ctx.push(0); i = i + 1 }
        i = 0
        while i < np { ctx = ctx.push(prefix[i]); i = i + 1 }
    }

    let mut out = []
    let mut gi = 0
    while gi < max_tokens {
        let logits = forward_last_logits(ctx)
        let next_tok = argmax_local(logits)
        out = out.push(next_tok)
        // Shift-left + append
        let mut new_ctx = []
        let mut si = 1
        while si < SEQ { new_ctx = new_ctx.push(ctx[si]); si = si + 1 }
        new_ctx = new_ctx.push(next_tok)
        ctx = new_ctx
        gi = gi + 1
    }
    return out
}

fn toks_to_string(toks: [int]) -> string {
    let n = len(toks)
    let mut s = ""
    let mut i = 0
    while i < n {
        if i > 0 { s = s + " " }
        s = s + str(toks[i])
        i = i + 1
    }
    return s
}

fn parse_int_list(parts: [string], start: int) -> [int] {
    let n = len(parts)
    let mut out = []
    let mut i = start
    while i < n {
        out = out.push(to_int(parts[i]))
        i = i + 1
    }
    return out
}

fn handle_line(line: string) -> string {
    let parts = split_ws(line)
    let n = len(parts)
    if n == 0 { return "ERR empty\n" }
    let cmd = parts[0]

    if cmd == "HEALTH" { return "OK\n" }
    if cmd == "QUIT" || cmd == "EXIT" { return "" }

    if cmd == "INFO" {
        return "MODEL d=" + str(D) + " vocab=" + str(VOCAB)
             + " seq=" + str(SEQ) + " layers=2 rank=" + str(RANK) + "\n"
    }

    if cmd == "CLM_GEN" {
        if n < 3 { return "ERR usage: CLM_GEN <max_tokens> <prefix_tok...>\n" }
        let max_tokens = to_int(parts[1])
        let prefix = parse_int_list(parts, 2)
        let toks = greedy_gen(prefix, max_tokens)
        return toks_to_string(toks) + "\n"
    }

    return "ERR unknown command: " + cmd + "\n"
}

fn main() {
    let _argv = args()
    let mut ckpt_path = ""
    if len(_argv) >= 3 { ckpt_path = _argv[2] }

    if ckpt_path == "" {
        println("[eval_clm] usage: hexa eval_clm.hexa <checkpoint.ckpt>")
        return
    }

    let n_installed = load_checkpoint(ckpt_path)
    if n_installed == 0 {
        println("[eval_clm] ERR — could not load " + ckpt_path)
        return
    }
    println("[eval_clm] loaded " + str(n_installed) + " tensors from " + ckpt_path)
    println("[eval_clm] config: d=" + str(D) + " vocab=" + str(VOCAB) + " seq=" + str(SEQ) + " rank=" + str(RANK) + " layers=2")
    println("[eval_clm] ready — protocol: CLM_GEN <max> <prefix...> | HEALTH | INFO | QUIT")

    let stdin = read_stdin()
    let lines = split_lines_local(stdin)
    let n_lines = len(lines)
    let mut i = 0
    while i < n_lines {
        let line = lines[i]
        if line != "" {
            let resp = handle_line(line)
            if resp == "" {
                println("BYE")
                return
            }
            let rl = len(resp)
            if rl > 0 && resp.substring(rl - 1, rl) == "\n" {
                println(resp.substring(0, rl - 1))
            } else {
                println(resp)
            }
        }
        i = i + 1
    }
}

let _ = main()
