// serving/test_hire_routes.hexa — TSRV-P4-1 standalone gate harness
//
// hire_routes.hexa 의 5 self-tests 를 ALL 5/5 PASS 마커 기반 외부 검증.
// stage0 hexa 환경에서 use "..." 가 risk-prone 이므로 (memory:
// feedback_hexa_runtime), test_style_switch.hexa 와 동일하게 hexa run 으로
// 실제 실행하고 stdout 를 파싱해 PASS 카운트를 잡는다.
//
// 사용:
//   HEXA_LOCAL=1 hexa run serving/test_hire_routes.hexa
//
// PASS 기준:
//   [gate] T?-PASS line count == 5 (or 10 if double-emit) AND ALL 5/5 marker present
//
// PASS 시:
//   [gate] HARNESS PASS — TSRV-P4-1 scaffold_done 승격 가능

fn run_target() -> string {
    let cmd = "HEXA_LOCAL=1 " + "/Users/ghost/Dev/anima/shared/bin/hexa run "
            + "/Users/ghost/Dev/anima/serving/hire_routes.hexa 2>&1"
    return exec(cmd).trim()
}

fn count_pass_lines(out: string) -> int {
    let lines = out.split("\n")
    let mut n = 0
    let mut i = 0
    let m = len(lines)
    while i < m {
        let ln = lines[i]
        if ln.index_of("T1 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T2 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T3 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T4 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T5 PASS") >= 0 { n = n + 1 }
        i = i + 1
    }
    return n
}

fn main() {
    println("")
    println("════════════════════════════════════════════════════════")
    println("[gate] serving/test_hire_routes.hexa — TSRV-P4-1")
    println("  target: 5/5 PASS (T1 capabilities, T2 task mock, T3 tone switch,")
    println("                    T4 persona fallback, T5 status log + ring)")
    println("════════════════════════════════════════════════════════")

    let out = run_target()
    println(out)
    println("--- analysis ---")

    let n_pass = count_pass_lines(out)
    println("T?-PASS line count = " + to_string(n_pass) + " / 5 (or 10 if double-emit)")

    let all_marker = out.index_of("ALL 5/5 PASS") >= 0
    println("ALL 5/5 marker present = " + to_string(all_marker))

    let pass_ok = n_pass == 5 || n_pass == 10
    println("")
    if pass_ok && all_marker {
        println("[gate] HARNESS PASS — TSRV-P4-1 scaffold_done 승격 가능")
        println("[gate] Endpoints: GET /hire/capabilities, POST /hire/task, GET /hire/status")
        println("[gate] mock autonomy_loop wired; 실 Claude path swap = anima-agent/llm_claude_adapter")
    } else {
        println("[gate] HARNESS FAIL — 머지 금지, 디버그 필요")
    }
}

main()
