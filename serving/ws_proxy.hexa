// serving/ws_proxy.hexa — WebSocket HTTP proxy (Cloudflare Tunnel bridge)
// Source: serving/ws_proxy.py (108 LOC)
//
// 8888 (HTTP+WS) -> 8765 (Anima WebSocket server)
//
// Cloudflare Tunnel connects to 8888, this proxy forwards to 8765.
// Handles both HTTP (static files) and WebSocket (chat) connections.
// Includes error recovery, heartbeat, and auto-reconnect.

comptime const WS_TARGET   = "ws://localhost:8765/ws"
comptime const HTTP_TARGET  = "http://localhost:8765"
comptime const PROXY_PORT   = 8888
comptime const HEARTBEAT_S  = 20.0
comptime const TIMEOUT_S    = 120.0

comptime const PSI_F_CRITICAL = 0.10

// ─── WebSocket handler ───

fn handle_ws(client_remote: string) -> string {
    // TODO[python-sdk]: aiohttp WebSocket proxy
    // 1. Accept WebSocket from client (heartbeat=20s, autoping, timeout=120s)
    // 2. Connect to WS_TARGET backend
    // 3. Bidirectional forwarding:
    //    forward_to_client: backend msg -> client ws
    //    forward_to_server: client msg -> backend ws
    // 4. Run both forwarders concurrently (asyncio.gather)
    // 5. Error handling: log warnings, close gracefully
    print("[+ws] client " + client_remote)
    "ws_ok"
}

// ─── HTTP handler ───

fn handle_http(path: string) -> string {
    // TODO[python-sdk]: aiohttp HTTP proxy
    // Forward GET requests to HTTP_TARGET + path
    // Set Cache-Control: no-cache for text/html
    // Return 502 on backend unavailable
    "http_response"
}

// ─── App setup ───

fn main() {
    print("Starting proxy: " + to_string(PROXY_PORT) + " -> 8765")
    // TODO[python-sdk]: aiohttp web.Application
    // Routes:
    //   GET /ws     -> handle_ws (WebSocket upgrade)
    //   GET /{path} -> handle_http (static + API proxy)
    //   GET /       -> handle_http (root)
    // web.run_app(app, host='0.0.0.0', port=PROXY_PORT)
    print("Proxy running on 0.0.0.0:" + to_string(PROXY_PORT))
}
