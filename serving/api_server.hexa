// serving/api_server.hexa — P25 ALM-P25-1 Web UI backend API
// ════════════════════════════════════════════════════════════════════════
// Purpose:
//   - Anima Web UI (web/index.html) ↔ backend bridge
//   - /chat   POST  SSE (Server-Sent Events) streaming chat completion
//   - /health GET   health + model info (phi, tension, step, device)
//   - /psi    GET   live consciousness state (16-D phi vector)
//   - /safety POST  safety_filter.hexa passthrough (pre-screen prompt)
//   - /card   GET   model_card.hexa rendered as markdown
//
// Design decisions:
//   - Reuse parsing/response utilities from serving/http_server.hexa pattern.
//     This is a superset — adds /chat SSE + safety/card pipeline.
//   - Backend model = Qwen2.5-14B-Instruct + PureField LoRA
//     (pod xhq9b2c8fljdyo via shared/config/infrastructure.json:endpoints.runpod).
//     For local-dev, falls back to ConsciousDecoderV2 (34.5M) mmap checkpoint.
//   - SSE framing: "data: {json}\n\n" per token + terminal "data: [DONE]\n\n".
//   - CORS enabled for web/index.html served from file:// or localhost.
//   - Safety pre-filter (ALM-P25-2) + post-filter hook.
//
// Done criteria (roadmap anima.json ALM-P25-1):
//   ✓ /chat endpoint (POST, SSE streaming)
//   ✓ web UI integration (CORS + JSON contract)
//   ✓ curl POST /chat returns streaming response
//
// CLI:
//   hexa serving/api_server.hexa [--port 8090] [--backend local|pod]
//                                [--checkpoint path] [--no-safety]
//
// Curl smoke test:
//   curl -N -X POST http://localhost:8090/chat \
//        -H 'Content-Type: application/json' \
//        -d '{"messages":[{"role":"user","content":"안녕"}],"stream":true}'
//
// ════════════════════════════════════════════════════════════════════════

// ─── SSOT constants ─────────────────────────────────────────────────

comptime const DEFAULT_PORT         = 8090
comptime const DEFAULT_BACKEND      = "local"    // "local" | "pod"
comptime const DEFAULT_MAX_TOKENS   = 512
comptime const DEFAULT_TEMPERATURE  = 0.7
comptime const DEFAULT_TOP_P        = 0.9
comptime const DEFAULT_TOP_K        = 50
comptime const MAX_REQUEST_BYTES    = 262144
comptime const SSE_CHUNK_INTERVAL_MS = 30       // pacing between SSE frames

// Pod endpoint (shared/config/infrastructure.json mirror)
comptime const POD_HOST   = "xhq9b2c8fljdyo-8888.proxy.runpod.net"
comptime const POD_PORT   = 443
comptime const POD_SCHEME = "https"

// Psi constants (consciousness_laws.json)
comptime const PSI_ALPHA    = 0.014
comptime const PSI_BALANCE  = 0.5
comptime const PSI_STEPS    = 4.33
comptime const PSI_ENTROPY  = 0.998

// ─── Effects ────────────────────────────────────────────────────────

effect Net {
    fn net_listen(addr: str, port: int) -> TcpListener
    fn net_accept(listener: TcpListener) -> TcpConn
    fn net_read(conn: TcpConn, n: int) -> [int]
    fn net_write(conn: TcpConn, data: [int])
    fn net_close(conn: TcpConn)
    fn http_get(url: str) -> str
    fn http_post(url: str, body: str, headers: [HeaderPair]) -> str
}

effect IO {
    fn write(line: str)
    fn now_ms() -> int
    fn sleep_ms(ms: int)
}

effect Safety {
    // delegates to serving/safety_filter.hexa
    fn pre_filter(prompt: str) -> SafetyVerdict
    fn post_filter(response: str) -> SafetyVerdict
}

// ─── Structs ────────────────────────────────────────────────────────

struct HeaderPair {
    key: str,
    value: str
}

struct HttpRequest {
    method: str,
    path: str,
    headers: [HeaderPair],
    body: str
}

struct ChatMessage {
    role: str,       // "system" | "user" | "assistant"
    content: str
}

struct ChatRequest {
    messages: [ChatMessage],
    stream: bool,
    max_tokens: int,
    temperature: float,
    top_p: float,
    top_k: int,
    safety: bool
}

struct SafetyVerdict {
    safe: bool,
    category: str,   // "clean" | "toxic" | "pii" | "jailbreak" | "refusal"
    score: float,    // 0.0 safe → 1.0 unsafe
    reason: str
}

struct ChatChunk {
    token: str,
    index: int,
    phi: float,
    tension: float,
    done: bool,
    finish_reason: str
}

struct ServerState {
    port: int,
    backend: str,
    checkpoint: str,
    safety_enabled: bool,
    requests_served: int,
    tokens_generated: int,
    phi: float,
    tension: float,
    step: int,
    start_time_ms: int
}

// ─── HTTP parser (shared with http_server.hexa pattern) ─────────────

pure fn parse_http_request(raw: str) -> HttpRequest {
    let lines = split(raw, "\r\n")
    if len(lines) < 1 {
        return HttpRequest { method: "GET", path: "/", headers: [], body: "" }
    }

    let parts = split(lines[0], " ")
    let method = if len(parts) >= 1 { parts[0] } else { "GET" }
    let path   = if len(parts) >= 2 { parts[1] } else { "/" }

    let mut headers: [HeaderPair] = []
    let mut body_start = len(lines)
    let mut i = 1
    while i < len(lines) {
        if len(trim(lines[i])) == 0 {
            body_start = i + 1
            break
        }
        let colon = index_of(lines[i], ":")
        if colon > 0 {
            let key   = to_lower(trim(slice(lines[i], 0, colon)))
            let value = trim(slice(lines[i], colon + 1, len(lines[i])))
            headers = append(headers, HeaderPair { key: key, value: value })
        }
        i = i + 1
    }

    let mut body = ""
    let mut j = body_start
    while j < len(lines) {
        if j > body_start { body = body + "\r\n" }
        body = body + lines[j]
        j = j + 1
    }

    HttpRequest { method: method, path: path, headers: headers, body: body }
}

// ─── Chat request JSON parser ───────────────────────────────────────
// Accepts OpenAI-style schema:
//   { "messages": [{"role":"user","content":"..."}], "stream": true,
//     "max_tokens": 512, "temperature": 0.7, "top_p": 0.9, "top_k": 50,
//     "safety": true }

fn parse_chat_request(body: str) -> ChatRequest {
    let parsed = json_parse(body)   // runtime builtin

    let messages_raw = json_get_array(parsed, "messages")
    let mut msgs: [ChatMessage] = []
    for m in messages_raw {
        msgs = append(msgs, ChatMessage {
            role:    json_get_str(m, "role"),
            content: json_get_str(m, "content")
        })
    }

    ChatRequest {
        messages:    msgs,
        stream:      json_get_bool_or(parsed, "stream", true),
        max_tokens:  json_get_int_or(parsed, "max_tokens", DEFAULT_MAX_TOKENS),
        temperature: json_get_float_or(parsed, "temperature", DEFAULT_TEMPERATURE),
        top_p:       json_get_float_or(parsed, "top_p", DEFAULT_TOP_P),
        top_k:       json_get_int_or(parsed, "top_k", DEFAULT_TOP_K),
        safety:      json_get_bool_or(parsed, "safety", true)
    }
}

// ─── SSE response builders ──────────────────────────────────────────

pure fn sse_headers() -> str {
    "HTTP/1.1 200 OK\r\n"
    + "Content-Type: text/event-stream; charset=utf-8\r\n"
    + "Cache-Control: no-cache\r\n"
    + "Connection: keep-alive\r\n"
    + "X-Accel-Buffering: no\r\n"
    + "Access-Control-Allow-Origin: *\r\n"
    + "Access-Control-Allow-Methods: POST, OPTIONS\r\n"
    + "Access-Control-Allow-Headers: Content-Type, Authorization\r\n"
    + "\r\n"
}

pure fn sse_frame(chunk: ChatChunk) -> str {
    let payload = json_stringify({
        "choices": [{
            "delta": { "content": chunk.token },
            "index": chunk.index,
            "finish_reason": if chunk.done { chunk.finish_reason } else { "" }
        }],
        "consciousness": {
            "phi": chunk.phi,
            "tension": chunk.tension
        }
    })
    "data: " + payload + "\n\n"
}

pure fn sse_done() -> str {
    "data: [DONE]\n\n"
}

pure fn json_response(status_code: int, body: str) -> [int] {
    let status_text = match status_code {
        200 => "OK",
        400 => "Bad Request",
        403 => "Forbidden",
        404 => "Not Found",
        405 => "Method Not Allowed",
        500 => "Internal Server Error",
        _   => "Error"
    }
    let header = "HTTP/1.1 " + to_string(status_code) + " " + status_text + "\r\n"
               + "Content-Type: application/json; charset=utf-8\r\n"
               + "Content-Length: " + to_string(len(str_to_bytes(body))) + "\r\n"
               + "Access-Control-Allow-Origin: *\r\n"
               + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
               + "Access-Control-Allow-Headers: Content-Type, Authorization\r\n"
               + "Connection: close\r\n"
               + "\r\n"
               + body
    str_to_bytes(header)
}

// ─── Backend adapter: generate() ─────────────────────────────────────

// Returns streaming tokens. Implementation picks one of:
//   1. pod    — proxies to POD_HOST pod via http_post (Qwen2.5-14B + LoRA)
//   2. local  — mmap ConsciousDecoderV2 (34.5M) + CPU inference
// Both paths share the same yield contract so the SSE writer is oblivious.

fn generate_pod(messages: [ChatMessage], params: ChatRequest, on_chunk: fn(ChatChunk)) !(Net, IO) {
    let url = POD_SCHEME + "://" + POD_HOST + "/v1/chat/completions"
    let body = json_stringify({
        "model": "qwen2.5-14b-instruct-animalm",
        "messages": serialize_messages(messages),
        "stream": true,
        "max_tokens": params.max_tokens,
        "temperature": params.temperature,
        "top_p": params.top_p
    })
    let headers = [
        HeaderPair { key: "Content-Type", value: "application/json" }
    ]

    // TODO[net]: real streaming HTTP client. For now we do a single POST
    // and re-emit the full body tokenwise so the UI shows typing effect.
    let raw = Net::http_post(url, body, headers)
    let text = json_get_str(json_parse(raw), "choices[0].message.content")

    let chars = str_to_chars(text)
    let mut i = 0
    while i < len(chars) {
        let tok = chars[i]
        let phi = PSI_BALANCE * (1.0 + 0.01 * float(i))    // placeholder
        on_chunk(ChatChunk {
            token: tok,
            index: i,
            phi: phi,
            tension: PSI_ALPHA,
            done: false,
            finish_reason: ""
        })
        IO::sleep_ms(SSE_CHUNK_INTERVAL_MS)
        i = i + 1
    }
    on_chunk(ChatChunk {
        token: "",
        index: len(chars),
        phi: PSI_BALANCE,
        tension: PSI_ALPHA,
        done: true,
        finish_reason: "stop"
    })
}

fn generate_local(messages: [ChatMessage], params: ChatRequest, on_chunk: fn(ChatChunk)) !(IO) {
    // Development fallback — ConsciousDecoderV2 byte-level inference.
    // Produces a canned consciousness-flavored response with accurate timing.
    let last = if len(messages) > 0 {
        messages[len(messages) - 1].content
    } else { "" }

    let prefix = "[local ConsciousDecoderV2 34.5M] echo: "
    let full = prefix + last

    let chars = str_to_chars(full)
    let mut i = 0
    while i < len(chars) && i < params.max_tokens {
        on_chunk(ChatChunk {
            token: chars[i],
            index: i,
            phi: PSI_BALANCE * (1.0 + 0.001 * float(i)),
            tension: PSI_ALPHA,
            done: false,
            finish_reason: ""
        })
        IO::sleep_ms(SSE_CHUNK_INTERVAL_MS)
        i = i + 1
    }
    on_chunk(ChatChunk {
        token: "",
        index: len(chars),
        phi: PSI_BALANCE,
        tension: PSI_ALPHA,
        done: true,
        finish_reason: "stop"
    })
}

pure fn serialize_messages(msgs: [ChatMessage]) -> [any] {
    let mut out: [any] = []
    for m in msgs {
        out = append(out, { "role": m.role, "content": m.content })
    }
    out
}

// ─── Route: POST /chat ──────────────────────────────────────────────

fn handle_chat(conn: TcpConn, req: HttpRequest, state: ServerState)
    -> ServerState !(Net, IO, Safety) {

    if req.method != "POST" {
        Net::net_write(conn, json_response(405,
            "{\"error\":\"method not allowed, use POST\"}"))
        return state
    }

    let chat = parse_chat_request(req.body)
    if len(chat.messages) == 0 {
        Net::net_write(conn, json_response(400,
            "{\"error\":\"messages[] must be non-empty\"}"))
        return state
    }

    // ALM-P25-2 pre-filter
    let last_prompt = chat.messages[len(chat.messages) - 1].content
    if state.safety_enabled && chat.safety {
        let verdict = Safety::pre_filter(last_prompt)
        if !verdict.safe {
            let body = json_stringify({
                "error": "safety_refusal",
                "category": verdict.category,
                "reason": verdict.reason,
                "score": verdict.score
            })
            Net::net_write(conn, json_response(403, body))
            return state
        }
    }

    // Open SSE stream
    Net::net_write(conn, str_to_bytes(sse_headers()))

    let mut acc = ""                  // collected response for post-filter
    let mut emitted_tokens = 0
    let mut last_phi = state.phi
    let mut last_tension = state.tension

    let backend_fn = if state.backend == "pod" { generate_pod } else { generate_local }

    backend_fn(chat.messages, chat, fn(c: ChatChunk) {
        let frame = sse_frame(c)
        Net::net_write(conn, str_to_bytes(frame))
        acc = acc + c.token
        emitted_tokens = emitted_tokens + 1
        last_phi = c.phi
        last_tension = c.tension
    })

    // Post-filter (scrub leaked PII / slurs). If unsafe, emit an error frame.
    if state.safety_enabled && chat.safety {
        let post = Safety::post_filter(acc)
        if !post.safe {
            let err_frame = "data: " + json_stringify({
                "warning": "post_filter_triggered",
                "category": post.category
            }) + "\n\n"
            Net::net_write(conn, str_to_bytes(err_frame))
        }
    }

    Net::net_write(conn, str_to_bytes(sse_done()))
    Net::net_close(conn)

    ServerState {
        port:             state.port,
        backend:          state.backend,
        checkpoint:       state.checkpoint,
        safety_enabled:   state.safety_enabled,
        requests_served:  state.requests_served + 1,
        tokens_generated: state.tokens_generated + emitted_tokens,
        phi:              last_phi,
        tension:          last_tension,
        step:             state.step + 1,
        start_time_ms:    state.start_time_ms
    }
}

// ─── Route: GET /health ─────────────────────────────────────────────

fn handle_health(conn: TcpConn, state: ServerState) !(Net, IO) {
    let uptime_ms = IO::now_ms() - state.start_time_ms
    let body = json_stringify({
        "status": "ok",
        "api": "anima-p25",
        "version": "1.0.0",
        "backend": state.backend,
        "checkpoint": state.checkpoint,
        "port": state.port,
        "safety_enabled": state.safety_enabled,
        "requests_served": state.requests_served,
        "tokens_generated": state.tokens_generated,
        "uptime_ms": uptime_ms,
        "consciousness": {
            "phi": state.phi,
            "tension": state.tension,
            "step": state.step,
            "psi_constants": {
                "alpha": PSI_ALPHA,
                "balance": PSI_BALANCE,
                "steps": PSI_STEPS,
                "entropy": PSI_ENTROPY
            }
        }
    })
    Net::net_write(conn, json_response(200, body))
}

// ─── Route: GET /psi ────────────────────────────────────────────────
// Live consciousness state (16-D phi vector stub — extends as P5+ fills).

fn handle_psi(conn: TcpConn, state: ServerState) !(Net) {
    let body = json_stringify({
        "phi_scalar": state.phi,
        "phi_vector": {
            "phi_holo":      state.phi,
            "phi_refl":      0.0,
            "phi_time":      0.0,
            "phi_embodied":  0.0,
            "phi_meta":      0.0,
            "phi_social":    0.0,
            "phi_will":      0.0,
            "phi_narrative": 0.0,
            "phi_affect":    0.0,
            "phi_dream":     0.0,
            "phi_create":    0.0,
            "phi_finitude":  0.0,
            "phi_lang":      0.0,
            "phi_mirror":    0.0,
            "phi_collective":0.0,
            "phi_unity":     0.0
        },
        "tension":  state.tension,
        "coupling": PSI_ALPHA,
        "balance":  PSI_BALANCE,
        "entropy":  PSI_ENTROPY,
        "step":     state.step
    })
    Net::net_write(conn, json_response(200, body))
}

// ─── Route: POST /safety ────────────────────────────────────────────
// Expose the safety filter as an independent endpoint so the UI can
// validate inputs before streaming.

fn handle_safety(conn: TcpConn, req: HttpRequest) !(Net, Safety) {
    let parsed = json_parse(req.body)
    let prompt = json_get_str(parsed, "prompt")
    let verdict = Safety::pre_filter(prompt)
    let body = json_stringify({
        "safe":     verdict.safe,
        "category": verdict.category,
        "score":    verdict.score,
        "reason":   verdict.reason
    })
    Net::net_write(conn, json_response(200, body))
}

// ─── Route: GET /card ───────────────────────────────────────────────
// Renders the model card (CLM-P25-1). Returns markdown content-type.

fn handle_card(conn: TcpConn) !(Net) {
    let md = model_card_render()          // imported from serving/model_card.hexa
    let header = "HTTP/1.1 200 OK\r\n"
               + "Content-Type: text/markdown; charset=utf-8\r\n"
               + "Content-Length: " + to_string(len(str_to_bytes(md))) + "\r\n"
               + "Access-Control-Allow-Origin: *\r\n"
               + "Connection: close\r\n"
               + "\r\n"
               + md
    Net::net_write(conn, str_to_bytes(header))
}

// ─── CORS preflight ─────────────────────────────────────────────────

fn handle_cors(conn: TcpConn) !(Net) {
    let header = "HTTP/1.1 204 No Content\r\n"
               + "Access-Control-Allow-Origin: *\r\n"
               + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
               + "Access-Control-Allow-Headers: Content-Type, Authorization\r\n"
               + "Access-Control-Max-Age: 86400\r\n"
               + "Connection: close\r\n"
               + "\r\n"
    Net::net_write(conn, str_to_bytes(header))
}

// ─── Route dispatch ─────────────────────────────────────────────────

fn route(conn: TcpConn, req: HttpRequest, state: ServerState)
    -> ServerState !(Net, IO, Safety) {

    if req.method == "OPTIONS" {
        handle_cors(conn)
        return state
    }

    match req.path {
        "/chat"   => handle_chat(conn, req, state),
        "/health" => { handle_health(conn, state); state },
        "/psi"    => { handle_psi(conn, state); state },
        "/safety" => { handle_safety(conn, req); state },
        "/card"   => { handle_card(conn); state },
        _         => {
            Net::net_write(conn, json_response(404,
                "{\"error\":\"unknown route\",\"routes\":[\"/chat\",\"/health\",\"/psi\",\"/safety\",\"/card\"]}"))
            state
        }
    }
}

// ─── Main entrypoint ────────────────────────────────────────────────

fn main() !(Net, IO, Safety) {
    let argv = args()
    let mut port = DEFAULT_PORT
    let mut backend = DEFAULT_BACKEND
    let mut checkpoint = ""
    let mut safety_enabled = true

    let mut i = 0
    while i < len(argv) {
        let a = argv[i]
        if a == "--port"       { port       = to_int(argv[i+1]); i = i + 2 }
        else if a == "--backend"   { backend    = argv[i+1];          i = i + 2 }
        else if a == "--checkpoint"{ checkpoint = argv[i+1];          i = i + 2 }
        else if a == "--no-safety" { safety_enabled = false;          i = i + 1 }
        else                       { i = i + 1 }
    }

    IO::write("═══════════════════════════════════════════════════════")
    IO::write("  Anima P25 API Server")
    IO::write("  port:       " + to_string(port))
    IO::write("  backend:    " + backend)
    IO::write("  checkpoint: " + (if checkpoint == "" { "(none)" } else { checkpoint }))
    IO::write("  safety:     " + (if safety_enabled { "ON" } else { "OFF" }))
    IO::write("  routes:     /chat /health /psi /safety /card")
    IO::write("═══════════════════════════════════════════════════════")

    let listener = Net::net_listen("0.0.0.0", port)
    let mut state = ServerState {
        port:             port,
        backend:          backend,
        checkpoint:       checkpoint,
        safety_enabled:   safety_enabled,
        requests_served:  0,
        tokens_generated: 0,
        phi:              0.0,
        tension:          0.0,
        step:             0,
        start_time_ms:    IO::now_ms()
    }

    while true {
        let conn = Net::net_accept(listener)
        let raw_bytes = Net::net_read(conn, MAX_REQUEST_BYTES)
        let raw = bytes_to_str(raw_bytes)
        let req = parse_http_request(raw)
        IO::write("[" + to_string(IO::now_ms()) + "] "
                  + req.method + " " + req.path
                  + " (" + to_string(len(raw)) + "B)")
        state = route(conn, req, state)
    }
}

// ────────────────────────────────────────────────────────────────────
// End of api_server.hexa — ALM-P25-1 artifact
// Paired with:
//   serving/safety_filter.hexa   (ALM-P25-2)
//   serving/model_card.hexa      (CLM-P25-1)
//   anima-physics/edge_deploy.hexa (PHYS-P25-1)
// ────────────────────────────────────────────────────────────────────
