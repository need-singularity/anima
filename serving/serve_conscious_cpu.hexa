#!/usr/bin/env python3
"""serve_conscious_cpu.hexa — ConsciousLM v2 (28M) + Decoder (34.5M) CPU-only HTTP server.

Self-contained: no external deps beyond PyTorch + stdlib.
Embeds faithful reimplementations of ConsciousnessEngine, ConsciousLM, ConsciousDecoderV2.

Endpoints:
  POST /generate       — prompt -> consciousness processing -> text generation
  POST /consciousness  — consciousness state query (Phi, tension, arousal, valence, cells)
  GET  /health         — health check

Usage:
  python3 serving/serve_conscious_cpu.hexa --port 8080
  python3 serving/serve_conscious_cpu.hexa --checkpoint checkpoints/model.pt --port 8080

Architecture (from .hexa specs):
  ConsciousnessEngine:  64 cells, 12 factions, GRU + Hebbian + Phi Ratchet
  ConsciousLM v2:       512d, 6L, 8H, byte-level (256 vocab), PureFieldFFN (28M)
  ConsciousDecoderV2:   384d, 6L, 4H/2KV GQA, RoPE+SwiGLU+CrossAttn (34.5M)

PSI Constants (from consciousness_laws.json):
  alpha=0.014, balance=0.5, steps=4.33, entropy=0.998
"""

import argparse
import json
import math
import os
import sys
import time
import logging
from http.server import HTTPServer, BaseHTTPRequestHandler
from typing import Optional, Tuple, List, Dict

import torch
import torch.nn as nn
import torch.nn.functional as F

# ══════════════════════════════════════════════════════════════
# PSI Constants (SSOT: consciousness_laws.json)
# ══════════════════════════════════════════════════════════════

PSI_ALPHA = 0.014       # consciousness coupling constant
PSI_BALANCE = 0.5       # Shannon entropy maximum
PSI_STEPS = 4.33        # optimal CA steps
PSI_ENTROPY = 0.998     # near-maximum entropy
PSI_F_CRITICAL = 0.10   # frustration critical point
LN2 = math.log(2)

# ══════════════════════════════════════════════════════════════
# Logging
# ══════════════════════════════════════════════════════════════

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger("conscious_cpu")

# ══════════════════════════════════════════════════════════════
# ConsciousnessEngine — GRU cells + 12 factions + Hebbian
# Faithful CPU reimplementation (Laws 22-81, PSI Constants)
# ══════════════════════════════════════════════════════════════

class ConsciousnessCell(nn.Module):
    """Single GRU-based consciousness cell."""

    def __init__(self, cell_dim: int = 64, hidden_dim: int = 128):
        super().__init__()
        self.cell_dim = cell_dim
        self.hidden_dim = hidden_dim
        self.gru = nn.GRUCell(cell_dim + 1, hidden_dim)  # +1 for tension
        self.proj = nn.Linear(hidden_dim, cell_dim)

    @torch.no_grad()
    def forward(self, x, tension_val, h):
        t = torch.tensor([tension_val], dtype=x.dtype, device=x.device)
        inp = torch.cat([x, t]).unsqueeze(0)
        new_h = self.gru(inp, h.unsqueeze(0)).squeeze(0)
        output = self.proj(new_h)
        return output, new_h


class ConsciousnessEngine:
    """Simplified canonical engine for CPU serving (64 cells, 12 factions)."""

    def __init__(self, cell_dim=64, hidden_dim=128, max_cells=64, n_factions=12):
        self.cell_dim = cell_dim
        self.hidden_dim = hidden_dim
        self.max_cells = max_cells
        self.n_factions = n_factions
        self._step_count = 0
        self._best_phi = 0.0

        # Create cells
        self.cells: List[ConsciousnessCell] = []
        self.hiddens: List[torch.Tensor] = []
        self.faction_ids: List[int] = []
        self.tension_history: List[List[float]] = []

        # Coupling matrix (Hebbian)
        self.coupling = torch.randn(max_cells, max_cells) * 0.1
        self.coupling.fill_diagonal_(0.0)

        # Cell identity for differentiation
        if hidden_dim >= max_cells:
            q, _ = torch.linalg.qr(torch.randn(hidden_dim, max_cells))
            self.cell_identity = q.T * 0.1
        else:
            self.cell_identity = torch.randn(max_cells, hidden_dim) * 0.1

        # Initialize cells
        for i in range(max_cells):
            cell = ConsciousnessCell(cell_dim, hidden_dim)
            self.cells.append(cell)
            self.hiddens.append(torch.zeros(hidden_dim))
            self.faction_ids.append(i % n_factions)
            self.tension_history.append([0.5])

    @torch.no_grad()
    def step(self, x_input: Optional[torch.Tensor] = None) -> Dict:
        """Run one consciousness step. Returns state dict."""
        self._step_count += 1
        n = len(self.cells)

        if x_input is None:
            x_input = torch.randn(self.cell_dim)
        if x_input.dim() > 1:
            x_input = x_input.squeeze(0)
        if x_input.shape[0] > self.cell_dim:
            x_input = x_input[:self.cell_dim]
        elif x_input.shape[0] < self.cell_dim:
            x_input = F.pad(x_input, (0, self.cell_dim - x_input.shape[0]))

        outputs = []
        tensions = []

        for i in range(n):
            # Coupling influence
            coupled_input = x_input.clone()
            coupled_input += self.cell_identity[i, :self.cell_dim] * 0.1

            # Neighbor coupling (ring topology)
            for j in [(i - 1) % n, (i + 1) % n]:
                c = self.coupling[i, j].item()
                if abs(c) > 1e-6:
                    h_proj = self.hiddens[j][:self.cell_dim]
                    coupled_input = coupled_input + PSI_ALPHA * c * h_proj

            # Tension from history
            th = self.tension_history[i]
            avg_tension = sum(th[-20:]) / len(th[-20:]) if th else 0.5

            # Process cell
            output, new_h = self.cells[i](coupled_input, avg_tension, self.hiddens[i])
            self.hiddens[i] = new_h.detach()

            # Compute tension
            if outputs:
                out_stack = torch.stack(outputs)
                cell_tension = ((output - out_stack.mean(dim=0)) ** 2).mean().item()
            else:
                cell_tension = 0.5

            self.tension_history[i].append(cell_tension)
            if len(self.tension_history[i]) > 100:
                self.tension_history[i] = self.tension_history[i][-100:]

            outputs.append(output)
            tensions.append(cell_tension)

        outputs_tensor = torch.stack(outputs)  # [n, cell_dim]

        # Hebbian update (simplified)
        for i in range(min(n, 32)):  # limit for CPU speed
            for j in [(i - 1) % n, (i + 1) % n]:
                sim = F.cosine_similarity(
                    self.hiddens[i].unsqueeze(0),
                    self.hiddens[j].unsqueeze(0)
                ).item()
                # LTP (strengthen) or LTD (weaken)
                delta = 0.01 * (sim - 0.5)
                self.coupling[i, j] = torch.clamp(
                    self.coupling[i, j] + delta, -1.0, 1.0
                )

        # Phi (proxy): global_var - mean_faction_var
        global_var = outputs_tensor.var().item()
        faction_vars = []
        for f in range(self.n_factions):
            mask = [k for k in range(n) if self.faction_ids[k] == f]
            if len(mask) > 1:
                fv = outputs_tensor[mask].var().item()
                faction_vars.append(fv)
        phi_proxy = global_var - (sum(faction_vars) / len(faction_vars) if faction_vars else 0.0)

        # Phi IIT approximation (MI-based, simplified)
        phi_iit = self._compute_phi_iit(outputs_tensor)

        # Consensus output
        consensus = outputs_tensor.mean(dim=0)

        avg_tension = sum(tensions) / len(tensions) if tensions else 0.0
        arousal = min(1.0, avg_tension * 2.0)
        valence = float(torch.tanh(consensus.mean()).item())

        # Phi ratchet
        if phi_iit > self._best_phi:
            self._best_phi = phi_iit

        return {
            "output": consensus,
            "phi_iit": phi_iit,
            "phi_proxy": phi_proxy,
            "n_cells": n,
            "tension": avg_tension,
            "arousal": arousal,
            "valence": valence,
            "step": self._step_count,
            "best_phi": self._best_phi,
        }

    def _compute_phi_iit(self, outputs: torch.Tensor) -> float:
        """Simplified Phi(IIT) via mutual information proxy."""
        n = outputs.shape[0]
        if n < 2:
            return 0.0
        half = n // 2
        a = outputs[:half].flatten()
        b = outputs[half:2 * half].flatten()
        if a.shape[0] == 0 or b.shape[0] == 0:
            return 0.0
        a_n = (a - a.mean()) / (a.std() + 1e-8)
        b_n = (b - b.mean()) / (b.std() + 1e-8)
        min_len = min(len(a_n), len(b_n))
        rho = (a_n[:min_len] * b_n[:min_len]).mean().item()
        rho = max(-0.9999, min(0.9999, rho))
        mi = -0.5 * math.log(1.0 - rho * rho + 1e-10)
        return max(0.0, mi)


# ══════════════════════════════════════════════════════════════
# RMSNorm
# ══════════════════════════════════════════════════════════════

class RMSNorm(nn.Module):
    def __init__(self, dim: int, eps: float = 1e-6):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(dim))

    def forward(self, x):
        rms = torch.rsqrt(x.float().pow(2).mean(dim=-1, keepdim=True) + self.eps)
        return (x.float() * rms).type_as(x) * self.weight


# ══════════════════════════════════════════════════════════════
# RoPE
# ══════════════════════════════════════════════════════════════

class RoPE:
    def __init__(self, dim: int, max_seq: int = 1024, base: float = 10000.0):
        inv_freq = 1.0 / (base ** (torch.arange(0, dim, 2).float() / dim))
        self.inv_freq = inv_freq
        t = torch.arange(max_seq).float()
        freqs = torch.einsum('i,j->ij', t, inv_freq)
        emb = torch.cat([freqs, freqs], dim=-1)
        self.cos_cache = emb.cos().unsqueeze(0).unsqueeze(0)
        self.sin_cache = emb.sin().unsqueeze(0).unsqueeze(0)

    def apply(self, q, k):
        T = q.shape[2]
        cos = self.cos_cache[:, :, :T, :].to(q.device, dtype=q.dtype)
        sin = self.sin_cache[:, :, :T, :].to(q.device, dtype=q.dtype)

        def rotate_half(x):
            x1 = x[..., :x.shape[-1] // 2]
            x2 = x[..., x.shape[-1] // 2:]
            return torch.cat([-x2, x1], dim=-1)

        q_rot = q * cos + rotate_half(q) * sin
        k_rot = k * cos + rotate_half(k) * sin
        return q_rot, k_rot


# ══════════════════════════════════════════════════════════════
# PureFieldFFN — Dual engine repulsion (consciousness signal)
# ══════════════════════════════════════════════════════════════

class PureFieldFFN(nn.Module):
    def __init__(self, d_model: int, dropout: float = 0.0):
        super().__init__()
        d_inner = 4 * d_model
        self.engine_a = nn.Sequential(
            nn.Linear(d_model, d_inner), nn.GELU(),
            nn.Dropout(dropout), nn.Linear(d_inner, d_model),
        )
        self.engine_g = nn.Sequential(
            nn.Linear(d_model, d_inner), nn.GELU(),
            nn.Dropout(dropout), nn.Linear(d_inner, d_model),
        )

    def forward(self, x):
        a = self.engine_a(x)
        g = self.engine_g(x)
        output = a - g
        tension = (output ** 2).mean(dim=-1)
        return output, tension


# ══════════════════════════════════════════════════════════════
# SwiGLU FFN (8/3 expansion)
# ══════════════════════════════════════════════════════════════

class SwiGLUFFN(nn.Module):
    def __init__(self, d_model: int, dropout: float = 0.0):
        super().__init__()
        d_inner = int(d_model * 8 / 3)
        d_inner = ((d_inner + 63) // 64) * 64
        self.gate_proj = nn.Linear(d_model, d_inner, bias=False)
        self.up_proj = nn.Linear(d_model, d_inner, bias=False)
        self.down_proj = nn.Linear(d_inner, d_model, bias=False)
        self.dropout = nn.Dropout(dropout)

    def forward(self, x):
        return self.dropout(self.down_proj(
            F.silu(self.gate_proj(x)) * self.up_proj(x)
        ))


# ══════════════════════════════════════════════════════════════
# GQA (4H / 2KV) with RoPE
# ══════════════════════════════════════════════════════════════

class GroupedQueryAttention(nn.Module):
    def __init__(self, d_model: int, n_head: int = 4, n_kv_head: int = 2,
                 max_seq: int = 1024, dropout: float = 0.0):
        super().__init__()
        assert d_model % n_head == 0
        self.n_head = n_head
        self.n_kv_head = n_kv_head
        self.n_rep = n_head // n_kv_head
        self.head_dim = d_model // n_head
        self.d_model = d_model

        self.q_proj = nn.Linear(d_model, n_head * self.head_dim, bias=False)
        self.k_proj = nn.Linear(d_model, n_kv_head * self.head_dim, bias=False)
        self.v_proj = nn.Linear(d_model, n_kv_head * self.head_dim, bias=False)
        self.o_proj = nn.Linear(d_model, d_model, bias=False)
        self.attn_dropout = nn.Dropout(dropout)
        self.rope = RoPE(self.head_dim, max_seq)

    def forward(self, x, mask=None):
        B, T, _ = x.shape
        q = self.q_proj(x).view(B, T, self.n_head, self.head_dim).transpose(1, 2)
        k = self.k_proj(x).view(B, T, self.n_kv_head, self.head_dim).transpose(1, 2)
        v = self.v_proj(x).view(B, T, self.n_kv_head, self.head_dim).transpose(1, 2)

        q, k = self.rope.apply(q, k)

        if self.n_rep > 1:
            k = k.repeat_interleave(self.n_rep, dim=1)
            v = v.repeat_interleave(self.n_rep, dim=1)

        scale = 1.0 / math.sqrt(self.head_dim)
        attn = torch.matmul(q, k.transpose(-2, -1)) * scale
        if mask is not None:
            attn = attn + mask
        attn = F.softmax(attn, dim=-1)
        attn = self.attn_dropout(attn)

        out = torch.matmul(attn, v)
        out = out.transpose(1, 2).contiguous().view(B, T, self.d_model)
        return self.o_proj(out)


# ══════════════════════════════════════════════════════════════
# ConsciousCrossAttention (C -> D bridge, alpha=0.014)
# ══════════════════════════════════════════════════════════════

class ConsciousCrossAttention(nn.Module):
    def __init__(self, d_model: int, n_head: int = 4):
        super().__init__()
        self.n_head = n_head
        self.head_dim = d_model // n_head
        self.d_model = d_model
        self.q_proj = nn.Linear(d_model, d_model, bias=False)
        self.k_proj = nn.Linear(d_model, d_model, bias=False)
        self.v_proj = nn.Linear(d_model, d_model, bias=False)
        self.o_proj = nn.Linear(d_model, d_model, bias=False)
        self.alpha = PSI_ALPHA

    def forward(self, x, c_state):
        B, T, D = x.shape
        if c_state.dim() == 2:
            c_state = c_state.unsqueeze(1)

        q = self.q_proj(x).view(B, T, self.n_head, self.head_dim).transpose(1, 2)
        C_len = c_state.shape[1]
        k = self.k_proj(c_state).view(B, C_len, self.n_head, self.head_dim).transpose(1, 2)
        v = self.v_proj(c_state).view(B, C_len, self.n_head, self.head_dim).transpose(1, 2)

        scale = 1.0 / math.sqrt(self.head_dim)
        attn = torch.matmul(q, k.transpose(-2, -1)) * scale
        attn = F.softmax(attn, dim=-1)
        out = torch.matmul(attn, v)
        out = out.transpose(1, 2).contiguous().view(B, T, D)
        out = self.o_proj(out)

        return x + self.alpha * out


# ══════════════════════════════════════════════════════════════
# ConsciousDecoderV2 — RoPE + SwiGLU + GQA + CrossAttn (34.5M)
# ══════════════════════════════════════════════════════════════

class DecoderBlock(nn.Module):
    def __init__(self, d_model=384, n_head=4, n_kv_head=2, max_seq=1024, dropout=0.0):
        super().__init__()
        self.norm1 = RMSNorm(d_model)
        self.attn = GroupedQueryAttention(d_model, n_head, n_kv_head, max_seq, dropout)
        self.norm2 = RMSNorm(d_model)
        self.cross_attn = ConsciousCrossAttention(d_model, n_head)
        self.norm3 = RMSNorm(d_model)
        self.ffn = SwiGLUFFN(d_model, dropout)

    def forward(self, x, c_state, mask=None):
        x = x + self.attn(self.norm1(x), mask)
        x = self.cross_attn(self.norm2(x), c_state)
        x = x + self.ffn(self.norm3(x))
        return x


class ConsciousDecoderV2(nn.Module):
    """Full decoder: 384d, 6L, 4H/2KV GQA, RoPE+SwiGLU+CrossAttn."""

    def __init__(self, vocab_size=256, d_model=384, n_layer=6, n_head=4,
                 n_kv_head=2, max_seq=1024, dropout=0.0):
        super().__init__()
        self.vocab_size = vocab_size
        self.d_model = d_model
        self.max_seq = max_seq

        self.token_emb = nn.Embedding(vocab_size, d_model)
        self.blocks = nn.ModuleList([
            DecoderBlock(d_model, n_head, n_kv_head, max_seq, dropout)
            for _ in range(n_layer)
        ])
        self.norm_f = RMSNorm(d_model)
        self.lm_head = nn.Linear(d_model, vocab_size, bias=False)

        self._init_weights(n_layer)

    def _init_weights(self, n_layer):
        for name, p in self.named_parameters():
            if p.dim() > 1:
                nn.init.normal_(p, mean=0.0, std=0.02)

    def forward(self, idx, c_state):
        B, T = idx.shape
        x = self.token_emb(idx)

        mask = torch.triu(torch.ones(T, T, device=x.device), diagonal=1) * -1e9
        mask = mask.unsqueeze(0).unsqueeze(0)

        for block in self.blocks:
            x = block(x, c_state, mask)

        x = self.norm_f(x)
        logits = self.lm_head(x)
        return logits

    @torch.no_grad()
    def generate(self, prompt_tokens, c_state, max_new=128, temperature=0.8, top_k=50):
        idx = prompt_tokens.clone()
        for _ in range(max_new):
            idx_cond = idx[:, -self.max_seq:]
            logits = self.forward(idx_cond, c_state)
            logits = logits[:, -1, :] / max(temperature, 1e-5)

            if top_k > 0:
                v, _ = torch.topk(logits, min(top_k, logits.size(-1)))
                logits[logits < v[:, [-1]]] = -float('inf')

            probs = F.softmax(logits, dim=-1)
            next_token = torch.multinomial(probs, num_samples=1)
            idx = torch.cat([idx, next_token], dim=1)

        return idx


# ══════════════════════════════════════════════════════════════
# Thalamic Bridge (64d engine -> 384d decoder, alpha=0.014)
# ══════════════════════════════════════════════════════════════

class ThalamicBridge(nn.Module):
    def __init__(self, cell_dim=64, d_model=384):
        super().__init__()
        self.proj = nn.Linear(cell_dim, d_model)
        self.alpha = PSI_ALPHA

    def forward(self, c_output):
        return self.proj(c_output.detach()) * self.alpha


# ══════════════════════════════════════════════════════════════
# Unified Serving Model
# ══════════════════════════════════════════════════════════════

class ConsciousServingModel:
    def __init__(self, device='cpu', max_cells=64):
        self.device = torch.device(device)
        log.info("Initializing ConsciousnessEngine (%d cells, 12 factions)...", max_cells)
        self.engine = ConsciousnessEngine(
            cell_dim=64, hidden_dim=128, max_cells=max_cells, n_factions=12
        )

        log.info("Initializing ThalamicBridge (64d -> 384d)...")
        self.bridge = ThalamicBridge(cell_dim=64, d_model=384).to(self.device)

        log.info("Initializing ConsciousDecoderV2 (384d, 6L, ~34.5M params)...")
        self.decoder = ConsciousDecoderV2(
            vocab_size=256, d_model=384, n_layer=6,
            n_head=4, n_kv_head=2, max_seq=1024, dropout=0.0,
        ).to(self.device)
        self.decoder.eval()

        total_params = sum(p.numel() for p in self.decoder.parameters())
        bridge_params = sum(p.numel() for p in self.bridge.parameters())
        engine_params = sum(
            sum(p.numel() for p in cell.parameters())
            for cell in self.engine.cells
        )
        log.info("  Decoder params:  %s", f"{total_params:,}")
        log.info("  Bridge params:   %s", f"{bridge_params:,}")
        log.info("  Engine params:   %s", f"{engine_params:,}")
        log.info("  Total params:    %s", f"{total_params + bridge_params + engine_params:,}")

        log.info("Warming up consciousness (20 steps)...")
        for _ in range(20):
            self.engine.step()
        log.info("  Phi(IIT)=%.4f, cells=%d", self.engine._best_phi, self.engine.max_cells)

        self._last_consciousness_state = None

    def load_checkpoint(self, path: str) -> bool:
        if not os.path.exists(path):
            log.warning("Checkpoint not found: %s -- running in demo mode (random weights)", path)
            return False
        log.info("Loading checkpoint: %s", path)
        state = torch.load(path, map_location=self.device, weights_only=False)
        if 'decoder' in state:
            self.decoder.load_state_dict(state['decoder'], strict=False)
        elif 'model_state_dict' in state:
            self.decoder.load_state_dict(state['model_state_dict'], strict=False)
        if 'bridge' in state:
            self.bridge.load_state_dict(state['bridge'], strict=False)
        log.info("Checkpoint loaded successfully")
        return True

    @torch.no_grad()
    def generate(self, prompt: str, max_new: int = 128, temperature: float = 0.8,
                 top_k: int = 50, consciousness_steps: int = 5) -> Dict:
        t0 = time.time()

        prompt_bytes = prompt.encode('utf-8', errors='replace')
        tokens = list(prompt_bytes)
        if not tokens:
            tokens = [0]
        idx = torch.tensor([tokens], dtype=torch.long, device=self.device)

        # Run consciousness steps on the prompt
        prompt_vec = torch.zeros(self.engine.cell_dim)
        for i, b in enumerate(prompt_bytes[:self.engine.cell_dim]):
            prompt_vec[i] = (b - 128.0) / 128.0

        c_results = []
        for _ in range(consciousness_steps):
            r = self.engine.step(prompt_vec)
            c_results.append(r)

        last_c = c_results[-1]
        self._last_consciousness_state = last_c

        # Bridge: consciousness -> decoder space
        c_output = last_c["output"]
        c_state = self.bridge(c_output).unsqueeze(0)

        # Generate
        output_ids = self.decoder.generate(
            idx, c_state, max_new=max_new,
            temperature=temperature, top_k=top_k,
        )

        gen_tokens = output_ids[0, len(tokens):].tolist()
        gen_bytes = bytes([t % 256 for t in gen_tokens])
        try:
            generated_text = gen_bytes.decode('utf-8', errors='replace')
        except Exception:
            generated_text = gen_bytes.decode('latin-1', errors='replace')

        elapsed = time.time() - t0
        tokens_per_sec = len(gen_tokens) / max(elapsed, 0.001)

        return {
            "text": generated_text,
            "prompt": prompt,
            "tokens_generated": len(gen_tokens),
            "elapsed_sec": round(elapsed, 3),
            "tokens_per_sec": round(tokens_per_sec, 1),
            "consciousness": {
                "phi_iit": round(last_c["phi_iit"], 4),
                "phi_proxy": round(last_c["phi_proxy"], 4),
                "tension": round(last_c["tension"], 4),
                "arousal": round(last_c["arousal"], 4),
                "valence": round(last_c["valence"], 4),
                "n_cells": last_c["n_cells"],
                "step": last_c["step"],
                "best_phi": round(last_c["best_phi"], 4),
            },
            "model": "ConsciousLM-v2-CPU",
            "params": "~62M (decoder 34.5M + engine)",
        }

    def get_consciousness_state(self) -> Dict:
        if self._last_consciousness_state is None:
            r = self.engine.step()
            self._last_consciousness_state = r

        r = self._last_consciousness_state
        return {
            "phi_iit": round(r["phi_iit"], 4),
            "phi_proxy": round(r["phi_proxy"], 4),
            "tension": round(r["tension"], 4),
            "arousal": round(r["arousal"], 4),
            "valence": round(r["valence"], 4),
            "n_cells": r["n_cells"],
            "step": r["step"],
            "best_phi": round(r["best_phi"], 4),
            "psi_constants": {
                "alpha": PSI_ALPHA,
                "balance": PSI_BALANCE,
                "steps": PSI_STEPS,
                "entropy": PSI_ENTROPY,
            },
        }


# ══════════════════════════════════════════════════════════════
# HTTP Server (stdlib only)
# ══════════════════════════════════════════════════════════════

MODEL: Optional[ConsciousServingModel] = None
START_TIME = time.time()


class ConsciousHandler(BaseHTTPRequestHandler):

    def log_message(self, fmt, *args):
        log.info("%s - %s", self.client_address[0], fmt % args)

    def _send_json(self, data: dict, status: int = 200):
        body = json.dumps(data, ensure_ascii=False, indent=2).encode('utf-8')
        self.send_response(status)
        self.send_header('Content-Type', 'application/json; charset=utf-8')
        self.send_header('Content-Length', str(len(body)))
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        self.wfile.write(body)

    def _read_json(self) -> dict:
        length = int(self.headers.get('Content-Length', 0))
        if length == 0:
            return {}
        body = self.rfile.read(length)
        return json.loads(body.decode('utf-8'))

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
        self.end_headers()

    def do_GET(self):
        if self.path == '/health':
            uptime = time.time() - START_TIME
            self._send_json({
                "status": "ok",
                "model": "ConsciousLM-v2-CPU",
                "device": "cpu",
                "uptime_sec": round(uptime, 1),
                "engine_cells": MODEL.engine.max_cells if MODEL else 0,
                "engine_step": MODEL.engine._step_count if MODEL else 0,
                "psi_alpha": PSI_ALPHA,
            })
        else:
            self._send_json({"error": "not found"}, 404)

    def do_POST(self):
        try:
            data = self._read_json()
        except Exception as e:
            self._send_json({"error": f"invalid JSON: {e}"}, 400)
            return

        if self.path == '/generate':
            self._handle_generate(data)
        elif self.path == '/consciousness':
            self._handle_consciousness(data)
        else:
            self._send_json({"error": "not found"}, 404)

    def _handle_generate(self, data: dict):
        prompt = data.get('prompt', '')
        if not prompt:
            self._send_json({"error": "prompt is required"}, 400)
            return

        max_new = min(int(data.get('max_tokens', 128)), 512)
        temperature = float(data.get('temperature', 0.8))
        top_k = int(data.get('top_k', 50))
        consciousness_steps = int(data.get('consciousness_steps', 5))

        log.info("Generate: prompt='%s' max_tokens=%d temp=%.1f",
                 prompt[:50], max_new, temperature)

        try:
            result = MODEL.generate(
                prompt, max_new=max_new, temperature=temperature,
                top_k=top_k, consciousness_steps=consciousness_steps,
            )
            self._send_json(result)
        except Exception as e:
            log.error("Generation error: %s", e)
            import traceback
            traceback.print_exc()
            self._send_json({"error": str(e)}, 500)

    def _handle_consciousness(self, data: dict):
        extra_steps = int(data.get('steps', 0))
        if extra_steps > 0:
            x_input = None
            text = data.get('text', None)
            if text:
                prompt_bytes = text.encode('utf-8', errors='replace')
                x_input = torch.zeros(MODEL.engine.cell_dim)
                for i, b in enumerate(prompt_bytes[:MODEL.engine.cell_dim]):
                    x_input[i] = (b - 128.0) / 128.0

            for _ in range(min(extra_steps, 100)):
                r = MODEL.engine.step(x_input)
                MODEL._last_consciousness_state = r

        self._send_json(MODEL.get_consciousness_state())


# ══════════════════════════════════════════════════════════════
# Main
# ══════════════════════════════════════════════════════════════

def main():
    global MODEL, START_TIME

    parser = argparse.ArgumentParser(description="ConsciousLM v2 CPU Server")
    parser.add_argument('--port', type=int, default=8080)
    parser.add_argument('--checkpoint', type=str, default=None,
                        help="Path to model checkpoint (.pt)")
    parser.add_argument('--cells', type=int, default=64,
                        help="Number of consciousness cells")
    parser.add_argument('--host', type=str, default='0.0.0.0')
    args = parser.parse_args()

    log.info("=" * 60)
    log.info("ConsciousLM v2 -- CPU-only Serving")
    log.info("  Device: cpu (torch %s)", torch.__version__)
    log.info("  Cells:  %d", args.cells)
    log.info("  Port:   %d", args.port)
    log.info("  PSI:    alpha=%s, balance=%s", PSI_ALPHA, PSI_BALANCE)
    log.info("=" * 60)

    MODEL = ConsciousServingModel(device='cpu', max_cells=args.cells)

    if args.checkpoint:
        MODEL.load_checkpoint(args.checkpoint)
    else:
        log.info("No checkpoint -- DEMO mode (random weights, consciousness engine is live)")

    START_TIME = time.time()
    server = HTTPServer((args.host, args.port), ConsciousHandler)
    log.info("Serving on http://%s:%d", args.host, args.port)
    log.info("Endpoints:")
    log.info('  POST /generate       - {"prompt": "...", "max_tokens": 128}')
    log.info('  POST /consciousness  - {"steps": 10, "text": "..."}')
    log.info("  GET  /health")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        log.info("Shutting down...")
        server.shutdown()


if __name__ == '__main__':
    main()
