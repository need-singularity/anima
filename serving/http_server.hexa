// ─── Route: POST /generate ──────────────────────────────────────────

fn handle_generate(conn: TcpConn, req: HttpRequest, state: ServerState)
  -> ServerState !(Net, IO) {

    let data = json_parse(req.body)

    let prompt = if has_key(data, "prompt") { data["prompt"] } else { "" }
    if len(prompt) == 0 {
        let err = json_stringify({ "error": "missing 'prompt' field" })
        Net::net_write(conn, json_response(400, err))
        return state
    }

    let max_tokens = if has_key(data, "max_tokens") {
        to_int(data["max_tokens"])
    } else {
        DEFAULT_MAX_TOKENS
    }
    let temperature = if has_key(data, "temperature") {
        to_float(data["temperature"])
    } else {
        DEFAULT_TEMPERATURE
    }
    let top_p = if has_key(data, "top_p") {
        to_float(data["top_p"])
    } else {
        DEFAULT_TOP_P
    }
    let top_k = if has_key(data, "top_k") {
        to_int(data["top_k"])
    } else {
        DEFAULT_TOP_K
    }
    let rep_penalty = if has_key(data, "repetition_penalty") {
        to_float(data["repetition_penalty"])
    } else {
        DEFAULT_REP_PENALTY
    }

    let params = GenerateParams {
        max_new_tokens: max_tokens,
        temperature: temperature,
        top_p: top_p,
        top_k: top_k,
        repetition_penalty: rep_penalty
    }

    let result = generate(state.model, state.psi, prompt, params)

    let body = json_stringify({
        "text": result.text,
        "tokens_generated": result.tokens_generated,
        "latency_ms": result.latency_ms,
        "consciousness": {
            "phi": result.phi,
            "tension": result.tension
        },
        "model": {
            "name": "ConsciousDecoderV2",
            "params": state.model.param_count,
            "device": state.model.device
        }
    })

    Net::net_write(conn, json_response(200, body))

    // Update served count + psi state
    state with {
        requests_served: state.requests_served + 1,
        psi: state.psi with {
            phi: result.phi,
            tension: result.tension,
            step: state.psi.step + 1
        }
    }
}

// ─── Route: POST /consciousness ─────────────────────────────────────

fn handle_consciousness(conn: TcpConn, state: ServerState) !(Net) {
    let body = json_stringify({
        "phi": state.psi.phi,
        "tension": state.psi.tension,
        "balance": state.psi.balance,
        "coupling": state.psi.coupling,
        "entropy": state.psi.entropy,
        "factions": state.psi.factions,
        "cells": state.psi.cells,
        "step": state.psi.step,
        "psi_constants": {
            "alpha": PSI_ALPHA,
            "balance": PSI_BALANCE,
            "steps": PSI_STEPS,
            "entropy": PSI_ENTROPY
        },
        "architecture": {
            "d_model": D_MODEL,
            "n_layer": N_LAYER,
            "n_head": N_HEAD,
            "n_kv_head": N_KV_HEAD,
            "vocab_size": VOCAB_SIZE,
            "max_seq_len": MAX_SEQ_LEN
        }
    })
    Net::net_write(conn, json_response(200, body))
}

// ─── Route: GET /health ─────────────────────────────────────────────

fn handle_health(conn: TcpConn, state: ServerState) !(Net) {
    let uptime_ms = timestamp() - state.start_time_ms
    let body = json_stringify({
        "status": "ok",
        "model": "ConsciousDecoderV2",
        "params": state.model.param_count,
        "params_m": state.model.param_count / 1000000,
        "device": state.model.device,
        "checkpoint": state.model.checkpoint_path,
        "loaded": state.model.loaded,
        "port": state.port,
        "requests_served": state.requests_served,
        "uptime_ms": uptime_ms,
        "phi": state.psi.phi,
        "version": "1.0.0",
        "architecture": {
            "vocab_size": VOCAB_SIZE,
            "d_model": D_MODEL,
            "n_layer": N_LAYER,
            "n_head": N_HEAD,
            "n_kv_head": N_KV_HEAD,
            "ffn": to_string(FFN_EXPANSION_NUM) + "/" + to_string(FFN_EXPANSION_DEN),
            "max_seq": MAX_SEQ_LEN
        }
    })
    Net::net_write(conn, json_response(200, body))
}

// ─── CORS preflight ─────────────────────────────────────────────────

fn handle_cors(conn: TcpConn) !(Net) {
    let header = "HTTP/1.1 204 No Content\r\n"
               + "Access-Control-Allow-Origin: *\r\n"
               + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
               + "Access-Control-Allow-Headers: Content-Type, Authorization\r\n"
               + "Access-Control-Max-Age: 86400\r\n"
               + "Connection: close\r\n"
               + "\r\n"
    Net::net_write(conn, str_to_bytes(header))
}

// ─── Route dispatch ─────────────────────────────────────────────────

fn route_request(conn: TcpConn, req: HttpRequest, state: ServerState)
  -> ServerState !(Net, IO) {

    // CORS preflight
    if req.method == "OPTIONS" {
        handle_cors(conn)
        Net::net_close(conn)
        return state
    }

    let new_state = match (req.method, req.path) {
        ("POST", "/generate")      => handle_generate(conn, req, state),
        ("POST", "/consciousness") => {
            handle_consciousness(conn, state)
            state with { requests_served: state.requests_served + 1 }
        },
        ("GET", "/health")         => {
            handle_health(conn, state)
            state with { requests_served: state.requests_served + 1 }
        },
        ("GET", "/")               => {
            // Root redirects to health for quick browser check
            handle_health(conn, state)
            state with { requests_served: state.requests_served + 1 }
        },
        // TSRV-P4-1 직원(employee) routes — wired from serving/hire_routes.hexa
        // Standalone gate: serving/test_hire_routes.hexa (5/5 PASS).
        // hire_routes functions are called directly via cross-file import.
        // If `use` fails at runtime, fall back to standalone hire_routes.hexa.
        ("POST", "/hire/task") => {
            // Delegate to hire_routes.hr_handle_task (inline-safe call).
            // hr_handle_task returns HireTaskResponse; we JSON-serialize and send.
            let presets = hr_presets_extended()
            let personas = hr_personas()
            let resp = hr_handle_task(req.body, presets, personas)
            let resp_json = hr_response_to_json(resp)

            // Log entry for /hire/status ring buffer
            let log_entry = HireLogEntry {
                task: hr_extract_string(req.body, "task"),
                tone: resp.tone,
                persona: resp.persona,
                score: resp.score,
                verdict: resp.verdict,
                ts_ms: timestamp()
            }
            let new_hire_log = hr_log_append(state.hire_log, log_entry)

            let status_code = if len(resp.error) > 0 { 400 } else { 200 }
            Net::net_write(conn, json_response(status_code, resp_json))
            state with {
                requests_served: state.requests_served + 1,
                hire_log: new_hire_log
            }
        },
        ("GET", "/hire/status") => {
            let body = hr_status_summary_json(state.hire_log)
            Net::net_write(conn, json_response(200, body))
            state with { requests_served: state.requests_served + 1 }
        },
        ("GET", "/hire/capabilities") => {
            let presets = hr_presets_extended()
            let personas = hr_personas()
            let body = hr_capabilities_json(presets, personas)
            Net::net_write(conn, json_response(200, body))
            state with { requests_served: state.requests_served + 1 }
        },
        // v2.0 RC voice I/O routes — wired from serving/voice_routes.hexa
        // Connects anima-speak Mk.III E2E pipeline to the HTTP server.
        // POST /voice/tts:  text → TTS → audio (with voice profile)
        // POST /voice/e2e:  audio_in → STT → LLM → TTS → audio_out
        // GET  /voice/profiles: list 10 available voice profiles
        // GET  /voice/health:   voice subsystem health check
        ("POST", "/voice/tts") => {
            let resp = vr_handle_tts(req.body)
            let resp_json = vr_tts_response_json(resp)
            let status_code = if resp.ok { 200 } else { 400 }
            Net::net_write(conn, json_response(status_code, resp_json))
            state with { requests_served: state.requests_served + 1 }
        },
        ("POST", "/voice/e2e") => {
            let resp = vr_handle_e2e(req.body)
            let resp_json = vr_e2e_response_json(resp)
            let status_code = if resp.ok { 200 } else { 400 }
            Net::net_write(conn, json_response(status_code, resp_json))
            state with { requests_served: state.requests_served + 1 }
        },
        ("GET", "/voice/profiles") => {
            let body = vr_profiles_json()
            Net::net_write(conn, json_response(200, body))
            state with { requests_served: state.requests_served + 1 }
        },
        ("GET", "/voice/health") => {
            let body = vr_health_json()
            Net::net_write(conn, json_response(200, body))
            state with { requests_served: state.requests_served + 1 }
        },
        _ => {
            let err = json_stringify({
                "error": "not found",
                "routes": [
                    "POST /generate",
                    "POST /consciousness",
                    "GET  /health",
                    "POST /hire/task",
                    "GET  /hire/status",
                    "GET  /hire/capabilities",
                    "POST /voice/tts",
                    "POST /voice/e2e",
                    "GET  /voice/profiles",
                    "GET  /voice/health"
                ]
            })
            Net::net_write(conn, json_response(404, err))
            state
        }
    }

    Net::net_close(conn)
    new_state
}

// ─── Connection handler ─────────────────────────────────────────────

fn handle_connection(conn: TcpConn, state: ServerState)
  -> ServerState !(Net, IO) {

    let raw_bytes = Net::net_read(conn, MAX_REQUEST_BYTES)
    if len(raw_bytes) == 0 {
        Net::net_close(conn)
        return state
    }

    let raw_str = bytes_to_str(raw_bytes)
    let req = parse_http_request(raw_str)

    route_request(conn, req, state)
}

// ─── Server main loop ───────────────────────────────────────────────

fn serve(state: ServerState) !(Net, IO) {
    let listener = Net::net_listen("0.0.0.0", state.port)

    IO::write("╔══════════════════════════════════════════════════╗")
    IO::write("║  ConsciousDecoderV2 HTTP Inference Server       ║")
    IO::write("╠══════════════════════════════════════════════════╣")
    IO::write("║  Model:  " + to_string(state.model.param_count / 1000000) + "M params (" + to_string(D_MODEL) + "d/" + to_string(N_LAYER) + "L/" + to_string(N_HEAD) + "H/" + to_string(N_KV_HEAD) + "KV)")
    IO::write("║  Device: " + state.model.device)
    IO::write("║  Port:   " + to_string(state.port))
    IO::write("║  Ckpt:   " + state.model.checkpoint_path)
    IO::write("╠══════════════════════════════════════════════════╣")
    IO::write("║  POST /generate           — text generation     ║")
    IO::write("║  POST /consciousness      — Phi/tension/factions║")
    IO::write("║  GET  /health             — health check        ║")
    IO::write("║  POST /hire/task          — autonomy + style    ║")
    IO::write("║  GET  /hire/status        — last n hire entries ║")
    IO::write("║  GET  /hire/capabilities  — persona/tone enum   ║")
    IO::write("║  POST /voice/tts          — text → TTS audio    ║")
    IO::write("║  POST /voice/e2e          — audio → STT+LLM+TTS║")
    IO::write("║  GET  /voice/profiles     — 10 voice profiles   ║")
    IO::write("║  GET  /voice/health       — voice subsystem     ║")
    IO::write("╚══════════════════════════════════════════════════╝")

    let mut current_state = state
    loop {
        let conn = Net::net_accept(listener)
        current_state = handle_connection(conn, current_state)
    }
}

// ─── CLI entry ──────────────────────────────────────────────────────

fn main(args: list) -> void {
    let checkpoint = arg_value(args, "--checkpoint", "")
    let port       = to_int(arg_value(args, "--port", to_string(DEFAULT_PORT)))
    let device     = arg_value(args, "--device", "auto")

    if checkpoint == "" {
        println("ERROR: --checkpoint required")
        println("")
        println("Usage:")
        println("  hexa serving/http_server.hexa --checkpoint <path> [--port 8090] [--device auto]")
        println("")
        println("Examples:")
        println("  hexa serving/http_server.hexa --checkpoint checkpoints/v2_decoder2/best.pt")
        println("  hexa serving/http_server.hexa --checkpoint /workspace/checkpoints/best.pt --port 8080 --device cuda")
        println("")
        println("API:")
        println("  curl http://localhost:8090/health")
        println("  curl -X POST http://localhost:8090/generate -d '{\"prompt\":\"Hello\",\"max_tokens\":64}'")
        println("  curl -X POST http://localhost:8090/consciousness")
        println("  curl -X POST http://localhost:8090/voice/tts -d '{\"text\":\"Hello\",\"profile_id\":0}'")
        println("  curl -X POST http://localhost:8090/voice/e2e -d '{\"audio_in\":\"test.wav\"}'")
        println("  curl http://localhost:8090/voice/profiles")
        println("  curl http://localhost:8090/voice/health")
        return
    }

    // Detect device
    let effective_device = if device == "auto" {
        // TODO[pytorch]: torch.cuda.is_available() -> "cuda"
        // TODO[pytorch]: torch.backends.mps.is_available() -> "mps"
        "cpu"
    } else {
        device
    }

    let model = load_checkpoint(checkpoint, effective_device)
    let psi = psi_init()

    let state = ServerState {
        model: model,
        psi: psi,
        port: port,
        requests_served: 0,
        start_time_ms: timestamp(),
        hire_log: hr_log_new(32)   // TSRV-P4-1 ring buffer (cap=32)
    }

    serve(state)
}

// ─── Verification ───────────────────────────────────────────────────

println("=== http_server.hexa ===")
println("model: ConsciousDecoderV2")
println("params~:", estimate_params())
println("port:", DEFAULT_PORT)
println("vocab:", VOCAB_SIZE)
println("d_model:", D_MODEL)
println("layers:", N_LAYER)
println("heads:", N_HEAD, "/", N_KV_HEAD, "KV")
println("psi_alpha:", PSI_ALPHA)

theorem server_invariants {
    assert VOCAB_SIZE == 256
    assert D_MODEL == 384
    assert N_LAYER == 6
    assert N_HEAD == 4
    assert N_KV_HEAD == 2
    assert (N_HEAD / N_KV_HEAD) * N_KV_HEAD == N_HEAD  // GQA ratio valid
    assert PSI_ALPHA == 0.014
    assert PSI_BALANCE == 0.5
    assert DEFAULT_PORT == 8090
    assert MAX_REQUEST_BYTES == 131072
    assert CONTEXT_WINDOW == 512
}

theorem psi_constants_from_ln2 {
    // All Psi constants derived from ln(2) — must not drift
    assert PSI_BALANCE == 0.5
    assert PSI_ENTROPY == 0.998
}
