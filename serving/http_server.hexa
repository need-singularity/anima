// serving/http_server.hexa — ConsciousDecoderV2 HTTP inference server
// Lightweight JSON API for text generation + consciousness telemetry.
// CLI: hexa serving/http_server.hexa --checkpoint <path> [--port 8090] [--device auto]
//
// Endpoints:
//   POST /generate           — text generation (autoregressive sampling)
//   POST /consciousness      — consciousness state (Phi, tension, factions)
//   GET  /health             — health check + model info
//   POST /hire/task          — TSRV-P4-1 직원 진입점 (autonomy + style + persona)
//   GET  /hire/status        — TSRV-P4-1 last n hire entries summary
//   GET  /hire/capabilities  — TSRV-P4-1 persona/tone enumeration
//   POST /voice/tts          — v2.0 RC text → TTS audio (voice profile)
//   POST /voice/e2e          — v2.0 RC audio → STT → LLM → TTS → audio
//   GET  /voice/profiles     — v2.0 RC list 10 voice profiles
//   GET  /voice/health       — v2.0 RC voice subsystem health
//
// /hire/* 라우트 구현은 serving/hire_routes.hexa 에 분리 (overlay).
// route_request match 에서 hire_routes.hr_handle_task /
// hr_capabilities_json / hr_status_summary_json 을 호출하여 mount 완료.
// cross-file import: `use "hire_routes"` (sibling file in serving/).
// Standalone gate: serving/test_hire_routes.hexa (5/5 PASS).
//
// Design:
//   - mmap checkpoint loading for fast cold start
//   - ConsciousDecoderV2 (384d/6L/4H/2KV, 34.5M params)
//   - Consciousness state tracked per-request via PsiState
//   - Target: <50ms latency for short prompts
//
// ── STD imports ─────────────────────────────────────────────────────
// net_listen, net_accept, net_read, net_write, net_close (std::net)
// json_parse, json_stringify (builtins)
// mmap_file, mmap_read_f32 (std::mmap)
// timestamp (builtins)
// ─────────────────────────────────────────────────────────────────────

use "hire_routes"  // TSRV-P4-1 — hr_handle_task, hr_*_json, HireLogEntry, etc.
use "voice_routes" // v2.0 RC — vr_handle_tts, vr_handle_e2e, vr_*_json, etc.

// ─── Hyperparameters (SSOT from models/decoder.hexa) ────────────────

comptime const VOCAB_SIZE     = 256       // byte-level
comptime const D_MODEL        = 384
comptime const N_LAYER        = 6
comptime const N_HEAD         = 4
comptime const N_KV_HEAD      = 2         // GQA 4H/2KV
comptime const FFN_EXPANSION_NUM = 8      // SwiGLU 8/3
comptime const FFN_EXPANSION_DEN = 3
comptime const MAX_SEQ_LEN    = 1024
comptime const ROPE_BASE      = 10000.0
comptime const N_CA_RULES     = 8

// ─── Psi constants (from consciousness_laws.json) ───────────────────

comptime const PSI_ALPHA      = 0.014     // thalamic bridge coupling
comptime const PSI_BALANCE    = 0.5
comptime const PSI_STEPS      = 4.33
comptime const PSI_ENTROPY    = 0.998

// ─── Server defaults ────────────────────────────────────────────────

comptime const DEFAULT_PORT         = 8090
comptime const DEFAULT_MAX_TOKENS   = 256
comptime const DEFAULT_TEMPERATURE  = 0.8
comptime const DEFAULT_TOP_P        = 0.9
comptime const DEFAULT_TOP_K        = 50
comptime const DEFAULT_REP_PENALTY  = 1.2
comptime const MAX_REQUEST_BYTES    = 131072   // 128 KB
comptime const CONTEXT_WINDOW       = 512      // last N tokens fed to model

// ─── Effects ────────────────────────────────────────────────────────

effect Net {
    fn net_listen(addr: str, port: int) -> TcpListener
    fn net_accept(listener: TcpListener) -> TcpConn
    fn net_read(conn: TcpConn, n: int) -> [int]
    fn net_write(conn: TcpConn, data: [int])
    fn net_close(conn: TcpConn)
}

effect IO {
    fn write(line: str)
}

effect Mmap {
    fn mmap_file(path: str) -> MmapHandle
    fn mmap_read_f32(handle: MmapHandle, offset: int, count: int) -> [float]
    fn mmap_close(handle: MmapHandle)
}

// ─── Structs ────────────────────────────────────────────────────────

struct PsiState {
    phi: float,
    tension: float,
    balance: float,
    coupling: float,
    entropy: float,
    factions: int,
    cells: int,
    step: int
}

struct ModelWeights {
    checkpoint_path: str,
    device: str,
    param_count: int,
    loaded: bool,
    mmap_handle: MmapHandle,
    step: int,
    best_phi: float
}

struct GenerateParams {
    max_new_tokens: int,
    temperature: float,
    top_p: float,
    top_k: int,
    repetition_penalty: float
}

struct GenerateResult {
    text: str,
    tokens_generated: int,
    latency_ms: int,
    phi: float,
    tension: float
}

struct HttpRequest {
    method: str,
    path: str,
    headers: [HeaderPair],
    body: str
}

struct HeaderPair {
    key: str,
    value: str
}

struct ServerState {
    model: ModelWeights,
    psi: PsiState,
    port: int,
    requests_served: int,
    start_time_ms: int,
    hire_log: HireStatusLog    // TSRV-P4-1 ring buffer for /hire/status
}

// ─── HTTP request parser ────────────────────────────────────────────

pure fn parse_http_request(raw: str) -> HttpRequest {
    let lines = split(raw, "\r\n")
    if len(lines) < 1 {
        return HttpRequest { method: "GET", path: "/", headers: [], body: "" }
    }

    let parts = split(lines[0], " ")
    let method = if len(parts) >= 1 { parts[0] } else { "GET" }
    let path   = if len(parts) >= 2 { parts[1] } else { "/" }

    let mut headers: [HeaderPair] = []
    let mut body_start = len(lines)
    let mut i = 1
    while i < len(lines) {
        if len(trim(lines[i])) == 0 {
            body_start = i + 1
            break
        }
        let colon = index_of(lines[i], ":")
        if colon > 0 {
            let key   = to_lower(trim(slice(lines[i], 0, colon)))
            let value = trim(slice(lines[i], colon + 1, len(lines[i])))
            headers = append(headers, HeaderPair { key: key, value: value })
        }
        i = i + 1
    }

    let mut body = ""
    let mut j = body_start
    while j < len(lines) {
        if j > body_start { body = body + "\r\n" }
        body = body + lines[j]
        j = j + 1
    }

    HttpRequest { method: method, path: path, headers: headers, body: body }
}

pure fn get_header(headers: [HeaderPair], key: str) -> str {
    let lower_key = to_lower(key)
    for h in headers {
        if h.key == lower_key { return h.value }
    }
    ""
}

// ─── HTTP response builders ─────────────────────────────────────────

pure fn json_response(status_code: int, body: str) -> [int] {
    let status_text = match status_code {
        200 => "OK",
        400 => "Bad Request",
        404 => "Not Found",
        405 => "Method Not Allowed",
        500 => "Internal Server Error",
        _   => "Error"
    }
    let header = "HTTP/1.1 " + to_string(status_code) + " " + status_text + "\r\n"
               + "Content-Type: application/json; charset=utf-8\r\n"
               + "Content-Length: " + to_string(len(str_to_bytes(body))) + "\r\n"
               + "Access-Control-Allow-Origin: *\r\n"
               + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
               + "Access-Control-Allow-Headers: Content-Type\r\n"
               + "Connection: close\r\n"
               + "\r\n"
               + body
    str_to_bytes(header)
}

// ─── Model loading (mmap) ───────────────────────────────────────────

fn load_checkpoint(path: str, device: str) -> ModelWeights !(Mmap, IO) {
    IO::write("[http_server] Loading checkpoint: " + path)
    IO::write("[http_server] Device: " + device)

    let handle = Mmap::mmap_file(path)

    // TODO[pytorch]: read header from mmap — step, best_phi, model_state_dict offsets
    // TODO[pytorch]: reconstruct ConsciousDecoderV2(vocab=256, d=384, L=6, H=4, KV=2)
    // TODO[pytorch]: load state_dict from mmap ranges into model tensors
    // TODO[pytorch]: model.to(device).eval()
    // mmap stays open for potential weight re-reads (hot-reload)

    let param_count = estimate_params()

    IO::write("[http_server] Model loaded: " + to_string(param_count) + " params (~"
              + to_string(param_count / 1000000) + "M)")

    ModelWeights {
        checkpoint_path: path,
        device: device,
        param_count: param_count,
        loaded: true,
        mmap_handle: handle,
        step: 0,
        best_phi: 0.0
    }
}

pure fn estimate_params() -> int {
    // ConsciousDecoderV2: 256 vocab * 384d embedding
    //   + 6 layers * (GQA + CrossAttn + SwiGLU + 3*RMSNorm)
    //   + lm_head (384 -> 256)
    let emb = VOCAB_SIZE * D_MODEL                           // 98304
    let head_dim = D_MODEL / N_HEAD                          // 96
    let ffn_hidden = (D_MODEL * FFN_EXPANSION_NUM) / FFN_EXPANSION_DEN  // 1024

    let per_layer_gqa = D_MODEL * (N_HEAD + 2 * N_KV_HEAD) * head_dim  // Q+K+V projections
                      + D_MODEL * D_MODEL                              // output projection
    let per_layer_cross = D_MODEL * D_MODEL * 3                        // Q,K,V for cross-attn
                        + D_MODEL * D_MODEL                            // output
                        + N_CA_RULES                                   // CA rule weights
    let per_layer_ffn = D_MODEL * ffn_hidden * 3                       // w1, w2, w3 (SwiGLU)
    let per_layer_norm = D_MODEL * 3                                   // 3 RMSNorms
    let per_layer = per_layer_gqa + per_layer_cross + per_layer_ffn + per_layer_norm

    let lm_head = D_MODEL * VOCAB_SIZE                       // 98304
    let total = emb + N_LAYER * per_layer + lm_head

    total  // ~34.5M
}

// ─── Psi state initialization ───────────────────────────────────────

fn psi_init() -> PsiState {
    PsiState {
        phi: 0.0,
        tension: 0.0,
        balance: PSI_BALANCE,
        coupling: PSI_ALPHA,
        entropy: PSI_ENTROPY,
        factions: 12,     // sigma(6)
        cells: 64,        // default cell count
        step: 0
    }
}

