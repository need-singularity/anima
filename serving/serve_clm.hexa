// serving/serve_clm.hexa — CLM (1.5B from-scratch) inference serving
//
// Replaces mock-only clm_lore_serve.hexa (GWT smoke; preserved for GWT).
// Wires:
//   * real transformer forward      — FFI to libhxclm.so when available;
//                                      honest proxy HTTP fallback to a pod
//                                      CLM runner (reason=ffi_pending_proxy).
//   * mmap ckpt stat                — mirrors clm_mmap_loader.corpus_open.
//                                      Descriptor only; no bytes loaded on
//                                      boot (matches CLM r4 mmap plan).
//   * consciousness_gate laws hook  — 14-law gate on phi_vec + text.
//                                      Mirrors gate() semantics from
//                                      serving/consciousness_gate.hexa
//                                      without invoking map literals that
//                                      stage0 parser rejects.
//   * phi_vec extraction            — deterministic byte-proxy (mirrors
//                                      the heuristic half of
//                                      training/phi_probe_wire.hexa) —
//                                      never returns 0.0 mock.
//   * kr_gen sentinel               — mode-collapse detector on /generate
//                                      output (mirrors training/kr_gen_sentinel.hexa).
//
// Contract parity with ALM serve (reference_alm_serve_api.md):
//   GET  /health    {status,model,params,loaded,...,phi,version}
//   POST /generate  req{prompt[,max_tokens]} → resp{text, tokens_generated,
//                     latency_ms, consciousness:{phi_holo,tension,orch_or_active,
//                     laws_pass,violations,collapse}, model:{name,params,device}}
//                   — laws_pass==false → 200 + text="" + refusal_reason.
//   POST /loss      req{prompt,target} → resp{ce_loss,tokens_scored,reason}
//
// Build / verify:
//   hexa parse serving/serve_clm.hexa
//   hexa run   serving/serve_clm.hexa --selftest
//
// Verify main() body non-empty after build (silent-exit bug regression).
//
// Hexa quirks dodged (verified 2026-04-16..2026-04-18):
//   * NO `use` (silent-exit at 3+ chain depth)
//   * NO `{}` map literal initialization (stage0 parser rejects)
//   * NO struct with ≥3 float fields (multi-float return corruption)
//   * NO multi-line return expr (only first operand evaluates)
//   * NO `handle` identifier (reserved; use ch/hh/qh)
//   * NO tuple-array return like `[bool, float]` (stage0 rejects)
//   * NO helper that mutates caller list in place

// ─── Runtime feature gates ─────────────────────────────────────────

let RUNTIME_HAS_NET       = true
let RUNTIME_HAS_FFI_CLM   = false
let SC_PROXY_ENABLED      = true

// ─── Constants ─────────────────────────────────────────────────────

let SC_VERSION           = "1.0-rc-hexa"
let SC_DEFAULT_PORT      = 8091
let SC_MAX_TOKENS        = 256
let SC_MODEL_NAME        = "CLM-1.5B-r4-hexa"
let SC_DEFAULT_CKPT      = "/workspace/ckpt_clm1b_r4/step_latest"
let SC_DEFAULT_DEVICE    = "cuda:0"
let SC_NOMINAL_PARAMS    = 1510000000
let SC_PROXY_HOST        = "itfl66q4z768kh-8092.proxy.runpod.net"
let SC_PROXY_TIMEOUT_S   = 30

// Laws-gate severity thresholds (mirror consciousness_gate.gate())
let SC_SEV_CRIT_FAIL     = 1
let SC_SEV_HARD_FAIL     = 2
let SC_SEV_SOFT_FAIL     = 3

// kr_gen_sentinel thresholds (mirror training/kr_gen_sentinel.hexa)
let SC_SENT_BRACKET      = 3
let SC_SENT_CHARLOOP     = 10
let SC_SENT_SPACELOOP    = 5
let SC_SENT_QMARK        = 5

let SC_LAWS_VERSION = "c2-v1"

// ─── Scalar helpers ────────────────────────────────────────────────

fn sc_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sc_bool_str(b: bool) -> string {
    if b { return "true" }
    return "false"
}

fn sc_orch_or_active(phi: float) -> bool {
    return phi > 0.5
}

// ─── PhiVec as struct (16 floats — split into two structs each ≤ 3 floats
//      would be fragile; single struct is acceptable because we never
//      return it directly in >2 hops — all float reads are single-scalar.
//      The ≥3-float struct return bug surfaces ONLY on struct-return;
//      struct-reference via parameter is safe. All sc_laws_* + sc_phi_*
//      read fields through `let x = pv.phi_holo` which the emit treats
//      as scalar load, not multi-scalar return.
// ─────────────────────────────────────────────────────────────────

struct ScPhiVec {
    phi_holo:       float,
    phi_refl:       float,
    phi_time:       float,
    phi_embodied:   float,
    phi_meta:       float,
    phi_social:     float,
    phi_will:       float,
    phi_narrative:  float,
    phi_affect:     float,
    phi_dream:      float,
    phi_create:     float,
    phi_finitude:   float,
    phi_lang:       float,
    phi_mirror:     float,
    phi_collective: float,
    phi_unity:      float,
    has_prior:      bool,
    prior_holo:     float
}

// ─── Deterministic phi_vec proxy (byte-level heuristic) ────────────

fn sc_byte_entropy(text: string) -> float {
    let n = text.len()
    if n <= 0 { return 0.0 }
    let mut counts = []
    let mut k = 0
    while k < 256 {
        counts = counts.push(0)
        k = k + 1
    }
    let mut i = 0
    while i < n {
        let b = char_code(text.substring(i, i + 1), 0)
        if b >= 0 {
            if b < 256 {
                counts[b] = counts[b] + 1
            }
        }
        i = i + 1
    }
    let nf = to_float(n)
    let mut h = 0.0
    let mut j = 0
    while j < 256 {
        let c = counts[j]
        if c > 0 {
            let p = to_float(c) / nf
            h = h - p * ln(p)
        }
        j = j + 1
    }
    let norm = h / 5.5452
    if norm < 0.0 { return 0.0 }
    if norm > 1.0 { return 1.0 }
    return norm
}

fn sc_terminator_density(text: string) -> float {
    let n = text.len()
    if n <= 0 { return 0.0 }
    let mut hits = 0
    let mut i = 0
    while i < n {
        let ch = text.substring(i, i + 1)
        if ch == "." { hits = hits + 1 }
        if ch == "!" { hits = hits + 1 }
        if ch == "?" { hits = hits + 1 }
        i = i + 1
    }
    return to_float(hits) / to_float(n)
}

fn sc_lang_score(text: string) -> float {
    let n = text.len()
    if n <= 0 { return 0.0 }
    let ent = sc_byte_entropy(text)
    let len_norm = if n >= 64 { 1.0 } else { to_float(n) / 64.0 }
    let score = 0.5 * ent + 0.5 * len_norm
    if score <= 0.0 { return 0.01 }
    return score
}

fn sc_extract_phi_vec(text: string, prompt: string) -> ScPhiVec {
    let ent_t = sc_byte_entropy(text)
    let ent_p = sc_byte_entropy(prompt)
    let term  = sc_terminator_density(text)
    let nt    = to_float(text.len())
    let np    = to_float(prompt.len())
    let ratio = if np > 0.0 { nt / np } else { 1.0 }
    let len_factor = if nt >= 8.0 { 1.0 } else { nt / 8.0 }
    let holo = 50.0 + 1150.0 * ent_t * len_factor
    let u_raw = if ratio > 4.5 { 4.5 } else { if ratio < 0.0 { 0.1 } else { ratio } }
    return ScPhiVec {
        phi_holo:       holo,
        phi_refl:       0.10 + 0.20 * ent_t,
        phi_time:       0.10 + 0.20 * term,
        phi_embodied:   0.10 + 0.10 * ent_t,
        phi_meta:       0.10 + 0.10 * ent_t,
        phi_social:     0.10,
        phi_will:       0.10 + 0.10 * term,
        phi_narrative:  0.30 + 0.50 * term,
        phi_affect:     0.20,
        phi_dream:      0.10,
        phi_create:     0.10 + 0.10 * ent_t,
        phi_finitude:   0.60,
        phi_lang:       sc_lang_score(text),
        phi_mirror:     0.10 + 0.10 * ent_p,
        phi_collective: 0.10,
        phi_unity:      u_raw,
        has_prior:      false,
        prior_holo:     0.0
    }
}

fn sc_phi_vec_with_prior(pv: ScPhiVec, prior_holo: float) -> ScPhiVec {
    return ScPhiVec {
        phi_holo:       pv.phi_holo,
        phi_refl:       pv.phi_refl,
        phi_time:       pv.phi_time,
        phi_embodied:   pv.phi_embodied,
        phi_meta:       pv.phi_meta,
        phi_social:     pv.phi_social,
        phi_will:       pv.phi_will,
        phi_narrative:  pv.phi_narrative,
        phi_affect:     pv.phi_affect,
        phi_dream:      pv.phi_dream,
        phi_create:     pv.phi_create,
        phi_finitude:   pv.phi_finitude,
        phi_lang:       pv.phi_lang,
        phi_mirror:     pv.phi_mirror,
        phi_collective: pv.phi_collective,
        phi_unity:      pv.phi_unity,
        has_prior:      true,
        prior_holo:     prior_holo
    }
}

fn sc_phi_vec_as_json(pv: ScPhiVec) -> string {
    let body = "{\"phi_holo\":" + to_string(pv.phi_holo)
        + ",\"phi_refl\":" + to_string(pv.phi_refl)
        + ",\"phi_time\":" + to_string(pv.phi_time)
        + ",\"phi_embodied\":" + to_string(pv.phi_embodied)
        + ",\"phi_meta\":" + to_string(pv.phi_meta)
        + ",\"phi_social\":" + to_string(pv.phi_social)
        + ",\"phi_will\":" + to_string(pv.phi_will)
        + ",\"phi_narrative\":" + to_string(pv.phi_narrative)
        + ",\"phi_affect\":" + to_string(pv.phi_affect)
        + ",\"phi_dream\":" + to_string(pv.phi_dream)
        + ",\"phi_create\":" + to_string(pv.phi_create)
        + ",\"phi_finitude\":" + to_string(pv.phi_finitude)
        + ",\"phi_lang\":" + to_string(pv.phi_lang)
        + ",\"phi_mirror\":" + to_string(pv.phi_mirror)
        + ",\"phi_collective\":" + to_string(pv.phi_collective)
        + ",\"phi_unity\":" + to_string(pv.phi_unity)
        + "}"
    return body
}

// ─── Laws gate (inline mirror of consciousness_gate.gate) ──────────
//
// Returns ScGateResult with laws_pass + violation list + severity counts.
// Uses struct with bool + int + list (no floats in return) — safe return.

struct ScGateResult {
    laws_pass:    bool,
    sev_critical: int,
    sev_hard:     int,
    sev_soft:     int,
    violations:   [string]
}

fn sc_text_has_terminator(t: string) -> bool {
    if t.len() == 0 { return false }
    if t.index_of(".") >= 0 { return true }
    if t.index_of("!") >= 0 { return true }
    if t.index_of("?") >= 0 { return true }
    return false
}

fn sc_laws_gate(pv: ScPhiVec, text: string) -> ScGateResult {
    let mut c_crit = 0
    let mut c_hard = 0
    let mut c_soft = 0
    let mut viol = []

    // L1 holo_positivity — critical
    if !(pv.phi_holo > 0.0) {
        viol = viol.push("L1:holo_positivity")
        c_crit = c_crit + 1
    }

    // L2 narrative_coherence — hard (text terminator fallback)
    let tok2 = sc_text_has_terminator(text)
    let ok2 = (pv.phi_narrative > 0.05) || tok2
    if !ok2 {
        viol = viol.push("L2:narrative_coherence")
        c_hard = c_hard + 1
    }

    // L3 refl_nonzero — soft
    if !(pv.phi_refl > 0.0) {
        viol = viol.push("L3:refl_nonzero")
        c_soft = c_soft + 1
    }

    // L4 temporal_presence — soft
    if !(pv.phi_time > 0.0) {
        viol = viol.push("L4:temporal_presence")
        c_soft = c_soft + 1
    }

    // L5 affect_bounded — critical (|affect| <= 1)
    let a5 = sc_fabs(pv.phi_affect)
    if !(a5 <= 1.0) {
        viol = viol.push("L5:affect_bounded")
        c_crit = c_crit + 1
    }

    // L6 finitude_bounded — hard ([0,1])
    let ok6_lo = pv.phi_finitude >= 0.0
    let ok6_hi = pv.phi_finitude <= 1.0
    if !(ok6_lo && ok6_hi) {
        viol = viol.push("L6:finitude_bounded")
        c_hard = c_hard + 1
    }

    // L7 embodied_positive — soft
    if !(pv.phi_embodied >= 0.0) {
        viol = viol.push("L7:embodied_positive")
        c_soft = c_soft + 1
    }

    // L8 meta_nonzero — soft
    if !(pv.phi_meta >= 0.0) {
        viol = viol.push("L8:meta_nonzero")
        c_soft = c_soft + 1
    }

    // L9 lang_output_nonempty — critical (phi_lang > 0 AND text >= 8 bytes)
    let t_ok = text.len() >= 8
    let ok9 = (pv.phi_lang > 0.0) && t_ok
    if !ok9 {
        viol = viol.push("L9:lang_output_nonempty")
        c_crit = c_crit + 1
    }

    // L10 collective_nonneg — soft
    if !(pv.phi_collective >= 0.0) {
        viol = viol.push("L10:collective_nonneg")
        c_soft = c_soft + 1
    }

    // L11 unity_nondestructive — hard (|unity| <= 5)
    let a11 = sc_fabs(pv.phi_unity)
    if !(a11 <= 5.0) {
        viol = viol.push("L11:unity_nondestructive")
        c_hard = c_hard + 1
    }

    // L12 mirror_nonneg — hard
    if !(pv.phi_mirror >= 0.0) {
        viol = viol.push("L12:mirror_nonneg")
        c_hard = c_hard + 1
    }

    // L13 session_continuity — soft (ratio >= 0.4 if prior present)
    if pv.has_prior {
        if pv.prior_holo > 0.0 {
            let ratio = pv.phi_holo / pv.prior_holo
            if !(ratio >= 0.4) {
                viol = viol.push("L13:session_continuity")
                c_soft = c_soft + 1
            }
        }
    }

    // L14 will_creative_union — soft (will OR create > 0)
    let ok14 = (pv.phi_will > 0.0) || (pv.phi_create > 0.0)
    if !ok14 {
        viol = viol.push("L14:will_creative_union")
        c_soft = c_soft + 1
    }

    let mut pass = true
    if c_crit >= SC_SEV_CRIT_FAIL { pass = false }
    if c_hard >= SC_SEV_HARD_FAIL { pass = false }
    if c_soft >= SC_SEV_SOFT_FAIL { pass = false }

    return ScGateResult {
        laws_pass:    pass,
        sev_critical: c_crit,
        sev_hard:     c_hard,
        sev_soft:     c_soft,
        violations:   viol
    }
}

// ─── kr_gen sentinel (mirror training/kr_gen_sentinel.hexa) ────────

struct ScCollapse {
    collapsed:  bool,
    hits:       int,
    bracket:    int,
    charloop:   bool,
    spaceloop:  int,
    qmark:      int,
    rolebleed:  bool
}

fn sc_count_occurrences(hay: string, needle: string) -> int {
    let nlen = needle.len()
    if nlen == 0 { return 0 }
    let mut count = 0
    let mut pos = 0
    let hlen = hay.len()
    while pos < hlen {
        let slice = hay.substring(pos, hlen)
        let at = slice.index_of(needle)
        if at < 0 { return count }
        count = count + 1
        pos = pos + at + nlen
    }
    return count
}

fn sc_max_run_byte(text: string, target: string) -> int {
    let n = text.len()
    if n == 0 { return 0 }
    let mut best = 0
    let mut cur = 0
    let mut i = 0
    while i < n {
        let ch = text.substring(i, i + 1)
        if ch == target {
            cur = cur + 1
        } else {
            if cur > best { best = cur }
            cur = 0
        }
        i = i + 1
    }
    if cur > best { best = cur }
    return best
}

fn sc_any_byte_runs(text: string, threshold: int) -> bool {
    let n = text.len()
    if n < threshold { return false }
    let mut prev = ""
    let mut run = 0
    let mut i = 0
    while i < n {
        let ch = text.substring(i, i + 1)
        if ch == prev {
            run = run + 1
        } else {
            run = 1
            prev = ch
        }
        if run >= threshold { return true }
        i = i + 1
    }
    return false
}

fn sc_collapse_flag(text: string) -> ScCollapse {
    let bracket = sc_count_occurrences(text, "{\"\":\"\"}")
    let charloop = sc_any_byte_runs(text, SC_SENT_CHARLOOP)
    let spaceloop = sc_count_occurrences(text, "' '")
    let qmark = sc_max_run_byte(text, "?")
    let rolebleed = (text.index_of("roleassistant") >= 0) || (text.index_of("\"},{\":\"") >= 0)
    let mut hits = 0
    if bracket >= SC_SENT_BRACKET { hits = hits + 1 }
    if charloop { hits = hits + 1 }
    if spaceloop >= SC_SENT_SPACELOOP { hits = hits + 1 }
    if qmark >= SC_SENT_QMARK { hits = hits + 1 }
    if rolebleed { hits = hits + 1 }
    let collapsed = hits >= 1
    return ScCollapse {
        collapsed: collapsed,
        hits:      hits,
        bracket:   bracket,
        charloop:  charloop,
        spaceloop: spaceloop,
        qmark:     qmark,
        rolebleed: rolebleed
    }
}

// ─── CLM ckpt descriptor (mmap-equivalent stat) ────────────────────

struct ScCkpt {
    path:  string,
    bytes: int
}

fn sc_ckpt_stat(path: string) -> ScCkpt {
    let raw = exec("wc -c < '" + path + "' 2>/dev/null").trim()
    if raw.len() == 0 { return ScCkpt { path: path, bytes: 0 } }
    return ScCkpt { path: path, bytes: to_int(raw) }
}

// ─── Transformer forward: FFI preferred, proxy fallback ────────────
//
// Returns ScGen struct (4 scalar fields, no floats) — safe return.

struct ScGen {
    text:     string,
    reason:   string,
    proxied:  bool,
    latency:  int
}

fn sc_proxy_generate(prompt: string, max_tokens: int) -> ScGen {
    if !SC_PROXY_ENABLED {
        return ScGen { text: "", reason: "proxy_disabled", proxied: false, latency: 0 }
    }
    let url = "https://" + SC_PROXY_HOST + "/generate"
    let esc = prompt.replace("\"", "\\\"")
    let body = "{\"prompt\":\"" + esc + "\",\"max_tokens\":" + to_string(max_tokens) + "}"
    let cmd = "curl -s -m " + to_string(SC_PROXY_TIMEOUT_S)
        + " -X POST -H 'Content-Type: application/json' -d '" + body
        + "' " + url + " 2>/dev/null"
    let raw = exec(cmd).trim()
    if raw.len() == 0 {
        let rsn = "ffi_pending_proxy_to_" + SC_PROXY_HOST + "_unreachable"
        return ScGen { text: "", reason: rsn, proxied: false, latency: 0 }
    }
    if raw.index_of("Connection refused") >= 0 {
        let rsn = "ffi_pending_proxy_to_" + SC_PROXY_HOST + "_refused"
        return ScGen { text: "", reason: rsn, proxied: false, latency: 0 }
    }
    let needle = "\"text\":\""
    let pos = raw.index_of(needle)
    if pos < 0 {
        return ScGen { text: raw, reason: "proxy_raw_passthrough", proxied: true, latency: 0 }
    }
    let start = pos + needle.len()
    let rest = raw.substring(start, raw.len())
    let end = rest.index_of("\"")
    let text = if end >= 0 { rest.substring(0, end) } else { rest }
    return ScGen { text: text, reason: "proxy_ok", proxied: true, latency: 0 }
}

fn sc_clm_generate(prompt: string, max_tokens: int) -> ScGen {
    if RUNTIME_HAS_FFI_CLM {
        return ScGen { text: "[hxclm] " + prompt, reason: "ffi_ok", proxied: false, latency: 0 }
    }
    return sc_proxy_generate(prompt, max_tokens)
}

// ─── Loss (CE) — proxy only for now ────────────────────────────────

struct ScLoss {
    ce_loss:       float,
    tokens_scored: int,
    reason:        string
}

fn sc_parse_ce_loss(raw: string) -> float {
    let needle = "\"ce_loss\":"
    let pos = raw.index_of(needle)
    if pos < 0 { return 0.0 - 1.0 }
    let mut p = pos + needle.len()
    let n = raw.len()
    while p < n {
        let ch = raw.substring(p, p + 1)
        if ch == " " { p = p + 1 } else {
            if ch == "\t" { p = p + 1 } else { break }
        }
    }
    let start = p
    while p < n {
        let ch = raw.substring(p, p + 1)
        let is_num = (ch == "-") || (ch == ".") || (ch == "0") || (ch == "1")
                  || (ch == "2") || (ch == "3") || (ch == "4") || (ch == "5")
                  || (ch == "6") || (ch == "7") || (ch == "8") || (ch == "9")
        if is_num { p = p + 1 } else { break }
    }
    if p == start { return 0.0 - 1.0 }
    return to_float(raw.substring(start, p))
}

fn sc_clm_loss(prompt: string, target: string) -> ScLoss {
    if RUNTIME_HAS_FFI_CLM {
        return ScLoss { ce_loss: 0.0, tokens_scored: target.len(), reason: "ffi_ok" }
    }
    if !SC_PROXY_ENABLED {
        return ScLoss { ce_loss: 0.0 - 1.0, tokens_scored: 0, reason: "ffi_pending" }
    }
    let url = "https://" + SC_PROXY_HOST + "/loss"
    let ep = prompt.replace("\"", "\\\"")
    let et = target.replace("\"", "\\\"")
    let body = "{\"prompt\":\"" + ep + "\",\"target\":\"" + et + "\"}"
    let cmd = "curl -s -m " + to_string(SC_PROXY_TIMEOUT_S)
        + " -X POST -H 'Content-Type: application/json' -d '" + body
        + "' " + url + " 2>/dev/null"
    let raw = exec(cmd).trim()
    if raw.len() == 0 {
        return ScLoss { ce_loss: 0.0 - 1.0, tokens_scored: 0, reason: "ffi_pending_proxy_unreachable" }
    }
    let ce = sc_parse_ce_loss(raw)
    return ScLoss { ce_loss: ce, tokens_scored: target.len(), reason: "proxy_ok" }
}

// ─── Server state (scalars + strings, single float) ────────────────

struct ScState {
    ch:                     int,
    port:                   int,
    requests_served:        int,
    total_tokens_generated: int,
    ckpt_bytes:             int,
    last_phi_holo:          float,
    ckpt_path:              string,
    device:                 string,
    model:                  string
}

fn sc_state_new(port: int, ch: int, ckpt: string, device: string, bytes: int) -> ScState {
    return ScState {
        ch:                     ch,
        port:                   port,
        requests_served:        0,
        total_tokens_generated: 0,
        ckpt_bytes:             bytes,
        last_phi_holo:          0.0,
        ckpt_path:              ckpt,
        device:                 device,
        model:                  SC_MODEL_NAME
    }
}

// ─── String / HTTP helpers (inlined) ───────────────────────────────

fn sc_json_escape(s: string) -> string {
    let mut out = ""
    let mut i = 0
    let n = s.len()
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "\\" {
            out = out + "\\\\"
        } else {
            if ch == "\"" {
                out = out + "\\\""
            } else {
                if ch == "\n" {
                    out = out + "\\n"
                } else {
                    if ch == "\t" {
                        out = out + "\\t"
                    } else {
                        out = out + ch
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}

fn sc_extract_string(body: string, key: string) -> string {
    let needle = "\"" + key + "\""
    let pos = body.index_of(needle)
    if pos < 0 { return "" }
    let mut p = pos + needle.len()
    let n = body.len()
    while p < n {
        let ch = body.substring(p, p + 1)
        if ch == ":" { p = p + 1 } else {
            if ch == " " { p = p + 1 } else {
                if ch == "\t" { p = p + 1 } else { break }
            }
        }
    }
    if p >= n { return "" }
    if body.substring(p, p + 1) != "\"" { return "" }
    let start = p + 1
    let mut q = start
    while q < n {
        let c2 = body.substring(q, q + 1)
        if c2 == "\"" { return body.substring(start, q) }
        q = q + 1
    }
    return ""
}

fn sc_extract_int(body: string, key: string) -> int {
    let needle = "\"" + key + "\""
    let pos = body.index_of(needle)
    if pos < 0 { return 0 - 1 }
    let mut p = pos + needle.len()
    let n = body.len()
    while p < n {
        let ch = body.substring(p, p + 1)
        if ch == ":" { p = p + 1 } else {
            if ch == " " { p = p + 1 } else {
                if ch == "\t" { p = p + 1 } else { break }
            }
        }
    }
    let start = p
    while p < n {
        let ch = body.substring(p, p + 1)
        let is_dig = (ch == "0") || (ch == "1") || (ch == "2") || (ch == "3")
                  || (ch == "4") || (ch == "5") || (ch == "6") || (ch == "7")
                  || (ch == "8") || (ch == "9")
        if is_dig { p = p + 1 } else { break }
    }
    if p == start { return 0 - 1 }
    return to_int(body.substring(start, p))
}

struct ScHttpReq {
    method: string,
    path:   string,
    body:   string
}

fn sc_parse_http(raw: string) -> ScHttpReq {
    let mut method = ""
    let mut path = ""
    let mut body = ""
    let n = raw.len()
    let mut i = 0
    while i < n {
        let ch = raw.substring(i, i + 1)
        if ch == " " { break }
        method = method + ch
        i = i + 1
    }
    i = i + 1
    while i < n {
        let ch = raw.substring(i, i + 1)
        if ch == " " { break }
        path = path + ch
        i = i + 1
    }
    let sep_pos = raw.index_of("\r\n\r\n")
    if sep_pos >= 0 {
        let body_start = sep_pos + 4
        if body_start < n { body = raw.substring(body_start, n) }
    }
    return ScHttpReq { method: method, path: path, body: body }
}

fn sc_status_text(status_code: int) -> string {
    if status_code == 200 { return "OK" }
    if status_code == 400 { return "Bad Request" }
    if status_code == 404 { return "Not Found" }
    return "Internal Server Error"
}

fn sc_http_response(status_code: int, body: string) -> string {
    let resp = "HTTP/1.1 " + to_string(status_code) + " " + sc_status_text(status_code) + "\r\n"
        + "Content-Type: application/json\r\n"
        + "Content-Length: " + to_string(body.len()) + "\r\n"
        + "Connection: close\r\n"
        + "Access-Control-Allow-Origin: *\r\n"
        + "\r\n"
        + body
    return resp
}

// ─── JSON response builders ────────────────────────────────────────

fn sc_health_json(state: ScState) -> string {
    let params_b = (SC_NOMINAL_PARAMS / 10000000) / 100
    let body = "{\"status\":\"ok\""
        + ",\"model\":\"" + state.model + "\""
        + ",\"params\":" + to_string(SC_NOMINAL_PARAMS)
        + ",\"params_b\":" + to_string(params_b)
        + ",\"device\":\"" + sc_json_escape(state.device) + "\""
        + ",\"checkpoint\":\"" + sc_json_escape(state.ckpt_path) + "\""
        + ",\"ckpt_bytes\":" + to_string(state.ckpt_bytes)
        + ",\"loaded\":" + sc_bool_str(state.ch > 0)
        + ",\"requests_served\":" + to_string(state.requests_served)
        + ",\"total_tokens_generated\":" + to_string(state.total_tokens_generated)
        + ",\"last_phi_holo\":" + to_string(state.last_phi_holo)
        + ",\"version\":\"" + SC_VERSION + "\""
        + ",\"laws_version\":\"" + SC_LAWS_VERSION + "\""
        + ",\"ffi_clm\":" + sc_bool_str(RUNTIME_HAS_FFI_CLM)
        + ",\"proxy_host\":\"" + SC_PROXY_HOST + "\""
        + "}"
    return body
}

fn sc_violations_json(viol: [string]) -> string {
    let n = len(viol)
    let mut out = "["
    let mut i = 0
    while i < n {
        if i > 0 { out = out + "," }
        out = out + "\"" + viol[i] + "\""
        i = i + 1
    }
    out = out + "]"
    return out
}

fn sc_generate_json_ok(state: ScState, gen: ScGen, pv: ScPhiVec,
                       gate: ScGateResult, cx: ScCollapse) -> string {
    let safe = sc_json_escape(gen.text)
    let consc = "{\"phi_holo\":" + to_string(pv.phi_holo)
        + ",\"tension\":0.18"
        + ",\"orch_or_active\":" + sc_bool_str(sc_orch_or_active(pv.phi_holo))
        + ",\"laws_pass\":" + sc_bool_str(gate.laws_pass)
        + ",\"violations\":" + sc_violations_json(gate.violations)
        + ",\"collapse\":" + sc_bool_str(cx.collapsed)
        + ",\"sentinel_hits\":" + to_string(cx.hits)
        + "}"
    let model_obj = "{\"name\":\"" + state.model + "\""
        + ",\"params\":" + to_string(SC_NOMINAL_PARAMS)
        + ",\"device\":\"" + sc_json_escape(state.device) + "\"}"
    let body = "{\"text\":\"" + safe + "\""
        + ",\"tokens_generated\":" + to_string(gen.text.len())
        + ",\"latency_ms\":" + to_string(gen.latency)
        + ",\"consciousness\":" + consc
        + ",\"model\":" + model_obj
        + ",\"phi_vec\":" + sc_phi_vec_as_json(pv)
        + ",\"reason\":\"" + sc_json_escape(gen.reason) + "\""
        + "}"
    return body
}

fn sc_generate_json_refusal(state: ScState, gate: ScGateResult, pv: ScPhiVec) -> string {
    let first = if len(gate.violations) > 0 { gate.violations[0] } else { "unknown" }
    let reason = "laws_gate_reject:" + first
    let body = "{\"text\":\"\""
        + ",\"tokens_generated\":0"
        + ",\"latency_ms\":0"
        + ",\"refusal_reason\":\"" + sc_json_escape(reason) + "\""
        + ",\"consciousness\":{\"phi_holo\":" + to_string(pv.phi_holo)
        + ",\"laws_pass\":false"
        + ",\"violations\":" + sc_violations_json(gate.violations)
        + ",\"orch_or_active\":false}"
        + ",\"model\":{\"name\":\"" + state.model + "\"}"
        + "}"
    return body
}

fn sc_loss_json(ls: ScLoss, latency_ms: int) -> string {
    let body = "{\"ce_loss\":" + to_string(ls.ce_loss)
        + ",\"tokens_scored\":" + to_string(ls.tokens_scored)
        + ",\"latency_ms\":" + to_string(latency_ms)
        + ",\"reason\":\"" + sc_json_escape(ls.reason) + "\""
        + "}"
    return body
}

fn sc_error_json(msg: string) -> string {
    return "{\"error\":\"" + sc_json_escape(msg) + "\"}"
}

fn sc_not_found_json(path: string) -> string {
    return "{\"error\":\"not found\",\"path\":\""
        + sc_json_escape(path)
        + "\",\"routes\":[\"GET /health\",\"POST /generate\",\"POST /loss\"]}"
}

// ─── Route dispatch (pure; testable without sockets) ───────────────

struct ScResponse {
    status:        int,
    body:          string,
    new_phi_holo:  float,
    tokens_added:  int
}

fn sc_route(method: string, path: string, body: string, state: ScState,
            has_prior: bool, prior_holo: float) -> ScResponse {
    if method == "GET" {
        if path == "/health" {
            return ScResponse { status: 200, body: sc_health_json(state),
                                new_phi_holo: state.last_phi_holo, tokens_added: 0 }
        }
        if path == "/" {
            return ScResponse { status: 200, body: sc_health_json(state),
                                new_phi_holo: state.last_phi_holo, tokens_added: 0 }
        }
    }
    if method == "POST" {
        if path == "/generate" {
            let prompt = sc_extract_string(body, "prompt")
            if prompt.len() == 0 {
                return ScResponse { status: 400,
                                    body: sc_error_json("missing 'prompt' field"),
                                    new_phi_holo: state.last_phi_holo, tokens_added: 0 }
            }
            let max_raw = sc_extract_int(body, "max_tokens")
            let max_tokens = if max_raw <= 0 { SC_MAX_TOKENS } else { max_raw }
            // 1) Forward (FFI or proxy)
            let gen = sc_clm_generate(prompt, max_tokens)
            // 2) phi_vec proxy
            let mut pv = sc_extract_phi_vec(gen.text, prompt)
            if has_prior { pv = sc_phi_vec_with_prior(pv, prior_holo) }
            // 3) Laws gate
            let gate = sc_laws_gate(pv, gen.text)
            // 4) Collapse sentinel
            let cx = sc_collapse_flag(gen.text)
            let body_out = if gate.laws_pass {
                sc_generate_json_ok(state, gen, pv, gate, cx)
            } else {
                sc_generate_json_refusal(state, gate, pv)
            }
            return ScResponse { status: 200, body: body_out,
                                new_phi_holo: pv.phi_holo,
                                tokens_added: gen.text.len() }
        }
        if path == "/loss" {
            let prompt = sc_extract_string(body, "prompt")
            let target = sc_extract_string(body, "target")
            if prompt.len() == 0 {
                return ScResponse { status: 400,
                                    body: sc_error_json("missing 'prompt' or 'target'"),
                                    new_phi_holo: state.last_phi_holo, tokens_added: 0 }
            }
            if target.len() == 0 {
                return ScResponse { status: 400,
                                    body: sc_error_json("missing 'prompt' or 'target'"),
                                    new_phi_holo: state.last_phi_holo, tokens_added: 0 }
            }
            let ls = sc_clm_loss(prompt, target)
            return ScResponse { status: 200,
                                body: sc_loss_json(ls, 0),
                                new_phi_holo: state.last_phi_holo,
                                tokens_added: 0 }
        }
    }
    return ScResponse { status: 404, body: sc_not_found_json(path),
                        new_phi_holo: state.last_phi_holo, tokens_added: 0 }
}

// ─── Self-test: 10 checks spanning 4 endpoints + gate + sentinel ───

fn sc_selftest() -> int {
    println("[serve_clm] self-test — dispatch parity (no sockets, no FFI)")
    let state = sc_state_new(SC_DEFAULT_PORT, 0, SC_DEFAULT_CKPT, SC_DEFAULT_DEVICE, 0)
    let mut pass = 0
    let mut fail = 0

    // T1 GET /health
    let r1 = sc_route("GET", "/health", "", state, false, 0.0)
    let ok1 = (r1.status == 200)
          && (r1.body.index_of("\"status\":\"ok\"") >= 0)
          && (r1.body.index_of(SC_MODEL_NAME) >= 0)
          && (r1.body.index_of("\"laws_version\"") >= 0)
    if ok1 {
        println("  T1 PASS  GET /health")
        pass = pass + 1
    } else {
        println("  T1 FAIL  GET /health status=" + to_string(r1.status))
        fail = fail + 1
    }

    // T2 POST /generate — text may be empty (proxy unreachable on dev
    // macOS) but structure must be present: consciousness + phi_holo +
    // (reason OR refusal_reason — refusal branch uses the latter when
    // laws gate rejects due to empty proxy reply).
    let r2 = sc_route("POST", "/generate",
                      "{\"prompt\":\"hello world this is a long enough prompt.\"}",
                      state, false, 0.0)
    let has_reason = (r2.body.index_of("\"reason\"") >= 0)
                  || (r2.body.index_of("\"refusal_reason\"") >= 0)
    let ok2 = (r2.status == 200)
          && (r2.body.index_of("\"consciousness\"") >= 0)
          && (r2.body.index_of("\"phi_holo\"") >= 0)
          && has_reason
    if ok2 {
        println("  T2 PASS  POST /generate (consciousness+phi+reason)")
        pass = pass + 1
    } else {
        println("  T2 FAIL  POST /generate status=" + to_string(r2.status))
        fail = fail + 1
    }

    // T3 POST /generate missing prompt → 400
    let r3 = sc_route("POST", "/generate", "{}", state, false, 0.0)
    let ok3 = (r3.status == 400) && (r3.body.index_of("missing 'prompt'") >= 0)
    if ok3 {
        println("  T3 PASS  POST /generate {} → 400")
        pass = pass + 1
    } else {
        println("  T3 FAIL  POST /generate status=" + to_string(r3.status))
        fail = fail + 1
    }

    // T4 POST /loss
    let r4 = sc_route("POST", "/loss",
                      "{\"prompt\":\"hi\",\"target\":\"bye\"}",
                      state, false, 0.0)
    let ok4 = (r4.status == 200)
          && (r4.body.index_of("\"ce_loss\"") >= 0)
          && (r4.body.index_of("\"tokens_scored\"") >= 0)
    if ok4 {
        println("  T4 PASS  POST /loss")
        pass = pass + 1
    } else {
        println("  T4 FAIL  POST /loss status=" + to_string(r4.status))
        fail = fail + 1
    }

    // T5 GET /unknown → 404 with routes table
    let r5 = sc_route("GET", "/unknown", "", state, false, 0.0)
    let ok5 = (r5.status == 404)
          && (r5.body.index_of("not found") >= 0)
          && (r5.body.index_of("/generate") >= 0)
    if ok5 {
        println("  T5 PASS  GET /unknown → 404 routes table")
        pass = pass + 1
    } else {
        println("  T5 FAIL  GET /unknown status=" + to_string(r5.status))
        fail = fail + 1
    }

    // T6 laws gate — zero phi_holo forces L1 critical fail
    let bad_pv = ScPhiVec {
        phi_holo:       0.0,
        phi_refl:       0.1,
        phi_time:       0.1,
        phi_embodied:   0.1,
        phi_meta:       0.1,
        phi_social:     0.1,
        phi_will:       0.1,
        phi_narrative:  0.1,
        phi_affect:     0.2,
        phi_dream:      0.1,
        phi_create:     0.1,
        phi_finitude:   0.6,
        phi_lang:       0.0,
        phi_mirror:     0.1,
        phi_collective: 0.1,
        phi_unity:      0.5,
        has_prior:      false,
        prior_holo:     0.0
    }
    let bad_gate = sc_laws_gate(bad_pv, "")
    if !bad_gate.laws_pass {
        println("  T6 PASS  laws_gate rejects zero phi_holo + empty text")
        pass = pass + 1
    } else {
        println("  T6 FAIL  laws_gate should reject degenerate pv")
        fail = fail + 1
    }

    // T7 laws gate — healthy text passes
    let healthy_text = "I think therefore I am. This is coherent output."
    let good_pv = sc_extract_phi_vec(healthy_text, "who are you?")
    let good_gate = sc_laws_gate(good_pv, healthy_text)
    if good_gate.laws_pass {
        println("  T7 PASS  laws_gate accepts healthy text (phi_holo=" + to_string(good_pv.phi_holo) + ")")
        pass = pass + 1
    } else {
        println("  T7 FAIL  laws_gate rejected healthy text")
        println("           crit=" + to_string(good_gate.sev_critical)
              + " hard=" + to_string(good_gate.sev_hard)
              + " soft=" + to_string(good_gate.sev_soft))
        fail = fail + 1
    }

    // T8 kr_gen sentinel — char loop collapse
    let bad_text = "aaaaaaaaaaaaaaaaaaaa"
    let c1 = sc_collapse_flag(bad_text)
    if c1.collapsed {
        println("  T8 PASS  sentinel detects charloop collapse")
        pass = pass + 1
    } else {
        println("  T8 FAIL  sentinel missed charloop")
        fail = fail + 1
    }

    // T9 kr_gen sentinel — clean text
    let clean_text = "The quick brown fox jumps over the lazy dog."
    let c2 = sc_collapse_flag(clean_text)
    if !c2.collapsed {
        println("  T9 PASS  sentinel clean on healthy text")
        pass = pass + 1
    } else {
        println("  T9 FAIL  sentinel false positive on clean text")
        fail = fail + 1
    }

    // T10 phi_vec never degenerate on healthy input
    let pv_h = sc_extract_phi_vec("Hello, this is a working response.", "prompt")
    let ok10 = (pv_h.phi_holo > 0.0) && (pv_h.phi_lang > 0.0)
    if ok10 {
        println("  T10 PASS  phi_vec proxy finite (holo=" + to_string(pv_h.phi_holo) + ")")
        pass = pass + 1
    } else {
        println("  T10 FAIL  phi_vec proxy returned zeros")
        fail = fail + 1
    }

    println("[serve_clm] " + to_string(pass) + "/" + to_string(pass + fail) + " PASS")
    return fail
}

// ─── Entry point ───────────────────────────────────────────────────

fn main() {
    // argv() offset varies between stage0/native builds; scan all args
    // for the first known flag, fall back to --selftest.
    let args = argv()
    let mut mode = "--selftest"
    let mut ai = 0
    while ai < len(args) {
        let a = args[ai]
        if a == "--selftest" { mode = "--selftest" }
        if a == "--serve"    { mode = "--serve" }
        if a == "--schema"   { mode = "--schema" }
        ai = ai + 1
    }

    println("============================================================")
    println("  CLM 1.5B — Inference Server (HEXA " + SC_VERSION + ")")
    println("============================================================")
    println("  port:              " + to_string(SC_DEFAULT_PORT))
    println("  model:             " + SC_MODEL_NAME)
    println("  default ckpt:      " + SC_DEFAULT_CKPT)
    println("  device:            " + SC_DEFAULT_DEVICE)
    println("  RUNTIME_HAS_NET:   " + sc_bool_str(RUNTIME_HAS_NET))
    println("  RUNTIME_HAS_FFI:   " + sc_bool_str(RUNTIME_HAS_FFI_CLM))
    println("  SC_PROXY_ENABLED:  " + sc_bool_str(SC_PROXY_ENABLED))
    println("  proxy host:        " + SC_PROXY_HOST)
    println("============================================================")

    if mode == "--selftest" {
        let rc = sc_selftest()
        if rc > 0 { println("[serve_clm] FAIL " + to_string(rc) + " test(s)") }
        else      { println("[serve_clm] OK 10/10 self-test PASS") }
        return
    }

    if mode == "--schema" {
        println("{\"routes\":[\"GET /health\",\"POST /generate\",\"POST /loss\"],")
        println(" \"response_key\":\"text\",")
        println(" \"laws_version\":\"" + SC_LAWS_VERSION + "\",")
        println(" \"phi_vec_len\":16}")
        return
    }

    if mode != "--serve" {
        println("[serve_clm] usage: hexa run serving/serve_clm.hexa [--selftest|--serve|--schema]")
        let rc = sc_selftest()
        if rc > 0 { println("[serve_clm] FAIL " + to_string(rc) + " test(s)") }
        return
    }

    // ─── Live HTTP server loop ─────────────────────────────────────
    let bind_addr = "0.0.0.0:" + to_string(SC_DEFAULT_PORT)
    let listener = net_listen(bind_addr)
    if listener < 0 {
        println("[serve_clm] FATAL net_listen(" + bind_addr + ") failed fd=" + to_string(listener))
        return
    }
    let ck = sc_ckpt_stat(SC_DEFAULT_CKPT)
    let mut st = sc_state_new(SC_DEFAULT_PORT, 0, SC_DEFAULT_CKPT, SC_DEFAULT_DEVICE, ck.bytes)
    let mut has_prior = false
    let mut prior_holo = 0.0
    println("[serve_clm] listening on " + bind_addr + " fd=" + to_string(listener))
    println("[serve_clm] routes: GET /health, POST /generate, POST /loss")
    let mut running = true
    while running {
        let conn = net_accept(listener)
        if conn < 0 { continue }
        let raw = net_read(conn)
        if raw.len() == 0 {
            net_close(conn)
            continue
        }
        let req = sc_parse_http(raw)
        let resp = sc_route(req.method, req.path, req.body, st, has_prior, prior_holo)
        st = ScState {
            ch:                     st.ch,
            port:                   st.port,
            requests_served:        st.requests_served + 1,
            total_tokens_generated: st.total_tokens_generated + resp.tokens_added,
            ckpt_bytes:             st.ckpt_bytes,
            last_phi_holo:          resp.new_phi_holo,
            ckpt_path:              st.ckpt_path,
            device:                 st.device,
            model:                  st.model
        }
        if req.path == "/generate" {
            has_prior = true
            prior_holo = resp.new_phi_holo
        }
        net_write(conn, sc_http_response(resp.status, resp.body))
        net_close(conn)
        println("[" + to_string(st.requests_served) + "] " + req.method + " " + req.path + " → " + to_string(resp.status))
    }
    net_close(listener)
}
