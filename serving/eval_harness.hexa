    let mut qs = []
    // physics / math / STEM (7)
    qs = qs.push(mk_item("mk01", "physics",
        hr_prompt4("뉴턴의 제2법칙 F=ma에서 힘 F가 두 배가 되고 질량 m이 일정할 때, 가속도 a는?", "1/2배", "2배", "4배", "변하지 않음"),
        "2"))
