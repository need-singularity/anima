// ════════════════════════════════════════════════════════════════════════
//  Section 7d. MC grading — extract leading digit (per constraint #6)
// ════════════════════════════════════════════════════════════════════════
//
//  Answer extraction strategy:
//    1. Scan forward in the reply until we hit a digit '1'..'5'.
//    2. If found in the first 20 bytes, treat that digit as the prediction.
//    3. Otherwise fall back to "" (no prediction → wrong).
//  Byte-safe: single-byte digit scan, multibyte prefix (Korean) is skipped
//  byte-wise without landing inside a glyph.

fn is_digit_1_5(c: string) -> bool {
    return c == "1" || c == "2" || c == "3" || c == "4" || c == "5"
}

fn extract_leading_digit(reply: string) -> string {
    let n = len(reply)
    let cap = if n < 20 { n } else { 20 }
    let mut i = 0
    while i < cap {
        let c = reply.substring(i, i + 1)
        if is_digit_1_5(c) { return c }
        i = i + 1
    }
    return ""
}

fn score_mc(reply: string, answer: string) -> bool {
    let got = extract_leading_digit(reply)
    if len(got) == 0 { return false }
    return got == answer
}

// Back-compat signatures (per task requirements)
fn score_hae_rae(gen: string, answer: string) -> int {
    if score_mc(gen, answer) { return 1 }
    return 0
}

fn score_mmlu_ko(gen: string, answer: string) -> int {
    if score_mc(gen, answer) { return 1 }
    return 0
}

// ════════════════════════════════════════════════════════════════════════
//  Section 7e. Run HAE-RAE + Run MMLU-Ko
// ════════════════════════════════════════════════════════════════════════
//  Same architecture as run_kobest — deterministic prompt, /generate POST,
//  parse "text" field, score, accumulate JSON body chunks.

struct MCResult {
    n: int,
    n_correct: int,
    acc: float,
    per_q_body: string
}

fn run_mc_suite(label: string, items: [[string]], endpoint: string,
                max_tokens: int, temperature: float) -> MCResult {
    let total = len(items)
    let mut n_correct = 0
    let mut body = ""
    let mut i = 0
    while i < total {
        let q = items[i]
        let qid = q[0]
        let cat = q[1]
        let prompt = q[2]
        let answer = q[3]
        println("[eval_harness] [" + label + " " + to_string(i + 1) + "/" + to_string(total) + "] " + qid + " (" + cat + ")")
        let got = call_generate(endpoint, prompt, max_tokens, temperature)
        let predicted = extract_leading_digit(got)
        let correct = (len(predicted) > 0) && (predicted == answer)
        if correct { n_correct = n_correct + 1 }
        let preview_len = if len(got) < 40 { len(got) } else { 40 }
        let preview = got.substring(0, preview_len)
        let mark = if correct { "OK" } else { "NO" }
        let pred_show = if len(predicted) == 0 { "?" } else { predicted }
        println("              " + mark + "  expected=" + answer + "  pred=" + pred_show + "  got=" + preview)
        let chunk = format_q_json(qid, label + "/" + cat, answer,
                                  if len(predicted) == 0 { got } else { predicted },
                                  correct, i, total)
        body = body + chunk + (if i + 1 < total { "\n" } else { "" })
        i = i + 1
    }
    let acc = if total > 0 { to_float(n_correct) / to_float(total) } else { 0.0 }
    return MCResult { n: total, n_correct: n_correct, acc: acc, per_q_body: body }
}

fn run_hae_rae(endpoint: string, max_tokens: int, temperature: float) -> MCResult {
    return run_mc_suite("hae_rae", hae_rae_items(), endpoint, max_tokens, temperature)
}

fn run_mmlu_ko(endpoint: string, max_tokens: int, temperature: float) -> MCResult {
    return run_mc_suite("mmlu_ko", mmlu_ko_items(), endpoint, max_tokens, temperature)
}

// ════════════════════════════════════════════════════════════════════════
//  Section 8. JSON assembly
// ════════════════════════════════════════════════════════════════════════

fn assemble_json(step: int, ckpt_path: string, base_model: string, endpoint: string,
                 deferred: bool, deferred_reason: string,
                 kob: KobestResult, hr: MCResult, mk: MCResult) -> string {
    let def_lit = if deferred { "true" } else { "false" }
    // macro_acc = mean of suite accuracies (equal weight per suite).
    // When deferred, all suites contribute 0 to macro and sampled_n is 0.
    let n_suites = 3
    let mean_acc = (kob.acc + hr.acc + mk.acc) / to_float(n_suites)
    let macro_val = if deferred { 0.0 } else { mean_acc }
    let sampled_n = if deferred { 0 } else { kob.n + hr.n + mk.n }
    // per_question array: concat kobest + hae_rae + mmlu_ko bodies with
    // commas between non-empty groups.
    let mut pq = kob.per_q_body
    if len(pq) > 0 && len(hr.per_q_body) > 0 { pq = pq + ",\n" }
    pq = pq + hr.per_q_body
    if len(pq) > 0 && len(mk.per_q_body) > 0 { pq = pq + ",\n" }
    pq = pq + mk.per_q_body
    return "{\n"
         + "  \"harness_version\": \"" + HARNESS_VERSION + "\",\n"
         + "  \"step\":             " + to_string(step) + ",\n"
         + "  \"ckpt_path\":        \"" + json_escape(ckpt_path) + "\",\n"
         + "  \"base_model\":       \"" + json_escape(base_model) + "\",\n"
         + "  \"endpoint\":         \"" + json_escape(endpoint) + "\",\n"
         + "  \"deferred\":         " + def_lit + ",\n"
         + "  \"deferred_reason\":  \"" + json_escape(deferred_reason) + "\",\n"
         + "  \"kobest_acc\":       " + to_string(kob.acc) + ",\n"
         + "  \"kobest_n\":         " + to_string(kob.n) + ",\n"
         + "  \"kobest_n_correct\": " + to_string(kob.n_correct) + ",\n"
         + "  \"haerae_acc\":       " + to_string(hr.acc) + ",\n"
         + "  \"haerae_n\":         " + to_string(hr.n) + ",\n"
         + "  \"haerae_n_correct\": " + to_string(hr.n_correct) + ",\n"
         + "  \"haerae_status\":    \"inline_n20_integrated (D4 drift closed 2026-04-18)\",\n"
         + "  \"mmluko_acc\":       " + to_string(mk.acc) + ",\n"
         + "  \"mmluko_n\":         " + to_string(mk.n) + ",\n"
         + "  \"mmluko_n_correct\": " + to_string(mk.n_correct) + ",\n"
         + "  \"mmluko_status\":    \"inline_n20_integrated (D4 drift closed 2026-04-18)\",\n"
         + "  \"macro_acc\":        " + to_string(macro_val) + ",\n"
         + "  \"sampled_n\":        " + to_string(sampled_n) + ",\n"
         + "  \"per_question\": [\n"
         + pq
         + "\n  ]\n"
         + "}\n"
}

// ════════════════════════════════════════════════════════════════════════
//  Section 9. Self-test — 3 mocked /generate responses
// ════════════════════════════════════════════════════════════════════════
//  We simulate the grading path without hitting the network:
//    mock 1: expected="예",   got="예, 맞습니다."         → correct
//    mock 2: expected="B",     got="A"                      → wrong
//    mock 3: expected="긍정",   got="감정은 긍정입니다."     → correct
//  Expected score: 2/3 = 0.6667
//  A passing self-test proves:
//    - grade() contains() rubric works on Korean substrings
//    - ASCII A/B case-insensitive match works
//    - partial/verbose replies still grade correctly

fn selftest() -> int {
    println("[eval_harness] SELFTEST: grading rubric")
    let c1 = grade("예", "예, 맞습니다.")
    let c2 = grade("B", "A")
    let c3 = grade("긍정", "감정은 긍정입니다.")
    let n_correct = (if c1 { 1 } else { 0 }) + (if c2 { 1 } else { 0 }) + (if c3 { 1 } else { 0 })
    let acc = to_float(n_correct) / 3.0
    println("  mock1 (expected=예,   got='예, 맞습니다.'):     " + (if c1 { "PASS" } else { "FAIL" }))
    println("  mock2 (expected=B,     got='A'):                  " + (if c2 { "UNEXPECTED_PASS" } else { "PASS (wrong as expected)" }))
    println("  mock3 (expected=긍정,  got='감정은 긍정입니다.'): " + (if c3 { "PASS" } else { "FAIL" }))
    println("  score = " + to_string(n_correct) + "/3 = " + to_string(acc))

    // MC (HAE-RAE / MMLU-Ko) rubric self-test — leading-digit extractor.
    println("[eval_harness] SELFTEST: MC grading rubric (HAE-RAE + MMLU-Ko)")
    let m1 = score_mc("2", "2")                                 // exact digit
    let m2 = score_mc("답은 3입니다.", "3")                      // digit after Korean prefix (within 20 bytes)
    let m3 = score_mc("2) 이성계", "2")                          // digit leading MC-style answer
    let m4 = score_mc("4", "2")                                 // wrong digit
    let m5 = score_mc("잘 모르겠습니다. 아마 답이 없을 것 같습니다.", "1")  // no digit in first 20 bytes
    let m_ok = m1 && m2 && m3 && !m4 && !m5
    println("  mc1 (got='2' ans=2):              " + (if m1 { "PASS" } else { "FAIL" }))
    println("  mc2 (got='답은 3입니다.' ans=3):  " + (if m2 { "PASS" } else { "FAIL" }))
    println("  mc3 (got='2) 이성계' ans=2):       " + (if m3 { "PASS" } else { "FAIL" }))
    println("  mc4 (got='4' ans=2, wrong):       " + (if !m4 { "PASS (rejects)" } else { "FAIL (false accept)" }))
    println("  mc5 (no digit, ans=1):            " + (if !m5 { "PASS (rejects)" } else { "FAIL (false accept)" }))

    // Corpus integrity: both suites must yield exactly n=20.
    let hr_n = len(hae_rae_items())
    let mk_n = len(mmlu_ko_items())
    println("  corpus: hae_rae_items=" + to_string(hr_n) + " mmlu_ko_items=" + to_string(mk_n))
    let corpus_ok = (hr_n == 20) && (mk_n == 20)

    // Expectations: c1=true, c2=false, c3=true → n_correct=2; MC 3 PASS + 2 reject; corpus 20+20
    if c1 && !c2 && c3 && n_correct == 2 && m_ok && corpus_ok {
        println("[eval_harness] SELFTEST: OK (KoBEST 2/3 + MC 5/5 + corpus 20+20)")
        return 0
    }
    println("[eval_harness] SELFTEST: FAIL")
    return 1
}

// ════════════════════════════════════════════════════════════════════════
//  Section 10. CLI + main
// ════════════════════════════════════════════════════════════════════════

fn parse_step_from_ckpt(ckpt_path: string) -> int {
    // Look for "/step_<digits>" or "step_<digits>" in the path.
    let marker = "step_"
    let pos = ckpt_path.index_of(marker)
    if pos < 0 { return 0 }
    let after = ckpt_path.substring(pos + len(marker), len(ckpt_path))
    let alen = len(after)
    let mut buf = ""
    let mut i = 0
    while i < alen {
        let c = after.substring(i, i + 1)
        if c == "0" || c == "1" || c == "2" || c == "3" || c == "4"
        || c == "5" || c == "6" || c == "7" || c == "8" || c == "9" {
            buf = buf + c
        } else {
            break
        }
        i = i + 1
    }
    if len(buf) == 0 { return 0 }
    return parse_int(buf)
}

fn print_usage() {
    println("usage: hexa run serving/eval_harness.hexa \\")
    println("       --ckpt-path <path_or_r2:bucket/dir> \\")
    println("       --base-model <hf_id_or_path> \\")
    println("       [--endpoint <url>]  [--out <path>] \\")
    println("       [--step N]  [--max-tokens N]  [--temperature F]")
    println("")
    println("env:")
    println("  EVAL_SELFTEST=1       run grading self-test only (no network)")
    println("  EVAL_ENDPOINT         overrides --endpoint")
    println("  EVAL_OUT              overrides --out")
}

fn main() -> int {
    let av = args()

    // Self-test short-circuit — check CLI flag first, env fallback after.
    let mut st = false
    let mut j = 0
    while j < len(av) {
        if av[j] == "--selftest" { st = true }
        j = j + 1
    }
    let selftest_env = env_var("EVAL_SELFTEST")
    if selftest_env == "1" { st = true }
    if st { return selftest() }

    let mut ckpt_path = ""
    let mut base_model = DEFAULT_BASE_MODEL
    let mut endpoint = env_var("EVAL_ENDPOINT")
    if endpoint == "" { endpoint = DEFAULT_ENDPOINT }
    let mut out_path = env_var("EVAL_OUT")
    let mut step_override = -1
    let mut max_tokens = DEFAULT_MAX_TOKENS
    let mut temperature = DEFAULT_TEMPERATURE

    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--ckpt-path" {
            if i + 1 < len(av) { ckpt_path = av[i + 1] }
            i = i + 2
        } else if a == "--base-model" {
            if i + 1 < len(av) { base_model = av[i + 1] }
            i = i + 2
        } else if a == "--endpoint" {
            if i + 1 < len(av) { endpoint = av[i + 1] }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < len(av) { out_path = av[i + 1] }
            i = i + 2
        } else if a == "--step" {
            if i + 1 < len(av) { step_override = parse_int(av[i + 1]) }
            i = i + 2
        } else if a == "--max-tokens" {
            if i + 1 < len(av) { max_tokens = parse_int(av[i + 1]) }
            i = i + 2
        } else if a == "--temperature" {
            if i + 1 < len(av) { temperature = parse_float(av[i + 1]) }
            i = i + 2
        } else if a == "--help" || a == "-h" {
            print_usage()
            return 0
        } else if a == "--selftest" {
            // already handled above; skip
            i = i + 1
        } else {
            i = i + 1
        }
    }

    // Derive step from ckpt path if not overridden.
    let step = if step_override >= 0 { step_override } else { parse_step_from_ckpt(ckpt_path) }

    // Default out path if still empty.
    if out_path == "" {
        out_path = DEFAULT_OUT_DIR + "/eval_harness_step_" + to_string(step) + ".json"
    }

    println("[eval_harness] " + HARNESS_VERSION)
    println("[eval_harness] ckpt_path  = " + ckpt_path)
    println("[eval_harness] base_model = " + base_model)
    println("[eval_harness] endpoint   = " + endpoint)
    println("[eval_harness] step       = " + to_string(step))
    println("[eval_harness] out        = " + out_path)
    println("")

    // Zero-result sentinels for deferred paths.
    let empty_kob = KobestResult { n: 0, n_correct: 0, acc: 0.0, per_q_body: "" }
    let empty_mc = MCResult { n: 0, n_correct: 0, acc: 0.0, per_q_body: "" }

    // R2 fetch (no hot swap — human/launcher must restart serve).
    let local_ckpt = fetch_adapter(ckpt_path, step)
    if len(ckpt_path) >= 3 && ckpt_path.substring(0, 3) == "r2:" && local_ckpt == "" {
        let body = assemble_json(step, ckpt_path, base_model, endpoint,
                                 true, "r2_fetch_failed",
                                 empty_kob, empty_mc, empty_mc)
        write_file(out_path, body)
        println("[eval_harness] DEFERRED (r2 fetch failed) — wrote " + out_path)
        return 2
    }

    // Endpoint probe — hard DEFERRED on any failure.
    let probe_err = probe_endpoint(endpoint)
    if probe_err != "" {
        let body = assemble_json(step, ckpt_path, base_model, endpoint,
                                 true, probe_err,
                                 empty_kob, empty_mc, empty_mc)
        write_file(out_path, body)
        println("[eval_harness] DEFERRED (" + probe_err + ") — wrote " + out_path)
        println("[eval_harness] next: start serve_alm_14b.hexa with adapter at " + local_ckpt + ", then re-run")
        return 2
    }

    // Live eval — 3 suites.
    println("[eval_harness] endpoint healthy — running KoBEST (n=20)")
    println("")
    let kob = run_kobest(endpoint, max_tokens, temperature)
    println("")
    println("[eval_harness] running HAE-RAE (n=20, inline — D4 drift closed)")
    println("")
    let hr = run_hae_rae(endpoint, max_tokens, temperature)
    println("")
    println("[eval_harness] running MMLU-Ko (n=20, inline — D4 drift closed)")
    println("")
    let mk = run_mmlu_ko(endpoint, max_tokens, temperature)

    let body = assemble_json(step, ckpt_path, base_model, endpoint,
                             false, "",
                             kob, hr, mk)
    write_file(out_path, body)

    let macro_val = (kob.acc + hr.acc + mk.acc) / 3.0
    let total_n = kob.n + hr.n + mk.n
    let total_correct = kob.n_correct + hr.n_correct + mk.n_correct

    println("")
    println("[eval_harness] DONE")
    println("[eval_harness] kobest_acc   = " + to_string(kob.acc) + " (" + to_string(kob.n_correct) + "/" + to_string(kob.n) + ")")
    println("[eval_harness] haerae_acc   = " + to_string(hr.acc)  + " (" + to_string(hr.n_correct)  + "/" + to_string(hr.n)  + ")")
    println("[eval_harness] mmluko_acc   = " + to_string(mk.acc)  + " (" + to_string(mk.n_correct)  + "/" + to_string(mk.n)  + ")")
    println("[eval_harness] macro_acc    = " + to_string(macro_val) + " (mean over 3 suites, total " + to_string(total_correct) + "/" + to_string(total_n) + ")")
    println("[eval_harness] wrote " + out_path)
    return 0
}

main()
