        hr_prompt4("빛의 진공 속 속력에 가장 가까운 값은?", "약 3 × 10^5 m/s", "약 3 × 10^8 m/s", "약 3 × 10^10 m/s", "약 3 × 10^6 m/s"),
        "2"))
