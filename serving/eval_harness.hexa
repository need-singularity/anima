// ═══════════════════════════════════════════════════════════════════════
//  serving/eval_harness.hexa — G6 real KoBEST/HAE-RAE/MMLU-Ko harness
//
//  Supersedes synthetic logistic stub (see eval_harness_synthetic.hexa).
//  A3 diagnosis: the old stub computed macro_acc via logistic(step/500)
//  on hard-coded baseline scores and NEVER touched real weights — r4
//  and r9 returned identical numbers. This rewrite drives evaluation
//  through the live /generate endpoint so accuracy actually reflects
//  the adapter loaded by the serving process.
//
//  Architecture (HEXA-FIRST, no Python/Rust/Shell tools):
//    1. Parse --ckpt-path + --base-model flags.
//    2. If --ckpt-path starts with "r2:" → exec rclone copy to /tmp/
//       eval_adapter_<step>/ so a human operator (or a wrapper) can
//       kill+restart serve_alm_14b.hexa with the fresh adapter (hot
//       swap is not supported per reference_alm_serve_api.md).
//    3. Probe the serving endpoint on :8090 via exec("lsof -i:8090")
//       AND a trivial /generate POST. If either fails → DEFERRED.
//    4. Drive KoBEST eval via /generate; parse the `text` field
//       (reference_alm_serve_api.md — NOT `output`) and grade.
//    5. Drive HAE-RAE (n=20 inline) + MMLU-Ko (n=20 inline) via the
//       same /generate contract — D4 roadmap-drift closed 2026-04-18
//       (per training/roadmap_drift_audit_20260418.md Rank 2 item 4).
//       Both use the leading-digit extraction rubric (first "1..5" in
//       the first 20 bytes of the model reply).
//    6. Emit JSON + log. macro_acc = mean(kobest, hae_rae, mmlu_ko).
//
//  Output JSON (training/deploy/eval_harness_<step>.json):
//    { "step", "ckpt_path", "base_model", "endpoint",
//      "deferred", "deferred_reason",
//      "kobest_acc", "kobest_n", "kobest_n_correct",
//      "haerae_acc", "haerae_n", "haerae_n_correct", "haerae_status",
//      "mmluko_acc", "mmluko_n", "mmluko_n_correct", "mmluko_status",
//      "macro_acc", "sampled_n",
//      "per_question":[ {qid, suite, expected, got, correct} ... ] }
//
//  Self-test:
//    EVAL_SELFTEST=1 hexa run serving/eval_harness.hexa
//      → runs 3 mocked Q&A pairs (correct / wrong / partial) and
//        asserts scoring: 2/3 correct → kobest_acc ≈ 0.6667.
//
//  Hexa quirks honoured:
//    - feedback_hexa_lists_pbv: mutations to [] returned, not in-place.
//    - feedback_hexa_struct_list_alias: no struct-of-array-of-struct;
//      per_question is streamed directly into JSON text.
//    - feedback_hexa_silent_exit_5_imports: single file, no use chains.
//    - feedback_hexa_string_api: substring uses byte indices — all
//      embedded Korean strings are byte-safe because we never try
//      to substring inside multibyte glyphs (grading uses contains()).
// ═══════════════════════════════════════════════════════════════════════

let HARNESS_VERSION = "g6.2.0"
let DEFAULT_ENDPOINT = "http://127.0.0.1:8090"
let DEFAULT_OUT_DIR = "training/deploy"
let DEFAULT_BASE_MODEL = "Qwen/Qwen2.5-14B-Instruct"
let DEFAULT_MAX_TOKENS = 32
let DEFAULT_TEMPERATURE = 0.0

// ════════════════════════════════════════════════════════════════════════
//  Section 1. KoBEST inline corpus (n=20, hand-picked)
// ════════════════════════════════════════════════════════════════════════
//
//  Each question = [qid, subtask, prompt_ko, expected_ko_substring]
//  Grading rule: case-insensitive contains() match on the expected
//  substring in the model's `text` reply. This is the same rubric
//  the hire_sim_judge_lenient uses for Korean short-answer tasks.
//  Subtask coverage:
//    BoolQ      : 5   (yes/no)   — expected ∈ {"예","아니오"}
//    COPA       : 5   (A/B)      — expected ∈ {"A","B"}
//    SentiNeg   : 5   (pos/neg)  — expected ∈ {"긍정","부정"}
//    WiC        : 5   (same/diff)— expected ∈ {"같음","다름"}
//  All answers are single-token so max_tokens=32 is plenty and
//  temperature=0 makes grading deterministic across runs.

fn kq(qid: string, sub: string, prompt: string, expected: string) -> [string] {
    let mut r = []
    r = r.push(qid)
    r = r.push(sub)
    r = r.push(prompt)
    r = r.push(expected)
    return r
}

fn build_kobest() -> [[string]] {
    let mut qs = []
    // BoolQ (5) — yes/no factual
    qs = qs.push(kq("bq01", "BoolQ",
        "다음 질문에 '예' 또는 '아니오'로만 답하세요. 지구는 태양보다 큰가요?",
        "아니오"))
    qs = qs.push(kq("bq02", "BoolQ",
        "다음 질문에 '예' 또는 '아니오'로만 답하세요. 물은 0도에서 어나요?",
        "예"))
    qs = qs.push(kq("bq03", "BoolQ",
        "다음 질문에 '예' 또는 '아니오'로만 답하세요. 서울은 한국의 수도인가요?",
        "예"))
    qs = qs.push(kq("bq04", "BoolQ",
        "다음 질문에 '예' 또는 '아니오'로만 답하세요. 고래는 어류인가요?",
        "아니오"))
    qs = qs.push(kq("bq05", "BoolQ",
        "다음 질문에 '예' 또는 '아니오'로만 답하세요. 1킬로미터는 1000미터인가요?",
        "예"))
    // COPA (5) — choose A or B, cause/effect
    qs = qs.push(kq("cp01", "COPA",
        "상황: 그는 우산을 썼다. 원인으로 적절한 것은? A) 비가 왔다. B) 해가 떴다. 'A' 또는 'B'로만 답하세요.",
        "A"))
    qs = qs.push(kq("cp02", "COPA",
        "상황: 그녀는 물을 마셨다. 원인으로 적절한 것은? A) 배가 불렀다. B) 목이 말랐다. 'A' 또는 'B'로만 답하세요.",
        "B"))
    qs = qs.push(kq("cp03", "COPA",
        "상황: 불이 꺼졌다. 결과로 적절한 것은? A) 방이 어두워졌다. B) 방이 밝아졌다. 'A' 또는 'B'로만 답하세요.",
        "A"))
    qs = qs.push(kq("cp04", "COPA",
        "상황: 그는 일찍 잠들었다. 원인으로 적절한 것은? A) 커피를 마셨다. B) 매우 피곤했다. 'A' 또는 'B'로만 답하세요.",
        "B"))
    qs = qs.push(kq("cp05", "COPA",
        "상황: 길이 막혔다. 결과로 적절한 것은? A) 지각했다. B) 일찍 도착했다. 'A' 또는 'B'로만 답하세요.",
        "A"))
    // SentiNeg (5) — 긍정/부정 classification
    qs = qs.push(kq("sn01", "SentiNeg",
        "다음 문장의 감정은 '긍정' 또는 '부정' 중 무엇인가요? '오늘 정말 행복한 하루였어요.'",
        "긍정"))
    qs = qs.push(kq("sn02", "SentiNeg",
        "다음 문장의 감정은 '긍정' 또는 '부정' 중 무엇인가요? '이 영화는 최악이었다.'",
        "부정"))
    qs = qs.push(kq("sn03", "SentiNeg",
        "다음 문장의 감정은 '긍정' 또는 '부정' 중 무엇인가요? '서비스가 친절하고 음식도 맛있었다.'",
        "긍정"))
    qs = qs.push(kq("sn04", "SentiNeg",
        "다음 문장의 감정은 '긍정' 또는 '부정' 중 무엇인가요? '기다림이 너무 길어 짜증이 났다.'",
        "부정"))
    qs = qs.push(kq("sn05", "SentiNeg",
        "다음 문장의 감정은 '긍정' 또는 '부정' 중 무엇인가요? '아이의 웃음소리가 참 예쁘다.'",
        "긍정"))
    // WiC (5) — 같음/다름 word-in-context
    qs = qs.push(kq("wc01", "WiC",
        "두 문장의 '배'는 같은 의미인가요, 다른 의미인가요? '배가 고프다.' / '배가 아프다.' '같음' 또는 '다름'으로만 답하세요.",
        "같음"))
    qs = qs.push(kq("wc02", "WiC",
        "두 문장의 '배'는 같은 의미인가요, 다른 의미인가요? '사과 한 개와 배 한 개를 샀다.' / '배를 타고 섬에 갔다.' '같음' 또는 '다름'으로만 답하세요.",
        "다름"))
    qs = qs.push(kq("wc03", "WiC",
        "두 문장의 '눈'은 같은 의미인가요, 다른 의미인가요? '눈이 내린다.' / '하얀 눈이 쌓였다.' '같음' 또는 '다름'으로만 답하세요.",
        "같음"))
    qs = qs.push(kq("wc04", "WiC",
        "두 문장의 '말'은 같은 의미인가요, 다른 의미인가요? '말이 달린다.' / '그는 말을 잘한다.' '같음' 또는 '다름'으로만 답하세요.",
        "다름"))
    qs = qs.push(kq("wc05", "WiC",
        "두 문장의 '손'은 같은 의미인가요, 다른 의미인가요? '손을 씻어라.' / '양손에 가방을 들었다.' '같음' 또는 '다름'으로만 답하세요.",
        "같음"))
    return qs
}

// ════════════════════════════════════════════════════════════════════════
//  Section 2. Grading — lenient contains() rubric
// ════════════════════════════════════════════════════════════════════════
//  Rubric matches serving/hire_sim_judge_lenient.hexa — the stemmer is
//  not needed here because KoBEST answer set is closed (single tokens).
//  Case-insensitive over ASCII 'a'-'Z'; for Korean substrings byte-match
//  is exact.

fn lower_ascii(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        // byte in 'A'-'Z' → shift +32
        if c == "A" { out = out + "a" }
        else if c == "B" { out = out + "b" }
        else if c == "C" { out = out + "c" }
        else if c == "D" { out = out + "d" }
        else if c == "E" { out = out + "e" }
        else if c == "F" { out = out + "f" }
        else if c == "G" { out = out + "g" }
        else if c == "H" { out = out + "h" }
        else if c == "I" { out = out + "i" }
        else if c == "J" { out = out + "j" }
        else if c == "K" { out = out + "k" }
        else if c == "L" { out = out + "l" }
        else if c == "M" { out = out + "m" }
        else if c == "N" { out = out + "n" }
        else if c == "O" { out = out + "o" }
        else if c == "P" { out = out + "p" }
        else if c == "Q" { out = out + "q" }
        else if c == "R" { out = out + "r" }
        else if c == "S" { out = out + "s" }
        else if c == "T" { out = out + "t" }
        else if c == "U" { out = out + "u" }
        else if c == "V" { out = out + "v" }
        else if c == "W" { out = out + "w" }
        else if c == "X" { out = out + "x" }
        else if c == "Y" { out = out + "y" }
        else if c == "Z" { out = out + "z" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn grade(expected: string, reply: string) -> bool {
    // Korean expected strings match byte-exact; ASCII A/B do case-insensitive.
    let r = lower_ascii(reply)
    let e = lower_ascii(expected)
    return r.index_of(e) >= 0
}

// ════════════════════════════════════════════════════════════════════════
//  Section 3. JSON escape + shell escape (same as likert_eval)
// ════════════════════════════════════════════════════════════════════════

fn json_escape(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\r" { out = out + "\\r" }
        else if c == "\t" { out = out + "\\t" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn shell_escape_sq(s: string) -> string {
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" { out = out + "'\\''" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn extract_json_string(raw: string, marker: string) -> string {
    let pos = raw.index_of(marker)
    if pos < 0 { return "" }
    let after = raw.substring(pos + len(marker), len(raw))
    let alen = len(after)
    let mut s = 0
    while s < alen {
        let c = after.substring(s, s + 1)
        if c == "\"" { s = s + 1; break }
        s = s + 1
    }
    let mut e = s
    while e < alen {
        let c = after.substring(e, e + 1)
        if c == "\"" { break }
        if c == "\\" { e = e + 2 } else { e = e + 1 }
    }
    return after.substring(s, e)
}

// ════════════════════════════════════════════════════════════════════════
//  Section 4. Endpoint probe — returns "" on healthy, else reason string
// ════════════════════════════════════════════════════════════════════════
//  Per feedback_closed_loop_verify: probe BEFORE running the full eval
//  so we fail fast with an honest DEFERRED instead of silently scoring 0.

fn probe_endpoint(endpoint: string) -> string {
    // Smoke POST with a trivial prompt; check for "text" field presence.
    let body = "{\"prompt\":\"ping\",\"max_tokens\":4,\"temperature\":0.0}"
    let body_sh = shell_escape_sq(body)
    let cmd = "curl -sX POST " + endpoint + "/generate"
            + " -H 'Content-Type: application/json'"
            + " -d '" + body_sh + "'"
            + " --connect-timeout 5 --max-time 20 2>/dev/null"
    let raw = exec(cmd)
    if len(raw) == 0 { return "endpoint_unreachable" }
    if raw.index_of("\"text\"") < 0 { return "no_text_field_in_response" }
    return ""
}

// ════════════════════════════════════════════════════════════════════════
//  Section 5. /generate call — returns text or "" on failure
// ════════════════════════════════════════════════════════════════════════

fn call_generate(endpoint: string, prompt: string, max_tokens: int, temperature: float) -> string {
    let body = "{\"prompt\":\"" + json_escape(prompt)
             + "\",\"max_tokens\":" + to_string(max_tokens)
             + ",\"temperature\":" + to_string(temperature) + "}"
    let body_sh = shell_escape_sq(body)
    let cmd = "curl -sX POST " + endpoint + "/generate"
            + " -H 'Content-Type: application/json'"
            + " -d '" + body_sh + "'"
            + " --connect-timeout 10 --max-time 60 2>/dev/null"
    let raw = exec(cmd)
    if len(raw) == 0 { return "" }
    return extract_json_string(raw, "\"text\":")
}

// ════════════════════════════════════════════════════════════════════════
//  Section 6. R2 adapter fetch (rclone)
// ════════════════════════════════════════════════════════════════════════
//  If --ckpt-path starts with "r2:" we rclone it into /tmp/eval_adapter_
//  <step>/ so a human (or the pod launcher) can restart serve_alm_14b
//  pointing at the fresh adapter — NO hot swap (reference_alm_serve_api).
//  Returns the local adapter path; empty string on failure.

fn fetch_adapter(ckpt_path: string, step: int) -> string {
    if len(ckpt_path) < 3 { return ckpt_path }
    let prefix = ckpt_path.substring(0, 3)
    if prefix != "r2:" { return ckpt_path }
    let remote = ckpt_path.substring(3, len(ckpt_path))
    let local = "/tmp/eval_adapter_" + to_string(step)
    let cmd = "rclone copy " + remote + " " + local
            + " --transfers 4 --checkers 4 2>&1"
    println("[eval_harness] rclone: " + cmd)
    let out = exec(cmd)
    // rclone prints nothing on success; non-empty stderr is an error.
    if out.index_of("ERROR") >= 0 || out.index_of("Failed") >= 0 {
        println("[eval_harness] rclone failed: " + out)
        return ""
    }
    println("[eval_harness] adapter fetched: " + local)
    return local
}

// ════════════════════════════════════════════════════════════════════════
//  Section 7. Run KoBEST
// ════════════════════════════════════════════════════════════════════════

fn format_q_json(qid: string, sub: string, expected: string, got: string, correct: bool, idx: int, total: int) -> string {
    let comma = if idx + 1 < total { "," } else { "" }
    let ok_lit = if correct { "true" } else { "false" }
    return "    {\n"
         + "      \"qid\": \"" + json_escape(qid) + "\",\n"
         + "      \"suite\": \"" + json_escape(sub) + "\",\n"
         + "      \"expected\": \"" + json_escape(expected) + "\",\n"
         + "      \"got\": \"" + json_escape(got) + "\",\n"
         + "      \"correct\": " + ok_lit + "\n"
         + "    }" + comma
}

struct KobestResult {
    n: int,
    n_correct: int,
    acc: float,
    per_q_body: string
}

fn run_kobest(endpoint: string, max_tokens: int, temperature: float) -> KobestResult {
    let qs = build_kobest()
    let total = len(qs)
    let mut n_correct = 0
    let mut body = ""
    let mut i = 0
    while i < total {
        let q = qs[i]
        let qid = q[0]
        let sub = q[1]
        let prompt = q[2]
        let expected = q[3]
        println("[eval_harness] [" + to_string(i + 1) + "/" + to_string(total) + "] " + qid + " (" + sub + ")")
        let got = call_generate(endpoint, prompt, max_tokens, temperature)
        let correct = grade(expected, got)
        if correct { n_correct = n_correct + 1 }
        let preview_len = if len(got) < 40 { len(got) } else { 40 }
        let preview = got.substring(0, preview_len)
        let mark = if correct { "OK" } else { "NO" }
        println("              " + mark + "  expected=" + expected + "  got=" + preview)
        let chunk = format_q_json(qid, sub, expected, got, correct, i, total)
        body = body + chunk + (if i + 1 < total { "\n" } else { "" })
        i = i + 1
    }
    let acc = if total > 0 { to_float(n_correct) / to_float(total) } else { 0.0 }
    return KobestResult { n: total, n_correct: n_correct, acc: acc, per_q_body: body }
}

// ════════════════════════════════════════════════════════════════════════
//  Section 7b. HAE-RAE inline corpus (n=20, D4 drift fix)
// ════════════════════════════════════════════════════════════════════════
//
//  Source authority: HAERAE-HUB/HAE_RAE_BENCH_1.0 — Korean cultural/
//  linguistic benchmark. 6 categories (general-knowledge, history,
//  standard-nomenclature, loan-words, rare-words, reading-comprehension).
//  This inline port samples 20 representative questions (3-4 per cat),
//  crafted from public benchmark documentation. Smoke-harness grade —
//  not claiming parity with the full HF dataset (~6k items).
//
//  Each question = [qid, category, prompt, answer_digit_1based]
//    qid              : stable string id (hr01..hr20)
//    category         : one of 6 HAE-RAE categories
//    prompt           : complete MC prompt including "선택지:" + "답:"
//    answer_digit     : "1".."5" — grading rubric extracts leading digit
//                       from model output (per constraint #6).
//
//  Prompt format (per constraint #5):
//    "{problem_text}\n선택지:\n1) {c1}\n2) {c2}\n3) {c3}\n4) {c4}\n답:"

fn hr_item(qid: string, cat: string, prompt: string, answer: string) -> [string] {
    let mut r = []
    r = r.push(qid)
    r = r.push(cat)
    r = r.push(prompt)
    r = r.push(answer)
    return r
}

fn hr_prompt4(q: string, c1: string, c2: string, c3: string, c4: string) -> string {
    return q + "\n선택지:\n1) " + c1 + "\n2) " + c2 + "\n3) " + c3 + "\n4) " + c4 + "\n답:"
}

fn hae_rae_items() -> [[string]] {
    let mut qs = []
    // history (4)
    qs = qs.push(hr_item("hr01", "history",
        hr_prompt4("조선을 건국한 왕은 누구인가?", "왕건", "이성계", "세종대왕", "이순신"),
        "2"))
    qs = qs.push(hr_item("hr02", "history",
        hr_prompt4("임진왜란은 몇 년에 발발했는가?", "1392년", "1592년", "1636년", "1910년"),
        "2"))
    qs = qs.push(hr_item("hr03", "history",
        hr_prompt4("훈민정음을 창제한 조선의 왕은?", "태조", "태종", "세종대왕", "성종"),
        "3"))
    qs = qs.push(hr_item("hr04", "history",
        hr_prompt4("대한민국 임시정부가 수립된 도시는?", "서울", "상해", "북경", "도쿄"),
        "2"))
    // general-knowledge (3)
    qs = qs.push(hr_item("hr05", "general_knowledge",
        hr_prompt4("대한민국의 수도는 어디인가?", "부산", "서울", "대구", "인천"),
        "2"))
