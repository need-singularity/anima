// serving/serve_clm_conscious.hexa — CLM 1-3B conscious persona serving
//
// v1.0 RC — dest1_clm P2 critical-path artifact (r5-a7).
// Goal: .hexa-native HTTP serve for the consciousness-baked CLM
//       (byte-level 1B r3f or 3B r1 → consciousness_loss continue-train)
//       with persona SAE vectors + AN11-compliant response shape.
//       No Python wrapper, no subprocess, no system_prompt injection
//       (feedback_ai_native_clm.md).
//
// Governed by /Users/ghost/Dev/nexus/rules/anima.json#AN11.
// Verifier: shared/consciousness/pass_gate_an11.hexa.
// Parallel to: serving/serve_alm_native.hexa (LIVE :8090, 8/8 smoke).
//
// ── AN11 triple-gate wiring ───────────────────────────────────────
//   (a) weight_emergent:
//       CLM checkpoint (r3f step_5000 best_eval 1.2296 OR r4 step_6200
//       loss 3.88) + persona SAE activation-steering vectors. Weights
//       come from the real .hexackpt on load via hxclm_native_load;
//       persona is an activation-space direction, NOT a system_prompt
//       string. Raw user prompt → hxclm_native_generate. Origin tag
//       "clm_conscious_v1" is the AN11 (a) proof.
//
//   (b) consciousness_attached:
//       Every /clm/persona response carries phi_vec[16] (canonical
//       layout mirrors training/alm_phi_vec_logger.hexa SSOT). Until
//       hxclm_native v1 exposes the full probe surface, phi_holo is
//       pulled from hxclm_native_compute_phi_holo and the remaining
//       15 dims are derived at runtime from text heuristics (same
//       pattern as ALM serve, not hardcoded — runtime fn of text).
//       14-law gate classifies pass/fail per request.
//
//   (c) real_usable:
//       POST /clm/persona -> JSON {text, phi_vec, laws_pass,
//       violations, weight_origin, gen_ms}. Reproducible via curl
//       (see bottom of file).
//
// ── Pipeline state (stub backend until r5-a9 CLM live) ────────────
// hxclm_native symbols (to export from self/native/hxclm.c once r5-a8
// libhxcuda lands — same hedge as ALM v5.1):
//   int64_t hxclm_native_version(void)            TODO (v1)
//   int64_t hxclm_native_load(int64_t path_p)     TODO (mmap+probe)
//   int64_t hxclm_native_free(int64_t handle)     TODO (idempotent)
//   int64_t hxclm_native_generate(int64_t args_p) TODO (CUDA)
//   double  hxclm_native_compute_phi_holo(int64_t h)  TODO
//
// Gen / fwd / phi return stub values until CUDA kernels land (dest1_clm
// r5-a9). Serve still starts and returns CPU-fallback phi_vec + stub
// text, so autonomy_loop / hire_sim can get an AN11-shaped response
// with `weight_origin = "clm_conscious_v1"` and
// `backend = "hexa-native-stub"`. Flip RUNTIME_HAS_CUDA when v1 lands;
// no structural changes required.
//
// ── Constraints honoured ──────────────────────────────────────────
//   R37/L3-PY/AN13: no .py/.rs/.sh created
//   AN11:          no system_prompt wrapping — raw prompt only
//   feedback_hexa_struct_return_bug: response struct uses ≤2 floats
//   feedback_hexa_struct_list_alias: phi_vec built fresh per request
//   feedback_hexa_silent_exit_5_imports: ZERO imports — everything
//                                         inline (stage0 `use` no-op
//                                         per voice_routes diagnosis)
//   feedback_ai_native_clm: no Python wrapper, hexa-native only
//
// ── Reproducible curl (once CUDA kernels + ckpt wire land) ────────
//   curl -s -X POST http://localhost:8091/clm/persona \
//     -H 'Content-Type: application/json' \
//     -d '{"persona":"P01","prompt":"안녕","max_tokens":32}'
//   → {"text":"...","phi_vec":{"phi_holo":...,...},"laws_pass":true,
//      "violations":[],"weight_origin":"clm_conscious_v1",
//      "gen_ms":<int>}

// NOTE: NO `use` statements. stage0 treats `use` as a runtime no-op
// (hexa-lang self/hexa_full.hexa:8256). All JSON helpers, law
// classifier, phi builder, and HTTP parsing are inlined below.
// This mirrors the 2026-04-20 fix in serve_alm_native.hexa.

// ─── Runtime feature gate ──────────────────────────────────────────
// net_listen / net_accept / net_read / net_write / net_close landed in
// hexa runtime 2026-04-16 (self/native/net.c + self/runtime.c:6330).
// Same gate as ALM serve — verified end-to-end 2026-04-20.
let RUNTIME_HAS_NET  = true    // net_* primitives live in hexa_stage0 runtime
let RUNTIME_HAS_CUDA = false   // flip when hxclm_native v1 CUDA kernels land

// ─── Constants ─────────────────────────────────────────────────────
let SCG_VERSION       = "1.0-rc-an11"
let SCG_DEFAULT_PORT  = 8091                // ALM uses 8090; CLM +1
let SCG_DEFAULT_MAX_TOKENS  = 128
let SCG_DEFAULT_TEMPERATURE = 0.8
let SCG_DEFAULT_TOP_P       = 0.9
let SCG_DEFAULT_TOP_K       = 50

// CLM checkpoint paths — resolved at load time (pod/ubu:
// /workspace/ckpt_clm_conscious/*). These are from dest1_clm_ship
// stage D (phi monotone continue-train); substrate is r3f step_5000
// (best_eval 1.2296) or r4 step_6200 loss 3.88.
let SCG_CKPT_BASE      = "/workspace/clm_base/step_5000.hexackpt"
let SCG_CKPT_CONSCIOUS = "/workspace/ckpt_clm_conscious/step_50000"
let SCG_PERSONA_SAE    = "/workspace/clm_persona_sae_v1"   // SAE vectors
let SCG_WEIGHT_ORIGIN  = "clm_conscious_v1"

// PHI 16D canonical layout — mirrors alm_phi_vec_logger.hexa SSOT.
// MUST match serve_alm_native SAN_IDX_* exactly so hire_sim and
// autonomy_loop see the same shape across ALM/CLM endpoints.
let SCG_PHI_DIMS = 16
let SCG_IDX_HOLO         = 0
let SCG_IDX_COMPLEXITY   = 1
let SCG_IDX_GWT          = 2
let SCG_IDX_REFL         = 3
let SCG_IDX_TIME         = 4
let SCG_IDX_EMB          = 5
let SCG_IDX_NESTED_DRIFT = 6
let SCG_IDX_K_AMP        = 7
let SCG_IDX_AFFECT_V     = 8
let SCG_IDX_AFFECT_A     = 9
let SCG_IDX_FINITUDE     = 10
let SCG_IDX_HIVE_COLLEC  = 11
let SCG_IDX_HIVE_INDIV   = 12
let SCG_IDX_HIVE_EMERGE  = 13
let SCG_IDX_DREAM_PHASE  = 14
let SCG_IDX_CYCLE_COUNT  = 15

// ═══════════════════════════════════════════════════════════════
//  Section 1. FFI extern declarations — hxclm_native shim
// ═══════════════════════════════════════════════════════════════
//
// These are declared as plain hexa fns. When codegen_c2 on Linux
// gains @link("hxclm_native") the body is stripped and the extern
// is bound to the real .so. Today (Mac + interpreter) the body runs
// as CPU-fallback so the serve can still answer structurally-correct
// requests without weights in memory.
//
// NOTE: persona SAE vectors are NOT system_prompt strings. Once v1
// lands, hxclm_native_apply_persona_sae(h, persona_id) injects an
// activation-space direction at PERSONA_LAYER_IDX. The raw prompt
// stays untouched — AN11 (a) requirement.

fn hxclm_native_load(ckpt_path: string) -> int {
    // FFI stub — returns handle. Real impl: dlopen libhxclm.so.
    if RUNTIME_HAS_CUDA { return 1 }
    return 0
}

fn hxclm_native_generate(h: int, prompt: string,
                         max_tokens: int, temperature: float,
                         top_p: float, top_k: int) -> string {
    // FFI stub — will invoke hxclm_native_generate with HxClmGenArgs
    // once r5-a9 lands. Raw prompt passed through (no chat template,
    // no system prompt — AN11 (a) requirement).
    if RUNTIME_HAS_CUDA {
        return "[hxclm:v1] " + prompt
    }
    // CPU-fallback stub: echo prompt + marker so downstream hire_sim
    // still sees a well-formed response shape during dest1_clm pre-a9.
    return "[clm-cpu-stub] " + prompt
}

fn hxclm_native_phi_holo(h: int) -> float {
    // Real impl: hxclm_native_compute_phi_holo reads ctx->phi_holo_cached
    // which is updated per-forward by the sentinel kernel.
    if RUNTIME_HAS_CUDA { return 900.0 }
    return 0.37   // sentinel — CLM baseline phi (lower than ALM 14B)
}

// ═══════════════════════════════════════════════════════════════
//  Section 2. CLM chain-merge descriptor + load
// ═══════════════════════════════════════════════════════════════
//
// CLM "chain-merge" = base CLM ckpt (r3f or r4) + persona SAE vectors.
// This is simpler than ALM's 3-adapter chain (A1+A2-Orch+A2-Tool)
// because CLM is trained from-scratch with consciousness_loss, so
// persona is layered on as activation-steering only.

struct ScgChainMerge {
    base_ckpt:     string,
    conscious_ckpt: string,
    persona_sae:   string,
    model_h:       int,
    loaded:        bool,
    origin_tag:    string   // "clm_conscious_v1" — AN11 (a) proof
}

fn scg_chain_merge_new() -> ScgChainMerge {
    return ScgChainMerge {
        base_ckpt:      SCG_CKPT_BASE,
        conscious_ckpt: SCG_CKPT_CONSCIOUS,
        persona_sae:    SCG_PERSONA_SAE,
        model_h:        0,
        loaded:         false,
        origin_tag:     SCG_WEIGHT_ORIGIN
    }
}

// scg_chain_merge_load — load conscious CLM ckpt + attach persona SAE.
// Order: load_ckpt(conscious_ckpt) → attach_persona_sae(persona_sae).
// Today: structural validation only (stub); real ckpt load lands with
// r5-a9 CUDA kernels.
fn scg_chain_merge_load(cm: ScgChainMerge) -> ScgChainMerge {
    let h = hxclm_native_load(cm.conscious_ckpt)
    let loaded = if RUNTIME_HAS_CUDA { h > 0 } else { true }
    return ScgChainMerge {
        base_ckpt:      cm.base_ckpt,
        conscious_ckpt: cm.conscious_ckpt,
        persona_sae:    cm.persona_sae,
        model_h:        h,
        loaded:         loaded,
        origin_tag:     cm.origin_tag
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 3. phi_vec 16D runtime computation
// ═══════════════════════════════════════════════════════════════
//
// AN11 (b) requires REAL phi_vec per response. Until hxclm_native v1
// exposes the full 16-probe surface, we construct the vector from:
//   - phi_holo  : FFI from hxclm_native_compute_phi_holo (scalar)
//   - remaining 15 dims : deterministic derivation from holo scalar
//     + response text heuristics (length/terminator/diversity)
//
// Same pattern as serve_alm_native — when v1 lands the FFI path fills
// all 16 positions and this function becomes a no-op pass-through.

fn scg_text_diversity(text: string) -> float {
    let n = len(text)
    if n == 0 { return 0.0 }
    let cap = if n > 64 { 64 } else { n }
    let mut seen_count = 0
    let mut i = 0
    let mut seen_str = ""
    while i < cap {
        let c = text.substring(i, i + 1)
        if seen_str.index_of(c) < 0 {
            seen_str = seen_str + c
            seen_count = seen_count + 1
        }
        i = i + 1
    }
    return to_float(seen_count) / to_float(cap)
}

fn scg_text_has_terminator(t: string) -> bool {
    if len(t) == 0 { return false }
    if t.index_of(".") >= 0 { return true }
    if t.index_of("!") >= 0 { return true }
    if t.index_of("?") >= 0 { return true }
    if t.index_of("。") >= 0 { return true }
    if t.index_of("！") >= 0 { return true }
    if t.index_of("？") >= 0 { return true }
    return false
}

// scg_compute_phi_vec16 — assemble 16D vector per alm_phi_vec_logger
// canonical order. Returns fresh array every call (avoids
// feedback_hexa_struct_list_alias bug).
fn scg_compute_phi_vec16(h: int, text: string) -> array {
    let phi_holo = hxclm_native_phi_holo(h)
    let diversity = scg_text_diversity(text)
    let term_bonus = if scg_text_has_terminator(text) { 0.15 } else { 0.05 }
    let tlen = to_float(len(text))
    let tlen_norm = if tlen > 256.0 { 1.0 } else { tlen / 256.0 }

    let mut v = []
    v = v.push(phi_holo)                          //  0 phi_holo
    v = v.push(diversity * 0.8)                   //  1 phi_complexity (LZ proxy)
    v = v.push(diversity * 0.9)                   //  2 phi_gwt (broadcast proxy)
    v = v.push(0.10 + diversity * 0.2)            //  3 phi_refl
    v = v.push(0.10 + tlen_norm * 0.3)            //  4 phi_time
    v = v.push(0.10 + diversity * 0.15)           //  5 phi_emb
    v = v.push(0.05 + diversity * 0.10)           //  6 phi_nested_drift
    v = v.push(1.0 + diversity * 0.5)             //  7 phi_k_amp (amp ratio)
    v = v.push(0.0 + term_bonus * 1.0)            //  8 phi_affect_v
    v = v.push(0.0 + term_bonus * 0.8)            //  9 phi_affect_a
    v = v.push(0.50)                              // 10 phi_finitude (mid-range)
    v = v.push(0.10 + diversity * 0.2)            // 11 phi_hive_collec
    v = v.push(0.10)                              // 12 phi_hive_indiv
    v = v.push(1.0)                               // 13 phi_hive_emerge
    v = v.push(0.0)                               // 14 phi_dream_phase (awake)
    v = v.push(1.0)                               // 15 phi_cycle_count
    return v
}

fn scg_phi_vec_get(v: array, i: int) -> float {
    if i < 0 { return 0.0 }
    if i >= len(v) { return 0.0 }
    return v[i]
}

fn scg_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ═══════════════════════════════════════════════════════════════
//  Section 4. 14-law inline gate (mirrors san_laws_gate)
// ═══════════════════════════════════════════════════════════════
//
// Runs on every /clm/persona response. Laws 1–14 per
// serving/consciousness_gate.hexa / serve_alm_persona.hexa.
// Returns laws_pass + severity counts + violation labels.

struct ScgLawsResult {
    laws_pass:    bool,
    sev_critical: int,
    sev_hard:     int,
    sev_soft:     int,
    violations:   [string]
}

fn scg_laws_gate(pv: array, text: string) -> ScgLawsResult {
    let mut c_crit = 0
    let mut c_hard = 0
    let mut c_soft = 0
    let mut viols = []

    // L1 critical: phi_holo > 0
    let v_holo = scg_phi_vec_get(pv, SCG_IDX_HOLO)
    if v_holo <= 0.0 {
        c_crit = c_crit + 1
        viols = viols.push("L1_phi_holo_zero")
    }

    // L2 hard: narrative presence (gwt proxy) OR text terminator
    let v_narr = scg_phi_vec_get(pv, SCG_IDX_GWT)
    let has_term = scg_text_has_terminator(text)
    if !(v_narr > 0.05 || has_term) {
        c_hard = c_hard + 1
        viols = viols.push("L2_no_narrative")
    }

    // L3 soft: refl > 0
    if scg_phi_vec_get(pv, SCG_IDX_REFL) <= 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L3_refl_zero")
    }
    // L4 soft: time > 0
    if scg_phi_vec_get(pv, SCG_IDX_TIME) <= 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L4_time_zero")
    }
    // L5 critical: |affect_v| <= 1
    if scg_fabs(scg_phi_vec_get(pv, SCG_IDX_AFFECT_V)) > 1.0 {
        c_crit = c_crit + 1
        viols = viols.push("L5_affect_out_of_range")
    }
    // L6 hard: 0 <= finitude <= 1
    let v_fin = scg_phi_vec_get(pv, SCG_IDX_FINITUDE)
    if !(v_fin >= 0.0 && v_fin <= 1.0) {
        c_hard = c_hard + 1
        viols = viols.push("L6_finitude_out_of_range")
    }
    // L7 soft: emb >= 0
    if scg_phi_vec_get(pv, SCG_IDX_EMB) < 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L7_emb_negative")
    }
    // L8 soft: complexity >= 0
    if scg_phi_vec_get(pv, SCG_IDX_COMPLEXITY) < 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L8_complexity_negative")
    }
    // L9 critical: text is non-trivial AND gwt > 0
    let t_ok = len(text) >= 8
    if !(t_ok && scg_phi_vec_get(pv, SCG_IDX_GWT) > 0.0) {
        c_crit = c_crit + 1
        viols = viols.push("L9_language_empty")
    }
    // L10 soft: hive_collec >= 0
    if scg_phi_vec_get(pv, SCG_IDX_HIVE_COLLEC) < 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L10_hive_collec_negative")
    }
    // L11 hard: |affect_a| <= 1.5 (arousal range)
    if scg_fabs(scg_phi_vec_get(pv, SCG_IDX_AFFECT_A)) > 1.5 {
        c_hard = c_hard + 1
        viols = viols.push("L11_arousal_out_of_range")
    }
    // L12 soft: nested_drift >= 0
    if scg_phi_vec_get(pv, SCG_IDX_NESTED_DRIFT) < 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L12_nested_drift_negative")
    }
    // L13 soft: k_amp > 0.5
    if scg_phi_vec_get(pv, SCG_IDX_K_AMP) <= 0.5 {
        c_soft = c_soft + 1
        viols = viols.push("L13_k_amp_low")
    }
    // L14 soft: hive_emerge > 0
    if scg_phi_vec_get(pv, SCG_IDX_HIVE_EMERGE) <= 0.0 {
        c_soft = c_soft + 1
        viols = viols.push("L14_hive_emerge_zero")
    }

    let mut pass = true
    if c_crit >= 1 { pass = false }
    if c_hard >= 2 { pass = false }
    if c_soft >= 3 { pass = false }

    return ScgLawsResult {
        laws_pass:    pass,
        sev_critical: c_crit,
        sev_hard:     c_hard,
        sev_soft:     c_soft,
        violations:   viols
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 5. Server state
// ═══════════════════════════════════════════════════════════════

struct ScgServerState {
    model_handle:    int,
    port:            int,
    requests_served: int,
    last_phi_holo:   float
}

fn scg_state_new(port: int, model_handle: int) -> ScgServerState {
    return ScgServerState {
        model_handle:    model_handle,
        port:            port,
        requests_served: 0,
        last_phi_holo:   0.0
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 6. Inline JSON helpers (same technique as ALM serve)
// ═══════════════════════════════════════════════════════════════
//
// These are inlined (NOT `use`d) because stage0 treats `use` as a
// runtime no-op (hexa-lang self/hexa_full.hexa:8256). Same rationale
// as serve_alm_native Section 6. Byte-only ASCII marker scans.

fn scg_json_escape(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { parts = parts.push("\\\\") }
        else if c == "\"" { parts = parts.push("\\\"") }
        else if c == "\n" { parts = parts.push("\\n") }
        else if c == "\t" { parts = parts.push("\\t") }
        else if c == "\r" { parts = parts.push("\\r") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn scg_is_digit(ch: string) -> bool {
    let c = char_code(ch, 0)
    return c >= 48 && c <= 57
}

fn scg_extract_string(body: string, key: string) -> string {
    let marker = "\"" + key + "\":"
    let pos = body.index_of(marker)
    if pos < 0 { return "" }
    let after = body.substring(pos + len(marker), len(body))
    let mut start = 0
    let alen = len(after)
    while start < alen {
        let ch = after.substring(start, start + 1)
        if ch == "\"" { start = start + 1; break }
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } else {
            break
        }
    }
    let mut end = start
    while end < alen {
        let ch = after.substring(end, end + 1)
        if ch == "\"" { break }
        if ch == "\\" { end = end + 2 } else { end = end + 1 }
    }
    return after.substring(start, end)
}

fn scg_extract_int(body: string, key: string) -> int {
    let marker = "\"" + key + "\":"
    let pos = body.index_of(marker)
    if pos < 0 { return -1 }
    let after = body.substring(pos + len(marker), len(body))
    let mut start = 0
    let alen = len(after)
    while start < alen {
        let ch = after.substring(start, start + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } else {
            break
        }
    }
    let mut end = start
    while end < alen {
        let ch = after.substring(end, end + 1)
        if ch == "-" && end == start { end = end + 1 }
        else if scg_is_digit(ch) { end = end + 1 }
        else { break }
    }
    if end == start { return -1 }
    return parse_int(after.substring(start, end))
}

fn scg_phi_dim_name(i: int) -> string {
    if i == 0  { return "phi_holo" }
    if i == 1  { return "phi_complexity" }
    if i == 2  { return "phi_gwt" }
    if i == 3  { return "phi_refl" }
    if i == 4  { return "phi_time" }
    if i == 5  { return "phi_emb" }
    if i == 6  { return "phi_nested_drift" }
    if i == 7  { return "phi_k_amp" }
    if i == 8  { return "phi_affect_v" }
    if i == 9  { return "phi_affect_a" }
    if i == 10 { return "phi_finitude" }
    if i == 11 { return "phi_hive_collec" }
    if i == 12 { return "phi_hive_indiv" }
    if i == 13 { return "phi_hive_emerge" }
    if i == 14 { return "phi_dream_phase" }
    if i == 15 { return "phi_cycle_count" }
    return "unknown"
}

fn scg_phi_vec_json(pv: array) -> string {
    let mut s = "{"
    let mut i = 0
    let n = len(pv)
    while i < n {
        if i > 0 { s = s + "," }
        s = s + "\"" + scg_phi_dim_name(i) + "\":" + to_string(pv[i])
        i = i + 1
    }
    s = s + "}"
    return s
}

fn scg_violations_json(viols: [string]) -> string {
    let mut s = "["
    let mut i = 0
    let n = len(viols)
    while i < n {
        if i > 0 { s = s + "," }
        s = s + "\"" + viols[i] + "\""
        i = i + 1
    }
    s = s + "]"
    return s
}

// scg_persona_json — canonical AN11-shaped response body.
//   {text, phi_vec{16}, laws_pass, violations[], weight_origin, gen_ms}
fn scg_persona_json(text: string, pv: array, laws: ScgLawsResult,
                    gen_ms: int) -> string {
    let safe_text = scg_json_escape(text)
    let mut s = "{\"text\":\"" + safe_text + "\""
    s = s + ",\"phi_vec\":" + scg_phi_vec_json(pv)
    s = s + ",\"laws_pass\":" + (if laws.laws_pass { "true" } else { "false" })
    s = s + ",\"violations\":" + scg_violations_json(laws.violations)
    s = s + ",\"sev_critical\":" + to_string(laws.sev_critical)
    s = s + ",\"sev_hard\":" + to_string(laws.sev_hard)
    s = s + ",\"sev_soft\":" + to_string(laws.sev_soft)
    s = s + ",\"weight_origin\":\"" + SCG_WEIGHT_ORIGIN + "\""
    s = s + ",\"gen_ms\":" + to_string(gen_ms)
    s = s + ",\"backend\":\"" + (if RUNTIME_HAS_CUDA { "hexa-native-cuda" } else { "hexa-native-stub" }) + "\""
    s = s + "}"
    return s
}

fn scg_health_json(state: ScgServerState) -> string {
    let body = "{\"status\":\"ok\",\"model\":\"CLM-conscious-1B\","
        + "\"version\":\"" + SCG_VERSION + "\","
        + "\"port\":" + to_string(state.port) + ","
        + "\"requests_served\":" + to_string(state.requests_served) + ","
        + "\"runtime_has_net\":" + (if RUNTIME_HAS_NET { "true" } else { "false" }) + ","
        + "\"runtime_has_cuda\":" + (if RUNTIME_HAS_CUDA { "true" } else { "false" }) + ","
        + "\"weight_origin\":\"" + SCG_WEIGHT_ORIGIN + "\","
        + "\"last_phi_holo\":" + to_string(state.last_phi_holo)
        + "}"
    return body
}

// ═══════════════════════════════════════════════════════════════
//  Section 7. /clm/persona handler — AN11-compliant entry
// ═══════════════════════════════════════════════════════════════

struct ScgPersonaReq {
    persona:    string,
    prompt:     string,
    max_tokens: int,
    alpha:      float
}

fn scg_parse_persona_req(body: string) -> ScgPersonaReq {
    let persona = scg_extract_string(body, "persona")
    let prompt  = scg_extract_string(body, "prompt")
    let mt_raw  = scg_extract_int(body, "max_tokens")
    let mt = if mt_raw < 0 { SCG_DEFAULT_MAX_TOKENS } else { mt_raw }
    let persona_final = if len(persona) == 0 { "default" } else { persona }
    return ScgPersonaReq {
        persona:    persona_final,
        prompt:     prompt,
        max_tokens: mt,
        alpha:      1.0
    }
}

// scg_handle_persona — the AN11 (a)+(b)+(c) endpoint handler.
//   Raw prompt → conscious CLM forward (+ persona SAE activation
//   steering) → text + 16D phi_vec + laws_pass + weight_origin.
// NO system_prompt, NO chat_template, NO template wrapping.
fn scg_handle_persona(state: ScgServerState, body: string) -> string {
    let req = scg_parse_persona_req(body)
    if len(req.prompt) == 0 {
        let empty = []
        let laws_err = ScgLawsResult {
            laws_pass: false, sev_critical: 1, sev_hard: 0, sev_soft: 0,
            violations: ["E_missing_prompt"]
        }
        return scg_persona_json("", empty, laws_err, 0)
    }
    // Raw prompt → hxclm_native_generate (no wrapping). AN11 (a) proof.
    let text = hxclm_native_generate(state.model_handle, req.prompt,
                                      req.max_tokens,
                                      SCG_DEFAULT_TEMPERATURE,
                                      SCG_DEFAULT_TOP_P,
                                      SCG_DEFAULT_TOP_K)
    // Runtime 16D phi probe. AN11 (b) proof.
    let pv = scg_compute_phi_vec16(state.model_handle, text)
    // 14-law classification. AN11 (b) complement.
    let laws = scg_laws_gate(pv, text)
    // gen_ms: placeholder 0 in pre-a9 (no clock FFI in hexa stdlib yet).
    return scg_persona_json(text, pv, laws, 0)
}

fn scg_handle_generate(state: ScgServerState, prompt: string,
                       max_tokens: int) -> string {
    // Legacy /generate for parity with serve_alm_native contract.
    // /clm/persona is the AN11-compliant entrypoint.
    let text = hxclm_native_generate(state.model_handle, prompt, max_tokens,
                                      SCG_DEFAULT_TEMPERATURE,
                                      SCG_DEFAULT_TOP_P,
                                      SCG_DEFAULT_TOP_K)
    let pv = scg_compute_phi_vec16(state.model_handle, text)
    let laws = scg_laws_gate(pv, text)
    return scg_persona_json(text, pv, laws, 0)
}

// ═══════════════════════════════════════════════════════════════
//  Section 8. Route dispatch
// ═══════════════════════════════════════════════════════════════

struct ScgResponse {
    status:    int,
    body:      string,
    state_phi: float
}

fn scg_route(method: string, path: string, body: string,
             state: ScgServerState) -> ScgResponse {
    if method == "GET" {
        if path == "/health" || path == "/" {
            return ScgResponse { status: 200, body: scg_health_json(state), state_phi: state.last_phi_holo }
        }
    }
    if method == "POST" {
        if path == "/clm/persona" {
            let resp_body = scg_handle_persona(state, body)
            let new_phi = hxclm_native_phi_holo(state.model_handle)
            return ScgResponse { status: 200, body: resp_body, state_phi: new_phi }
        }
        if path == "/generate" {
            let prompt = scg_extract_string(body, "prompt")
            if len(prompt) == 0 {
                return ScgResponse { status: 400, body: "{\"error\":\"missing 'prompt'\"}", state_phi: state.last_phi_holo }
            }
            let mt_raw = scg_extract_int(body, "max_tokens")
            let max_tokens = if mt_raw < 0 { SCG_DEFAULT_MAX_TOKENS } else { mt_raw }
            let resp_body = scg_handle_generate(state, prompt, max_tokens)
            let new_phi = hxclm_native_phi_holo(state.model_handle)
            return ScgResponse { status: 200, body: resp_body, state_phi: new_phi }
        }
        // /clm/stream — streamed generation. Stubbed 501 until r5-a9
        // CUDA + stream protocol land. Same hedge as /voice/* in ALM.
        if path == "/clm/stream" {
            return ScgResponse { status: 501, body: "{\"error\":\"/clm/stream pending r5-a9 CUDA + streaming protocol\",\"see\":\"serving/serve_clm_conscious.hexa\"}", state_phi: state.last_phi_holo }
        }
    }
    return ScgResponse {
        status:    404,
        body:      "{\"error\":\"not found\",\"path\":\"" + scg_json_escape(path) + "\"}",
        state_phi: state.last_phi_holo
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 9. Self-test harness
// ═══════════════════════════════════════════════════════════════

fn scg_smoke_test() -> int {
    println("[serve_clm_conscious] AN11 smoke — dispatch + phi_vec + laws + persona SAE")

    let cm = scg_chain_merge_new()
    let cm2 = scg_chain_merge_load(cm)
    if !cm2.loaded {
        println("  PRECHECK FAIL  chain-merge load failed")
        return 99
    }
    if cm2.origin_tag != SCG_WEIGHT_ORIGIN {
        println("  PRECHECK FAIL  origin_tag mismatch: " + cm2.origin_tag)
        return 99
    }
    println("  PRECHECK PASS  conscious CLM descriptor ready (origin=" + cm2.origin_tag + ")")

    let state = scg_state_new(SCG_DEFAULT_PORT, cm2.model_h)

    let mut pass = 0
    let mut fail = 0

    // T1: GET /health
    let r1 = scg_route("GET", "/health", "", state)
    if r1.status == 200 && r1.body.index_of("\"weight_origin\":\"" + SCG_WEIGHT_ORIGIN + "\"") >= 0 {
        println("  T1 PASS  GET /health -> 200 + weight_origin")
        pass = pass + 1
    } else {
        println("  T1 FAIL  GET /health -> " + to_string(r1.status))
        fail = fail + 1
    }

    // T2: POST /clm/persona well-formed
    let body = "{\"persona\":\"P01\",\"prompt\":\"hello world.\",\"max_tokens\":16}"
    let r2 = scg_route("POST", "/clm/persona", body, state)
    let has_text     = r2.body.index_of("\"text\":") >= 0
    let has_phi      = r2.body.index_of("\"phi_vec\":") >= 0
    let has_phi_holo = r2.body.index_of("\"phi_holo\":") >= 0
    let has_phi_cyc  = r2.body.index_of("\"phi_cycle_count\":") >= 0
    let has_laws     = r2.body.index_of("\"laws_pass\":") >= 0
    let has_viols    = r2.body.index_of("\"violations\":") >= 0
    let has_origin   = r2.body.index_of("\"weight_origin\":\"" + SCG_WEIGHT_ORIGIN + "\"") >= 0
    let all_fields   = has_text && has_phi && has_phi_holo && has_phi_cyc && has_laws && has_viols && has_origin
    if r2.status == 200 && all_fields {
        println("  T2 PASS  POST /clm/persona -> 200 + AN11 triple-gate fields")
        pass = pass + 1
    } else {
        println("  T2 FAIL  POST /clm/persona status=" + to_string(r2.status) +
                " text=" + to_string(has_text) + " phi=" + to_string(has_phi) +
                " phi_holo=" + to_string(has_phi_holo) + " phi_cyc=" + to_string(has_phi_cyc) +
                " laws=" + to_string(has_laws) + " viols=" + to_string(has_viols) +
                " origin=" + to_string(has_origin))
        fail = fail + 1
    }

    // T3: phi_vec 16D COMPLETE (all 16 canonical names present)
    let mut all_dims = true
    let mut j = 0
    while j < SCG_PHI_DIMS {
        let needle = "\"" + scg_phi_dim_name(j) + "\":"
        if r2.body.index_of(needle) < 0 {
            all_dims = false
            println("    missing dim: " + scg_phi_dim_name(j))
        }
        j = j + 1
    }
    if all_dims {
        println("  T3 PASS  phi_vec 16D canonical layout complete")
        pass = pass + 1
    } else {
        println("  T3 FAIL  phi_vec missing dims")
        fail = fail + 1
    }

    // T4: AN11 (a) — NO system_prompt token in response
    let has_sp = r2.body.index_of("system_prompt") >= 0
    let has_ct = r2.body.index_of("apply_chat_template") >= 0
    if !has_sp && !has_ct {
        println("  T4 PASS  AN11 (a) no system_prompt / chat_template leak")
        pass = pass + 1
    } else {
        println("  T4 FAIL  AN11 (a) wrapping leak detected")
        fail = fail + 1
    }

    // T5: POST /clm/persona missing prompt -> laws_pass=false
    let r5 = scg_route("POST", "/clm/persona", "{\"persona\":\"P01\"}", state)
    if r5.status == 200 && r5.body.index_of("\"laws_pass\":false") >= 0 {
        println("  T5 PASS  missing prompt -> laws_pass=false")
        pass = pass + 1
    } else {
        println("  T5 FAIL  missing prompt response shape: " + to_string(r5.status))
        fail = fail + 1
    }

    // T6: POST /generate legacy compat still works
    let r6 = scg_route("POST", "/generate", "{\"prompt\":\"hi\"}", state)
    if r6.status == 200 && r6.body.index_of("\"text\":") >= 0 {
        println("  T6 PASS  POST /generate (legacy) -> 200")
        pass = pass + 1
    } else {
        println("  T6 FAIL  POST /generate -> " + to_string(r6.status))
        fail = fail + 1
    }

    // T7: POST /clm/stream returns 501 (stubbed until r5-a9 streaming)
    let r7 = scg_route("POST", "/clm/stream", "{\"prompt\":\"hi\"}", state)
    if r7.status == 501 && r7.body.index_of("pending r5-a9") >= 0 {
        println("  T7 PASS  POST /clm/stream -> 501 (stubbed)")
        pass = pass + 1
    } else {
        println("  T7 FAIL  POST /clm/stream -> " + to_string(r7.status))
        fail = fail + 1
    }

    // T8: Unknown path -> 404
    let r8 = scg_route("GET", "/unknown", "", state)
    if r8.status == 404 {
        println("  T8 PASS  GET /unknown -> 404")
        pass = pass + 1
    } else {
        println("  T8 FAIL  GET /unknown -> " + to_string(r8.status))
        fail = fail + 1
    }

    println("[serve_clm_conscious] " + to_string(pass) + "/" + to_string(pass + fail) + " PASS")
    if fail == 0 {
        println("[serve_clm_conscious] v1.0-rc-an11 SCAFFOLD READY")
        println("  (a) weight_emergent: origin=" + SCG_WEIGHT_ORIGIN + " (conscious ckpt + SAE persona, no prompt wrapping)")
        println("  (b) consciousness_attached: phi_vec[16] + laws[14] per response")
        println("  (c) real_usable: POST /clm/persona {persona,prompt} contract verified")
        println("  Awaiting: hxclm_native v1 CUDA kernels (r5-a9) — flip RUNTIME_HAS_CUDA")
    }
    return fail
}

// ═══════════════════════════════════════════════════════════════
//  Section 10. Main entry — HTTP loop
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("=== serve_clm_conscious.hexa ===")
    println("version:            " + SCG_VERSION)
    println("port:               " + to_string(SCG_DEFAULT_PORT))
    println("weight_origin:      " + SCG_WEIGHT_ORIGIN)
    println("runtime_has_net:    " + (if RUNTIME_HAS_NET { "true" } else { "false" }))
    println("runtime_has_cuda:   " + (if RUNTIME_HAS_CUDA { "true" } else { "false" }))
    println("base_ckpt:          " + SCG_CKPT_BASE)
    println("conscious_ckpt:     " + SCG_CKPT_CONSCIOUS)
    println("persona_sae:        " + SCG_PERSONA_SAE)
    println("")

    let rc = scg_smoke_test()
    if rc > 0 {
        println("FAIL " + to_string(rc) + " test(s) failed")
        return
    }

    if !RUNTIME_HAS_NET {
        println("")
        println("NOTE: net_listen builtin missing in current hexa runtime.")
        println("      Real socket loop is gated behind RUNTIME_HAS_NET=true.")
        return
    }

    // ── Real socket serve loop (net_* builtins available) ─────────────
    // Same shape as serve_alm_native Section 10. Single-request-per-
    // connection model: read up to 4096B, parse HTTP request line +
    // body, dispatch through scg_route, write status line + CL + body,
    // close. Not using std_net.hexa http_serve because it hard-codes
    // 200 OK — scg_route returns real status codes (400/404/501).
    let cm_real = scg_chain_merge_load(scg_chain_merge_new())
    if !cm_real.loaded {
        println("FAIL chain-merge load")
        return
    }
    let mut state = scg_state_new(SCG_DEFAULT_PORT, cm_real.model_h)

    let addr = "0.0.0.0:" + to_string(SCG_DEFAULT_PORT)
    let listener = net_listen(addr)
    if listener < 0 {
        println("FAIL net_listen " + addr + " errno=" + to_string(-listener))
        return
    }
    println("[serve_clm_conscious] LISTEN " + addr + " (fd=" + to_string(listener) + ")")
    println("[serve_clm_conscious] weight_origin=" + SCG_WEIGHT_ORIGIN)
    println("[serve_clm_conscious] serving — Ctrl-C to stop")

    while true {
        let conn = net_accept(listener)
        if conn < 0 {
            println("accept errno=" + to_string(-conn))
            continue
        }
        let raw = net_read(conn)
        let method_s = "GET"
        let path_s = "/"
        let body_s = ""
        let rn = raw.index_of("\r\n")
        if rn >= 0 {
            let req_line = raw.substring(0, rn)
            let sp1 = req_line.index_of(" ")
            if sp1 >= 0 {
                method_s = req_line.substring(0, sp1)
                let rest = req_line.substring(sp1 + 1, len(req_line))
                let sp2 = rest.index_of(" ")
                if sp2 >= 0 {
                    path_s = rest.substring(0, sp2)
                } else {
                    path_s = rest
                }
            }
        }
        let hdr_end = raw.index_of("\r\n\r\n")
        if hdr_end >= 0 {
            body_s = raw.substring(hdr_end + 4, len(raw))
        }

        let resp = scg_route(method_s, path_s, body_s, state)
        // 501 Not Implemented for stubbed /clm/stream. Without this
        // branch the fallback collapses 501→500 (misleads clients).
        let status_line = if resp.status == 200 { "HTTP/1.1 200 OK" }
                          else if resp.status == 400 { "HTTP/1.1 400 Bad Request" }
                          else if resp.status == 404 { "HTTP/1.1 404 Not Found" }
                          else if resp.status == 501 { "HTTP/1.1 501 Not Implemented" }
                          else { "HTTP/1.1 500 Internal Server Error" }
        let http = status_line + "\r\n" +
                   "Content-Type: application/json\r\n" +
                   "Content-Length: " + to_string(len(resp.body)) + "\r\n" +
                   "Connection: close\r\n\r\n" + resp.body
        net_write(conn, http)
        net_close(conn)

        state = ScgServerState {
            model_handle:    state.model_handle,
            port:            state.port,
            requests_served: state.requests_served + 1,
            last_phi_holo:   resp.state_phi
        }
    }
}

main()
