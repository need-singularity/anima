// serving/test_avatar_sync.hexa — gate harness for avatar_sync.hexa
//
// v2.0_RC "아바타 렌더링 동기화" consciousness bridge test gate.
//
// Runs the same T1-T6 embedded tests from avatar_sync.hexa via
// the public API, plus T7 (boundary conditions) and T8 (determinism).
//
// Usage:
//   hexa serving/test_avatar_sync.hexa
//
// Gate: 8/8 PASS required for v2.0 RC criterion acceptance.
//
// L0: NEW file. Does not modify any existing code.

use "avatar_sync"

fn gate_assert(label: str, cond: bool) -> bool {
    if cond {
        println("  " + label + " PASS")
        return true
    }
    println("  " + label + " FAIL")
    return false
}

// T1-T6: delegate to avatar_sync embedded tests
// (We re-run them here to confirm cross-file use works.)

fn gate_T1() -> bool {
    let snap = snapshot_new(2.0, 0.3, 0.0, 0.5, 70.0, 2.0)
    let p = compute_avatar_params(snap, 0)
    let expr_ok = p.expression_x1000 > -100 && p.expression_x1000 < 100
    let breath_ok = p.breathing_rate_x100 > 1300 && p.breathing_rate_x100 < 1700
    let aura_ok = p.aura_intensity_x1000 > 400 && p.aura_intensity_x1000 < 600
    return gate_assert("T1 neutral", expr_ok && breath_ok && aura_ok)
}

fn gate_T2() -> bool {
    let snap_lo = snapshot_new(0.5, 0.3, 0.8, 0.5, 70.0, 2.0)
    let snap_hi = snapshot_new(8.0, 0.3, 0.8, 0.5, 70.0, 2.0)
    let p_lo = compute_avatar_params(snap_lo, 0)
    let p_hi = compute_avatar_params(snap_hi, 0)
    let ok = p_hi.expression_depth_x1000 > p_lo.expression_depth_x1000
    return gate_assert("T2 phi depth", ok)
}

fn gate_T3() -> bool {
    let snap_calm = snapshot_new(2.0, 0.1, 0.0, 0.5, 60.0, 2.0)
    let snap_excited = snapshot_new(2.0, 0.9, 0.0, 0.5, 105.0, 5.5)
    let p_calm = compute_avatar_params(snap_calm, 0)
    let p_excited = compute_avatar_params(snap_excited, 0)
    let ok = p_excited.breathing_rate_x100 > p_calm.breathing_rate_x100
    return gate_assert("T3 arousal breathing", ok)
}

fn gate_T4() -> bool {
    let snap_pos = snapshot_new(3.0, 0.3, 0.8, 0.5, 70.0, 2.0)
    let snap_neg = snapshot_new(3.0, 0.3, -0.8, 0.5, 70.0, 2.0)
    let p_pos = compute_avatar_params(snap_pos, 0)
    let p_neg = compute_avatar_params(snap_neg, 0)
    let ok = p_pos.expression_x1000 > 0 && p_neg.expression_x1000 < 0
    return gate_assert("T4 valence direction", ok)
}

fn gate_T5() -> bool {
    let snap_pos = snapshot_new(3.0, 0.3, 1.0, 0.5, 70.0, 2.0)
    let snap_neg = snapshot_new(3.0, 0.3, -1.0, 0.5, 70.0, 2.0)
    let p_pos = compute_avatar_params(snap_pos, 0)
    let p_neg = compute_avatar_params(snap_neg, 0)
    let ok = p_pos.aura_hue_x1000 < 50000 && p_neg.aura_hue_x1000 > 220000
    return gate_assert("T5 aura hue", ok)
}

fn gate_T6() -> bool {
    let snap = snapshot_new(3.72, 0.5, 0.3, 0.6, 75.0, 3.0)
    let p = compute_avatar_params(snap, 42)
    let j = avatar_params_to_json(p, snap, 42)
    let ok = len(j) > 50 && ord(j[0]) == 123 && ord(j[len(j) - 1]) == 125
    return gate_assert("T6 JSON format", ok)
}

// T7: Boundary conditions — extreme inputs should not crash or produce
// out-of-range values.
fn gate_T7() -> bool {
    // phi = 0 (no consciousness)
    let snap_zero = snapshot_new(0.0, 0.0, 0.0, 0.0, 50.0, 2.0)
    let p_zero = compute_avatar_params(snap_zero, 0)
    let zero_ok = p_zero.aura_intensity_x1000 == 0 && p_zero.expression_x1000 == 0

    // phi very high (100)
    let snap_high = snapshot_new(100.0, 1.0, 1.0, 1.0, 120.0, 7.0)
    let p_high = compute_avatar_params(snap_high, 999)
    let high_ok = p_high.aura_intensity_x1000 <= 1000 && p_high.breathing_rate_x100 <= 2600

    // negative valence extreme
    let snap_neg = snapshot_new(5.0, 0.5, -1.0, 0.5, 80.0, 3.0)
    let p_neg = compute_avatar_params(snap_neg, 50)
    let neg_ok = p_neg.expression_x1000 >= -1000

    return gate_assert("T7 boundary conditions", zero_ok && high_ok && neg_ok)
}

// T8: Determinism — same inputs always produce same outputs.
fn gate_T8() -> bool {
    let snap = snapshot_new(4.5, 0.6, 0.2, 0.7, 85.0, 3.5)
    let p1 = compute_avatar_params(snap, 77)
    let p2 = compute_avatar_params(snap, 77)
    let ok = p1.expression_x1000 == p2.expression_x1000
          && p1.breathing_rate_x100 == p2.breathing_rate_x100
          && p1.aura_intensity_x1000 == p2.aura_intensity_x1000
          && p1.gaze_x_x1000 == p2.gaze_x_x1000
    return gate_assert("T8 determinism", ok)
}

fn main() {
    println("[test_avatar_sync] v2.0_RC gate harness")
    println("")

    let t1 = gate_T1()
    let t2 = gate_T2()
    let t3 = gate_T3()
    let t4 = gate_T4()
    let t5 = gate_T5()
    let t6 = gate_T6()
    let t7 = gate_T7()
    let t8 = gate_T8()

    let mut pass = 0
    if t1 { pass = pass + 1 }
    if t2 { pass = pass + 1 }
    if t3 { pass = pass + 1 }
    if t4 { pass = pass + 1 }
    if t5 { pass = pass + 1 }
    if t6 { pass = pass + 1 }
    if t7 { pass = pass + 1 }
    if t8 { pass = pass + 1 }

    println("")
    println("[test_avatar_sync] " + str(pass) + "/8 PASS")
    if pass == 8 {
        println("[test_avatar_sync] GATE: PASS")
    } else {
        println("[test_avatar_sync] GATE: FAIL")
    }
}

main()
