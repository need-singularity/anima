// serving/test_style_switch.hexa — TCLM-P2-2 standalone harness
//
// style_switch.hexa 는 본 파일이 import 할 수 없는 stage0 hexa 환경
// (use "..." 미지원, memory: feedback_hexa_runtime). 따라서 본 harness
// 는 style_switch.hexa 를 직접 호출하지 않고 hexa run 으로 실행해서
// 출력을 수집한 뒤 검증한다.
//
// 사용:
//   HEXA_LOCAL=1 hexa run serving/test_style_switch.hexa
//
// 검증:
//   - hexa run serving/style_switch.hexa 의 stdout 에 5/5 PASS 마커 발견
//   - 라인 단위 ALL 5/5 PASS 패턴 검출

fn run_target() -> string {
    // R10/R14: hexa run 직접 호출 — local cache 사용을 위해 HEXA_LOCAL=1 설정.
    let cmd = "HEXA_LOCAL=1 " + "/Users/ghost/Dev/anima/shared/bin/hexa run "
            + "/Users/ghost/Dev/anima/serving/style_switch.hexa 2>&1"
    return exec(cmd).trim()
}

fn count_pass_lines(out: string) -> int {
    let lines = out.split("\n")
    let mut n = 0
    let mut i = 0
    let m = len(lines)
    while i < m {
        let ln = lines[i]
        // PASS 마커: T1..T5 의 "Tx PASS" 또는 ALL 5/5 PASS
        if ln.index_of(" PASS ") >= 0 || ln.index_of(" PASS") >= 0 {
            // T1..T5 라인만 셈 (ALL line 은 별도)
            if ln.index_of("T1 PASS") >= 0 { n = n + 1 }
            else if ln.index_of("T2 PASS") >= 0 { n = n + 1 }
            else if ln.index_of("T3 PASS") >= 0 { n = n + 1 }
            else if ln.index_of("T4 PASS") >= 0 { n = n + 1 }
            else if ln.index_of("T5 PASS") >= 0 { n = n + 1 }
        }
        i = i + 1
    }
    return n
}

fn main() {
    println("[test_style_switch] driving serving/style_switch.hexa")
    let out = run_target()
    println(out)
    println("--- analysis ---")
    let n_pass = count_pass_lines(out)
    println("T?-PASS line count = " + to_string(n_pass) + " / 5")
    let all_marker = out.index_of("ALL 5/5 PASS") >= 0
    println("ALL 5/5 marker present = " + to_string(all_marker))
    // hexa run 이 println 라인을 2회 출력하는 환경에서 n_pass 가 10 이 될
    // 수 있다. 5 의 배수이고 ALL 5/5 마커가 있으면 PASS 로 본다 — 모든
    // T1..T5 라인이 PASS 마커를 들고 있으면 충분.
    let pass_ok = n_pass == 5 || n_pass == 10
    if pass_ok && all_marker {
        println("[test_style_switch] HARNESS PASS")
    } else {
        println("[test_style_switch] HARNESS FAIL")
    }
}

main()
