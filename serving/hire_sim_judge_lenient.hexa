// Parallel-array lookup. Returns synonyms list, or [] if no match.
fn lookup_synonyms(kw_norm: string) -> array {
    let keys = syn_keywords()
    let vals = syn_values()
    let n = len(keys)
    let mut i = 0
    while i < n {
        if keys[i] == kw_norm { return vals[i] }
        i = i + 1
    }
    return []
}

// ════════════════════════════════════════════════════════════════════
// 4. Lenient match predicate
// ════════════════════════════════════════════════════════════════════

fn matches_lenient(kw: string, text_norm: string) -> bool {
    let kw_norm = normalize_text(kw)
    // 4a. direct contains
    if text_norm.contains(kw_norm) { return true }
    // 4b. synonym contains (each synonym normalized + stemmed fallback)
    let syns = lookup_synonyms(kw_norm)
    let mut i = 0
    while i < len(syns) {
        let sn_norm = normalize_text(syns[i])
        if text_norm.contains(sn_norm) { return true }
        if !sn_norm.contains(" ") {
            let sn_stem = simple_stem(sn_norm)
            if len(sn_stem) >= 4 && text_norm.contains(sn_stem) { return true }
        }
        i = i + 1
    }
    // 4c. stem the keyword itself and check
    if !kw_norm.contains(" ") {
        let kw_stem = simple_stem(kw_norm)
        if len(kw_stem) >= 4 && text_norm.contains(kw_stem) { return true }
    }
    return false
}

// ════════════════════════════════════════════════════════════════════
// 5. Public scoring API (single-keyword ANY-match per task spec)
// ════════════════════════════════════════════════════════════════════

// Count how many gold keywords match leniently in the candidate.
fn judge_lenient_hit_count(candidate: string, gold: array) -> int {
    let text_norm = normalize_text(candidate)
    let n = len(gold)
    let mut hits = 0
    let mut i = 0
    while i < n {
        if matches_lenient(gold[i], text_norm) { hits = hits + 1 }
        i = i + 1
    }
    return hits
}

// Per task spec: 1.0 if ANY synonym/stemmed match, 0.0 otherwise.
fn judge_lenient_score(candidate: string, gold: array) -> float {
    if len(gold) == 0 { return 0.0 }
    let hits = judge_lenient_hit_count(candidate, gold)
    if hits > 0 { return 1.0 }
    return 0.0
}

// Strict mirror for comparison (byte-for-byte match, lowercase).
fn judge_strict_hit_count(candidate: string, gold: array) -> int {
    let lo = candidate.to_lower()
    let n = len(gold)
    let mut hits = 0
    let mut i = 0
    while i < n {
        let kw_lo = gold[i].to_lower()
        if lo.contains(kw_lo) { hits = hits + 1 }
        i = i + 1
    }
    return hits
}

fn judge_strict_score(candidate: string, gold: array) -> float {
    if len(gold) == 0 { return 0.0 }
    let hits = judge_strict_hit_count(candidate, gold)
    if hits > 0 { return 1.0 }
    return 0.0
}
