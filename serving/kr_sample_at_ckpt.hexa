// ═══════════════════════════════════════════════════════════════
//  serving/kr_sample_at_ckpt.hexa — ALM 14B KR sample @ ckpt save
//
//  Runs 5 Korean greedy-decode samples against an ALM 14B LoRA
//  checkpoint and appends results to /workspace/kr_samples.log.
//
//  PROMPTS (hard-coded per task spec):
//    ["안녕하세요", "오늘 날씨", "한국어 모델", "딥러닝이란", "안녕"]
//
//  OUTPUT FORMAT (one line per prompt):
//    [kr_sample] step=N prompt="..." gen="..."
//
//  GAP NOTE — HEXA-FIRST rationale + fallback:
//    ALM 14B is Qwen/Qwen2.5-14B-Instruct + PEFT LoRA safetensors.
//    The live training path is train_alm_14b.hexa (PyTorch/transformers via exec).
//    There is no hexa-native Qwen2.5 loader or BPE tokenizer on the pod,
//    so this wrapper shells out to a tiny Python generator that uses
//    the same transformers+peft stack the trainer uses. When a
//    hexa-native ALM loader ships (HEXACKPT-v1 path in train_alm_lora),
//    swap the exec() body here for a direct load.
//
//  Usage:
//    hexa /workspace/anima/serving/kr_sample_at_ckpt.hexa
//      # auto-picks latest step_NNNN under /workspace/ckpt_alm_14b_r4/
//    echo /path/to/step_NNNN > /tmp/kr_ckpt_path.txt
//    hexa /workspace/anima/serving/kr_sample_at_ckpt.hexa
//      # uses /tmp/kr_ckpt_path.txt (args() ordering-bug workaround)
//
//  Side-effects:
//    - writes /tmp/kr_gen.py helper (idempotent)
//    - invokes python3 /tmp/kr_gen.py <ckpt_path> > /tmp/kr_gen.out
//    - appends to /workspace/kr_samples.log
//
//  NOTE 2026-04-12: Uses only substring + len + trim + starts_with
//  for string operations (no .split/.replace/.contains/.find/.rfind,
//  which are not guaranteed in the current hexa binary).
// ═══════════════════════════════════════════════════════════════

let CKPT_ROOT   = "/workspace/ckpt_alm_14b_r4"
let SAMPLES_LOG = "/workspace/kr_samples.log"
let HELPER_PATH = "/tmp/kr_gen.py"
let ARG_FILE    = "/tmp/kr_ckpt_path.txt"
let BASE_MODEL  = "Qwen/Qwen2.5-14B-Instruct"
let MAX_NEW     = 48

// ── Manual string helpers ──────────────────────────────────────
fn str_contains(hay, needle) {
    let hn = len(hay)
    let nn = len(needle)
    if nn == 0 { return true }
    if nn > hn { return false }
    let mut i = 0
    while i + nn <= hn {
        if hay.substring(i, i + nn) == needle { return true }
        i = i + 1
    }
    return false
}

fn str_index_of(hay, needle) {
    // Returns first byte-offset of needle in hay, or -1.
    let hn = len(hay)
    let nn = len(needle)
    if nn == 0 { return 0 }
    if nn > hn { return -1 }
    let mut i = 0
    while i + nn <= hn {
        if hay.substring(i, i + nn) == needle { return i }
        i = i + 1
    }
    return -1
}

fn str_last_slash(s) {
    // Returns index of last '/' or -1.
    let n = len(s)
    let mut i = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == "/" { return i }
        i = i - 1
    }
    return -1
}

fn split_lines(text) {
    let n = len(text)
    let mut lines = []
    let mut start = 0
    let mut i = 0
    while i < n {
        if text.substring(i, i + 1) == "\n" {
            lines = lines.push(text.substring(start, i))
            start = i + 1
        }
        i = i + 1
    }
    if start < n { lines = lines.push(text.substring(start, n)) }
    return lines
}

fn now_stamp() {
    return exec("date +%Y-%m-%dT%H:%M:%S").trim()
}

// ── Ckpt resolution ────────────────────────────────────────────
fn resolve_ckpt() {
    if file_exists(ARG_FILE) {
        let raw = read_file(ARG_FILE)
        let p = raw.trim()
        if len(p) > 0 { return p }
    }
    let out = exec("ls " + CKPT_ROOT + " 2>/dev/null | grep '^step_' | sort -V | tail -1")
    let latest = out.trim()
    if len(latest) == 0 { return "" }
    return CKPT_ROOT + "/" + latest
}

fn parse_step_from_path(p) {
    let idx = str_last_slash(p)
    let base = p.substring(idx + 1, len(p))
    if base.starts_with("step_") {
        return base.substring(5, len(base))
    }
    return "unknown"
}

// ── Python helper (written once per invocation) ────────────────
fn write_helper() {
    // NOTE: Korean prompts hand-rolled as JSON with \u escapes so we
    // never have to embed raw multibyte UTF-8 inside a hexa string
    // literal (the hexa lexer's treatment of multi-byte is untested
    // and we want to stay on the safe path).
    //
    // DEVICE POLICY: ALM_DEVICE env var controls placement.
    //   'cpu'  (default): safe, non-intrusive to running GPU training
    //   'cuda': fast but contends with running train_alm_14b.hexa
    //   'auto': accelerate decides (may offload base to CPU)
    let py = "#!/usr/bin/env python3\n" +
        "# Auto-generated by kr_sample_at_ckpt.hexa. DO NOT EDIT BY HAND.\n" +
        "import sys, json, time, os\n" +
        "import torch\n" +
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n" +
        "from peft import PeftModel\n" +
        "\n" +
        "BASE = os.environ.get('ALM_BASE', '" + BASE_MODEL + "')\n" +
        "CKPT = sys.argv[1]\n" +
        "MAX_NEW = int(os.environ.get('ALM_MAX_NEW', '" + str(MAX_NEW) + "'))\n" +
        "DEVICE = os.environ.get('ALM_DEVICE', 'cpu')\n" +
        "\n" +
        "PROMPTS = [\n" +
        "    '\\uc548\\ub155\\ud558\\uc138\\uc694',\n" +
        "    '\\uc624\\ub298 \\ub0a0\\uc528',\n" +
        "    '\\ud55c\\uad6d\\uc5b4 \\ubaa8\\ub378',\n" +
        "    '\\ub525\\ub7ec\\ub2dd\\uc774\\ub780',\n" +
        "    '\\uc548\\ub155',\n" +
        "]\n" +
        "\n" +
        "def log(msg):\n" +
        "    print(msg, flush=True)\n" +
        "\n" +
        "log(f'[kr_gen] base={BASE} ckpt={CKPT} device={DEVICE}')\n" +
        "t0 = time.time()\n" +
        "tok = AutoTokenizer.from_pretrained(BASE, trust_remote_code=True)\n" +
        "\n" +
        "load_kwargs = dict(\n" +
        "    torch_dtype=torch.bfloat16,\n" +
        "    trust_remote_code=True,\n" +
        ")\n" +
        "if DEVICE == 'cpu':\n" +
        "    model = AutoModelForCausalLM.from_pretrained(BASE, **load_kwargs)\n" +
        "    model = model.to('cpu')\n" +
        "elif DEVICE == 'auto':\n" +
        "    model = AutoModelForCausalLM.from_pretrained(BASE, device_map='auto', **load_kwargs)\n" +
        "else:\n" +
        "    model = AutoModelForCausalLM.from_pretrained(BASE, **load_kwargs)\n" +
        "    model = model.to(DEVICE)\n" +
        "\n" +
        "model = PeftModel.from_pretrained(model, CKPT)\n" +
        "model.eval()\n" +
        "log(f'[kr_gen] loaded in {time.time()-t0:.1f}s')\n" +
        "\n" +
        "results = []\n" +
        "for p in PROMPTS:\n" +
        "    tg = time.time()\n" +
        "    enc = tok(p, return_tensors='pt').to(model.device)\n" +
        "    with torch.no_grad():\n" +
        "        out = model.generate(\n" +
        "            **enc,\n" +
        "            max_new_tokens=MAX_NEW,\n" +
        "            do_sample=False,\n" +
        "            num_beams=1,\n" +
        "            pad_token_id=tok.eos_token_id,\n" +
        "        )\n" +
        "    full = tok.decode(out[0], skip_special_tokens=True)\n" +
        "    gen = full[len(p):] if full.startswith(p) else full\n" +
        "    gen = gen.replace('\\n', ' ').strip()\n" +
        "    results.append({'prompt': p, 'gen': gen})\n" +
        "    log(f'[kr_gen] prompt done in {time.time()-tg:.1f}s')\n" +
        "\n" +
        "print('===KR_SAMPLES_BEGIN===', flush=True)\n" +
        "print(json.dumps(results, ensure_ascii=False), flush=True)\n" +
        "print('===KR_SAMPLES_END===', flush=True)\n"
    write_file(HELPER_PATH, py)
}

// ── Append helper (via unique tmp + cat >> to avoid /tmp-full races) ──
let TMP_DIR = "/workspace/tmp_zstd"

fn append_log(line) {
    let stamp = now_stamp()
    let full = "[" + stamp + "] " + line + "\n"
    let nano = exec("date +%s%N").trim()
    let tmp_line = TMP_DIR + "/.kr_log_" + nano + ".txt"
    write_file(tmp_line, full)
    let _ = exec("cat " + tmp_line + " >> " + SAMPLES_LOG + " && rm -f " + tmp_line)
    println(full.substring(0, len(full) - 1))
}

fn main() {
    let ckpt = resolve_ckpt()
    if len(ckpt) == 0 {
        println("[kr_sample] FATAL — no checkpoint found under " + CKPT_ROOT)
        append_log("[kr_sample] ERROR ckpt_missing root=" + CKPT_ROOT)
        return
    }
    if !file_exists(ckpt + "/adapter_config.json") {
        println("[kr_sample] FATAL — not a LoRA ckpt (missing adapter_config.json): " + ckpt)
        append_log("[kr_sample] ERROR not_lora ckpt=" + ckpt)
        return
    }

    let step = parse_step_from_path(ckpt)
    append_log("[kr_sample] BEGIN step=" + step + " ckpt=" + ckpt)

    write_helper()

    let run_cmd = "python3 " + HELPER_PATH + " " + ckpt +
        " > /tmp/kr_gen.out 2>&1; echo RC=$?"
    let rc_out = exec(run_cmd)
    if !str_contains(rc_out, "RC=0") {
        let tail = exec("tail -20 /tmp/kr_gen.out 2>&1")
        append_log("[kr_sample] ERROR rc!=0 step=" + step)
        append_log("[kr_sample] ERROR tail=" + tail.substring(0, 400))
        return
    }

    // Extract JSON results between markers.
    let raw = read_file("/tmp/kr_gen.out")
    let begin_tag = "===KR_SAMPLES_BEGIN==="
    let end_tag   = "===KR_SAMPLES_END==="
    let bi = str_index_of(raw, begin_tag)
    let ei = str_index_of(raw, end_tag)
    if bi < 0 || ei < 0 || ei <= bi {
        append_log("[kr_sample] ERROR missing_markers step=" + step)
        return
    }
    let mid = raw.substring(bi + len(begin_tag), ei)
    let json_line = mid.trim()

    // Emit per-prompt lines via a python one-liner (the JSON parser)
    // writing directly to SAMPLES_LOG. This keeps UTF-8 bytes intact
    // without re-implementing JSON in hexa.
    let json_tmp = "/tmp/.kr_sample_json.txt"
    write_file(json_tmp, json_line)
    let stamp = now_stamp()
    let emit_cmd = "python3 -c \"" +
        "import json,sys,time; " +
        "d=json.loads(open('" + json_tmp + "').read()); " +
        "stamp='" + stamp + "'; " +
        "step='" + step + "'; " +
        "lines=[f'[{stamp}] [kr_sample] step={step} prompt=\\\"'+r['prompt']+'\\\" gen=\\\"'+r['gen']+'\\\"' for r in d]; " +
        "open('" + SAMPLES_LOG + "','a').write('\\n'.join(lines)+'\\n'); " +
        "print('\\n'.join(lines))\""
    let emit_out = exec(emit_cmd)
    println(emit_out)

    append_log("[kr_sample] END step=" + step)
    let _ = exec("rm -f " + json_tmp)
}

main()
