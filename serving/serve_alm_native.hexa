// serving/serve_alm_native.hexa — ALM 14B native HEXA serve scaffold
//
// v2.0 RC criterion: replace serve_alm_14b.py (Python) with .hexa-only serve.
// User directive (R-NO-PYTHON): NO Python fallback. NO subprocess.
//
// ── Status (2026-04-16) ──────────────────────────────────────────────
// BLOCKER: live hexa_stage0 binary lacks net_listen/net_accept/net_read/
// net_write/net_close builtins. std_net.hexa exists only in a hexa-lang
// worktree branch (rt-32-j) and has not been merged into the runtime.
//
// Therefore this file is currently a SCAFFOLD that:
//   1. Validates JSON request/response shaping (logic-only, no socket).
//   2. Mounts the voice_routes / hire_routes / avatar handlers in a
//      single dispatch fn route_path(method, path, body).
//   3. Calls a forward_qwen14b FFI hook (extern; will resolve once
//      hxlmhead Linux .so + Qwen weight loader land).
//   4. Self-tests via a request_table[] inside main() — proves the
//      handler dispatch is wire-compatible with serve_alm_14b.py.
//
// Hexa-first principle (R1): once net_listen lands in the live binary,
// flip RUNTIME_HAS_NET = true, wire net_accept loop, and this becomes
// the canonical serve. No code changes outside that block needed.
//
// Architecture decision: Option A — hexa orchestrates, FFI to compiled
// C/CUDA shim does the Qwen forward. Subprocess Python is FORBIDDEN.
// libtorch (Option C) deferred — adds 4GB dep + bf16 ABI complexity.

use "voice_routes"
use "hire_routes"

// ─── Runtime feature gate ──────────────────────────────────────────
let RUNTIME_HAS_NET = false   // flip to true when hexa stdlib has net_*
let RUNTIME_HAS_FFI_QWEN = false  // flip when hxqwen14b_forward .so lands

// ─── Constants (mirror serve_alm_14b.py) ───────────────────────────
let SAN_VERSION       = "2.0-rc-native"
let SAN_DEFAULT_PORT  = 8090
let SAN_DEFAULT_MAX_TOKENS  = 256
let SAN_DEFAULT_TEMPERATURE = 0.8
let SAN_DEFAULT_TOP_P       = 0.9
let SAN_DEFAULT_TOP_K       = 50
let SAN_DEFAULT_REP_PENALTY = 1.2
let SAN_PSI_ALPHA           = 0.014
let SAN_PSI_BALANCE         = 0.5

// ─── FFI extern declarations (resolve once .so lands) ──────────────
// These will use @link("hxqwen14b") once codegen_c2 supports platform
// conditional linking on Linux. Today they fall back to mock paths.

fn hxqwen14b_load(ckpt_path: string) -> int {
    // FFI stub — returns model handle (int).
    // Real impl: dlopen libhxqwen14b.so; call qwen14b_load_lora(ckpt).
    if RUNTIME_HAS_FFI_QWEN { return 1 }
    return 0
}

fn hxqwen14b_generate(model_handle: int, prompt: string, max_tokens: int,
                       temperature: float, top_p: float, top_k: int) -> string {
    // FFI stub — returns generated text.
    // Real impl: dlsym hxqwen14b_generate; runs Qwen14B + LoRA fwd loop
    // with KV-cache, sampling, EOS detect.
    if RUNTIME_HAS_FFI_QWEN {
        return "[hxqwen14b] " + prompt
    }
    return "[mock-native-serve] " + prompt + " (FFI unavailable)"
}

fn hxqwen14b_compute_phi_holo(model_handle: int) -> float {
    // FFI stub — returns last-step phi_holo.
    // Real impl: read model.last_hidden_states; compute MI-binned phi.
    if RUNTIME_HAS_FFI_QWEN { return 0.42 }
    return 0.0
}

// ─── Server state ──────────────────────────────────────────────────

struct SanServerState {
    model_handle: int,
    port: int,
    requests_served: int,
    start_ms: int,
    last_phi: float,
    last_tension: float
}

fn san_state_new(port: int, model_handle: int) -> SanServerState {
    return SanServerState {
        model_handle: model_handle,
        port: port,
        requests_served: 0,
        start_ms: 0,
        last_phi: 0.0,
        last_tension: 0.0
    }
}

// ─── JSON response builders (string-only, no effect system) ────────

fn san_health_json(state: SanServerState) -> string {
    let body = "{\"status\":\"ok\",\"model\":\"ALM-14B-r9-LoRA\","
        + "\"version\":\"" + SAN_VERSION + "\","
        + "\"port\":" + to_string(state.port) + ","
        + "\"requests_served\":" + to_string(state.requests_served) + ","
        + "\"runtime_has_net\":" + (if RUNTIME_HAS_NET { "true" } else { "false" }) + ","
        + "\"runtime_has_ffi_qwen\":" + (if RUNTIME_HAS_FFI_QWEN { "true" } else { "false" }) + ","
        + "\"phi\":" + to_string(state.last_phi) + ","
        + "\"tension\":" + to_string(state.last_tension)
        + "}"
    return body
}

fn san_consciousness_json(state: SanServerState) -> string {
    return "{\"phi\":" + to_string(state.last_phi)
        + ",\"tension\":" + to_string(state.last_tension)
        + ",\"balance\":" + to_string(SAN_PSI_BALANCE)
        + ",\"coupling\":" + to_string(SAN_PSI_ALPHA)
        + ",\"requests_served\":" + to_string(state.requests_served)
        + "}"
}

fn san_generate_json(state: SanServerState, prompt: string, max_tokens: int) -> string {
    let text = hxqwen14b_generate(state.model_handle, prompt, max_tokens,
                                    SAN_DEFAULT_TEMPERATURE, SAN_DEFAULT_TOP_P, SAN_DEFAULT_TOP_K)
    let phi = hxqwen14b_compute_phi_holo(state.model_handle)
    let safe_text = vr_json_escape(text)
    return "{\"text\":\"" + safe_text + "\","
        + "\"tokens_generated\":" + to_string(len(text)) + ","
        + "\"latency_ms\":0,"
        + "\"consciousness\":{\"phi_holo\":" + to_string(phi) + ",\"tension\":0.0,"
        + "\"orch_or_active\":" + (if phi > 0.5 { "true" } else { "false" }) + "},"
        + "\"model\":{\"name\":\"ALM-14B-r9-LoRA\",\"backend\":\"hexa-native\"}"
        + "}"
}

// ─── Route dispatch (pure function, testable without sockets) ──────

struct SanResponse {
    status: int,
    body: string,
    state_phi: float
}

fn san_route(method: string, path: string, body: string,
             state: SanServerState) -> SanResponse {
    // /health and /
    if method == "GET" {
        if path == "/health" || path == "/" {
            return SanResponse { status: 200, body: san_health_json(state), state_phi: state.last_phi }
        }
        if path == "/voice/health" {
            return SanResponse { status: 200, body: vr_health_json(), state_phi: state.last_phi }
        }
        if path == "/voice/profiles" {
            return SanResponse { status: 200, body: vr_profiles_json(), state_phi: state.last_phi }
        }
        if path == "/hire/capabilities" {
            let presets = hr_presets_extended()
            let personas = hr_personas()
            return SanResponse { status: 200, body: hr_capabilities_json(presets, personas), state_phi: state.last_phi }
        }
    }
    if method == "POST" {
        if path == "/generate" {
            let prompt = vr_extract_string(body, "prompt")
            if len(prompt) == 0 {
                return SanResponse { status: 400, body: "{\"error\":\"missing 'prompt'\"}", state_phi: state.last_phi }
            }
            let max_tok_raw = vr_extract_int(body, "max_tokens")
            let max_tokens = if max_tok_raw < 0 { SAN_DEFAULT_MAX_TOKENS } else { max_tok_raw }
            let resp_body = san_generate_json(state, prompt, max_tokens)
            let new_phi = hxqwen14b_compute_phi_holo(state.model_handle)
            return SanResponse { status: 200, body: resp_body, state_phi: new_phi }
        }
        if path == "/consciousness" {
            return SanResponse { status: 200, body: san_consciousness_json(state), state_phi: state.last_phi }
        }
        if path == "/voice/tts" {
            let resp = vr_handle_tts(body)
            let json_body = vr_tts_response_json(resp)
            let code = if resp.ok { 200 } else { 400 }
            return SanResponse { status: code, body: json_body, state_phi: state.last_phi }
        }
        if path == "/voice/e2e" {
            let resp = vr_handle_e2e(body)
            let json_body = vr_e2e_response_json(resp)
            let code = if resp.ok { 200 } else { 400 }
            return SanResponse { status: code, body: json_body, state_phi: state.last_phi }
        }
    }
    return SanResponse {
        status: 404,
        body: "{\"error\":\"not found\",\"path\":\"" + vr_json_escape(path) + "\"}",
        state_phi: state.last_phi
    }
}

// ─── Self-test harness (proves dispatch wire-compat) ───────────────

fn san_smoke_test() -> int {
    println("[serve_alm_native] smoke test — dispatch (no sockets)")
    let state = san_state_new(SAN_DEFAULT_PORT, hxqwen14b_load("/tmp/dummy"))

    let mut pass = 0
    let mut fail = 0

    // T1: GET /health → 200 + status:ok
    let r1 = san_route("GET", "/health", "", state)
    if r1.status == 200 && r1.body.index_of("\"status\":\"ok\"") >= 0 {
        println("  T1 PASS  GET /health → 200")
        pass = pass + 1
    } else {
        println("  T1 FAIL  GET /health → " + to_string(r1.status))
        fail = fail + 1
    }

    // T2: GET /voice/health → 200
    let r2 = san_route("GET", "/voice/health", "", state)
    if r2.status == 200 {
        println("  T2 PASS  GET /voice/health → 200")
        pass = pass + 1
    } else {
        println("  T2 FAIL  GET /voice/health → " + to_string(r2.status))
        fail = fail + 1
    }

    // T3: GET /voice/profiles → 200 + 10 profiles
    let r3 = san_route("GET", "/voice/profiles", "", state)
    if r3.status == 200 && r3.body.index_of("school_idol") >= 0 {
        println("  T3 PASS  GET /voice/profiles → 200 (10 profiles)")
        pass = pass + 1
    } else {
        println("  T3 FAIL  GET /voice/profiles → " + to_string(r3.status))
        fail = fail + 1
    }

    // T4: POST /generate {prompt:"hi"} → 200
    let r4 = san_route("POST", "/generate", "{\"prompt\":\"hi\",\"max_tokens\":16}", state)
    if r4.status == 200 && r4.body.index_of("\"text\":") >= 0 {
        println("  T4 PASS  POST /generate → 200 (mock-native-serve)")
        pass = pass + 1
    } else {
        println("  T4 FAIL  POST /generate → " + to_string(r4.status))
        fail = fail + 1
    }

    // T5: POST /generate {} → 400 missing prompt
    let r5 = san_route("POST", "/generate", "{}", state)
    if r5.status == 400 {
        println("  T5 PASS  POST /generate {} → 400 (missing prompt)")
        pass = pass + 1
    } else {
        println("  T5 FAIL  POST /generate {} → " + to_string(r5.status))
        fail = fail + 1
    }

    // T6: GET /unknown → 404
    let r6 = san_route("GET", "/unknown", "", state)
    if r6.status == 404 {
        println("  T6 PASS  GET /unknown → 404")
        pass = pass + 1
    } else {
        println("  T6 FAIL  GET /unknown → " + to_string(r6.status))
        fail = fail + 1
    }

    // T7: GET /hire/capabilities → 200
    let r7 = san_route("GET", "/hire/capabilities", "", state)
    if r7.status == 200 {
        println("  T7 PASS  GET /hire/capabilities → 200")
        pass = pass + 1
    } else {
        println("  T7 FAIL  GET /hire/capabilities → " + to_string(r7.status))
        fail = fail + 1
    }

    println("[serve_alm_native] " + to_string(pass) + "/" + to_string(pass + fail) + " PASS")
    if fail == 0 {
        println("[serve_alm_native] SCAFFOLD READY — awaiting net_listen builtin + hxqwen14b .so")
    }
    return fail
}

// ─── Main entry ────────────────────────────────────────────────────

fn main() {
    println("=== serve_alm_native.hexa ===")
    println("version:           " + SAN_VERSION)
    println("port:              " + to_string(SAN_DEFAULT_PORT))
    println("runtime_has_net:   " + (if RUNTIME_HAS_NET { "true" } else { "false" }))
    println("runtime_has_ffi:   " + (if RUNTIME_HAS_FFI_QWEN { "true" } else { "false" }))
    println("")

    let rc = san_smoke_test()
    if rc > 0 {
        println("FAIL — " + to_string(rc) + " test(s) failed")
        return
    }

    if !RUNTIME_HAS_NET {
        println("")
        println("NOTE: net_listen builtin missing in current hexa runtime.")
        println("      Real socket loop is gated behind RUNTIME_HAS_NET=true.")
        println("      Today: scaffold only. Dispatch verified, sockets pending.")
        println("")
        println("To bring online:")
        println("  1. Land net_listen/accept/read/write/close in hexa runtime")
        println("     (already exists in self/std_net.hexa branch rt-32-j)")
        println("  2. Build libhxqwen14b.so with Qwen2.5-14B + LoRA forward")
        println("     (FFI stubs hxqwen14b_load/generate/compute_phi_holo)")
        println("  3. Flip RUNTIME_HAS_NET = true, RUNTIME_HAS_FFI_QWEN = true")
        println("  4. Wire net_accept loop in serve_loop()")
        println("  5. Replace serve_alm_14b.py on ALM pod itfl66q4z768kh")
        return
    }

    // Future path — once net builtins land:
    //   let listener = net_listen("0.0.0.0:" + to_string(SAN_DEFAULT_PORT))
    //   let model_handle = hxqwen14b_load("/workspace/ckpt_r9")
    //   let mut state = san_state_new(SAN_DEFAULT_PORT, model_handle)
    //   loop {
    //     let conn = net_accept(listener)
    //     let raw = net_read(conn)
    //     let req = parse_http_request(raw)
    //     let resp = san_route(req.method, req.path, req.body, state)
    //     state = state with { last_phi: resp.state_phi,
    //                          requests_served: state.requests_served + 1 }
    //     net_write(conn, build_http_response(resp.status, resp.body))
    //     net_close(conn)
    //   }
}

main()
