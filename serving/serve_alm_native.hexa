struct SanServerState {
    model_handle:    int,
    port:            int,
    requests_served: int,
    last_phi_holo:   float
}

fn san_state_new(port: int, model_handle: int) -> SanServerState {
    return SanServerState {
        model_handle:    model_handle,
        port:            port,
        requests_served: 0,
        last_phi_holo:   0.0
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 6. JSON builders (phi_vec 16D canonical names)
// ═══════════════════════════════════════════════════════════════

// ─── Inlined JSON helpers (2026-04-20 P1 serve blocker close) ────────
// Root cause: stage0 interpreter treats `use "voice_routes"` as a no-op
// (hexa-lang self/hexa_full.hexa:8256 — `if k == "Use" { return val_void() }`).
// The imported vr_* / hr_* functions NEVER land in env_fns, so every call
// site resolved as "Runtime error: undefined function" → silent val_void
// → downstream logic (len(prompt)==0) false-negatived, bouncing /generate
// to 400 and making smoke test fail, which aborted main() before reaching
// net_listen. Proper fix needs module_loader preprocessing pipeline
// integration (tracked: dest1_alm follow-up) — this inlines the 3 byte-JSON
// helpers san_route actually needs so the server binds TODAY.
fn san_json_escape(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { parts = parts.push("\\\\") }
        else if c == "\"" { parts = parts.push("\\\"") }
        else if c == "\n" { parts = parts.push("\\n") }
        else if c == "\t" { parts = parts.push("\\t") }
        else if c == "\r" { parts = parts.push("\\r") }
        else { parts = parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn san_is_digit(ch: string) -> bool {
    let c = char_code(ch, 0)
    return c >= 48 && c <= 57
}

// Byte-only ASCII marker scan — same technique as voice_routes.hexa:877.
// Looks for "key":" and extracts until next unescaped ".
fn san_extract_string(body: string, key: string) -> string {
    let marker = "\"" + key + "\":"
    let pos = body.index_of(marker)
    if pos < 0 { return "" }
    let after = body.substring(pos + len(marker), len(body))
    let mut start = 0
    let alen = len(after)
    while start < alen {
        let ch = after.substring(start, start + 1)
        if ch == "\"" { start = start + 1; break }
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } else {
            break
        }
    }
    let mut end = start
    while end < alen {
        let ch = after.substring(end, end + 1)
        if ch == "\"" { break }
        if ch == "\\" { end = end + 2 } else { end = end + 1 }
    }
    return after.substring(start, end)
}

fn san_extract_int(body: string, key: string) -> int {
    let marker = "\"" + key + "\":"
    let pos = body.index_of(marker)
    if pos < 0 { return -1 }
    let after = body.substring(pos + len(marker), len(body))
    let mut start = 0
    let alen = len(after)
    while start < alen {
        let ch = after.substring(start, start + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } else {
            break
        }
    }
    let mut end = start
    while end < alen {
        let ch = after.substring(end, end + 1)
        if ch == "-" && end == start { end = end + 1 }
        else if san_is_digit(ch) { end = end + 1 }
        else { break }
    }
    if end == start { return -1 }
    return parse_int(after.substring(start, end))
}

fn san_phi_dim_name(i: int) -> string {
    if i == 0  { return "phi_holo" }
    if i == 1  { return "phi_complexity" }
    if i == 2  { return "phi_gwt" }
    if i == 3  { return "phi_refl" }
    if i == 4  { return "phi_time" }
    if i == 5  { return "phi_emb" }
    if i == 6  { return "phi_nested_drift" }
    if i == 7  { return "phi_k_amp" }
    if i == 8  { return "phi_affect_v" }
    if i == 9  { return "phi_affect_a" }
    if i == 10 { return "phi_finitude" }
    if i == 11 { return "phi_hive_collec" }
    if i == 12 { return "phi_hive_indiv" }
    if i == 13 { return "phi_hive_emerge" }
    if i == 14 { return "phi_dream_phase" }
    if i == 15 { return "phi_cycle_count" }
    return "unknown"
}

fn san_phi_vec_json(pv: array) -> string {
    let mut s = "{"
    let mut i = 0
    let n = len(pv)
    while i < n {
        if i > 0 { s = s + "," }
        s = s + "\"" + san_phi_dim_name(i) + "\":" + to_string(pv[i])
        i = i + 1
    }
    s = s + "}"
    return s
}

fn san_violations_json(viols: [string]) -> string {
    let mut s = "["
    let mut i = 0
    let n = len(viols)
    while i < n {
        if i > 0 { s = s + "," }
        s = s + "\"" + viols[i] + "\""
        i = i + 1
    }
    s = s + "]"
    return s
}

// san_persona_json — canonical AN11-shaped response body.
//   {text, phi_vec{16}, laws_pass, violations[], weight_origin, gen_ms}
fn san_persona_json(text: string, pv: array, laws: SanLawsResult,
                    gen_ms: int) -> string {
    let safe_text = san_json_escape(text)
    let mut s = "{\"text\":\"" + safe_text + "\""
    s = s + ",\"phi_vec\":" + san_phi_vec_json(pv)
    s = s + ",\"laws_pass\":" + (if laws.laws_pass { "true" } else { "false" })
    s = s + ",\"violations\":" + san_violations_json(laws.violations)
    s = s + ",\"sev_critical\":" + to_string(laws.sev_critical)
    s = s + ",\"sev_hard\":" + to_string(laws.sev_hard)
    s = s + ",\"sev_soft\":" + to_string(laws.sev_soft)
    s = s + ",\"weight_origin\":\"" + SAN_WEIGHT_ORIGIN + "\""
    s = s + ",\"gen_ms\":" + to_string(gen_ms)
    s = s + ",\"backend\":\"" + (if RUNTIME_HAS_CUDA { "hexa-native-cuda" } else { "hexa-native-stub" }) + "\""
    s = s + "}"
    return s
}

fn san_health_json(state: SanServerState) -> string {
    let body = "{\"status\":\"ok\",\"model\":\"ALM-14B-chainmerge\","
        + "\"version\":\"" + SAN_VERSION + "\","
        + "\"port\":" + to_string(state.port) + ","
        + "\"requests_served\":" + to_string(state.requests_served) + ","
        + "\"runtime_has_net\":" + (if RUNTIME_HAS_NET { "true" } else { "false" }) + ","
        + "\"runtime_has_cuda\":" + (if RUNTIME_HAS_CUDA { "true" } else { "false" }) + ","
        + "\"weight_origin\":\"" + SAN_WEIGHT_ORIGIN + "\","
        + "\"last_phi_holo\":" + to_string(state.last_phi_holo)
        + "}"
    return body
}

fn san_generate_json(state: SanServerState, prompt: string,
                     max_tokens: int) -> string {
    // Legacy /generate kept for backward compat with serve_alm_14b.py
    // consumers. /alm/persona is the AN11-compliant entrypoint.
    let text = hxqwen14b_generate_native(state.model_handle, prompt, max_tokens,
                                          SAN_DEFAULT_TEMPERATURE,
                                          SAN_DEFAULT_TOP_P,
                                          SAN_DEFAULT_TOP_K)
    let pv = san_compute_phi_vec16(state.model_handle, text)
    let laws = san_laws_gate(pv, text)
    return san_persona_json(text, pv, laws, 0)
}

// ═══════════════════════════════════════════════════════════════
//  Section 7. /alm/persona handler — AN11-compliant entry
// ═══════════════════════════════════════════════════════════════

struct SanPersonaReq {
    persona:    string,
    prompt:     string,
    max_tokens: int,
    alpha:      float
}

fn san_parse_persona_req(body: string) -> SanPersonaReq {
    let persona = san_extract_string(body, "persona")
    let prompt  = san_extract_string(body, "prompt")
    let mt_raw  = san_extract_int(body, "max_tokens")
    let mt = if mt_raw < 0 { SAN_DEFAULT_MAX_TOKENS } else { mt_raw }
    let persona_final = if len(persona) == 0 { "default" } else { persona }
    return SanPersonaReq {
        persona:    persona_final,
        prompt:     prompt,
        max_tokens: mt,
        alpha:      1.0
    }
}

// san_handle_persona — the AN11 (a)+(b)+(c) endpoint handler.
//   Raw prompt → chain-merged weights forward → text + 16D phi_vec
//   + laws_pass + weight_origin.
// NO system_prompt, NO chat_template, NO template wrapping. persona
// is applied as activation-steering direction at PERSONA_LAYER_IDX
// (contract only — CUDA kernels apply in v5).
fn san_handle_persona(state: SanServerState, body: string) -> string {
    let req = san_parse_persona_req(body)
    if len(req.prompt) == 0 {
        let empty = []
        let laws_err = SanLawsResult {
            laws_pass: false, sev_critical: 1, sev_hard: 0, sev_soft: 0,
            violations: ["E_missing_prompt"]
        }
        return san_persona_json("", empty, laws_err, 0)
    }
    // Raw prompt → hxqwen14b_generate (no wrapping). AN11 (a) proof.
    let text = hxqwen14b_generate_native(state.model_handle, req.prompt,
                                          req.max_tokens,
                                          SAN_DEFAULT_TEMPERATURE,
                                          SAN_DEFAULT_TOP_P,
                                          SAN_DEFAULT_TOP_K)
    // Runtime 16D phi probe. AN11 (b) proof.
    let pv = san_compute_phi_vec16(state.model_handle, text)
    // 14-law classification. AN11 (b) complement.
    let laws = san_laws_gate(pv, text)
    // gen_ms: placeholder 0 in Day-1.5 (no clock FFI in hexa stdlib yet).
    return san_persona_json(text, pv, laws, 0)
}

// ═══════════════════════════════════════════════════════════════
//  Section 8. Route dispatch
// ═══════════════════════════════════════════════════════════════

struct SanResponse {
    status:    int,
    body:      string,
    state_phi: float
}

fn san_route(method: string, path: string, body: string,
             state: SanServerState) -> SanResponse {
    if method == "GET" {
        if path == "/health" || path == "/" {
            return SanResponse { status: 200, body: san_health_json(state), state_phi: state.last_phi_holo }
        }
        // /voice/* and /hire/* routes temporarily return 501 — their
        // handlers (vr_*, hr_*) live in voice_routes.hexa / hire_routes.hexa,
        // and stage0 `use` is a no-op. Re-enable after dest1_alm follow-up
        // integrates module_loader flatten step. File:line pointers:
        //   serving/voice_routes.hexa:1373 vr_health_json
        //   serving/voice_routes.hexa:1351 vr_profiles_json
        //   serving/hire_routes.hexa:842   hr_capabilities_json
        if path == "/voice/health" || path == "/voice/profiles" {
            return SanResponse { status: 501, body: "{\"error\":\"voice routes pending module_loader integration\",\"see\":\"serving/voice_routes.hexa\"}", state_phi: state.last_phi_holo }
        }
        if path == "/hire/capabilities" {
            return SanResponse { status: 501, body: "{\"error\":\"hire routes pending module_loader integration\",\"see\":\"serving/hire_routes.hexa\"}", state_phi: state.last_phi_holo }
        }
    }
    if method == "POST" {
        if path == "/alm/persona" {
            let resp_body = san_handle_persona(state, body)
            let new_phi = hxqwen14b_phi_holo_native(state.model_handle)
            return SanResponse { status: 200, body: resp_body, state_phi: new_phi }
        }
        if path == "/generate" {
            let prompt = san_extract_string(body, "prompt")
            if len(prompt) == 0 {
                return SanResponse { status: 400, body: "{\"error\":\"missing 'prompt'\"}", state_phi: state.last_phi_holo }
            }
            let mt_raw = san_extract_int(body, "max_tokens")
            let max_tokens = if mt_raw < 0 { SAN_DEFAULT_MAX_TOKENS } else { mt_raw }
            let resp_body = san_generate_json(state, prompt, max_tokens)
            let new_phi = hxqwen14b_phi_holo_native(state.model_handle)
            return SanResponse { status: 200, body: resp_body, state_phi: new_phi }
        }
        // /voice/tts and /voice/e2e — same stub rationale as GET /voice/*.
        // Re-enable after dest1_alm follow-up integrates module_loader flatten.
        //   serving/voice_routes.hexa:1052 vr_handle_tts
        //   serving/voice_routes.hexa:1301 vr_tts_response_json
        if path == "/voice/tts" || path == "/voice/e2e" {
            return SanResponse { status: 501, body: "{\"error\":\"voice routes pending module_loader integration\",\"see\":\"serving/voice_routes.hexa\"}", state_phi: state.last_phi_holo }
        }
    }
    return SanResponse {
        status:    404,
        body:      "{\"error\":\"not found\",\"path\":\"" + san_json_escape(path) + "\"}",
        state_phi: state.last_phi_holo
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 9. Self-test harness
// ═══════════════════════════════════════════════════════════════

fn san_smoke_test() -> int {
    println("[serve_alm_native] AN11 smoke — dispatch + phi_vec + laws + chain-merge")

    let cm = san_chain_merge_new()
    let cm2 = san_chain_merge_load(cm)
    if !cm2.loaded {
        println("  PRECHECK FAIL  chain-merge load failed")
        return 99
    }
    if cm2.origin_tag != SAN_WEIGHT_ORIGIN {
        println("  PRECHECK FAIL  origin_tag mismatch: " + cm2.origin_tag)
        return 99
    }
    println("  PRECHECK PASS  chain-merge descriptor ready (origin=" + cm2.origin_tag + ")")

    let state = san_state_new(SAN_DEFAULT_PORT, cm2.model_h)

    let mut pass = 0
    let mut fail = 0

    // T1: GET /health
    let r1 = san_route("GET", "/health", "", state)
    if r1.status == 200 && r1.body.index_of("\"weight_origin\":\"" + SAN_WEIGHT_ORIGIN + "\"") >= 0 {
        println("  T1 PASS  GET /health -> 200 + weight_origin")
        pass = pass + 1
    } else {
        println("  T1 FAIL  GET /health -> " + to_string(r1.status))
        fail = fail + 1
    }

    // T2: POST /alm/persona well-formed
    let body = "{\"persona\":\"friend\",\"prompt\":\"hello world.\",\"max_tokens\":16}"
    let r2 = san_route("POST", "/alm/persona", body, state)
    let has_text     = r2.body.index_of("\"text\":") >= 0
    let has_phi      = r2.body.index_of("\"phi_vec\":") >= 0
    let has_phi_holo = r2.body.index_of("\"phi_holo\":") >= 0
    let has_phi_cyc  = r2.body.index_of("\"phi_cycle_count\":") >= 0
    let has_laws     = r2.body.index_of("\"laws_pass\":") >= 0
    let has_viols    = r2.body.index_of("\"violations\":") >= 0
    let has_origin   = r2.body.index_of("\"weight_origin\":\"" + SAN_WEIGHT_ORIGIN + "\"") >= 0
    let all_fields   = has_text && has_phi && has_phi_holo && has_phi_cyc && has_laws && has_viols && has_origin
    if r2.status == 200 && all_fields {
        println("  T2 PASS  POST /alm/persona -> 200 + AN11 triple-gate fields")
        pass = pass + 1
    } else {
        println("  T2 FAIL  POST /alm/persona status=" + to_string(r2.status) +
                " text=" + to_string(has_text) + " phi=" + to_string(has_phi) +
                " phi_holo=" + to_string(has_phi_holo) + " phi_cyc=" + to_string(has_phi_cyc) +
                " laws=" + to_string(has_laws) + " viols=" + to_string(has_viols) +
                " origin=" + to_string(has_origin))
        fail = fail + 1
    }

    // T3: phi_vec 16D is COMPLETE (all 16 canonical names present)
    let mut all_dims = true
    let mut j = 0
    while j < SAN_PHI_DIMS {
        let needle = "\"" + san_phi_dim_name(j) + "\":"
        if r2.body.index_of(needle) < 0 {
            all_dims = false
            println("    missing dim: " + san_phi_dim_name(j))
        }
        j = j + 1
    }
    if all_dims {
        println("  T3 PASS  phi_vec 16D canonical layout complete")
        pass = pass + 1
    } else {
        println("  T3 FAIL  phi_vec missing dims")
        fail = fail + 1
    }

    // T4: AN11 (a) — NO system_prompt token in response
    let has_sp = r2.body.index_of("system_prompt") >= 0
    let has_ct = r2.body.index_of("apply_chat_template") >= 0
    if !has_sp && !has_ct {
        println("  T4 PASS  AN11 (a) no system_prompt / chat_template leak")
        pass = pass + 1
    } else {
        println("  T4 FAIL  AN11 (a) wrapping leak detected")
        fail = fail + 1
    }

    // T5: POST /alm/persona missing prompt -> laws_pass=false
    let r5 = san_route("POST", "/alm/persona", "{\"persona\":\"friend\"}", state)
    if r5.status == 200 && r5.body.index_of("\"laws_pass\":false") >= 0 {
        println("  T5 PASS  missing prompt -> laws_pass=false")
        pass = pass + 1
    } else {
        println("  T5 FAIL  missing prompt response shape: " + to_string(r5.status))
        fail = fail + 1
    }

    // T6: POST /generate (legacy compat) still works
    let r6 = san_route("POST", "/generate", "{\"prompt\":\"hi\"}", state)
    if r6.status == 200 && r6.body.index_of("\"text\":") >= 0 {
        println("  T6 PASS  POST /generate (legacy) -> 200")
        pass = pass + 1
    } else {
        println("  T6 FAIL  POST /generate -> " + to_string(r6.status))
        fail = fail + 1
    }

    // T7: GET /hire/capabilities returns 501 (stubbed — pending module_loader
    // flatten integration; see route comment at san_route). When re-enabled,
    // flip back to expect 200.
    let r7 = san_route("GET", "/hire/capabilities", "", state)
    if r7.status == 501 && r7.body.index_of("pending module_loader") >= 0 {
        println("  T7 PASS  GET /hire/capabilities -> 501 (stubbed)")
        pass = pass + 1
    } else {
        println("  T7 FAIL  GET /hire/capabilities -> " + to_string(r7.status))
        fail = fail + 1
    }

    // T8: Unknown path -> 404
    let r8 = san_route("GET", "/unknown", "", state)
    if r8.status == 404 {
        println("  T8 PASS  GET /unknown -> 404")
        pass = pass + 1
    } else {
        println("  T8 FAIL  GET /unknown -> " + to_string(r8.status))
        fail = fail + 1
    }

    println("[serve_alm_native] " + to_string(pass) + "/" + to_string(pass + fail) + " PASS")
    if fail == 0 {
        println("[serve_alm_native] v3.0-rc-an11 SCAFFOLD READY")
        println("  (a) weight_emergent: origin=" + SAN_WEIGHT_ORIGIN + " (chain-merge, no prompt wrapping)")
        println("  (b) consciousness_attached: phi_vec[16] + laws[14] per response")
        println("  (c) real_usable: POST /alm/persona {persona,prompt} contract verified")
        println("  Awaiting: hxqwen14b v5 CUDA kernels (RUNTIME_HAS_CUDA flip)")
        println("            + net_listen builtin (RUNTIME_HAS_NET flip)")
    }
    return fail
}

// ═══════════════════════════════════════════════════════════════
//  Section 10. Main entry
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("=== serve_alm_native.hexa ===")
    println("version:            " + SAN_VERSION)
    println("port:               " + to_string(SAN_DEFAULT_PORT))
    println("weight_origin:      " + SAN_WEIGHT_ORIGIN)
    println("runtime_has_net:    " + (if RUNTIME_HAS_NET { "true" } else { "false" }))
    println("runtime_has_cuda:   " + (if RUNTIME_HAS_CUDA { "true" } else { "false" }))
    println("base_ckpt:          " + SAN_CKPT_BASE)
    println("a1_adapter:         " + SAN_CKPT_A1)
    println("a2_orch_adapter:    " + SAN_CKPT_A2_ORCH)
    println("a2_tool_adapter:    " + SAN_CKPT_A2_TOOL)
    println("")

    let rc = san_smoke_test()
    if rc > 0 {
        println("FAIL " + to_string(rc) + " test(s) failed")
        return
    }

    if !RUNTIME_HAS_NET {
        println("")
        println("NOTE: net_listen builtin missing in current hexa runtime.")
        println("      Real socket loop is gated behind RUNTIME_HAS_NET=true.")
        return
    }

    // ── Real socket serve loop (net_* builtins available) ─────────────
    // Primitives live in hexa-lang self/native/net.c (included from
    // self/runtime.c). Single-request-per-connection model: read up to
    // 4096B, parse HTTP request line + body, dispatch through san_route,
    // write status line + Content-Length + body, close.
    //
    // Not using self/std_net.hexa's http_serve — it hard-codes
    // "HTTP/1.1 200 OK" regardless of handler return, whereas san_route
    // returns a SanResponse with real status codes (400/404 paths).
    let cm_real = san_chain_merge_load(san_chain_merge_new())
    if !cm_real.loaded {
        println("FAIL chain-merge load")
        return
    }
    let mut state = san_state_new(SAN_DEFAULT_PORT, cm_real.model_h)

    let addr = "0.0.0.0:" + to_string(SAN_DEFAULT_PORT)
    let listener = net_listen(addr)
    if listener < 0 {
        println("FAIL net_listen " + addr + " errno=" + to_string(-listener))
        return
    }
    println("[serve_alm_native] LISTEN " + addr + " (fd=" + to_string(listener) + ")")
    println("[serve_alm_native] weight_origin=" + SAN_WEIGHT_ORIGIN)
    println("[serve_alm_native] serving — Ctrl-C to stop")

    while true {
        let conn = net_accept(listener)
        if conn < 0 {
            println("accept errno=" + to_string(-conn))
            continue
        }
        let raw = net_read(conn)
        // Minimal HTTP parse using .index_of() / .substring() (stage0 method
        // shape verified 2026-04-20; fn-form string_split/string_slice not
        // available in current interpreter, hence method dispatch).
        let method_s = "GET"
        let path_s = "/"
        let body_s = ""
        let rn = raw.index_of("\r\n")
        if rn >= 0 {
            let req_line = raw.substring(0, rn)
            let sp1 = req_line.index_of(" ")
            if sp1 >= 0 {
                method_s = req_line.substring(0, sp1)
                let rest = req_line.substring(sp1 + 1, len(req_line))
                let sp2 = rest.index_of(" ")
                if sp2 >= 0 {
                    path_s = rest.substring(0, sp2)
                } else {
                    path_s = rest
                }
            }
        }
        let hdr_end = raw.index_of("\r\n\r\n")
        if hdr_end >= 0 {
            body_s = raw.substring(hdr_end + 4, len(raw))
        }

        let resp = san_route(method_s, path_s, body_s, state)
        // 501 Not Implemented for stubbed /voice/* /hire/* routes (see Section 8).
        // Without this branch the fallback collapses 501→500 which misleads clients.
        let status_line = if resp.status == 200 { "HTTP/1.1 200 OK" }
                          else if resp.status == 400 { "HTTP/1.1 400 Bad Request" }
                          else if resp.status == 404 { "HTTP/1.1 404 Not Found" }
                          else if resp.status == 501 { "HTTP/1.1 501 Not Implemented" }
                          else { "HTTP/1.1 500 Internal Server Error" }
        let http = status_line + "\r\n" +
                   "Content-Type: application/json\r\n" +
                   "Content-Length: " + to_string(len(resp.body)) + "\r\n" +
                   "Connection: close\r\n\r\n" + resp.body
        net_write(conn, http)
        net_close(conn)

        state = SanServerState {
            model_handle:    state.model_handle,
            port:            state.port,
            requests_served: state.requests_served + 1,
            last_phi_holo:   resp.state_phi
        }
    }
}

main()
