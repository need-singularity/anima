// serving/test_clm_lore_serve.hexa — TCLM-P2-1 gate harness
//
// Dedicated 5-test driver for `serving/clm_lore_serve.hexa`. 본 harness 는
// main 파일이 export 하는 공개 함수 (test_T1..T5) 를 다시 호출해, 머지
// gate 기준 (5/5 PASS) 을 독립적으로 확증한다.
//
// 왜 별도 파일?
//   - 머지 gate 는 이 파일 하나만 보면 PASS/FAIL 를 알 수 있다.
//   - 메인 파일(clm_lore_serve.hexa)은 library 로 retain, 추후 http_server
//     wire 시 main 부 삭제 없이 use 가능.
//   - repeat-runs + anima-train.json scaffold_done 근거는 이 gate 결과.
//
// Hexa quirk 회피:
//   - `use "clm_lore_serve"` 로 serving/clm_lore_serve.hexa 전체를 로드.
//     memory:feedback_hexa_runtime 에 use 가 training/ 에서 flaky 라는
//     경고가 있으나, serving/ 는 eval_clm.hexa 가 use "nn_core" 로 성공
//     사례가 있고, 본 harness 도 동일 디렉토리 sibling import 이므로 OK.
//     (실 probe: use 후 main() 자동 실행 → 필터링은 run_embedded_tests 가
//     같이 출력되는 것 수용, gate 판정은 [gate] 블록으로 구분.)
//   - 어떤 struct/fn 도 본 파일에서 재정의하지 않음 (충돌 방지).
//
// 실행:
//   $HEXA serving/test_clm_lore_serve.hexa
//
// PASS 기준:
//   [gate] 5/5 PASS   → TCLM-P2-1 scaffold_done 승격 가능
//   [gate] <5 PASS    → 머지 금지

use "clm_lore_serve"

fn main() {
    println("")
    println("════════════════════════════════════════════════════════")
    println("[gate] serving/test_clm_lore_serve.hexa — TCLM-P2-1")
    println("  target: 5/5 PASS (T1 e2e, T2 30-turn, T3 tone, T4 lore fb, T5 style fb)")
    println("════════════════════════════════════════════════════════")

    let t1 = test_T1_single_turn_e2e()
    let t2 = test_T2_30turn_consistency()
    let t3 = test_T3_tone_switch()
    let t4 = test_T4_lore_fallback()
    let t5 = test_T5_style_fallback()

    let mut pass = 0
    if t1 { pass = pass + 1 }
    if t2 { pass = pass + 1 }
    if t3 { pass = pass + 1 }
    if t4 { pass = pass + 1 }
    if t5 { pass = pass + 1 }

    println("")
    println("[gate] T1 (e2e)                  = " + (if t1 { "PASS" } else { "FAIL" }))
    println("[gate] T2 (30-turn consistency)  = " + (if t2 { "PASS" } else { "FAIL" }))
    println("[gate] T3 (tone switch 4/4)      = " + (if t3 { "PASS" } else { "FAIL" }))
    println("[gate] T4 (lore fallback)        = " + (if t4 { "PASS" } else { "FAIL" }))
    println("[gate] T5 (style fallback)       = " + (if t5 { "PASS" } else { "FAIL" }))
    println("")

    if pass == 5 {
        println("[gate] 5/5 PASS — TCLM-P2-1 scaffold_done 승격 가능 (mock CLM)")
    } else {
        println("[gate] " + str(pass) + "/5 PASS — 머지 금지, 디버그 필요")
    }
}

main()
