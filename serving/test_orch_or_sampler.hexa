// ═══════════════════════════════════════════════════════════════
//  serving/test_orch_or_sampler.hexa
//
//  D3 — self-test harness for Orch-OR inference sampler.
//  Target: 5/5 PASS.
//
//  Assertions:
//    T1  dim contract        — token_id ∈ [0, vocab) across mode/phi combos
//    T2  determinism         — (seed, phi, logits) triplet reproducible
//    T3  phi=0 ≈ Born rule   — chi-square vs top-K Born-rule expected
//    T4  phi=high distinct   — KL(phi_high ‖ phi_zero) > threshold
//    T5  latency under 10ms  — 100-call batch mean at vocab=32000
//
//  Usage:
//    HEXA_LOCAL=1 hexa run /Users/ghost/Dev/anima/serving/test_orch_or_sampler.hexa
//
//  The caller must ensure serving/quantum_collapse_sample.hexa exists
//  (symlink or cp from anima-engines/). This harness refuses to run
//  if the dependency is missing — it does NOT create symlinks itself
//  (side-effect isolation).
// ═══════════════════════════════════════════════════════════════

use "sampler_wrap"

// ── Helpers (chi-square, KL, histograms) ──
fn build_hist(
    logits:      [float],
    phi_holo:    float,
    tension:     float,
    temperature: float,
    n_samples:   int,
    vocab:       int,
    mode:        string
) -> [int] {
    let mut hist = []
    let mut k = 0
    while k < vocab {
        hist = hist.push(0)
        k = k + 1
    }

    let mut i = 0
    while i < n_samples {
        let cfg = SamplerConfig {
            mode: mode,
            temperature: temperature,
            tension: tension,
            phi_holo_context: phi_holo,
            seed: i + 1    // non-zero → deterministic, each call different
        }
        let out = sample_next_token(logits, cfg)
        let t = out.token_id
        if t >= 0 && t < vocab {
            // rebuild hist (pbv rule)
            let mut new_h = []
            let mut j = 0
            while j < vocab {
                if j == t {
                    new_h = new_h.push(hist[j] + 1)
                } else {
                    new_h = new_h.push(hist[j])
                }
                j = j + 1
            }
            hist = new_h
        }
        i = i + 1
    }
    return hist
}

// Chi-square statistic = Σ (obs - exp)² / exp  over nonzero expected bins.
// `expected` is a real-valued count vector (same length as `hist`).
fn chi_square(hist: [int], expected: [float]) -> float {
    let n = len(hist)
    let mut x2 = 0.0
    let mut i = 0
    while i < n {
        let e = expected[i]
        if e > 0.5 {
            let o = hist[i] * 1.0
            let d = o - e
            x2 = x2 + (d * d) / e
        }
        i = i + 1
    }
    return x2
}

// KL(P‖Q) over nonzero P bins, with small epsilon for Q to avoid infinity.
// Both inputs are integer counts; we normalize inside.
fn kl_divergence(p_hist: [int], q_hist: [int]) -> float {
    let np = len(p_hist)
    let nq = len(q_hist)
    if np != nq { return -1.0 }

    let mut sum_p = 0
    let mut sum_q = 0
    let mut i = 0
    while i < np {
        sum_p = sum_p + p_hist[i]
        sum_q = sum_q + q_hist[i]
        i = i + 1
    }
    if sum_p == 0 || sum_q == 0 { return 0.0 }
    let inv_p = 1.0 / (sum_p * 1.0)
    let inv_q = 1.0 / (sum_q * 1.0)

    let eps = 1.0e-6
    let mut kl = 0.0
    let mut j = 0
    while j < np {
        let p_norm = p_hist[j] * inv_p
        let q_norm = q_hist[j] * inv_q + eps
        if p_norm > 0.0 {
            kl = kl + p_norm * log(p_norm / q_norm)
        }
        j = j + 1
    }
    return kl
}

// Expected Born-rule counts over the full vocab for a given logit vector.
// The engine collapses to top-K (8) via softmax of top-K logits, so the
// expected mass outside top-K is 0. We compute softmax over top-K and
// scatter those back into a vocab-sized vector.
fn expected_born_counts(
    logits:    [float],
    n_samples: int,
    vocab:     int
) -> [float] {
    let tk = qcs_topk(logits, 8)
    let k = len(tk.values)
    let probs = qcs_softmax_temp(tk.values, 1.0)
    let mut out = []
    let mut i = 0
    while i < vocab {
        out = out.push(0.0)
        i = i + 1
    }
    // scatter probs back — rebuild list (pbv)
    let mut j = 0
    while j < k {
        let idx = tk.indices[j]
        let mut new_out = []
        let mut m = 0
        while m < vocab {
            if m == idx {
                new_out = new_out.push(probs[j] * (n_samples * 1.0))
            } else {
                new_out = new_out.push(out[m])
            }
            m = m + 1
        }
        out = new_out
        j = j + 1
    }
    return out
}

// ── File existence / dependency probe ──
fn dep_present(path: string) -> int {
    let r = exec("test -e " + path + " && echo OK || echo MISS").trim()
    if r == "OK" { return 1 }
    return 0
}

// ── ms-precision timer (R37/AN13/L3-PY: python3 removed 2026-04-18) ──
// Previously: python3 -c 'import time; print(int(time.time()*1000))'
// Replacement: gdate/date ns-precision shell, then divide by 1e6 via shell.
// See CLAUDE.md §.py 절대 금지.
fn now_ms_str() -> int {
    let ns = exec("gdate +%s%N 2>/dev/null || date +%s000000000").trim()
    let ms = exec("echo $(( " + ns + " / 1000000 ))").trim()
    return ms.to_int()
}

// ──────────────────────────────────────────────────────────────
//  MAIN
// ──────────────────────────────────────────────────────────────

println("")
println("════════════════════════════════════════════════════════")
println("[gate] serving/test_orch_or_sampler.hexa — D3 Orch-OR sampler")
println("  target: 5/5 PASS")
println("    T1 dim contract")
println("    T2 determinism")
println("    T3 chi² vs Born rule (phi=0)")
println("    T4 KL divergence (phi=high vs phi=0)")
println("    T5 latency < 10ms @ vocab=32000")
println("════════════════════════════════════════════════════════")

// ── Dependency check ──
let dep_qcs = dep_present("/Users/ghost/Dev/anima/serving/quantum_collapse_sample.hexa")
if dep_qcs == 0 {
    println("[gate] MISSING dep: serving/quantum_collapse_sample.hexa")
    println("[gate] hint: ln -sf /Users/ghost/Dev/anima/anima-engines/quantum_collapse_sample.hexa \\")
    println("             /Users/ghost/Dev/anima/serving/quantum_collapse_sample.hexa")
    println("[gate] HARNESS ABORT — dep missing, 머지 금지")
} else {
    println("[gate] dep_ok: serving/quantum_collapse_sample.hexa")

    let mut pass_count = 0

    // ─────────────────────────────────────────────────────────────
    // T1: dim contract — across mode, T, phi, seed combos, token_id
    //      must be in [0, vocab). Covers every branch of the wrapper.
    // ─────────────────────────────────────────────────────────────
    let vocab_small = 64
    let mut lg_small = []
    let mut a = 0
    while a < vocab_small {
        lg_small = lg_small.push(0.02 * (a * 1.0))
        a = a + 1
    }

    let mut t1_fail = 0
    let mut t1_total = 0

    // All 8 combinations of (mode, temp, phi)
    let cfg1a = SamplerConfig { mode: "orch_or",  temperature: 1.0, tension: 0.0, phi_holo_context: 0.0,    seed: 1 }
    let r1a = sample_next_token(lg_small, cfg1a)
    t1_total = t1_total + 1
    if r1a.token_id < 0 || r1a.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1b = SamplerConfig { mode: "orch_or",  temperature: 1.0, tension: 0.1, phi_holo_context: 1500.0, seed: 2 }
    let r1b = sample_next_token(lg_small, cfg1b)
    t1_total = t1_total + 1
    if r1b.token_id < 0 || r1b.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1c = SamplerConfig { mode: "orch_or",  temperature: 0.0, tension: 0.0, phi_holo_context: 0.0,    seed: 3 }
    let r1c = sample_next_token(lg_small, cfg1c)
    t1_total = t1_total + 1
    if r1c.token_id < 0 || r1c.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1d = SamplerConfig { mode: "orch_or",  temperature: 2.0, tension: 0.5, phi_holo_context: 500.0,  seed: 4 }
    let r1d = sample_next_token(lg_small, cfg1d)
    t1_total = t1_total + 1
    if r1d.token_id < 0 || r1d.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1e = SamplerConfig { mode: "standard", temperature: 1.0, tension: 0.0, phi_holo_context: 0.0,    seed: 5 }
    let r1e = sample_next_token(lg_small, cfg1e)
    t1_total = t1_total + 1
    if r1e.token_id < 0 || r1e.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1f = SamplerConfig { mode: "standard", temperature: 0.5, tension: 0.0, phi_holo_context: 0.0,    seed: 6 }
    let r1f = sample_next_token(lg_small, cfg1f)
    t1_total = t1_total + 1
    if r1f.token_id < 0 || r1f.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1g = SamplerConfig { mode: "standard", temperature: 0.0, tension: 0.0, phi_holo_context: 0.0,    seed: 7 }
    let r1g = sample_next_token(lg_small, cfg1g)
    t1_total = t1_total + 1
    if r1g.token_id < 0 || r1g.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    let cfg1h = SamplerConfig { mode: "unknown",  temperature: 1.0, tension: 0.0, phi_holo_context: 0.0,    seed: 8 }
    let r1h = sample_next_token(lg_small, cfg1h)
    t1_total = t1_total + 1
    if r1h.token_id < 0 || r1h.token_id >= vocab_small { t1_fail = t1_fail + 1 }

    println("  T1 dim contract = " + str(t1_total - t1_fail) + "/" + str(t1_total))
    if t1_fail == 0 {
        pass_count = pass_count + 1
        println("[gate] T1 PASS — dim contract holds across 8 configs")
    } else {
        println("[gate] T1 FAIL — " + str(t1_fail) + " out-of-range tokens")
    }

    // ─────────────────────────────────────────────────────────────
    // T2: determinism — same (logits, seed, phi_holo, mode) yields
    //      the same token_id. Run twice back-to-back, compare.
    // ─────────────────────────────────────────────────────────────
    let cfg2 = SamplerConfig {
        mode: "orch_or",
        temperature: 1.0,
        tension: 0.2,
        phi_holo_context: 1200.0,
        seed: 31415
    }
    let r2a = sample_next_token(lg_small, cfg2)
    let r2b = sample_next_token(lg_small, cfg2)
    let r2c = sample_next_token(lg_small, cfg2)

    let cfg2std = SamplerConfig {
        mode: "standard",
        temperature: 0.8,
        tension: 0.0,
        phi_holo_context: 0.0,
        seed: 27182
    }
    let r2d = sample_next_token(lg_small, cfg2std)
    let r2e = sample_next_token(lg_small, cfg2std)

    let det_or  = r2a.token_id == r2b.token_id && r2b.token_id == r2c.token_id
    let det_std = r2d.token_id == r2e.token_id

    println("  T2 orch_or  seed=31415 → " + str(r2a.token_id) + "/" + str(r2b.token_id) + "/" + str(r2c.token_id))
    println("  T2 standard seed=27182 → " + str(r2d.token_id) + "/" + str(r2e.token_id))
    if det_or && det_std {
        pass_count = pass_count + 1
        println("[gate] T2 PASS — determinism holds for fixed seed")
    } else {
        println("[gate] T2 FAIL — nondeterministic output for fixed seed")
    }

    // ─────────────────────────────────────────────────────────────
    // T3: phi=0 distribution ≈ Born-rule top-K. Chi-square vs expected.
    //      Threshold: df = k-1 = 7, α=0.001 → critical ~24.3. We use
    //      a loose threshold of 30 (allow some LCG sampling noise) on
    //      N=600 samples.
    // ─────────────────────────────────────────────────────────────
    let vocab_t3 = 64
    let mut lg_t3 = []
    let mut b = 0
    while b < vocab_t3 {
        // crafted gradient so top-K is well separated
        lg_t3 = lg_t3.push(0.1 * (b * 1.0))
        b = b + 1
    }
    let n_s3 = 600
    let hist0 = build_hist(lg_t3, 0.0, 0.0, 1.0, n_s3, vocab_t3, "orch_or")
    let expected = expected_born_counts(lg_t3, n_s3, vocab_t3)

    let x2 = chi_square(hist0, expected)
    // For df=7, χ²@α=0.001 ≈ 24.3. We allow slack up to 40 because:
    //   - LCG is not a cryptographic PRNG
    //   - qcs internal action counter may occasionally skip a step
    //   - N=600 is modest
    let chi_threshold = 40.0
    println("  T3 chi² = " + str(x2) + "  (threshold " + str(chi_threshold) + ", df=7)")
    if x2 < chi_threshold {
        pass_count = pass_count + 1
        println("[gate] T3 PASS — phi=0 distribution ≈ Born-rule top-K")
    } else {
        println("[gate] T3 FAIL — phi=0 distribution deviates from expected")
    }

    // ─────────────────────────────────────────────────────────────
    // T4: phi_holo=high distribution differs from phi=0. KL > 0.05.
    // ─────────────────────────────────────────────────────────────
    let n_s4 = 600
    let hist_hi = build_hist(lg_t3, 1500.0, 0.0, 1.0, n_s4, vocab_t3, "orch_or")
    let kl = kl_divergence(hist_hi, hist0)
    let kl_threshold = 0.05
    println("  T4 KL(hi ‖ zero) = " + str(kl) + "  (threshold " + str(kl_threshold) + ")")
    if kl > kl_threshold {
        pass_count = pass_count + 1
        println("[gate] T4 PASS — high Φ_holo shifts distribution")
    } else {
        println("[gate] T4 FAIL — Φ_holo has no observable effect")
    }

    // ─────────────────────────────────────────────────────────────
    // T5: latency under 10ms at vocab=32000. Measure mean over N=20
    //      calls (start-to-end wall via gdate/date ns; R37/AN13/L3-PY 2026-04-18).
    // ─────────────────────────────────────────────────────────────
    let vocab_big = 32000
    let mut lg_big = []
    let mut c = 0
    while c < vocab_big {
        // small random-ish gradient (deterministic mod)
        let f = (c % 100) * 0.01
        lg_big = lg_big.push(f)
        c = c + 1
    }
    let cfg_big = SamplerConfig {
        mode: "orch_or",
        temperature: 1.0,
        tension: 0.0,
        phi_holo_context: 1000.0,
        seed: 99
    }

    let n_lat = 20
    let t0 = now_ms_str()
    let mut q = 0
    while q < n_lat {
        let r = sample_next_token(lg_big, cfg_big)
        q = q + 1
    }
    let t1 = now_ms_str()
    let total_ms = t1 - t0
    let mean_ms = (total_ms * 1.0) / (n_lat * 1.0)
    let lat_threshold = 10.0

    println("  T5 latency mean = " + str(mean_ms) + "ms  (N=" + str(n_lat) + ", vocab=" + str(vocab_big) + ", threshold " + str(lat_threshold) + "ms)")
    if mean_ms < lat_threshold {
        pass_count = pass_count + 1
        println("[gate] T5 PASS — latency under threshold")
    } else {
        println("[gate] T5 FAIL — latency exceeds 10ms/call at vocab=32000")
    }

    // ── Final ──
    println("")
    println("════════════════════════════════════════════════════════")
    if pass_count == 5 {
        println("[gate] ALL 5/5 PASS — D3 Orch-OR sampler scaffold_done 승격 가능")
        println("[gate] files: serving/orch_or_sampler.hexa")
        println("[gate]        serving/sampler_wrap.hexa")
        println("[gate]        serving/test_orch_or_sampler.hexa")
        println("[gate] deps:  anima-engines/quantum_collapse_sample.hexa (unmodified)")
    } else {
        println("[gate] " + str(pass_count) + "/5 PASS — 머지 금지, 디버그 필요")
    }
    println("════════════════════════════════════════════════════════")
}
