fn is_korean_char(codepoint: int) -> bool {
    // Hangul Syllables (AC00-D7AF) + Jamo (1100-11FF, 3130-318F)
    (0xAC00 <= codepoint && codepoint <= 0xD7AF) ||
    (0x1100 <= codepoint && codepoint <= 0x11FF) ||
    (0x3130 <= codepoint && codepoint <= 0x318F)
}

fn korean_ratio(text: string) -> float {
    // Fraction of non-whitespace, non-punctuation chars that are Korean
    // TODO[runtime]: filter chars, count Korean via is_korean_char, return ratio
    0.0
}

