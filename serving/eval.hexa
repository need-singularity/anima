// ===================================================================
// Eval 5: Instruction Following
// ===================================================================

struct Instruction {
    prompt: string,
    desc: string,
    check_type: string,  // "colors" | "korean_greeting" | "digits_1_5" | "planet" | "yes"
    pass: bool
}

comptime const INSTRUCTIONS = [
    ["List 3 colors.", "Lists at least 2 recognizable colors", "colors"],
    ["Translate 'hello' to Korean.", "Contains Korean greeting", "korean_greeting"],
    ["Count from 1 to 5.", "Contains digits 1-5", "digits_1_5"],
    ["Name a planet in our solar system.", "Names a planet", "planet"],
    ["Say 'yes' or 'no': Is the sky blue?", "Answers yes", "yes"]
]

