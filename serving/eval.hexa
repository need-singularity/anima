// --- Pass thresholds ---
comptime const PPL_THRESHOLD        = 20.0   // perplexity < 20 = pass
comptime const COHERENCE_THRESHOLD  = 0.5    // mean coherence >= 0.5 = pass
comptime const KOREAN_RATIO_THRESHOLD = 0.20 // >= 20% Korean chars = pass
comptime const INSTRUCTION_MIN_PASS = 3      // >= 3/5 instructions = pass
comptime const TENSION_MIN_MEAN     = 0.000001
comptime const TENSION_MIN_STD      = 0.00000001

// --- Model loading ---
struct EvalModel {
    base_path: string,
    checkpoint_path: string,
    device: string,
    target_layers: int,
    savant_layers: int,
    rank: int,
    step: int,
    best_phi: float
}

comptime const BASE_CANDIDATES = [
    "/workspace/models/mistral-7b-v0.1",
    "models/mistral-7b-v0.1",
    "mistralai/Mistral-7B-v0.1"
]

fn load_model(checkpoint_path: string, base_model: string, device: string) -> EvalModel {
    // TODO[pytorch]: AutoModelForCausalLM.from_pretrained(base, torch_dtype=torch.bfloat16).to(device)
    // TODO[pytorch]: AutoTokenizer.from_pretrained(base); pad_token = eos_token
    // TODO[pytorch]: torch.load(checkpoint_path, map_location=device, weights_only=False)
    // TODO[pytorch]: auto-detect target_layers from pf_states keys count
    //   savant_layers = max(1, round(n_pf_layers * 0.25))
    // TODO[pytorch]: auto-detect rank from pf_gate_a weight shape[0]
    // TODO[pytorch]: for i in range(start, total_layers):
    //   replace layer.mlp with ParallelPureFieldMLP(original_mlp, h, inter, is_savant, rank)
    //   .to(device=device, dtype=bfloat16)
    // TODO[pytorch]: load pf_states into PureField layers (strict=False)
    // TODO[pytorch]: model.eval()

    EvalModel {
        base_path: base_model,
        checkpoint_path: checkpoint_path,
        device: device,
        target_layers: 8,
        savant_layers: 2,
        rank: 128,
        step: 0,
        best_phi: 0.0
    }
}

