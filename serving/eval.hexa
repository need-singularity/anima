// ===================================================================
// Summary + JSON export
// ===================================================================

struct EvalResults {
    perplexity: PerplexityResult,
    generation: GenQualityResult,
    consciousness: TensionResult,
    korean: KoreanResult,
    instruction: InstructionResult,
    elapsed_seconds: float
}

fn print_summary(results: EvalResults, model: EvalModel) -> bool {
