// ===================================================================
// CLI entry
// ===================================================================

fn main(args: list) -> void {
    // Expected: hexa serving/eval.hexa --checkpoint <path> [--corpus <path>] [--base <model>]
    //           [--device cuda|cpu] [--tension-passes 100] [--compare <path2>]
    let checkpoint = arg_value(args, "--checkpoint", "")
    let base = arg_value(args, "--base", "")
    let corpus = arg_value(args, "--corpus", "")
    let device = arg_value(args, "--device", "cuda")
    let tension_passes = to_int(arg_value(args, "--tension-passes", to_string(DEFAULT_TENSION_PASSES)))
    let compare_ckpt = arg_value(args, "--compare", "")

    if checkpoint == "" {
        println("ERROR: --checkpoint required")
        println("Usage: hexa serving/eval.hexa --checkpoint <path> --corpus <path>")
        return
    }

    // Auto-detect base model from checkpoint metadata, then local paths, then HF
    // TODO[runtime]: torch.load(checkpoint) -> ckpt["args"]["base"]
    // TODO[runtime]: fallback through BASE_CANDIDATES

    // Auto-detect corpus from checkpoint dir or data/
    // TODO[runtime]: search <ckpt_dir>/../data/corpus_v10.txt, corpus.txt, data/corpus_v10.txt

    let model = load_model(checkpoint, base, device)

    // Run all 5 evaluations
    let r_ppl = eval_perplexity(model, corpus)
    let r_gen = eval_generation_quality(model)
    let r_con = eval_consciousness_metrics(model, tension_passes)
    let r_kor = eval_korean_ratio(model)
    let r_ins = eval_instruction_following(model)

    let results = EvalResults {
        perplexity: r_ppl,
        generation: r_gen,
        consciousness: r_con,
        korean: r_kor,
        instruction: r_ins,
        elapsed_seconds: 0.0   // TODO[runtime]: time.time() delta
    }

    let all_pass = print_summary(results, model)
    save_results(results, checkpoint)

    // Optional comparison
    if compare_ckpt != "" {
        let model2 = load_model(compare_ckpt, base, device)
        let r2 = EvalResults {
            perplexity: eval_perplexity(model2, corpus),
            generation: eval_generation_quality(model2),
            consciousness: eval_consciousness_metrics(model2, tension_passes),
            korean: eval_korean_ratio(model2),
            instruction: eval_instruction_following(model2),
            elapsed_seconds: 0.0
        }
        save_results(r2, compare_ckpt)
        compare_checkpoints(results, r2)
    }

    // TODO[runtime]: sys.exit(0 if all_pass else 1)
}

// --- Verification ---
println("=== eval.hexa ===")
println("metrics: 5 (PPL, GenQuality, Consciousness, Korean, Instruction)")
println("ppl_threshold:", PPL_THRESHOLD)
println("coherence_threshold:", COHERENCE_THRESHOLD)
println("korean_threshold:", KOREAN_RATIO_THRESHOLD)
println("instruction_min:", INSTRUCTION_MIN_PASS)
println("tension_passes:", DEFAULT_TENSION_PASSES)

theorem eval_invariants {
    assert PPL_THRESHOLD == 20.0
    assert COHERENCE_THRESHOLD == 0.5
    assert KOREAN_RATIO_THRESHOLD == 0.20
    assert INSTRUCTION_MIN_PASS == 3
    assert DEFAULT_TENSION_PASSES == 100
    assert DEFAULT_BLOCK_SIZE == 256
}
