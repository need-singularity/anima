// --- Side-by-side comparison ---
fn compare_checkpoints(results_a: EvalResults, results_b: EvalResults) -> void {
    // TODO[runtime]: print 78-col table:
    //   Eval                Checkpoint A        Checkpoint B        Delta
    //   Perplexity          XX.XXXX             XX.XXXX             +/-X.XXXX </>
