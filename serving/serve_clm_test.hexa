// serving/serve_clm_test.hexa — integration harness for serve_clm.hexa
//
// Invokes `hexa run serving/serve_clm.hexa --selftest` and verifies:
//   T1 — final summary reports 10/10 PASS
//   T2 — GET /health endpoint PASS line present
//   T3 — POST /generate endpoint PASS line present
//   T4 — POST /loss endpoint PASS line present
//   T5 — GET /unknown → 404 routes table line present
//   T6 — laws_gate + sentinel PASS lines present
//
// Usage:
//   hexa run serving/serve_clm_test.hexa

let SCT_SERVE_FILE = "serving/serve_clm.hexa"

fn sct_run() -> string {
    let cmd = "hexa run " + SCT_SERVE_FILE + " --selftest 2>&1"
    return exec(cmd)
}

fn sct_has(out: string, needle: string) -> bool {
    return out.index_of(needle) >= 0
}

fn sct_harness() -> int {
    println("[serve_clm_test] running: hexa run " + SCT_SERVE_FILE + " --selftest")
    let out = sct_run()
    let mut ok = 0
    let mut bad = 0

    let final_pass = sct_has(out, "OK 10/10 self-test PASS") || sct_has(out, "10/10 PASS")
    if final_pass {
        println("  T1 PASS  serve_clm --selftest → 10/10")
        ok = ok + 1
    } else {
        println("  T1 FAIL  --selftest did not finalize 10/10 PASS")
        bad = bad + 1
    }

    if sct_has(out, "T1 PASS  GET /health") {
        println("  T2 PASS  GET /health endpoint verified")
        ok = ok + 1
    } else {
        println("  T2 FAIL  GET /health line missing")
        bad = bad + 1
    }

    if sct_has(out, "T2 PASS  POST /generate") {
        println("  T3 PASS  POST /generate endpoint verified")
        ok = ok + 1
    } else {
        println("  T3 FAIL  POST /generate line missing")
        bad = bad + 1
    }

    if sct_has(out, "T4 PASS  POST /loss") {
        println("  T4 PASS  POST /loss endpoint verified")
        ok = ok + 1
    } else {
        println("  T4 FAIL  POST /loss line missing")
        bad = bad + 1
    }

    if sct_has(out, "T5 PASS  GET /unknown") {
        println("  T5 PASS  GET /unknown → 404 verified")
        ok = ok + 1
    } else {
        println("  T5 FAIL  /unknown 404 line missing")
        bad = bad + 1
    }

    let laws_ok = sct_has(out, "T6 PASS  laws_gate") && sct_has(out, "T7 PASS  laws_gate")
    let sent_ok = sct_has(out, "T8 PASS  sentinel") && sct_has(out, "T9 PASS  sentinel")
    let phi_ok  = sct_has(out, "T10 PASS  phi_vec")
    if laws_ok && sent_ok && phi_ok {
        println("  T6 PASS  laws_gate + sentinel + phi_vec wired")
        ok = ok + 1
    } else {
        println("  T6 FAIL  laws/sentinel/phi wiring lines missing")
        bad = bad + 1
    }

    println("[serve_clm_test] " + to_string(ok) + "/" + to_string(ok + bad) + " harness PASS")
    if bad > 0 {
        println("---- selftest output follows ----")
        println(out)
        return 1
    }
    return 0
}

fn main() {
    let rc = sct_harness()
    if rc == 0 { println("[serve_clm_test] OK") }
    else       { println("[serve_clm_test] FAIL rc=" + to_string(rc)) }
}
