# Python — R37/AN13/L3-PY 전면 금지 (2026-04-18)
# .py 파일은 생성/수정/커밋 모두 금지. 혹시 untracked 로 발생해도 git add 차단.
**/*.py
__pycache__/
*.pyc
*.egg-info/

# Virtual environments
.venv/
venv/

# Environment
.env
.local/

# Model files — checkpoints (400MB+) and GGUF (multi-GB)
*.pt
anima/checkpoints/
anima/models/

# Trained LoRA adapters pulled from H100 pods (400MB–2.1GB each)
# Stored locally for CP1 deployment; push to R2 for distribution.
state/trained_adapters/
state/trained_adapters_r*/
*.safetensors

# Large corpus files (100-200MB each) — use R2 for distribution
anima/data/corpus_*.txt
anima/data/corpus_multilingual/
training/corpus_*.txt
training/corpus_*.txt.gz
training/deploy/.reval_tmp/

# anima-speak voice corpus audio — use R2 for distribution (GitHub 100MB/file limit)
anima-speak/corpus/**/raw/
anima-speak/corpus/**/wav16k/
anima-speak/corpus/_logs/

# Root-level checkpoints (non-canonical)
/checkpoints/

# Root-level runtime state (PIDs, daemon logs, evo_runner state)
/data/
# atlas canonical symlinks — tracked exception (SSOT, raw#10 proof-carrying)
!/data/atlas.signals.n6
/logs/
*.pid

# Rust build artifacts
**/target/

# Hexa transpile/build artifacts — .c intermediates and compiled binaries
/build/
/anima-agent/build/
/training/build/

# IDE
.superpowers/

# Claude Code worktrees
.claude/*
!.claude/settings.json
!.claude/hooks/

# Large data
*.db
anima/config/tokenizer_*.model
anima/config/tokenizer_*.vocab
anima/config/tokenizer_64k_multilingual.model
anima/config/tokenizer_64k_multilingual.vocab

# TECS-L calc symlink
calc
# .shared / shared symlinks → ../nexus/shared (local-only, not committed)
.shared
/shared
tecsrs

# anima/config → ../config symlink (local alias, not tracked — CLAUDE.md refs config/ directly)
/anima/config
# Playwright MCP cache
.playwright-mcp/

# Secrets — API keys, tokens, credentials
SECRET.md
*.secret
*.credentials
config.toml
.runpod/
.secrets/
.env.local
.env.production
*.hexaw

# NVRTC PTX disk cache (cuda_rtc.hexa) — rebuilt on first run
.hexa-cache/

# Claude Code memory (account-shared, local only)
.claude-memory/

# macOS
.DS_Store

# Growth absorbed runtime state — transient JSON produced by growth_loop; archive tarballs are tracked for reproducibility
/.growth/absorbed/*.json
!/.growth/absorbed/archive/

# Adversarial bench runtime sandboxes (copies of anima-hexad/) — regenerated each run
state/adv_bench_sandbox/
training/corpus_alm_70b.jsonl
training/corpus/
# kowiki / 자동 파이프라인 대용량 코퍼스 (1.3GB+) — R2 배포
training/corpus_auto/
# tool-use 코퍼스 jsonl 원본 — R2 배포
training/corpus_tool/*.jsonl
# YouTube 오디오북 코퍼스 (1.4GB+ wav/srt/json) — R2 배포
training/corpus_yt_ko/
training/corpus_ko_ytv1/
# corpus 분할 테스트 샘플 (wav + metadata.csv) — R2 또는 재생성 가능
training/corpus_test_pipeline/
# 학습 로그
training/logs/
# persona demo .py (HEXA-FIRST 정책 — .py 금지, 보관만)
anima-agent/results/*.py

# airgenome rig_trend consumer ephemeral advice (300s regenerated)
.hook-advice.md

# airgenome hook runtime state (per-project, owned by `airgenome hook` CLI — see tool/airgenome_cli_probe.hexa)
.hook-commands/

# AOT 컴파일 산출물 (소스는 tool/ · $HEXA_LANG/에 존재, 바이너리는 재빌드 가능)
/bin/

# 외부 리포 로컬 심볼릭 링크 (n6-architecture — local-only, not committed)
/n6/

# 로컬 호스트 probe 스냅샷 (ubu/ubu2/htz/mac 상태, 런타임 전용)
/infra_state.json

# 런타임 감사 로그 (JSONL append-only — problem_solving_protocol)
.raw-audit/

# Runtime ephemeral state — timestamped ticks (roadmap_integrity_guard / roadmap_live_daemon / paths pruner / TUI heartbeat / auto-reflect log)
state/integrity_drift_*.json
state/roadmap_coverage_tick_*.json
state/paths_prune_candidates_*.json
state/anima_tui_heartbeat.json
state/roadmap_auto_reflect_log.json
dist/
