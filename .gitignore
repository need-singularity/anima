# Python
__pycache__/
*.pyc
*.egg-info/

# Virtual environments
.venv/
venv/

# Environment
.env
.local/

# Model files — checkpoints (400MB+) and GGUF (multi-GB)
*.pt
anima/checkpoints/
anima/models/

# Large corpus files (100-200MB each) — use R2 for distribution
anima/data/corpus_*.txt
anima/data/corpus_multilingual/

# Root-level checkpoints (non-canonical)
/checkpoints/

# Root-level runtime state (PIDs, daemon logs, evo_runner state)
/data/
/logs/
*.pid

# Rust build artifacts
**/target/

# IDE
.superpowers/

# Claude Code worktrees
.claude/*
!.claude/settings.json
!.claude/hooks/

# Large data
*.db
anima/config/tokenizer_*.model
anima/config/tokenizer_*.vocab
anima/config/tokenizer_64k_multilingual.model
anima/config/tokenizer_64k_multilingual.vocab

# TECS-L calc symlink
calc
# .shared / shared symlinks → ../nexus/shared (local-only, not committed)
.shared
/shared
tecsrs

# anima/config → ../config symlink (local alias, not tracked — CLAUDE.md refs config/ directly)
/anima/config
# Playwright MCP cache
.playwright-mcp/

# Secrets — API keys, tokens, credentials
SECRET.md
*.secret
*.credentials
config.toml
.runpod/
.env.local
.env.production
*.hexaw

# NVRTC PTX disk cache (cuda_rtc.hexa) — rebuilt on first run
.hexa-cache/

# Claude Code memory (account-shared, local only)
.claude-memory/

# macOS
.DS_Store

# Growth absorbed runtime state — transient JSON produced by growth_loop; archive tarballs are tracked for reproducibility
/.growth/absorbed/*.json
!/.growth/absorbed/archive/
