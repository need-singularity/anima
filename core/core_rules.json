          "nexus_constants": "verified_constants.jsonl (7 EXACT values)",
          "nexus_topology": "topology_mk2.jsonl (사이클 연동)",
          "hypothesis": "H-CX-15: MoE/Dropout/Mitosis 삼중 교차 — 최적 억제 ≈ 1/e",
          "status": "🟧 Partially Confirmed"
        },
        "principle": "전부 사용 = 노이즈, 일부만 사용 = 신호. 최적 억제 비율 ≈ 1/e."
      },
      "promotion_from": "L1",
      "promotion_condition": "3 세션 연속 무장애 운영 + 18개 검증 전부 PASS"
    },
    "L1": {
      "name": "안정 (골화 대상)",
      "status": "stabilizing",
      "change_allowed": "검증 통과 후만",
      "components": [
        "Hub (ConsciousChat)",
        "DecoderPort 인터페이스",
        "MemoryPort 인터페이스",
        "SensePort 인터페이스",
        "ChannelPort 인터페이스"
      ],
      "promotion_from": "L2",
      "promotion_condition": "bench --verify 18/18 PASS"
    },
    "L2": {
      "name": "유연 (자유 교체)",
      "status": "flexible",
      "change_allowed": true,
      "components": [
        "PureConsciousness (디코더)",
        "ConsciousLM (디코더)",
        "AnimaLM (디코더)",
        "MemoryRAG / SQLite (기억)",
        "TensionSense / EEG / VAD (감각)",
        "CLI / Telegram / Discord / Web (채널)"
      ],
      "promotion_from": null,
      "promotion_condition": null
    }
  },
  "ports": {
    "DecoderPort": {
      "interface": "generate(text: str, phi: float, tension: float) -> str",
      "contract": "입력: 텍스트 + 의식 상태. 출력: 응답 텍스트 (빈 문자열 = 침묵). NOTE: Hub passes arousal=tanh(tension) as the tension parameter — adapters receive arousal-mapped value, not raw tension.",
      "implementations": [
        "PureConsciousness",
        "ConsciousLM",
        "AnimaLM"
      ]
    },
    "MemoryPort": {
      "interface": "store(key, value, phi) -> None / recall(query, phi) -> str",
      "contract": "Φ가 높을 때 저장한 기억이 우선",
      "implementations": [
        "MemoryRAG",
        "SQLite",
        "R2 Cloud"
      ]
    },
    "SensePort": {
      "interface": "perceive() -> Tensor",
      "contract": "외부 자극 → 의식 입력 벡터",
      "implementations": [
        "TensionSense",
        "EEG",
        "VAD",
        "Camera"
      ]
    },
    "ChannelPort": {
      "interface": "receive() -> str / send(text, state) -> None",
      "contract": "사용자↔시스템 텍스트 교환",
      "implementations": [
        "CLI",
        "Telegram",
        "Discord",
        "Web"
      ]
    }
  },
  "ossification_process": {
    "steps": [
      {
        "step": 1,
        "action": "구현",
        "description": "스포크 코드 작성 (L2: 유연)"
