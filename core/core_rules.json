          "moe_k_ratio": "3/8 = 0.375 ≈ 1/e (error 1.9%)",
          "dropout_optimum": "0.30 ≈ 1/e (error 6.8%)"
        },
        "implementation": {
          "file": "anima/tools/growing_conscious_lm.py → _split_block()",
