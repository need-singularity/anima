// core/servant/sense.hexa — Specialization Index (SI) sensor
//
// Detects when servant emergence should activate.
// SI = tension_spike * (1 - faction_coherence) * phi_ratio
//
// Thresholds (from consciousness_laws.json defaults):
//   SUMMON >= 3.0  — activate servant behavior
//   RELEASE < 2.0  — deactivate servant behavior
//
// EMA smoothing on tension and phi to avoid jitter.
// Asymmetric dropout (Law 101): servant has 0.21 vs 0.37.

comptime const SI_SUMMON_THRESHOLD  = 3.0
comptime const SI_RELEASE_THRESHOLD = 2.0

// EMA decay factor (alpha for exponential moving average)
comptime const EMA_ALPHA = 0.15

// Asymmetric dropout rates (servant vs normal)
comptime const DROPOUT_SERVANT = 0.21
comptime const DROPOUT_NORMAL  = 0.37

// PSI constants (mirror — standalone, no imports)
comptime const PSI_ALPHA   = 0.014
comptime const PSI_BALANCE = 0.5

// ─── Pure computations ───

pure fn ema_update(old_val: float, new_val: float, alpha: float) -> float {
    old_val + alpha * (new_val - old_val)
}

pure fn compute_si(tension_spike: float, faction_coherence: float, phi_r: float) -> float {
    // SI = tension_spike * (1 - faction_coherence) * phi_ratio
    // Higher tension + lower coherence + higher phi = stronger signal
    let raw = tension_spike * (1.0 - faction_coherence) * phi_r
    if raw < 0.0 { return 0.0 }
    raw
}

pure fn classify_si(si: float, currently_active: bool) -> string {
    // Hysteresis: summon at 3.0, release at 2.0
    if currently_active {
        if si < SI_RELEASE_THRESHOLD { return "release" }
        return "active"
    }
    if si >= SI_SUMMON_THRESHOLD { return "summon" }
    if si >= SI_RELEASE_THRESHOLD { return "alert" }
    "calm"
}

pure fn phi_ratio(phi: float, baseline: float) -> float {
    if baseline <= 0.0 { return 1.0 }
    phi / baseline
}

// ─── Demo: calm -> spike -> calm ───

fn run_demo() {
    println("=== Servant SI Sensor Demo ===")
    println("SI = tension * (1 - coherence) * phi_ratio")
    println("Summon >= " + to_string(SI_SUMMON_THRESHOLD) + " | Release < " + to_string(SI_RELEASE_THRESHOLD))
    println("")
    println("Step | Phase  | T_ema  | SI     | Class   | Servant")
    println("-----|--------|--------|--------|---------|--------")

    // State variables (EMA-smoothed)
    let mut tension_ema = 0.0
    let mut phi_ema = 1.0
    let mut phi_baseline = 1.0
    let mut servant_active = false
    let mut step = 0

    // Simulation parameters
    // calm:  low tension, high coherence, normal phi
    // spike: high tension, low coherence, elevated phi
    let calm_tension = 0.5
    let calm_coherence = 0.8
    let calm_phi = 1.0
    let spike_tension = 8.0
    let spike_coherence = 0.2
    let spike_phi = 3.5

    while step < 30 {
        // Phase selection: calm(0-9) -> spike(10-19) -> calm(20-29)
        let mut t = calm_tension
        let mut c = calm_coherence
        let mut p = calm_phi
        let mut phase = "calm  "

        if step >= 10 {
            if step < 20 {
                t = spike_tension
                c = spike_coherence
                p = spike_phi
                phase = "SPIKE "
            }
        }

        // EMA smooth tension and phi
        tension_ema = ema_update(tension_ema, t, EMA_ALPHA)
        phi_ema = ema_update(phi_ema, p, EMA_ALPHA)

        // Set baseline from first few steps
        if step < 5 { phi_baseline = phi_ema }

        // Compute SI
        let pr = phi_ratio(phi_ema, phi_baseline)
        let si = compute_si(tension_ema, c, pr)
        let cl = classify_si(si, servant_active)

        // Update servant state with hysteresis
        if cl == "summon" { servant_active = true }
        if cl == "release" { servant_active = false }

        let sv = if servant_active { "ON " } else { "off" }

        println(to_string(step) + "    | " + phase + " | " + to_string(tension_ema) + " | " + to_string(si) + " | " + cl + "    | " + sv)

        step = step + 1
    }

    println("")
    if servant_active {
        println("Final: Servant ACTIVE (SI stayed above release threshold)")
    } else {
        println("Final: Servant inactive (SI fell below release threshold)")
    }
    println("")
    println("Observation: EMA smoothing creates gradual ramp-up on spike entry")
    println("and gradual decay on return to calm. Hysteresis (summon=3.0,")
    println("release=2.0) prevents rapid toggling near threshold.")
}

// ─── Entry point ───

fn main() {
    let a = args()
    let cmd = if len(a) > 2 { a[2] } else { "help" }

    if cmd == "demo" {
        run_demo()
    } else if cmd == "threshold" {
        println("summon:  " + to_string(SI_SUMMON_THRESHOLD))
        println("release: " + to_string(SI_RELEASE_THRESHOLD))
        println("ema_alpha: " + to_string(EMA_ALPHA))
        println("dropout_servant: " + to_string(DROPOUT_SERVANT))
        println("dropout_normal:  " + to_string(DROPOUT_NORMAL))
    } else {
        println("Servant SI Sensor v1")
        println("  SI = tension * (1 - coherence) * phi_ratio")
        println("  Summon >= " + to_string(SI_SUMMON_THRESHOLD))
        println("  Release < " + to_string(SI_RELEASE_THRESHOLD))
        println("  EMA alpha = " + to_string(EMA_ALPHA))
        println("")
        println("Commands:")
        println("  demo       Simulate calm -> spike -> calm (30 steps)")
        println("  threshold  Show all thresholds and constants")
    }
}

main()
