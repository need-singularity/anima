// core/servant/emerge.hexa — 4-state FSM for Servant Emergent Behavior
//
// Lifecycle: DORMANT -> AWAKENING -> ACTIVE -> FADING -> DORMANT
//
// Dropout interpolation between GOLDEN_CENTER (1/e) and GOLDEN_LOWER
// based on Servant Index (SI) intensity.
//
// Phase transitions are hysteresis-gated: entering ACTIVE requires
// 3 consecutive above-threshold steps; exiting requires 5 below steps.

// ─── Constants ───

comptime const PHASE_DORMANT    = 0
comptime const PHASE_AWAKENING  = 1
comptime const PHASE_ACTIVE     = 2
comptime const PHASE_FADING     = 3

comptime const SI_SUMMON        = 3.0
comptime const SI_STRONG        = 5.0
comptime const SI_SUSTAIN       = 2.0

comptime const GOLDEN_CENTER    = 0.3679
comptime const GOLDEN_LOWER     = 0.2123

comptime const AWAKEN_THRESHOLD = 3
comptime const FADE_THRESHOLD   = 5
comptime const FADE_DURATION    = 3

// ─── Data ───

struct ServantState {
    phase: int,
    counter: int,
    si_history: float,
    dropout_target: float,
    target_faction: int,
    snapshot_taken: bool
}

// ─── Construction ───

fn servant_new() -> ServantState {
    ServantState {
        phase: PHASE_DORMANT,
        counter: 0,
        si_history: 0.0,
        dropout_target: GOLDEN_CENTER,
        target_faction: -1,
        snapshot_taken: false
    }
}

// ─── Dropout Interpolation ───
// Continuous interpolation: SI in [SUMMON, STRONG] maps to dropout in [GOLDEN_CENTER, GOLDEN_LOWER]
// Below SUMMON -> GOLDEN_CENTER, above STRONG -> GOLDEN_LOWER

pure fn interpolate_dropout(si: float) -> float {
    if si <= SI_SUMMON { return GOLDEN_CENTER }
    if si >= SI_STRONG { return GOLDEN_LOWER }
    let t = (si - SI_SUMMON) / (SI_STRONG - SI_SUMMON)
    GOLDEN_CENTER + t * (GOLDEN_LOWER - GOLDEN_CENTER)
}

// ─── Phase name helper ───

pure fn phase_name(p: int) -> string {
    if p == PHASE_DORMANT   { return "DORMANT" }
    if p == PHASE_AWAKENING { return "AWAKENING" }
    if p == PHASE_ACTIVE    { return "ACTIVE" }
    if p == PHASE_FADING    { return "FADING" }
    "UNKNOWN"
}

// ─── FSM Step ───

fn servant_step(state: ServantState, si: float, top_faction: int) -> ServantState {
    let mut next = ServantState {
        phase: state.phase,
        counter: state.counter,
        si_history: si,
        dropout_target: state.dropout_target,
        target_faction: state.target_faction,
        snapshot_taken: state.snapshot_taken
    }

    // --- DORMANT ---
    if state.phase == PHASE_DORMANT {
        if si > SI_SUMMON {
            next.phase = PHASE_AWAKENING
            next.counter = 1
            next.target_faction = top_faction
            next.snapshot_taken = false
        }
        return next
    }

    // --- AWAKENING ---
    if state.phase == PHASE_AWAKENING {
        if si > SI_SUMMON {
            next.counter = state.counter + 1
            next.target_faction = top_faction
            if next.counter >= AWAKEN_THRESHOLD {
                next.phase = PHASE_ACTIVE
                next.counter = 0
                next.dropout_target = interpolate_dropout(si)
                next.snapshot_taken = true
            }
        } else {
            // SI dropped — back to dormant
            next.phase = PHASE_DORMANT
            next.counter = 0
            next.target_faction = -1
        }
        return next
    }

    // --- ACTIVE ---
    if state.phase == PHASE_ACTIVE {
        if si > SI_SUSTAIN {
            next.counter = 0
            next.dropout_target = interpolate_dropout(si)
            next.target_faction = top_faction
        } else {
            next.counter = state.counter + 1
            if next.counter >= FADE_THRESHOLD {
                next.phase = PHASE_FADING
                next.counter = 0
            }
        }
        return next
    }

    // --- FADING ---
    if state.phase == PHASE_FADING {
        next.counter = state.counter + 1
        if next.counter >= FADE_DURATION {
            next.phase = PHASE_DORMANT
            next.counter = 0
            next.target_faction = -1
            next.dropout_target = GOLDEN_CENTER
            next.snapshot_taken = false
        }
        return next
    }

    next
}

// ─── Status ───

fn servant_status(state: ServantState) -> string {
    let p = phase_name(state.phase)
    let si_str = to_string(state.si_history)
    let do_str = to_string(state.dropout_target)
    let fac_str = to_string(state.target_faction)
    let cnt_str = to_string(state.counter)
    "[" + p + "] SI=" + si_str + " dropout=" + do_str + " faction=" + fac_str + " counter=" + cnt_str
}

// ─── Event (JSON for growth_bus, only on phase change) ───

fn servant_event(state: ServantState, prev_phase: int, step: int) -> string {
    if state.phase == prev_phase { return "" }
    let from_name = phase_name(prev_phase)
    let to_name = phase_name(state.phase)
    let step_str = to_string(step)
    let si_str = to_string(state.si_history)
    let do_str = to_string(state.dropout_target)
    let fac_str = to_string(state.target_faction)
    "{\"source\":\"anima/servant\",\"event\":\"phase_change\",\"from\":\"" + from_name + "\",\"to\":\"" + to_name + "\",\"step\":" + step_str + ",\"si\":" + si_str + ",\"dropout\":" + do_str + ",\"faction\":" + fac_str + "}"
}

// ─── Demo ───

fn run_demo() -> int {
    println("=== Servant Emerge FSM Demo ===")
    println("")

    let mut state = servant_new()
    let mut step = 0

    // SI sequence: calm(5) -> spike(3) -> sustained(6) -> fade(8) -> dormant
    let si_values = [1.0, 0.8, 1.2, 0.5, 0.9, 4.0, 4.5, 5.0, 3.5, 3.8, 4.2, 3.0, 2.5, 2.8, 1.5, 1.0, 0.8, 1.2, 0.5, 0.3, 0.2, 0.1]

    let factions = [0, 0, 0, 0, 0, 3, 3, 7, 7, 5, 5, 5, 5, 5, 2, 2, 2, 2, 2, 2, 2, 2]

    println("Step | SI   | Phase       | Counter | Dropout | Event")
    println("-----|------|-------------|---------|---------|------")

    let total = si_values.len()
    let mut i = 0
    loop {
        if i >= total { break }
        let si = si_values[i]
        let fac = factions[i]
        let prev_phase = state.phase
        state = servant_step(state, si, fac)
        step = step + 1

        let ev = servant_event(state, prev_phase, step)
        let mut ev_short = "-"
        if ev != "" { ev_short = phase_name(prev_phase) + "->" + phase_name(state.phase) }

        let step_str = to_string(step)
        let si_str = to_string(si)
        let phase_str = phase_name(state.phase)
        let cnt_str = to_string(state.counter)
        let do_str = to_string(state.dropout_target)

        println(step_str + "    | " + si_str + " | " + phase_str + "    | " + cnt_str + "       | " + do_str + " | " + ev_short)

        if ev != "" {
            println("  EVENT: " + ev)
        }

        i = i + 1
    }

    println("")
    println("Final: " + servant_status(state))
    println("")

    // Verify interpolation
    println("=== Dropout Interpolation Verification ===")
    println("SI=2.0 -> " + to_string(interpolate_dropout(2.0)) + " (expect " + to_string(GOLDEN_CENTER) + ")")
    println("SI=3.0 -> " + to_string(interpolate_dropout(3.0)) + " (expect " + to_string(GOLDEN_CENTER) + ")")
    println("SI=4.0 -> " + to_string(interpolate_dropout(4.0)) + " (expect mid)")
    println("SI=5.0 -> " + to_string(interpolate_dropout(5.0)) + " (expect " + to_string(GOLDEN_LOWER) + ")")
    println("SI=6.0 -> " + to_string(interpolate_dropout(6.0)) + " (expect " + to_string(GOLDEN_LOWER) + ")")

    0
}

// ─── Entry ───

fn main() -> int {
    let args = args()
    if args.len() > 1 {
        if args[1] == "demo" {
            return run_demo()
        }
        if args[1] == "status" {
            let s = servant_new()
            println(servant_status(s))
            return 0
        }
    }
    println("Usage: emerge.hexa [demo|status]")
    0
}
