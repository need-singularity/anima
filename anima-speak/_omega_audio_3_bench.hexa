// ω-audio-3 side-by-side bench: vocal() (python worker) vs vocal_hexa() (pure hexa).
import "anima_audio.hexa"

println("=== ω-audio-3 vocal_hexa POC bench ===")

// --- correctness sanity: build one of each ---
let p_py = vocal(440.0, 0.5, 100)
let p_hx = vocal_hexa(440.0, 0.5, 100)
let by_py = _file_bytes(p_py)
let by_hx = _file_bytes(p_hx)
println("python vocal path: " + p_py + " bytes=" + to_string(by_py))
println("hexa   vocal path: " + p_hx + " bytes=" + to_string(by_hx))
println("expected ~4844 (44 + 2400*2)")

// --- bench python vocal: 3 warm runs (skip cold worker import) ---
let _w1 = vocal(440.0, 0.5, 100)
let _w2 = vocal(440.0, 0.5, 100)
let mut py_sum = 0
let mut i = 0
while i < 3 {
    let t0 = time_ms()
    let p = vocal(440.0, 0.5, 100)
    let t1 = time_ms()
    let dt = t1 - t0
    println("py run " + to_string(i+1) + ": " + to_string(dt) + " ms")
    py_sum = py_sum + dt
    i = i + 1
}
let py_mean = py_sum / 3
println("python vocal warm mean: " + to_string(py_mean) + " ms (3 runs)")

// --- bench hexa vocal: 3 warm runs ---
let _wh1 = vocal_hexa(440.0, 0.5, 100)
let mut hx_sum = 0
let mut j = 0
while j < 3 {
    let t0 = time_ms()
    let p = vocal_hexa(440.0, 0.5, 100)
    let t1 = time_ms()
    let dt = t1 - t0
    println("hx run " + to_string(j+1) + ": " + to_string(dt) + " ms")
    hx_sum = hx_sum + dt
    j = j + 1
}
let hx_mean = hx_sum / 3
println("hexa   vocal warm mean: " + to_string(hx_mean) + " ms (3 runs)")

// --- summary ---
println("---")
println("BENCH_RESULT py_mean_ms=" + to_string(py_mean) + " hx_mean_ms=" + to_string(hx_mean) + " py_bytes=" + to_string(by_py) + " hx_bytes=" + to_string(by_hx))
