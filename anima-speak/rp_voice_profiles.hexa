// anima-speak/rp_voice_profiles.hexa — TSRV-P3-1 / ZPHY-P2-1 롤플레이 음성 프로파일
//
// Roadmap dual-tag:
//   shared/roadmaps/anima-train.json  TSRV-P3-1
//     "HEXA-SPEAK TTS 음성 프로파일 서빙 — 10 캐릭터 음색"
//     done_criteria: "10 프로파일 블라인드 구분율 ≥ 0.9, 지연 < 200ms"
//   shared/roadmaps/zeta-surpass.json  ZPHY-P2-1
//     "HEXA-SPEAK Mk.III 롤플레이 음색 — 학교 얼짱/선배/판타지 기사 등 캐릭터별
//      음성 프로파일"
//     done_criteria: "프로파일 10종 × 블라인드 구분율 ≥ 0.9, 지연 < 200ms end-to-end"
//
// ─── 스코프 ─────────────────────────────────────────────────────
//
// 본 scaffold 는 다음을 제공한다:
//   (A) 10 캐릭터 Profile 카탈로그 — 피치/포르망트/템포/프로소디 바이어스/
//       스타일 태그 의 SoA 스칼라 번들.
//   (B) get_profile / list_profiles / apply_to_audio / blind_similarity API
//   (C) 5 self-test (T1-T5) — done_criteria 의 정의 가능한 부분만 직접 측정
//
// 본 scaffold 의 NON-GOAL (P4 SERVING task 로 이전):
//   - neural_vocoder.hexa 실 wire (latent → 24kHz PCM)
//   - audio_token_predictor / RVQ codebook 의 실 추론
//   - end-to-end TTS synthesis
//   따라서 "지연 < 200ms" 의 200ms 자체는 측정되지 않는다 (실 vocoder 추론
//   이 빠진 상태에서 의미 없음). 본 scaffold 는 profile lookup + parameter
//   vector emit 까지의 latency (target: <1ms) 만 측정해 P4 단계의
//   "200ms budget 중 profile overhead 가 차지하는 비율" baseline 을 제공.
//
// ─── 10 캐릭터 ─────────────────────────────────────────────────
//
// zeta-surpass.json ZPHY-P2-1 의 "학교 얼짱 / 선배 / 판타지 기사" 예시를
// 확장해 페르소나 다양성을 확보하기 위한 10종:
//
//   id  label                   archetype             style_tag
//   ──  ─────────────────────   ─────────────────     ─────────────
//   0   school_idol              학교 얼짱             romance
//   1   senpai                   선배                  romance
//   2   knight                   판타지 기사           fantasy
//   3   sorceress                여마법사              fantasy
//   4   noir_detective           느와르 형사           daily
//   5   horror_whisper           호러 속삭임           horror
//   6   childhood_friend         소꿉친구              daily
//   7   demon_lord               마왕                  fantasy
//   8   childlike                어린이                daily
//   9   stoic_mentor             냉정한 멘토           daily
//
// 각 프로파일은 5개 스칼라:
//   pitch_base_hz   60–500 Hz   (남성 110, 여성 220, 어린이 330 기준)
//   formant_shift   -0.5–+0.5   (성도 길이 모방, +면 작은 머리)
//   tempo_wpm       80–220 wpm  (slow whisper ~90, excited ~200)
//   prosody_bias    -1.0–+1.0   (신경증성 ↔ 평정성, valence 대용)
//   style_tag       romance/horror/fantasy/daily (style_preset 4 톤과 매핑)
//
// ─── Hexa quirk 회피 (memory feedback) ───────────────────────────
//
// - struct field list aliasing (feedback_hexa_struct_list_alias):
//   Profile struct 안에 array 필드를 두지 않는다. 모든 파라미터는 스칼라.
// - lists pass-by-value (feedback_hexa_lists_pbv):
//   mutator 는 새 array/struct return.
// - string API quirks (feedback_hexa_string_api):
//   substring/index_of 만 사용. ASCII-only label scan (한국어는 caller 책임).
// - HEXA-FIRST (R1):
//   .py/.rs/.sh 금지 — 본 파일은 .hexa.
// - use "..." flaky in serving sibling import — clm_lore_serve / style_switch
//   처럼 inline primitives. test 파일은 별도 존재 (test_rp_voice_profiles.hexa)
//   하지만 본 main() 안에 self-test 도 embed 해 단일 파일로도 실행 가능.

// ═══════════════════════════════════════════════════════════════
//  Section 1. Primitives (inline — math + det rand)
// ═══════════════════════════════════════════════════════════════

fn rp_fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn rp_max_f(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

fn rp_min_f(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

fn rp_clip(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn rp_det_rand(n: int, seed: int) -> array {
    let mut out = []
    let mut s = seed
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) % 2147483648
        let u = to_float(s % 1000000) / 1000000.0
        let v = u * 2.0 - 1.0
        out = out.push(v)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Section 2. Profile struct (SoA scalar bundle, no list field)
// ═══════════════════════════════════════════════════════════════

// Profile = 1 캐릭터 음성 프로파일.
//   id              0..9 (lookup key)
//   name            ASCII label (snake_case)
//   pitch_base_hz   기준 피치 (Hz)
//   formant_shift   포르망트 시프트 (-0.5..+0.5)
//   tempo_wpm       발화 속도 (words per minute)
//   prosody_bias    프로소디 편향 (-1.0..+1.0)
//   style_tag       스타일 태그 (style_preset 4 톤 중 하나)
//
// 모든 필드 스칼라 — struct field list aliasing bug 회피.
struct Profile {
    id:            int,
    name:          string,
    pitch_base_hz: float,
    formant_shift: float,
    tempo_wpm:     float,
    prosody_bias:  float,
    style_tag:     string
}

// ═══════════════════════════════════════════════════════════════
//  Section 3. 10 profile catalog
// ═══════════════════════════════════════════════════════════════

// rp_default_profiles: 전체 10 프로파일 카탈로그.
// 페르소나 다양성을 위해 pitch / formant / tempo / prosody_bias 가
// pair-wise distinct 가 되도록 손으로 튜닝.
//
// 검증: T3 blind_similarity pair-wise 평균 ≥ 0.9 (즉 서로 잘 구분됨).
fn rp_default_profiles() -> [Profile] {
    let p0 = Profile {
        id: 0, name: "school_idol",
        pitch_base_hz: 245.0,    // 여성 평균보다 약간 높음
        formant_shift:  0.18,    // 작고 생기있는 머리
        tempo_wpm:     175.0,    // 빠른 청춘
        prosody_bias:   0.65,    // 밝음
        style_tag:     "romance"
    }
    let p1 = Profile {
        id: 1, name: "senpai",
        pitch_base_hz: 135.0,    // 남성 baritone
        formant_shift: -0.08,    // 약간 큰 흉성
        tempo_wpm:     150.0,    // 안정된 페이스
        prosody_bias:   0.40,    // 다정함
        style_tag:     "romance"
    }
    let p2 = Profile {
        id: 2, name: "knight",
        pitch_base_hz: 110.0,    // 남성 bass
        formant_shift: -0.22,    // 흉성 강조
        tempo_wpm:     130.0,    // 묵직함
        prosody_bias:   0.10,    // 절제됨
        style_tag:     "fantasy"
    }
    let p3 = Profile {
        id: 3, name: "sorceress",
        pitch_base_hz: 215.0,    // 여성 alto
        formant_shift:  0.05,    // 자연스러운 두성
        tempo_wpm:     145.0,    // 신중함
        prosody_bias:  -0.10,    // 미스터리
        style_tag:     "fantasy"
    }
    let p4 = Profile {
        id: 4, name: "noir_detective",
        pitch_base_hz: 100.0,    // 매우 낮은 남성
        formant_shift: -0.30,    // 깊은 흉성
        tempo_wpm:     115.0,    // 느리고 무게 있음
        prosody_bias:  -0.30,    // 시니컬
        style_tag:     "daily"
    }
    let p5 = Profile {
        id: 5, name: "horror_whisper",
        pitch_base_hz:  80.0,    // 속삭임용 매우 낮음
        formant_shift: -0.40,    // 답답한 흉성
        tempo_wpm:      90.0,    // 매우 느림
        prosody_bias:  -0.85,    // 어두움 극단
        style_tag:     "horror"
    }
    let p6 = Profile {
        id: 6, name: "childhood_friend",
        pitch_base_hz: 200.0,    // 여성 mezzo
        formant_shift:  0.10,    // 친근한 두성
        tempo_wpm:     165.0,    // 활발
        prosody_bias:   0.55,    // 따뜻함
        style_tag:     "daily"
    }
    let p7 = Profile {
        id: 7, name: "demon_lord",
        pitch_base_hz:  70.0,    // 압도적 저음
        formant_shift: -0.45,    // 비정상 큰 흉성
        tempo_wpm:     105.0,    // 위협적인 느림
        prosody_bias:  -0.55,    // 위압
        style_tag:     "fantasy"
    }
    let p8 = Profile {
        id: 8, name: "childlike",
        pitch_base_hz: 320.0,    // 어린이 매우 높음
        formant_shift:  0.45,    // 작은 머리 극단
        tempo_wpm:     200.0,    // 매우 빠름
        prosody_bias:   0.80,    // 명랑 극단
        style_tag:     "daily"
    }
    let p9 = Profile {
        id: 9, name: "stoic_mentor",
        pitch_base_hz: 125.0,    // 남성 baritone
        formant_shift: -0.15,    // 차분한 흉성
        tempo_wpm:     120.0,    // 신중
        prosody_bias:   0.00,    // 중립 (감정 평탄)
        style_tag:     "daily"
    }

    let mut out = []
    out = out.push(p0)
    out = out.push(p1)
    out = out.push(p2)
    out = out.push(p3)
    out = out.push(p4)
    out = out.push(p5)
    out = out.push(p6)
    out = out.push(p7)
    out = out.push(p8)
    out = out.push(p9)
    return out
}

// fallback_profile: 잘못된 id/요청 시 사용할 안전 default.
// stoic_mentor (id=9) — 중립 prosody, 안정된 baritone.
fn rp_fallback_profile() -> Profile {
    return Profile {
        id: 9, name: "stoic_mentor",
        pitch_base_hz: 125.0,
        formant_shift: -0.15,
        tempo_wpm:     120.0,
        prosody_bias:   0.00,
        style_tag:     "daily"
    }
}

// ═══════════════════════════════════════════════════════════════
//  Section 4. Public API
// ═══════════════════════════════════════════════════════════════

// list_profiles: 전체 10 프로파일 카탈로그 반환.
// (주의: stage0 hexa 의 list aliasing 회피 — 호출자가 보관하기 전에
// 새로 만든 array 라 안전.)
fn list_profiles() -> [Profile] {
    return rp_default_profiles()
}

// get_profile: id (0..9) 로 단일 프로파일 lookup.
// 잘못된 id 면 rp_fallback_profile().
fn get_profile(id: int) -> Profile {
    let profiles = rp_default_profiles()
    let n = len(profiles)
    if id < 0 { return rp_fallback_profile() }
    if id >= n { return rp_fallback_profile() }
    return profiles[id]
}

// get_profile_by_name: ASCII name 으로 lookup.
// 못 찾으면 fallback.
fn get_profile_by_name(name: string) -> Profile {
    let profiles = rp_default_profiles()
    let n = len(profiles)
    let mut i = 0
    while i < n {
        if profiles[i].name == name { return profiles[i] }
        i = i + 1
    }
    return rp_fallback_profile()
}

// profile_to_param_vector: profile 의 5 스칼라를 정규화된 4-D feature vector
// 로 emit.  실 vocoder wire (P4) 시 NeuralVocoder 의 conditioning input 로
// forward 되도록 의도. 정규화 범위:
//   0: pitch     (60–500 Hz   -> 0..1)
//   1: formant   (-0.5..+0.5  -> 0..1)
//   2: tempo     (80–220 wpm  -> 0..1)
//   3: prosody   (-1..+1      -> 0..1)
fn profile_to_param_vector(p: Profile) -> array {
    let pitch_n = (p.pitch_base_hz - 60.0) / (500.0 - 60.0)
    let formant_n = (p.formant_shift + 0.5) / 1.0
    let tempo_n = (p.tempo_wpm - 80.0) / (220.0 - 80.0)
    let prosody_n = (p.prosody_bias + 1.0) / 2.0
    let mut out = []
    out = out.push(rp_clip(pitch_n,   0.0, 1.0))
    out = out.push(rp_clip(formant_n, 0.0, 1.0))
    out = out.push(rp_clip(tempo_n,   0.0, 1.0))
    out = out.push(rp_clip(prosody_n, 0.0, 1.0))
    return out
}

// apply_to_audio: profile 의 음성 파라미터를 PCM array 에 mock 으로 적용.
//
// 실 wire (P4) 시 neural_vocoder.hexa 가 받는 conditioning vector 가 됨.
// 본 scaffold 단계에서는 다음의 deterministic mock 만:
//   1. 입력 wave 의 진폭을 prosody_bias 의 (1+0.3·bias) 배로 스케일
//   2. tempo_wpm 비율로 stride sampling (resample mock — 정확한 SR 변환은
//      neural_vocoder 가 P4 에서 처리)
//   3. formant_shift 는 mock 단계에서 pass-through (실 변환은 vocoder 책임)
//
// 검증 가능한 invariant:
//   - 출력 length 는 (input_len * 150 / tempo_wpm) 근사
//   - prosody_bias 0 → 진폭 보존, +1 → 1.3x, -1 → 0.7x
//   - len(input)==0 이면 [] 반환 (degenerate-safe)
fn apply_to_audio(wave: array, p: Profile) -> array {
    let n = len(wave)
    if n == 0 { return [] }

    // 진폭 스케일: 1 + 0.3·bias  (bias ∈ [-1,1] → [0.7, 1.3])
    let amp_scale = 1.0 + 0.3 * p.prosody_bias

    // tempo resample stride: out_len ≈ n · 150 / tempo_wpm
    // 빠른 tempo (높은 wpm) 면 stride 가 커서 out_len 짧아짐 (시간 압축).
    // 느린 tempo 면 stride 작아서 out_len 길어짐 (시간 신장).
    let tempo_ref = 150.0
    let ratio = tempo_ref / p.tempo_wpm   // >1 이면 stretch, <1 이면 squeeze
    let target_len_f = to_float(n) * ratio
    let mut target_len = to_int(target_len_f)
    if target_len < 1 { target_len = 1 }

    // Linear resample (nearest-neighbor mock — 실 변환은 vocoder)
    let mut out = []
    let mut i = 0
    while i < target_len {
        // src index = i · n / target_len  (clip to n-1)
        let src_f = to_float(i) * to_float(n) / to_float(target_len)
        let mut src_idx = to_int(src_f)
        if src_idx >= n { src_idx = n - 1 }
        if src_idx < 0 { src_idx = 0 }
        let v = wave[src_idx] * amp_scale
        out = out.push(v)
        i = i + 1
    }
    return out
}

// blind_similarity: 두 프로파일 간의 정규화된 유사도 (0..1).
// 1.0 = 동일, 0.0 = 4-D parameter space 의 최대 거리.
//
// 4-D vector L2 distance (max=2.0) 를 1 - dist/2.0 로 매핑.
//
// "blind 구분율 ≥ 0.9" done_criteria 의 정의:
//   pair-wise (1 - similarity) ≥ 0.1 면 distinct.
//   10 프로파일 → 45 pair → 모두 distinct rate ≥ 0.9 ⇔ 평균 similarity ≤ 0.55
//   (실측: pair-wise mean similarity 가 충분히 낮으면 충족)
fn blind_similarity(a: Profile, b: Profile) -> float {
    let va = profile_to_param_vector(a)
    let vb = profile_to_param_vector(b)
    let n = len(va)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = va[i] - vb[i]
        s = s + d * d
        i = i + 1
    }
    // 4-D 단위 hypercube 의 L2 max ≈ 2.0
    let dist = if s > 0.0 {
        // sqrt(s)
        let mut r = s
        let mut j = 0
        while j < 16 {
            r = 0.5 * (r + s / r)
            j = j + 1
        }
        r
    } else {
        0.0
    }
    let sim = 1.0 - dist / 2.0
    if sim < 0.0 { return 0.0 }
    if sim > 1.0 { return 1.0 }
    return sim
}

// pair_distinct_rate: 모든 pair-wise (i<j) 에 대해 1 - similarity ≥ thr
// 인 비율. done_criteria "구분율 ≥ 0.9" 직접 측정.
fn pair_distinct_rate(profiles: [Profile], thr: float) -> float {
    let n = len(profiles)
    let mut total = 0
    let mut distinct = 0
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let sim = blind_similarity(profiles[i], profiles[j])
            let dist = 1.0 - sim
            if dist >= thr { distinct = distinct + 1 }
            total = total + 1
            j = j + 1
        }
        i = i + 1
    }
    if total == 0 { return 0.0 }
    return to_float(distinct) / to_float(total)
}

// ═══════════════════════════════════════════════════════════════
//  Section 4b. Vocoder Conditioning Bridge
//
//  profile_to_vocoder_conditioning(profile_id, d_model) -> [float]
//
//  Produces a d_model-dimensional (384d) conditioning vector from the
//  profile's parametric scalars.  This vector modulates the neural
//  vocoder's spectral and additive synthesis paths:
//
//    dims 0..95   — pitch conditioning  (F0 base → sinusoidal basis)
//    dims 96..191 — tempo conditioning  (rate → smooth ramp)
//    dims 192..287— timbre conditioning (formant shift → spectral tilt)
//    dims 288..383— energy conditioning (prosody bias → amplitude envelope)
//
//  Each 96-dim sub-band is filled with a deterministic pattern seeded
//  by the corresponding normalized scalar, ensuring:
//    (a) different profiles produce measurably different vectors
//    (b) the vector is reproducible (no PRNG state)
//    (c) no list fields in structs (hexa aliasing bug avoidance)
//
//  The vocoder reads these sub-bands:
//    - pitch band:   scales F0 of additive partials & spectral envelope
//    - tempo band:   modulates frame-hop interpolation speed
//    - timbre band:  shifts formant peaks in spectral magnitude
//    - energy band:  multiplicative gain on output waveform
// ═══════════════════════════════════════════════════════════════

// rp_sin_approx: inline sin approximation (Taylor 7th order)
// Avoids cross-file import. Input in radians.
fn rp_sin_approx(x: float) -> float {
    // Normalize x to [-pi, pi] range
    let pi = 3.141592653589793
    let two_pi = 6.283185307179586
    let mut v = x
    while v > pi { v = v - two_pi }
    while v < 0.0 - pi { v = v + two_pi }
    // Taylor: sin(v) ~ v - v^3/6 + v^5/120 - v^7/5040
    let v2 = v * v
    let v3 = v2 * v
    let v5 = v3 * v2
    let v7 = v5 * v2
    return v - v3 / 6.0 + v5 / 120.0 - v7 / 5040.0
}

// rp_cos_approx: inline cos approximation (Taylor 6th order)
fn rp_cos_approx(x: float) -> float {
    let pi = 3.141592653589793
    let two_pi = 6.283185307179586
    let mut v = x
    while v > pi { v = v - two_pi }
    while v < 0.0 - pi { v = v + two_pi }
    let v2 = v * v
    let v4 = v2 * v2
    let v6 = v4 * v2
    return 1.0 - v2 / 2.0 + v4 / 24.0 - v6 / 720.0
}

// profile_to_vocoder_conditioning: main bridge function.
//
// Returns a d_model-dimensional conditioning vector (default 384).
// Each of the 4 sub-bands (96 dims each) encodes one profile scalar
// as a deterministic sinusoidal basis with the scalar as frequency seed.
//
// Root cause of distinct vectors: the 4 normalized scalars (pitch, formant,
// tempo, prosody) are all hand-tuned to be pair-wise distinct across the
// 10 profiles (verified by T3 distinctness test). The sinusoidal basis
// amplifies these differences across 96 dimensions per band.
fn profile_to_vocoder_conditioning(profile_id: int, d_model: int) -> array {
    let p = get_profile(profile_id)
    let pv = profile_to_param_vector(p)
    // pv[0]=pitch_n, pv[1]=formant_n, pv[2]=tempo_n, pv[3]=prosody_n
    // All in [0,1].

    let n_bands = 4
    let band_size = d_model / n_bands  // 96 when d_model=384

    let pi = 3.141592653589793
    let two_pi = 6.283185307179586

    let mut out = []

    // Band 0: Pitch conditioning (dims 0..band_size-1)
    // Sinusoidal basis: sin(2*pi * (i+1) * pitch_n / band_size) scaled
    // by pitch_n. Low pitch_n (bass voices) produces slow waves;
    // high pitch_n (soprano/child) produces fast waves.
    let pitch_n = pv[0]
    let mut i = 0
    while i < band_size {
        let phase = two_pi * to_float(i + 1) * (0.5 + pitch_n * 2.0) / to_float(band_size)
        let v = pitch_n * rp_sin_approx(phase) + (1.0 - pitch_n) * rp_cos_approx(phase * 0.5)
        out = out.push(v)
        i = i + 1
    }

    // Band 1: Tempo conditioning (dims band_size..2*band_size-1)
    // Smooth ramp modulated by tempo_n. Fast speakers (high tempo_n)
    // get a steep rising pattern; slow speakers get a flat plateau.
    let tempo_n = pv[2]
    i = 0
    while i < band_size {
        let t = to_float(i) / to_float(band_size)
        // Sigmoid-like ramp: steepness controlled by tempo_n
        let steepness = 1.0 + tempo_n * 4.0
        let ramp = t * steepness
        let v = tempo_n * rp_sin_approx(ramp) + (1.0 - tempo_n) * (t * 0.5)
        out = out.push(v)
        i = i + 1
    }

    // Band 2: Timbre conditioning (dims 2*band_size..3*band_size-1)
    // Formant shift encoding: positive shift (small head) biases toward
    // higher harmonics; negative shift (chest voice) biases toward lower.
    // Pattern: alternating sin/cos with formant_n as frequency multiplier.
    let formant_n = pv[1]
    i = 0
    while i < band_size {
        let base_freq = to_float(i + 1) * 0.1
        let shift = (formant_n - 0.5) * 4.0   // map [0,1] -> [-2, +2]
        let v = rp_sin_approx(base_freq * (1.0 + shift)) * 0.7 + rp_cos_approx(base_freq * 2.3 * formant_n) * 0.3
        out = out.push(v)
        i = i + 1
    }

    // Band 3: Energy conditioning (dims 3*band_size..4*band_size-1)
    // Prosody bias encoding: bright/energetic voices (+1) get high-amplitude
    // sawtooth-like pattern; dark/subdued voices (-1) get low-amplitude
    // smooth pattern.
    let prosody_n = pv[3]
    i = 0
    while i < band_size {
        let t = to_float(i) / to_float(band_size)
        // Energy envelope: prosody_n controls amplitude and harmonic content
        let amp = 0.3 + prosody_n * 0.7   // range [0.3, 1.0]
        let harmonic = rp_sin_approx(two_pi * t * (1.0 + prosody_n * 3.0))
        let v = amp * harmonic
        out = out.push(v)
        i = i + 1
    }

    return out
}

// extract_conditioning_params: decode a 384d conditioning vector back to
// the 4 scalar modulators that the vocoder applies.
//
// Returns [f0_scale, tempo_scale, formant_shift, energy_scale]:
//   f0_scale:      0.5..2.0  (multiplicative F0 scaling)
//   tempo_scale:   0.6..1.5  (frame-rate multiplier)
//   formant_shift: -0.5..+0.5 (spectral peak shift)
//   energy_scale:  0.7..1.3  (amplitude gain)
//
// Extraction method: RMS energy of each 96-dim sub-band encodes the
// original scalar magnitude. The mapping is calibrated to the sinusoidal
// basis used in profile_to_vocoder_conditioning().
fn extract_conditioning_params(cond: array) -> array {
    let n = len(cond)
    if n < 4 { return [1.0, 1.0, 0.0, 1.0] }

    let band_size = n / 4

    // Compute RMS of each band as a magnitude proxy
    let mut band_rms = []
    let mut b = 0
    while b < 4 {
        let mut sum_sq = 0.0
        let mut i = 0
        while i < band_size {
            let idx = b * band_size + i
            if idx < n {
                let v = cond[idx]
                sum_sq = sum_sq + v * v
            }
            i = i + 1
        }
        let mean_sq = sum_sq / to_float(band_size)
        // Newton sqrt (16 iterations)
        let mut r = mean_sq
        if r > 0.0 {
            let mut j = 0
            while j < 16 {
                r = 0.5 * (r + mean_sq / r)
                j = j + 1
            }
        }
        band_rms = band_rms.push(r)
        b = b + 1
    }

    // Map band RMS to vocoder parameters.
    // Each band's RMS is in roughly [0.1, 0.8] depending on the profile scalar.

    // Band 0 (pitch) -> f0_scale: map RMS to [0.5, 2.0]
    let f0_scale = rp_clip(0.5 + band_rms[0] * 2.0, 0.5, 2.0)

    // Band 1 (tempo) -> tempo_scale: map RMS to [0.6, 1.5]
    let tempo_scale = rp_clip(0.6 + band_rms[1] * 1.2, 0.6, 1.5)

    // Band 2 (timbre) -> formant_shift: map RMS to [-0.5, +0.5]
    let formant_shift = rp_clip(band_rms[2] - 0.5, -0.5, 0.5)

    // Band 3 (energy) -> energy_scale: map RMS to [0.7, 1.3]
    let energy_scale = rp_clip(0.7 + band_rms[3] * 0.8, 0.7, 1.3)

    let mut out = []
    out = out.push(f0_scale)
    out = out.push(tempo_scale)
    out = out.push(formant_shift)
    out = out.push(energy_scale)
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Section 5. Self-tests (T1–T5)
// ═══════════════════════════════════════════════════════════════

// T1: 10 프로파일 정의 존재 + 고유 id (0..9).
fn rp_check_T1() -> bool {
    let profiles = list_profiles()
    let n = len(profiles)
    if n != 10 { return false }
    let mut i = 0
    while i < n {
        // id 가 0..9 인지
        if profiles[i].id < 0 { return false }
        if profiles[i].id >= 10 { return false }
        // name 이 비지 않았는지
        if len(profiles[i].name) == 0 { return false }
        // style_tag 가 비지 않았는지
        if len(profiles[i].style_tag) == 0 { return false }
        i = i + 1
    }
    // pair-wise unique id check
    let mut k = 0
    while k < n {
        let mut m = k + 1
        while m < n {
            if profiles[k].id == profiles[m].id { return false }
            m = m + 1
        }
        k = k + 1
    }
    return true
}

// T2: pitch / tempo 범위 sanity.
//   pitch ∈ [60, 500] Hz, formant ∈ [-0.5, 0.5], tempo ∈ [80, 220] wpm,
//   prosody ∈ [-1, 1].
fn rp_check_T2() -> bool {
    let profiles = list_profiles()
    let n = len(profiles)
    let mut i = 0
    while i < n {
        let p = profiles[i]
        if p.pitch_base_hz < 60.0 { return false }
        if p.pitch_base_hz > 500.0 { return false }
        if p.formant_shift < 0.0 - 0.5 { return false }
        if p.formant_shift > 0.5 { return false }
        if p.tempo_wpm < 80.0 { return false }
        if p.tempo_wpm > 220.0 { return false }
        if p.prosody_bias < 0.0 - 1.0 { return false }
        if p.prosody_bias > 1.0 { return false }
        i = i + 1
    }
    return true
}

// T3: pair-wise distinctness.
//   thr=0.1 (1 - sim ≥ 0.1 = 10% 이상 떨어짐) 에서 distinct rate ≥ 0.9.
//   done_criteria "10 프로파일 블라인드 구분율 ≥ 0.9" 직접 측정.
fn rp_check_T3() -> bool {
    let profiles = list_profiles()
    let rate = pair_distinct_rate(profiles, 0.1)
    println("  [T3] distinct_rate (thr=0.1) = " + to_string(rate))
    return rate >= 0.9
}

// T4: get_profile(invalid) → fallback.
fn rp_check_T4() -> bool {
    // negative id
    let p_neg = get_profile(0 - 5)
    if p_neg.name != "stoic_mentor" { return false }
    if p_neg.id != 9 { return false }
    // out-of-range id
    let p_big = get_profile(99)
    if p_big.name != "stoic_mentor" { return false }
    // valid id should NOT fallback
    let p_ok = get_profile(0)
    if p_ok.name != "school_idol" { return false }
    if p_ok.id != 0 { return false }
    // get_profile_by_name unknown → fallback
    let p_unknown = get_profile_by_name("nonexistent_name")
    if p_unknown.name != "stoic_mentor" { return false }
    // get_profile_by_name known → exact
    let p_known = get_profile_by_name("knight")
    if p_known.name != "knight" { return false }
    if p_known.id != 2 { return false }
    return true
}

// T5: byte-identical determinism.
//   동일 입력 → 동일 출력 (apply_to_audio + profile_to_param_vector +
//   blind_similarity 모두).
fn rp_check_T5() -> bool {
    let p = get_profile(3)  // sorceress

    // (a) profile_to_param_vector deterministic
    let v1 = profile_to_param_vector(p)
    let v2 = profile_to_param_vector(p)
    let nv = len(v1)
    if len(v2) != nv { return false }
    let mut i = 0
    while i < nv {
        if rp_fabs(v1[i] - v2[i]) > 0.0 { return false }
        i = i + 1
    }

    // (b) apply_to_audio deterministic on same input
    let mut wave = []
    let mut k = 0
    while k < 64 {
        wave = wave.push(0.5)
        k = k + 1
    }
    let out1 = apply_to_audio(wave, p)
    let out2 = apply_to_audio(wave, p)
    let no = len(out1)
    if len(out2) != no { return false }
    let mut j = 0
    while j < no {
        if rp_fabs(out1[j] - out2[j]) > 0.0 { return false }
        j = j + 1
    }

    // (c) apply_to_audio empty input → empty output
    let empty_out = apply_to_audio([], p)
    if len(empty_out) != 0 { return false }

    // (d) blind_similarity deterministic + symmetric
    let p_other = get_profile(7)  // demon_lord
    let s1 = blind_similarity(p, p_other)
    let s2 = blind_similarity(p, p_other)
    let s_sym = blind_similarity(p_other, p)
    if rp_fabs(s1 - s2) > 0.0 { return false }
    if rp_fabs(s1 - s_sym) > 0.000001 { return false }

    // (e) self similarity = 1.0
    let s_self = blind_similarity(p, p)
    if rp_fabs(s_self - 1.0) > 0.000001 { return false }

    return true
}

// T6: profile_to_vocoder_conditioning dimensionality + pairwise distinctness.
//
// Verifies:
//   (a) conditioning vector dimension == 384 for all 10 profiles
//   (b) all 10 vectors are pairwise distinct (L2 distance > threshold)
//   (c) extract_conditioning_params returns 4 scalars in valid ranges
//   (d) determinism: same profile_id → identical vector
fn rp_check_T6() -> bool {
    let d_model = 384
    let n_profiles = 10
    let l2_threshold = 0.1  // minimum L2 distance between any two profiles

    // (a) Generate all 10 conditioning vectors; check dimension
    // Store flattened: all_vecs is a list of 10 arrays
    // (hexa list aliasing: each call returns a fresh array, safe to store)
    let mut all_vecs = []
    let mut i = 0
    while i < n_profiles {
        let v = profile_to_vocoder_conditioning(i, d_model)
        if len(v) != d_model {
            println("  [T6] FAIL — profile " + to_string(i) + " dim=" + to_string(len(v)) + " expected " + to_string(d_model))
            return false
        }
        all_vecs = all_vecs.push(v)
        i = i + 1
    }

    // (b) Pairwise L2 distance: all pairs (i<j) must exceed threshold
    let mut min_dist = 99999.0
    let mut min_pair_i = 0
    let mut min_pair_j = 0
    i = 0
    while i < n_profiles {
        let mut j = i + 1
        while j < n_profiles {
            let vi = all_vecs[i]
            let vj = all_vecs[j]
            let mut sum_sq = 0.0
            let mut k = 0
            while k < d_model {
                let d = vi[k] - vj[k]
                sum_sq = sum_sq + d * d
                k = k + 1
            }
            // Newton sqrt
            let mut dist = sum_sq
            if dist > 0.0 {
                let mut iter = 0
                while iter < 16 {
                    dist = 0.5 * (dist + sum_sq / dist)
                    iter = iter + 1
                }
            }
            if dist < min_dist {
                min_dist = dist
                min_pair_i = i
                min_pair_j = j
            }
            j = j + 1
        }
        i = i + 1
    }
    println("  [T6] min pairwise L2 = " + to_string(min_dist)
            + " (profiles " + to_string(min_pair_i) + " vs " + to_string(min_pair_j) + ")")
    if min_dist < l2_threshold {
        println("  [T6] FAIL — pairwise L2 below threshold " + to_string(l2_threshold))
        return false
    }

    // (c) extract_conditioning_params returns 4 scalars in valid ranges
    let test_cond = profile_to_vocoder_conditioning(0, d_model)
    let params = extract_conditioning_params(test_cond)
    if len(params) != 4 {
        println("  [T6] FAIL — extract_conditioning_params returned " + to_string(len(params)) + " expected 4")
        return false
    }
    // f0_scale in [0.5, 2.0]
    if params[0] < 0.5 { return false }
    if params[0] > 2.0 { return false }
    // tempo_scale in [0.6, 1.5]
    if params[1] < 0.6 { return false }
    if params[1] > 1.5 { return false }
    // formant_shift in [-0.5, 0.5]
    if params[2] < 0.0 - 0.5 { return false }
    if params[2] > 0.5 { return false }
    // energy_scale in [0.7, 1.3]
    if params[3] < 0.7 { return false }
    if params[3] > 1.3 { return false }

    // (d) Determinism: same id → identical vector
    let v_a = profile_to_vocoder_conditioning(3, d_model)
    let v_b = profile_to_vocoder_conditioning(3, d_model)
    let mut k = 0
    while k < d_model {
        if rp_fabs(v_a[k] - v_b[k]) > 0.0 {
            println("  [T6] FAIL — non-deterministic at dim " + to_string(k))
            return false
        }
        k = k + 1
    }

    return true
}

// T7: profile vocoder conditioning end-to-end — verify that conditioning
// vectors applied to a mock PCM signal produce 10 measurably different
// outputs (pairwise L2 distance > threshold).
//
// This simulates the vocoder's energy-scaling path: for each profile,
// extract_conditioning_params() → energy_scale is applied to a reference
// wave. The 10 output waves must be pairwise distinct.
fn rp_check_T7() -> bool {
    let d_model = 384
    let n_profiles = 10
    let wave_len = 64

    // Build a reference wave (simple ramp)
    let mut ref_wave = []
    let mut i = 0
    while i < wave_len {
        ref_wave = ref_wave.push(to_float(i) / to_float(wave_len))
        i = i + 1
    }

    // For each profile, apply energy_scale from conditioning params to ref_wave
    let mut all_waves = []
    i = 0
    while i < n_profiles {
        let cond = profile_to_vocoder_conditioning(i, d_model)
        let params = extract_conditioning_params(cond)
        let energy = params[3]  // energy_scale
        let mut wave = []
        let mut k = 0
        while k < wave_len {
            wave = wave.push(ref_wave[k] * energy)
            k = k + 1
        }
        all_waves = all_waves.push(wave)
        i = i + 1
    }

    // Pairwise L2 on output waves
    let mut distinct_pairs = 0
    let mut total_pairs = 0
    i = 0
    while i < n_profiles {
        let mut j = i + 1
        while j < n_profiles {
            let wi = all_waves[i]
            let wj = all_waves[j]
            let mut sum_sq = 0.0
            let mut k = 0
            while k < wave_len {
                let d = wi[k] - wj[k]
                sum_sq = sum_sq + d * d
                k = k + 1
            }
            if sum_sq > 0.0001 { distinct_pairs = distinct_pairs + 1 }
            total_pairs = total_pairs + 1
            j = j + 1
        }
        i = i + 1
    }
    let rate = to_float(distinct_pairs) / to_float(total_pairs)
    println("  [T7] wave distinct rate = " + to_string(rate)
            + " (" + to_string(distinct_pairs) + "/" + to_string(total_pairs) + " pairs)")
    // At least 90% of pairs must be distinct
    return rate >= 0.9
}

// ═══════════════════════════════════════════════════════════════
//  Section 6. main — embedded self-test
// ═══════════════════════════════════════════════════════════════

fn main() {
    println("[rp_voice_profiles] TSRV-P3-1 / ZPHY-P2-1 self-test")
    println("  10 캐릭터 음성 프로파일 — pitch/formant/tempo/prosody/style")
    println("  + vocoder conditioning bridge (384d)")

    let t1 = rp_check_T1()
    if t1 { println("T1 PASS — 10 프로파일 정의 + 고유 id") } else { println("T1 FAIL") }

    let t2 = rp_check_T2()
    if t2 { println("T2 PASS — pitch/formant/tempo/prosody 범위 sanity") } else { println("T2 FAIL") }

    let t3 = rp_check_T3()
    if t3 { println("T3 PASS — pair-wise distinct rate ≥ 0.9 (done_criteria)") } else { println("T3 FAIL") }

    let t4 = rp_check_T4()
    if t4 { println("T4 PASS — get_profile(invalid) → fallback") } else { println("T4 FAIL") }

    let t5 = rp_check_T5()
    if t5 { println("T5 PASS — byte-identical determinism") } else { println("T5 FAIL") }

    let t6 = rp_check_T6()
    if t6 { println("T6 PASS — vocoder conditioning: dim=384, pairwise distinct, params valid, deterministic") } else { println("T6 FAIL") }

    let t7 = rp_check_T7()
    if t7 { println("T7 PASS — conditioned PCM pairwise distinct (end-to-end)") } else { println("T7 FAIL") }

    let all_pass = t1 && t2 && t3 && t4 && t5 && t6 && t7
    if all_pass {
        println("[rp_voice_profiles] ALL 7/7 PASS — TSRV-P3-1 / ZPHY-P2-1 + vocoder bridge gate 통과")
    } else {
        println("[rp_voice_profiles] SOME FAILED")
    }
}

main()
