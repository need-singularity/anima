// anima_audio_demo.hexa — anima 의 organ 탐색 corpus 생성기
//
// 5 phase 진화 시연, 모두 학습 없이 organ 조합만으로:
//   Phase A: raw organ (vocal/breath/pipe) — 옹알이
//   Phase B: 확장 organ (vocal_lf/pipe3/pipe_glide/cat/mix) — 모음·전이·마찰
//   Phase C: phone helper (CV syllable) — 음절 조립
//   Phase D: hive 공리 (consonance/egyptian_chord/banach reverb)
//   Phase E: spectral 원자 (tone, lpf/hpf) + xfade (fade) + 균일화 (normalize)
//   Phase F: time-varying 원자 (chirp) + 자기측정 (meter)
//   Phase G: P₂=28 harmonic + echo/tremolo + sf-ufo mains_hum + σ·τ=48 ouroboros
//   Phase H: loss/ufo.txt 매핑 — harmonic_milestone (8 axiom-k sparse stack)
//   Phase I: 학문적 noise/pitch — noise_pink (1/f) + vibrato (pitch LFO)
//   Phase J: 학문적 wave/noise/filter — noise_brown (φ=2) + square + comb
//   Phase K: 비선형/변조/엔벨롭 — triangle + clip + ring_mod + adsr
//   Phase L: digital/FM/blue noise — bit_crush + fm_synth + noise_blue
//   Phase M: 학문 reference — noise_white (flat) + reverse + all_pass (Schroeder)
//   Phase N: parametric EQ — dc_block + low_shelf + high_shelf (RBJ EQ)
//   Phase O: violet noise + flanger + am_mod (DSB-LC) — 진짜 고갈
//   Phase P: chorus + rectify + gate (loop wave 1)
//   Phase Q: compressor + limiter + saturate_asinh (loop wave 2)

import "./anima_audio.hexa"
import "./anima_audio_phone.hexa"

fn main() {
    let CORPUS_A = "/Users/ghost/core/anima/anima-speak/corpus/babble"
    let CORPUS_B = "/Users/ghost/core/anima/anima-speak/corpus/extended"
    let CORPUS_C = "/Users/ghost/core/anima/anima-speak/corpus/syllables"
    print("anima audio — 3-phase organ exploration corpus")
    print("")

    // ═══ Phase A: 옹알이 (raw 3 organ) ═══════════════════
    print("[Phase A] raw organ — 톤/마찰/모음")
    let _ = save(vocal(220.0, 0.5, 400), CORPUS_A + "/01_tone_220.wav")
    let _ = save(vocal(110.0, 0.5, 250), CORPUS_A + "/02a_lo_110.wav")
    let _ = save(vocal(220.0, 0.5, 250), CORPUS_A + "/02b_mid_220.wav")
    let _ = save(vocal(440.0, 0.5, 250), CORPUS_A + "/02c_hi_440.wav")
    let _ = save(breath(3000.0, 7000.0, 0.35, 120), CORPUS_A + "/03_fricative_cheu.wav")
    let _ = save(breath(500.0, 2500.0, 0.35, 140), CORPUS_A + "/04_fricative_zeu.wav")
    let _ = save(pipe(vocal(180.0, 0.4, 350), 700.0, 1100.0, 6.0), CORPUS_A + "/05_vowel_a_2F.wav")
    let _ = save(pipe(vocal(180.0, 0.4, 350), 300.0, 2300.0, 6.0), CORPUS_A + "/06_vowel_i_2F.wav")
    let _ = save(pipe(vocal(180.0, 0.4, 350), 300.0, 800.0, 6.0), CORPUS_A + "/07_vowel_u_2F.wav")
    let _ = save(pipe(vocal(180.0, 0.4, 350), 300.0, 1300.0, 6.0), CORPUS_A + "/08_vowel_eu_2F.wav")
    print("  -> " + CORPUS_A + " (10 WAV)")

    // ═══ Phase B: 확장 organ ═══════════════════════════
    print("[Phase B] pipe3 (3F) + pipe_glide + vocal_lf + cat + mix")
    // 3-formant 모음 (F3 추가 → 자연도 UP)
    let _ = save(pipe3(vocal_lf(180.0, 0.5, 350), 800.0, 1200.0, 2600.0, 6.0), CORPUS_B + "/3F_a.wav")
    let _ = save(pipe3(vocal_lf(180.0, 0.5, 350), 300.0, 2300.0, 3100.0, 7.0), CORPUS_B + "/3F_i.wav")
    let _ = save(pipe3(vocal_lf(180.0, 0.5, 350), 350.0, 700.0, 2400.0, 7.0), CORPUS_B + "/3F_u.wav")
    // diphthong (formant glide)
    let _ = save(pipe_glide(vocal_lf(180.0, 0.5, 450), 800.0, 1200.0, 300.0, 2300.0, 6.0), CORPUS_B + "/glide_a_i.wav")
    let _ = save(pipe_glide(vocal_lf(180.0, 0.5, 450), 800.0, 1200.0, 350.0, 700.0, 6.0), CORPUS_B + "/glide_a_u.wav")
    // voiced fricative (mix)
    let _ = save(mix(vocal_lf(150.0, 0.35, 200), breath(2000.0, 5000.0, 0.25, 200)), CORPUS_B + "/voiced_z.wav")
    // "사" via cat (unvoiced fric + vowel)
    let _ = save(cat(breath(4000.0, 8000.0, 0.30, 80), pipe3(vocal_lf(180.0, 0.4, 280), 800.0, 1200.0, 2600.0, 6.0)), CORPUS_B + "/syl_sa_manual.wav")
    print("  -> " + CORPUS_B + " (7 WAV)")

    // ═══ Phase C: phone helper — CV syllables ══════════
    // ═══ Phase D: hive 공리 기반 ═══════════════════════
    let CORPUS_D = "/Users/ghost/core/anima/anima-speak/corpus/axioms"
    print("[Phase D] hive 공리 적용 — consonance / egyptian / banach reverb")
    let _ = save(consonance(220.0, 0.4, 500), CORPUS_D + "/consonance_4_3.wav")
    let _ = save(axiom_chord(180.0, 600), CORPUS_D + "/egyptian_chord.wav")
    let dry = phone_vowel("a", 180.0, 350)
    let _ = save(reverb_axiom(dry), CORPUS_D + "/reverb_banach_psi.wav")
    let _ = save(reverb(dry, 0.5, 0.7), CORPUS_D + "/reverb_long.wav")
    print("  -> " + CORPUS_D + " (4 WAV)")

    print("[Phase C] phone helper — 모음 8개 + CV 음절 5개")
    let _ = save(phone_vowel("a",  180.0, 300), CORPUS_C + "/v_a.wav")
    let _ = save(phone_vowel("eo", 180.0, 300), CORPUS_C + "/v_eo.wav")
    let _ = save(phone_vowel("o",  180.0, 300), CORPUS_C + "/v_o.wav")
    let _ = save(phone_vowel("u",  180.0, 300), CORPUS_C + "/v_u.wav")
    let _ = save(phone_vowel("eu", 180.0, 300), CORPUS_C + "/v_eu.wav")
    let _ = save(phone_vowel("i",  180.0, 300), CORPUS_C + "/v_i.wav")
    let _ = save(phone_vowel("ae", 180.0, 300), CORPUS_C + "/v_ae.wav")
    let _ = save(phone_vowel("e",  180.0, 300), CORPUS_C + "/v_e.wav")
    let _ = save(phone_syllable("s",  "a",  180.0, 350), CORPUS_C + "/syl_sa.wav")
    let _ = save(phone_syllable("sh", "i",  180.0, 350), CORPUS_C + "/syl_shi.wav")
    let _ = save(phone_syllable("ch", "a",  180.0, 350), CORPUS_C + "/syl_cha.wav")
    let _ = save(phone_syllable("h",  "a",  180.0, 350), CORPUS_C + "/syl_ha.wav")
    let _ = save(phone_syllable("",   "i",  180.0, 300), CORPUS_C + "/syl_bare_i.wav")
    print("  -> " + CORPUS_C + " (13 WAV)")

    // ═══ Phase E: spectral 원자 + 크로스페이드 + 균일화 ═══════
    let CORPUS_E = "/Users/ghost/core/anima/anima-speak/corpus/spectral"
    print("[Phase E] tone + lpf/hpf + fade + normalize")
    // pure tones (harmonic X)
    let _ = save(tone_axiom(220.0, 400), CORPUS_E + "/tone_220.wav")
    let _ = save(tone_axiom(440.0, 400), CORPUS_E + "/tone_440.wav")
    let _ = save(tone_axiom(880.0, 400), CORPUS_E + "/tone_880.wav")
    // lpf / hpf on breath (marcation)
    let breath_raw = breath(500.0, 7000.0, 0.5, 250)
    let _ = save(lpf_axiom(breath_raw),  CORPUS_E + "/breath_lpf1k.wav")     // soft (1k)
    let _ = save(hpf_axiom(breath_raw),  CORPUS_E + "/breath_hpf1.5k.wav")   // sibilant (1.5k)
    // lpf / hpf on vocal — "muffled" vs "bright"
    let vox = vocal_lf(180.0, 0.5, 300)
    let _ = save(lpf(vox, 600.0, 4),   CORPUS_E + "/vocal_muffled.wav")
    let _ = save(hpf(vox, 1800.0, 4),  CORPUS_E + "/vocal_thin.wav")
    // fade crossfade between two 3F vowels
    let va = pipe3(vocal_lf(200.0, 0.5, 280), 800.0, 1200.0, 2600.0, 6.0)
    let vi = pipe3(vocal_lf(200.0, 0.5, 280), 300.0, 2300.0, 3100.0, 6.0)
    let _ = save(fade_axiom(va, vi), CORPUS_E + "/xfade_a_to_i.wav")
    let vu = pipe3(vocal_lf(200.0, 0.5, 280), 350.0, 700.0, 2400.0, 6.0)
    let _ = save(fade_axiom(va, vu), CORPUS_E + "/xfade_a_to_u.wav")
    // normalize — different amplitudes → same peak
    let _ = save(normalize_axiom(vocal_lf(220.0, 0.95, 300)), CORPUS_E + "/norm_from_loud.wav")
    let _ = save(normalize_axiom(vocal_lf(220.0, 0.08, 300)), CORPUS_E + "/norm_from_quiet.wav")
    print("  -> " + CORPUS_E + " (10 WAV)")

    // ═══ Phase F: chirp (sweep) + meter (self-measure) ════════
    let CORPUS_F = "/Users/ghost/core/anima/anima-speak/corpus/chirps"
    print("[Phase F] chirp (sweep) + meter (self-measure)")
    let up   = chirp_axiom(100.0,  2000.0, 500)      // 상승 swoop
    let down = chirp_axiom(2000.0, 100.0,  500)      // 하강 swoop
    let flat = chirp_axiom(440.0,  440.0,  400)      // 정지 (= tone)
    let sirene = cat(chirp_axiom(400.0, 1200.0, 300), chirp_axiom(1200.0, 400.0, 300))
    let _ = save(up,     CORPUS_F + "/chirp_up.wav")
    let _ = save(down,   CORPUS_F + "/chirp_down.wav")
    let _ = save(flat,   CORPUS_F + "/chirp_flat.wav")
    let _ = save(sirene, CORPUS_F + "/chirp_sirene.wav")
    print("  -> " + CORPUS_F + " (4 WAV)")
    // meter: anima 자기 측정 — Phase E spectral corpus 일부 재측정
    print("  meter (self-measure on Phase E outputs):")
    print("    tone_440         : " + meter("/Users/ghost/core/anima/anima-speak/corpus/spectral/tone_440.wav"))
    print("    breath_lpf1k     : " + meter("/Users/ghost/core/anima/anima-speak/corpus/spectral/breath_lpf1k.wav"))
    print("    breath_hpf1.5k   : " + meter("/Users/ghost/core/anima/anima-speak/corpus/spectral/breath_hpf1.5k.wav"))
    print("    norm_from_loud   : " + meter("/Users/ghost/core/anima/anima-speak/corpus/spectral/norm_from_loud.wav"))
    print("    norm_from_quiet  : " + meter("/Users/ghost/core/anima/anima-speak/corpus/spectral/norm_from_quiet.wav"))
    print("    chirp_up         : " + meter(up))
    print("    chirp_sirene     : " + meter(sirene))

    // ═══ Phase G: 공리 정확 organ — P₂=28 + echo + tremolo + mains_hum + 48 lattice ══
    let CORPUS_G = "/Users/ghost/core/anima/anima-speak/corpus/axiom_exact"
    print("[Phase G] P₂=28 harmonic + echo/tremolo + sf-ufo mains + σ·τ=48 ouroboros")
    // P₂ = 28 harmonic-cap source (self_reference_closure_28)
    let _ = save(harmonic_28_axiom(180.0, 400), CORPUS_G + "/h28_180.wav")
    let _ = save(harmonic_28_axiom(220.0, 400), CORPUS_G + "/h28_220.wav")
    // sf-ufo mains hum (σ·sopfr = 60 Hz, BT-62 grid)
    let _ = save(mains_hum(800), CORPUS_G + "/mains_60hz.wav")
    // echo organ — banach 1/3 feedback × n·10 ms tap
    let v_a = pipe3(vocal_lf(180.0, 0.5, 250), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(echo_axiom(v_a), CORPUS_G + "/echo_a.wav")
    let _ = save(echo(v_a, 120, 0.6), CORPUS_G + "/echo_a_long.wav")
    // tremolo organ — n=6 Hz LFO × Ψ=0.5 depth
    let _ = save(tremolo_axiom(harmonic_28_axiom(220.0, 600)), CORPUS_G + "/tremolo_h28.wav")
    let _ = save(tremolo(v_a, 12.0, 0.8), CORPUS_G + "/tremolo_fast.wav")
    // σ·τ = 48 ouroboros lattice — 48 pitch frames in one phrase
    // (chirp_axiom 1 step 마다 σ·τ/n=8 ms · n=6 회 자기 회귀 → 총 48 frame)
    let lattice_a = chirp_axiom(220.0, 440.0, 250)
    let lattice_b = chirp_axiom(440.0, 220.0, 250)
    let lattice_step = fade_axiom(lattice_a, lattice_b)        // 1 ouroboros cycle
    let cycle2 = fade_axiom(lattice_step, lattice_step)        // 2 cycles
    let cycle3 = fade_axiom(cycle2, lattice_step)              // 3 cycles  (≈ 48-frame envelope)
    let _ = save(cycle3, CORPUS_G + "/ouroboros_48.wav")
    print("  -> " + CORPUS_G + " (8 WAV)")
    // 공리 정확 검증 — meter
    print("  meter (axiom-exact verification):")
    print("    h28_180        : " + meter(CORPUS_G + "/h28_180.wav"))
    print("    mains_60hz     : " + meter(CORPUS_G + "/mains_60hz.wav"))
    print("    echo_a (1/3 fb): " + meter(CORPUS_G + "/echo_a.wav"))
    print("    tremolo_h28    : " + meter(CORPUS_G + "/tremolo_h28.wav"))
    print("    ouroboros_48   : " + meter(CORPUS_G + "/ouroboros_48.wav"))

    // ═══ Phase H: loss/ufo.txt — milestone-sparse harmonic stack ══════
    let CORPUS_H = "/Users/ghost/core/anima/anima-speak/corpus/milestone"
    print("[Phase H] harmonic_milestone (sparse 8-axiom k stack)")
    // base_constant_set + derived 만 활성화한 sparse harmonic
    let _ = save(harmonic_milestone_axiom(110.0, 600), CORPUS_H + "/milestone_110.wav")
    let _ = save(harmonic_milestone_axiom(180.0, 600), CORPUS_H + "/milestone_180.wav")
    let _ = save(harmonic_milestone_axiom(220.0, 600), CORPUS_H + "/milestone_220.wav")
    // dense vs sparse 대비 — 같은 f0
    let _ = save(harmonic_28_axiom(180.0, 600),        CORPUS_H + "/dense_28_180.wav")
    let _ = save(harmonic_milestone_axiom(180.0, 600), CORPUS_H + "/sparse_8_180.wav")
    print("  -> " + CORPUS_H + " (5 WAV)")
    print("  meter (milestone vs dense):")
    print("    dense_28_180 : " + meter(CORPUS_H + "/dense_28_180.wav"))
    print("    sparse_8_180 : " + meter(CORPUS_H + "/sparse_8_180.wav"))

    // ═══ Phase I: 학문적 noise/pitch — pink noise + vibrato ═══════
    let CORPUS_I = "/Users/ghost/core/anima/anima-speak/corpus/scholarly"
    print("[Phase I] noise_pink (1/f) + vibrato (pitch LFO)")
    let _ = save(noise_pink_axiom(800),                      CORPUS_I + "/pink_800.wav")
    let _ = save(noise_pink(0.7, 600),                       CORPUS_I + "/pink_louder.wav")
    let v_a = pipe3(vocal_lf(220.0, 0.5, 600), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(vibrato_axiom(v_a),                         CORPUS_I + "/vibrato_subtle.wav")
    let _ = save(vibrato(v_a, 5.0, 50.0),                    CORPUS_I + "/vibrato_strong.wav")
    let _ = save(vibrato(harmonic_28_axiom(220.0, 600), 6.0, 30.0), CORPUS_I + "/vibrato_h28.wav")
    print("  -> " + CORPUS_I + " (5 WAV)")
    print("  meter:")
    print("    pink_800       : " + meter(CORPUS_I + "/pink_800.wav"))
    print("    vibrato_subtle : " + meter(CORPUS_I + "/vibrato_subtle.wav"))

    // ═══ Phase J: brown noise + square wave + comb filter ═══════
    let CORPUS_J = "/Users/ghost/core/anima/anima-speak/corpus/wave_family"
    print("[Phase J] noise_brown (φ=2) + square_wave (odd k) + comb (FIR)")
    let _ = save(noise_brown_axiom(800),                CORPUS_J + "/brown_800.wav")
    let _ = save(square_axiom(220.0, 400),              CORPUS_J + "/square_220.wav")
    let _ = save(square_axiom(110.0, 400),              CORPUS_J + "/square_110.wav")
    // wave family 비교 — 같은 220 Hz
    let _ = save(vocal(220.0, 0.5, 400),                CORPUS_J + "/saw_220.wav")     // sawtooth (all k)
    let _ = save(square_axiom(220.0, 400),              CORPUS_J + "/sq_220.wav")      // odd k only
    let _ = save(tone_axiom(220.0, 400),                CORPUS_J + "/sin_220.wav")     // k=1 only
    // comb on vocal — spectral comb 효과
    let v_a = pipe3(vocal_lf(220.0, 0.5, 400), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(comb_axiom(v_a),                       CORPUS_J + "/comb_a.wav")
    let _ = save(comb(v_a, 5, 0.7),                     CORPUS_J + "/comb_a_short.wav")
    print("  -> " + CORPUS_J + " (8 WAV)")
    print("  meter:")
    print("    brown_800   : " + meter(CORPUS_J + "/brown_800.wav"))
    print("    square_220  : " + meter(CORPUS_J + "/square_220.wav"))
    print("    comb_a      : " + meter(CORPUS_J + "/comb_a.wav"))

    // ═══ Phase K: triangle + clip + ring_mod + adsr ════════════
    let CORPUS_K = "/Users/ghost/core/anima/anima-speak/corpus/nonlinear"
    print("[Phase K] triangle + clip (tanh) + ring_mod + adsr (4-segment)")
    let _ = save(triangle_axiom(220.0, 400),         CORPUS_K + "/triangle_220.wav")
    let _ = save(triangle_axiom(440.0, 400),         CORPUS_K + "/triangle_440.wav")
    // clip — tone + drive 변화
    let pure_t = tone_axiom(220.0, 400)
    let _ = save(clip(pure_t, 1.0),                  CORPUS_K + "/clip_drive_1.wav")    // 거의 linear
    let _ = save(clip_axiom(pure_t),                 CORPUS_K + "/clip_axiom_tau4.wav") // mild
    let _ = save(clip(pure_t, 20.0),                 CORPUS_K + "/clip_drive_20.wav")   // heavy
    // ring_mod — vocal × 60Hz carrier (sf-ufo)
    let v_a = pipe3(vocal_lf(220.0, 0.5, 400), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(ring_mod_axiom(v_a),                CORPUS_K + "/ring_60hz.wav")
    let _ = save(ring_mod(v_a, 220.0),               CORPUS_K + "/ring_220hz.wav")     // 동조
    let _ = save(ring_mod(v_a, 1234.0),              CORPUS_K + "/ring_1234hz.wav")    // 비동조
    // adsr — 길이 다양
    let _ = save(adsr_axiom(triangle_axiom(440.0, 800)), CORPUS_K + "/adsr_axiom.wav")
    let _ = save(adsr(triangle_axiom(440.0, 800), 200, 100, 0.3, 200), CORPUS_K + "/adsr_long.wav")
    print("  -> " + CORPUS_K + " (10 WAV)")
    print("  meter:")
    print("    triangle_220 : " + meter(CORPUS_K + "/triangle_220.wav"))
    print("    clip_drive_20: " + meter(CORPUS_K + "/clip_drive_20.wav"))
    print("    ring_60hz    : " + meter(CORPUS_K + "/ring_60hz.wav"))
    print("    adsr_axiom   : " + meter(CORPUS_K + "/adsr_axiom.wav"))

    // ═══ Phase L: digital quantize + FM synthesis + blue noise ═════
    let CORPUS_L = "/Users/ghost/core/anima/anima-speak/corpus/digital_fm"
    print("[Phase L] bit_crush + fm_synth (Bessel) + noise_blue (+√f)")
    let _ = save(noise_blue_axiom(800),                    CORPUS_L + "/blue_800.wav")
    // FM synth — φ:1 ratio (axiom)
    let _ = save(fm_synth_axiom(220.0, 600),               CORPUS_L + "/fm_220_phi.wav")
    let _ = save(fm_synth(440.0, 110.0, 5.0, AX_PSI, 600), CORPUS_L + "/fm_440_4to1_I5.wav")  // ratio 4:1
    let _ = save(fm_synth(220.0, 220.0, 2.0, AX_PSI, 600), CORPUS_L + "/fm_220_1to1_I2.wav")  // ratio 1:1
    // bit_crush — depth 다양
    let v_a = pipe3(vocal_lf(220.0, 0.5, 400), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(bit_crush(v_a, 16),                       CORPUS_L + "/bc_16bit.wav")     // full
    let _ = save(bit_crush(v_a, 8),                        CORPUS_L + "/bc_8bit.wav")
    let _ = save(bit_crush_axiom(v_a),                     CORPUS_L + "/bc_sopfr_5bit.wav") // axiom
    let _ = save(bit_crush(v_a, 2),                        CORPUS_L + "/bc_2bit.wav")      // extreme
    print("  -> " + CORPUS_L + " (8 WAV)")
    print("  meter:")
    print("    blue_800        : " + meter(CORPUS_L + "/blue_800.wav"))
    print("    fm_220_phi      : " + meter(CORPUS_L + "/fm_220_phi.wav"))
    print("    bc_sopfr_5bit   : " + meter(CORPUS_L + "/bc_sopfr_5bit.wav"))

    // ═══ Phase M: 학문 reference — white + reverse + all_pass ═══════
    let CORPUS_M = "/Users/ghost/core/anima/anima-speak/corpus/reference"
    print("[Phase M] noise_white (flat) + reverse (time reversal) + all_pass (Schroeder)")
    let _ = save(noise_white_axiom(800),                  CORPUS_M + "/white_800.wav")
    // reverse — sirene chirp 의 reverse
    let sweep_up = chirp_axiom(100.0, 2000.0, 500)
    let _ = save(reverse(sweep_up),                       CORPUS_M + "/reverse_sweep.wav")
    let v_a = pipe3(vocal_lf(220.0, 0.5, 400), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(reverse(v_a),                            CORPUS_M + "/reverse_a.wav")
    // all_pass — magnitude flat, phase only
    let _ = save(all_pass_axiom(v_a),                     CORPUS_M + "/allpass_axiom.wav")
    let _ = save(all_pass(v_a, 20, 0.7),                  CORPUS_M + "/allpass_short.wav")
    // 학문 비교 demo: 4 noise color in one file (cat)
    let n4 = cat(cat(noise_white_axiom(300), noise_pink_axiom(300)),
                 cat(noise_brown_axiom(300), noise_blue_axiom(300)))
    let _ = save(n4, CORPUS_M + "/noise_4color.wav")
    print("  -> " + CORPUS_M + " (6 WAV)")
    print("  meter:")
    print("    white_800       : " + meter(CORPUS_M + "/white_800.wav"))
    print("    reverse_sweep   : " + meter(CORPUS_M + "/reverse_sweep.wav"))
    print("    allpass_axiom   : " + meter(CORPUS_M + "/allpass_axiom.wav"))

    // ═══ Phase N: parametric EQ — dc_block + low/high shelf ═══════
    let CORPUS_N = "/Users/ghost/core/anima/anima-speak/corpus/eq"
    print("[Phase N] dc_block (5Hz HPF) + low_shelf + high_shelf (RBJ)")
    let v_a = pipe3(vocal_lf(220.0, 0.5, 400), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(dc_block(v_a),                           CORPUS_N + "/dcblock_a.wav")
    let _ = save(low_shelf_axiom(v_a),                    CORPUS_N + "/lshelf_axiom.wav")     // +6dB <1k
    let _ = save(low_shelf(v_a, 500.0, 0.0 - 12.0),       CORPUS_N + "/lshelf_cut12.wav")     // -12dB
    let _ = save(high_shelf_axiom(v_a),                   CORPUS_N + "/hshelf_axiom.wav")     // +6dB >1.5k
    let _ = save(high_shelf(v_a, 2000.0, 12.0),           CORPUS_N + "/hshelf_boost12.wav")
    // shelf cascade — warm + bright voice
    let _ = save(high_shelf_axiom(low_shelf_axiom(v_a)),  CORPUS_N + "/shelves_warm_bright.wav")
    print("  -> " + CORPUS_N + " (6 WAV)")
    print("  meter:")
    print("    dcblock_a            : " + meter(CORPUS_N + "/dcblock_a.wav"))
    print("    lshelf_axiom (+6dB)  : " + meter(CORPUS_N + "/lshelf_axiom.wav"))
    print("    hshelf_axiom (+6dB)  : " + meter(CORPUS_N + "/hshelf_axiom.wav"))

    // ═══ Phase O: violet noise + flanger + am_mod ═══════════════
    let CORPUS_O = "/Users/ghost/core/anima/anima-speak/corpus/final"
    print("[Phase O] noise_violet (f²) + flanger (LFO comb) + am_mod (DSB-LC)")
    let _ = save(noise_violet_axiom(800),                CORPUS_O + "/violet_800.wav")
    let v_a = pipe3(vocal_lf(220.0, 0.5, 800), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(flanger_axiom(v_a),                     CORPUS_O + "/flanger_axiom.wav")
    let _ = save(flanger(v_a, 8.0, 5.0, 1.0),            CORPUS_O + "/flanger_strong.wav")
    let _ = save(am_mod_axiom(v_a),                      CORPUS_O + "/am_60hz_psi.wav")
    let _ = save(am_mod(v_a, 200.0, 1.0),                CORPUS_O + "/am_200hz_full.wav")
    // 6 noise color cat 시연 (white→pink→brown→blue→violet→silence)
    let n6 = cat(cat(cat(noise_white_axiom(250), noise_pink_axiom(250)),
                     cat(noise_brown_axiom(250), noise_blue_axiom(250))),
                 cat(noise_violet_axiom(250), silence(250)))
    let _ = save(n6, CORPUS_O + "/noise_6color.wav")
    print("  -> " + CORPUS_O + " (6 WAV)")
    print("  meter:")
    print("    violet_800   : " + meter(CORPUS_O + "/violet_800.wav"))
    print("    flanger_axiom: " + meter(CORPUS_O + "/flanger_axiom.wav"))
    print("    am_60hz_psi  : " + meter(CORPUS_O + "/am_60hz_psi.wav"))

    // ═══ Phase P: chorus + rectify + gate ═══════════════════════
    let CORPUS_P = "/Users/ghost/core/anima/anima-speak/corpus/dynamic"
    print("[Phase P] chorus (3-voice detune) + rectify (|x|) + gate (threshold)")
    let v_a = pipe3(vocal_lf(220.0, 0.5, 600), 800.0, 1200.0, 2600.0, 6.0)
    let _ = save(chorus(v_a),                     CORPUS_P + "/chorus_a.wav")
    let pure_t = tone_axiom(220.0, 400)
    let _ = save(rectify(pure_t),                 CORPUS_P + "/rectify_220.wav")  // → 440 dominant
    let _ = save(rectify(triangle_axiom(220.0, 400)), CORPUS_P + "/rectify_tri.wav")
    let mixed = mix(v_a, gain(noise_white_axiom(600), 0.05))
    let _ = save(gate_axiom(mixed),               CORPUS_P + "/gate_axiom.wav")    // -24dB
    let _ = save(gate(mixed, 0.0 - 12.0),         CORPUS_P + "/gate_strong.wav")
    print("  -> " + CORPUS_P + " (5 WAV)")
    print("  meter:")
    print("    chorus_a       : " + meter(CORPUS_P + "/chorus_a.wav"))
    print("    rectify_220    : " + meter(CORPUS_P + "/rectify_220.wav"))
    print("    gate_axiom     : " + meter(CORPUS_P + "/gate_axiom.wav"))

    // ═══ Phase Q: compressor + limiter + saturate_asinh ═══════════
    let CORPUS_Q = "/Users/ghost/core/anima/anima-speak/corpus/dynamics2"
    print("[Phase Q] compressor + limiter + saturate_asinh")
    let v_a = pipe3(vocal_lf(220.0, 0.5, 600), 800.0, 1200.0, 2600.0, 6.0)
    // dynamic 처리 비교
    let _ = save(compressor_axiom(v_a),               CORPUS_Q + "/comp_axiom.wav")    // -24/τ:1
    let _ = save(compressor(v_a, 0.0 - 12.0, 8.0),    CORPUS_Q + "/comp_8to1.wav")
    let _ = save(limiter(v_a),                        CORPUS_Q + "/limiter.wav")
    // saturation 비교 — clip(tanh) vs asinh
    let pure_t = tone_axiom(220.0, 400)
    let _ = save(clip(pure_t, 4.0),                   CORPUS_Q + "/sat_tanh_4.wav")
    let _ = save(saturate_asinh_axiom(pure_t),        CORPUS_Q + "/sat_asinh_axiom.wav")
    let _ = save(saturate_asinh(pure_t, 20.0),        CORPUS_Q + "/sat_asinh_20.wav")
    print("  -> " + CORPUS_Q + " (6 WAV)")
    print("  meter:")
    print("    comp_axiom (-24/τ:1) : " + meter(CORPUS_Q + "/comp_axiom.wav"))
    print("    limiter (-2/100:1)   : " + meter(CORPUS_Q + "/limiter.wav"))
    print("    sat_asinh_axiom      : " + meter(CORPUS_Q + "/sat_asinh_axiom.wav"))

    print("")
    print("done. total 117 WAV across 17 phases.")
}
