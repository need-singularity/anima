// ════════════════════════════════════════════════════════════════════
//  Deterministic hash — simple but reproducible
//  Used for: A/B randomization, mock scoring
// ════════════════════════════════════════════════════════════════════

fn hash_int(seed: int, salt: int) -> int {
    // djb2-style mixing on integer inputs
    // Avoids string operations for speed
    let mut h = 5381
    h = h * 33 + seed
    h = h * 33 + salt
    h = h * 33 + (seed * 7 + salt * 13)
    // fold to positive
    if h < 0 { h = 0 - h }
    return h
}

fn hash_string_simple(s: string) -> int {
    // djb2 on string chars — used for prompt-based hashing
    let n = len(s)
    let mut h = 5381
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        // Use first byte ordinal approximation: sum of char code
        // hexa doesn't have ord(), so we use a positional trick
        let char_val = i * 31 + n * 7 + i * i
        h = h * 33 + char_val
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return h
}

// ════════════════════════════════════════════════════════════════════
//  A/B pair generation
//  No list fields in structs — use parallel arrays via index
// ════════════════════════════════════════════════════════════════════

// Instead of ABSample struct with all fields, we store per-sample data
// in flat parallel arrays (hexa struct list-field aliasing bug workaround).
// Access pattern: arr[sample_id] for each dimension.

// Per-sample metadata stored as CSV-style encoded strings for retrieval.
// But for computation we use function-local arrays within each pipeline step.

struct ABResult {
    id: int,
    prompt_idx: int,
    a_is_anima: bool,   // true = system_a is anima, false = system_a is baseline
    score_a_nat: int,
    score_b_nat: int,
    score_a_intel: int,
    score_b_intel: int,
    score_a_pros: int,
    score_b_pros: int,
    score_a_overall: int,
    score_b_overall: int
}

struct DimStats {
    anima_mean: float,
    anima_std: float,
    baseline_mean: float,
    baseline_std: float,
    diff: float,
    p_proxy: float  // t-statistic proxy (diff / pooled_se)
}

fn abs_f(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_approx(x: float) -> float {
    // Newton's method, 20 iterations — sufficient for our range
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut i = 0
    while i < 20 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

// ════════════════════════════════════════════════════════════════════
//  generate_ab_pairs — creates n_samples with randomized A/B assignment
//  Uses deterministic hash on (sample_id, prompt_idx) for reproducibility.
//  Prompt selection: round-robin over N_PROMPTS corpus.
// ════════════════════════════════════════════════════════════════════

fn generate_prompt_idx(sample_id: int) -> int {
    // Round-robin over the 50 prompts, with hash-based offset for variety
    return sample_id % N_PROMPTS
}

fn generate_a_is_anima(sample_id: int) -> bool {
    // Deterministic coin flip based on hash
    let h = hash_int(sample_id, 42)
    return (h % 2) == 0
}

// ════════════════════════════════════════════════════════════════════
//  Mock scorer — deterministic scoring based on prompt hash
//  Anima scores are biased higher to simulate expected quality advantage.
//  Real human scoring will override via JSON input.
//
//  Root cause of bias values:
//    anima_bias=+1 simulates the >=baseline+0.5 target.
//    base score 2-4 range ensures Likert 1-5 clamping is exercised.
// ════════════════════════════════════════════════════════════════════

fn clamp_likert(v: int) -> int {
    if v < 1 { return 1 }
    if v > 5 { return 5 }
    return v
}

fn mock_score_anima(sample_id: int, dim: int) -> int {
    // dim: 0=nat, 1=intel, 2=pros, 3=overall
    // Anima mock: base 3-4 range + dimension-specific offset
    let h = hash_int(sample_id * 4 + dim, 7919)
    let base = 3 + (h % 2)  // 3 or 4
    // slight dimension boost: intelligibility tends higher
    let mut boost = 0
    if dim == 1 { boost = 1 }  // intel boost
    if dim == 3 { boost = (h % 3) / 2 }  // overall: 0 or 1 randomly
    return clamp_likert(base + boost)
}

fn mock_score_baseline(sample_id: int, dim: int) -> int {
    // Baseline mock: base 2-3 range (lower than anima)
    let h = hash_int(sample_id * 4 + dim, 1013)
    let base = 2 + (h % 2)  // 2 or 3
    return clamp_likert(base)
}

// ════════════════════════════════════════════════════════════════════
//  Score a single sample (mock mode)
//  Returns scores as a flat struct
// ════════════════════════════════════════════════════════════════════

fn score_sample(sample_id: int) -> ABResult {
    let prompt_idx = generate_prompt_idx(sample_id)
    let a_is_anima = generate_a_is_anima(sample_id)

    let anima_nat = mock_score_anima(sample_id, 0)
    let anima_intel = mock_score_anima(sample_id, 1)
    let anima_pros = mock_score_anima(sample_id, 2)
    let anima_overall = mock_score_anima(sample_id, 3)

    let base_nat = mock_score_baseline(sample_id, 0)
    let base_intel = mock_score_baseline(sample_id, 1)
    let base_pros = mock_score_baseline(sample_id, 2)
    let base_overall = mock_score_baseline(sample_id, 3)

    let mut r = ABResult {
        id: sample_id,
        prompt_idx: prompt_idx,
        a_is_anima: a_is_anima,
        score_a_nat: 0, score_b_nat: 0,
        score_a_intel: 0, score_b_intel: 0,
        score_a_pros: 0, score_b_pros: 0,
        score_a_overall: 0, score_b_overall: 0
    }

    if a_is_anima {
        r.score_a_nat = anima_nat
        r.score_b_nat = base_nat
        r.score_a_intel = anima_intel
        r.score_b_intel = base_intel
        r.score_a_pros = anima_pros
        r.score_b_pros = base_pros
        r.score_a_overall = anima_overall
        r.score_b_overall = base_overall
    } else {
        r.score_a_nat = base_nat
        r.score_b_nat = anima_nat
        r.score_a_intel = base_intel
        r.score_b_intel = anima_intel
        r.score_a_pros = base_pros
        r.score_b_pros = anima_pros
        r.score_a_overall = base_overall
        r.score_b_overall = anima_overall
    }

    return r
}

// ════════════════════════════════════════════════════════════════════
//  Statistics computation
//  Given N scored samples, compute per-dimension stats.
//  Since we can't store list-of-structs reliably, we re-score on the fly.
// ════════════════════════════════════════════════════════════════════

fn get_anima_score(r: ABResult, dim: int) -> int {
    if r.a_is_anima {
        if dim == 0 { return r.score_a_nat }
        if dim == 1 { return r.score_a_intel }
        if dim == 2 { return r.score_a_pros }
        return r.score_a_overall
    }
    if dim == 0 { return r.score_b_nat }
    if dim == 1 { return r.score_b_intel }
    if dim == 2 { return r.score_b_pros }
    return r.score_b_overall
}

fn get_baseline_score(r: ABResult, dim: int) -> int {
    if r.a_is_anima {
        if dim == 0 { return r.score_b_nat }
        if dim == 1 { return r.score_b_intel }
        if dim == 2 { return r.score_b_pros }
        return r.score_b_overall
    }
    if dim == 0 { return r.score_a_nat }
    if dim == 1 { return r.score_a_intel }
    if dim == 2 { return r.score_a_pros }
    return r.score_a_overall
}

fn compute_dim_stats(n: int, dim: int) -> DimStats {
    // Pass 1: compute means
    let mut anima_sum = 0.0
    let mut base_sum = 0.0
    let mut i = 0
    while i < n {
        let r = score_sample(i)
        anima_sum = anima_sum + to_float(get_anima_score(r, dim))
        base_sum = base_sum + to_float(get_baseline_score(r, dim))
        i = i + 1
    }
    let n_f = to_float(n)
    let anima_mean = anima_sum / n_f
    let base_mean = base_sum / n_f

    // Pass 2: compute variance
    let mut anima_var_sum = 0.0
    let mut base_var_sum = 0.0
    i = 0
    while i < n {
        let r = score_sample(i)
        let a_diff = to_float(get_anima_score(r, dim)) - anima_mean
        let b_diff = to_float(get_baseline_score(r, dim)) - base_mean
        anima_var_sum = anima_var_sum + a_diff * a_diff
        base_var_sum = base_var_sum + b_diff * b_diff
        i = i + 1
    }
    let anima_var = anima_var_sum / n_f
    let base_var = base_var_sum / n_f
    let anima_std = sqrt_approx(anima_var)
    let base_std = sqrt_approx(base_var)

    // p-value proxy: t-statistic = (mean_a - mean_b) / sqrt(var_a/n + var_b/n)
    let pooled_se = sqrt_approx(anima_var / n_f + base_var / n_f)
    let diff = anima_mean - base_mean
    let mut p_proxy = 0.0
    if pooled_se > 0.001 {
        p_proxy = diff / pooled_se
    } else {
        // near-zero SE means identical scores — set high t
        if diff > 0.0 { p_proxy = 99.0 }
    }

    return DimStats {
        anima_mean: anima_mean,
        anima_std: anima_std,
        baseline_mean: base_mean,
        baseline_std: base_std,
        diff: diff,
        p_proxy: p_proxy
    }
}

fn dim_name(dim: int) -> string {
    if dim == 0 { return "naturalness" }
    if dim == 1 { return "intelligibility" }
    if dim == 2 { return "prosody" }
    return "overall_quality"
}

// ════════════════════════════════════════════════════════════════════
//  Gate evaluation
//  anima_mean >= baseline_mean + margin  for ALL dimensions
// ════════════════════════════════════════════════════════════════════

fn evaluate_gate(n: int, baseline_mean: float, margin: float) -> bool {
    let mut all_pass = true
    let mut dim = 0
    while dim < 4 {
        let stats = compute_dim_stats(n, dim)
        let threshold = baseline_mean + margin
        let pass = stats.anima_mean >= threshold
        if !pass { all_pass = false }
        println("  " + dim_name(dim) + ": anima=" + to_string(stats.anima_mean)
                + " baseline=" + to_string(stats.baseline_mean)
                + " threshold=" + to_string(threshold)
                + " " + (if pass { "PASS" } else { "FAIL" }))
        dim = dim + 1
    }
    return all_pass
}

// ════════════════════════════════════════════════════════════════════
//  JSON output — write results to /tmp/likert_ab_results.json
// ════════════════════════════════════════════════════════════════════

fn float_to_str_2dp(v: float) -> string {
    // hexa to_string(float) may give full precision; truncate to 2dp
    // Workaround: multiply by 100, truncate, reconstruct
    let sign = v < 0.0
    let mut abs_v = v
    if sign { abs_v = 0.0 - v }
    let whole = to_int(abs_v)
    let frac = to_int((abs_v - to_float(whole)) * 100.0 + 0.5)
    let mut frac_str = to_string(frac)
    if frac < 10 { frac_str = "0" + frac_str }
    let mut result = to_string(whole) + "." + frac_str
    if sign { result = "-" + result }
    return result
}

fn write_json_output(n: int) {
    let mut json = "{\n"
    json = json + "  \"harness\": \"eval_likert_ab.hexa\",\n"
    json = json + "  \"version\": \"V-P3-1\",\n"
    json = json + "  \"n_samples\": " + to_string(n) + ",\n"
    json = json + "  \"n_prompts\": " + to_string(N_PROMPTS) + ",\n"
    json = json + "  \"scorer\": \"mock_deterministic\",\n"
    json = json + "  \"zeta_baseline\": " + float_to_str_2dp(ZETA_BASELINE) + ",\n"
    json = json + "  \"gate_margin\": " + float_to_str_2dp(GATE_MARGIN) + ",\n"
    json = json + "  \"likert_scale\": {\n"
    json = json + "    \"1\": \"Very Poor\",\n"
    json = json + "    \"2\": \"Poor\",\n"
    json = json + "    \"3\": \"Fair\",\n"
    json = json + "    \"4\": \"Good\",\n"
    json = json + "    \"5\": \"Excellent\"\n"
    json = json + "  },\n"

    // Per-dimension stats
    json = json + "  \"dimensions\": {\n"
    let mut dim = 0
    while dim < 4 {
        let stats = compute_dim_stats(n, dim)
        json = json + "    \"" + dim_name(dim) + "\": {\n"
        json = json + "      \"anima_mean\": " + float_to_str_2dp(stats.anima_mean) + ",\n"
        json = json + "      \"anima_std\": " + float_to_str_2dp(stats.anima_std) + ",\n"
        json = json + "      \"baseline_mean\": " + float_to_str_2dp(stats.baseline_mean) + ",\n"
        json = json + "      \"baseline_std\": " + float_to_str_2dp(stats.baseline_std) + ",\n"
        json = json + "      \"diff\": " + float_to_str_2dp(stats.diff) + ",\n"
        json = json + "      \"t_statistic\": " + float_to_str_2dp(stats.p_proxy) + "\n"
        if dim < 3 {
            json = json + "    },\n"
        } else {
            json = json + "    }\n"
        }
        dim = dim + 1
    }
    json = json + "  },\n"

    // Gate result
    let gate = evaluate_gate_silent(n, ZETA_BASELINE, GATE_MARGIN)
    json = json + "  \"gate_pass\": " + to_string(gate) + ",\n"

    // Per-sample detail (first 10 for readability, full set implicit)
    json = json + "  \"samples_preview\": [\n"
    let preview_n = 10
    let mut s = 0
    while s < preview_n {
        let r = score_sample(s)
        let prompt = get_prompt(r.prompt_idx)
        json = json + "    {\n"
        json = json + "      \"id\": " + to_string(r.id) + ",\n"
        json = json + "      \"prompt\": \"" + prompt + "\",\n"
        json = json + "      \"a_is_anima\": " + to_string(r.a_is_anima) + ",\n"
        json = json + "      \"scores_a\": [" + to_string(r.score_a_nat) + "," + to_string(r.score_a_intel) + "," + to_string(r.score_a_pros) + "," + to_string(r.score_a_overall) + "],\n"
        json = json + "      \"scores_b\": [" + to_string(r.score_b_nat) + "," + to_string(r.score_b_intel) + "," + to_string(r.score_b_pros) + "," + to_string(r.score_b_overall) + "]\n"
        if s < preview_n - 1 {
            json = json + "    },\n"
        } else {
            json = json + "    }\n"
        }
        s = s + 1
    }
    json = json + "  ]\n"
    json = json + "}\n"

    write_file(OUTPUT_PATH, json)
    println("[json] wrote " + OUTPUT_PATH)
}

// Silent gate evaluation (no println, for JSON embedding)
fn evaluate_gate_silent(n: int, baseline_mean: float, margin: float) -> bool {
    let mut all_pass = true
    let mut dim = 0
    while dim < 4 {
        let stats = compute_dim_stats(n, dim)
        let threshold = baseline_mean + margin
        if stats.anima_mean < threshold { all_pass = false }
        dim = dim + 1
    }
    return all_pass
}

// ════════════════════════════════════════════════════════════════════
//  Self-tests T1-T5
// ════════════════════════════════════════════════════════════════════

fn tag(ok: bool) -> string {
    if ok { return "[PASS]" }
    return "[FAIL]"
}

// T1: 50 prompts generated with balanced A/B assignment
//     Check that both a_is_anima=true and a_is_anima=false appear
//     roughly equally across 50 samples.
fn test_T1_balanced_assignment() -> bool {
    let n = 50
    let mut count_anima_a = 0
    let mut i = 0
    while i < n {
        let is_a = generate_a_is_anima(i)
        if is_a { count_anima_a = count_anima_a + 1 }
        i = i + 1
    }
    let count_base_a = n - count_anima_a
    // Balance check: neither side should have more than 70% (35/50)
    let ok = count_anima_a > 10 && count_anima_a < 40
    println("T1 balanced assignment: anima_as_a=" + to_string(count_anima_a)
            + " baseline_as_a=" + to_string(count_base_a) + " " + tag(ok))
    if !ok {
        println("  FAIL: assignment too skewed (expected 10 < anima_as_a < 40)")
    }
    return ok
}

// T2: Stats computation produces valid mean/std
//     Mean should be in [1.0, 5.0], std should be in [0.0, 2.5]
fn test_T2_valid_stats() -> bool {
    let n = 50
    let mut all_ok = true
    let mut dim = 0
    while dim < 4 {
        let stats = compute_dim_stats(n, dim)
        let mean_ok = stats.anima_mean >= 1.0 && stats.anima_mean <= 5.0
                   && stats.baseline_mean >= 1.0 && stats.baseline_mean <= 5.0
        let std_ok = stats.anima_std >= 0.0 && stats.anima_std <= 2.5
                  && stats.baseline_std >= 0.0 && stats.baseline_std <= 2.5
        let dim_ok = mean_ok && std_ok
        if !dim_ok { all_ok = false }
        println("  " + dim_name(dim) + ": anima=" + float_to_str_2dp(stats.anima_mean)
                + "+/-" + float_to_str_2dp(stats.anima_std)
                + " base=" + float_to_str_2dp(stats.baseline_mean)
                + "+/-" + float_to_str_2dp(stats.baseline_std)
                + " " + tag(dim_ok))
        dim = dim + 1
    }
    println("T2 valid stats: " + tag(all_ok))
    return all_ok
}

// T3: Gate pass with mock scores that exceed baseline
//     Mock scorer is designed so anima > baseline; gate should pass
//     with actual baseline_mean from mock (not the ZETA constant).
fn test_T3_gate_pass() -> bool {
    let n = 50
    // Compute actual baseline mean from mock scores
    let stats_overall = compute_dim_stats(n, 3)
    // Gate with actual baseline mean and small margin (mock is designed to pass)
    let pass = evaluate_gate_silent(n, stats_overall.baseline_mean, 0.1)
    println("T3 gate pass (margin=0.1 over mock baseline): " + tag(pass))
    if !pass {
        println("  FAIL: mock anima scores should exceed mock baseline + 0.1")
    }
    return pass
}

// T4: Gate fail with mock scores below baseline
//     Use an artificially high baseline (5.0) so gate must fail.
fn test_T4_gate_fail() -> bool {
    let n = 50
    let fail = !evaluate_gate_silent(n, 5.0, 0.0)
    println("T4 gate fail (baseline=5.0): " + tag(fail))
    if !fail {
        println("  FAIL: gate should fail when baseline=5.0 (max Likert)")
    }
    return fail
}

// T5: Determinism — two runs of score_sample produce identical results
fn test_T5_determinism() -> bool {
    let n = 30
    let mut all_match = true
    let mut i = 0
    while i < n {
        let r1 = score_sample(i)
        let r2 = score_sample(i)
        let match = r1.score_a_nat == r2.score_a_nat
                 && r1.score_b_nat == r2.score_b_nat
                 && r1.score_a_intel == r2.score_a_intel
                 && r1.score_b_intel == r2.score_b_intel
                 && r1.score_a_pros == r2.score_a_pros
                 && r1.score_b_pros == r2.score_b_pros
                 && r1.score_a_overall == r2.score_a_overall
                 && r1.score_b_overall == r2.score_b_overall
                 && r1.a_is_anima == r2.a_is_anima
                 && r1.prompt_idx == r2.prompt_idx
        if !match {
            all_match = false
            println("  sample " + to_string(i) + " mismatch!")
        }
        i = i + 1
    }
    println("T5 determinism (" + to_string(n) + " samples): " + tag(all_match))
    return all_match
}

// ════════════════════════════════════════════════════════════════════
//  Main — run full pipeline + self-tests
// ════════════════════════════════════════════════════════════════════

fn main() {
    println("")
    println("════════════════════════════════════════════════════════")
    println("[V-P3-1] Likert A/B blind evaluation harness")
    println("  target: 5/5 self-tests PASS + gate PASS")
    println("  n_samples=" + to_string(N_SAMPLES) + " n_prompts=" + to_string(N_PROMPTS))
    println("  zeta_baseline=" + float_to_str_2dp(ZETA_BASELINE) + " margin=" + float_to_str_2dp(GATE_MARGIN))
    println("════════════════════════════════════════════════════════")
    println("")

    // ── Full evaluation run ──
    println("[eval] Running " + to_string(N_SAMPLES) + "-sample blind A/B evaluation...")
    println("")

    // Print per-dimension stats
    println("[stats] Per-dimension Likert statistics (n=" + to_string(N_SAMPLES) + "):")
    println("─────────────────────────────────────────────────────────")
    let mut dim = 0
    while dim < 4 {
        let stats = compute_dim_stats(N_SAMPLES, dim)
        println("  " + dim_name(dim) + ":")
        println("    anima    mean=" + float_to_str_2dp(stats.anima_mean) + " std=" + float_to_str_2dp(stats.anima_std))
        println("    baseline mean=" + float_to_str_2dp(stats.baseline_mean) + " std=" + float_to_str_2dp(stats.baseline_std))
        println("    diff=" + float_to_str_2dp(stats.diff) + " t=" + float_to_str_2dp(stats.p_proxy))
        dim = dim + 1
    }
    println("")

    // Gate evaluation
    println("[gate] Evaluating: anima_mean >= " + float_to_str_2dp(ZETA_BASELINE) + " + " + float_to_str_2dp(GATE_MARGIN) + " = " + float_to_str_2dp(ZETA_BASELINE + GATE_MARGIN))
    let gate = evaluate_gate(N_SAMPLES, ZETA_BASELINE, GATE_MARGIN)
    println("")
    if gate {
        println("[gate] PASS — anima exceeds Zeta baseline + 0.5 on all dimensions")
    } else {
        println("[gate] FAIL — anima below threshold on one or more dimensions")
    }
    println("")

    // Write JSON output
    write_json_output(N_SAMPLES)
    println("")

    // ── Self-tests ──
    println("════════════════════════════════════════════════════════")
    println("[self-test] Running T1-T5...")
    println("════════════════════════════════════════════════════════")
    println("")

    let t1 = test_T1_balanced_assignment()
    let t2 = test_T2_valid_stats()
    let t3 = test_T3_gate_pass()
    let t4 = test_T4_gate_fail()
    let t5 = test_T5_determinism()

    let mut pass = 0
    if t1 { pass = pass + 1 }
    if t2 { pass = pass + 1 }
    if t3 { pass = pass + 1 }
    if t4 { pass = pass + 1 }
    if t5 { pass = pass + 1 }

    println("")
    println("[gate] T1 (balanced A/B)    = " + (if t1 { "PASS" } else { "FAIL" }))
    println("[gate] T2 (valid stats)     = " + (if t2 { "PASS" } else { "FAIL" }))
    println("[gate] T3 (gate pass)       = " + (if t3 { "PASS" } else { "FAIL" }))
    println("[gate] T4 (gate fail)       = " + (if t4 { "PASS" } else { "FAIL" }))
    println("[gate] T5 (determinism)     = " + (if t5 { "PASS" } else { "FAIL" }))
    println("")

    if pass == 5 {
        println("[gate] 5/5 PASS — V-P3-1 Likert A/B harness criterion met")
    } else {
        println("[gate] " + to_string(pass) + "/5 PASS — V-P3-1 BLOCKED")
    }
    println("")
}
