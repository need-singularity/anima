    if idx == 28 { return "다음 세대의 인공지능은 어떤 모습일까요?" }
    if idx == 29 { return "테스트 문장입니다. 모든 음소를 확인합니다." }
    // English prompts 30-49
    if idx == 30 { return "Hello, the weather is beautiful today." }
    if idx == 31 { return "What is consciousness? Let us think deeply about it." }
