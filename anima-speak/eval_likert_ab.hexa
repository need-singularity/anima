// anima-speak/eval_likert_ab.hexa — V-P3-1 Likert A/B blind evaluation harness
//
// Purpose:
//   100-sample blind A/B evaluation harness for anima-speak Mk.III voice quality.
//   Likert score target: >= Zeta baseline + 0.5
//
// Likert scale (5-point):
//   1=Very Poor, 2=Poor, 3=Fair, 4=Good, 5=Excellent
//
// Dimensions:
//   naturalness, intelligibility, prosody, overall_quality
//
// Pipeline:
//   generate_ab_pairs(n) -> randomized A/B assignment (deterministic hash)
//   compute_likert_stats(...)  -> mean, std, p-value proxy per dimension
//   evaluate_gate(...)         -> anima mean >= baseline + margin
//
// Prompts: 30 Korean + 20 English built-in (V-P3-2 Korean regression set)
//
// Mock scorer: deterministic hash-based scoring (for automated gate check).
//              Real human scoring overrides via JSON input.
//
// Output: /tmp/likert_ab_results.json
//
// Self-tests: T1-T5 (run at end)
//
// Hexa quirks:
//   - Standalone (no imports)
//   - No list fields in structs — parallel arrays indexed by sample id
//   - let mut, string type, stage0 auto-invokes main()
//
// Run:
//   hexa run anima-speak/eval_likert_ab.hexa
//
// Gate:
//   [gate] 5/5 PASS  -> V-P3-1 criterion met
//   [gate] <5 PASS   -> merge blocked

// ════════════════════════════════════════════════════════════════════
//  Constants
// ════════════════════════════════════════════════════════════════════

let OUTPUT_PATH = "/tmp/likert_ab_results.json"
let N_PROMPTS = 50    // 30 Korean + 20 English
let N_SAMPLES = 100   // default evaluation size
let ZETA_BASELINE = 3.2  // Zeta AI reference mean (estimated from public benchmarks)
let GATE_MARGIN = 0.5    // anima must beat baseline by this much

// Likert labels (for JSON output reference)
let LIKERT_1 = "Very Poor"
let LIKERT_2 = "Poor"
let LIKERT_3 = "Fair"
let LIKERT_4 = "Good"
let LIKERT_5 = "Excellent"

// ════════════════════════════════════════════════════════════════════
//  Prompt corpus — 30 Korean + 20 English
//  (same set used for V-P3-2 Korean regression testing)
// ════════════════════════════════════════════════════════════════════

