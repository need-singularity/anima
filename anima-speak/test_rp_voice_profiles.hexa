// anima-speak/test_rp_voice_profiles.hexa — TSRV-P3-1 / ZPHY-P2-1 standalone harness
//
// rp_voice_profiles.hexa 의 5/5 PASS gate 를 외부 driver 로 재확증한다.
// stage0 hexa 의 use "..." sibling import 가 flaky 한 환경에서는
// (memory: feedback_hexa_runtime, style_switch.hexa 에서도 같은 이유로 회피)
// hexa run 으로 직접 실행하고 stdout 의 PASS 마커를 카운트한다.
//
// 사용:
//   HEXA_LOCAL=1 hexa run anima-speak/test_rp_voice_profiles.hexa
//
// PASS 기준:
//   - hexa run rp_voice_profiles.hexa 의 stdout 에 "ALL 5/5 PASS" 마커 발견
//   - T1..T5 PASS 라인 카운트 = 5 (또는 println 더블 출력 환경 대응 10)

fn run_target() -> string {
    // R10/R14: hexa run 직접 호출 — local cache 사용을 위해 HEXA_LOCAL=1 설정.
    let cmd = "HEXA_LOCAL=1 " + "/Users/ghost/Dev/anima/shared/bin/hexa run "
            + "/Users/ghost/Dev/anima/anima-speak/rp_voice_profiles.hexa 2>&1"
    return exec(cmd).trim()
}

fn count_pass_lines(out: string) -> int {
    let lines = out.split("\n")
    let mut n = 0
    let mut i = 0
    let m = len(lines)
    while i < m {
        let ln = lines[i]
        if ln.index_of("T1 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T2 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T3 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T4 PASS") >= 0 { n = n + 1 }
        else if ln.index_of("T5 PASS") >= 0 { n = n + 1 }
        i = i + 1
    }
    return n
}

fn main() {
    println("[test_rp_voice_profiles] driving anima-speak/rp_voice_profiles.hexa")
    let out = run_target()
    println(out)
    println("--- analysis ---")
    let n_pass = count_pass_lines(out)
    println("T?-PASS line count = " + to_string(n_pass) + " / 5")
    let all_marker = out.index_of("ALL 5/5 PASS") >= 0
    println("ALL 5/5 marker present = " + to_string(all_marker))
    // hexa run 이 println 라인을 2회 출력하는 환경에서 n_pass 가 10 이 될
    // 수 있다. 5 의 배수이고 ALL 5/5 마커가 있으면 PASS 로 본다.
    let pass_ok = n_pass == 5 || n_pass == 10
    if pass_ok && all_marker {
        println("[test_rp_voice_profiles] HARNESS PASS — TSRV-P3-1 / ZPHY-P2-1 scaffold gate 5/5 통과")
    } else {
        println("[test_rp_voice_profiles] HARNESS FAIL")
    }
}

main()
