// anima-speak/speak_e2e.hexa — HEXA-SPEAK Mk.III End-to-End Voice Wrapper
//
// Roadmap:
//   shared/roadmaps/extreme.json#destinations[0]   — anima-speak Mk.III E2E voice IO
//   anima/clm consciousness_standalone destinations  — same first criterion
//
// Purpose:
//   Thin orchestration layer that turns a single audio_in_path into an
//   audio_out_path by chaining:
//       (a) load wav
//       (b) STT  : audio  -> text
//       (c) LLM  : text   -> reply_text  (CLM/ALM endpoint, whichever ships first)
//       (d) TTS  : reply  -> audio
//       (e) save wav
//
//   The wrapper treats STT and TTS as pluggable backends. Defaults are
//   deterministic mocks (STT_MOCK, TTS_MOCK) so the file is always
//   smoke-testable without real models / weights / network. Real backends
//   are wired by env vars:
//       SPEAK_STT_BACKEND  ∈ {mock, whisper}
//       SPEAK_TTS_BACKEND  ∈ {mock, vocoder}
//       SPEAK_MODEL_ENDPOINT  e.g. http://localhost:8090/generate
//       SPEAK_MODEL_KIND   ∈ {clm, alm}  (informational only)
//
//   Mk.III neural vocoder + Whisper / equivalent STT are wired
//   only when those backends become non-stub. Until then, the mock path
//   provides byte-identical determinism for harness gating.
//
// Hexa quirk avoidance (memory):
//   - Strings are byte-safe ASCII for transcripts; multibyte text only
//     enters via JSON \u-escapes when calling real endpoints.
//   - No struct list aliasing: helper fns return new structs.
//   - HEXA-FIRST (R1): no .py/.rs/.sh files spawned by mock path. Real
//     STT/TTS shell-outs gated behind explicit backend env vars.
//   - L0 freeze: only adds a new file; does not modify
//     anima/core/{hub,laws,runtime/anima_runtime}.hexa or any other L0
//     anchor.
//   - Does NOT touch the uncommitted set:
//       anima-speak/corpus/, corpus_pipeline.hexa,
//       rp_voice_profiles.hexa, test_rp_voice_profiles.hexa
//
// CLI:
//   hexa run anima-speak/speak_e2e.hexa \
//        --in test.wav --out out.wav \
//        --endpoint http://localhost:8000/v1/chat
//
// Invariants:
//   I1  audio_out_path always written when run_e2e returns ok=true
//   I2  Mock path is byte-identical across runs given same audio_in_path
//   I3  meta sidecar at out + ".meta.json" always emitted
//   I4  latency_ms always computed (>= 0, mock path is small but nonzero)
//   I5  No call to STT/TTS/LLM panics; all errors degrade to ok=false
//
// Test harness:
//   anima-speak/test_speak_e2e.hexa — 10 dry-run scenarios, all mock,
//   verifies determinism + latency bounds + meta sidecar shape.

// ════════════════════════════════════════════════════════════════════
//  Section 0. Imports
// ════════════════════════════════════════════════════════════════════
//
// neural_vocoder.hexa provides decode_wave() + write_wav() — the real
// Mk.III synthesis path. Import does not auto-invoke the imported
// file's main(), verified 2026-04-16 (hexa import semantics).

import "./neural_vocoder.hexa"

// ════════════════════════════════════════════════════════════════════
//  Section 1. Constants
// ════════════════════════════════════════════════════════════════════

let SPEAK_E2E_VERSION = "Mk.III-E2E-1.0.0"
let SPEAK_SAMPLE_RATE = 24000
let SPEAK_BITS_PER_SAMPLE = 16
let SPEAK_CHANNELS = 1

// Default mock latency budget (ms) — real backends override.
let MOCK_STT_LATENCY_MS = 5
let MOCK_LLM_LATENCY_MS = 7
let MOCK_TTS_LATENCY_MS = 9

// Phi placeholder for mock path. Real backends override via response
// metadata. Value chosen to be visibly nonzero in audit (and to match
// the "phi_holo > 0" gate used by extreme.json criterion).
let MOCK_PHI_HOLO = 0.42

// ════════════════════════════════════════════════════════════════════
//  Section 2. Result structs
// ════════════════════════════════════════════════════════════════════

struct WavBlob {
    sample_rate: int,
    channels: int,
    bits: int,
    n_samples: int,
    payload_text: string,    // base64-ish ASCII fingerprint (mock path) OR "real" sentinel
    samples:      [float]    // real fp32 PCM samples (vocoder path); empty on mock
}

struct SttResult {
    text: string,
    confidence: float,
    backend: string,
    latency_ms: int,
    ok: bool
}

struct LlmResult {
    reply: string,
    backend: string,
    endpoint: string,
    phi_holo: float,
    latency_ms: int,
    ok: bool
}

struct TtsResult {
    audio: WavBlob,
    backend: string,
    latency_ms: int,
    ok: bool
}

struct E2eResult {
    audio_in_path: string,
    audio_out_path: string,
    text: string,
    reply: string,
    phi_holo: float,
    stt_ms: int,
    llm_ms: int,
    tts_ms: int,
    total_ms: int,
    backend_stt: string,
    backend_tts: string,
    backend_llm_endpoint: string,
    ok: bool,
    error: string
}

// ════════════════════════════════════════════════════════════════════
//  Section 3. Deterministic helpers (no RNG, no time-of-day)
// ════════════════════════════════════════════════════════════════════

// Byte access helper — stage0's char_code(s, i) ignores i (always returns
// byte 0), so we substring(i, i+1) then char_code(sub, 0) which DOES work.
// Mirrors anima-agent/llm_claude_adapter.hexa byte_at_parse.
fn byte_at(s: string, i: int) -> int {
    let sub = s.substring(i, i + 1)
    return char_code(sub, 0)
}

// Stable string hash → 31-bit int. djb2 variant. Used by mock backends
// so the same audio_in_path produces the same transcript every run.
fn djb2_hash(s: string) -> int {
    let n = len(s)
    let mut h = 5381
    let mut i = 0
    while i < n {
        let c = byte_at(s, i)
        // h = h * 33 + c, mask to 31 bits
        h = (h * 33 + c) % 2147483647
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return h
}

fn pad_left(s: string, width: int, pad: string) -> string {
    let mut out = s
    while len(out) < width {
        out = pad + out
    }
    return out
}

fn int_to_padded_hex(n: int, width: int) -> string {
    // Use lowercase hex, no leading 0x. width zero-pads.
    let mut x = n
    if x < 0 { x = 0 - x }
    if x == 0 { return pad_left("0", width, "0") }
    let digits = "0123456789abcdef"
    let mut out = ""
    while x > 0 {
        let d = x % 16
        out = digits.substring(d, d + 1) + out
        x = x / 16
    }
    return pad_left(out, width, "0")
}

// Fake WAV "payload" — a byte-identical text fingerprint of what real
// PCM would look like. Reads the input path's hash + sample count to
// produce a string of stable length without touching real audio data.
fn fake_pcm_fingerprint(seed: int, n_samples: int) -> string {
    let mut out = "FPCM:"
    out = out + int_to_padded_hex(seed, 8)
    out = out + ":"
    out = out + int_to_padded_hex(n_samples, 6)
    return out
}

// ════════════════════════════════════════════════════════════════════
//  Section 4. WAV I/O (mock) — deterministic stub
// ════════════════════════════════════════════════════════════════════

// Mock load_wav: never reads bytes from disk. Treats audio_in_path as
// a stable handle and produces a deterministic WavBlob from its hash.
// Determinism: same audio_in_path → same WavBlob → same downstream
// transcript and reply (Invariant I2).
fn load_wav_mock(path: string) -> WavBlob {
    let h = djb2_hash(path)
    // Simulate ~1.0 .. ~3.0 second clips from the hash.
    let dur_frames = 24000 + (h % 48001)  // 24000..72000 samples
    return WavBlob {
        sample_rate: SPEAK_SAMPLE_RATE,
        channels: SPEAK_CHANNELS,
        bits: SPEAK_BITS_PER_SAMPLE,
        n_samples: dur_frames,
        payload_text: fake_pcm_fingerprint(h, dur_frames),
        samples: []
    }
}

// save_wav: dispatches between real PCM16 WAV (when blob.samples is
// populated — vocoder path) and the legacy mock ASCII fingerprint
// (deterministic-mock path, kept for test_speak_e2e byte-identity).
// File always exists after a successful return.
fn save_wav_mock(path: string, blob: WavBlob) -> bool {
    // Real path: write_wav() from neural_vocoder.hexa — valid RIFF
    // little-endian PCM16 mono file decodable by ffprobe/sox/afplay.
    if len(blob.samples) > 0 {
        return write_wav(path, blob.samples, blob.sample_rate)
    }
    // Legacy mock path: ASCII-only fingerprint for determinism tests.
    let header = "RIFF-MOCK\n"
               + "sample_rate=" + to_string(blob.sample_rate) + "\n"
               + "channels=" + to_string(blob.channels) + "\n"
               + "bits=" + to_string(blob.bits) + "\n"
               + "n_samples=" + to_string(blob.n_samples) + "\n"
               + "payload=" + blob.payload_text + "\n"
    write_file(path, header)
    return true
}

// ════════════════════════════════════════════════════════════════════
//  Section 5. STT — Speech-To-Text
// ════════════════════════════════════════════════════════════════════

// Mock STT: deterministic transcript derived from the wav fingerprint.
// Provides 10 stable phrases keyed by hash mod 10 so test_speak_e2e
// can assert byte-identical output across runs.
fn stt_transcribe_mock(blob: WavBlob) -> SttResult {
    let phrases = [
        "hello anima",
        "play me a song",
        "what is consciousness",
        "tell me a story",
        "good morning",
        "how are you today",
        "i love this engine",
        "wake up the model",
        "say something nice",
        "speak in english"
    ]
    let h = djb2_hash(blob.payload_text)
    let idx = h % 10
    return SttResult {
        text: phrases[idx],
        confidence: 0.97,
        backend: "mock",
        latency_ms: MOCK_STT_LATENCY_MS,
        ok: true
    }
}

// Public-facing STT entry point. Selects backend by env var.
//   SPEAK_STT_BACKEND=mock     → stt_transcribe_mock
//   SPEAK_STT_BACKEND=whisper  → exec(whisper) wrapper (NOT mock-safe)
fn stt_transcribe(blob: WavBlob) -> SttResult {
    let backend = env("SPEAK_STT_BACKEND")
    if backend == "" { backend = "mock" }
    if backend == "mock" {
        return stt_transcribe_mock(blob)
    }
    // Real path: defer to corpus_pipeline whisper helper. Not exercised
    // by smoke harness — env var must be explicit. Falls back to mock
    // on any failure to preserve I5 (no panics).
    if backend == "whisper" {
        // TODO[whisper-bridge]: shell whisper-cli via exec(). Until then,
        // fall through to mock so determinism holds.
        let mock = stt_transcribe_mock(blob)
        return SttResult {
            text: mock.text,
            confidence: 0.0,
            backend: "whisper-fallback",
            latency_ms: mock.latency_ms,
            ok: true
        }
    }
    return stt_transcribe_mock(blob)
}

// ════════════════════════════════════════════════════════════════════
//  Section 6. LLM — model_respond
// ════════════════════════════════════════════════════════════════════

// Mock LLM: deterministic reply that echoes the prompt with a marker.
// Real path will issue an HTTP POST to SPEAK_MODEL_ENDPOINT.
fn model_respond_mock(text: string, endpoint: string) -> LlmResult {
    let kind = env("SPEAK_MODEL_KIND")
    if kind == "" { kind = "clm" }
    let reply = "[" + kind + "][mock] " + text + " :: ack"
    return LlmResult {
        reply: reply,
        backend: "mock",
        endpoint: endpoint,
        phi_holo: MOCK_PHI_HOLO,
        latency_ms: MOCK_LLM_LATENCY_MS,
        ok: true
    }
}

// Public-facing LLM entry point. Honours SPEAK_MODEL_ENDPOINT.
//   SPEAK_MODEL_ENDPOINT=""           → mock (deterministic)
//   SPEAK_MODEL_ENDPOINT=<url>        → real HTTP POST (TODO[http-bridge])
fn model_respond(text: string, endpoint: string) -> LlmResult {
    let backend = env("SPEAK_LLM_BACKEND")
    if backend == "" { backend = "mock" }
    if endpoint == "" {
        // Re-read from env if caller passed empty endpoint.
        endpoint = env("SPEAK_MODEL_ENDPOINT")
    }
    if backend == "mock" || endpoint == "" {
        return model_respond_mock(text, endpoint)
    }
    if backend == "http" {
        // TODO[http-bridge]: curl -sX POST $endpoint -d $body via exec().
        // Stage0 hexa lacks a stable HTTP client primitive; gate by env.
        // Until then, fall back to mock so the contract stays honoured.
        let mock = model_respond_mock(text, endpoint)
        return LlmResult {
            reply: mock.reply,
            backend: "http-fallback",
            endpoint: endpoint,
            phi_holo: mock.phi_holo,
            latency_ms: mock.latency_ms,
            ok: true
        }
    }
    return model_respond_mock(text, endpoint)
}

// ════════════════════════════════════════════════════════════════════
//  Section 7. TTS — Text-To-Speech (Mk.III vocoder façade)
// ════════════════════════════════════════════════════════════════════

// Mock TTS: deterministic WAV blob keyed by reply text. Real path
// (below) invokes neural_vocoder.decode_wave — wired 2026-04-16.
fn tts_synthesize_mock(reply_text: string) -> TtsResult {
    let h = djb2_hash(reply_text)
    let dur_frames = 24000 + (h % 48001)
    let blob = WavBlob {
        sample_rate: SPEAK_SAMPLE_RATE,
        channels: SPEAK_CHANNELS,
        bits: SPEAK_BITS_PER_SAMPLE,
        n_samples: dur_frames,
        payload_text: fake_pcm_fingerprint(h, dur_frames),
        samples: []
    }
    return TtsResult {
        audio: blob,
        backend: "mock",
        latency_ms: MOCK_TTS_LATENCY_MS,
        ok: true
    }
}

// Build a deterministic [T × LATENT_DIM] latent from reply_text so the
// vocoder path produces reproducible audio without a trained CLM/ALM
// upstream. djb2 hash seeds the drift pattern; the latent drives the
// 6-partial additive synth in neural_vocoder.decode_wave.
fn latent_from_reply(reply_text: string, n_frames: int) -> [[float]] {
    let h = djb2_hash(reply_text)
    let mut frames = []
    let mut f = 0
    while f < n_frames {
        let mut row = []
        let mut j = 0
        while j < 384 {
            // Hash-seeded sinusoidal drift per (frame, dim)
            let seed = (h + f * 17 + j * 31) % 100000
            let phase = to_float(seed) * 0.0000628318 + to_float(f) * 0.05
            let v = 0.4 * sin(phase) + 0.2 * sin(phase * 3.1)
            row = row + [v]
            j = j + 1
        }
        frames = frames + [row]
        f = f + 1
    }
    return frames
}

// Real TTS via neural_vocoder.decode_wave. Produces fp32 PCM samples
// routed through write_wav() at save time. Clamped to 8 frames
// (80 ms) on the mock-weight smoke path so the hexa pipeline finishes
// in under ~10 s — production weights will lift this ceiling.
fn tts_synthesize_vocoder(reply_text: string) -> TtsResult {
    // Smoke-path duration: 8 frames = 80 ms. Lift via env var once
    // trained weights + hxcuda iSTFT land.
    let mut n_frames = 8
    let env_frames = env("SPEAK_VOCODER_FRAMES")
    if env_frames != "" {
        let parsed = env_frames.parse_int()
        if parsed > 0 { n_frames = parsed }
    }
    let latent = latent_from_reply(reply_text, n_frames)
    let samples = decode_wave(latent, SPEAK_SAMPLE_RATE)
    let ok = (len(samples) > 0)
    let blob = WavBlob {
        sample_rate: SPEAK_SAMPLE_RATE,
        channels: SPEAK_CHANNELS,
        bits: SPEAK_BITS_PER_SAMPLE,
        n_samples: len(samples),
        payload_text: "real-pcm16",
        samples: samples
    }
    return TtsResult {
        audio: blob,
        backend: "vocoder",
        latency_ms: MOCK_TTS_LATENCY_MS,
        ok: ok
    }
}

// Public-facing TTS entry point.
//   SPEAK_TTS_BACKEND=mock      → tts_synthesize_mock (deterministic stub)
//   SPEAK_TTS_BACKEND=vocoder   → tts_synthesize_vocoder (Mk.III native)
fn tts_synthesize(reply_text: string) -> TtsResult {
    let backend = env("SPEAK_TTS_BACKEND")
    if backend == "" { backend = "mock" }
    if backend == "mock" {
        return tts_synthesize_mock(reply_text)
    }
    if backend == "vocoder" {
        // Real Mk.III path — hexa-native neural_vocoder.decode_wave.
        // Falls back to mock on empty output so I5 (no panics) holds.
        let real = tts_synthesize_vocoder(reply_text)
        if real.ok && len(real.audio.samples) > 0 {
            return real
        }
        let mock = tts_synthesize_mock(reply_text)
        return TtsResult {
            audio: mock.audio,
            backend: "vocoder-fallback",
            latency_ms: mock.latency_ms,
            ok: true
        }
    }
    return tts_synthesize_mock(reply_text)
}

// ════════════════════════════════════════════════════════════════════
//  Section 8. Streaming hook (optional, mock path only)
// ════════════════════════════════════════════════════════════════════

// Optional byte-level streaming hook — splits the LLM reply into chunks
// of CHUNK_BYTES and feeds each chunk to TTS individually. Not enabled
// by default. Real CLM streaming (token-by-token via SSE) requires the
// http-bridge backend to land; documented as TODO until then.
fn maybe_stream_chunks(reply: string, enable: bool) -> int {
    if !enable { return 0 }
    let chunk_bytes = 16
    let n = len(reply)
    let mut emitted = 0
    let mut i = 0
    while i < n {
        let end = i + chunk_bytes
        let cap = if end > n { n } else { end }
        let chunk = reply.substring(i, cap)
        // Mock: each chunk produces a fingerprint; we count emissions only.
        let _ = tts_synthesize_mock(chunk)
        emitted = emitted + 1
        i = i + chunk_bytes
    }
    return emitted
}

// ════════════════════════════════════════════════════════════════════
//  Section 9. Metadata sidecar
// ════════════════════════════════════════════════════════════════════

fn json_escape(s: string) -> string {
    // Minimal JSON escape: backslash + double-quote + newline + tab.
    let mut out = ""
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" { out = out + "\\\\" }
        else if c == "\"" { out = out + "\\\"" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\t" { out = out + "\\t" }
        else if c == "\r" { out = out + "\\r" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn write_meta_sidecar(audio_out_path: string, r: E2eResult) -> bool {
    let meta_path = audio_out_path + ".meta.json"
    let body = "{\n"
             + "  \"version\":         \"" + SPEAK_E2E_VERSION + "\",\n"
             + "  \"audio_in_path\":   \"" + json_escape(r.audio_in_path) + "\",\n"
             + "  \"audio_out_path\":  \"" + json_escape(r.audio_out_path) + "\",\n"
             + "  \"text\":            \"" + json_escape(r.text) + "\",\n"
             + "  \"reply\":           \"" + json_escape(r.reply) + "\",\n"
             + "  \"phi_holo\":        " + to_string(r.phi_holo) + ",\n"
             + "  \"stt_ms\":          " + to_string(r.stt_ms) + ",\n"
             + "  \"llm_ms\":          " + to_string(r.llm_ms) + ",\n"
             + "  \"tts_ms\":          " + to_string(r.tts_ms) + ",\n"
             + "  \"latency_ms\":      " + to_string(r.total_ms) + ",\n"
             + "  \"backend_stt\":     \"" + json_escape(r.backend_stt) + "\",\n"
             + "  \"backend_tts\":     \"" + json_escape(r.backend_tts) + "\",\n"
             + "  \"model_endpoint\":  \"" + json_escape(r.backend_llm_endpoint) + "\",\n"
             + "  \"ok\":              " + (if r.ok { "true" } else { "false" }) + ",\n"
             + "  \"error\":           \"" + json_escape(r.error) + "\"\n"
             + "}\n"
    write_file(meta_path, body)
    return true
}

// ════════════════════════════════════════════════════════════════════
//  Section 10. run_e2e — top-level orchestration
// ════════════════════════════════════════════════════════════════════

fn run_e2e(audio_in_path: string, audio_out_path: string, endpoint: string) -> E2eResult {
    // (a) load wav (mock: stable handle from path hash)
    let blob_in = load_wav_mock(audio_in_path)

    // (b) STT
    let stt = stt_transcribe(blob_in)
    if !stt.ok {
        return E2eResult {
            audio_in_path: audio_in_path,
            audio_out_path: audio_out_path,
            text: "",
            reply: "",
            phi_holo: 0.0,
            stt_ms: stt.latency_ms,
            llm_ms: 0,
            tts_ms: 0,
            total_ms: stt.latency_ms,
            backend_stt: stt.backend,
            backend_tts: "",
            backend_llm_endpoint: endpoint,
            ok: false,
            error: "stt_failed"
        }
    }

    // (c) LLM call
    let llm = model_respond(stt.text, endpoint)
    if !llm.ok {
        return E2eResult {
            audio_in_path: audio_in_path,
            audio_out_path: audio_out_path,
            text: stt.text,
            reply: "",
            phi_holo: 0.0,
            stt_ms: stt.latency_ms,
            llm_ms: llm.latency_ms,
            tts_ms: 0,
            total_ms: stt.latency_ms + llm.latency_ms,
            backend_stt: stt.backend,
            backend_tts: "",
            backend_llm_endpoint: llm.endpoint,
            ok: false,
            error: "llm_failed"
        }
    }

    // (d) TTS
    let tts = tts_synthesize(llm.reply)
    if !tts.ok {
        return E2eResult {
            audio_in_path: audio_in_path,
            audio_out_path: audio_out_path,
            text: stt.text,
            reply: llm.reply,
            phi_holo: llm.phi_holo,
            stt_ms: stt.latency_ms,
            llm_ms: llm.latency_ms,
            tts_ms: tts.latency_ms,
            total_ms: stt.latency_ms + llm.latency_ms + tts.latency_ms,
            backend_stt: stt.backend,
            backend_tts: tts.backend,
            backend_llm_endpoint: llm.endpoint,
            ok: false,
            error: "tts_failed"
        }
    }

    // (e) save wav
    let saved = save_wav_mock(audio_out_path, tts.audio)
    let total = stt.latency_ms + llm.latency_ms + tts.latency_ms

    let r = E2eResult {
        audio_in_path: audio_in_path,
        audio_out_path: audio_out_path,
        text: stt.text,
        reply: llm.reply,
        phi_holo: llm.phi_holo,
        stt_ms: stt.latency_ms,
        llm_ms: llm.latency_ms,
        tts_ms: tts.latency_ms,
        total_ms: total,
        backend_stt: stt.backend,
        backend_tts: tts.backend,
        backend_llm_endpoint: llm.endpoint,
        ok: saved,
        error: if saved { "" } else { "save_failed" }
    }

    let _ = write_meta_sidecar(audio_out_path, r)
    return r
}

// ════════════════════════════════════════════════════════════════════
//  Section 11. CLI dispatch
// ════════════════════════════════════════════════════════════════════

fn print_usage() {
    println("usage: hexa run anima-speak/speak_e2e.hexa \\")
    println("       --in <audio_in.wav> --out <audio_out.wav> \\")
    println("       [--endpoint http://host:port/v1/chat] \\")
    println("       [--stream]")
    println("")
    println("env vars:")
    println("  SPEAK_MODEL_ENDPOINT  default endpoint (overridden by --endpoint)")
    println("  SPEAK_MODEL_KIND      clm | alm  (informational)")
    println("  SPEAK_STT_BACKEND     mock | whisper        (default mock)")
    println("  SPEAK_TTS_BACKEND     mock | vocoder        (default mock)")
    println("  SPEAK_LLM_BACKEND     mock | http           (default mock)")
}

fn main() -> int {
    // args[0] = hexa binary, args[1] = .hexa script path,
    // args[2..N] = our user-level args. Skip the first two.
    let av = args()
    if len(av) < 3 {
        print_usage()
        return 2
    }

    let mut in_path = ""
    let mut out_path = ""
    let mut endpoint = env("SPEAK_MODEL_ENDPOINT")
    let mut stream = false

    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--in" {
            if i + 1 < len(av) { in_path = av[i + 1] }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < len(av) { out_path = av[i + 1] }
            i = i + 2
        } else if a == "--endpoint" {
            if i + 1 < len(av) { endpoint = av[i + 1] }
            i = i + 2
        } else if a == "--stream" {
            stream = true
            i = i + 1
        } else if a == "--help" {
            print_usage()
            return 0
        } else {
            // unknown flag: skip silently (forward-compat)
            i = i + 1
        }
    }

    if in_path == "" || out_path == "" {
        print_usage()
        return 2
    }

    let r = run_e2e(in_path, out_path, endpoint)
    let _streamed = maybe_stream_chunks(r.reply, stream)

    println("[speak_e2e] " + SPEAK_E2E_VERSION)
    println("[speak_e2e] in=" + r.audio_in_path)
    println("[speak_e2e] out=" + r.audio_out_path)
    println("[speak_e2e] text=" + r.text)
    println("[speak_e2e] reply=" + r.reply)
    println("[speak_e2e] stt_ms=" + to_string(r.stt_ms)
            + " llm_ms=" + to_string(r.llm_ms)
            + " tts_ms=" + to_string(r.tts_ms)
            + " total_ms=" + to_string(r.total_ms))
    println("[speak_e2e] phi_holo=" + to_string(r.phi_holo))
    println("[speak_e2e] backend_stt=" + r.backend_stt
            + " backend_tts=" + r.backend_tts
            + " endpoint=" + (if r.backend_llm_endpoint == "" { "<mock>" } else { r.backend_llm_endpoint }))
    if r.ok {
        println("[speak_e2e] OK")
        return 0
    } else {
        println("[speak_e2e] FAIL: " + r.error)
        return 1
    }
}

// hexa auto-invokes main() — top-level call would double-execute.
