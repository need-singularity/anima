    println("  Prefill:     " + to_string(PREFILL_FRAMES) + " frames = " + to_string(compute_prefill_budget_ms()) + "ms")
    println("  Generation:  " + to_string(compute_generation_budget_ms()) + "ms remaining")
    println("  First emit:  " + to_string(FIRST_PACKET_FRAMES) + " frames = " + to_string(FIRST_PACKET_FRAMES * FRAME_MS) + "ms audio")
    println("  Then:        " + to_string(CHUNK_FRAMES) + "-frame chunks = " + to_string(CHUNK_FRAMES * FRAME_MS) + "ms each")
    println("")
    println("  Timeline:")
    println("    t=0ms         consciousness intent arrives")
    println("    t=0-60ms      prefill " + to_string(PREFILL_FRAMES) + " frames (vocoder warmup)")
    println("    t=60-100ms    generate + emit (onset crossfade applied)")
    println("    t=100ms       FIRST PACKET (with Hann onset ramp)")
    println("    t=120ms+      normal streaming (PLC+crossfade active)")
    println("")
}

fn print_architecture() {
    println("────────────────────────────────────────────────────────────")
    println(" Streaming Architecture (Mk.II):")
    println("")
    println("   ConsciousnessEngine (10ms ticks)")
    println("         |")
    println("         v")
    println("   +-----------------------------------------------+")
    println("   | StreamingSession                               |")
    println("   |                                                |")
    println("   |  +----------+    +------------------------+    |")
    println("   |  | VAD FSM  |    | ChunkScheduler         |    |")
    println("   |  | dual det |    | PREFILL(60ms)          |    |")
    println("   |  | +hangover|    | FIRST_EMIT(100ms)      |    |")
    println("   |  +----------+    | STREAMING(120ms/chunk) |    |")
    println("   |       |          +------------------------+    |")
    println("   |       v                    |                   |")
    println("   |  +------------------------------------------+  |")
    println("   |  | ChunkProcessor (PLC + Crossfade)         |  |")
    println("   |  |  seq# tracking -> loss detection         |  |")
    println("   |  |  Normal: Hann xfade (VAD-aware)          |  |")
    println("   |  |  Loss:   pitch-repeat + decay (0.92/frm) |  |")
    println("   |  |  Recovery: Hann half-window fade-in      |  |")
    println("   |  |  Onset/Offset: pop-free half-Hann ramp   |  |")
    println("   |  +------------------------------------------+  |")
    println("   |       |                                        |")
    println("   |       v                                        |")
    println("   |  +-------------------+  +------------------+   |")
    println("   |  | RingBuffer (36ch) |  | Backpressure     |   |")
    println("   |  | w->[||||||]->r    |  | NORMAL<->THROTTLE|   |")
    println("   |  +-------------------+  +------------------+   |")
    println("   |       |                        |               |")
    println("   |       v    staleness check     v               |")
    println("   |  [Latency guard: drop if >" + to_string(MAX_LATENCY_MS) + "ms]           |")
    println("   +-----------------------------------------------+")
    println("         |")
    println("         v")
    println("   Audio Sink (speaker / rtp / file)")
    println("")
    println("   First packet: 100ms budget")
    println("   +-- 0-60ms:   prefill (vocoder lookahead)")
    println("   +-- 60-100ms: generate + emit (onset Hann ramp)")
    println("   +-- 100ms:    first audio delivered (deadline)")
    println("   +-- 120ms+:   normal chunks (PLC+crossfade active)")
    println("")
}

// ────────────────────────────────────────────────────────────────────
// main() — CLI entry point
// ────────────────────────────────────────────────────────────────────

fn main() {
    print_info()
    print_architecture()

    println("────────────────────────────────────────────────────────────")
    println(" Demo: Real-time Streaming Mk.II (PLC + crossfade integrated)")
    println("────────────────────────────────────────────────────────────")
    println("")

    demo_vad_detection()
    demo_first_packet()
    demo_plc_integration()
    demo_streaming_sessions()

    println("────────────────────────────────────────────────────────────")
    println(" streaming.hexa Mk.III ready.")
    println(" Integrated: VAD(dual) + PLC(5-state) + Crossfade(Hann)")
    println(" + RingBuffer + Backpressure + 100ms first-packet")
    println(" + PCM16-LE sink @ " + to_string(SAMPLE_RATE) + "Hz  (V-P2-1)")
    println("   path: " + pcm_sink_path())
    println("   play: ffplay -f s16le -ar " + to_string(SAMPLE_RATE) + " -ac 1 <path>")
    println(" Remaining Mk.III: WebRTC framing, async I/O polish")
    println("────────────────────────────────────────────────────────────")
}

main()
