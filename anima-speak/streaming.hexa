fn print_info() {
    println("================================================================")
    println(" HEXA-SPEAK Mk.II — Real-time Streaming Engine")
    println("================================================================")
    println("")
    println(" Components:")
    println("   VAD FSM:       4-state (SILENCE->SPEECH_START->SPEAKING->SPEECH_END)")
    println("                  dual-criteria: energy>" + to_string(VAD_ENERGY_THRESH) + " + ZCR in [" + to_string(VAD_ZCR_LO) + "," + to_string(VAD_ZCR_THRESH) + "]")
    println("                  hangover=" + to_string(VAD_HANGOVER_FRAMES) + " frames (" + to_string(VAD_HANGOVER_FRAMES * FRAME_MS) + "ms)")
    println("                  onset=" + to_string(VAD_ONSET_FRAMES) + " frames, offset=" + to_string(VAD_OFFSET_FRAMES) + " frames")
    println("")
    println("   PLC:           5-state (Normal->Conceal->Fadeout->Muted, Recovery)")
    println("                  decay=" + to_string(PLC_DECAY) + "/frame, max=" + to_string(PLC_MAX_MS) + "ms")
    println("                  fadeout at " + to_string(PLC_MUTE_THRESH) + " losses, mute at " + to_string(PLC_MAX_CONSEC))
    println("")
    println("   Crossfade:     Hann window " + to_string(CROSSFADE_MS) + "ms (" + to_string(CROSSFADE_SAMP) + " samples)")
    println("                  types: normal (voice-voice), onset (silence-voice), offset (voice-silence)")
    println("                  VAD-aware: onset/offset use half-Hann ramp (pop prevention)")
    println("")
    println("   Ring Buffer:   capacity=" + to_string(RING_CAPACITY) + " chunks (" + to_string(RING_CAPACITY * CHUNK_FRAMES * FRAME_MS) + "ms)")
    println("                  drop-oldest on overflow")
    println("")
    println("   Backpressure:  high=" + to_string(BACKPRESSURE_HIGH) + " (throttle), low=" + to_string(BACKPRESSURE_LOW) + " (resume)")
    println("")
    println("   Scheduler:     first_packet=" + to_string(FIRST_PACKET_BUDGET_MS) + "ms")
    println("                  prefill=" + to_string(PREFILL_FRAMES) + " frames (" + to_string(compute_prefill_budget_ms()) + "ms)")
    println("                  then " + to_string(CHUNK_FRAMES) + "-frame chunks (" + to_string(CHUNK_FRAMES * FRAME_MS) + "ms)")
    println("")
    println("   Latency guard: max=" + to_string(MAX_LATENCY_MS) + "ms (stale chunks dropped)")
    println("")
    println(" PSI coupling:    alpha=" + to_string(PSI_ALPHA))
    println(" Sample rate:     " + to_string(SAMPLE_RATE) + "Hz")
    println(" Frame rate:      " + to_string(FRAME_HZ) + "Hz (" + to_string(FRAME_MS) + "ms/frame)")
    println("")
}

fn demo_vad_detection() {
    println("── VAD Detection (energy + ZCR dual-criteria) ──")
    println("")
    println("  State                    Energy   ZCR      Active")
    println("  ─────────────────────────────────────────────────")

    let e1 = compute_frame_energy(0.05, 0.05, 0)
    let z1 = compute_zcr(0.05, 0)
    let a1 = is_speech_active(e1, z1)
    println("  silent  (t=0.05,a=0.05)  " + to_string(e1) + "  " + to_string(z1) + "  " + to_string(a1))

    let e2 = compute_frame_energy(0.15, 0.3, 0)
    let z2 = compute_zcr(0.15, 0)
    let a2 = is_speech_active(e2, z2)
    println("  quiet   (t=0.15,a=0.30)  " + to_string(e2) + "  " + to_string(z2) + "  " + to_string(a2))

    let e3 = compute_frame_energy(0.42, 0.6, 0)
    let z3 = compute_zcr(0.42, 0)
    let a3 = is_speech_active(e3, z3)
    println("  normal  (t=0.42,a=0.60)  " + to_string(e3) + "  " + to_string(z3) + "  " + to_string(a3))

    let e4 = compute_frame_energy(0.91, 0.8, 0)
    let z4 = compute_zcr(0.91, 0)
    let a4 = is_speech_active(e4, z4)
    println("  loud    (t=0.91,a=0.80)  " + to_string(e4) + "  " + to_string(z4) + "  " + to_string(a4))
    println("")
}

fn demo_plc_integration() {
    println("── PLC + Crossfade Integration ──")
    println("")

    // Normal chunk processing (no loss, voice-voice)
    let r1 = process_chunk_plc_xfade("tail[c0]", "chunk[c1]", 1, 1, PLC_NORMAL, 0, S_SPEAKING, S_SPEAKING)
    println("  Normal (voice->voice):     " + r1)

    // Packet loss (expected 2, got 4)
    let r2 = process_chunk_plc_xfade("tail[c1]", "chunk[c4]", 2, 4, PLC_NORMAL, 0, S_SPEAKING, S_SPEAKING)
    println("  Loss (2 chunks lost):      " + r2)

    // Recovery after loss
    let r3 = process_chunk_plc_xfade("tail[plc]", "chunk[c5]", 5, 5, PLC_CONCEAL, 2, S_SPEAKING, S_SPEAKING)
    println("  Recovery (fade-in):        " + r3)

    // Silence->voice onset (pop prevention)
    let r4 = process_chunk_plc_xfade("tail[silence]", "chunk[c6]", 6, 6, PLC_NORMAL, 0, S_SILENCE, S_SPEECH_START)
    println("  Onset (silence->voice):    " + r4)

    // Voice->silence offset (pop prevention)
    let r5 = process_chunk_plc_xfade("tail[voice]", "silence[c7]", 7, 7, PLC_NORMAL, 0, S_SPEAKING, S_SILENCE)
    println("  Offset (voice->silence):   " + r5)

    println("")
}

fn demo_streaming_sessions() {
    println("── Streaming Sessions (Mk.II: PLC + crossfade integrated) ──")
    println("")

    // Test 1: Active speech (joyful)
    println("  Test 1: Joyful speech (t=0.42, a=0.6, 1s)")
    let r1 = stream_synthesize(0.71, 0.42, 0.6, 0.5, 64, 1000)
    println("  -> " + r1)
    println("")

    // Test 2: Near-silent (low arousal)
    println("  Test 2: Near-silent (t=0.05, a=0.05, 1s)")
    let r2 = stream_synthesize(0.35, 0.05, 0.05, 0.0, 32, 1000)
    println("  -> " + r2)
    println("")

    // Test 3: Angry/loud (high tension, 2s)
    println("  Test 3: Angry/loud (t=0.91, a=0.8, 2s)")
    let r3 = stream_synthesize(0.88, 0.91, 0.8, -0.5, 64, 2000)
    println("  -> " + r3)
    println("")

    // Test 4: Short burst (300ms)
    println("  Test 4: Short burst (t=0.6, a=0.5, 300ms)")
    let r4 = stream_synthesize(0.55, 0.6, 0.5, 0.2, 32, 300)
    println("  -> " + r4)
    println("")
}

