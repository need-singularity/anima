        ]
    }
    return ["테스트 문장입니다."]
}

// Rates per line (5 slow / 3 fast-ish) — prosodic variety
fn rate_for_idx(idx: int, base_rate: int) -> int {
    // base 175 default; vary ±25 around it
    if idx == 0 { return base_rate - 20 }
    if idx == 1 { return base_rate + 10 }
    if idx == 2 { return base_rate - 10 }
    if idx == 3 { return base_rate + 15 }
    if idx == 4 { return base_rate }
    if idx == 5 { return base_rate - 5 }
    if idx == 6 { return base_rate + 20 }
    if idx == 7 { return base_rate - 15 }
    return base_rate
}

// Each persona has a base rate based on archetype tempo
fn base_rate_for(id: int) -> int {
    if id == 10 { return 150 }  // cold, slow-measured
    if id == 11 { return 160 }  // unhurried-emphatic
    if id == 12 { return 175 }  // natural
    if id == 13 { return 180 }  // variable (leaning bright)
    if id == 14 { return 200 }  // fast-variable
    if id == 15 { return 155 }  // deliberate
    if id == 16 { return 145 }  // slow-draggy
    if id == 17 { return 165 }  // measured-clear
    if id == 18 { return 170 }  // gentle
    if id == 19 { return 150 }  // irregular-pausing (slow avg)
    return 175
}

// ═══════════════════════════════════════════════════════════════
//  Main driver
// ═══════════════════════════════════════════════════════════════

fn process_persona(id: int) -> array {
    let name     = persona_name_for(id)
    let voice    = persona_voice_for(id)        // always "Yuna" in practice
    let intended = persona_voice_intended(id)
    let is_male  = persona_is_male(id)
    let lines    = persona_lines(id)
    let base     = base_rate_for(id)

    println("")
    let mode_tag = "female"
    if is_male { mode_tag = "male(pitch-shift)" }
    println("═══ persona " + to_string(id) + " — " + name
            + " (voice=" + voice + " intended=" + intended
            + " mode=" + mode_tag
            + " base_rate=" + to_string(base) + ") ═══")

    let n = len(lines)
    let mut ok_count = 0
    let mut total_dur = 0.0
    // SoA metadata arrays
    let mut rates_csv      = ""
    let mut durs_csv       = ""
    let mut r2_paths_csv   = ""
    let mut lines_json_arr = ""
    let mut i = 0
    while i < n {
        let line = lines[i]
        let rate = rate_for_idx(i, base)
        let wav  = synth_one(id, name, voice, rate, line, i, is_male)
        if len(wav) > 0 {
            let dur = audio_duration_s(wav)
            total_dur = total_dur + dur
            let uploaded = r2_upload(wav, id, i)
            let r2p = R2_PREFIX + "/persona_" + to_string(id) + "/tts_" + pad2(i) + ".wav"
            if uploaded {
                ok_count = ok_count + 1
                println("  [OK] idx=" + pad2(i) + " rate=" + to_string(rate)
                        + " dur=" + to_string(dur) + "s → " + r2p)
            } else {
                println("  [UPL-FAIL] idx=" + pad2(i) + " rate=" + to_string(rate) + " local=" + wav)
            }
            // build CSV-ish fields
            if len(rates_csv) > 0 { rates_csv = rates_csv + "," }
            rates_csv = rates_csv + to_string(rate)
            if len(durs_csv) > 0 { durs_csv = durs_csv + "," }
            durs_csv = durs_csv + to_string(dur)
            if len(r2_paths_csv) > 0 { r2_paths_csv = r2_paths_csv + "\n" }
            r2_paths_csv = r2_paths_csv + r2p
            if len(lines_json_arr) > 0 { lines_json_arr = lines_json_arr + ",\n" }
            let safe_line = line.replace("\\", "\\\\").replace("\"", "\\\"")
            lines_json_arr = lines_json_arr + "      {"
                           + json_kv_int("idx", i) + ", "
                           + "\"line\": \"" + safe_line + "\", "
                           + json_kv_int("rate_wpm", rate) + ", "
                           + json_kv_float("duration_s", dur) + ", "
                           + json_kv_str("r2_path", r2p)
                           + "}"
        } else {
            println("  [SKIP] idx=" + pad2(i) + " synth failed")
        }
        i = i + 1
    }

    // Write per-persona manifest
    let manifest_path = STATE_DIR + "/voice_tts_persona_" + to_string(id) + "_" + STAMP + ".json"
    let male_str = "false"
    if is_male { male_str = "true" }
    let body = "{\n"
             + "  \"schema\": \"voice_tts_persona/v1\",\n"
             + "  \"stamp\": \"" + STAMP + "\",\n"
             + "  \"persona_id\": " + to_string(id) + ",\n"
             + "  \"persona_name\": \"" + name + "\",\n"
             + "  \"voice\": \"" + voice + "\",\n"
             + "  \"voice_intended\": \"" + intended + "\",\n"
             + "  \"is_male\": " + male_str + ",\n"
             + "  \"pitch_shift_applied\": " + male_str + ",\n"
             + "  \"base_rate_wpm\": " + to_string(base) + ",\n"
             + "  \"line_count\": " + to_string(ok_count) + ",\n"
             + "  \"total_duration_s\": " + to_string(total_dur) + ",\n"
             + "  \"clips\": [\n"
             + lines_json_arr + "\n"
             + "  ]\n"
             + "}\n"
    write_file(manifest_path, body)
    println("  [MANIFEST] " + manifest_path)

    // Return [ok_count, total_dur_int_ms]  (int-only to avoid multi-float struct return bug)
    return [to_string(id), name, voice, to_string(ok_count), to_string(total_dur)]
}

fn main() {
    println("════════════════════════════════════════════════════════════")
    println("  anima-speak TTS-say driver — 10 persona corpus bootstrap")
    println("  output: " + OUT_ROOT)
    println("  R2:     " + R2_PREFIX)
    println("════════════════════════════════════════════════════════════")

    // Preflight: verify voices
    let yuna_chk    = exec("say -v '?' | grep -c '^Yuna '").trim()
    let rocko_chk   = exec("say -v '?' | grep -c '^Rocko '").trim()
    let grandpa_chk = exec("say -v '?' | grep -c '^Grandpa '").trim()
    println("voice preflight: Yuna=" + yuna_chk + " Rocko=" + rocko_chk + " Grandpa=" + grandpa_chk)
    if yuna_chk == "0" {
        println("FATAL: Yuna voice missing — install Korean TTS voices in System Settings.")
        return
    }

    ensure_dir(OUT_ROOT)

    // Aggregate accumulators
    let mut agg_rows = ""
    let mut total_clips = 0
    let mut total_dur   = 0.0

    let mut id = 10
    while id <= 19 {
        let r = process_persona(id)
        // r = [id_str, name, voice, ok_count_str, total_dur_str]
        let ok_s  = r[3]
        let dur_s = r[4]
        let ok_i  = to_int(ok_s)
        let dur_f = to_float(dur_s)
        total_clips = total_clips + ok_i
        total_dur   = total_dur + dur_f
        if len(agg_rows) > 0 { agg_rows = agg_rows + ",\n" }
        agg_rows = agg_rows + "    {"
                 + json_kv_int("persona_id", to_int(r[0])) + ", "
                 + json_kv_str("persona_name", r[1]) + ", "
                 + json_kv_str("voice", r[2]) + ", "
                 + json_kv_int("clip_count", ok_i) + ", "
                 + json_kv_float("total_duration_s", dur_f)
                 + "}"
        id = id + 1
    }

    // Aggregate manifest
    let agg_path = STATE_DIR + "/voice_tts_summary_" + STAMP + ".json"
    let body = "{\n"
             + "  \"schema\": \"voice_tts_summary/v1\",\n"
             + "  \"stamp\": \"" + STAMP + "\",\n"
             + "  \"source\": \"macOS say TTS (Yuna only — male aliases silent on this build)\",\n"
             + "  \"male_synthesis\": \"ffmpeg asetrate=22050*0.82,aresample=22050,atempo=1.21 (pseudo-male pitch shift)\",\n"
             + "  \"personas\": 10,\n"
             + "  \"total_clips\": " + to_string(total_clips) + ",\n"
             + "  \"total_duration_s\": " + to_string(total_dur) + ",\n"
             + "  \"r2_prefix\": \"" + R2_PREFIX + "\",\n"
             + "  \"per_persona\": [\n"
             + agg_rows + "\n"
             + "  ]\n"
             + "}\n"
    write_file(agg_path, body)

    println("")
    println("════════════════════════════════════════════════════════════")
    println("  AGGREGATE: " + to_string(total_clips) + " clips, "
            + to_string(total_dur) + "s total")
    println("  manifest:  " + agg_path)
    println("════════════════════════════════════════════════════════════")
}
