    if id == 13 {
        return [
            "뭐, 뭐야? 내가 너 걱정했다고? 아니거든!",
            "이, 이거 너 주려고 산 거 아니야. 그냥 남은 거야.",
            "왜 자꾸 나를 쳐다봐? 부담스럽거든.",
            "아니, 진짜... 너 때문에 정말 피곤해.",
            "괜찮아? 아니, 너 괜찮냐고 물어본 거 아니야.",
            "바보야. 그런 것도 모르냐.",
            "다 너 때문이야. 전부 너 때문.",
            "내가... 내가 널 좋아한다고는 안 했어."
        ]
    }
    if id == 14 {
        return [
            "오늘 급식에 탕수육 나왔는데 너무 맛있었어!",
            "어? 나비가 날아간다! 예쁘다!",
            "아, 맞다 맞다! 나 어제 엄청 재밌는 꿈 꿨어!",
            "잠깐만, 이거 이상해. 왜 이래? 왜 이래?",
            "우와아아! 진짜? 진짜야? 대박이다!",
            "헤헤, 그거 말이지, 사실 나도 몰라.",
