// anima-speak/tts_say_driver.hexa — macOS `say` TTS corpus bootstrap for v2.0 RC
//
// Purpose: generate baseline Korean voice corpus for 10 webtoon personas (id 10..19)
// using the macOS built-in `say` command. This unblocks serve-layer voice stub
// replacement when YouTube CC sourcing was a drought (1/9 queries hit).
//
// Plan SSOT: shared/state/voice_corpus_source_plan_20260417.json
// Pilot: shared/state/voice_pilot_summary_20260417.json
//
// Pipeline per clip:
//   1) say -v <voice> -r <rate_wpm> -o out.aiff "<ko_line>"
//   2) ffmpeg: aiff -> 16kHz mono PCM16 WAV, loudnorm
//   3) ffprobe: duration
//   4) rclone copy -> r2:anima-models/voice_corpus/persona_{id}/tts_{idx:02d}.wav
//
// Voices (verified via `say -v ?` + byte-identity check):
//   - Yuna      — Korean female (the ONLY real Korean TTS voice installed).
//   - Rocko/Grandpa/Eddy/Reed/Flo/Grandma/Sandy/Shelley (ko_KR) all produce
//     byte-identical AIFF output → they are aliases to Yuna's engine.
// Strategy: use Yuna, then apply ffmpeg pitch-shift down (0.82x asetrate +
// atempo 1.21 compensation) for male archetypes to synthesize a lower voice.
// 'Minsu' is NOT a valid macOS voice name on this system — hence the pitch-shift
// workaround. Manifest 'voice' field preserves intended target for future swap.
//
// Hexa quirks avoided:
//   - lists pass-by-value: all mutations via return
//   - struct list aliasing: SoA scalar arrays only
//   - no string slicing on multibyte: all Korean strings treated opaquely
//   - HEXA-FIRST: wraps say/ffmpeg/ffprobe/rclone via exec()

let OUT_ROOT    = "/Users/ghost/Dev/anima/anima-speak/corpus/tts_say"
let R2_PREFIX   = "r2:anima-models/voice_corpus"
let STATE_DIR   = "/Users/ghost/Dev/anima/shared/state"
let STAMP       = "20260417"

// ═══════════════════════════════════════════════════════════════
//  Helpers
// ═══════════════════════════════════════════════════════════════

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

fn ensure_dir(path: string) {
    let _ = exec("mkdir -p " + shell_escape(path))
}

fn file_bytes(path: string) -> int {
    let out = exec("stat -f %z " + shell_escape(path) + " 2>/dev/null").trim()
    if len(out) == 0 { return 0 }
    return to_int(out)
}

fn audio_duration_s(path: string) -> float {
    let out = exec("ffprobe -v error -show_entries format=duration -of csv=p=0 "
                   + shell_escape(path) + " 2>/dev/null").trim()
    if len(out) == 0 { return 0.0 }
    return to_float(out)
}

fn pad2(n: int) -> string {
    if n < 10 { return "0" + to_string(n) }
    return to_string(n)
}

// JSON emit helpers (manual — avoids hexa json quirks on multibyte)
fn json_kv_str(k: string, v: string) -> string {
    return "\"" + k + "\": \"" + v.replace("\"", "\\\"") + "\""
}
fn json_kv_int(k: string, v: int) -> string {
    return "\"" + k + "\": " + to_string(v)
}
fn json_kv_float(k: string, v: float) -> string {
    return "\"" + k + "\": " + to_string(v)
}

fn write_file(path: string, content: string) {
    let tmp = path + ".tmp"
    let cmd = "cat > " + shell_escape(tmp) + " <<'HEXA_EOF'\n" + content + "\nHEXA_EOF"
    let _ = exec(cmd)
    let _ = exec("mv " + shell_escape(tmp) + " " + shell_escape(path))
}

// ═══════════════════════════════════════════════════════════════
//  Voice pipeline: one (persona, idx, line, rate) → WAV → R2
// ═══════════════════════════════════════════════════════════════

// Returns wav_path ("" on failure).
// voice: always "Yuna" in practice (see comment at top); retained as param for
// future (real male voices when available).
// is_male: if true, applies asetrate=22050*0.82 + atempo=1.21 filter to produce
// a ~3-semitone-lower pseudo-male voice while preserving wall-clock duration.
fn synth_one(persona_id: int, persona_name: string, voice: string,
             rate: int, line: string, idx: int, is_male: bool) -> string {
    let pdir = OUT_ROOT + "/persona_" + to_string(persona_id) + "_" + persona_name
    ensure_dir(pdir)
    let aiff = pdir + "/tts_" + pad2(idx) + ".aiff"
    let wav  = pdir + "/tts_" + pad2(idx) + ".wav"

    // 1) say → AIFF (22050 Hz, mono, 16-bit BE)
    let cmd_say = "say -v " + shell_escape(voice)
                + " -r " + to_string(rate)
                + " -o " + shell_escape(aiff)
                + " " + shell_escape(line)
                + " 2>&1"
    let _ = exec(cmd_say)
    if file_bytes(aiff) < 10000 {
        println("  [FAIL] say produced empty aiff for persona " + to_string(persona_id)
                + " idx " + to_string(idx) + " (bytes=" + to_string(file_bytes(aiff)) + ")")
        return ""
    }

    // 2) ffmpeg → 16kHz mono PCM16 WAV with loudnorm
    //    For male archetypes: pitch shift down via asetrate + atempo compensation.
    let mut af = "loudnorm=I=-16:TP=-1.5:LRA=11"
    if is_male {
        // asetrate lower → lower pitch + slower tempo; atempo restores duration.
        // 0.82 * 1.21 ≈ 0.992 (near 1.0) so duration preserved.
        af = "asetrate=22050*0.82,aresample=22050,atempo=1.21,loudnorm=I=-16:TP=-1.5:LRA=11"
    }
    let cmd_ff = "ffmpeg -y -loglevel error -i " + shell_escape(aiff)
               + " -af " + shell_escape(af)
               + " -ac 1 -ar 16000 -c:a pcm_s16le "
               + shell_escape(wav) + " 2>&1"
    let _ = exec(cmd_ff)
    if file_bytes(wav) < 1000 {
        println("  [FAIL] ffmpeg produced empty wav for persona " + to_string(persona_id)
                + " idx " + to_string(idx))
        return ""
    }
    // aiff cleanup
    let _ = exec("rm -f " + shell_escape(aiff))
    return wav
}

// Returns true on success
fn r2_upload(wav_path: string, persona_id: int, idx: int) -> bool {
    let remote = R2_PREFIX + "/persona_" + to_string(persona_id) + "/tts_" + pad2(idx) + ".wav"
    let cmd = "rclone copyto " + shell_escape(wav_path) + " " + shell_escape(remote)
            + " --quiet 2>&1"
    let out = exec(cmd).trim()
    // verify
    let chk = exec("rclone lsf " + shell_escape(remote) + " 2>&1").trim()
    if len(chk) == 0 { return false }
    return true
}

// ═══════════════════════════════════════════════════════════════
//  Persona data (id 10..19), inlined to avoid list pass-by-value
// ═══════════════════════════════════════════════════════════════

fn persona_name_for(id: int) -> string {
    if id == 10 { return "ice_queen" }
    if id == 11 { return "chaebol_heir" }
    if id == 12 { return "pure_heroine" }
    if id == 13 { return "tsundere_oppa" }
    if id == 14 { return "airhead_friend" }
    if id == 15 { return "charismatic_prez" }
    if id == 16 { return "thug_returnee" }
    if id == 17 { return "cold_heiress" }
    if id == 18 { return "gentle_oppa" }
    if id == 19 { return "fallen_antagonist" }
    return "unknown"
}

fn persona_voice_for(id: int) -> string {
    // Only 'Yuna' actually synthesizes Korean on this system; male voice
    // aliases (Rocko/Grandpa/...) are byte-identical to Yuna. We use Yuna
    // universally and synthesize male archetypes via ffmpeg pitch-shift.
    // Manifest still records the intended target voice label for future swap.
    return "Yuna"
}

fn persona_voice_intended(id: int) -> string {
    // Intended voice target — for manifest traceability. Actual synthesis uses Yuna.
    if id == 10 { return "Yuna" }         // ice_queen
    if id == 11 { return "Minsu-like" }   // chaebol_heir
    if id == 12 { return "Yuna" }         // pure_heroine
    if id == 13 { return "Minsu-like" }   // tsundere_oppa
    if id == 14 { return "Yuna" }         // airhead_friend
    if id == 15 { return "Minsu-deep" }   // charismatic_prez
    if id == 16 { return "Minsu-like" }   // thug_returnee
    if id == 17 { return "Yuna" }         // cold_heiress
    if id == 18 { return "Minsu-like" }   // gentle_oppa
    if id == 19 { return "Minsu-deep" }   // fallen_antagonist
    return "Yuna"
}

fn persona_is_male(id: int) -> bool {
    if id == 11 { return true }
    if id == 13 { return true }
    if id == 15 { return true }
    if id == 16 { return true }
    if id == 18 { return true }
    if id == 19 { return true }
    return false
}

