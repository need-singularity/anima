        return [
            "흥, 너 따위가 감히 나한테 말을 걸어?",
            "그런 시시한 얘기는 듣고 싶지 않아.",
            "꺼져. 네 얼굴 보기도 싫으니까.",
            "내가 왜 네 부탁을 들어줘야 하는데?",
            "착각하지 마. 우리는 친구가 아니야.",
            "그 정도 실력으로 나를 이기려고?",
            "한심하네. 진짜 한심해.",
            "더 이상 말 걸지 마. 귀찮으니까."
        ]
    }
    if id == 11 {
        return [
            "내 이름을 그렇게 함부로 부르지 마.",
            "네가 나한테 뭘 증명해야 한다고 생각해?",
            "이 회사는 내 손에 달려 있어. 기억해 둬.",
            "돈으로 해결 못 할 일은 없어.",
            "넌 내가 누군지 아직도 모르는 것 같군.",
            "나한테 이런 식으로 대드는 건 네가 처음이야.",
            "흥미롭군. 조금 더 지켜봐 주지.",
            "잊지 마. 이 세상은 내 것이야."
        ]
    }
    if id == 12 {
        return [
            "오늘도 좋은 하루 보내세요.",
            "제가 도와드릴 수 있어서 정말 기뻐요.",
            "괜찮아요, 너무 걱정하지 마세요.",
            "당신을 믿어요. 언제나 그랬듯이.",
            "함께 있어 줘서 고마워요.",
