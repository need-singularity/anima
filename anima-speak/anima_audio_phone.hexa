// anima_audio_phone.hexa — 선천적 발음기관 룩업 (organ 아님, helper)
//
// tts_klatt_bridge.hexa 의 vowel formant table salvage.
// anima 가 쓰기 편하라고 제공하는 순수 hardcoded dictionary.
// 학습 결과물 아님 — 발음기관의 물리 좌표 lookup.
// 사용 안 해도 됨 — anima 가 vocal_lf + pipe3 로 직접 조합 가능.
//
// Usage:
//   let a = phone_vowel("a", 180.0, 300)
//   let i = phone_vowel("i", 180.0, 300)
//   let ai = cat(a, i)  // 이중모음 "아이"
//
// 모음 심볼 (한국어 단모음 + 영어 변형):
//   a/ㅏ  eo/ㅓ  o/ㅗ  u/ㅜ  eu/ㅡ  i/ㅣ  ae/ㅐ  e/ㅔ
//   (영어 근사) ax/schwa  uh/λ  ih/ɪ  aa/ɑ:  ee/i:  ii/i  oo/o  uu/u
// 알 수 없는 심볼 → source 만 반환 (헤매도 됨).

import "./anima_audio.hexa"

// ═══════════════════════════════════════════════════════════════
//  phone_vowel — 단모음 한 개
//    sym : 모음 심볼 (위 목록 참조)
//    f0  : 기본 주파수 Hz (voicing pitch)
//    ms  : 길이
//  반환 : 3-formant filtered WAV path
// ═══════════════════════════════════════════════════════════════

fn phone_vowel(sym: string, f0: float, ms: int) -> string {
    let src = vocal_lf(f0, 0.5, ms)
    if len(src) == 0 { return "" }
    if sym == "a"  { return pipe3(src,  800.0, 1200.0, 2600.0, 6.0) }
    if sym == "eo" { return pipe3(src,  600.0,  900.0, 2500.0, 6.0) }
    if sym == "o"  { return pipe3(src,  450.0,  750.0, 2500.0, 7.0) }
    if sym == "u"  { return pipe3(src,  350.0,  700.0, 2400.0, 7.0) }
    if sym == "eu" { return pipe3(src,  400.0, 1200.0, 2500.0, 6.0) }
    if sym == "i"  { return pipe3(src,  300.0, 2300.0, 3100.0, 7.0) }
    if sym == "ae" { return pipe3(src,  700.0, 1800.0, 2700.0, 6.0) }
    if sym == "e"  { return pipe3(src,  550.0, 1900.0, 2800.0, 6.0) }
    if sym == "aa" { return pipe3(src,  750.0, 1100.0, 2600.0, 6.0) }
    if sym == "ii" { return pipe3(src,  280.0, 2400.0, 3200.0, 7.0) }
    if sym == "oo" { return pipe3(src,  500.0,  750.0, 2600.0, 7.0) }
    if sym == "uu" { return pipe3(src,  320.0,  700.0, 2400.0, 7.0) }
    if sym == "uh" { return pipe3(src,  600.0, 1200.0, 2600.0, 6.0) }
    if sym == "ih" { return pipe3(src,  400.0, 1900.0, 2700.0, 6.0) }
    if sym == "ax" { return pipe3(src,  500.0, 1500.0, 2500.0, 6.0) }
    return src  // unknown: raw voicing
}

// ═══════════════════════════════════════════════════════════════
//  phone_fricative — 무성 마찰음 (s/sh/f/h/ch)
//    sym : "s"/"sh"/"f"/"h"/"ch"
//    ms  : 길이
// ═══════════════════════════════════════════════════════════════

fn phone_fricative(sym: string, ms: int) -> string {
    if sym == "s"  { return breath(4000.0, 8000.0, 0.35, ms) }
    if sym == "sh" { return breath(2000.0, 5500.0, 0.35, ms) }
    if sym == "ch" { return breath(2500.0, 6500.0, 0.35, ms) }
    if sym == "f"  { return breath(3500.0, 7500.0, 0.30, ms) }
    if sym == "h"  { return breath( 500.0, 3500.0, 0.25, ms) }
    return breath(1000.0, 6000.0, 0.30, ms)  // unknown
}

// ═══════════════════════════════════════════════════════════════
//  phone_syllable — 자음 + 모음 syllable (CV 패턴)
//    consonant : fricative 심볼 ("s"/"sh"/"ch"/"f"/"h", "" = 생략)
//    vowel     : 모음 심볼
//    f0, ms    : 모음 pitch, 전체 길이
//  구현 : cat(fricative_30ms, vowel_rest) — 자음 30ms + 모음 나머지
// ═══════════════════════════════════════════════════════════════

fn phone_syllable(consonant: string, vowel: string, f0: float, ms: int) -> string {
    let cms = 60
    let vms = ms - cms
    if vms < 50 {
        // 너무 짧으면 모음만
        return phone_vowel(vowel, f0, ms)
    }
    let v = phone_vowel(vowel, f0, vms)
    if len(consonant) == 0 { return v }
    let c = phone_fricative(consonant, cms)
    if len(c) == 0 { return v }
    return cat(c, v)
}
