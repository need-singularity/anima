// anima-speak/train_w_ctrl.hexa — W_ctrl 보코더 헤드 학습
//
// 4,608 params: W[12 × 384] — latent(384d) → tanh → ctrl(12d)
// ctrl = {freq_offset, gain} × 6 partials
//
// Loss: spectral matching — ||synth_spec(W@latent) − target_spec||²
//
// CLI:
//   hexa anima-speak/train_w_ctrl.hexa --steps 200 --lr 0.001 \
//        [--corpus anima-speak/corpus] [--out anima-speak/ckpt_w_ctrl.json]
//
// Phases:
//   1. Build training pairs: (latent[384], target_ctrl[12]) per frame
//      - Synthetic mode: F0 contour + harmonic gains from formula
//      - Corpus mode: WAV → DFT → F0 extract → harmonic amplitudes
//   2. Gradient descent on W_ctrl: ∇L = 2(ŷ−y)·sech²(Wx)·x^T
//   3. Save W[12×384] flat row-major to JSON checkpoint
//
// n=6: LATENT_DIM=384=64×6, N_PARTIALS=6, CTRL_DIM=12=6×2

let LATENT_DIM = 384
let N_PARTIALS = 6
let CTRL_DIM   = 12
let TWO_PI     = 6.283185307179586
let BASE_FREQ  = 200.0   // Hz, partial 0 nominal
let SR         = 24000
let HOP        = 240     // 10ms frame

// ═══════════════════════════════════════════════════════
// 1. Synthetic training data — speech-like F0 contours
// ═══════════════════════════════════════════════════════

// Generate N training pairs (latent[384], target_ctrl[12])
// F0 varies 80-400 Hz across frames (speech range)
// Harmonics: gain ∝ 1/(partial+1) with per-frame modulation
fn make_training_data(n_pairs: int) -> [[float]] {
    // Flat array: each "row" is 384 (latent) + 12 (target) = 396 floats
    let row_len = LATENT_DIM + CTRL_DIM
    let mut data = []
    let mut i = 0
    while i < n_pairs {
        let mut row = []

        // F0 for this frame — sweep across speech range
        let t = to_float(i) / to_float(n_pairs)
        let f0 = 100.0 + 200.0 * sin(TWO_PI * t * 3.0 + 0.5) * sin(TWO_PI * t * 0.7)
        // Clamp to speech range
        let mut f0c = f0
        if f0c < 80.0 { f0c = 80.0 }
        if f0c > 400.0 { f0c = 400.0 }

        // Latent: spectrogram-like features from the target F0
        // Place energy peaks at harmonic positions in the 384-bin "spectrum"
        let mut j = 0
        while j < LATENT_DIM {
            let bin_freq = to_float(j) * to_float(SR / 2) / to_float(LATENT_DIM)
            let mut val = 0.0
            let mut p = 0
            while p < N_PARTIALS {
                let harm_freq = f0c * to_float(p + 1)
                let dist = (bin_freq - harm_freq) / 20.0
                val = val + (1.0 / to_float(p + 1)) * exp(-0.5 * dist * dist)
                p = p + 1
            }
            row = row.push(val)
            j = j + 1
        }

        // Target ctrl: 6 × {freq_offset, gain}
        let mut p = 0
        while p < N_PARTIALS {
            let harm_freq = f0c * to_float(p + 1)
            let nominal = BASE_FREQ * to_float(p + 1)
            // freq_offset in [-1, 1]: log2(harm_freq / nominal) clamped
            let LN2 = 0.6931471805599453
            let mut offset = 0.0
            if nominal > 0.0 { offset = log(harm_freq / nominal) / LN2 }
            if offset > 1.0 { offset = 1.0 }
            if offset < -1.0 { offset = -1.0 }
            // gain: 1/(p+1) with slight modulation
            let g = (1.0 / to_float(p + 1)) * (0.8 + 0.4 * sin(TWO_PI * t * 5.0 + to_float(p)))
            let mut gc = g
            if gc > 1.0 { gc = 1.0 }
            if gc < -1.0 { gc = -1.0 }
            row = row.push(offset)
            row = row.push(gc)
            p = p + 1
        }

        data = data.push(row)
        i = i + 1
    }
    return data
}

// ═══════════════════════════════════════════════════════
// 1b. Real corpus data — WAV → spectral features → training pairs
//
// Pure hexa WAV loader (R1/HEXA-FIRST — Python 0 dependency).
// Pipeline: `od -tu1` parses RIFF header chunks → `od -tu2` reads PCM_S16LE
// data block → awk does mono downmix + linear resample → stdout floats.
// hexa reads 240,000 lines (24kHz × 10s) via split+parse_float.
// Benchmark: ~1s vs previous Python 7s on a 17 MB 16 kHz clip.
// ═══════════════════════════════════════════════════════

fn load_wav_samples_text(path: string) -> [float] {
    // POSIX-only pipeline. od strips header bytes as decimal; awk:
    //   1) walks RIFF/WAVE chunks in header (reads first 256 bytes)
    //   2) extracts sr/channels/bits/data_offset/data_len
    //   3) re-invokes od to emit 16-bit LE samples as unsigned decimals
    //   4) sign-corrects (v>=32768 -> v-65536), mono downmix if stereo
    //   5) linear-interp resamples to 24kHz, prints one float per line (<=24000*10)
    // No Python, no .py file, no new host dependency beyond coreutils.
    let cmd = "awk -v WAV='" + path + "' -v TGT_SR=24000 -v TGT_SEC=10 'BEGIN { " +
        "cmd=\"od -An -v -tu1 -N 256 -j 0 \\\"\" WAV \"\\\"\"; hdr=\"\"; " +
        "while ((cmd | getline line)>0) hdr=hdr\" \"line; close(cmd); " +
        "n=split(hdr, tmp, /[ \\t\\n]+/); m=0; " +
        "for (i=1; i<=n; i++) if (tmp[i]!=\"\") { b[m]=tmp[i]+0; m++; } " +
        "off=12; while (off+8<=m) { " +
        "  t=b[off] \"_\" b[off+1] \"_\" b[off+2] \"_\" b[off+3]; " +
        "  csz=b[off+4]+b[off+5]*256+b[off+6]*65536+b[off+7]*16777216; " +
        "  if (t==\"102_109_116_32\") { channels=b[off+10]+b[off+11]*256; " +
        "    sr=b[off+12]+b[off+13]*256+b[off+14]*65536+b[off+15]*16777216; " +
        "    bits=b[off+22]+b[off+23]*256; } " +
        "  if (t==\"100_97_116_97\") { data_byte_off=off+8; data_len=csz; break; } " +
        "  off=off+8+csz; if (csz%2==1) off++; } " +
        "if (bits!=16 || sr==0) exit 1; " +
        "bn=sr*TGT_SEC*2*channels; if (bn>data_len) bn=data_len; " +
        "cmd2=\"od -An -v -tu2 -N \" bn \" -j \" data_byte_off \" \\\"\" WAV \"\\\"\"; " +
        "nsamp=0; " +
        "while ((cmd2 | getline line)>0) { " +
        "  nv=split(line, vals, /[ \\t\\n]+/); " +
        "  for (i=1; i<=nv; i++) { if (vals[i]==\"\") continue; " +
        "    v=vals[i]+0; if (v>=32768) v-=65536; nsamp++; s[nsamp]=v; } } " +
        "close(cmd2); " +
        "if (channels>1) { nf=int(nsamp/channels); " +
        "  for (f=0; f<nf; f++) { acc=0; for (c=0; c<channels; c++) acc+=s[f*channels+c+1]; mono[f+1]=acc/channels; } " +
        "  nm=nf; } else { for (i=1; i<=nsamp; i++) mono[i]=s[i]; nm=nsamp; } " +
        "n_out=int(nm*TGT_SR/sr); ratio=sr/TGT_SR; inv=1.0/32768.0; " +
        "for (i=0; i<n_out; i++) { sp=i*ratio; idx=int(sp)+1; " +
        "  if (idx+1<=nm) { frac=sp-int(sp); printf \"%.6f\\n\", (mono[idx]*(1-frac)+mono[idx+1]*frac)*inv; } " +
        "  else if (idx<=nm) printf \"%.6f\\n\", mono[idx]*inv; } " +
        "}' 2>/dev/null"
    let raw = exec(cmd)
    // Bulk split — avoids O(n²) substring/concat over 240K-line stdout.
    let lines = raw.split("\n")
    let nl = len(lines)
    let mut samples = []
    let mut i = 0
    while i < nl {
        let ln = lines[i]
        if len(ln) > 0 {
            samples = samples.push(parse_float(ln))
        }
        i = i + 1
    }
    return samples
}

// Simple F0 estimation via zero-crossing rate (ZCR)
// Returns estimated Hz for a window of samples
fn estimate_f0_zcr(window: [float], sr: int) -> float {
    let n = len(window)
    if n < 2 { return 150.0 }
    let mut crossings = 0
    let mut i = 1
    while i < n {
        if (window[i-1] >= 0.0 && window[i] < 0.0) || (window[i-1] < 0.0 && window[i] >= 0.0) {
            crossings = crossings + 1
        }
        i = i + 1
    }
    if crossings < 2 { return 150.0 }
    // F0 ≈ sr * crossings / (2 * n)
    let f0 = to_float(sr) * to_float(crossings) / (2.0 * to_float(n))
    if f0 < 50.0 { return 50.0 }
    if f0 > 500.0 { return 500.0 }
    return f0
}

// RMS energy of a window
fn rms_energy(window: [float]) -> float {
    let n = len(window)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + window[i] * window[i]
        i = i + 1
    }
    return sqrt(s / to_float(n))
}

// Build training pairs from real audio samples
fn make_corpus_data(samples: [float], max_pairs: int) -> [[float]] {
    let n_total = len(samples)
    let frame_len = 240  // HOP at 24kHz
    let n_frames = n_total / frame_len
    let mut n_use = n_frames
    if n_use > max_pairs { n_use = max_pairs }

    let mut data = []
    let mut f = 0
    while f < n_use {
        let start = f * frame_len
        // Extract window
        let mut window = []
        let mut j = 0
        while j < frame_len {
            if start + j < n_total {
                window = window.push(samples[start + j])
            } else {
                window = window.push(0.0)
            }
            j = j + 1
        }

        // Pseudo-latent: spectral magnitude bins
        // Simplified: use windowed sample values + their products as features
        // Pad/truncate to LATENT_DIM
        let mut latent = []
        j = 0
        while j < LATENT_DIM {
            if j < frame_len {
                latent = latent.push(window[j])
            } else {
                // Mirror/extend
                let idx = j % frame_len
                latent = latent.push(window[idx] * 0.5)
            }
            j = j + 1
        }

        // Target ctrl: estimate F0 + harmonic gains
        let f0 = estimate_f0_zcr(window, SR)
        let energy = rms_energy(window)
        let LN2 = 0.6931471805599453
        let mut ctrl = []
        let mut p = 0
        while p < N_PARTIALS {
            let harm_freq = f0 * to_float(p + 1)
            let nominal = BASE_FREQ * to_float(p + 1)
            let mut offset = 0.0
            if nominal > 0.0 { offset = log(harm_freq / nominal) / LN2 }
            if offset > 1.0 { offset = 1.0 }
            if offset < -1.0 { offset = -1.0 }
            // Gain: decaying harmonics scaled by energy
            let g = energy * 2.0 / to_float(p + 1)
            let mut gc = g
            if gc > 1.0 { gc = 1.0 }
            if gc < -1.0 { gc = -1.0 }
            ctrl = ctrl.push(offset)
            ctrl = ctrl.push(gc)
            p = p + 1
        }

        // Combine latent + ctrl into one row
        let mut row = latent
        j = 0
        while j < CTRL_DIM { row = row.push(ctrl[j]); j = j + 1 }
        data = data.push(row)
        f = f + 1
    }
    return data
}

// Scan corpus directory for WAV files via shell
fn list_corpus_wavs(corpus_dir: string) -> [string] {
    let raw = exec("find " + corpus_dir + " -name '*.wav' -type f 2>/dev/null | head -20")
    let lines = raw.split("\n")
    let nl = len(lines)
    let mut paths = []
    let mut i = 0
    while i < nl {
        let ln = lines[i]
        if len(ln) > 0 { paths = paths.push(ln) }
        i = i + 1
    }
    return paths
}

// ═══════════════════════════════════════════════════════
// 2. Forward + Loss + Backward
// ═══════════════════════════════════════════════════════

fn tanh_f(x: float) -> float {
    return tanh(x)
}

fn sech2(x: float) -> float {
    let t = tanh(x)
    return 1.0 - t * t
}

// Forward: y_hat = tanh(W @ x). Native matvec (single C-call, no interp loop).
fn forward(W: [float], x: [float]) -> [float] {
    let z = matvec(W, x, CTRL_DIM, LATENT_DIM)
    let mut y = []
    let mut i = 0
    while i < CTRL_DIM {
        y = y.push(tanh_f(z[i]))
        i = i + 1
    }
    return y
}

// Forward into pre-allocated buffers (zero-alloc hot path).
// y_buf, z_buf must have length >= CTRL_DIM (pre-filled on first call).
// Inline matvec avoids heap-allocating a new 12-element array per call.
fn forward_into(W: [float], x: [float], y_buf: [float], z_buf: [float]) -> [float] {
    // Inline W @ x → z_buf (avoids matvec heap alloc)
    let mut i = 0
    while i < CTRL_DIM {
        let mut acc = 0.0
        let mut j = 0
        while j < LATENT_DIM {
            acc = acc + W[i * LATENT_DIM + j] * x[j]
            j = j + 1
        }
        z_buf[i] = acc
        i = i + 1
    }
    i = 0
    while i < CTRL_DIM {
        y_buf[i] = tanh_f(z_buf[i])
        i = i + 1
    }
    return y_buf
}

// MSE loss: mean of (y_hat - y_target)^2
fn mse_loss(y_hat: [float], y_target: [float]) -> float {
    let n = len(y_hat)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = y_hat[i] - y_target[i]
        s = s + d * d
        i = i + 1
    }
    return s / to_float(n)
}

// Gradient: dL/dW[i,j] = (2/N) * (y_hat[i] - y[i]) * sech²(z[i]) * x[j]
// where z = W @ x (pre-activation)
fn backward(W: [float], x: [float], y_target: [float]) -> [float] {
    // Compute z = W @ x (pre-activation) via native matvec.
    let z = matvec(W, x, CTRL_DIM, LATENT_DIM)

    // Compute gradient
    let mut grad = []
    let scale = 2.0 / to_float(CTRL_DIM)
    let mut i = 0
    while i < CTRL_DIM {
        let err = tanh_f(z[i]) - y_target[i]
        let s2 = sech2(z[i])
        let coeff = scale * err * s2
        let mut j = 0
        while j < LATENT_DIM {
            grad = grad.push(coeff * x[j])
            j = j + 1
        }
        i = i + 1
    }
    return grad
}

// Accumulate gradient directly into grad_acc (zero-alloc hot path).
// z_buf must have length >= CTRL_DIM (pre-filled on first call).
// Avoids creating temporary 4608-element grad array + 12-element matvec array
// per data sample. This alone saves ~74 MB/step of leaked heap memory.
fn backward_acc(W: [float], x: [float], y_target: [float], grad_acc: [float], z_buf: [float]) {
    // Inline W @ x → z_buf (avoids matvec heap alloc)
    let mut i = 0
    while i < CTRL_DIM {
        let mut acc = 0.0
        let mut j = 0
        while j < LATENT_DIM {
            acc = acc + W[i * LATENT_DIM + j] * x[j]
            j = j + 1
        }
        z_buf[i] = acc
        i = i + 1
    }
    let scale = 2.0 / to_float(CTRL_DIM)
    i = 0
    while i < CTRL_DIM {
        let err = tanh_f(z_buf[i]) - y_target[i]
        let s2 = sech2(z_buf[i])
        let coeff = scale * err * s2
        let mut j = 0
        while j < LATENT_DIM {
            grad_acc[i * LATENT_DIM + j] = grad_acc[i * LATENT_DIM + j] + coeff * x[j]
            j = j + 1
        }
        i = i + 1
    }
}

// ═══════════════════════════════════════════════════════
// 3. Training loop
// ═══════════════════════════════════════════════════════

fn init_weights() -> [float] {
    // Xavier-like init: W[i,j] = small sinusoidal pattern
    let mut W = []
    let n = CTRL_DIM * LATENT_DIM
    let scale = 1.0 / to_float(LATENT_DIM)
    let mut k = 0
    while k < n {
        let v = scale * sin(to_float(k) * 0.0137 + 0.5) * 0.1
        W = W.push(v)
        k = k + 1
    }
    return W
}

fn train(data: [[float]], steps: int, lr: float) -> [float] {
    let mut W = init_weights()
    let n_data = len(data)
    let n_w = len(W)

    println("[train] params=" + to_string(n_w) + " data=" + to_string(n_data)
            + " steps=" + to_string(steps) + " lr=" + to_string(lr))

    // Pre-allocate reusable buffers ONCE — avoids O(steps * n_data) array
    // allocations that leak ~74 MB/step (no GC in hexa native runtime).
    // Without this, the process OOMs around step 19K on 100K-step runs.
    let mut grad_acc = []
    let mut k = 0
    while k < n_w { grad_acc = grad_acc.push(0.0); k = k + 1 }

    // Pre-allocate x/y/y_hat/z extraction buffers
    let mut x_buf = []
    let mut j = 0
    while j < LATENT_DIM { x_buf = x_buf.push(0.0); j = j + 1 }
    let mut y_buf = []
    j = 0
    while j < CTRL_DIM { y_buf = y_buf.push(0.0); j = j + 1 }
    let mut yhat_buf = []
    j = 0
    while j < CTRL_DIM { yhat_buf = yhat_buf.push(0.0); j = j + 1 }
    // z_buf: pre-activation buffer shared by forward_into + backward_acc
    let mut z_buf = []
    j = 0
    while j < CTRL_DIM { z_buf = z_buf.push(0.0); j = j + 1 }

    let mut step = 0
    while step < steps {
        // Zero grad_acc in-place (reuse allocation)
        k = 0
        while k < n_w { grad_acc[k] = 0.0; k = k + 1 }

        let mut total_loss = 0.0
        let mut d = 0
        while d < n_data {
            let row = data[d]
            // Extract latent[0..384] into pre-allocated x_buf
            j = 0
            while j < LATENT_DIM { x_buf[j] = row[j]; j = j + 1 }
            // Extract target[384..396] into pre-allocated y_buf
            j = 0
            while j < CTRL_DIM { y_buf[j] = row[LATENT_DIM + j]; j = j + 1 }

            // Forward pass into pre-allocated buffers (zero heap alloc)
            yhat_buf = forward_into(W, x_buf, yhat_buf, z_buf)
            total_loss = total_loss + mse_loss(yhat_buf, y_buf)

            // Backward pass — accumulate directly into grad_acc (zero heap alloc)
            backward_acc(W, x_buf, y_buf, grad_acc, z_buf)
            d = d + 1
        }

        // SGD update: W -= lr * grad_acc / n_data
        let inv_n = 1.0 / to_float(n_data)
        k = 0
        while k < n_w {
            W[k] = W[k] - lr * grad_acc[k] * inv_n
            k = k + 1
        }

        let avg_loss = total_loss / to_float(n_data)
        if step % 20 == 0 || step == steps - 1 {
            println("[train] step=" + to_string(step)
                    + " loss=" + to_string(avg_loss))
        }
        step = step + 1
    }

    return W
}

// ═══════════════════════════════════════════════════════
// 4. Checkpoint save (JSON flat array)
// ═══════════════════════════════════════════════════════

fn save_checkpoint(path: string, W: [float]) -> bool {
    let mut body = "{\n"
    body = body + "  \"name\": \"w_ctrl\",\n"
    body = body + "  \"shape\": [" + to_string(CTRL_DIM) + ", " + to_string(LATENT_DIM) + "],\n"
    body = body + "  \"params\": " + to_string(len(W)) + ",\n"
    body = body + "  \"data\": ["
    let mut i = 0
    while i < len(W) {
        if i > 0 { body = body + "," }
        // 6 decimal places
        body = body + to_string(W[i])
        i = i + 1
    }
    body = body + "]\n}\n"
    write_file(path, body)
    println("[train] saved " + to_string(len(W)) + " params → " + path)
    return true
}

// ═══════════════════════════════════════════════════════
// 5. Evaluation — synthesize with trained W and report
// ═══════════════════════════════════════════════════════

fn eval_trained(W: [float], data: [[float]]) -> float {
    let mut total_loss = 0.0
    let n = len(data)
    let mut i = 0
    while i < n {
        let row = data[i]
        let mut x = []
        let mut j = 0
        while j < LATENT_DIM { x = x.push(row[j]); j = j + 1 }
        let mut y = []
        j = 0
        while j < CTRL_DIM { y = y.push(row[LATENT_DIM + j]); j = j + 1 }
        let y_hat = forward(W, x)
        total_loss = total_loss + mse_loss(y_hat, y)
        i = i + 1
    }
    return total_loss / to_float(n)
}

// ═══════════════════════════════════════════════════════
// 6. CLI
// ═══════════════════════════════════════════════════════

fn main() {
    println("train_w_ctrl — HEXA-SPEAK Mk.III vocoder head trainer")
    println("  params: " + to_string(CTRL_DIM * LATENT_DIM) + " (W[" + to_string(CTRL_DIM) + "×" + to_string(LATENT_DIM) + "])")

    let av = args()
    let mut steps = 200
    let mut lr = 0.001
    let mut n_data = 100
    let mut out_path = "anima-speak/ckpt_w_ctrl.json"
    let mut corpus_dir = ""

    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--steps" {
            if i + 1 < len(av) { steps = av[i + 1].parse_int() }
            i = i + 2
        } else if a == "--lr" {
            if i + 1 < len(av) { lr = to_float(av[i + 1].parse_int()) / 1000.0 }
            i = i + 2
        } else if a == "--data" {
            if i + 1 < len(av) { n_data = av[i + 1].parse_int() }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < len(av) { out_path = av[i + 1] }
            i = i + 2
        } else if a == "--corpus" {
            if i + 1 < len(av) { corpus_dir = av[i + 1] }
            i = i + 2
        } else {
            i = i + 1
        }
    }

    let mut data = []
    if len(corpus_dir) > 0 {
        // Real corpus mode: load WAVs, extract features
        println("[train] corpus mode: " + corpus_dir)
        let wavs = list_corpus_wavs(corpus_dir)
        println("[train] found " + to_string(len(wavs)) + " WAV files")
        let pairs_per_wav = n_data / len(wavs)
        let mut w = 0
        while w < len(wavs) {
            println("[train] loading " + wavs[w] + " ...")
            let samples = load_wav_samples_text(wavs[w])
            println("[train]   " + to_string(len(samples)) + " samples")
            let pairs = make_corpus_data(samples, pairs_per_wav)
            println("[train]   " + to_string(len(pairs)) + " training pairs")
            let mut p = 0
            while p < len(pairs) { data = data.push(pairs[p]); p = p + 1 }
            w = w + 1
        }
        println("[train] total corpus pairs: " + to_string(len(data)))
    } else {
        // Synthetic mode
        println("[train] synthetic mode: " + to_string(n_data) + " pairs")
        data = make_training_data(n_data)
    }
    println("[train] data ready: " + to_string(len(data)) + " pairs × " + to_string(LATENT_DIM + CTRL_DIM) + "d")

    // Pre-training eval (random init baseline)
    let W_init = init_weights()
    let loss_init = eval_trained(W_init, data)
    println("[train] init loss=" + to_string(loss_init))

    // Train
    let W = train(data, steps, lr)

    // Post-training eval
    let loss_final = eval_trained(W, data)
    println("[train] final loss=" + to_string(loss_final))
    println("[train] improvement=" + to_string(loss_init / loss_final) + "x")

    // Save
    let _ = save_checkpoint(out_path, W)

    // Sample: show first frame's pred vs target
    if len(data) > 0 {
        let row = data[0]
        let mut x = []
        let mut j = 0
        while j < LATENT_DIM { x = x.push(row[j]); j = j + 1 }
        let y_hat = forward(W, x)
        println("[train] sample pred: " + to_string(y_hat[0]) + ", " + to_string(y_hat[1])
                + ", " + to_string(y_hat[2]) + ", " + to_string(y_hat[3]))
        println("[train] sample true: " + to_string(row[LATENT_DIM]) + ", " + to_string(row[LATENT_DIM + 1])
                + ", " + to_string(row[LATENT_DIM + 2]) + ", " + to_string(row[LATENT_DIM + 3]))
    }
}
