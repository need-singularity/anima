// ω-audio-6 alloc+indexed-write bench.
// Measures: vocal_hexa, vocal_lf_hexa, breath_hexa, chain (vocal->pipe).
// Captures byte hash to verify deterministic / no new drift vs audio-5.
import "anima_audio.hexa"

let R = 5

fn _wav_hash(path: string) -> string {
    let s = exec("shasum -a 256 " + path + " 2>/dev/null | awk '{print $1}'").trim()
    return s
}

fn _bench_organ(label: string, fn_id: int, freq: float) -> int {
    // fn_id: 0=vocal_hexa, 1=vocal_lf_hexa, 2=breath_hexa, 3=chain
    let _w = if fn_id == 0 { vocal_hexa(freq, 0.5, 100) }
             else if fn_id == 1 { vocal_lf_hexa(freq, 0.5, 100) }
             else if fn_id == 2 { breath_hexa(800.0, 4000.0, 0.5, 100) }
             else { vocal_hexa(freq, 0.5, 100) }
    let mut sum = 0
    let mut i = 0
    while i < R {
        let t0 = time_ms()
        let p = if fn_id == 0 { vocal_hexa(freq, 0.5, 100) }
                else if fn_id == 1 { vocal_lf_hexa(freq, 0.5, 100) }
                else if fn_id == 2 { breath_hexa(800.0, 4000.0, 0.5, 100) }
                else {
                    let v = vocal_hexa(freq, 0.5, 100)
                    pipe_hexa(v, 700.0, 1100.0, 6.0)
                }
        let t1 = time_ms()
        let dt = t1 - t0
        println(label + " run " + to_string(i+1) + ": " + to_string(dt) + " ms")
        sum = sum + dt
        i = i + 1
    }
    let mean = sum / R
    println(label + " mean: " + to_string(mean) + " ms")
    return mean
}

println("=== ω-audio-6 alloc+indexed-write bench ===")

// === HASH CAPTURE (drift check vs audio-5) ===
let hp_v = vocal_hexa(440.0, 0.5, 100)
let hp_lf = vocal_lf_hexa(220.0, 0.5, 100)
let hp_b = breath_hexa(800.0, 4000.0, 0.5, 100)
let hv = vocal_hexa(440.0, 0.5, 100)
let hp = pipe_hexa(hv, 700.0, 1100.0, 6.0)
let h_v = _wav_hash(hp_v)
let h_lf = _wav_hash(hp_lf)
let h_b = _wav_hash(hp_b)
let h_p = _wav_hash(hp)
println("HASH vocal_hexa(440,0.5,100): " + h_v)
println("HASH vocal_lf_hexa(220,0.5,100): " + h_lf)
println("HASH breath_hexa(800,4000,0.5,100): " + h_b)
println("HASH chain(vocal->pipe): " + h_p)

// === BENCH ===
let m_v = _bench_organ("vocal", 0, 440.0)
let m_lf = _bench_organ("vocal_lf", 1, 220.0)
let m_b = _bench_organ("breath", 2, 0.0)
let m_chain = _bench_organ("chain", 3, 440.0)

println("---")
println("BENCH_RESULT vocal_ms=" + to_string(m_v)
        + " vocal_lf_ms=" + to_string(m_lf)
        + " breath_ms=" + to_string(m_b)
        + " chain_ms=" + to_string(m_chain))
println("HASHES vocal=" + h_v + " vocal_lf=" + h_lf + " breath=" + h_b + " chain=" + h_p)
