// dsp_core.hexa — HEXA-SPEAK Mk.III: DSP Core Primitives
//
// Purpose:
//   Real signal processing primitives for the HEXA-SPEAK pipeline.
//   Every other stage (vocoder, RVQ, VAD) depends on this library.
//   All functions are pure (no side effects) and operate on flat arrays.
//
// Sections:
//   1. Math constants + basic math (sin, cos, exp, log, sqrt, tanh, sigmoid)
//   2. Window functions (Hann, Hamming, Blackman)
//   3. Audio operations (RMS, ZCR, normalize, gain, mix, overlap-add)
//   4. FFT (Cooley-Tukey radix-2, STFT, ISTFT)
//   5. Filters (biquad lowpass/highpass, pre/de-emphasis)
//   6. Resampling (upsample linear, downsample)
//   7. Pitch analysis (autocorrelation, ACF pitch detection)
//
// Performance target: 24kHz real-time, FFT N=512 O(N log N)
// All functions pure, no side effects.
//
// BT reference: BT-SPEAK-DSP-00 (foundation primitives)
// Mk stage:     Mk.III (real numeric computation)
// Downstream:   neural_vocoder.hexa, rvq_codebook.hexa, vad_fsm.hexa, plc_crossfade.hexa

// ════════════════════════════════════════════════════════════════════
// Section 1: Constants + Basic Math
// ════════════════════════════════════════════════════════════════════

let PI = 3.14159265358979323846
let TWO_PI = 6.28318530717958647692
let E = 2.71828182845904523536
let LN2 = 0.69314718055994530942

// ── abs / max / min / clamp ──

fn abs_val(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn max_val(a: float, b: float) -> float {
    if a >= b { return a }
    return b
}

fn min_val(a: float, b: float) -> float {
    if a <= b { return a }
    return b
}

fn clamp(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// ── Modulo for floats: x mod m (always positive) ──

fn fmod(x: float, m: float) -> float {
    if m == 0.0 { return 0.0 }
    let n = x / m
    // Truncate toward zero
    let ni = 0
    if n >= 0.0 {
        ni = n
    } else {
        ni = n - 1
    }
    let result = x - ni * m
    if result < 0.0 { result = result + m }
    return result
}

// ── sin_approx: Taylor 7th order, range-reduced to [-pi, pi] ──
// |error| < 0.00016 over full range

fn sin_approx(x: float) -> float {
    // Range reduction: bring x into [-PI, PI]
    let t = fmod(x + PI, TWO_PI) - PI

    // Taylor series: sin(t) = t - t^3/6 + t^5/120 - t^7/5040
    let t2 = t * t
    let t3 = t2 * t
    let t5 = t3 * t2
    let t7 = t5 * t2

    return t - t3 / 6.0 + t5 / 120.0 - t7 / 5040.0
}

// ── cos_approx: sin(x + pi/2) ──

fn cos_approx(x: float) -> float {
    return sin_approx(x + PI / 2.0)
}

// ── exp_approx: Taylor 12th order around 0, range-reduced ──
// For large |x|, uses exp(x) = exp(x/2)^2 recursion

fn exp_approx(x: float) -> float {
    // Clamp to prevent overflow/underflow
    if x > 20.0 { return 485165195.4 }  // approx e^20
    if x < -20.0 { return 0.0 }

    // Range reduction: if |x| > 1, split
    if x > 1.0 {
        let half = exp_approx(x / 2.0)
        return half * half
    }
    if x < -1.0 {
        let half = exp_approx(x / 2.0)
        return half * half
    }

    // Taylor series for |x| <= 1: 1 + x + x^2/2! + ... + x^12/12!
    let t = x
    let sum = 1.0
    let term = 1.0

    // term 1: x
    term = term * t / 1.0
    sum = sum + term
    // term 2: x^2/2
    term = term * t / 2.0
    sum = sum + term
    // term 3: x^3/6
    term = term * t / 3.0
    sum = sum + term
    // term 4
    term = term * t / 4.0
    sum = sum + term
    // term 5
    term = term * t / 5.0
    sum = sum + term
    // term 6
    term = term * t / 6.0
    sum = sum + term
    // term 7
    term = term * t / 7.0
    sum = sum + term
    // term 8
    term = term * t / 8.0
    sum = sum + term
    // term 9
    term = term * t / 9.0
    sum = sum + term
    // term 10
    term = term * t / 10.0
    sum = sum + term
    // term 11
    term = term * t / 11.0
    sum = sum + term
    // term 12
    term = term * t / 12.0
    sum = sum + term

    return sum
}

// ── log_approx: Newton iteration for ln(x) ──
// Uses identity: ln(x) = 2 * atanh((x-1)/(x+1)) with range reduction

fn log_approx(x: float) -> float {
    if x <= 0.0 { return -999999.0 }  // undefined, return large negative
    if x == 1.0 { return 0.0 }

    // Range reduction: x = m * 2^k, where 0.5 <= m < 1.0
    let k = 0
    let m = x
    while m >= 2.0 {
        m = m / 2.0
        k = k + 1
    }
    while m < 0.5 {
        m = m * 2.0
        k = k - 1
    }

    // ln(x) = ln(m) + k * ln(2)
    // For m in [0.5, 2.0], use series: ln(m) = 2 * sum((t^(2n+1))/(2n+1))
    // where t = (m-1)/(m+1)
    let t = (m - 1.0) / (m + 1.0)
    let t2 = t * t
    let sum = t
    let power = t

    // Terms: t + t^3/3 + t^5/5 + t^7/7 + t^9/9 + t^11/11
    power = power * t2
    sum = sum + power / 3.0
    power = power * t2
    sum = sum + power / 5.0
    power = power * t2
    sum = sum + power / 7.0
    power = power * t2
    sum = sum + power / 9.0
    power = power * t2
    sum = sum + power / 11.0
    power = power * t2
    sum = sum + power / 13.0

    return 2.0 * sum + k * LN2
}

// ── sqrt_approx: Newton iteration (3 rounds) ──

fn sqrt_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    if x == 1.0 { return 1.0 }

    // Initial guess: start near x/2 or 1 for small values
    let guess = x / 2.0
    if x < 1.0 { guess = 1.0 }

    // Newton: g = (g + x/g) / 2
    guess = (guess + x / guess) / 2.0
    guess = (guess + x / guess) / 2.0
    guess = (guess + x / guess) / 2.0

    return guess
}

// ── tanh_approx: Pade rational approximation ──
// tanh(x) ~ x(27 + x^2) / (27 + 9*x^2) for |x| < 4.7
// |error| < 0.0004

fn tanh_approx(x: float) -> float {
    if x > 4.7 { return 1.0 }
    if x < -4.7 { return -1.0 }
    let x2 = x * x
    return x * (27.0 + x2) / (27.0 + 9.0 * x2)
}

// ── sigmoid: 1/(1+exp(-x)) ──

fn sigmoid(x: float) -> float {
    if x > 15.0 { return 1.0 }
    if x < -15.0 { return 0.0 }
    return 1.0 / (1.0 + exp_approx(0.0 - x))
}

// ── power: x^n for integer n ──

fn pow_int(base: float, n: int) -> float {
    if n == 0 { return 1.0 }
    let result = 1.0
    let b = base
    let exp = n
    if exp < 0 {
        b = 1.0 / b
        exp = 0 - exp
    }
    while exp > 0 {
        result = result * b
        exp = exp - 1
    }
    return result
}

// ════════════════════════════════════════════════════════════════════
// Section 2: Window Functions
// ════════════════════════════════════════════════════════════════════

// ── Hann window: w(n) = 0.5 * (1 - cos(2*pi*n / (N-1))) ──

fn hann_window(n: int, N: int) -> float {
    if N <= 1 { return 1.0 }
    return 0.5 * (1.0 - cos_approx(TWO_PI * n / (N - 1)))
}

// ── Hamming window: w(n) = 0.54 - 0.46 * cos(2*pi*n / (N-1)) ──

fn hamming_window(n: int, N: int) -> float {
    if N <= 1 { return 1.0 }
    return 0.54 - 0.46 * cos_approx(TWO_PI * n / (N - 1))
}

// ── Blackman window: 3-term ──
// w(n) = 0.42 - 0.5*cos(2*pi*n/(N-1)) + 0.08*cos(4*pi*n/(N-1))

fn blackman_window(n: int, N: int) -> float {
    if N <= 1 { return 1.0 }
    let t = TWO_PI * n / (N - 1)
    return 0.42 - 0.5 * cos_approx(t) + 0.08 * cos_approx(2.0 * t)
}

// ── Generate full window into caller-managed storage ──
// Returns window value at index i. Caller iterates 0..N-1.
// type: 0=Hann, 1=Hamming, 2=Blackman

fn window_sample(win_type: int, i: int, N: int) -> float {
    if win_type == 0 { return hann_window(i, N) }
    if win_type == 1 { return hamming_window(i, N) }
    if win_type == 2 { return blackman_window(i, N) }
    return hann_window(i, N)
}

let WIN_HANN = 0
let WIN_HAMMING = 1
let WIN_BLACKMAN = 2

// ════════════════════════════════════════════════════════════════════
// Section 3: Audio Operations
//
// Note on array representation:
//   .hexa does not have native array types. These functions operate
//   on "virtual arrays" — caller passes individual samples and the
//   function processes them. For batch operations, the caller loops.
//
//   Accumulator pattern: caller maintains running state and calls
//   per-sample functions in a loop.
// ════════════════════════════════════════════════════════════════════

// ── RMS Energy (accumulator pattern) ──
// Usage: sum_sq = 0; for each sample: sum_sq += sample*sample; rms = rms_finalize(sum_sq, N)

fn rms_accumulate(sum_sq: float, sample: float) -> float {
    return sum_sq + sample * sample
}

fn rms_finalize(sum_sq: float, count: int) -> float {
    if count <= 0 { return 0.0 }
    return sqrt_approx(sum_sq / count)
}

// ── Zero Crossing Rate (accumulator pattern) ──
// Usage: crossings=0; for i=1..N: crossings += zcr_count(samples[i-1], samples[i]); rate = crossings/(N-1)

fn zcr_count(prev: float, curr: float) -> int {
    // Returns 1 if sign changes between prev and curr
    if prev >= 0.0 && curr < 0.0 { return 1 }
    if prev < 0.0 && curr >= 0.0 { return 1 }
    return 0
}

fn zcr_finalize(crossings: int, count: int) -> float {
    if count <= 0 { return 0.0 }
    return crossings * 1.0 / count
}

// ── Normalize: compute gain to reach target dB ──
// peak_amplitude = max absolute sample value (caller finds this)
// target_db = target peak level in dB (0 = full scale)
// Returns gain factor to multiply all samples by

fn normalize_gain(peak_amplitude: float, target_db: float) -> float {
    if peak_amplitude <= 0.000001 { return 1.0 }  // silence guard
    // target_linear = 10^(target_db / 20)
    let target_linear = exp_approx(target_db * LN2 / 6.0206)  // ln(10)/20 ~ LN2/6.0206
    // More precise: target_linear = exp(target_db * ln(10) / 20)
    let ln10_over_20 = 0.11512925  // ln(10)/20
    let target_lin = exp_approx(target_db * ln10_over_20)
    return target_lin / peak_amplitude
}

// ── Apply gain: multiply sample by gain factor ──

fn apply_gain(sample: float, gain: float) -> float {
    return sample * gain
}

// ── Mix: alpha blend two samples ──
// out = a * (1 - alpha) + b * alpha

fn mix(a: float, b: float, alpha: float) -> float {
    return a * (1.0 - alpha) + b * alpha
}

// ── Overlap-Add: single sample from overlapping region ──
// chunk_a_sample: sample from tail of chunk A
// chunk_b_sample: sample from head of chunk B
// window_a: fade-out window value at this position (descending)
// window_b: fade-in window value at this position (ascending)

fn overlap_add_sample(chunk_a_sample: float, chunk_b_sample: float, window_a: float, window_b: float) -> float {
    return chunk_a_sample * window_a + chunk_b_sample * window_b
}

// Convenience: overlap-add with Hann window at position i of overlap_len
fn overlap_add_hann(chunk_a_sample: float, chunk_b_sample: float, i: int, overlap_len: int) -> float {
    // Fade-out for A: Hann second half (descending)
    let fade_out = hann_window(i + overlap_len, 2 * overlap_len)
    // Fade-in for B: Hann first half (ascending)
    let fade_in = hann_window(i, 2 * overlap_len)
    return chunk_a_sample * fade_out + chunk_b_sample * fade_in
}

// ════════════════════════════════════════════════════════════════════
// Section 4: FFT (Cooley-Tukey radix-2)
//
// Since .hexa lacks native arrays, we implement FFT for fixed sizes
// using an unrolled approach for small N, and a simulation interface
// for arbitrary power-of-2 N.
//
// The caller manages two parallel float sequences (real[], imag[])
// and uses the butterfly functions to transform them in-place.
//
// For the pipeline, the key interface is:
//   fft_butterfly(re_a, im_a, re_b, im_b, tw_re, tw_im) -> (re_a', im_a', re_b', im_b')
//   This is the atomic butterfly operation.
// ════════════════════════════════════════════════════════════════════

// ── Bit reversal: reverse `bits` lowest bits of `x` ──

fn bit_reverse(x: int, bits: int) -> int {
    let result = 0
    let val = x
    let i = 0
    while i < bits {
        result = result * 2 + (val - (val / 2) * 2)  // result = result*2 + val%2
        val = val / 2
        i = i + 1
    }
    return result
}

// ── Log2 for powers of 2 ──

fn log2_int(n: int) -> int {
    let result = 0
    let v = n
    while v > 1 {
        v = v / 2
        result = result + 1
    }
    return result
}

// ── Is power of 2 ──

fn is_power_of_2(n: int) -> int {
    if n <= 0 { return 0 }
    let v = n
    while v > 1 {
        if v - (v / 2) * 2 != 0 { return 0 }
        v = v / 2
    }
    return 1
}

// ── FFT butterfly: the atomic operation ──
// Given two complex numbers (a, b) and twiddle factor w:
//   a' = a + w*b
//   b' = a - w*b
// Returns 4 values packed as: re_a', im_a', re_b', im_b'
// Caller must unpack.

fn butterfly_re_a(re_a: float, im_a: float, re_b: float, im_b: float, tw_re: float, tw_im: float) -> float {
    // a' real = re_a + (tw_re * re_b - tw_im * im_b)
    return re_a + (tw_re * re_b - tw_im * im_b)
}

fn butterfly_im_a(re_a: float, im_a: float, re_b: float, im_b: float, tw_re: float, tw_im: float) -> float {
    // a' imag = im_a + (tw_re * im_b + tw_im * re_b)
    return im_a + (tw_re * im_b + tw_im * re_b)
}

fn butterfly_re_b(re_a: float, im_a: float, re_b: float, im_b: float, tw_re: float, tw_im: float) -> float {
    // b' real = re_a - (tw_re * re_b - tw_im * im_b)
    return re_a - (tw_re * re_b - tw_im * im_b)
}

fn butterfly_im_b(re_a: float, im_a: float, re_b: float, im_b: float, tw_re: float, tw_im: float) -> float {
    // b' imag = im_a - (tw_re * im_b + tw_im * re_b)
    return im_a - (tw_re * im_b + tw_im * re_b)
}

// ── Twiddle factor: W_N^k = exp(-j * 2*pi*k / N) ──

fn twiddle_re(k: int, N: int) -> float {
    return cos_approx(0.0 - TWO_PI * k / N)
}

fn twiddle_im(k: int, N: int) -> float {
    return sin_approx(0.0 - TWO_PI * k / N)
}

// ── Inverse twiddle: W_N^(-k) = exp(+j * 2*pi*k / N) ──

fn twiddle_inv_re(k: int, N: int) -> float {
    return cos_approx(TWO_PI * k / N)
}

fn twiddle_inv_im(k: int, N: int) -> float {
    return sin_approx(TWO_PI * k / N)
}

// ── Magnitude and power spectrum (per-bin) ──

fn magnitude_bin(re: float, im: float) -> float {
    return sqrt_approx(re * re + im * im)
}

fn power_bin(re: float, im: float) -> float {
    return re * re + im * im
}

// ── FFT for small fixed sizes (N=2, N=4, N=8) — fully unrolled ──

// N=2 FFT: [x0, x1] -> [x0+x1, x0-x1]
fn fft2_out0_re(re0: float, re1: float) -> float { return re0 + re1 }
fn fft2_out0_im(im0: float, im1: float) -> float { return im0 + im1 }
fn fft2_out1_re(re0: float, re1: float) -> float { return re0 - re1 }
fn fft2_out1_im(im0: float, im1: float) -> float { return im0 - im1 }

// ── STFT frame processing (per-frame interface) ──
// Caller extracts one frame from the signal, applies window, calls FFT.
// stft_frame_sample: get windowed sample at position i within a frame

fn stft_frame_sample(sample: float, win_type: int, i: int, fft_size: int) -> float {
    return sample * window_sample(win_type, i, fft_size)
}

// STFT hop computation
fn stft_num_frames(signal_len: int, fft_size: int, hop: int) -> int {
    if hop <= 0 { return 0 }
    if signal_len < fft_size { return 0 }
    return (signal_len - fft_size) / hop + 1
}

// STFT frame start index
fn stft_frame_start(frame_idx: int, hop: int) -> int {
    return frame_idx * hop
}

// ── ISTFT: overlap-add synthesis (per-sample interface) ──
// After IFFT of each frame, the caller windows and accumulates.
// istft_synth_sample: windowed IFFT output ready for OLA accumulation

fn istft_synth_sample(ifft_sample: float, win_type: int, i: int, fft_size: int) -> float {
    return ifft_sample * window_sample(win_type, i, fft_size)
}

// ISTFT output length
fn istft_output_len(num_frames: int, fft_size: int, hop: int) -> int {
    if num_frames <= 0 { return 0 }
    return fft_size + (num_frames - 1) * hop
}

// ISTFT normalization: after OLA, divide by sum of squared windows at each position
fn istft_window_norm(win_type: int, fft_size: int, hop: int) -> float {
    // Compute sum of squared window values at any fully-covered position
    // For Hann window OLA with 50% overlap, this is exactly 1.0
    let sum = 0.0
    let frame = 0
    let max_frames = fft_size / hop
    if max_frames < 1 { max_frames = 1 }
    while frame < max_frames {
        let pos = frame * hop  // position within the overlap region
        if pos < fft_size {
            let w = window_sample(win_type, pos, fft_size)
            sum = sum + w * w
        }
        frame = frame + 1
    }
    if sum < 0.0001 { return 1.0 }
    return 1.0 / sum
}

// ════════════════════════════════════════════════════════════════════
// Section 5: Filters
// ════════════════════════════════════════════════════════════════════

// ── Biquad coefficients for lowpass ──
// H(z) = (b0 + b1*z^-1 + b2*z^-2) / (1 + a1*z^-1 + a2*z^-2)
// Using Audio EQ Cookbook (Robert Bristow-Johnson)

// Intermediate: compute omega and alpha for biquad design
fn biquad_omega(cutoff_hz: float, sample_rate: float) -> float {
    return TWO_PI * cutoff_hz / sample_rate
}

fn biquad_alpha(omega: float, Q: float) -> float {
    return sin_approx(omega) / (2.0 * Q)
}

// ── Lowpass biquad coefficients ──
// Returns coefficient by index: 0=b0, 1=b1, 2=b2, 3=a1, 4=a2
// (a0 is normalized to 1)

fn lpf_coeff(cutoff_hz: float, sample_rate: float, Q: float, idx: int) -> float {
    let w = biquad_omega(cutoff_hz, sample_rate)
    let cs = cos_approx(w)
    let al = biquad_alpha(w, Q)
    let a0 = 1.0 + al

    if idx == 0 { return ((1.0 - cs) / 2.0) / a0 }  // b0
    if idx == 1 { return (1.0 - cs) / a0 }            // b1
    if idx == 2 { return ((1.0 - cs) / 2.0) / a0 }  // b2
    if idx == 3 { return (0.0 - 2.0 * cs) / a0 }     // a1
    if idx == 4 { return (1.0 - al) / a0 }            // a2
    return 0.0
}

// ── Highpass biquad coefficients ──

fn hpf_coeff(cutoff_hz: float, sample_rate: float, Q: float, idx: int) -> float {
    let w = biquad_omega(cutoff_hz, sample_rate)
    let cs = cos_approx(w)
    let al = biquad_alpha(w, Q)
    let a0 = 1.0 + al

    if idx == 0 { return ((1.0 + cs) / 2.0) / a0 }  // b0
    if idx == 1 { return (0.0 - (1.0 + cs)) / a0 }   // b1
    if idx == 2 { return ((1.0 + cs) / 2.0) / a0 }  // b2
    if idx == 3 { return (0.0 - 2.0 * cs) / a0 }     // a1
    if idx == 4 { return (1.0 - al) / a0 }            // a2
    return 0.0
}

// ── Biquad filter: process one sample (Direct Form I) ──
// State: x1, x2 (previous inputs), y1, y2 (previous outputs)
// Returns filtered output sample

fn biquad_tick(sample: float, b0: float, b1: float, b2: float, a1: float, a2: float, x1: float, x2: float, y1: float, y2: float) -> float {
    return b0 * sample + b1 * x1 + b2 * x2 - a1 * y1 - a2 * y2
}

// ── Preemphasis: y[n] = x[n] - coeff * x[n-1] ──

fn preemphasis_tick(sample: float, prev_sample: float, coeff: float) -> float {
    return sample - coeff * prev_sample
}

// ── Deemphasis (inverse): y[n] = x[n] + coeff * y[n-1] ──

fn deemphasis_tick(sample: float, prev_output: float, coeff: float) -> float {
    return sample + coeff * prev_output
}

// ════════════════════════════════════════════════════════════════════
// Section 6: Resampling
// ════════════════════════════════════════════════════════════════════

// ── Upsample linear: compute interpolated sample at fractional position ──
// Given two adjacent samples and fractional position t in [0, 1):
//   out = s0 * (1 - t) + s1 * t

fn lerp(s0: float, s1: float, t: float) -> float {
    return s0 * (1.0 - t) + s1 * t
}

// For upsampling by integer factor:
// Output index i maps to input position i/factor
// Source index = floor(i/factor), frac = i/factor - floor(i/factor)
fn upsample_src_index(out_idx: int, factor: int) -> int {
    return out_idx / factor
}

fn upsample_frac(out_idx: int, factor: int) -> float {
    let src = out_idx / factor
    return (out_idx * 1.0 / factor) - src
}

fn upsample_output_len(input_len: int, factor: int) -> int {
    return (input_len - 1) * factor + 1
}

// ── Downsample: take every factor-th sample ──

fn downsample_src_index(out_idx: int, factor: int) -> int {
    return out_idx * factor
}

fn downsample_output_len(input_len: int, factor: int) -> int {
    if factor <= 0 { return 0 }
    return (input_len + factor - 1) / factor
}

// ════════════════════════════════════════════════════════════════════
// Section 7: Pitch Analysis
// ════════════════════════════════════════════════════════════════════

// ── Autocorrelation at lag tau (single lag computation) ──
// R(tau) = sum_{n=0}^{N-tau-1} x[n] * x[n+tau]
// Caller iterates over samples and accumulates.

fn autocorr_accumulate(sample_n: float, sample_n_plus_tau: float) -> float {
    return sample_n * sample_n_plus_tau
}

// ── ACF pitch detection: find lag of maximum autocorrelation ──
// min_lag = sr / max_hz, max_lag = sr / min_hz
// Caller computes R(tau) for each lag and finds the peak.

fn pitch_lag_to_hz(lag: int, sample_rate: int) -> float {
    if lag <= 0 { return 0.0 }
    return sample_rate * 1.0 / lag
}

fn hz_to_lag(hz: float, sample_rate: int) -> int {
    if hz <= 0.0 { return 0 }
    return sample_rate / hz
}

fn pitch_min_lag(sample_rate: int, max_hz: float) -> int {
    return hz_to_lag(max_hz, sample_rate)
}

fn pitch_max_lag(sample_rate: int, min_hz: float) -> int {
    return hz_to_lag(min_hz, sample_rate)
}

// ── Parabolic interpolation for sub-sample pitch refinement ──
// Given autocorrelation at lags (tau-1, tau, tau+1), refine the peak.
// Returns fractional lag offset from tau.

fn parabolic_interp_offset(r_prev: float, r_peak: float, r_next: float) -> float {
    let denom = 2.0 * (2.0 * r_peak - r_prev - r_next)
    if abs_val(denom) < 0.00001 { return 0.0 }
    return (r_prev - r_next) / denom
}

// ════════════════════════════════════════════════════════════════════
// Section 8: dB / Linear Conversion Utilities
// ════════════════════════════════════════════════════════════════════

fn linear_to_db(x: float) -> float {
    if x <= 0.000001 { return -120.0 }
    return 20.0 * log_approx(x) / log_approx(10.0)
}

fn db_to_linear(db: float) -> float {
    return exp_approx(db * 0.11512925)  // db * ln(10)/20
}

