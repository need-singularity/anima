fn test_sin_cos() {
    println("── sin/cos accuracy ──")
    println("  x          sin_approx   expected     error")

    // Test points: 0, pi/6, pi/4, pi/3, pi/2, pi
    let s0 = sin_approx(0.0)
    println("  0          " + to_string(s0) + "   0.0          " + to_string(abs_val(s0 - 0.0)))

    let s1 = sin_approx(PI / 6.0)
    println("  pi/6       " + to_string(s1) + "   0.5          " + to_string(abs_val(s1 - 0.5)))

    let s2 = sin_approx(PI / 4.0)
    println("  pi/4       " + to_string(s2) + "   0.7071       " + to_string(abs_val(s2 - 0.70710678)))

    let s3 = sin_approx(PI / 2.0)
    println("  pi/2       " + to_string(s3) + "   1.0          " + to_string(abs_val(s3 - 1.0)))

    let s4 = sin_approx(PI)
    println("  pi         " + to_string(s4) + "   0.0          " + to_string(abs_val(s4 - 0.0)))

    let s5 = sin_approx(3.0 * PI / 2.0)
    println("  3pi/2      " + to_string(s5) + "   -1.0         " + to_string(abs_val(s5 + 1.0)))

    println("")
    println("  x          cos_approx   expected     error")
    let c0 = cos_approx(0.0)
    println("  0          " + to_string(c0) + "   1.0          " + to_string(abs_val(c0 - 1.0)))
    let c1 = cos_approx(PI / 3.0)
    println("  pi/3       " + to_string(c1) + "   0.5          " + to_string(abs_val(c1 - 0.5)))
    let c2 = cos_approx(PI)
    println("  pi         " + to_string(c2) + "   -1.0         " + to_string(abs_val(c2 + 1.0)))
    println("")
}

fn test_exp_log() {
    println("── exp/log accuracy ──")
    let e0 = exp_approx(0.0)
    println("  exp(0)   = " + to_string(e0) + "  expected 1.0    err=" + to_string(abs_val(e0 - 1.0)))
    let e1 = exp_approx(1.0)
    println("  exp(1)   = " + to_string(e1) + "  expected 2.7183 err=" + to_string(abs_val(e1 - 2.71828)))
    let e2 = exp_approx(2.0)
    println("  exp(2)   = " + to_string(e2) + "  expected 7.3891 err=" + to_string(abs_val(e2 - 7.38906)))
    let e3 = exp_approx(-1.0)
    println("  exp(-1)  = " + to_string(e3) + "  expected 0.3679 err=" + to_string(abs_val(e3 - 0.36788)))

    println("")
    let l1 = log_approx(1.0)
    println("  ln(1)    = " + to_string(l1) + "  expected 0.0    err=" + to_string(abs_val(l1 - 0.0)))
    let l2 = log_approx(E)
    println("  ln(e)    = " + to_string(l2) + "  expected 1.0    err=" + to_string(abs_val(l2 - 1.0)))
    let l3 = log_approx(10.0)
    println("  ln(10)   = " + to_string(l3) + "  expected 2.3026 err=" + to_string(abs_val(l3 - 2.30259)))
    let l4 = log_approx(0.5)
    println("  ln(0.5)  = " + to_string(l4) + "  expected -0.6931 err=" + to_string(abs_val(l4 + 0.69315)))
    println("")
}

