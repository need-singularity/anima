fn test_windows() {
    println("── Window functions (N=16) ──")
    println("  n   Hann     Hamming  Blackman")
    let N = 16
    let i = 0
    while i < N {
        let h = hann_window(i, N)
        let hm = hamming_window(i, N)
        let bk = blackman_window(i, N)
        println("  " + to_string(i) + "   " + to_string(h) + "   " + to_string(hm) + "   " + to_string(bk))
        i = i + 1
    }

    // Verify symmetry: w(n) == w(N-1-n)
    println("")
    println("  Symmetry check (Hann):")
    let sym_ok = 1
    let j = 0
    while j < N / 2 {
        let w1 = hann_window(j, N)
        let w2 = hann_window(N - 1 - j, N)
        let diff = abs_val(w1 - w2)
        if diff > 0.001 { sym_ok = 0 }
        j = j + 1
    }
    if sym_ok == 1 {
        println("  PASS: Hann window symmetric")
    } else {
        println("  FAIL: Hann window NOT symmetric")
    }
    println("")
}

fn test_fft_roundtrip() {
    println("── FFT butterfly round-trip (N=2) ──")
    // Test: FFT then IFFT of [3.0, -1.0]
    let re0 = 3.0
    let re1 = -1.0
    let im0 = 0.0
    let im1 = 0.0

    // Forward FFT N=2: twiddle W_2^0 = (1, 0)
    let fre0 = fft2_out0_re(re0, re1)
    let fim0 = fft2_out0_im(im0, im1)
    let fre1 = fft2_out1_re(re0, re1)
    let fim1 = fft2_out1_im(im0, im1)
    println("  Input:   [" + to_string(re0) + ", " + to_string(re1) + "]")
    println("  FFT:     [" + to_string(fre0) + "+j" + to_string(fim0) + ", " + to_string(fre1) + "+j" + to_string(fim1) + "]")
    println("  Expected:[2.0+j0, 4.0+j0]")

    // Inverse: IFFT N=2 is same as FFT but divide by N
    let ire0 = fft2_out0_re(fre0, fre1) / 2.0
    let iim0 = fft2_out0_im(fim0, fim1) / 2.0
    let ire1 = fft2_out1_re(fre0, fre1) / 2.0
    let iim1 = fft2_out1_im(fim0, fim1) / 2.0
    println("  IFFT:    [" + to_string(ire0) + ", " + to_string(ire1) + "]")
    let err0 = abs_val(ire0 - re0)
    let err1 = abs_val(ire1 - re1)
    if err0 < 0.001 && err1 < 0.001 {
        println("  PASS: round-trip error < 0.001")
    } else {
        println("  FAIL: round-trip error = " + to_string(err0) + ", " + to_string(err1))
    }
    println("")

    // Butterfly test with twiddle
    println("── FFT butterfly with twiddle ──")
    let tw_re = twiddle_re(1, 8)  // W_8^1 = cos(-pi/4) + j*sin(-pi/4)
    let tw_im = twiddle_im(1, 8)
    println("  W_8^1 = " + to_string(tw_re) + " + j" + to_string(tw_im))
    println("  Expected: 0.7071 + j(-0.7071)")
    let tw_err = abs_val(tw_re - 0.70711) + abs_val(tw_im + 0.70711)
    if tw_err < 0.01 {
        println("  PASS: twiddle error < 0.01")
    } else {
        println("  FAIL: twiddle error = " + to_string(tw_err))
    }
    println("")
}

fn test_audio_ops() {
    println("── Audio operations ──")

    // RMS of [0.5, -0.5, 0.3, -0.3, 0.1]
    let sq = 0.0
    sq = rms_accumulate(sq, 0.5)
    sq = rms_accumulate(sq, -0.5)
    sq = rms_accumulate(sq, 0.3)
    sq = rms_accumulate(sq, -0.3)
    sq = rms_accumulate(sq, 0.1)
    let rms = rms_finalize(sq, 5)
    println("  RMS([0.5,-0.5,0.3,-0.3,0.1]) = " + to_string(rms))
    println("  Expected: sqrt((0.25+0.25+0.09+0.09+0.01)/5) = sqrt(0.138) = 0.3715")

    // ZCR
    let zc = 0
    zc = zc + zcr_count(0.5, -0.5)   // cross
    zc = zc + zcr_count(-0.5, 0.3)   // cross
    zc = zc + zcr_count(0.3, -0.3)   // cross
    zc = zc + zcr_count(-0.3, 0.1)   // cross
    let zcr = zcr_finalize(zc, 4)
    println("  ZCR([0.5,-0.5,0.3,-0.3,0.1]) = " + to_string(zcr) + " (" + to_string(zc) + "/4 crossings)")
    println("  Expected: 4/4 = 1.0")

    // Mix
    let mx = mix(1.0, 0.0, 0.3)
    println("  mix(1.0, 0.0, 0.3) = " + to_string(mx) + " expected 0.7")

    // Gain
    let g = apply_gain(0.5, 2.0)
    println("  gain(0.5, 2.0) = " + to_string(g) + " expected 1.0")

    // Overlap-add with Hann
    let ola = overlap_add_hann(1.0, 0.0, 0, 8)
    println("  OLA(1.0, 0.0, i=0, len=8) = " + to_string(ola))

    println("")
}

fn test_filters() {
    println("── Biquad filter coefficients ──")
    let sr = 24000.0
    let fc = 1000.0
    let Q = 0.707

    println("  Lowpass: fc=" + to_string(fc) + " sr=" + to_string(sr) + " Q=" + to_string(Q))
    let b0 = lpf_coeff(fc, sr, Q, 0)
    let b1 = lpf_coeff(fc, sr, Q, 1)
    let b2 = lpf_coeff(fc, sr, Q, 2)
    let a1 = lpf_coeff(fc, sr, Q, 3)
    let a2 = lpf_coeff(fc, sr, Q, 4)
    println("  b0=" + to_string(b0) + " b1=" + to_string(b1) + " b2=" + to_string(b2))
    println("  a1=" + to_string(a1) + " a2=" + to_string(a2))

    println("")
    println("  Highpass: fc=" + to_string(fc) + " sr=" + to_string(sr) + " Q=" + to_string(Q))
    let hb0 = hpf_coeff(fc, sr, Q, 0)
    let hb1 = hpf_coeff(fc, sr, Q, 1)
    let hb2 = hpf_coeff(fc, sr, Q, 2)
    let ha1 = hpf_coeff(fc, sr, Q, 3)
    let ha2 = hpf_coeff(fc, sr, Q, 4)
    println("  b0=" + to_string(hb0) + " b1=" + to_string(hb1) + " b2=" + to_string(hb2))
    println("  a1=" + to_string(ha1) + " a2=" + to_string(ha2))

    // Preemphasis test
    println("")
    let pe = preemphasis_tick(0.8, 0.5, 0.97)
    println("  preemphasis(0.8, prev=0.5, coeff=0.97) = " + to_string(pe) + " expected 0.315")
    let de = deemphasis_tick(0.315, 0.5, 0.97)
    println("  deemphasis(0.315, prev_out=0.5, coeff=0.97) = " + to_string(de) + " expected ~0.8")
    println("")
}

fn test_resample() {
    println("── Resampling ──")

    // Upsample by 3: [1.0, 4.0] -> [1.0, 2.0, 3.0, 4.0]
    let factor = 3
    let out_len = upsample_output_len(2, factor)
    println("  Upsample x" + to_string(factor) + ": input=[1.0, 4.0] -> output_len=" + to_string(out_len))

    let i = 0
    while i < out_len {
        let src = upsample_src_index(i, factor)
        let frac = upsample_frac(i, factor)
        // Simulate: input[0]=1.0, input[1]=4.0
        let s0 = 1.0
        let s1 = 4.0
        if src == 0 {
            let val = lerp(s0, s1, frac)
            println("    out[" + to_string(i) + "] src=" + to_string(src) + " frac=" + to_string(frac) + " val=" + to_string(val))
        } else {
            println("    out[" + to_string(i) + "] src=" + to_string(src) + " (end)")
        }
        i = i + 1
    }

    // Downsample by 2: every other sample
    let ds_len = downsample_output_len(8, 2)
    println("  Downsample x2: input_len=8 -> output_len=" + to_string(ds_len))
    println("")
}

fn test_pitch() {
    println("── Pitch analysis ──")
    let sr = 24000

    // 200 Hz -> lag = 24000/200 = 120
    let lag_200 = hz_to_lag(200.0, sr)
    let hz_back = pitch_lag_to_hz(lag_200, sr)
    println("  200 Hz -> lag=" + to_string(lag_200) + " -> back=" + to_string(hz_back) + " Hz")

    // Range for voice: 80-500 Hz
    let min_l = pitch_min_lag(sr, 500.0)
    let max_l = pitch_max_lag(sr, 80.0)
    println("  Voice range 80-500 Hz -> lag range [" + to_string(min_l) + ", " + to_string(max_l) + "]")

    // Parabolic interpolation test
    // Peak at tau=120, R(119)=0.8, R(120)=1.0, R(121)=0.9
    let offset = parabolic_interp_offset(0.8, 1.0, 0.9)
    let refined_lag = 120.0 + offset
    let refined_hz = sr * 1.0 / refined_lag
    println("  Parabolic refinement: R(119)=0.8, R(120)=1.0, R(121)=0.9")
    println("    offset=" + to_string(offset) + " refined_lag=" + to_string(refined_lag) + " Hz=" + to_string(refined_hz))

    println("")
}

fn test_db_conversion() {
    println("── dB conversion ──")
    let db1 = linear_to_db(1.0)
    println("  1.0 -> " + to_string(db1) + " dB (expected 0)")
    let db2 = linear_to_db(0.5)
    println("  0.5 -> " + to_string(db2) + " dB (expected -6.02)")
    let lin1 = db_to_linear(0.0)
    println("  0 dB -> " + to_string(lin1) + " (expected 1.0)")
    let lin2 = db_to_linear(-6.0)
    println("  -6 dB -> " + to_string(lin2) + " (expected ~0.501)")
    println("")
}

fn test_stft_params() {
    println("── STFT parameters ──")
    let sig_len = 4800   // 200ms @ 24kHz
    let fft_size = 512
    let hop = 128

    let nf = stft_num_frames(sig_len, fft_size, hop)
    println("  signal=" + to_string(sig_len) + " fft=" + to_string(fft_size) + " hop=" + to_string(hop))
    println("  frames = " + to_string(nf))
    println("  frame starts: ")
    let f = 0
    while f < nf && f < 5 {
        let start = stft_frame_start(f, hop)
        println("    frame " + to_string(f) + " -> sample " + to_string(start))
        f = f + 1
    }
    if nf > 5 { println("    ...") }

    let out_len = istft_output_len(nf, fft_size, hop)
    println("  ISTFT output length = " + to_string(out_len))

    let norm = istft_window_norm(WIN_HANN, fft_size, hop)
    println("  ISTFT window norm (Hann, hop=" + to_string(hop) + ") = " + to_string(norm))
    println("")
}

