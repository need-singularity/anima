// anima-speak/experiments/ab_metrics.hexa — Objective A/B audio metrics
//
// Usage: hexa ab_metrics.hexa [stamp]   (default stamp: 20260419)
// Computes per-clip sox/soxi/ffprobe stats for tts_say_yuna vs piper_ko_v1 corpus.
// Output: TSV at $BASE/ab_test/metrics_<stamp>.tsv
//
// raw#9: hexa-only; subprocess to sox/soxi/ffprobe + awk for stat-line parsing.
// Created 2026-04-26 by Ω-rules P4 Phase 4 (replacement for ab_metrics.sh).

let BASE = "/home/aiden/mac_home/dev/anima/anima-speak/corpus"

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

fn file_exists(path: string) -> bool {
    let r = exec("test -f " + shell_escape(path) + " && echo y || echo n").trim()
    return r == "y"
}

fn pad2(n: int) -> string {
    if n < 10 { return "0" + to_string(n) }
    return to_string(n)
}

fn persona_name_for(id: int) -> string {
    if id == 10 { return "ice_queen" }
    if id == 11 { return "chaebol_heir" }
    if id == 12 { return "pure_heroine" }
    if id == 13 { return "tsundere_oppa" }
    if id == 14 { return "airhead_friend" }
    if id == 15 { return "charismatic_prez" }
    if id == 16 { return "thug_returnee" }
    if id == 17 { return "cold_heiress" }
    if id == 18 { return "gentle_oppa" }
    if id == 19 { return "fallen_antagonist" }
    return "unknown"
}

// analyze: emit TSV row for a single wav file.
// Output: persona<TAB>idx<TAB>engine<TAB>sr<TAB>dur<TAB>rms<TAB>pk<TAB>vol_adj<TAB>spec
fn analyze(wav: string, engine: string, persona: string, idx: int, out_path: string) {
    let sr = exec("soxi -r " + shell_escape(wav) + " 2>/dev/null || echo 0").trim()
    let dur = exec("soxi -D " + shell_escape(wav) + " 2>/dev/null || echo 0").trim()
    // sox <wav> -n stats — capture full stderr block
    let stats_cmd = "sox " + shell_escape(wav) + " -n stats 2>&1"
    let stats = to_string(exec(stats_cmd))
    let rms_cmd = "echo " + shell_escape(stats) + " | awk '/RMS lev dB/{print $4}'"
    let rms = exec(rms_cmd).trim()
    let pk_cmd = "echo " + shell_escape(stats) + " | awk '/Pk lev dB/{print $4}'"
    let pk = exec(pk_cmd).trim()
    let vadj_cmd = "echo " + shell_escape(stats) + " | awk '/Volume adjustment/{print $3}'"
    let vadj = exec(vadj_cmd).trim()
    let spec_cmd = "sox " + shell_escape(wav) + " -n stat 2>&1 | grep 'Rough' | awk '{print $NF}'"
    let spec = exec(spec_cmd).trim()
    let row = persona + "\t" + to_string(idx) + "\t" + engine
            + "\t" + sr + "\t" + dur + "\t" + rms + "\t" + pk
            + "\t" + vadj + "\t" + spec
    let _ = exec("printf '%s\\n' " + shell_escape(row) + " >> " + shell_escape(out_path))
}

let _argv = args()
let stamp = if len(_argv) >= 3 { _argv[2] } else { "20260419" }
let out_path = BASE + "/ab_test/metrics_" + stamp + ".tsv"
let header = "persona\tidx\tengine\tsr\tdur_s\trms_dB\tpk_dB\tvol_adj\tfreq_band_p90"
let _ = exec("printf '%s\\n' " + shell_escape(header) + " > " + shell_escape(out_path))

let mut id = 10
while id <= 19 {
    let pname = persona_name_for(id)
    let mut idx = 0
    while idx <= 7 {
        let pad = pad2(idx)
        let old_wav = BASE + "/tts_say/persona_" + to_string(id) + "_" + pname + "/tts_" + pad + ".wav"
        let new_wav = BASE + "/ab_test/piper_ko_v1/persona_" + to_string(id) + "_" + pname + "/tts_" + pad + ".wav"
        if file_exists(old_wav) { analyze(old_wav, "say_yuna_16k", pname, idx, out_path) }
        if file_exists(new_wav) { analyze(new_wav, "piper_ko_22k", pname, idx, out_path) }
        idx = idx + 1
    }
    id = id + 1
}

println("done → " + out_path)
let count = exec("wc -l " + shell_escape(out_path) + " 2>/dev/null").trim()
println(count)
