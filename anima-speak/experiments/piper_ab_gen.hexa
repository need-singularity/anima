// anima-speak/experiments/piper_ab_gen.hexa — Piper neural TTS A/B corpus generator
//
// Purpose: replace the macOS `say -v Yuna` baseline in tts_say_driver.hexa with
// piper-kss-korean (22050 Hz neural VITS) + per-persona emotion params + ffmpeg
// filter chain for emotional color. Output corpus/ab_test/piper_ko_v1/ for A/B.
//
// R37/AN13/L3-PY: hexa-only; subprocess to piper (rust binary) and ffmpeg.
//
// Pipeline per clip:
//   1) echo "<ko_line>" | piper --model ... --output_file X.wav
//         (native 22050 Hz mono float32 → pcm16)
//   2) ffmpeg filter chain (persona-specific: pitch, EQ, reverb, loudnorm)
//   3) persist at 22050 Hz (NO 16kHz downsample)
//
// Piper emotion knobs:
//   --noise_scale   (0.4..0.9)  generator variability
//   --length_scale  (0.8..1.3)  pacing
//   --noise_w       (0.5..1.0)  phoneme width noise

let PIPER_BIN    = "/home/aiden/bin/tts_tools/piper/piper"
let PIPER_MODEL  = "/home/aiden/bin/tts_tools/voices/ko/piper-kss-korean.onnx"
let PIPER_CONFIG = "/home/aiden/bin/tts_tools/voices/ko/piper-kss-korean.onnx.json"
let OUT_ROOT     = "/home/aiden/mac_home/dev/anima/anima-speak/corpus/ab_test/piper_ko_v1"
let STATE_DIR    = "/home/aiden/mac_home/dev/anima/anima-speak/corpus/ab_test"
let STAMP        = "20260419"

// ═══════════════════════════════════════════════════════════════
//  Helpers (Linux-adapted: stat -c %s)
// ═══════════════════════════════════════════════════════════════

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

fn ensure_dir(path: string) {
    let _ = exec("mkdir -p " + shell_escape(path))
}

fn file_bytes(path: string) -> int {
    let out = exec("stat -c %s " + shell_escape(path) + " 2>/dev/null").trim()
    if len(out) == 0 { return 0 }
    return to_int(out)
}

fn audio_duration_s(path: string) -> float {
    let out = exec("ffprobe -v error -show_entries format=duration -of csv=p=0 "
                   + shell_escape(path) + " 2>/dev/null").trim()
    if len(out) == 0 { return 0.0 }
    return to_float(out)
}

fn pad2(n: int) -> string {
    if n < 10 { return "0" + to_string(n) }
    return to_string(n)
}

fn json_kv_str(k: string, v: string) -> string {
    return "\"" + k + "\": \"" + v.replace("\"", "\\\"") + "\""
}

fn json_kv_int(k: string, v: int) -> string {
    return "\"" + k + "\": " + to_string(v)
}

fn json_kv_float(k: string, v: float) -> string {
    return "\"" + k + "\": " + to_string(v)
}

fn write_file(path: string, content: string) {
    let tmp = path + ".tmp"
    let cmd = "cat > " + shell_escape(tmp) + " <<'HEXA_EOF'\n" + content + "\nHEXA_EOF"
    let _ = exec(cmd)
    let _ = exec("mv " + shell_escape(tmp) + " " + shell_escape(path))
}

// ═══════════════════════════════════════════════════════════════
//  Persona lookup (10..19)
// ═══════════════════════════════════════════════════════════════

fn persona_name_for(id: int) -> string {
    if id == 10 { return "ice_queen" }
    if id == 11 { return "chaebol_heir" }
    if id == 12 { return "pure_heroine" }
    if id == 13 { return "tsundere_oppa" }
    if id == 14 { return "airhead_friend" }
    if id == 15 { return "charismatic_prez" }
    if id == 16 { return "thug_returnee" }
    if id == 17 { return "cold_heiress" }
    if id == 18 { return "gentle_oppa" }
    if id == 19 { return "fallen_antagonist" }
    return "unknown"
}

fn persona_is_male(id: int) -> bool {
    if id == 11 { return true }
    if id == 13 { return true }
    if id == 15 { return true }
    if id == 16 { return true }
    if id == 18 { return true }
    if id == 19 { return true }
    return false
}

// Emotional parameter tuple: length_scale, noise_scale, noise_w (×100, int)
// Returned as string "L,N,W" (×100) to avoid list-of-float pass-by-value quirks.
fn persona_piper_params(id: int) -> string {
    if id == 10 { return "120,55,60"   }  // ice_queen: slower, restrained, precise
    if id == 11 { return "110,55,70"   }  // chaebol: slow-measured
    if id == 12 { return "100,75,85"   }  // pure: natural-warm
    if id == 13 { return "95,80,100"   }  // tsundere: quick varied
    if id == 14 { return "80,85,100"   }  // airhead: very fast, erratic
    if id == 15 { return "115,50,60"   }  // prez: slow-authoritative
    if id == 16 { return "125,70,80"   }  // thug: drawl
    if id == 17 { return "115,50,65"   }  // cold heiress: precise
    if id == 18 { return "105,70,80"   }  // gentle: warm-relaxed
    if id == 19 { return "125,75,85"   }  // fallen: slow-unstable
    return "100,66,80"
}

// ffmpeg filter chain per persona (post-piper).
// For male personas, pitch-shift down via asetrate + atempo.
// Plus persona-specific EQ/compressor/reverb for character.
fn persona_ffmpeg_filter(id: int) -> string {
    let is_male = persona_is_male(id)

    // base loudness (gentler LRA than current tts_say's LRA=11)
    let ln = "loudnorm=I=-18:TP=-2:LRA=7"

    // Optional pitch-shift for male personas (22050 base)
    // 0.78 * 1.28 ≈ 0.999 (preserves duration)
    let mut pitch = ""
    if is_male {
        pitch = "asetrate=22050*0.78,aresample=22050,atempo=1.28,"
    }

    // Persona-specific tonal filter (EQ + optional reverb)
    let mut tone = ""
    if id == 10 {
        // ice_queen: precision cut highs slightly, clean
        tone = "equalizer=f=200:t=q:w=1.2:g=-2,equalizer=f=3500:t=q:w=1:g=1,"
    } else if id == 11 {
        // chaebol: bass authority
        tone = "equalizer=f=150:t=q:w=1:g=3,equalizer=f=4000:t=q:w=1:g=1.5,"
    } else if id == 12 {
        // pure: brighten, subtle air
        tone = "equalizer=f=400:t=q:w=1:g=-1,equalizer=f=6000:t=q:w=1.5:g=2,"
    } else if id == 13 {
        // tsundere: slight tremor, brighten
        tone = "vibrato=f=5:d=0.15,equalizer=f=5000:t=q:w=1:g=1.5,"
    } else if id == 14 {
        // airhead: bright bubbly
        tone = "equalizer=f=300:t=q:w=1:g=-1,equalizer=f=5500:t=q:w=1:g=2.5,"
    } else if id == 15 {
        // prez: broadcast-style EQ, tight
        tone = "equalizer=f=120:t=q:w=1:g=2.5,equalizer=f=3000:t=q:w=1:g=1,highpass=f=80,"
    } else if id == 16 {
        // thug: gritty, darker
        tone = "equalizer=f=180:t=q:w=1:g=2,equalizer=f=4500:t=q:w=1:g=-2,"
    } else if id == 17 {
        // cold_heiress: refined, clean
        tone = "equalizer=f=250:t=q:w=1.2:g=-1.5,equalizer=f=4000:t=q:w=1:g=1.5,"
    } else if id == 18 {
        // gentle_oppa: warmth + subtle reverb tail
        tone = "equalizer=f=200:t=q:w=1:g=2,equalizer=f=5500:t=q:w=1:g=1,aecho=0.7:0.6:40:0.18,"
    } else if id == 19 {
        // fallen_antagonist: dark, hollow reverb
        tone = "equalizer=f=100:t=q:w=1:g=2,equalizer=f=6000:t=q:w=1:g=-2,aecho=0.8:0.9:80:0.25,"
    }

    return pitch + tone + ln
}

