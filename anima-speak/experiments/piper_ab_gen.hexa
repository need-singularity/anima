// Parse "120,55,60" → (1.20, 0.55, 0.60). Hexa doesn't have tuples so return CSV.
fn parse_param_str(s: string, idx: int) -> float {
    let parts = s.split(",")
    if idx >= len(parts) { return 1.0 }
    return to_float(parts[idx]) / 100.0
}

// ═══════════════════════════════════════════════════════════════
//  Synthesis: one line (text → 22050 Hz wav with persona filter)
// ═══════════════════════════════════════════════════════════════

fn synth_one(persona_id: int, persona_name: string,
             line: string, idx: int) -> string {
    let pdir = OUT_ROOT + "/persona_" + to_string(persona_id) + "_" + persona_name
    ensure_dir(pdir)
    let raw = pdir + "/tts_" + pad2(idx) + ".raw.wav"
    let wav = pdir + "/tts_" + pad2(idx) + ".wav"

    let params = persona_piper_params(persona_id)
    let ls = parse_param_str(params, 0)  // length_scale
    let ns = parse_param_str(params, 1)  // noise_scale
    let nw = parse_param_str(params, 2)  // noise_w

    // 1) piper synthesis — accept UTF-8 Korean on stdin
    let cmd_piper = "echo " + shell_escape(line)
                  + " | " + PIPER_BIN
                  + " --model " + PIPER_MODEL
                  + " --config " + PIPER_CONFIG
                  + " --length_scale " + to_string(ls)
                  + " --noise_scale " + to_string(ns)
                  + " --noise_w " + to_string(nw)
                  + " --output_file " + shell_escape(raw)
                  + " 2>&1"
    let _ = exec(cmd_piper)
    if file_bytes(raw) < 5000 {
        println("  [FAIL] piper produced empty wav for persona " + to_string(persona_id)
                + " idx " + to_string(idx) + " (bytes=" + to_string(file_bytes(raw)) + ")")
        return ""
    }

    // 2) ffmpeg filter chain (persona-specific)
    let af = persona_ffmpeg_filter(persona_id)
    let cmd_ff = "ffmpeg -y -loglevel error -i " + shell_escape(raw)
               + " -af " + shell_escape(af)
               + " -ac 1 -ar 22050 -c:a pcm_s16le "
               + shell_escape(wav) + " 2>&1"
    let _ = exec(cmd_ff)
    if file_bytes(wav) < 1000 {
        println("  [FAIL] ffmpeg empty for persona " + to_string(persona_id)
                + " idx " + to_string(idx))
        return ""
    }
    // cleanup raw
    let _ = exec("rm -f " + shell_escape(raw))
    return wav
}

// ═══════════════════════════════════════════════════════════════
//  Persona driver
// ═══════════════════════════════════════════════════════════════

fn process_persona(id: int) -> array {
    let name    = persona_name_for(id)
    let is_male = persona_is_male(id)
    let lines   = persona_lines(id)
    let params  = persona_piper_params(id)

    println("")
    let mode_tag = "female"
    if is_male { mode_tag = "male(pitch-shift)" }
    println("═══ persona " + to_string(id) + " — " + name
            + " (mode=" + mode_tag
            + " params=" + params + ") ═══")

    let n = len(lines)
    let mut ok_count = 0
    let mut total_dur = 0.0
    let mut lines_json_arr = ""
    let mut i = 0
    while i < n {
        let line = lines[i]
        let wav  = synth_one(id, name, line, i)
        if len(wav) > 0 {
            let dur = audio_duration_s(wav)
            total_dur = total_dur + dur
            ok_count = ok_count + 1
            println("  [OK] idx=" + pad2(i)
                    + " dur=" + to_string(dur) + "s → " + wav)
            if len(lines_json_arr) > 0 { lines_json_arr = lines_json_arr + ",\n" }
            let safe_line = line.replace("\\", "\\\\").replace("\"", "\\\"")
            lines_json_arr = lines_json_arr + "      {"
                           + json_kv_int("idx", i) + ", "
                           + "\"line\": \"" + safe_line + "\", "
                           + json_kv_float("duration_s", dur) + ", "
                           + json_kv_str("wav", wav)
                           + "}"
        } else {
            println("  [SKIP] idx=" + pad2(i) + " synth failed")
        }
        i = i + 1
    }

    let manifest_path = STATE_DIR + "/piper_persona_" + to_string(id) + "_" + STAMP + ".json"
    let male_str = "false"
    if is_male { male_str = "true" }
    let body = "{\n"
             + "  \"schema\": \"piper_ab_persona/v1\",\n"
             + "  \"stamp\": \"" + STAMP + "\",\n"
             + "  \"engine\": \"piper-kss-korean\",\n"
             + "  \"sample_rate\": 22050,\n"
             + "  \"persona_id\": " + to_string(id) + ",\n"
             + "  \"persona_name\": \"" + name + "\",\n"
             + "  \"is_male\": " + male_str + ",\n"
             + "  \"piper_params\": \"" + params + "\",\n"
             + "  \"line_count\": " + to_string(ok_count) + ",\n"
             + "  \"total_duration_s\": " + to_string(total_dur) + ",\n"
             + "  \"clips\": [\n"
             + lines_json_arr + "\n"
             + "  ]\n"
             + "}\n"
    write_file(manifest_path, body)
    println("  [MANIFEST] " + manifest_path)

    return [to_string(id), name, to_string(ok_count), to_string(total_dur)]
}

fn main() {
    println("════════════════════════════════════════════════════════════")
    println("  anima-speak piper A/B generator — 10 persona × 8 lines")
    println("  engine: piper-kss-korean (22050 Hz VITS)")
    println("  filter: per-persona piper emotion params + ffmpeg tonal chain")
    println("  R37 compliance: no python, hexa-only orchestration")
    println("════════════════════════════════════════════════════════════")

    ensure_dir(OUT_ROOT)

    let mut total_ok = 0
    let mut total_dur = 0.0
    let mut id = 10
    while id <= 19 {
        let res = process_persona(id)
        total_ok = total_ok + to_int(res[2])
        total_dur = total_dur + to_float(res[3])
        id = id + 1
    }

    println("")
    println("════════════════════════════════════════════════════════════")
    println("  TOTAL: " + to_string(total_ok) + " / 80 ok")
    println("  TOTAL DURATION: " + to_string(total_dur) + " s")
    println("  OUT_ROOT: " + OUT_ROOT)
    println("════════════════════════════════════════════════════════════")
}
