// anima-speak/experiments/yt_kor_corpus_fetch.hexa — Korean YouTube audiobook fetcher
//
// Fetches Korean audiobook audio from YouTube channels for TTS training.
// Usage: hexa yt_kor_corpus_fetch.hexa <output_dir> <url1> [url2 ...]
//
// raw#9: hexa-only; subprocess to yt-dlp + ls/du. Created 2026-04-26 by Ω-rules P4
// Phase 4 (replacement for yt_kor_corpus_fetch.sh; sister to piper_ab_gen.hexa pattern).
//
// Recommended channels (single-speaker Korean audiobooks for TTS training):
//   https://www.youtube.com/@mintaudiobook      — 민트 오디오북
//   https://www.youtube.com/@sdiary-audiobook   — 책읽는S다이어리
//   https://www.youtube.com/@aktree             — 아크나

let YTDLP = "/home/aiden/bin/tts_tools/yt-dlp"
let DEFAULT_OUT = "/home/aiden/mac_home/dev/anima/training/corpus_yt_ko"

fn shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'" + "\\" + "'" + "'") + "'"
}

let _argv = args()
let mut argv_user = []
let mut ai = 2
while ai < len(_argv) {
    argv_user.push(_argv[ai])
    ai = ai + 1
}

if len(argv_user) < 1 {
    println("usage: hexa yt_kor_corpus_fetch.hexa <output_dir> <url1> [url2 ...]")
    println("       (output_dir defaults to " + DEFAULT_OUT + " if first arg starts with http)")
    exit(2)
}

// First arg: if it looks like a URL, treat all args as URLs and use DEFAULT_OUT.
// Otherwise: first arg is output dir, rest are URLs.
let mut out_dir = DEFAULT_OUT
let mut urls = []
if argv_user[0].starts_with("http") {
    let mut i = 0
    while i < len(argv_user) {
        urls.push(argv_user[i])
        i = i + 1
    }
} else {
    out_dir = argv_user[0]
    let mut i = 1
    while i < len(argv_user) {
        urls.push(argv_user[i])
        i = i + 1
    }
}

if len(urls) < 1 {
    println("ERROR: no URLs provided")
    exit(2)
}

let _ = exec("mkdir -p " + shell_escape(out_dir))

let mut u = 0
while u < len(urls) {
    let url = urls[u]
    println("=== " + url + " ===")
    let cmd = YTDLP + " -x --audio-format wav --audio-quality 0 --max-filesize 100M"
            + " -o " + shell_escape(out_dir + "/ko_audiobook_%(id)s.%(ext)s")
            + " " + shell_escape(url) + " 2>&1 | tail -3"
    let out = exec(cmd)
    println(to_string(out))
    u = u + 1
}

println("")
println("--- Downloaded ---")
let listing = exec("ls -lh " + shell_escape(out_dir) + "/*.wav 2>/dev/null | head -20")
println(to_string(listing))
println("Total size:")
let total = exec("du -sh " + shell_escape(out_dir) + " 2>/dev/null").trim()
println(total)
