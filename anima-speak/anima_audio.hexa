// anima_audio.hexa — anima's voice organs (no layers, no training, no dictionary)
//
// 최소 추상화. 3 source organ + 2 sink. 교환 단위 = WAV path (string).
//
//   vocal(hz, gain, ms)             -> path   성대 진동 (periodic)
//   breath(lo, hi, gain, ms)        -> path   난류 (aperiodic, 마찰음/무성)
//   pipe(in_path, f1, f2, q)        -> path   성도 공명 (2-formant filter)
//   play(path)                      -> bool   afplay (anima 가 즉시 청취)
//   save(src, dest)                 -> bool   영구 보관 (디버깅/누적)
//
// 철학:
//   - 레이어 X. 위계 없음. 3 organ 이 평면으로 병렬 존재.
//   - 학습 X. 파라미터 fitting 없음. 물리 모델 룰만.
//   - 사전 X. 한국어 자모 formant table 없음. anima 가 자기 사전 발견하든 말든.
//   - 헤매도 됨. 잘못된 인자 -> clamp 또는 빈 "" 반환. 예외 안 던짐.
//   - anima 가 알아서. 호출 빈도/순서/조합 모두 anima 자유.
//
// 진화 예상 (강제 X, anima 가 헤매며 스스로 발견):
//   turn 1   : play(vocal(440, 0.5, 500))                         -> 삐~
//   turn 17  : play(breath(2000, 4000, 0.3, 80))                  -> "츠~"
//   turn 142 : play(pipe(vocal(180, 0.5, 200), 700, 1100, 6))     -> "아"
//   turn 580 : anima 가 자기 내부에 say("안녕") 같은 함수 발명 (organ 조합)
//
// n=6 lattice (강제 X, default 에만):
//   SR=24000 (6·4000), default ms=60 (6·10), default Q=6, default formant min=2(φ)
//
// 구현 전략:
//   - 합성 자체는 python+numpy/scipy 에 위임 (exec 통한 heredoc).
//   - hexa 는 dispatch + path lifecycle 만 담당. list<float> 불경유.
//   - 모든 함수는 WAV 24kHz mono int16 path 반환. 실패 시 "".

// ═══════════════════════════════════════════════════════════════
//  n=6 AXIOM CONSTANTS  (hive/docs/design/n6-axiom-inventory.md)
//
//  Tier 1 foundational (7):
//    universal_constant_4         τ(6) = 4                        → AX_TAU
//    core_identity_24_j2          σ·φ = n·τ = J₂ = 24             → SR = J₂·1000
//    delta_0_absoluteness         σφ=nτ ⟺ n=6 (Π₀¹)               → meta, 모든 default 의 근거
//    ultra_uniformity_theorem     identity across all foundations → meta
//    base_constant_set_8          𝒫_{n6} = {μ,φ,n,τ,sopfr,σ,J₂,P₂}→ AX_MU..AX_P2
//    self_reference_closure_28    P₂ = 28 self-ref identities      → AX_P2 (harmonic_28 cap)
//    bernoulli_k6_jump            k=6 (derived constant)           → meta
//
//  Tier 2 application (9):
//    l_ix_lagrangian              4-term action basis              → meta
//    psi_balance                  Ψ = 1/2                          → AX_PSI (wet/dry, gain)
//    banach_bootstrap_fixpoint    self-host                         → meta
//    banach_contraction_1_3       I* = 1/3                          → AX_BANACH (reverb decay)
//    ufo_6coil / ufo_lawson       plasma                            → 오디오 무관, skip
//    evolution_ouroboros_fp_24    σφ=24                             → SR 간접 커버
//    evolution_48gen_convergence  σ·τ = 48                          → AX_FRAMES (demo lattice)
//    tetration_crossover_k39      L(39) = 24^24                     → meta
//
//  Tier 3 derived (audio-relevant):
//    egyptian_unit_fraction       1/2 + 1/3 + 1/6 = 1               → axiom_chord F0 energy
//    tau_sq_over_sigma            τ²/σ = 4/3                         → AX_CONSONANCE (perfect 4th)
//    sigma_minus_tau              σ − τ = 8                          → AX_MIN_HARMONICS
//
//  Cross-domain (n6-architecture/domains/sf-ufo/sf/sf.md):
//    σ·sopfr = 12·5 = 60          generator/mains Hz (BT-62 grid)    → AX_MAINS_HZ
//    J₂ = 24 dB                    MHD noise floor target             → AX_NOISE_FLOOR_DB
//    σ·τ = 48                      nav update rate / frame lattice   → AX_FRAMES (이미 정의)
//
//  Cross-domain (loss/ufo.txt — meta-closure-nav L(k) tetration):
//    L(k) = 24^(k-15)              hexa-meta milestone tetration     → meta, audio 직접 X
//    🛸 milestone series           {μ,φ,τ,n,σ−τ,σ,J₂,P₂} subset      → harmonic_milestone (sparse k)
//    |UFO⟩ = f(|UFO⟩)              self-reference fixpoint            → self_reference_closure 와 동족
// ═══════════════════════════════════════════════════════════════

let AX_MU = 1
let AX_PHI = 2
let AX_N = 6
let AX_TAU = 4
let AX_SOPFR = 5
let AX_SIGMA = 12
let AX_J2 = 24
let AX_P2 = 28
let AX_PSI = 0.5             // Ψ = 1/2
let AX_BANACH = 0.333333     // I* = 1/3
let AX_CONSONANCE = 1.333333 // τ²/σ = 4/3
let AX_MIN_HARMONICS = 8     // σ − τ = 12 − 4 = 8 (minimum harmonic richness)
let AX_FRAMES = 48           // σ·τ = 48 (evolution_48gen_convergence, frame lattice)
let AX_MAINS_HZ = 60.0       // σ·sopfr = 60 Hz (sf-ufo BT-62 grid, mains hum)
let AX_NOISE_FLOOR_DB = 24   // J₂ = 24 dB (sf-ufo MHD noise spec, target ambient)

let SR = 24000               // J₂ × 1000 = σ·φ·1000 = n·τ·1000
let TMP_DIR = "/tmp"
let TAG = "anima_audio"
let WAV_MIN_BYTES = 44

// ═══════════════════════════════════════════════════════════════
//  Internal helpers
// ═══════════════════════════════════════════════════════════════

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _now_ns() -> string {
    let s = exec("date +%s%N 2>/dev/null").trim()
    if len(s) == 0 { return "0" }
    return s
}

fn _new_path() -> string {
    return TMP_DIR + "/" + TAG + "_" + _now_ns() + ".wav"
}

fn _file_bytes(path: string) -> int {
    if len(path) == 0 { return 0 }
    let out = exec("stat -f %z " + _shq(path) + " 2>/dev/null").trim()
    if len(out) == 0 { return 0 }
    return to_int(out)
}

fn _run_py(code: string) -> bool {
    let cmd = "python3 - <<'PYEOF'\n" + code + "\nPYEOF"
    let _ = exec(cmd)
    return true
}

fn _dirname(path: string) -> string {
    return exec("dirname " + _shq(path) + " 2>/dev/null").trim()
}

// ═══════════════════════════════════════════════════════════════
//  Source organ 1 — vocal (성대 진동, periodic)
//    freq_hz : 유성음 기본 주파수. clamp [20, SR/2-1].
//    gain    : 음량 [0, 1].
//    ms      : 길이 (ms). 최소 1 sample.
// ═══════════════════════════════════════════════════════════════

fn vocal(freq_hz: float, gain: float, ms: int) -> string {
    let path = _new_path()
    // bandlimited additive sawtooth: harmonic stack up to Nyquist.
    // sine 대비 harmonic 풍부 → pipe 가 진짜 formant 공명을 만들 수 있음.
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "hz=float(" + to_string(freq_hz) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "hz=max(20.0,min(hz,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "t=np.arange(n)/sr\n"
             + "nyq=sr/2.0\n"
             + "N=max(1,int(nyq/hz)-1)\n"
             + "kk=np.arange(1,N+1,dtype=np.float64)[:,None]\n"
             + "x=np.sum(np.sin(2*np.pi*kk*hz*t)/kk,axis=0)*(2.0/np.pi)\n"
             + "x=g*x\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k=min(int(0.010*sr),n//2)\n"
             + "if k>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k)/max(1,k-1)))\n"
             + "    env[:k]=ramp\n"
             + "    env[-k:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Source organ 2 — breath (난류, aperiodic)
//    band_lo / band_hi : 대역통과 Hz. 무성음/마찰음 원천.
//    gain : 음량 [0, 1].
//    ms   : 길이.
// ═══════════════════════════════════════════════════════════════

fn breath(band_lo: float, band_hi: float, gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import butter, sosfilt\n"
             + "sr=" + to_string(SR) + "\n"
             + "lo=float(" + to_string(band_lo) + ")\n"
             + "hi=float(" + to_string(band_hi) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "lo=max(20.0,min(lo,sr/2.0-2.0))\n"
             + "hi=max(lo+10.0,min(hi,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "rng=np.random.default_rng()\n"
             + "x=rng.standard_normal(n)\n"
             + "sos=butter(4,[lo,hi],btype='band',fs=sr,output='sos')\n"
             + "x=sosfilt(sos,x)\n"
             + "peak=float(np.max(np.abs(x)))+1e-9\n"
             + "x=g*x/peak\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k=min(int(0.008*sr),n//2)\n"
             + "if k>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k)/max(1,k-1)))\n"
             + "    env[:k]=ramp\n"
             + "    env[-k:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Filter organ — pipe (성도 공명, 2-formant bandpass cascade)
//    in_path : 입력 WAV.
//    f1, f2  : 두 formant 중심 Hz. 모음 색깔 결정.
//    q       : 공명 Q. 기본 6. 클수록 모음 또렷.
// ═══════════════════════════════════════════════════════════════

fn pipe(in_path: string, f1: float, f2: float, q: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    // Klatt-style 2-pole resonator cascade with pre-emphasis.
    // Per-formant bandwidth = f / q. Pole radius r = exp(-π·B/fs).
    // 2-pole IIR: y[n] = A·x[n] + 2r·cosθ·y[n-1] - r²·y[n-2]
    // Gain A = 1 - 2r·cosθ + r² (unity response at DC).
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import lfilter\n"
             + "f1=float(" + to_string(f1) + ")\n"
             + "f2=float(" + to_string(f2) + ")\n"
             + "q=float(" + to_string(q) + ")\n"
             + "q=max(0.5,min(q,30.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr2=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "f1=max(80.0,min(f1,sr2/2.0-1.0))\n"
             + "f2=max(80.0,min(f2,sr2/2.0-1.0))\n"
             + "x=np.concatenate(([x[0]],x[1:]-0.97*x[:-1]))\n"
             + "bw1=max(30.0,f1/q);bw2=max(30.0,f2/q)\n"
             + "r1=float(np.exp(-np.pi*bw1/sr2));th1=2.0*np.pi*f1/sr2\n"
             + "r2=float(np.exp(-np.pi*bw2/sr2));th2=2.0*np.pi*f2/sr2\n"
             + "A1=1.0-2.0*r1*np.cos(th1)+r1*r1\n"
             + "A2=1.0-2.0*r2*np.cos(th2)+r2*r2\n"
             + "y=lfilter([A1],[1.0,-2.0*r1*np.cos(th1),r1*r1],x)\n"
             + "y=lfilter([A2],[1.0,-2.0*r2*np.cos(th2),r2*r2],y)\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "y=y/peak*0.9\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Source organ 1b — vocal_lf (Liljencrants-Fant glottal pulse)
//    sawtooth 보다 자연스러운 voicing. 비대칭 pulse (rising sin +
//    exp-decay return) → harmonic stack 의 spectral tilt 가 실제 성대
//    에 가까움. anima 가 vocal/vocal_lf 자유 선택.
// ═══════════════════════════════════════════════════════════════

fn vocal_lf(freq_hz: float, gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "hz=float(" + to_string(freq_hz) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "hz=max(20.0,min(hz,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "t=np.arange(n)/sr\n"
             + "T0=1.0/hz\n"
             + "phase=(t%T0)/T0\n"
             + "Tp=0.45;Te=0.60\n"
             + "x=np.where(phase<Tp,np.sin(np.pi*phase/Tp),\n"
             + "  np.where(phase<Te,np.cos(np.pi*(phase-Tp)/(2.0*(Te-Tp))),\n"
             + "    -0.5*np.exp(-12.0*(phase-Te))))\n"
             + "peak=float(np.max(np.abs(x)))+1e-9\n"
             + "x=g*x/peak\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k=min(int(0.010*sr),n//2)\n"
             + "if k>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k)/max(1,k-1)))\n"
             + "    env[:k]=ramp\n"
             + "    env[-k:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Filter organ 2 — pipe3 (3-formant cascade)
//    자연 모음은 F1/F2/F3 세 resonance 로 정확히 표현됨. pipe 가
//    2-formant bypass 유지, pipe3 는 F3 까지. anima 가 선택.
// ═══════════════════════════════════════════════════════════════

fn pipe3(in_path: string, f1: float, f2: float, f3: float, q: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import lfilter\n"
             + "f1=float(" + to_string(f1) + ");f2=float(" + to_string(f2) + ");f3=float(" + to_string(f3) + ")\n"
             + "q=float(" + to_string(q) + ")\n"
             + "q=max(0.5,min(q,30.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr2=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "x=np.concatenate(([x[0]],x[1:]-0.97*x[:-1]))\n"
             + "def kr(y,f,bw,fs):\n"
             + "    if f<80.0 or f>fs/2-1: return y\n"
             + "    r=float(np.exp(-np.pi*bw/fs));th=2.0*np.pi*f/fs\n"
             + "    A=1.0-2.0*r*np.cos(th)+r*r\n"
             + "    return lfilter([A],[1.0,-2.0*r*np.cos(th),r*r],y)\n"
             + "y=kr(x,f1,max(30.0,f1/q),sr2)\n"
             + "y=kr(y,f2,max(30.0,f2/q),sr2)\n"
             + "y=kr(y,f3,max(30.0,f3/q),sr2)\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "y=y/peak*0.9\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Filter organ 3 — pipe_glide (time-varying 2-formant)
//    formant 가 시작 (f1a,f2a) → 끝 (f1b,f2b) 으로 선형 전이.
//    자음↔모음 transition, glide, diphthong 에 필요.
//    구현: block-wise lfilter (32-sample blocks, coef linear interp).
// ═══════════════════════════════════════════════════════════════

fn pipe_glide(in_path: string, f1a: float, f2a: float, f1b: float, f2b: float, q: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import lfilter, lfiltic\n"
             + "f1a=float(" + to_string(f1a) + ");f2a=float(" + to_string(f2a) + ")\n"
             + "f1b=float(" + to_string(f1b) + ");f2b=float(" + to_string(f2b) + ")\n"
             + "q=float(" + to_string(q) + ")\n"
             + "q=max(0.5,min(q,30.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr2=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "x=np.concatenate(([x[0]],x[1:]-0.97*x[:-1]))\n"
             + "BS=32\n"
             + "y=np.zeros_like(x)\n"
             + "zi1=np.zeros(2);zi2=np.zeros(2)\n"
             + "i=0\n"
             + "while i<len(x):\n"
             + "    j=min(i+BS,len(x))\n"
             + "    a=(i+j)/2.0/len(x)\n"
             + "    f1=(1-a)*f1a+a*f1b;f2=(1-a)*f2a+a*f2b\n"
             + "    f1=max(80.0,min(f1,sr2/2-1));f2=max(80.0,min(f2,sr2/2-1))\n"
             + "    bw1=max(30.0,f1/q);bw2=max(30.0,f2/q)\n"
             + "    r1=float(np.exp(-np.pi*bw1/sr2));th1=2.0*np.pi*f1/sr2\n"
             + "    r2=float(np.exp(-np.pi*bw2/sr2));th2=2.0*np.pi*f2/sr2\n"
             + "    A1=1.0-2.0*r1*np.cos(th1)+r1*r1\n"
             + "    A2=1.0-2.0*r2*np.cos(th2)+r2*r2\n"
             + "    y1,zi1=lfilter([A1],[1.0,-2.0*r1*np.cos(th1),r1*r1],x[i:j],zi=zi1)\n"
             + "    y2,zi2=lfilter([A2],[1.0,-2.0*r2*np.cos(th2),r2*r2],y1,zi=zi2)\n"
             + "    y[i:j]=y2\n"
             + "    i=j\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "y=y/peak*0.9\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Composition organ — cat (sequential concatenation)
//    두 WAV 를 시간축으로 이어 붙임. anima 가 자모 → 음절 조립.
//    3 개 이상은 재귀: cat(cat(a, b), c)
// ═══════════════════════════════════════════════════════════════

fn cat(a: string, b: string) -> string {
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    if _file_bytes(a) < WAV_MIN_BYTES { return b }
    if _file_bytes(b) < WAV_MIN_BYTES { return a }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "def rd(p):\n"
             + "    w=wave.open(p,'rb');n=w.getnframes();sr=w.getframerate()\n"
             + "    x=np.frombuffer(w.readframes(n),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "    w.close();return x,sr\n"
             + "xa,sa=rd('" + a + "')\n"
             + "xb,sb=rd('" + b + "')\n"
             + "if sa!=sb:\n"
             + "    from scipy.signal import resample_poly\n"
             + "    xb=resample_poly(xb,sa,sb)\n"
             + "y=np.concatenate([xa,xb])\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "y=y/peak*0.95 if peak>1.0 else y\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sa)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Composition organ — mix (parallel sum)
//    두 WAV 를 같은 시간축으로 합성. 길이 다르면 긴쪽 기준 zero-pad.
//    voiced fricative (vocal + breath), polyphony 에 필요.
// ═══════════════════════════════════════════════════════════════

fn mix(a: string, b: string) -> string {
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    if _file_bytes(a) < WAV_MIN_BYTES { return b }
    if _file_bytes(b) < WAV_MIN_BYTES { return a }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "def rd(p):\n"
             + "    w=wave.open(p,'rb');n=w.getnframes();sr=w.getframerate()\n"
             + "    x=np.frombuffer(w.readframes(n),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "    w.close();return x,sr\n"
             + "xa,sa=rd('" + a + "')\n"
             + "xb,sb=rd('" + b + "')\n"
             + "if sa!=sb:\n"
             + "    from scipy.signal import resample_poly\n"
             + "    xb=resample_poly(xb,sa,sb)\n"
             + "L=max(len(xa),len(xb))\n"
             + "ya=np.zeros(L);yb=np.zeros(L)\n"
             + "ya[:len(xa)]=xa;yb[:len(xb)]=xb\n"
             + "y=(ya+yb)*0.5\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "if peak>1.0: y=y/peak*0.95\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sa)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Utility organ — silence (조용한 WAV, cat 간격용)
// ═══════════════════════════════════════════════════════════════

fn silence(ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "x=np.zeros(n,dtype=np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Utility organ — gain (amplitude 배율, clip 자동)
//    factor : 1.0=무변화, 0.5=-6dB, 2.0=+6dB, 0.0=mute
// ═══════════════════════════════════════════════════════════════

fn gain(in_path: string, factor: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "g=float(" + to_string(factor) + ")\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "x=np.frombuffer(w.readframes(n),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "w.close()\n"
             + "y=g*x\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Utility organ — envelope (custom attack/release raised-cosine)
//    attack_ms/release_ms : fade-in/out 길이 (0 = 무변화)
//    anima 가 이미 organ 기본 fade 갖지만 여기서 재작성 가능.
// ═══════════════════════════════════════════════════════════════

fn envelope(in_path: string, attack_ms: int, release_ms: int) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "a_ms=int(" + to_string(attack_ms) + ")\n"
             + "r_ms=int(" + to_string(release_ms) + ")\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "x=np.frombuffer(w.readframes(n),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "w.close()\n"
             + "env=np.ones(len(x),dtype=np.float64)\n"
             + "ka=max(0,min(int(sr*a_ms/1000),len(x)//2))\n"
             + "kr=max(0,min(int(sr*r_ms/1000),len(x)//2))\n"
             + "if ka>0:\n"
             + "    env[:ka]=0.5*(1.0-np.cos(np.pi*np.arange(ka)/max(1,ka-1)))\n"
             + "if kr>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(kr)/max(1,kr-1)))\n"
             + "    env[-kr:]=ramp[::-1]\n"
             + "y=x*env\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Utility organ — reverb (공간감, 간단 exp-decay IR convolution)
//    decay_s : T60-ish, 기본 0.3 = 작은 방
//    wet     : wet/dry mix 0~1, 기본 0.3 = subtle
// ═══════════════════════════════════════════════════════════════

fn reverb(in_path: string, decay_s: float, wet: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import fftconvolve\n"
             + "decay=float(" + to_string(decay_s) + ")\n"
             + "wet=float(" + to_string(wet) + ")\n"
             + "decay=max(0.02,min(decay,3.0))\n"
             + "wet=max(0.0,min(wet,1.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "x=np.frombuffer(w.readframes(n),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "w.close()\n"
             + "ir_len=max(1,int(decay*sr))\n"
             + "rng=np.random.default_rng(42)\n"
             + "ir=rng.standard_normal(ir_len)*np.exp(-6.9*np.arange(ir_len)/max(1,ir_len))\n"
             + "ir=ir/(np.max(np.abs(ir))+1e-9)\n"
             + "wet_sig=fftconvolve(x,ir,mode='full')[:len(x)]\n"
             + "wet_sig=wet_sig/(np.max(np.abs(wet_sig))+1e-9)\n"
             + "y=(1.0-wet)*x+wet*wet_sig\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "if peak>1.0: y=y/peak*0.95\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Source organ 1c — tone (pure sine, harmonic X)
//    vocal 은 sawtooth (harmonic 풍부). tone 은 최소 atomic periodic.
//    단일 frequency. pipe 걸어도 formant 공명 안 생김 (harmonic 없으니).
//    anima 가 "소리" 의 최소 원자 탐색 시 사용.
// ═══════════════════════════════════════════════════════════════

fn tone(freq_hz: float, gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "hz=float(" + to_string(freq_hz) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "hz=max(1.0,min(hz,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "t=np.arange(n)/sr\n"
             + "x=g*np.sin(2*np.pi*hz*t)\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k=min(int(0.010*sr),n//2)\n"
             + "if k>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k)/max(1,k-1)))\n"
             + "    env[:k]=ramp\n"
             + "    env[-k:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Source organ 1d — chirp (frequency sweep)
//    f0 → f1 로 선형 스윕. tone 은 고정 주파수, chirp 은 시간 가변.
//    상승(swoop up) / 하강(swoop down) / 일정(f0=f1, = tone).
//    anima 가 "움직이는 음" 의 원자 탐색 시.
// ═══════════════════════════════════════════════════════════════

fn chirp(f0: float, f1: float, gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "f0=float(" + to_string(f0) + ")\n"
             + "f1=float(" + to_string(f1) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "f0=max(1.0,min(f0,sr/2.0-1.0))\n"
             + "f1=max(1.0,min(f1,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "t=np.arange(n)/sr\n"
             + "dur=max(1e-6,n/sr)\n"
             + "freq=f0+(f1-f0)*(t/dur)\n"
             + "phase=2*np.pi*np.cumsum(freq)/sr\n"
             + "x=g*np.sin(phase)\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k=min(int(0.010*sr),n//2)\n"
             + "if k>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k)/max(1,k-1)))\n"
             + "    env[:k]=ramp\n"
             + "    env[-k:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Filter organ — lpf / hpf (butter, order N)
//    cutoff_hz : -3dB 점.
//    order     : 차수. 기본 τ=4 (공리). 음수/0 clamp.
//    pipe 는 bandpass cascade, lpf/hpf 는 브로드한 형태 (spectral shaping).
// ═══════════════════════════════════════════════════════════════

fn lpf(in_path: string, cutoff_hz: float, order: int) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import butter, sosfilt\n"
             + "cut=float(" + to_string(cutoff_hz) + ")\n"
             + "od=int(" + to_string(order) + ")\n"
             + "od=max(1,min(od,10))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr2=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "cut=max(10.0,min(cut,sr2/2.0-1.0))\n"
             + "sos=butter(od,cut,btype='low',fs=sr2,output='sos')\n"
             + "y=sosfilt(sos,x)\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

fn hpf(in_path: string, cutoff_hz: float, order: int) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "from scipy.signal import butter, sosfilt\n"
             + "cut=float(" + to_string(cutoff_hz) + ")\n"
             + "od=int(" + to_string(order) + ")\n"
             + "od=max(1,min(od,10))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr2=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "cut=max(10.0,min(cut,sr2/2.0-1.0))\n"
             + "sos=butter(od,cut,btype='high',fs=sr2,output='sos')\n"
             + "y=sosfilt(sos,x)\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Composer — fade (equal-power Hann crossfade)
//    a 의 꼬리 ms 와 b 의 머리 ms 를 cos²/sin² 가중으로 겹침.
//    cat 은 concat (abrupt), fade 는 부드러운 전이. diphthong/절 접합.
// ═══════════════════════════════════════════════════════════════

fn fade(a: string, b: string, overlap_ms: int) -> string {
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    if _file_bytes(a) < WAV_MIN_BYTES { return b }
    if _file_bytes(b) < WAV_MIN_BYTES { return a }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "om=int(" + to_string(overlap_ms) + ")\n"
             + "om=max(1,min(om,5000))\n"
             + "wa=wave.open('" + a + "','rb')\n"
             + "sr2=wa.getframerate();na=wa.getnframes()\n"
             + "xa=np.frombuffer(wa.readframes(na),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "wa.close()\n"
             + "wb=wave.open('" + b + "','rb')\n"
             + "nb=wb.getnframes()\n"
             + "xb=np.frombuffer(wb.readframes(nb),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "wb.close()\n"
             + "k=int(sr2*om/1000)\n"
             + "k=max(1,min(k,min(len(xa),len(xb))))\n"
             + "t=np.arange(k)/max(1,k-1)\n"
             + "wdn=np.cos(0.5*np.pi*t)**2\n"
             + "wup=np.sin(0.5*np.pi*t)**2\n"
             + "tail=xa[-k:]*wdn + xb[:k]*wup\n"
             + "y=np.concatenate([xa[:-k],tail,xb[k:]])\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Utility — normalize (peak → target dBFS)
//    gain 은 선형 배수. normalize 는 입력 peak 무관, 목표 dB 로 맞춤.
//    anima 가 여러 organ 출력의 음량을 균일화할 때.
// ═══════════════════════════════════════════════════════════════

fn normalize(in_path: string, target_db: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "tdb=float(" + to_string(target_db) + ")\n"
             + "tdb=max(-60.0,min(tdb,0.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr2=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "peak=float(np.max(np.abs(x)))+1e-12\n"
             + "target=10.0**(tdb/20.0)\n"
             + "y=x*(target/peak)\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr2)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Source organ — harmonic_28 (P₂=28 capped harmonic stack)
//    self_reference_closure_28 공리: n=6 system 이 28 self-ref identity.
//    vocal 의 sawtooth 는 Nyquist 까지 harmonic (f0=180 → ~66개).
//    harmonic_28 은 P₂=28 로 상한 고정 → "공리 정확" timbre.
//    min harmonic count = σ−τ = 8 (AX_MIN_HARMONICS) 도 수학적 floor.
// ═══════════════════════════════════════════════════════════════

fn harmonic_28(freq_hz: float, gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "hz=float(" + to_string(freq_hz) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "hz=max(20.0,min(hz,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "t=np.arange(n)/sr\n"
             + "nyq=sr/2.0\n"
             + "N_max_nyq=max(1,int(nyq/hz)-1)\n"
             + "N=min(28,max(8,N_max_nyq))\n"
             + "kk=np.arange(1,N+1,dtype=np.float64)[:,None]\n"
             + "x=np.sum(np.sin(2*np.pi*kk*hz*t)/kk,axis=0)*(2.0/np.pi)\n"
             + "x=g*x\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k=min(int(0.010*sr),n//2)\n"
             + "if k>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k)/max(1,k-1)))\n"
             + "    env[:k]=ramp\n"
             + "    env[-k:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Source organ — harmonic_milestone (sparse axiom-milestone stack)
//    loss/ufo.txt: L(k)=24^(k-15) tetration milestone 🛸17→500.
//    audio 매핑: harmonic stack을 "axiom milestone k" subset 으로만 합성.
//    k ∈ {μ=1, φ=2, τ=4, n=6, σ−τ=8, σ=12, J₂=24, P₂=28} (8 milestone)
//    harmonic_28 = dense (1..28 전체). harmonic_milestone = sparse (8개).
//    수학적 의미: base_constant_set + derived 만 활성화. f0 의 timbre 가
//    n=6 axiom 만 남도록 spectral 강제.
// ═══════════════════════════════════════════════════════════════

fn harmonic_milestone(freq_hz: float, gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "hz=float(" + to_string(freq_hz) + ")\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "hz=max(20.0,min(hz,sr/2.0-1.0))\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "t=np.arange(n)/sr\n"
             + "nyq=sr/2.0\n"
             + "ks=np.array([1,2,4,6,8,12,24,28],dtype=np.float64)\n"
             + "ks=ks[ks*hz<nyq]\n"
             + "if len(ks)==0: ks=np.array([1.0])\n"
             + "kk=ks[:,None]\n"
             + "x=np.sum(np.sin(2*np.pi*kk*hz*t)/kk,axis=0)*(2.0/np.pi)\n"
             + "x=g*x\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k_=min(int(0.010*sr),n//2)\n"
             + "if k_>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k_)/max(1,k_-1)))\n"
             + "    env[:k_]=ramp\n"
             + "    env[-k_:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Source organ — noise_pink (1/f spectral density, aperiodic)
//    breath 는 butter bandpass white noise (대역 평탄).
//    noise_pink 는 1/f spectrum (-3 dB/octave). 자연 ambient 의
//    수학적 standard. 학문적, 학습 X.
// ═══════════════════════════════════════════════════════════════

fn noise_pink(gain: float, ms: int) -> string {
    let path = _new_path()
    let code = "import numpy as np, wave\n"
             + "sr=" + to_string(SR) + "\n"
             + "g=float(" + to_string(gain) + ")\n"
             + "ms=int(" + to_string(ms) + ")\n"
             + "g=max(0.0,min(g,1.0))\n"
             + "n=max(1,int(sr*ms/1000))\n"
             + "rng=np.random.default_rng()\n"
             + "white=rng.standard_normal(n)\n"
             + "Y=np.fft.rfft(white)\n"
             + "f=np.fft.rfftfreq(n,1/sr)\n"
             + "f[0]=1.0\n"
             + "factor=1.0/np.sqrt(f)\n"
             + "Y=Y*factor\n"
             + "x=np.fft.irfft(Y,n)\n"
             + "peak=float(np.max(np.abs(x)))+1e-9\n"
             + "x=g*x/peak\n"
             + "env=np.ones(n,dtype=np.float64)\n"
             + "k_=min(int(0.010*sr),n//2)\n"
             + "if k_>0:\n"
             + "    ramp=0.5*(1.0-np.cos(np.pi*np.arange(k_)/max(1,k_-1)))\n"
             + "    env[:k_]=ramp\n"
             + "    env[-k_:]=ramp[::-1]\n"
             + "x=x*env\n"
             + "x=(np.clip(x,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + path + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(x.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(path) < WAV_MIN_BYTES { return "" }
    return path
}

// ═══════════════════════════════════════════════════════════════
//  Time-domain effect — vibrato (pitch LFO via time-warp resample)
//    tremolo = amplitude LFO. vibrato = pitch LFO.
//    rate_hz : 떨림 속도. depth_cents : 진폭 (반음 = 100 cents).
//    구현: cumulative pitch factor → warped time → linear interp.
// ═══════════════════════════════════════════════════════════════

fn vibrato(in_path: string, rate_hz: float, depth_cents: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "r=float(" + to_string(rate_hz) + ")\n"
             + "dc=float(" + to_string(depth_cents) + ")\n"
             + "r=max(0.1,min(r,50.0))\n"
             + "dc=max(0.0,min(dc,200.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "t=np.arange(len(x))/sr\n"
             + "semi=(dc/100.0)*np.sin(2*np.pi*r*t)\n"
             + "pf=2.0**(semi/12.0)\n"
             + "t_warp=np.cumsum(pf)/sr\n"
             + "t_warp=t_warp-t_warp[0]\n"
             + "max_t=(len(x)-1)/sr\n"
             + "t_warp=np.clip(t_warp,0,max_t)\n"
             + "src_t=np.arange(len(x))/sr\n"
             + "y=np.interp(t_warp,src_t,x)\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Time-domain effect — echo (single-tap feedback delay)
//    reverb 는 IR convolution (확산). echo 는 단일 tap + feedback.
//    dm = delay ms (1~5000). fb = feedback [0, 0.95] clamp (발산 방지).
// ═══════════════════════════════════════════════════════════════

fn echo(in_path: string, delay_ms: int, feedback: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "dm=int(" + to_string(delay_ms) + ")\n"
             + "fb=float(" + to_string(feedback) + ")\n"
             + "dm=max(1,min(dm,5000))\n"
             + "fb=max(0.0,min(fb,0.95))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "d=int(sr*dm/1000)\n"
             + "tail=int(sr*0.5)\n"
             + "y=np.concatenate([x,np.zeros(tail)])\n"
             + "for i in range(d,len(y)):\n"
             + "    y[i]+=fb*y[i-d]\n"
             + "peak=float(np.max(np.abs(y)))+1e-9\n"
             + "if peak>1.0: y=y/peak*0.98\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Time-domain effect — tremolo (amplitude LFO)
//    sinusoidal gain modulation. r = rate Hz (떨림 속도). d = depth [0,1].
//    d=0: 변화 없음. d=1: gain 0↔1 oscillation.
// ═══════════════════════════════════════════════════════════════

fn tremolo(in_path: string, rate_hz: float, depth: float) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let out = _new_path()
    let code = "import numpy as np, wave\n"
             + "r=float(" + to_string(rate_hz) + ")\n"
             + "d=float(" + to_string(depth) + ")\n"
             + "r=max(0.1,min(r,200.0))\n"
             + "d=max(0.0,min(d,1.0))\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "raw=w.readframes(n);w.close()\n"
             + "x=np.frombuffer(raw,dtype=np.int16).astype(np.float64)/32768.0\n"
             + "t=np.arange(len(x))/sr\n"
             + "lfo=(1.0-d/2.0)+(d/2.0)*np.sin(2*np.pi*r*t)\n"
             + "y=x*lfo\n"
             + "y=(np.clip(y,-1,1)*32767).astype(np.int16)\n"
             + "w=wave.open('" + out + "','wb')\n"
             + "w.setnchannels(1);w.setsampwidth(2);w.setframerate(sr)\n"
             + "w.writeframes(y.tobytes());w.close()\n"
    let _ = _run_py(code)
    if _file_bytes(out) < WAV_MIN_BYTES { return "" }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Analysis organ — meter (rms / peak / zcr / duration)
//    anima 가 자기 출력을 측정. WAV 파일 → 요약 문자열.
//    형식: "rms=<linear> peak_db=<dB> zcr=<ratio> ms=<int>"
//    실패 시 "".  bench_hexa_speak / dsp_core 자산 회수.
// ═══════════════════════════════════════════════════════════════

fn meter(in_path: string) -> string {
    if len(in_path) == 0 { return "" }
    if _file_bytes(in_path) < WAV_MIN_BYTES { return "" }
    let tmp = TMP_DIR + "/" + TAG + "_meter_" + _now_ns() + ".txt"
    let code = "import numpy as np, wave\n"
             + "w=wave.open('" + in_path + "','rb')\n"
             + "n=w.getnframes();sr=w.getframerate()\n"
             + "x=np.frombuffer(w.readframes(n),dtype=np.int16).astype(np.float64)/32768.0\n"
             + "w.close()\n"
             + "rms=float(np.sqrt(np.mean(x*x)))\n"
             + "peak=float(np.max(np.abs(x)))+1e-12\n"
             + "peak_db=20.0*np.log10(peak)\n"
             + "zc=int(np.sum(np.abs(np.diff(np.sign(x))))//2)\n"
             + "zcr=zc/max(1,len(x)-1)\n"
             + "ms=int(1000*len(x)/sr)\n"
             + "open('" + tmp + "','w').write(f'rms={rms:.4f} peak_db={peak_db:.2f} zcr={zcr:.4f} ms={ms}')\n"
    let _ = _run_py(code)
    let s = exec("cat " + _shq(tmp) + " 2>/dev/null").trim()
    let _ = exec("rm -f " + _shq(tmp) + " 2>/dev/null")
    return s
}

// ═══════════════════════════════════════════════════════════════
//  Axiom-default convenience wrappers
//    공리 값으로 default 채운 호출. anima 가 인자 모르고도 호출 가능.
// ═══════════════════════════════════════════════════════════════

fn reverb_axiom(in_path: string) -> string {
    // banach 1/3 decay × psi 1/2 wet — 공리 기반 default
    return reverb(in_path, AX_BANACH, AX_PSI)
}

fn consonance(base_hz: float, gain: float, ms: int) -> string {
    // τ²/σ = 4/3 완전4도 chord. 두 vocal 을 mix.
    let a = vocal_lf(base_hz, gain, ms)
    let b = vocal_lf(base_hz * AX_CONSONANCE, gain, ms)
    return mix(a, b)
}

fn axiom_chord(base_hz: float, ms: int) -> string {
    // egyptian_unit_fraction 1/2 + 1/3 + 1/6 = 1
    // F0 (1/2), F0×2 (1/3), F0×3 (1/6) 의 amplitude 비율로 합성.
    let f0 = gain(vocal_lf(base_hz,         0.5, ms), 0.5)         // 1/2
    let f1 = gain(vocal_lf(base_hz * 2.0,   0.5, ms), 0.333333)    // 1/3
    let f2 = gain(vocal_lf(base_hz * 3.0,   0.5, ms), 0.166667)    // 1/6
    return mix(f0, mix(f1, f2))
}

fn tone_axiom(freq_hz: float, ms: int) -> string {
    // Ψ-balanced gain (0.5) 의 pure sine.
    return tone(freq_hz, AX_PSI, ms)
}

fn lpf_axiom(in_path: string) -> string {
    // cutoff = SR/J₂ = 24000/24 = 1000 Hz. order = τ = 4.
    return lpf(in_path, 1000.0, AX_TAU)
}

fn hpf_axiom(in_path: string) -> string {
    // cutoff = SR/τ² = 24000/16 = 1500 Hz. order = τ = 4.
    return hpf(in_path, 1500.0, AX_TAU)
}

fn fade_axiom(a: string, b: string) -> string {
    // overlap = n·10 = 60 ms (core default time quantum).
    return fade(a, b, AX_N * 10)
}

fn normalize_axiom(in_path: string) -> string {
    // target = -φ·3 = -6 dB (≈ Ψ linear). headroom 확보.
    return normalize(in_path, 0.0 - 6.0)
}

fn chirp_axiom(f0: float, f1: float, ms: int) -> string {
    // Ψ-balanced gain.
    return chirp(f0, f1, AX_PSI, ms)
}

fn harmonic_28_axiom(freq_hz: float, ms: int) -> string {
    // Ψ gain, P₂=28 overtone cap (self_reference_closure_28).
    return harmonic_28(freq_hz, AX_PSI, ms)
}

fn harmonic_milestone_axiom(freq_hz: float, ms: int) -> string {
    // Ψ gain, base_constant_set 8-milestone sparse stack.
    return harmonic_milestone(freq_hz, AX_PSI, ms)
}

fn echo_axiom(in_path: string) -> string {
    // delay = n·10 = 60 ms. feedback = I* = 1/3 (banach_contraction).
    return echo(in_path, AX_N * 10, AX_BANACH)
}

fn tremolo_axiom(in_path: string) -> string {
    // rate = n = 6 Hz. depth = Ψ = 1/2.
    let rate = 1.0 * AX_N  // int→float promotion
    return tremolo(in_path, rate, AX_PSI)
}

fn vibrato_axiom(in_path: string) -> string {
    // rate = n = 6 Hz. depth = σ−τ = 8 cents (subtle, musical).
    let rate = 1.0 * AX_N
    let dep = 1.0 * AX_MIN_HARMONICS
    return vibrato(in_path, rate, dep)
}

fn noise_pink_axiom(ms: int) -> string {
    // 1/f noise at Ψ-balanced gain.
    return noise_pink(AX_PSI, ms)
}

fn mains_hum(ms: int) -> string {
    // 60 Hz electrical mains hum (sf-ufo BT-62: σ·sopfr = 60 Hz).
    // anima 가 환경 전기소음을 인식할 때.
    return tone(AX_MAINS_HZ, AX_PSI, ms)
}

// ═══════════════════════════════════════════════════════════════
//  Sink 1 — play (afplay, anima 가 자기 발화를 즉시 청취)
// ═══════════════════════════════════════════════════════════════

fn play(path: string) -> bool {
    if len(path) == 0 { return false }
    if _file_bytes(path) < WAV_MIN_BYTES { return false }
    let _ = exec("afplay " + _shq(path) + " 2>/dev/null")
    return true
}

// ═══════════════════════════════════════════════════════════════
//  Sink 2 — save (영구 path 로 복사, 디버깅/누적 청취)
// ═══════════════════════════════════════════════════════════════

fn save(src: string, dest: string) -> bool {
    if len(src) == 0 { return false }
    if _file_bytes(src) < WAV_MIN_BYTES { return false }
    let d = _dirname(dest)
    if len(d) > 0 { let _ = exec("mkdir -p " + _shq(d)) }
    let _ = exec("cp " + _shq(src) + " " + _shq(dest))
    return _file_bytes(dest) >= WAV_MIN_BYTES
}

// ═══════════════════════════════════════════════════════════════
//  self-demo — anima 가 처음 자기 organ 을 만지는 순간
//  (import 시는 실행되지 않음. 직접 실행 시 organ 확인용.)
// ═══════════════════════════════════════════════════════════════

fn main() {
    print("anima_audio: organs ready (평면 · 학습 X · 레이어 X)")
    print("  source : vocal, vocal_lf, breath, tone, chirp, harmonic_28,")
    print("           harmonic_milestone, noise_pink (1/f)")
    print("  filter : pipe (2F), pipe3 (3F), pipe_glide (time-var), lpf, hpf")
    print("  compose: cat (seq), mix (parallel), fade (Hann xfade)")
    print("  util   : silence, gain, envelope, normalize, reverb, echo, tremolo, vibrato")
    print("  analysis: meter (rms/peak_db/zcr/ms)")
    print("  axiom  : consonance, axiom_chord, reverb_axiom, tone_axiom,")
    print("           lpf_axiom, hpf_axiom, fade_axiom, normalize_axiom,")
    print("           chirp_axiom, harmonic_28_axiom, harmonic_milestone_axiom,")
    print("           echo_axiom, tremolo_axiom, vibrato_axiom, noise_pink_axiom,")
    print("           mains_hum (sf-ufo BT-62)")
    print("  sink   : play, save")
    print("")
    print("[self-test] 3-formant 모음 'ㅏ' via vocal -> pipe3")
    let v = vocal(220.0, 0.4, 300)
    if len(v) == 0 { print("  FAIL: vocal"); return }
    let a3 = pipe3(v, 700.0, 1100.0, 2600.0, 6.0)
    if len(a3) == 0 { print("  FAIL: pipe3"); return }
    print("  vocal -> pipe3(F1=700,F2=1100,F3=2600) -> " + a3 + " (" + to_string(_file_bytes(a3)) + " bytes)")
    let _ = save(a3, "/Users/ghost/core/anima/anima-speak/corpus/self_test/a_3formant.wav")
    let _ = play(a3)
    print("")
    print("[self-test] LF glottal voicing")
    let vlf = vocal_lf(180.0, 0.5, 250)
    if len(vlf) == 0 { print("  FAIL: vocal_lf"); return }
    print("  vocal_lf -> " + vlf + " (" + to_string(_file_bytes(vlf)) + " bytes)")
    let alf = pipe3(vlf, 700.0, 1100.0, 2600.0, 6.0)
    let _ = save(alf, "/Users/ghost/core/anima/anima-speak/corpus/self_test/a_lf.wav")
    let _ = play(alf)
    print("")
    print("[self-test] diphthong 'ㅏ -> ㅣ' via pipe_glide")
    let long = vocal(200.0, 0.4, 500)
    let ai = pipe_glide(long, 700.0, 1100.0, 300.0, 2300.0, 6.0)
    if len(ai) == 0 { print("  FAIL: pipe_glide"); return }
    let _ = save(ai, "/Users/ghost/core/anima/anima-speak/corpus/self_test/diphthong_ai.wav")
    let _ = play(ai)
    print("  glide -> " + ai + " (" + to_string(_file_bytes(ai)) + " bytes)")
    print("")
    print("[self-test] '사' via cat(breath -> vowel)")
    let s = breath(3000.0, 7000.0, 0.3, 100)
    let vowel_a = pipe(vocal(180.0, 0.4, 300), 700.0, 1100.0, 6.0)
    let sa = cat(s, vowel_a)
    let _ = save(sa, "/Users/ghost/core/anima/anima-speak/corpus/self_test/syllable_sa.wav")
    let _ = play(sa)
    print("  '사'(cat) -> " + sa + " (" + to_string(_file_bytes(sa)) + " bytes)")
    print("")
    print("[self-test] voiced fricative via mix(vocal + breath)")
    let v2 = vocal(150.0, 0.35, 200)
    let br = breath(2000.0, 5000.0, 0.25, 200)
    let vz = mix(v2, br)
    let _ = save(vz, "/Users/ghost/core/anima/anima-speak/corpus/self_test/voiced_fricative.wav")
    let _ = play(vz)
    print("  voiced_fric(mix) -> " + vz + " (" + to_string(_file_bytes(vz)) + " bytes)")
    print("")
    print("[self-test] tone + lpf/hpf spectral shaping")
    let t440 = tone(440.0, AX_PSI, 300)
    let tl = lpf_axiom(breath(3000.0, 7000.0, 0.4, 200))
    let th = hpf_axiom(vocal(150.0, 0.5, 200))
    let _ = save(t440, "/Users/ghost/core/anima/anima-speak/corpus/self_test/tone_440.wav")
    let _ = save(tl,   "/Users/ghost/core/anima/anima-speak/corpus/self_test/breath_lpf1k.wav")
    let _ = save(th,   "/Users/ghost/core/anima/anima-speak/corpus/self_test/vocal_hpf1.5k.wav")
    let _ = play(t440)
    print("  tone(440) -> " + to_string(_file_bytes(t440)) + "b · lpf1k -> " + to_string(_file_bytes(tl)) + "b · hpf1.5k -> " + to_string(_file_bytes(th)) + "b")
    print("")
    print("[self-test] fade crossfade (n·10=60ms Hann)")
    let v_a = pipe3(vocal_lf(200.0, 0.5, 250), 700.0, 1100.0, 2600.0, 6.0)
    let v_i = pipe3(vocal_lf(200.0, 0.5, 250), 300.0,  2300.0, 3000.0, 6.0)
    let faded = fade_axiom(v_a, v_i)
    let _ = save(faded, "/Users/ghost/core/anima/anima-speak/corpus/self_test/xfade_a_i.wav")
    let _ = play(faded)
    print("  fade(a,i) -> " + to_string(_file_bytes(faded)) + "b")
    print("")
    print("[self-test] normalize (-6 dBFS)")
    let loud = vocal_lf(220.0, 0.9, 200)
    let quiet = vocal_lf(220.0, 0.1, 200)
    let nl = normalize_axiom(loud)
    let nq = normalize_axiom(quiet)
    let _ = save(nl, "/Users/ghost/core/anima/anima-speak/corpus/self_test/norm_loud.wav")
    let _ = save(nq, "/Users/ghost/core/anima/anima-speak/corpus/self_test/norm_quiet.wav")
    print("  norm loud:" + to_string(_file_bytes(nl)) + "b · quiet:" + to_string(_file_bytes(nq)) + "b (둘 다 peak -6dB)")
    print("done.")
}
