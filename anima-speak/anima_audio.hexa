fn main() {
    print("anima_audio: organs ready (평면 · 학습 X · 레이어 X)")
    print("  source : vocal, vocal_lf, breath, tone, chirp, harmonic_28,")
    print("           harmonic_milestone, square_wave, triangle_wave,")
    print("           fm_synth (Bessel sidebands),")
    print("           noise_white (flat), noise_pink (1/f),")
    print("           noise_brown (1/f² = AX_PHI), noise_blue (f), noise_violet (f²)")
    print("  filter : pipe (2F), pipe3 (3F), pipe_glide (time-var), lpf, hpf,")
    print("           comb (FIR), all_pass (Schroeder), dc_block,")
    print("           low_shelf, high_shelf (RBJ EQ cookbook)")
    print("  compose: cat (seq), mix (parallel), fade (Hann xfade)")
    print("  util   : silence, gain, envelope, adsr, normalize, reverb, echo,")
    print("           tremolo, vibrato, clip (tanh), ring_mod (DSB-SC AM),")
    print("           am_mod (DSB-LC AM), flanger (LFO comb sweep),")
    print("           chorus (3-voice detune), rectify (|x| octave-up),")
    print("           gate (threshold mute), compressor, limiter,")
    print("           saturate_asinh (gentle), bit_crush, reverse")
    print("  analysis: meter (rms/peak_db/zcr/ms)")
    print("  axiom  : consonance, axiom_chord, reverb_axiom, tone_axiom,")
    print("           lpf_axiom, hpf_axiom, fade_axiom, normalize_axiom,")
    print("           chirp_axiom, harmonic_28_axiom, harmonic_milestone_axiom,")
    print("           echo_axiom, tremolo_axiom, vibrato_axiom,")
    print("           noise_pink_axiom, noise_brown_axiom (slope=AX_PHI),")
    print("           square_axiom, triangle_axiom, comb_axiom,")
    print("           clip_axiom (τ drive), ring_mod_axiom (60Hz carrier),")
    print("           adsr_axiom, noise_blue_axiom, fm_synth_axiom (φ ratio),")
    print("           bit_crush_axiom (sopfr=5 bit), noise_white_axiom,")
    print("           all_pass_axiom (Banach 1/3),")
    print("           low_shelf_axiom (1k cut, +6dB), high_shelf_axiom (1.5k cut, +6dB),")
    print("           noise_violet_axiom, flanger_axiom (τ ms, φ depth, Ψ rate),")
    print("           am_mod_axiom (60Hz, Ψ depth), gate_axiom (-J₂ dB),")
    print("           compressor_axiom (-J₂, τ:1), saturate_asinh_axiom,")
    print("           limiter, mains_hum (sf-ufo BT-62)")
    print("  sink   : play, save")
    print("")
    print("[self-test] 3-formant 모음 'ㅏ' via vocal -> pipe3")
    let v = vocal(220.0, 0.4, 300)
    if len(v) == 0 { print("  FAIL: vocal"); return }
    let a3 = pipe3(v, 700.0, 1100.0, 2600.0, 6.0)
    if len(a3) == 0 { print("  FAIL: pipe3"); return }
    print("  vocal -> pipe3(F1=700,F2=1100,F3=2600) -> " + a3 + " (" + to_string(_file_bytes(a3)) + " bytes)")
    let _ = save(a3, "/Users/ghost/core/anima/anima-speak/corpus/self_test/a_3formant.wav")
    let _ = play(a3)
    print("")
    print("[self-test] LF glottal voicing")
    let vlf = vocal_lf(180.0, 0.5, 250)
    if len(vlf) == 0 { print("  FAIL: vocal_lf"); return }
    print("  vocal_lf -> " + vlf + " (" + to_string(_file_bytes(vlf)) + " bytes)")
    let alf = pipe3(vlf, 700.0, 1100.0, 2600.0, 6.0)
    let _ = save(alf, "/Users/ghost/core/anima/anima-speak/corpus/self_test/a_lf.wav")
    let _ = play(alf)
    print("")
    print("[self-test] diphthong 'ㅏ -> ㅣ' via pipe_glide")
    let long = vocal(200.0, 0.4, 500)
    let ai = pipe_glide(long, 700.0, 1100.0, 300.0, 2300.0, 6.0)
    if len(ai) == 0 { print("  FAIL: pipe_glide"); return }
    let _ = save(ai, "/Users/ghost/core/anima/anima-speak/corpus/self_test/diphthong_ai.wav")
    let _ = play(ai)
    print("  glide -> " + ai + " (" + to_string(_file_bytes(ai)) + " bytes)")
    print("")
    print("[self-test] '사' via cat(breath -> vowel)")
    let s = breath(3000.0, 7000.0, 0.3, 100)
    let vowel_a = pipe(vocal(180.0, 0.4, 300), 700.0, 1100.0, 6.0)
    let sa = cat(s, vowel_a)
    let _ = save(sa, "/Users/ghost/core/anima/anima-speak/corpus/self_test/syllable_sa.wav")
    let _ = play(sa)
    print("  '사'(cat) -> " + sa + " (" + to_string(_file_bytes(sa)) + " bytes)")
    print("")
    print("[self-test] voiced fricative via mix(vocal + breath)")
    let v2 = vocal(150.0, 0.35, 200)
    let br = breath(2000.0, 5000.0, 0.25, 200)
    let vz = mix(v2, br)
    let _ = save(vz, "/Users/ghost/core/anima/anima-speak/corpus/self_test/voiced_fricative.wav")
    let _ = play(vz)
    print("  voiced_fric(mix) -> " + vz + " (" + to_string(_file_bytes(vz)) + " bytes)")
    print("")
    print("[self-test] tone + lpf/hpf spectral shaping")
    let t440 = tone(440.0, AX_PSI, 300)
    let tl = lpf_axiom(breath(3000.0, 7000.0, 0.4, 200))
    let th = hpf_axiom(vocal(150.0, 0.5, 200))
    let _ = save(t440, "/Users/ghost/core/anima/anima-speak/corpus/self_test/tone_440.wav")
    let _ = save(tl,   "/Users/ghost/core/anima/anima-speak/corpus/self_test/breath_lpf1k.wav")
    let _ = save(th,   "/Users/ghost/core/anima/anima-speak/corpus/self_test/vocal_hpf1.5k.wav")
    let _ = play(t440)
    print("  tone(440) -> " + to_string(_file_bytes(t440)) + "b · lpf1k -> " + to_string(_file_bytes(tl)) + "b · hpf1.5k -> " + to_string(_file_bytes(th)) + "b")
    print("")
    print("[self-test] fade crossfade (n·10=60ms Hann)")
    let v_a = pipe3(vocal_lf(200.0, 0.5, 250), 700.0, 1100.0, 2600.0, 6.0)
    let v_i = pipe3(vocal_lf(200.0, 0.5, 250), 300.0,  2300.0, 3000.0, 6.0)
    let faded = fade_axiom(v_a, v_i)
    let _ = save(faded, "/Users/ghost/core/anima/anima-speak/corpus/self_test/xfade_a_i.wav")
    let _ = play(faded)
    print("  fade(a,i) -> " + to_string(_file_bytes(faded)) + "b")
    print("")
    print("[self-test] normalize (-6 dBFS)")
    let loud = vocal_lf(220.0, 0.9, 200)
    let quiet = vocal_lf(220.0, 0.1, 200)
    let nl = normalize_axiom(loud)
    let nq = normalize_axiom(quiet)
    let _ = save(nl, "/Users/ghost/core/anima/anima-speak/corpus/self_test/norm_loud.wav")
    let _ = save(nq, "/Users/ghost/core/anima/anima-speak/corpus/self_test/norm_quiet.wav")
    print("  norm loud:" + to_string(_file_bytes(nl)) + "b · quiet:" + to_string(_file_bytes(nq)) + "b (둘 다 peak -6dB)")
    print("done.")
}
