// ω-audio-7 notch organ bench + Ω-B replication test.
// Synthesis path is pure hexa (vocal_hexa, pipe_hexa, notch_hexa).
// Validation FFT done by an external python analyzer (analyzer-only).
import "anima_audio.hexa"

let R = 5

fn _wav_hash(path: string) -> string {
    let s = exec("shasum -a 256 " + path + " 2>/dev/null | awk '{print $1}'").trim()
    return s
}

println("=== ω-audio-7 notch organ bench ===")

// === Ω-B /m/ replication: notch(pipe(vocal(120,0.5,300),250,2500,6.0), 1000, W) ===
// Probe multiple widths to find sharpest depth (RBJ Q = hz/width).
let v = vocal_hexa(120.0, 0.5, 300)
let p = pipe_hexa(v, 250.0, 2500.0, 6.0)
let m_path_w400 = notch_hexa(p, 1000.0, 400.0)
let m_path_w200 = notch_hexa(p, 1000.0, 200.0)
let m_path_w100 = notch_hexa(p, 1000.0, 100.0)
let m_path_w50  = notch_hexa(p, 1000.0,  50.0)
println("M_PATH_W400 " + m_path_w400)
println("M_PATH_W200 " + m_path_w200)
println("M_PATH_W100 " + m_path_w100)
println("M_PATH_W50  " + m_path_w50)
let _ = exec("cp " + m_path_w400 + " /tmp/omega_audio_7_m_w400.wav")
let _ = exec("cp " + m_path_w200 + " /tmp/omega_audio_7_m_w200.wav")
let _ = exec("cp " + m_path_w100 + " /tmp/omega_audio_7_m_w100.wav")
let _ = exec("cp " + m_path_w50  + " /tmp/omega_audio_7_m_w50.wav")
// Default test path = the one we use for the headline metric.
let m_path = m_path_w200
println("M_PATH " + m_path)
println("M_BYTES " + to_string(_file_bytes(m_path)))
println("HASH_M " + _wav_hash(m_path))
// Save for analyzer.
let _ = exec("cp " + m_path + " /tmp/omega_audio_7_m.wav")
let _ = exec("cp " + p + " /tmp/omega_audio_7_p_pre.wav")

// Sanity reference: pipe-only (no notch) -> baseline Ω-B input.
println("P_PATH " + p)
println("HASH_P " + _wav_hash(p))

// === Bench: notch_hexa on 100ms pipe-filtered input, 5 warm runs ===
let v100 = vocal_hexa(120.0, 0.5, 100)
let p100 = pipe_hexa(v100, 250.0, 2500.0, 6.0)
println("BENCH_INPUT_BYTES " + to_string(_file_bytes(p100)))

// Warmup.
let _w = notch_hexa(p100, 1000.0, 400.0)

let mut sum = 0
let mut i = 0
while i < R {
    let t0 = time_ms()
    let q = notch_hexa(p100, 1000.0, 400.0)
    let t1 = time_ms()
    let dt = t1 - t0
    println("notch run " + to_string(i+1) + ": " + to_string(dt) + " ms (path=" + q + ")")
    sum = sum + dt
    i = i + 1
}
let mean = sum / R
println("notch_hexa mean (5 runs, 100ms input): " + to_string(mean) + " ms")
println("BENCH_RESULT notch_hexa_ms=" + to_string(mean))
