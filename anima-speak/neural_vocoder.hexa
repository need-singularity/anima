// neural_vocoder.hexa — HEXA-SPEAK Mk.III: Native Neural Vocoder
//
// Purpose:
//   Decode RVQ latents → 24kHz fp32 PCM via real hexa neural compute.
//   Replaces the Mk.I 42-line skeleton (string-tag stub).
//
// Architecture (Mk.III Stage C, 2026-04-16):
//   Stage A   Latent → control signals (matmul: 384d latent → 6 sinusoidal
//             partials × {gain, freq_offset_log_hz} = 12d control vector
//             per frame).
//   Stage B   Control signals → 24 kHz waveform via additive sinusoid
//             synthesis with per-frame envelope smoothing (linear interp
//             across hop=240 samples).
//   Stage C   Spectral synthesis via iSTFT (FULLY WIRED):
//             latent(384d) -> W_spec(384 x 257) -> magnitude spectrum
//             -> Griffin-Lim iterative phase estimation (6 iterations)
//             -> iSTFT (CPU DFT inline / GPU via hxcuda_istft_bf16 FFI)
//             -> overlap-add -> 24 kHz PCM.
//             Auto-activates when HXCUDA_ENABLE=1 is set.
//             GPU path: hxcuda_istft_bridge.hexa dispatches to libhxcuda.so.
//             CPU path: inline O(N^2) DFT in this file for self-test.
//             Kernel source: hexa-lang/self/native/hxcuda_stft.cu
//
//   Route selection:
//     HXCUDA_ENABLE=1  -> Stage C (spectral synthesis, GPU or CPU DFT)
//     otherwise        -> Stage B (additive synthesis, fast, bounded timbre)
//     NEUROVOC_NATIVE=1 overrides both -> C-shim fused Stage A+B.
//
// n=6 parameters (anima n=6 invariant):
//   sample_rate    = 24000
//   frame_hz       = 100             (10ms hop, matches Stage 2/3)
//   hop            = 240             (24000 / 100)
//   latent_dim     = 384 = 64 × 6    (RVQ output dim)
//   n_partials     = 6               (additive partials per frame)
//   ctrl_dim       = 12 = 6 × 2      ({gain, freq_offset} per partial)
//   n_fft          = 512             (iSTFT window — Stage C)
//   istft_hop      = 128
//   spec_bins      = 257 = N_FFT/2+1 (magnitude spectrum dimension)
//   gl_iters       = 6               (Griffin-Lim phase iterations)
//
// Mk stage:     Mk.III Stage C (spectral synthesis wired)
// Upstream:     rvq_codebook.rvq_decode → [T_frames][384]
// Downstream:   plc_crossfade / vad_fsm / WAV sink
//
// Hexa quirks honoured (per memory/feedback_hexa_runtime.md):
//   - No `a[i] = v` bare assignment in growable arrays (use concat or
//     pre-sized buffer + write_at; here all output arrays grow via `+`).
//   - No `let match = ...` (match is reserved); we use `let m_state` etc.
//   - No `use "nn_core"` — primitives are inlined for self-containment.
//   - No cross-file `use "..."` imports — bridge API is called by the
//     pipeline orchestrator; inline CPU DFT provided for self-test.
//   - Top-level `main()` call removed (hexa auto-invokes; explicit call
//     would double-execute, see speak_e2e.hexa final comment).
//
// FFI gating (2026-04-16 — Linux libhxcuda.so verified):
//   HXCUDA_ENABLE=1  -> Stage C active (spectral synthesis)
//   HXCUDA_DISABLE=1 -> force Stage B additive path even on Linux
//   No silent fallbacks: dispatch errors surface via println and
//   caller honours I5 (empty audio on failure).

// ════════════════════════════════════════════════════════════════════
// Section 1. Constants
// ════════════════════════════════════════════════════════════════════

let SAMPLE_RATE   = 24000
let FRAME_HZ      = 100
let HOP           = 240
let LATENT_DIM    = 384
let N_PARTIALS    = 6
let CTRL_DIM      = 12          // 6 partials × {gain, freq_offset_log_hz}
let N_FFT         = 512         // iSTFT path (Stage C)
let ISTFT_HOP     = 128

let TWO_PI        = 6.283185307179586
let BASE_FREQ_HZ  = 200.0       // partial 0 fundamental ~ 200 Hz
let MAX_GAIN      = 0.18        // headroom: 6-partial sum < 1.0

// Stage C spectral synthesis constants
let SPEC_BINS     = 257          // N_FFT / 2 + 1 = 512/2 + 1
let SPEC_DIM      = 257          // output dim of W_spec projection
let GL_ITERS      = 6            // Griffin-Lim phase estimation iterations
let SPEC_FLOOR    = 0.001        // magnitude floor to avoid log(0) in phase est

// ════════════════════════════════════════════════════════════════════
// Section 1b. Native FFI — hxvocoder C shim (Stage A+B fused)
//
// hxvocoder_decode_nv: 4-arg entry (within FFI 6-arg ceiling)
//   out_p, latent_flat_p, W_ctrl_p, n_frames
// All constants baked (SR=24000, HOP=240, etc). ~100x over interpreter.
// Gate: NEUROVOC_NATIVE=1 activates the C path.
// Build: clang -O3 -shared -fPIC -o libhxvocoder.dylib hxvocoder.c -lm
// ════════════════════════════════════════════════════════════════════
@link("hxvocoder")
extern fn hxvocoder_version() -> int

@link("hxvocoder")
extern fn hxvocoder_decode_nv(out_p: int, latent_flat_p: int, W_ctrl_p: int, n_frames: int)

@link("hxvocoder")
extern fn hxvocoder_write_wav(path_p: int, samples_p: int, n_samples: int, sample_rate: int, result_p: int)

// ════════════════════════════════════════════════════════════════════
// Section 2. Pure-hexa NN primitives (inlined; no `use nn_core`)
// ════════════════════════════════════════════════════════════════════

fn vec_zeros(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// y[out_dim] = W[out_dim × in_dim] · x[in_dim] + b[out_dim]
// W is row-major flat. b may be empty (treated as zeros).
fn linear_proj(x: [float], W: [float], b: [float], in_dim: int, out_dim: int) -> [float] {
    let mut y = []
    let mut i = 0
    let has_bias = (len(b) == out_dim)
    while i < out_dim {
        let mut s = 0.0
        if has_bias { s = b[i] }
        let mut j = 0
        while j < in_dim {
            s = s + W[i * in_dim + j] * x[j]
            j = j + 1
        }
        y = y.push(s)
        i = i + 1
    }
    return y
}

// tanh-bounded activation, used for control-signal head so partial
// gains and freq offsets stay in a bounded, audible range.
fn tanh_vec(x: [float]) -> [float] {
    let mut y = []
    let mut i = 0
    while i < len(x) {
        y = y.push(tanh(x[i]))
        i = i + 1
    }
    return y
}

// Identity-like mock weight: W[o,i] = 1 if i % out_dim == o else 0.
// Sums every (in_dim/out_dim)-th input feature into output o. Used as
// the default projection when no trained weights are loaded (smoke
// test path). Keeps signal flow live without all-zero dead activations.
fn mock_weight_identity(in_dim: int, out_dim: int) -> [float] {
    let mut W = []
    let mut o = 0
    while o < out_dim {
        let mut i = 0
        while i < in_dim {
            if i % out_dim == o {
                W = W.push(1.0 / to_float(in_dim / out_dim))
            } else {
                W = W.push(0.0)
            }
            i = i + 1
        }
        o = o + 1
    }
    return W
}

// ════════════════════════════════════════════════════════════════════
// Section 2b. Checkpoint loader — W_ctrl from ckpt_w_ctrl.json
//
// JSON format: {"data": [f0, f1, ...]} — 4608 floats row-major.
// Falls back to mock_weight_identity if file missing or parse fails.
// ════════════════════════════════════════════════════════════════════

fn load_w_ctrl(path: string) -> [float] {
    let raw = read_file(path)
    if len(raw) < 10 {
        println("[neural_vocoder] no checkpoint at " + path + " — using mock weights")
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    // Find "data": [ ... ] — extract the array of floats
    let marker = "\"data\": ["
    let pos = raw.index_of(marker)
    if pos < 0 {
        println("[neural_vocoder] checkpoint parse fail — using mock weights")
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    let start = pos + len(marker)
    // Find closing ']' by scanning from start (no 2-arg index_of in stage0)
    let tail = raw.substring(start, len(raw))
    let end_pos = tail.index_of("]")
    if end_pos < 0 {
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    // Parse comma-separated floats — split once, trim, parse.
    // Avoids O(n²) char-by-char substring/concat over 4608-float JSON.
    let nums_str = tail.substring(0, end_pos)
    let parts = nums_str.split(",")
    let np = len(parts)
    let mut W = []
    let mut i = 0
    while i < np {
        let p = parts[i].trim()
        if len(p) > 0 { W = W.push(parse_float(p)) }
        i = i + 1
    }
    if len(W) != CTRL_DIM * LATENT_DIM {
        println("[neural_vocoder] checkpoint size mismatch: " + to_string(len(W))
                + " expected " + to_string(CTRL_DIM * LATENT_DIM) + " — using mock")
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    println("[neural_vocoder] loaded W_ctrl from " + path + " (" + to_string(len(W)) + " params)")
    return W
}

// ════════════════════════════════════════════════════════════════════
// Section 2c. Stage C weight loader — W_spec from ckpt_w_spec.json
//
// W_spec: [SPEC_BINS x LATENT_DIM] = [257 x 384] = 98688 floats.
// Projects 384d latent -> 257d magnitude spectrum (one per frame).
// JSON format: {"data": [f0, f1, ...]} — same as W_ctrl.
// Falls back to mock_weight_identity if checkpoint missing.
//
// Math:  mag[b] = sum_j W_spec[b * LATENT_DIM + j] * latent[j]
//        where b in [0, SPEC_BINS), j in [0, LATENT_DIM)
// ════════════════════════════════════════════════════════════════════

fn load_w_spec(path: string) -> [float] {
    let expected_size = SPEC_DIM * LATENT_DIM
    let raw = read_file(path)
    if len(raw) < 10 {
        println("[neural_vocoder] no W_spec checkpoint at " + path + " — using mock weights")
        return mock_weight_identity(LATENT_DIM, SPEC_DIM)
    }
    let marker = "\"data\": ["
    let pos = raw.index_of(marker)
    if pos < 0 {
        println("[neural_vocoder] W_spec checkpoint parse fail — using mock weights")
        return mock_weight_identity(LATENT_DIM, SPEC_DIM)
    }
    let start = pos + len(marker)
    let tail = raw.substring(start, len(raw))
    let end_pos = tail.index_of("]")
    if end_pos < 0 {
        return mock_weight_identity(LATENT_DIM, SPEC_DIM)
    }
    let nums_str = tail.substring(0, end_pos)
    let parts = nums_str.split(",")
    let np = len(parts)
    let mut W = []
    let mut i = 0
    while i < np {
        let p = parts[i].trim()
        if len(p) > 0 { W = W.push(parse_float(p)) }
        i = i + 1
    }
    if len(W) != expected_size {
        println("[neural_vocoder] W_spec size mismatch: " + to_string(len(W))
                + " expected " + to_string(expected_size) + " — using mock")
        return mock_weight_identity(LATENT_DIM, SPEC_DIM)
    }
    println("[neural_vocoder] loaded W_spec from " + path + " (" + to_string(len(W)) + " params)")
    return W
}

// ════════════════════════════════════════════════════════════════════
// Section 3. Stage A — Latent → control signals
// ════════════════════════════════════════════════════════════════════

// One frame: [LATENT_DIM] → [CTRL_DIM]
// ctrl[2*p]   = log-frequency offset for partial p (in [-1, +1])
// ctrl[2*p+1] = gain for partial p              (in [-1, +1])
fn latent_to_ctrl(latent_frame: [float], W: [float]) -> [float] {
    // Linear projection then tanh activation
    let raw = linear_proj(latent_frame, W, [], LATENT_DIM, CTRL_DIM)
    return tanh_vec(raw)
}

// ════════════════════════════════════════════════════════════════════
// Section 4. Stage B — Additive synthesis
//
// Per output sample at global time-index t, find the surrounding two
// frames, linearly interpolate the control vector, and accumulate
// partials = sum_p gain_p · sin(2π · freq_p · t / SR).
//
// Note: phase continuity across frame boundaries is maintained by
// integrating frequency into a running phase accumulator per partial.
// (NOT closed-form sin(2π·f·t) which would phase-jump on freq changes.)
// ════════════════════════════════════════════════════════════════════

fn freq_from_offset(partial_idx: int, offset: float) -> float {
    // Partial p has nominal frequency BASE_FREQ_HZ × (p + 1)
    // offset ∈ [-1, +1] scales it by 2^offset (one octave each way)
    let nominal = BASE_FREQ_HZ * to_float(partial_idx + 1)
    // 2^offset ≈ exp(offset · ln2)
    let LN2 = 0.6931471805599453
    let scale = exp(offset * LN2)
    return nominal * scale
}

fn synth_additive(ctrl_frames: [[float]], n_samples: int) -> [float] {
    // Per-partial phase accumulator (radians)
    let mut phase = vec_zeros(N_PARTIALS)

    // Output buffer (grow via concat to honour hexa quirks)
    let mut out = []

    // Inverse sample rate
    let inv_sr = 1.0 / to_float(SAMPLE_RATE)

    let n_frames = len(ctrl_frames)
    let mut t = 0
    while t < n_samples {
        // Locate the two surrounding frames
        let frame_pos = to_float(t) / to_float(HOP)
        let mut f0 = to_int(frame_pos)
        if f0 < 0 { f0 = 0 }
        if f0 >= n_frames { f0 = n_frames - 1 }
        let mut f1 = f0 + 1
        if f1 >= n_frames { f1 = n_frames - 1 }
        let alpha = frame_pos - to_float(f0)

        // Accumulate sample
        let mut s = 0.0
        let mut p = 0
        while p < N_PARTIALS {
            // Linear interp of {offset, gain} between f0 and f1
            let off_a = ctrl_frames[f0][p * 2]
            let off_b = ctrl_frames[f1][p * 2]
            let off = off_a * (1.0 - alpha) + off_b * alpha
            let gain_a = ctrl_frames[f0][p * 2 + 1]
            let gain_b = ctrl_frames[f1][p * 2 + 1]
            let gain = gain_a * (1.0 - alpha) + gain_b * alpha

            let freq = freq_from_offset(p, off)
            // Phase increment for this sample
            let dphi = TWO_PI * freq * inv_sr
            phase[p] = phase[p] + dphi
            // Wrap to [0, 2π) to keep magnitude bounded for sin precision
            if phase[p] > TWO_PI { phase[p] = phase[p] - TWO_PI }
            if phase[p] < 0.0   { phase[p] = phase[p] + TWO_PI }

            s = s + gain * MAX_GAIN * sin(phase[p])
            p = p + 1
        }

        out = out.push(s)
        t = t + 1
    }
    return out
}

// ════════════════════════════════════════════════════════════════════
// Section 4b. Stage C — Spectral synthesis (iSTFT path)
//
// Full spectral synthesis pipeline:
//   1. Latent projection: latent[384d] -> W_spec[257 x 384] -> mag[257]
//      Each latent frame is projected to a magnitude spectrum via matmul.
//      ReLU ensures non-negative magnitudes (physical constraint: energy
//      cannot be negative in the frequency domain).
//
//   2. Prosody conditioning (optional): scale magnitude envelope by
//      energy_scale from prosody params (applied as multiplicative gain).
//
//   3. Phase estimation — Griffin-Lim iterative algorithm:
//      Starting from random phase, alternate between:
//        a) Construct complex spectrum: S[k] = mag[k] * exp(j * phase[k])
//        b) iDFT -> time domain signal
//        c) Re-window the time-domain frame
//        d) DFT -> recover phase: phase[k] = atan2(Im, Re)
//      After GL_ITERS iterations, the phase is consistent with the
//      magnitude constraint. 6 iterations is sufficient for speech
//      (diminishing returns beyond ~10, see Griffin & Lim 1984).
//
//   4. iSTFT reconstruction via overlap-add:
//      Each frame: complex spectrum -> iDFT -> multiply synthesis window
//      -> accumulate into output buffer at hop-spaced positions.
//      COLA (Constant Overlap-Add) normalization divides by the
//      accumulated window-squared sum for perfect reconstruction.
//
//   5. Output: fp32 PCM at 24 kHz in [-1, +1].
//
// Inline CPU DFT: O(N^2) per frame, correct but slow (~1000x vs GPU).
// On HXCUDA_ENABLE=1 with GPU: hxcuda_istft_bridge.hexa handles the
// fast path. The pipeline orchestrator (hexa_speak.hexa) calls both
// files in sequence. For self-test, the inline CPU DFT runs standalone.
// ════════════════════════════════════════════════════════════════════

// ── 4b.1  Hann window generator (for STFT/iSTFT windowing) ──
// Hann(n) = 0.5 * (1 - cos(2*pi*n/N))
// Satisfies COLA constraint when hop <= n_fft/2 (here 128 <= 256).
fn make_hann_window(n_fft: int) -> [float] {
    let mut w = []
    let mut i = 0
    let inv_n = 1.0 / to_float(n_fft)
    while i < n_fft {
        let v = 0.5 * (1.0 - cos(TWO_PI * to_float(i) * inv_n))
        w = w.push(v)
        i = i + 1
    }
    return w
}

// ── 4b.2  Inline CPU DFT (real-to-complex, complex-to-real) ──
// Pure-hexa O(N^2) DFT. No FFT — correct reference for self-test.
// These mirror hxcuda_istft_bridge.hexa Section 8 but are inlined
// here because cross-file `use` imports are forbidden.

// cpu_dft_r2c: windowed frame x[n_fft] -> complex spectrum [re,im,...] (2*bins)
// DFT: X[k] = sum_n x[n] * exp(-j*2*pi*k*n/N)
fn cpu_dft_r2c(x: [float], n_fft: int) -> [float] {
    let bins = n_fft / 2 + 1
    let mut result = []
    let mut k = 0
    while k < bins {
        let mut re = 0.0
        let mut im = 0.0
        let mut n = 0
        while n < n_fft {
            let angle = TWO_PI * to_float(k) * to_float(n) / to_float(n_fft)
            re = re + x[n] * cos(angle)
            im = im - x[n] * sin(angle)   // negative sign: DFT convention
            n = n + 1
        }
        result = result.push(re)
        result = result.push(im)
        k = k + 1
    }
    return result
}

// cpu_dft_c2r: complex spectrum [re,im,...] (2*bins) -> real signal [n_fft]
// iDFT: x[n] = (1/N) * sum_k X[k] * exp(+j*2*pi*k*n/N)
// Only bins 0..N/2 are given; conjugate symmetry doubles contributions
// for 1 <= k < N/2.
fn cpu_dft_c2r(spec_ri: [float], n_fft: int) -> [float] {
    let bins = n_fft / 2 + 1
    let inv_n = 1.0 / to_float(n_fft)
    let mut result = []
    let mut n = 0
    while n < n_fft {
        let mut val = 0.0
        let mut k = 0
        while k < bins {
            let re = spec_ri[k * 2]
            let im = spec_ri[k * 2 + 1]
            let angle = TWO_PI * to_float(k) * to_float(n) / to_float(n_fft)
            // iDFT contribution: Re{ X[k] * exp(+j*angle) }
            //   = re*cos(angle) - im*sin(angle)
            let contrib = re * cos(angle) - im * sin(angle)
            // DC (k=0) and Nyquist (k=N/2) count once; others twice
            // because the negative-frequency bin is the conjugate mirror.
            if k == 0 || k == n_fft / 2 {
                val = val + contrib
            } else {
                val = val + 2.0 * contrib
            }
            k = k + 1
        }
        result = result.push(val * inv_n)
        n = n + 1
    }
    return result
}

// ── 4b.3  Latent -> magnitude spectrum projection ──
// Projects one latent frame [384d] through W_spec [257 x 384]
// to produce a non-negative magnitude spectrum [257].
// ReLU activation ensures mag >= 0 (physical constraint).
fn latent_to_mag_spectrum(latent_frame: [float], W_spec: [float]) -> [float] {
    // Linear projection: mag_raw[b] = sum_j W_spec[b*384 + j] * latent[j]
    let raw = linear_proj(latent_frame, W_spec, [], LATENT_DIM, SPEC_DIM)
    // ReLU: magnitude must be non-negative (energy is non-negative)
    let mut mag = []
    let mut i = 0
    while i < SPEC_DIM {
        let v = raw[i]
        if v > 0.0 {
            mag = mag.push(v)
        } else {
            mag = mag.push(SPEC_FLOOR)   // floor prevents zero-energy bins
        }
        i = i + 1
    }
    return mag
}

// ── 4b.4  Griffin-Lim phase estimation ──
// Given a magnitude spectrum, estimate phase iteratively.
// Algorithm (Griffin & Lim, 1984):
//   1. Start with random phase (uniform in [0, 2*pi])
//   2. Construct complex: S = mag * exp(j*phase)
//   3. iDFT -> time-domain frame
//   4. DFT -> new complex spectrum
//   5. Extract phase: new_phase = atan2(Im, Re)
//   6. Repeat from step 2 with new_phase
// After GL_ITERS, return the final complex spectrum as [re,im,...].
//
// For deterministic self-test, initial phase uses a simple hash of the
// magnitude values rather than true random (no PRNG dependency).
fn griffin_lim_phase(mag: [float], n_fft: int) -> [float] {
    let bins = n_fft / 2 + 1

    // Initial phase: deterministic pseudo-random from mag values.
    // phase[k] = (mag[k] * 137.035999) mod (2*pi)
    // The fine-structure constant multiplier spreads phases well.
    let mut phase = []
    let mut k = 0
    while k < bins {
        let init_phase = mag[k] * 137.035999
        // Wrap to [0, 2*pi)
        let mut p = init_phase - to_float(to_int(init_phase / TWO_PI)) * TWO_PI
        if p < 0.0 { p = p + TWO_PI }
        phase = phase.push(p)
        k = k + 1
    }

    // Iterative refinement
    let mut iter = 0
    while iter < GL_ITERS {
        // Construct complex spectrum: S[k] = mag[k] * exp(j * phase[k])
        let mut spec_ri = []
        k = 0
        while k < bins {
            let re = mag[k] * cos(phase[k])
            let im = mag[k] * sin(phase[k])
            spec_ri = spec_ri.push(re)
            spec_ri = spec_ri.push(im)
            k = k + 1
        }

        // iDFT -> time domain
        let time_frame = cpu_dft_c2r(spec_ri, n_fft)

        // DFT -> recover complex spectrum with updated phase
        let new_spec = cpu_dft_r2c(time_frame, n_fft)

        // Extract phase: atan2(Im, Re)
        let mut new_phase = []
        k = 0
        while k < bins {
            let re = new_spec[k * 2]
            let im = new_spec[k * 2 + 1]
            // atan2 gives angle in [-pi, pi]; we keep as-is (sin/cos handle it)
            new_phase = new_phase.push(atan2(im, re))
            k = k + 1
        }
        phase = new_phase
        iter = iter + 1
    }

    // Build final complex spectrum with converged phase
    let mut final_spec = []
    k = 0
    while k < bins {
        let re = mag[k] * cos(phase[k])
        let im = mag[k] * sin(phase[k])
        final_spec = final_spec.push(re)
        final_spec = final_spec.push(im)
        k = k + 1
    }
    return final_spec
}

// ── 4b.5  iSTFT overlap-add reconstruction (CPU path) ──
// Reconstructs PCM audio from per-frame complex spectra via iDFT +
// overlap-add with Hann synthesis window and COLA normalization.
//
// spec_frames: [[float]] — each element is [re,im,...] with 2*bins floats
// n_fft:       int       — FFT window size (512)
// hop:         int       — hop length (128)
// window:      [float]   — synthesis window [n_fft] (Hann)
//
// Returns: [float] — reconstructed audio
fn istft_overlap_add(spec_frames: [[float]], n_fft: int, hop: int, window: [float]) -> [float] {
    let n_frames = len(spec_frames)
    let out_len = (n_frames - 1) * hop + n_fft
    if out_len <= 0 { return [] }

    // Accumulator buffers via alloc_raw for O(1) random-access writes.
    // audio_buf: accumulated windowed iDFT output
    // wsum_buf:  accumulated window^2 for COLA normalization
    let audio_buf = alloc_raw(out_len * 4)
    let wsum_buf  = alloc_raw(out_len * 4)
    // Zero-fill both buffers
    let mut zi = 0
    while zi < out_len {
        write_f32(audio_buf, zi * 4, 0.0)
        write_f32(wsum_buf,  zi * 4, 0.0)
        zi = zi + 1
    }

    // Overlap-add loop: for each frame, iDFT + window + accumulate
    let mut t = 0
    while t < n_frames {
        // iDFT: complex spectrum -> n_fft time-domain samples
        let time_frame = cpu_dft_c2r(spec_frames[t], n_fft)

        // Window + accumulate at position t*hop
        let mut k = 0
        while k < n_fft {
            let s = t * hop + k
            if s < out_len {
                let w = window[k]
                // audio_buf[s] += time_frame[k] * w
                let old_a = deref_f32(audio_buf, s * 4)
                write_f32(audio_buf, s * 4, old_a + time_frame[k] * w)
                // wsum_buf[s] += w * w  (for COLA normalization)
                let old_w = deref_f32(wsum_buf, s * 4)
                write_f32(wsum_buf, s * 4, old_w + w * w)
            }
            k = k + 1
        }
        t = t + 1
    }

    // COLA normalization: divide audio by window sum to recover true amplitude.
    // Where wsum is near-zero (edges), output is set to 0.0 to avoid division
    // by zero. Hann window with hop=128 on n_fft=512 gives wsum >= 0.5 in
    // the steady-state region.
    let eps = 1.0e-8
    let mut result = []
    let mut ri = 0
    while ri < out_len {
        let a = deref_f32(audio_buf, ri * 4)
        let w = deref_f32(wsum_buf, ri * 4)
        if w > eps {
            result = result.push(a / w)
        } else {
            result = result.push(0.0)
        }
        ri = ri + 1
    }

    free_raw(audio_buf, out_len * 4)
    free_raw(wsum_buf, out_len * 4)
    return result
}

// ── 4b.6  vocoder_spectral: full Stage C entry point ──
// Decodes RVQ latent frames to 24kHz PCM via spectral synthesis.
//
// Pipeline per frame:
//   latent[384d] -> W_spec matmul -> mag[257] -> ReLU
//   -> Griffin-Lim(6 iters) -> complex[257] -> iDFT -> windowed frame
// Then all frames are overlap-added into continuous PCM.
//
// prosody_energy: multiplicative gain from prosody conditioning (1.0 = neutral).
// W_spec:         spectral projection weights [257 x 384].
fn vocoder_spectral(latent_frames: [[float]], W_spec: [float], prosody_energy: float) -> [float] {
    let n_frames = len(latent_frames)
    if n_frames == 0 { return [] }

    let n_fft = N_FFT
    let hop = ISTFT_HOP
    let bins = n_fft / 2 + 1
    let window = make_hann_window(n_fft)

    println("[neural_vocoder] Stage C spectral: frames=" + to_string(n_frames)
            + " n_fft=" + to_string(n_fft) + " hop=" + to_string(hop)
            + " bins=" + to_string(bins) + " gl_iters=" + to_string(GL_ITERS))

    // Per-frame: project latent -> magnitude -> Griffin-Lim -> complex spectrum
    let mut spec_frames = []
    let mut f = 0
    while f < n_frames {
        // Step 1: latent -> magnitude spectrum
        let mut mag = latent_to_mag_spectrum(latent_frames[f], W_spec)

        // Step 2: prosody energy conditioning (multiplicative scale)
        // prosody_energy > 1.0 boosts, < 1.0 attenuates. Applied uniformly
        // across all frequency bins. A per-bin formant-aware scaling would
        // be the Mk.IV upgrade path.
        if prosody_energy != 1.0 {
            let mut mag_scaled = []
            let mut b = 0
            while b < SPEC_DIM {
                let v = mag[b] * prosody_energy
                if v < SPEC_FLOOR { mag_scaled = mag_scaled.push(SPEC_FLOOR) }
                else { mag_scaled = mag_scaled.push(v) }
                b = b + 1
            }
            mag = mag_scaled
        }

        // Step 3: Griffin-Lim phase estimation (inline CPU DFT)
        let complex_spec = griffin_lim_phase(mag, n_fft)
        spec_frames = spec_frames.push(complex_spec)
        f = f + 1
    }

    // Step 4: iSTFT overlap-add reconstruction
    let pcm = istft_overlap_add(spec_frames, n_fft, hop, window)

    println("[neural_vocoder] Stage C produced " + to_string(len(pcm)) + " samples")
    return pcm
}

// ── 4b.7  vocoder_additive: Stage B wrapper ──
// Wraps the existing Stage A+B path for clean routing from decode_wave.
fn vocoder_additive(latent_frames: [[float]], W_ctrl: [float]) -> [float] {
    let n_frames = len(latent_frames)
    if n_frames == 0 { return [] }

    let mut ctrl_frames = []
    let mut f = 0
    while f < n_frames {
        let c = latent_to_ctrl(latent_frames[f], W_ctrl)
        ctrl_frames = ctrl_frames.push(c)
        f = f + 1
    }
    let n_samples = n_frames * HOP
    return synth_additive(ctrl_frames, n_samples)
}

// ════════════════════════════════════════════════════════════════════
// Section 5. Stage C — hxcuda iSTFT FFI hook (auto-probe)
//
// Source: hexa-lang/self/native/hxcuda_stft.cu
// Builds:
//   Linux: bash scripts/build_hxcuda_linux.sh
//          -> self/native/build/libhxcuda.so
//          Verified 2026-04-16 on RTX 3090 (sm_86, cuFFT-backed).
//          C-level dlopen + dlsym + hxcuda_istft_bf16 round-trip: PASS
//          (n_fft=8 hop=4 n_frames=3, DC input, finite normalised output).
//   Mac:   no CUDA on macOS — libhxcuda.dylib does not build.
//          dlopen returns NULL, Stage C probe reports offline, path
//          falls through to Stage B additive synth (default).
//
// Signature (struct-args ABI, mirrors hxcuda_stft.cu HxCudaIstftArgs):
//   off  0: n_frames     (int64)
//   off  8: n_fft        (int64)
//   off 16: hop          (int64)
//   off 24: out_len      (int64)  total audio_out buffer samples
//   off 32: spec_p       (int64)  device cufftComplex* [n_frames * bins]
//   off 40: window_p     (int64)  device float* [n_fft]
//   off 48: audio_out_p  (int64)  device float* [out_len]
//   off 56: n_samples_out(int64)  host int64_t* — effective sample count
//   total = 64 bytes

// hxcuda_stft_version() — 0 args, returns >=1 when STFT/iSTFT kernels
// are present. Used as the capability probe below.
@link("hxcuda")
extern fn hxcuda_stft_version() -> int

@link("hxcuda")
extern fn hxcuda_istft_bf16(args_p: int) -> int

@link("hxcuda")
extern fn hxcuda_stft_bf16(args_p: int) -> int

// Module-level one-shot probe result. 0 = unknown, 1 = online, -1 = offline.
// Populated by hxcuda_available() on first call.
let mut _hxcuda_probe_state = 0

// Returns true iff libhxcuda is loadable on this host AND the STFT
// kernels are present (version >=1). Probes once per run and caches
// the result. Honours HXCUDA_DISABLE=1 as a kill-switch.
//
// Mac safety: calling a null __ffi_sym_* on the codegen_c2 path is UB.
// To avoid this we require HXCUDA_ENABLE=1 as an explicit opt-in flag,
// which the Linux build sets before launch (see speak_e2e / deploy
// scripts). Without the flag we short-circuit to OFFLINE without ever
// touching the extern symbol — making Mac smoke runs safe even after
// libhxcuda.dylib never ships for macOS.
fn hxcuda_available() -> bool {
    if _hxcuda_probe_state == 1 { return true }
    if _hxcuda_probe_state == -1 { return false }
    // Kill switch — force Stage B even when libhxcuda is present.
    let kill = env("HXCUDA_DISABLE")
    if kill == "1" {
        println("[neural_vocoder] HXCUDA_DISABLE=1 — Stage C forced offline")
        _hxcuda_probe_state = -1
        return false
    }
    // Opt-in gate: only probe when the deploy side has confirmed that
    // libhxcuda is present on this host. The Linux pod launcher sets
    // HXCUDA_ENABLE=1; Mac never does → probe never touches the extern.
    let enable = env("HXCUDA_ENABLE")
    if enable != "1" {
        println("[neural_vocoder] Stage C OFFLINE — HXCUDA_ENABLE unset (Mac smoke default)")
        _hxcuda_probe_state = -1
        return false
    }
    // Live probe (Linux pod path): hxcuda_stft_version() returns 1 when
    // libhxcuda.so is loaded. Requires LD_LIBRARY_PATH to include the
    // hexa-lang/self/native/build directory.
    let v = hxcuda_stft_version()
    if v >= 1 {
        println("[neural_vocoder] Stage C ONLINE — libhxcuda loaded, hxcuda_stft_version=" + to_string(v))
        _hxcuda_probe_state = 1
        return true
    }
    println("[neural_vocoder] Stage C OFFLINE — probe returned " + to_string(v))
    _hxcuda_probe_state = -1
    return false
}

// ════════════════════════════════════════════════════════════════════
// Section 6. Public entry — decode_wave
//
// Inputs:
//   latent_frames: [[float]]  — [T_frames][LATENT_DIM] from RVQ decode
//   sample_rate:   int        — must match SAMPLE_RATE (24000)
//
// Returns:
//   [float] — n_samples = T_frames × HOP fp32 audio in [-1, +1]
//
// On invalid input (empty latent, wrong sample rate, dim mismatch),
// returns an empty array. Callers gate on len(out) > 0.
// ════════════════════════════════════════════════════════════════════

fn decode_wave(latent_frames: [[float]], sample_rate: int) -> [float] {
    if sample_rate != SAMPLE_RATE {
        println("[neural_vocoder] sample_rate mismatch: got "
                + to_string(sample_rate) + " expected " + to_string(SAMPLE_RATE))
        return []
    }
    let n_frames = len(latent_frames)
    if n_frames == 0 {
        return []
    }
    if len(latent_frames[0]) != LATENT_DIM {
        println("[neural_vocoder] latent dim mismatch: got "
                + to_string(len(latent_frames[0]))
                + " expected " + to_string(LATENT_DIM))
        return []
    }

    // ── Route selection: Stage C (spectral) vs Stage B (additive) ──
    // HXCUDA_ENABLE=1 activates spectral synthesis (CPU DFT inline or
    // GPU via hxcuda_istft_bridge). Without it, additive synthesis is
    // used (fast, bounded timbre, good for smoke checks).
    let stage_c_ready = hxcuda_available()
    if stage_c_ready {
        println("[neural_vocoder] Stage C ACTIVE — spectral synthesis via iSTFT")
        // Load W_spec weights (spectral projection: 384d -> 257 magnitude bins)
        let spec_ckpt_path = env("SPEAK_CKPT_W_SPEC")
        let W_spec = if spec_ckpt_path != "" { load_w_spec(spec_ckpt_path) } else { load_w_spec("anima-speak/ckpt_w_spec.json") }
        // Prosody energy conditioning: default 1.0 (neutral).
        // Pipeline orchestrator (hexa_speak.hexa) passes the real value
        // from emotion_prosody.compute_energy_scale(). For standalone
        // decode_wave calls, 1.0 means no prosody modulation.
        let prosody_energy = 1.0
        return vocoder_spectral(latent_frames, W_spec, prosody_energy)
    } else {
        println("[neural_vocoder] Stage B active — additive synthesis (no CUDA)")
    }

    // ── Native fast-path: Stage A+B fused in C (NEUROVOC_NATIVE=1) ──
    let use_native = env("NEUROVOC_NATIVE")
    if use_native == "1" {
        // Marshal hexa arrays → raw f32 buffers for hxvocoder_decode_nv
        let n_lat = n_frames * LATENT_DIM
        let latent_buf = alloc_raw(n_lat * 4)
        let mut fi = 0
        while fi < n_frames {
            let mut ji = 0
            while ji < LATENT_DIM {
                write_f32(latent_buf, (fi * LATENT_DIM + ji) * 4, latent_frames[fi][ji])
                ji = ji + 1
            }
            fi = fi + 1
        }
        // W_ctrl: load checkpoint first
        let ckpt_p = env("SPEAK_CKPT_W_CTRL")
        let W_ctrl_n = if ckpt_p != "" { load_w_ctrl(ckpt_p) } else { load_w_ctrl("anima-speak/ckpt_w_ctrl.json") }
        let n_w = CTRL_DIM * LATENT_DIM
        let W_buf = alloc_raw(n_w * 4)
        let mut wi = 0
        while wi < n_w {
            write_f32(W_buf, wi * 4, W_ctrl_n[wi])
            wi = wi + 1
        }
        // Output buffer
        let n_samples = n_frames * HOP
        let out_buf = alloc_raw(n_samples * 4)
        // Dispatch to C
        hxvocoder_decode_nv(out_buf, latent_buf, W_buf, n_frames)
        // Read back samples
        let mut wave = []
        let mut si = 0
        while si < n_samples {
            wave = wave.push(deref_f32(out_buf, si * 4))
            si = si + 1
        }
        free_raw(latent_buf, n_lat * 4)
        free_raw(W_buf, n_w * 4)
        free_raw(out_buf, n_samples * 4)
        return wave
    }

    // ── Fallback: pure-hexa Stage A + B (additive synthesis) ──
    let ckpt_path = env("SPEAK_CKPT_W_CTRL")
    let W_ctrl = if ckpt_path != "" { load_w_ctrl(ckpt_path) } else { load_w_ctrl("anima-speak/ckpt_w_ctrl.json") }
    return vocoder_additive(latent_frames, W_ctrl)
}

// ════════════════════════════════════════════════════════════════════
// Section 7. WAV I/O (PCM16, mono)
//
// Hexa string ops are null-terminated, so binary bytes don't survive
// a write_file() call. Workaround: build the WAV byte-for-byte as an
// int array, base64-encode it manually (3-bytes → 4-chars), shell
// `base64 -d` into the destination file. Avoids any python dependency
// and only relies on POSIX `base64`.
// ════════════════════════════════════════════════════════════════════

let B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

fn b64_char(i: int) -> string {
    return B64_ALPHA.substring(i, i + 1)
}

fn bytes_to_b64(bytes: [int]) -> string {
    // Collect b64 chars in a list, join once at end — avoids O(n²) string concat.
    let n = len(bytes)
    let mut chars = []
    let mut i = 0
    while i + 3 <= n {
        let b0 = bytes[i]
        let b1 = bytes[i + 1]
        let b2 = bytes[i + 2]
        let t = (b0 * 65536) + (b1 * 256) + b2
        chars = chars.push(b64_char((t / 262144) % 64))
        chars = chars.push(b64_char((t / 4096) % 64))
        chars = chars.push(b64_char((t / 64) % 64))
        chars = chars.push(b64_char(t % 64))
        i = i + 3
    }
    let rem = n - i
    if rem == 1 {
        let b0 = bytes[i]
        let t = b0 * 65536
        chars = chars.push(b64_char((t / 262144) % 64))
        chars = chars.push(b64_char((t / 4096) % 64))
        chars = chars.push("==")
    } else if rem == 2 {
        let b0 = bytes[i]
        let b1 = bytes[i + 1]
        let t = (b0 * 65536) + (b1 * 256)
        chars = chars.push(b64_char((t / 262144) % 64))
        chars = chars.push(b64_char((t / 4096) % 64))
        chars = chars.push(b64_char((t / 64) % 64))
        chars = chars.push("=")
    }
    return chars.join("")
}

// Append the 4 little-endian bytes of `v` (signed int32) to `bytes`.
fn push_u32_le(bytes: [int], v: int) -> [int] {
    let mut u = v
    if u < 0 { u = u + 4294967296 }
    let mut out = bytes
    out = out.push(u % 256)
    out = out.push((u / 256) % 256)
    out = out.push((u / 65536) % 256)
    out = out.push((u / 16777216) % 256)
    return out
}

fn push_u16_le(bytes: [int], v: int) -> [int] {
    let mut u = v
    if u < 0 { u = u + 65536 }
    let mut out = bytes
    out = out.push(u % 256)
    out = out.push((u / 256) % 256)
    return out
}

fn push_str(bytes: [int], s: string) -> [int] {
    let mut out = bytes
    let mut i = 0
    while i < len(s) {
        let sub = s.substring(i, i + 1)
        out = out.push(char_code(sub, 0))
        i = i + 1
    }
    return out
}

// Build PCM16 mono WAV bytes from fp32 audio in [-1, +1].
fn build_wav_bytes(samples: [float], sample_rate: int) -> [int] {
    let n = len(samples)
    let data_len = n * 2                          // 16-bit mono
    let chunk_size = 36 + data_len                // RIFF chunk size

    let mut bytes = []

    // ── RIFF header ──
    bytes = push_str(bytes, "RIFF")
    bytes = push_u32_le(bytes, chunk_size)
    bytes = push_str(bytes, "WAVE")

    // ── fmt subchunk ──
    bytes = push_str(bytes, "fmt ")
    bytes = push_u32_le(bytes, 16)                // subchunk1 size (PCM)
    bytes = push_u16_le(bytes, 1)                 // PCM format
    bytes = push_u16_le(bytes, 1)                 // 1 channel (mono)
    bytes = push_u32_le(bytes, sample_rate)
    bytes = push_u32_le(bytes, sample_rate * 2)   // byte rate
    bytes = push_u16_le(bytes, 2)                 // block align
    bytes = push_u16_le(bytes, 16)                // bits per sample

    // ── data subchunk ──
    bytes = push_str(bytes, "data")
    bytes = push_u32_le(bytes, data_len)

    // ── samples ──
    let mut i = 0
    while i < n {
        let mut s = samples[i]
        if s >  1.0 { s =  1.0 }
        if s < -1.0 { s = -1.0 }
        let s16 = to_int(s * 32767.0)
        bytes = push_u16_le(bytes, s16)
        i = i + 1
    }
    return bytes
}

// Public WAV writer. Returns true on success.
fn write_wav(path: string, samples: [float], sample_rate: int) -> bool {
    if len(samples) == 0 {
        println("[neural_vocoder] write_wav: empty samples — skipping write")
        return false
    }
    // Native fast-path: hxvocoder_write_wav writes WAV directly via fwrite.
    // Replaces O(n²) HexaVal byte-push + base64 roundtrip (48K = 5.35s → <1ms).
    let use_native = env("NEUROVOC_NATIVE")
    if use_native == "1" {
        let n = len(samples)
        let buf = alloc_raw(n * 4)
        let mut i = 0
        while i < n {
            write_f32(buf, i * 4, samples[i])
            i = i + 1
        }
        let path_c = cstring(path)
        hxvocoder_write_wav(path_c, buf, n, sample_rate, 0)
        free_raw(buf, n * 4)
        return true
    }
    let bytes = build_wav_bytes(samples, sample_rate)
    let b64 = bytes_to_b64(bytes)
    let tmp = path + ".b64"
    write_file(tmp, b64)
    let cmd = "base64 -d -i " + tmp + " > " + path + " && rm -f " + tmp
    let _ = exec(cmd)
    return true
}

// ════════════════════════════════════════════════════════════════════
// Section 8. Demo / smoke harness
// ════════════════════════════════════════════════════════════════════

// Build a synthetic latent: [T_frames][384] of small sinusoidal patterns
// so the mock projection produces non-trivial control signals.
fn make_demo_latent(n_frames: int) -> [[float]] {
    let mut frames = []
    let mut f = 0
    while f < n_frames {
        let mut row = []
        let mut j = 0
        while j < LATENT_DIM {
            // Slow drift across frames + per-dim wave
            let phase = (to_float(f) * 0.07) + (to_float(j) * 0.025)
            let v = 0.5 * sin(phase) + 0.2 * sin(phase * 2.7)
            row = row.push(v)
            j = j + 1
        }
        frames = frames.push(row)
        f = f + 1
    }
    return frames
}

// ════════════════════════════════════════════════════════════════════
// Section 8b. Stage C spectral self-test
//
// Verifies the spectral synthesis pipeline independently of the
// main decode_wave routing. Uses inline CPU DFT (no bridge import).
//
// Test 1: iSTFT round-trip (DFT -> iDFT recovers original signal)
// Test 2: Griffin-Lim converges (phase estimation reduces error)
// Test 3: vocoder_spectral produces non-zero PCM from mock latent
// ════════════════════════════════════════════════════════════════════

fn fabs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn test_spectral_round_trip() -> bool {
    println("[neural_vocoder] test_spectral_round_trip:")
    // Generate a short test signal: 64 samples of mixed sinusoids
    let n_fft = 64
    let mut signal = []
    let mut i = 0
    while i < n_fft {
        let t = to_float(i) / 24000.0
        let v = 0.5 * sin(TWO_PI * 440.0 * t) + 0.3 * sin(TWO_PI * 880.0 * t)
        signal = signal.push(v)
        i = i + 1
    }

    // Forward DFT
    let spec = cpu_dft_r2c(signal, n_fft)
    // Inverse DFT
    let recon = cpu_dft_c2r(spec, n_fft)

    // Check reconstruction error
    let mut max_err = 0.0
    i = 0
    while i < n_fft {
        let diff = fabs(signal[i] - recon[i])
        if diff > max_err { max_err = diff }
        i = i + 1
    }
    println("  DFT->iDFT max_err=" + to_string(max_err))
    if max_err < 0.001 {
        println("  PASS (round-trip error < 0.001)")
        return true
    }
    println("  FAIL (round-trip error too large)")
    return false
}

fn test_griffin_lim_convergence() -> bool {
    println("[neural_vocoder] test_griffin_lim_convergence:")
    // Create a known magnitude spectrum (5 bins for n_fft=8)
    let n_fft = 8
    let bins = n_fft / 2 + 1   // = 5
    let mut mag = []
    let mut k = 0
    while k < bins {
        // Simple decreasing magnitude: simulates typical speech spectrum
        mag = mag.push(1.0 / to_float(k + 1))
        k = k + 1
    }

    // Run Griffin-Lim
    let complex_spec = griffin_lim_phase(mag, n_fft)

    // Verify: extracted magnitude should match input magnitude
    let mut max_mag_err = 0.0
    k = 0
    while k < bins {
        let re = complex_spec[k * 2]
        let im = complex_spec[k * 2 + 1]
        let recovered_mag = sqrt(re * re + im * im)
        let diff = fabs(recovered_mag - mag[k])
        if diff > max_mag_err { max_mag_err = diff }
        k = k + 1
    }
    println("  GL magnitude consistency err=" + to_string(max_mag_err))
    if max_mag_err < 0.01 {
        println("  PASS (GL magnitude consistent after " + to_string(GL_ITERS) + " iters)")
        return true
    }
    println("  FAIL (GL magnitude drifted)")
    return false
}

fn test_spectral_vocoder_output() -> bool {
    println("[neural_vocoder] test_spectral_vocoder_output:")
    // Build a small mock latent (3 frames of 384d)
    let n_test_frames = 3
    let latent = make_demo_latent(n_test_frames)

    // Use mock W_spec (identity-like projection)
    let W_spec = mock_weight_identity(LATENT_DIM, SPEC_DIM)

    // Run spectral synthesis with neutral prosody
    let pcm = vocoder_spectral(latent, W_spec, 1.0)

    let expected_min_samples = 10  // should produce some audio
    println("  spectral output: " + to_string(len(pcm)) + " samples")
    if len(pcm) < expected_min_samples {
        println("  FAIL (too few samples)")
        return false
    }

    // Check that output is not all-zero (synthesis produced signal)
    let mut max_abs = 0.0
    let mut si = 0
    while si < len(pcm) {
        let a = fabs(pcm[si])
        if a > max_abs { max_abs = a }
        si = si + 1
    }
    println("  max|pcm|=" + to_string(max_abs))
    if max_abs > 0.0001 {
        println("  PASS (non-trivial output)")
        return true
    }
    println("  FAIL (output is near-silent)")
    return false
}

fn main() {
    println("neural_vocoder Mk.III Stage C — sr=" + to_string(SAMPLE_RATE)
            + " hop=" + to_string(HOP)
            + " latent_dim=" + to_string(LATENT_DIM)
            + " partials=" + to_string(N_PARTIALS)
            + " n_fft=" + to_string(N_FFT)
            + " spec_bins=" + to_string(SPEC_BINS)
            + " gl_iters=" + to_string(GL_ITERS))

    // CLI: --frames N  --out PATH  --test-spectral
    let av = args()
    let mut n_frames = 50            // default 0.5 s @ 100 Hz
    let mut out_path = ""
    let mut run_spectral_tests = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--frames" {
            if i + 1 < len(av) { n_frames = av[i + 1].parse_int() }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < len(av) { out_path = av[i + 1] }
            i = i + 2
        } else if a == "--test-spectral" {
            run_spectral_tests = true
            i = i + 1
        } else {
            i = i + 1
        }
    }

    // ── Stage C spectral self-tests (always run via --test-spectral) ──
    if run_spectral_tests {
        println("")
        println("═══════ Stage C Spectral Self-Tests ═══════")
        let mut pass_count = 0
        let mut total = 3

        if test_spectral_round_trip() { pass_count = pass_count + 1 }
        if test_griffin_lim_convergence() { pass_count = pass_count + 1 }
        if test_spectral_vocoder_output() { pass_count = pass_count + 1 }

        println("")
        println("[neural_vocoder] spectral tests: " + to_string(pass_count) + "/" + to_string(total) + " PASS")
        if pass_count < total {
            println("[neural_vocoder] SPECTRAL TEST FAILURE")
            exit(1)
        }
        println("═══════ Stage C tests PASS ═══════")
        println("")
    }

    // ── Standard demo / smoke (Stage B additive by default) ──
    println("[neural_vocoder] frames=" + to_string(n_frames)
            + " expected_samples=" + to_string(n_frames * HOP)
            + " duration_ms=" + to_string(n_frames * HOP * 1000 / SAMPLE_RATE))

    let latent = make_demo_latent(n_frames)
    let wave = decode_wave(latent, SAMPLE_RATE)

    println("[neural_vocoder] produced " + to_string(len(wave)) + " samples")
    if len(wave) >= 4 {
        println("[neural_vocoder] sample[0..3] = "
                + to_string(wave[0]) + ", "
                + to_string(wave[1]) + ", "
                + to_string(wave[2]) + ", "
                + to_string(wave[3]))
    }

    if out_path != "" {
        let ok = write_wav(out_path, wave, SAMPLE_RATE)
        if ok {
            println("[neural_vocoder] wrote WAV -> " + out_path)
        } else {
            println("[neural_vocoder] WAV write failed")
        }
    }
}
