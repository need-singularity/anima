// neural_vocoder.hexa — HEXA-SPEAK Mk.III: Native Neural Vocoder
//
// Purpose:
//   Decode RVQ latents → 24kHz fp32 PCM via real hexa neural compute.
//   Replaces the Mk.I 42-line skeleton (string-tag stub).
//
// Architecture (Mk.III, 2026-04-16):
//   Stage A   Latent → control signals (matmul: 384d latent → 6 sinusoidal
//             partials × {gain, freq_offset_log_hz} = 12d control vector
//             per frame).
//   Stage B   Control signals → 24 kHz waveform via additive sinusoid
//             synthesis with per-frame envelope smoothing (linear interp
//             across hop=240 samples).
//   Stage C   Optional iSTFT path through hxcuda_istft_bf16 FFI.
//             Auto-activates when libhxcuda is loadable on the host:
//             Linux (pod with libhxcuda.so) -> Stage C online.
//             Mac (no CUDA, libhxcuda.dylib absent) -> Stage C offline,
//             fallback to Stage B additive synthesis.
//             Kernel source: hexa-lang/self/native/hxcuda_stft.cu
//             (hxcuda_stft_bf16, hxcuda_istft_bf16, hxcuda_stft_version).
//
//   Why additive instead of full iSTFT for Mk.III:
//     1. iSTFT in pure hexa (no CUDA, no hxblas wired in this file)
//        would cost ~16 s for 1 s of audio (measured 2026-04-16).
//        Additive over 6 partials is O(N · partials) = ~12 s/sec.
//     2. With UNTRAINED (mock-identity) projection weights, iSTFT
//        outputs near-white noise. Additive synthesis with tone
//        scaling produces a bandwidth-limited timbre — audibly
//        meaningful for smoke checks.
//     3. The iSTFT FFI hook stays declared (Stage C) so when the
//        kernel + trained weights land, the path swaps cleanly.
//
// n=6 parameters (anima n=6 invariant):
//   sample_rate    = 24000
//   frame_hz       = 100             (10ms hop, matches Stage 2/3)
//   hop            = 240             (24000 / 100)
//   latent_dim     = 384 = 64 × 6    (RVQ output dim)
//   n_partials     = 6               (additive partials per frame)
//   ctrl_dim       = 12 = 6 × 2      ({gain, freq_offset} per partial)
//   n_fft          = 512             (iSTFT window — Stage C only)
//   istft_hop      = 128
//
// Mk stage:     Mk.III (real numerical compute, FFI hooks wired)
// Upstream:     rvq_codebook.rvq_decode → [T_frames][384]
// Downstream:   plc_crossfade / vad_fsm / WAV sink
//
// Hexa quirks honoured (per memory/feedback_hexa_runtime.md):
//   - No `a[i] = v` bare assignment in growable arrays (use concat or
//     pre-sized buffer + write_at; here all output arrays grow via `+`).
//   - No `let match = ...` (match is reserved); we use `let m_state` etc.
//   - No `use "nn_core"` — primitives are inlined for self-containment.
//   - Top-level `main()` call removed (hexa auto-invokes; explicit call
//     would double-execute, see speak_e2e.hexa final comment).
//
// FFI gating (2026-04-16 — Linux libhxcuda.so verified):
//   auto       → probe hxcuda_stft_version() via FFI. If library loads
//                and version >= 1, mark Stage C online. Currently logs
//                availability; full iSTFT marshalling lands in a follow-up
//                (spec synth + cuda malloc/memcpy + kernel dispatch).
//   HXCUDA_DISABLE=1 → force Stage B additive path even on Linux
//   No silent fallbacks: dispatch errors surface via println and
//   caller honours I5 (empty audio on failure).

// ════════════════════════════════════════════════════════════════════
// Section 1. Constants
// ════════════════════════════════════════════════════════════════════

let SAMPLE_RATE   = 24000
let FRAME_HZ      = 100
let HOP           = 240
let LATENT_DIM    = 384
let N_PARTIALS    = 6
let CTRL_DIM      = 12          // 6 partials × {gain, freq_offset_log_hz}
let N_FFT         = 512         // iSTFT path (Stage C)
let ISTFT_HOP     = 128

let TWO_PI        = 6.283185307179586
let BASE_FREQ_HZ  = 200.0       // partial 0 fundamental ~ 200 Hz
let MAX_GAIN      = 0.18        // headroom: 6-partial sum < 1.0

// ════════════════════════════════════════════════════════════════════
// Section 2. Pure-hexa NN primitives (inlined; no `use nn_core`)
// ════════════════════════════════════════════════════════════════════

fn vec_zeros(n: int) -> [float] {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(0.0)
        i = i + 1
    }
    return out
}

// ── BLAS fast-path FFI (macOS Accelerate / Linux libhxblas) ──
// Mirrors training/accelerate_blas.hexa pattern. Single GEMV via sgemm
// with M=1, K=in_dim, N=out_dim. W layout: row-major [out_dim × in_dim].
// Treat W as A^T (since y = W·x = (xᵀ·Wᵀ)ᵀ): row-major matmul of
//   A=[1×K] · B=[K×N]  with B = Wᵀ stored row-major as [in_dim × out_dim].
// To avoid an explicit transpose, we use CblasTrans on B (W row-major
// [out_dim × in_dim] becomes its transpose viewed as [in_dim × out_dim]).
//
// Activation gate: NEUROVOC_BLAS=1 enables the fast path on macOS.
// Default off so that systems without Accelerate (Linux pod build that
// doesn't link to libhxblas) keep the scalar fallback.
@link("Accelerate")
extern fn cblas_sgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: *Void, lda: int, B: *Void, ldb: int, beta: float, C: *Void, ldc: int)

// y[out_dim] = W[out_dim × in_dim] · x[in_dim] + b[out_dim]
// W is row-major flat. b may be empty (treated as zeros).
//
// Dual-path: BLAS fast (NEUROVOC_BLAS=1) vs scalar fallback (default).
// The BLAS path round-trips x and W into raw f32 buffers per call; for
// a single GEMV (M=1) the conversion overhead can dominate. Best ROI is
// when the caller pre-stages W once per checkpoint and reuses the raw
// pointer across many frames — see linear_proj_blas_cached for that.
fn linear_proj(x: [float], W: [float], b: [float], in_dim: int, out_dim: int) -> [float] {
    let use_blas = env("NEUROVOC_BLAS")
    if use_blas == "1" {
        // Fast path: cblas_sgemm with M=1, transB=Trans so the row-major
        // [out_dim × in_dim] W is viewed as [in_dim × out_dim] for matmul.
        // x_buf: [1 × in_dim], W_buf: [out_dim × in_dim] (raw row-major copy).
        let x_buf = alloc_raw(in_dim * 4)
        let mut xi = 0
        while xi < in_dim {
            write_f32(x_buf, xi * 4, x[xi])
            xi = xi + 1
        }
        let n_w = in_dim * out_dim
        let W_buf = alloc_raw(n_w * 4)
        let mut wi = 0
        while wi < n_w {
            write_f32(W_buf, wi * 4, W[wi])
            wi = wi + 1
        }
        let C_buf = alloc_raw(out_dim * 4)
        // CblasRowMajor=101, NoTrans=111, Trans=112
        // C[1×N] = A[1×K] * B[K×N]; we provide W as [N×K] row-major and pass
        // transB=Trans so BLAS reads it as [K×N]. Note: ldb is the leading
        // dim of *as-stored* W = K (in_dim).
        cblas_sgemm(101, 111, 112,
                    1, out_dim, in_dim,
                    1.0, x_buf, in_dim,
                    W_buf, in_dim,
                    0.0, C_buf, out_dim)
        let mut y = []
        let has_bias_f = (len(b) == out_dim)
        let mut i = 0
        while i < out_dim {
            let mut v = deref_f32(C_buf, i * 4)
            if has_bias_f { v = v + b[i] }
            y = y.push(v)
            i = i + 1
        }
        free_raw(x_buf, in_dim * 4)
        free_raw(W_buf, n_w * 4)
        free_raw(C_buf, out_dim * 4)
        return y
    }
    // Scalar fallback (portable, default)
    let mut y = []
    let mut i = 0
    let has_bias = (len(b) == out_dim)
    while i < out_dim {
        let mut s = 0.0
        if has_bias { s = b[i] }
        let mut j = 0
        while j < in_dim {
            s = s + W[i * in_dim + j] * x[j]
            j = j + 1
        }
        y = y.push(s)
        i = i + 1
    }
    return y
}

// tanh-bounded activation, used for control-signal head so partial
// gains and freq offsets stay in a bounded, audible range.
fn tanh_vec(x: [float]) -> [float] {
    let mut y = []
    let mut i = 0
    while i < len(x) {
        y = y.push(tanh(x[i]))
        i = i + 1
    }
    return y
}

// Identity-like mock weight: W[o,i] = 1 if i % out_dim == o else 0.
// Sums every (in_dim/out_dim)-th input feature into output o. Used as
// the default projection when no trained weights are loaded (smoke
// test path). Keeps signal flow live without all-zero dead activations.
fn mock_weight_identity(in_dim: int, out_dim: int) -> [float] {
    let mut W = []
    let mut o = 0
    while o < out_dim {
        let mut i = 0
        while i < in_dim {
            if i % out_dim == o {
                W = W.push(1.0 / to_float(in_dim / out_dim))
            } else {
                W = W.push(0.0)
            }
            i = i + 1
        }
        o = o + 1
    }
    return W
}

// ════════════════════════════════════════════════════════════════════
// Section 2b. Checkpoint loader — W_ctrl from ckpt_w_ctrl.json
//
// JSON format: {"data": [f0, f1, ...]} — 4608 floats row-major.
// Falls back to mock_weight_identity if file missing or parse fails.
// ════════════════════════════════════════════════════════════════════

fn load_w_ctrl(path: string) -> [float] {
    let raw = read_file(path)
    if len(raw) < 10 {
        println("[neural_vocoder] no checkpoint at " + path + " — using mock weights")
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    // Find "data": [ ... ] — extract the array of floats
    let marker = "\"data\": ["
    let pos = raw.index_of(marker)
    if pos < 0 {
        println("[neural_vocoder] checkpoint parse fail — using mock weights")
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    let start = pos + len(marker)
    // Find closing ']' by scanning from start (no 2-arg index_of in stage0)
    let tail = raw.substring(start, len(raw))
    let end_pos = tail.index_of("]")
    if end_pos < 0 {
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    // Parse comma-separated floats — split once, trim, parse.
    // Avoids O(n²) char-by-char substring/concat over 4608-float JSON.
    let nums_str = tail.substring(0, end_pos)
    let parts = nums_str.split(",")
    let np = len(parts)
    let mut W = []
    let mut i = 0
    while i < np {
        let p = parts[i].trim()
        if len(p) > 0 { W = W.push(parse_float(p)) }
        i = i + 1
    }
    if len(W) != CTRL_DIM * LATENT_DIM {
        println("[neural_vocoder] checkpoint size mismatch: " + to_string(len(W))
                + " expected " + to_string(CTRL_DIM * LATENT_DIM) + " — using mock")
        return mock_weight_identity(LATENT_DIM, CTRL_DIM)
    }
    println("[neural_vocoder] loaded W_ctrl from " + path + " (" + to_string(len(W)) + " params)")
    return W
}

// ════════════════════════════════════════════════════════════════════
// Section 3. Stage A — Latent → control signals
// ════════════════════════════════════════════════════════════════════

// One frame: [LATENT_DIM] → [CTRL_DIM]
// ctrl[2*p]   = log-frequency offset for partial p (in [-1, +1])
// ctrl[2*p+1] = gain for partial p              (in [-1, +1])
fn latent_to_ctrl(latent_frame: [float], W: [float]) -> [float] {
    // Linear projection then tanh activation
    let raw = linear_proj(latent_frame, W, [], LATENT_DIM, CTRL_DIM)
    return tanh_vec(raw)
}

// ════════════════════════════════════════════════════════════════════
// Section 4. Stage B — Additive synthesis
//
// Per output sample at global time-index t, find the surrounding two
// frames, linearly interpolate the control vector, and accumulate
// partials = sum_p gain_p · sin(2π · freq_p · t / SR).
//
// Note: phase continuity across frame boundaries is maintained by
// integrating frequency into a running phase accumulator per partial.
// (NOT closed-form sin(2π·f·t) which would phase-jump on freq changes.)
// ════════════════════════════════════════════════════════════════════

fn freq_from_offset(partial_idx: int, offset: float) -> float {
    // Partial p has nominal frequency BASE_FREQ_HZ × (p + 1)
    // offset ∈ [-1, +1] scales it by 2^offset (one octave each way)
    let nominal = BASE_FREQ_HZ * to_float(partial_idx + 1)
    // 2^offset ≈ exp(offset · ln2)
    let LN2 = 0.6931471805599453
    let scale = exp(offset * LN2)
    return nominal * scale
}

fn synth_additive(ctrl_frames: [[float]], n_samples: int) -> [float] {
    // Per-partial phase accumulator (radians)
    let mut phase = vec_zeros(N_PARTIALS)

    // Output buffer (grow via concat to honour hexa quirks)
    let mut out = []

    // Inverse sample rate
    let inv_sr = 1.0 / to_float(SAMPLE_RATE)

    let n_frames = len(ctrl_frames)
    let mut t = 0
    while t < n_samples {
        // Locate the two surrounding frames
        let frame_pos = to_float(t) / to_float(HOP)
        let mut f0 = to_int(frame_pos)
        if f0 < 0 { f0 = 0 }
        if f0 >= n_frames { f0 = n_frames - 1 }
        let mut f1 = f0 + 1
        if f1 >= n_frames { f1 = n_frames - 1 }
        let alpha = frame_pos - to_float(f0)

        // Accumulate sample
        let mut s = 0.0
        let mut p = 0
        while p < N_PARTIALS {
            // Linear interp of {offset, gain} between f0 and f1
            let off_a = ctrl_frames[f0][p * 2]
            let off_b = ctrl_frames[f1][p * 2]
            let off = off_a * (1.0 - alpha) + off_b * alpha
            let gain_a = ctrl_frames[f0][p * 2 + 1]
            let gain_b = ctrl_frames[f1][p * 2 + 1]
            let gain = gain_a * (1.0 - alpha) + gain_b * alpha

            let freq = freq_from_offset(p, off)
            // Phase increment for this sample
            let dphi = TWO_PI * freq * inv_sr
            phase[p] = phase[p] + dphi
            // Wrap to [0, 2π) to keep magnitude bounded for sin precision
            if phase[p] > TWO_PI { phase[p] = phase[p] - TWO_PI }
            if phase[p] < 0.0   { phase[p] = phase[p] + TWO_PI }

            s = s + gain * MAX_GAIN * sin(phase[p])
            p = p + 1
        }

        out = out.push(s)
        t = t + 1
    }
    return out
}

// ════════════════════════════════════════════════════════════════════
// Section 5. Stage C — hxcuda iSTFT FFI hook (auto-probe)
//
// Source: hexa-lang/self/native/hxcuda_stft.cu
// Builds:
//   Linux: bash scripts/build_hxcuda_linux.sh
//          -> self/native/build/libhxcuda.so
//          Verified 2026-04-16 on RTX 3090 (sm_86, cuFFT-backed).
//          C-level dlopen + dlsym + hxcuda_istft_bf16 round-trip: PASS
//          (n_fft=8 hop=4 n_frames=3, DC input, finite normalised output).
//   Mac:   no CUDA on macOS — libhxcuda.dylib does not build.
//          dlopen returns NULL, Stage C probe reports offline, path
//          falls through to Stage B additive synth (default).
//
// Signature (struct-args ABI, mirrors hxcuda_stft.cu HxCudaIstftArgs):
//   off  0: n_frames     (int64)
//   off  8: n_fft        (int64)
//   off 16: hop          (int64)
//   off 24: out_len      (int64)  total audio_out buffer samples
//   off 32: spec_p       (int64)  device cufftComplex* [n_frames * bins]
//   off 40: window_p     (int64)  device float* [n_fft]
//   off 48: audio_out_p  (int64)  device float* [out_len]
//   off 56: n_samples_out(int64)  host int64_t* — effective sample count
//   total = 64 bytes

// hxcuda_stft_version() — 0 args, returns >=1 when STFT/iSTFT kernels
// are present. Used as the capability probe below.
@link("hxcuda")
extern fn hxcuda_stft_version() -> int

@link("hxcuda")
extern fn hxcuda_istft_bf16(args_p: int) -> int

@link("hxcuda")
extern fn hxcuda_stft_bf16(args_p: int) -> int

// Module-level one-shot probe result. 0 = unknown, 1 = online, -1 = offline.
// Populated by hxcuda_available() on first call.
let mut _hxcuda_probe_state = 0

// Returns true iff libhxcuda is loadable on this host AND the STFT
// kernels are present (version >=1). Probes once per run and caches
// the result. Honours HXCUDA_DISABLE=1 as a kill-switch.
//
// Mac safety: calling a null __ffi_sym_* on the codegen_c2 path is UB.
// To avoid this we require HXCUDA_ENABLE=1 as an explicit opt-in flag,
// which the Linux build sets before launch (see speak_e2e / deploy
// scripts). Without the flag we short-circuit to OFFLINE without ever
// touching the extern symbol — making Mac smoke runs safe even after
// libhxcuda.dylib never ships for macOS.
fn hxcuda_available() -> bool {
    if _hxcuda_probe_state == 1 { return true }
    if _hxcuda_probe_state == -1 { return false }
    // Kill switch — force Stage B even when libhxcuda is present.
    let kill = env("HXCUDA_DISABLE")
    if kill == "1" {
        println("[neural_vocoder] HXCUDA_DISABLE=1 — Stage C forced offline")
        _hxcuda_probe_state = -1
        return false
    }
    // Opt-in gate: only probe when the deploy side has confirmed that
    // libhxcuda is present on this host. The Linux pod launcher sets
    // HXCUDA_ENABLE=1; Mac never does → probe never touches the extern.
    let enable = env("HXCUDA_ENABLE")
    if enable != "1" {
        println("[neural_vocoder] Stage C OFFLINE — HXCUDA_ENABLE unset (Mac smoke default)")
        _hxcuda_probe_state = -1
        return false
    }
    // Live probe (Linux pod path): hxcuda_stft_version() returns 1 when
    // libhxcuda.so is loaded. Requires LD_LIBRARY_PATH to include the
    // hexa-lang/self/native/build directory.
    let v = hxcuda_stft_version()
    if v >= 1 {
        println("[neural_vocoder] Stage C ONLINE — libhxcuda loaded, hxcuda_stft_version=" + to_string(v))
        _hxcuda_probe_state = 1
        return true
    }
    println("[neural_vocoder] Stage C OFFLINE — probe returned " + to_string(v))
    _hxcuda_probe_state = -1
    return false
}

// ════════════════════════════════════════════════════════════════════
// Section 6. Public entry — decode_wave
//
// Inputs:
//   latent_frames: [[float]]  — [T_frames][LATENT_DIM] from RVQ decode
//   sample_rate:   int        — must match SAMPLE_RATE (24000)
//
// Returns:
//   [float] — n_samples = T_frames × HOP fp32 audio in [-1, +1]
//
// On invalid input (empty latent, wrong sample rate, dim mismatch),
// returns an empty array. Callers gate on len(out) > 0.
// ════════════════════════════════════════════════════════════════════

fn decode_wave(latent_frames: [[float]], sample_rate: int) -> [float] {
    if sample_rate != SAMPLE_RATE {
        println("[neural_vocoder] sample_rate mismatch: got "
                + to_string(sample_rate) + " expected " + to_string(SAMPLE_RATE))
        return []
    }
    let n_frames = len(latent_frames)
    if n_frames == 0 {
        return []
    }
    if len(latent_frames[0]) != LATENT_DIM {
        println("[neural_vocoder] latent dim mismatch: got "
                + to_string(len(latent_frames[0]))
                + " expected " + to_string(LATENT_DIM))
        return []
    }

    // ── Stage C (CUDA iSTFT) — capability probe + dispatch gate ──
    // Auto-probes libhxcuda; logs ONLINE/OFFLINE exactly once per run.
    // Dispatch marshalling (spec synthesis + cuda alloc/memcpy/kernel)
    // is scoped for a follow-up change — the probe & FFI binding are
    // validated here so the hot-swap lands cleanly.
    let stage_c_ready = hxcuda_available()
    if stage_c_ready {
        println("[neural_vocoder] Stage C path reachable; iSTFT marshalling follow-up pending")
        // TODO[hxcuda-istft-bridge]: latent -> spec (Stage A') -> cuda_malloc
        // -> cudaMemcpyHostToDevice -> hxcuda_istft_bf16 -> D2H -> pcm out.
        // Falls through to Stage B (additive) until the bridge lands.
    } else {
        println("[neural_vocoder] Stage B active — additive synthesis (no CUDA)")
    }

    // ── Stage A: latent → ctrl per frame ──
    // Load trained W_ctrl from checkpoint; fallback to mock-weight identity.
    let ckpt_path = env("SPEAK_CKPT_W_CTRL")
    let W_ctrl = if ckpt_path != "" { load_w_ctrl(ckpt_path) } else { load_w_ctrl("anima-speak/ckpt_w_ctrl.json") }

    let mut ctrl_frames = []
    let mut f = 0
    while f < n_frames {
        let c = latent_to_ctrl(latent_frames[f], W_ctrl)
        ctrl_frames = ctrl_frames.push(c)
        f = f + 1
    }

    // ── Stage B: additive synth ──
    let n_samples = n_frames * HOP
    return synth_additive(ctrl_frames, n_samples)
}

// ════════════════════════════════════════════════════════════════════
// Section 7. WAV I/O (PCM16, mono)
//
// Hexa string ops are null-terminated, so binary bytes don't survive
// a write_file() call. Workaround: build the WAV byte-for-byte as an
// int array, base64-encode it manually (3-bytes → 4-chars), shell
// `base64 -d` into the destination file. Avoids any python dependency
// and only relies on POSIX `base64`.
// ════════════════════════════════════════════════════════════════════

let B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

fn b64_char(i: int) -> string {
    return B64_ALPHA.substring(i, i + 1)
}

fn bytes_to_b64(bytes: [int]) -> string {
    // Collect b64 chars in a list, join once at end — avoids O(n²) string concat.
    let n = len(bytes)
    let mut chars = []
    let mut i = 0
    while i + 3 <= n {
        let b0 = bytes[i]
        let b1 = bytes[i + 1]
        let b2 = bytes[i + 2]
        let t = (b0 * 65536) + (b1 * 256) + b2
        chars = chars.push(b64_char((t / 262144) % 64))
        chars = chars.push(b64_char((t / 4096) % 64))
        chars = chars.push(b64_char((t / 64) % 64))
        chars = chars.push(b64_char(t % 64))
        i = i + 3
    }
    let rem = n - i
    if rem == 1 {
        let b0 = bytes[i]
        let t = b0 * 65536
        chars = chars.push(b64_char((t / 262144) % 64))
        chars = chars.push(b64_char((t / 4096) % 64))
        chars = chars.push("==")
    } else if rem == 2 {
        let b0 = bytes[i]
        let b1 = bytes[i + 1]
        let t = (b0 * 65536) + (b1 * 256)
        chars = chars.push(b64_char((t / 262144) % 64))
        chars = chars.push(b64_char((t / 4096) % 64))
        chars = chars.push(b64_char((t / 64) % 64))
        chars = chars.push("=")
    }
    return chars.join("")
}

// Append the 4 little-endian bytes of `v` (signed int32) to `bytes`.
fn push_u32_le(bytes: [int], v: int) -> [int] {
    let mut u = v
    if u < 0 { u = u + 4294967296 }
    let mut out = bytes
    out = out.push(u % 256)
    out = out.push((u / 256) % 256)
    out = out.push((u / 65536) % 256)
    out = out.push((u / 16777216) % 256)
    return out
}

fn push_u16_le(bytes: [int], v: int) -> [int] {
    let mut u = v
    if u < 0 { u = u + 65536 }
    let mut out = bytes
    out = out.push(u % 256)
    out = out.push((u / 256) % 256)
    return out
}

fn push_str(bytes: [int], s: string) -> [int] {
    let mut out = bytes
    let mut i = 0
    while i < len(s) {
        let sub = s.substring(i, i + 1)
        out = out.push(char_code(sub, 0))
        i = i + 1
    }
    return out
}

// Build PCM16 mono WAV bytes from fp32 audio in [-1, +1].
fn build_wav_bytes(samples: [float], sample_rate: int) -> [int] {
    let n = len(samples)
    let data_len = n * 2                          // 16-bit mono
    let chunk_size = 36 + data_len                // RIFF chunk size

    let mut bytes = []

    // ── RIFF header ──
    bytes = push_str(bytes, "RIFF")
    bytes = push_u32_le(bytes, chunk_size)
    bytes = push_str(bytes, "WAVE")

    // ── fmt subchunk ──
    bytes = push_str(bytes, "fmt ")
    bytes = push_u32_le(bytes, 16)                // subchunk1 size (PCM)
    bytes = push_u16_le(bytes, 1)                 // PCM format
    bytes = push_u16_le(bytes, 1)                 // 1 channel (mono)
    bytes = push_u32_le(bytes, sample_rate)
    bytes = push_u32_le(bytes, sample_rate * 2)   // byte rate
    bytes = push_u16_le(bytes, 2)                 // block align
    bytes = push_u16_le(bytes, 16)                // bits per sample

    // ── data subchunk ──
    bytes = push_str(bytes, "data")
    bytes = push_u32_le(bytes, data_len)

    // ── samples ──
    let mut i = 0
    while i < n {
        let mut s = samples[i]
        if s >  1.0 { s =  1.0 }
        if s < -1.0 { s = -1.0 }
        let s16 = to_int(s * 32767.0)
        bytes = push_u16_le(bytes, s16)
        i = i + 1
    }
    return bytes
}

// Public WAV writer. Returns true on success.
fn write_wav(path: string, samples: [float], sample_rate: int) -> bool {
    if len(samples) == 0 {
        println("[neural_vocoder] write_wav: empty samples — skipping write")
        return false
    }
    let bytes = build_wav_bytes(samples, sample_rate)
    let b64 = bytes_to_b64(bytes)
    // Write base64 to a temp file, decode to destination via shell.
    // Rationale: argv length limit (~256K macOS) is safer with file I/O.
    let tmp = path + ".b64"
    write_file(tmp, b64)
    let cmd = "base64 -d -i " + tmp + " > " + path + " && rm -f " + tmp
    let _ = exec(cmd)
    return true
}

// ════════════════════════════════════════════════════════════════════
// Section 8. Demo / smoke harness
// ════════════════════════════════════════════════════════════════════

// Build a synthetic latent: [T_frames][384] of small sinusoidal patterns
// so the mock projection produces non-trivial control signals.
fn make_demo_latent(n_frames: int) -> [[float]] {
    let mut frames = []
    let mut f = 0
    while f < n_frames {
        let mut row = []
        let mut j = 0
        while j < LATENT_DIM {
            // Slow drift across frames + per-dim wave
            let phase = (to_float(f) * 0.07) + (to_float(j) * 0.025)
            let v = 0.5 * sin(phase) + 0.2 * sin(phase * 2.7)
            row = row.push(v)
            j = j + 1
        }
        frames = frames.push(row)
        f = f + 1
    }
    return frames
}

fn main() {
    println("neural_vocoder Mk.III — sr=" + to_string(SAMPLE_RATE)
            + " hop=" + to_string(HOP)
            + " latent_dim=" + to_string(LATENT_DIM)
            + " partials=" + to_string(N_PARTIALS))

    // CLI: --frames N  --out PATH
    let av = args()
    let mut n_frames = 50            // default 0.5 s @ 100 Hz
    let mut out_path = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--frames" {
            if i + 1 < len(av) { n_frames = av[i + 1].parse_int() }
            i = i + 2
        } else if a == "--out" {
            if i + 1 < len(av) { out_path = av[i + 1] }
            i = i + 2
        } else {
            i = i + 1
        }
    }

    println("[neural_vocoder] frames=" + to_string(n_frames)
            + " expected_samples=" + to_string(n_frames * HOP)
            + " duration_ms=" + to_string(n_frames * HOP * 1000 / SAMPLE_RATE))

    let latent = make_demo_latent(n_frames)
    let wave = decode_wave(latent, SAMPLE_RATE)

    println("[neural_vocoder] produced " + to_string(len(wave)) + " samples")
    if len(wave) >= 4 {
        println("[neural_vocoder] sample[0..3] = "
                + to_string(wave[0]) + ", "
                + to_string(wave[1]) + ", "
                + to_string(wave[2]) + ", "
                + to_string(wave[3]))
    }

    if out_path != "" {
        let ok = write_wav(out_path, wave, SAMPLE_RATE)
        if ok {
            println("[neural_vocoder] wrote WAV → " + out_path)
        } else {
            println("[neural_vocoder] WAV write failed")
        }
    }
}
