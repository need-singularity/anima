{
  "_doc": "anima 드리프트 규칙 — loop-guard.hexa L5 에서 참조",
  "rules": [
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+ consciousness laws",
      "actual_cmd": "python3 -c \"import json; d=json.load(open('anima-core/consciousness_laws.json')); print(len(d.get('laws',[])))\"",
      "label": "법칙 수 (README)"
    },
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+ files",
      "actual_cmd": "find anima-agent -type f | wc -l",
      "label": "anima-agent 파일수"
    },
    {
      "type": "file_count",
      "doc": "anima-core/README.md",
      "pattern": "runtime/.*\\d+ files",
      "dir": "anima-core/runtime",
      "glob": "*.hexa",
      "label": "runtime/ 파일수"
    },
    {
      "type": "inline_number",
      "doc": "bench/CLAUDE.md",
      "pattern": "\\d+.*벤치",
      "actual_cmd": "find bench -name '*.hexa' -type f | wc -l",
      "label": "벤치마크 파일수"
    }
  ]
}
