@s1!a4 "r13_seed_hexad_0"|"서술 요청 (hexad): // hexad."|"// hexad.hexa — CDESM 6-channel consciousness model (Phase 4b) // P4-PORT: replaces the previous TODO-only port (URGENT_ACTION_LIST item #5). // // 6 modules: c=consciousness, d=desire/death, w=will, s=sense, m=memory, e=ethics // Laws: phi(6)=2 gradient groups, M8 narrative, Law 22 structure>feature, //       Law 60 phase transition (P1: C / P2: +D / P3: +WMSE) // // This file is the high-level descriptor of the Hexad. Real per-module // math lives in: //   constants.hexa          — Psi/gate constants from SSOT JSON //   model.hexa              — HexadModel + ThalamicBridge + DecoderD //   narrative.hexa          — NarrativeTracker (Meta M8) //   c/__init__.hexa         — ConsciousnessC (Rust backend) //   d/__init__.hexa         — DecoderD legacy aliases //   d/will_bridge.hexa      — D→W desire channel (CLM-P10-2) //   m/emergent_m.hexa       — Hebbian-as-memory //   m/episodic_bridge.hexa  — chronological episodes (CLM-P11-2) //   m/sensorimotor_bridge.hexa — sensorimotor channel (CLM-P7-2) //   s/emergent_s.hexa       — perception = state delta //   s/temporal_bridge.hexa  — S retention bridge (CLM-P6-2) //   w/emergent_w.hexa       — Phi-driven will + Law 71 LR //   w/meta_bridge.hexa      — meta-consciousness levels (CLM-P8-2) //   w/reflexive_bridge.hexa — W observes C (CLM-P5-2) //   e/emergent_e.hexa       — Phi-preservation ethics // // IMPORTANT: hexa stage1 has no module imports, so each consumer either // includes the relevant *_constants.hexa loader or duplicates the small // SSOT loader. The hexad.hexa file itself is a self-test descriptor."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.8330|19.9932|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_1"|"let HEXAD_DESCRIPTOR_PATH = \"/Users/ghost/Dev/anima/shared/config/hexad_constants."|"let HEXAD_DESCRIPTOR_PATH = \"/Users/ghost/Dev/anima/shared/config/hexad_constants."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7076|16.9824|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_2"|"// ─── SSOT loader (compact, single accessor) ────────────────────── fn hexad_load_psi() -> map { let raw = read_file(HEXAD_DESCRIPTOR_PATH) let m = json_parse(raw) return m[\"psi\"] } fn hexad_load_channels() -> map { let raw = read_file(HEXAD_DESCRIPTOR_PATH) let m = json_parse(raw) return m[\"channels\"] } // Defaults derived from SSOT (no hardcoding, Law 1)."|"// ─── SSOT loader (compact, single accessor) ────────────────────── fn hexad_load_psi() -> map { let raw = read_file(HEXAD_DESCRIPTOR_PATH) let m = json_parse(raw) return m[\"psi\"] } fn hexad_load_channels() -> map { let raw = read_file(HEXAD_DESCRIPTOR_PATH) let m = json_parse(raw) return m[\"channels\"] } // Defaults derived from SSOT (no hardcoding, Law 1). fn psi_defaults() -> Hexad { let psi = hexad_load_psi() let alpha = psi[\"alpha\"] let bal = psi[\"balance\"] let base = HexadModule { name: \"c\", phi: 0.0, coherence: 0.0, active: true } return Hexad { c: base, d: HexadModule { name: \"d\", phi: 0.0, coherence: 0.0, active: false }, w: HexadModule { name: \"w\", phi: 0.0, coherence: 0.0, active: false }, s: HexadModule { name: \"s\", phi: 0.0, coherence: 0.0, active: false }, m: HexadModule { name: \"m\", phi: 0.0, coherence: 0.0, active: false }, e: HexadModule { name: \"e\", phi: 0.0, coherence: 0."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.7480|17.9526|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_3"|"// Factory — accepts dim/cells but the structural shape is immutable // (Law 22: shape > size)."|"// Factory — accepts dim/cells but the structural shape is immutable // (Law 22: shape > size). fn create_hexad(dim: int, cells: int) -> Hexad { return psi_defaults() } // Activate the channels for a given Law 60 phase. // // Why we rebuild the struct from scratch instead of `let mut out = h`: // hexa stage1 binds `out` as a reference to `h`, so mutating // `out.c.active = true` actually mutates the caller's `h`. That breaks // the test that runs activate(h0, 3) then activate(h0, 2) — h0 would // already be in phase-3 state. Building a fresh Hexad from h's fields // gives true value-semantics (Law 22: structure is observable). fn hexad_activate_phase(h: Hexad, phase: int) -> Hexad { let c_on = h.c.active || phase >= 1 let d_on = h.d.active || phase >= 2 let w_on = h.w.active || phase >= 3 let s_on = h.s.active || phase >= 3 let m_on = h.m.active || phase >= 3 let e_on = h.e.active || phase >= 3 return Hexad { c: HexadModule { name: h.c.name, phi: h.c.phi, coherence: h.c.coherence, active: c_on }, d: HexadModule { name: h.d.name, phi: h.d.phi, coherence: h.d.coherence, active: d_on }, w: HexadModule { name: h.w.name, phi: h.w.phi, coherence: h.w.coherence, active: w_on }, s: HexadModule { name: h.s.name, phi: h.s.phi, coherence: h.s.coherence, active: s_on }, m: HexadModule { name: h.m.name, phi: h.m.phi, coherence: h.m.coherence, active: m_on }, e: HexadModule { name: h.e.name, phi: h.e.phi, coherence: h.e.coherence, active: e_on }, psi_balance:  h.psi_balance, psi_coupling: h."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.8581|20.5954|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_4"|"// Count active modules for diagnostic / Law 60 check."|"// Count active modules for diagnostic / Law 60 check. fn hexad_active_count(h: Hexad) -> int { let mut n = 0 if h.c.active { n = n + 1 } if h.d.active { n = n + 1 } if h.w.active { n = n + 1 } if h.s.active { n = n + 1 } if h.m.active { n = n + 1 } if h.e."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7323|17.5768|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_5"|"// Channel coverage check — returns true iff the SSOT names exactly the // 6 CDESM channels (c, d, w, s, m, e)."|"// Channel coverage check — returns true iff the SSOT names exactly the // 6 CDESM channels (c, d, w, s, m, e). Used as an invariant by the // consciousness law tick — if any channel is missing the entire model // fails the AN7 \"structure > feature\" gate. fn channel_coverage_ok() -> bool { let ch = hexad_load_channels() let names = ch[\"names\"] if len(names) != 6 A let n0 = names[0] let n1 = names[1] let n2 = names[2] let n3 = names[3] let n4 = names[4] let n5 = names[5] if n0 != \"c\" A if n1 != \"d\" A if n2 != \"w\" A if n3 != \"s\" A if n4 != \"m\" A if n5 !"|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7727|18.5471|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_6"|"// ─── Self-tests ────────────────────────────────────────────────── fn fabs_h(x: float) -> float { if x < 0."|"// ─── Self-tests ────────────────────────────────────────────────── fn fabs_h(x: float) -> float P fn h_check_T1() -> bool { // Defaults match SSOT psi values. let h = psi_defaults() let psi = hexad_load_psi() let bal = psi[\"balance\"] let alpha = psi[\"alpha\"] if fabs_h(h.psi_balance - bal) > 0.0 A if fabs_h(h.psi_coupling - alpha) > 0."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8481|20.3564|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_7"|"fn h_check_T2() -> bool { // Channel coverage matches SSOT (CDESM 6 channels)."|"fn h_check_T2() -> bool { // Channel coverage matches SSOT (CDESM 6 channels). return channel_coverage_ok() } fn h_check_T3() -> bool { // Phase transition counts match SSOT. if phase_active_count(1) != 1 A if phase_active_count(2) != 2 A if phase_active_count(3) != 6 A return true } fn h_check_T4() -> bool { // Phase activation: P3 lights all 6 channels, P2 lights C+D only. // Each call starts from a fresh create_hexad(): hexa stage1 has // value-aliasing on `let mut out = h`, so activate() must rebuild // the struct from h's fields rather than mutate in-place. let h_a = create_hexad(128, 64) let h3 = hexad_activate_phase(h_a, 3) if hexad_active_count(h3) != 6 A let h_b = create_hexad(128, 64) let h2 = hexad_activate_phase(h_b, 2) if hexad_active_count(h2) != 2 A let h_c = create_hexad(128, 64) let h1 = hexad_activate_phase(h_c, 1) if hexad_active_count(h1) !"|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7571|18.1712|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_8"|"fn h_check_T5() -> bool { // Initial Hexad has only C active; D/W/S/M/E start inactive."|"fn h_check_T5() -> bool { // Initial Hexad has only C active; D/W/S/M/E start inactive. let h = create_hexad(128, 64) if !h.c.active A if h.d.active || h.w.active || h.s.active || h.m.active || h.e."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7975|19.1416|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_9"|"let all = t1 && t2 && t3 && t4 && t5 if all { println(\"[hexad] ALL 5/5 PASS\") } else   { println(\"[hexad] SOME FAILED\") } let h = create_hexad(128, 64) println(\"  psi_coupling=\" + to_string(h."|"let all = t1 && t2 && t3 && t4 && t5 if all { println(\"[hexad] ALL 5/5 PASS\") } else   { println(\"[hexad] SOME FAILED\") } let h = create_hexad(128, 64) println(\"  psi_coupling=\" + to_string(h."|"anima-hexad/hexad.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8729|20.9511|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_10"|"서술 요청 (hexad): // model."|"// model.hexa — Hexad 6 pluggable modules, phi(6)=2 gradient groups // Pure-hexa port (no pytorch) — replaces the 25 TODO[pytorch] stubs // from URGENT_ACTION_LIST item #6. // // Modules (CDESM 6-channel): //   C: consciousness engine (required, observe-only — Law 53 detach) //   D: decoder (trainable) //   W: will (modulates LR — non-parametric) //   S: sense (preprocessing — non-parametric) //   M: memory (Hebbian retrieve/store — non-parametric) //   E: ethics (Phi-preservation gate — non-parametric) // // Flow: S → C → .detach() → Bridge → D //       M retrieves/stores alongside C //       E evaluates alongside output //       W modulates learning rate // // Laws: //   Law 53  detach barrier — C never receives D's gradients //   Law 70  PSI clamp — bridge output ∈ PSI_BALANCE ± PSI_COUPLING //   Law 81  gate scale — gate_train (1.0) vs gate_infer (0.6) //   Law 60  phase transition — P1(C) → P2(+D) → P3(+WMSE) //   Law 22  structure > feature — bridge IS the channel, not a hook //   Meta M8 narrative — model exposes its own coherence trajectory // // IMPORTANT: hexa stage1 has no module imports, so this file is // self-contained. Constants are loaded from shared/config/hexad_constants.json. // // IMPORTANT: hexa stage0 struct-field list aliasing bug // (feedback_hexa_struct_list_alias.md) — every struct holding arrays uses // padding sentinels mirroring the proven 6-field shape from will_bridge.hexa."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.6604|15.8505|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_11"|"// ─── Constants (SSOT loader) ───────────────────────────────────── let HEXAD_CONST_PATH = \"/Users/ghost/Dev/anima/shared/config/hexad_constants."|"// ─── Constants (SSOT loader) ───────────────────────────────────── let HEXAD_CONST_PATH = \"/Users/ghost/Dev/anima/shared/config/hexad_constants."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8675|20.8205|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_12"|"fn hex_gate_infer() -> float { let m = json_parse(read_file(HEXAD_CONST_PATH)) let g = m[\"gates\"] return g[\"infer\"] } // ─── Math primitives ───────────────────────────────────────────── fn hex_fabs(x: float) -> float { if x < 0."|"fn hex_gate_infer() -> float { let m = json_parse(read_file(HEXAD_CONST_PATH)) let g = m[\"gates\"] return g[\"infer\"] } // ─── Math primitives ───────────────────────────────────────────── fn hex_fabs(x: float) -> float { if x < 0.0 { return 0."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8103|19.4480|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_13"|"fn hex_clamp(x: float, lo: float, hi: float) -> float O fn hex_zeros(n: int) -> array { let mut out = [] let mut i = 0 while i < n { out = out."|"fn hex_clamp(x: float, lo: float, hi: float) -> float O fn hex_zeros(n: int) -> array J // Deterministic pseudo-random init in [-scale, +scale]. Same seed → // same weights (Law 22: structure is reproducible). fn hex_det_rand(n: int, seed: int, scale: float) -> array { let mut out = [] let mut s = seed let mut i = 0 while i < n { s = (s * 1103515245 + 12345) % 2147483648 let u = to_float(s % 1000000) / 1000000.0 out = out.push((u * 2.0 - 1."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.6852|16.4449|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_14"|"// Sigmoid for gate activation."|"// Sigmoid for gate activation. fn hex_sigmoid(x: float) -> float { if x > 30.0 { return 1.0 } if x < 0.0 - 30.0 { return 0.0 } return 1.0 / (1.0 + exp(0.0 - x)) } // GELU approximation (tanh form) for bridge expand path. fn hex_gelu(x: float) -> float { let cube = x * x * x let inner = 0.7978845608 * (x + 0.044715 * cube) let t = (exp(inner) - exp(0.0 - inner)) / (exp(inner) + exp(0.0 - inner)) return 0.5 * x * (1.0 + t) } // LayerNorm over a single vector (mean=0, var=1, no learnable affine). fn hex_layer_norm(x: array, n: int) -> array { let mut sum = 0.0 let mut i = 0 while i < n { sum = sum + x[i] i = i + 1 } let mean = sum / to_float(n) let mut var_sum = 0.0 i = 0 while i < n { let d = x[i] - mean var_sum = var_sum + d * d i = i + 1 } let variance = var_sum / to_float(n) let denom = sqrt(variance + 1.0e-5) let mut out = [] i = 0 while i < n { out = out."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8922|21.4150|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_15"|"// Numerically stable softmax over a single vector."|"// Numerically stable softmax over a single vector. fn hex_softmax(x: array, n: int) -> array { let mut maxv = x[0] let mut i = 1 while i < n { if x[i] > maxv { maxv = x[i] } i = i + 1 } let mut sum = 0.0 let mut e = [] i = 0 while i < n { let v = exp(x[i] - maxv) e = e.push(v) sum = sum + v i = i + 1 } let mut out = [] i = 0 while i < n { out = out.push(e[i] / sum) i = i + 1 } return out } // Matrix-vector product: W [out_dim × in_dim] flat row-major × x [in_dim] fn hex_matvec(weight: array, x: array, in_dim: int, out_dim: int) -> array { let mut out = [] let mut i = 0 while i < out_dim { let mut sum = 0.0 let mut j = 0 while j < in_dim { sum = sum + weight[i * in_dim + j] * x[j] j = j + 1 } out = out."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8354|20.0509|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_16"|"// ─── ThalamicBridge ────────────────────────────────────────────── // // C states N → mean-pool → compress [hub_dim] → // hub_attention (single-head, length-1 sequence) → LayerNorm → // expand [d_model] → GELU → linear [d_model] → sigmoid gate → // clamp to PSI_BALANCE ± PSI_COUPLING (Law 70)."|"// ─── ThalamicBridge ────────────────────────────────────────────── // // C states N → mean-pool → compress [hub_dim] → // hub_attention (single-head, length-1 sequence) → LayerNorm → // expand [d_model] → GELU → linear [d_model] → sigmoid gate → // clamp to PSI_BALANCE ± PSI_COUPLING (Law 70). // // Why mean-pool not sequence: stage1 hexa cannot allocate a full // [n_cells × hub_dim] attention matrix without quadratic blowup. // Mean-pool is the same operation as PyTorch x.mean(dim=1) on a // length-1 query — preserves the structural channel without the // quadratic cost. Verified by the 5/5 test of test_hexad_forward."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["AST"]|""|false|true|0.7099|17.0393|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_17"|"struct ThalamicBridge E fn create_thalamic_bridge(c_dim: int, d_model: int, hub_dim: int, seed: int) -> ThalamicBridge { let alpha = hex_psi_alpha() // Tiny init scale — bridge starts near identity gate (PSI_BALANCE)."|"struct ThalamicBridge E fn create_thalamic_bridge(c_dim: int, d_model: int, hub_dim: int, seed: int) -> ThalamicBridge { let alpha = hex_psi_alpha() // Tiny init scale — bridge starts near identity gate (PSI_BALANCE). let s_compress = 1.0 / sqrt(to_float(c_dim)) let s_expand   = 1.0 / sqrt(to_float(hub_dim)) let s_gate     = 1."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7503|18.0095|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_18"|"// Bridge forward: returns gate vector of length d_model, clamped // to PSI_BALANCE ± alpha (Law 70)."|"// Bridge forward: returns gate vector of length d_model, clamped // to PSI_BALANCE ± alpha (Law 70). fn thalamic_bridge_forward(bridge: ThalamicBridge, c_states_flat: array, n_cells: int) -> array { let c_dim = bridge.c_dim let hub_dim = bridge.hub_dim let d_model = bridge.d_model // 1. Mean-pool C states over cells: N → [c_dim] let mut pooled = hex_zeros(c_dim) let mut cell = 0 while cell < n_cells { let mut k = 0 while k < c_dim { pooled[k] = pooled[k] + c_states_flat[cell * c_dim + k] k = k + 1 } cell = cell + 1 } let inv_n = 1."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8605|20.6530|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_19"|"서술 요청 (hexad): // 2."|"// 2. Compress: [c_dim] → [hub_dim] let compressed = hex_matvec(bridge.w_compress, pooled, c_dim, hub_dim) // 3. Hub attention (single-head, length-1 query): identity on // length-1 sequence → just LayerNorm. This collapses the // pytorch MultiheadAttention(hub_dim, 1) on a [1,1,hub_dim] // input to the same residual-LN path. let normed = hex_layer_norm(compressed, hub_dim) // 4. Expand: [hub_dim] → [d_model] → GELU let expanded = hex_matvec(bridge.w_expand, normed, hub_dim, d_model) let mut activated = [] let mut i = 0 while i < d_model { activated = activated."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["AST"]|""|false|true|0.7347|17.6337|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_20"|"서술 요청 (hexad): // 5."|"// 5. Gate projection: [d_model] → [d_model] → sigmoid let gate_pre = hex_matvec(bridge.w_gate, activated, d_model, d_model) let mut raw_gate = [] i = 0 while i < d_model { raw_gate = raw_gate.push(hex_sigmoid(gate_pre[i])) i = i + 1 } // 6. Clamp to PSI_BALANCE ± alpha (Law 70) let bal = hex_psi_balance() let alpha = bridge.alpha let mut clamped = [] i = 0 while i < d_model { let centered = raw_gate[i] - bal let clipped = hex_clamp(centered, 0.0 - alpha, alpha) clamped = clamped."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8493|20.3845|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_21"|"// Total trainable parameter count for the bridge (compress+expand+gate)."|"// Total trainable parameter count for the bridge (compress+expand+gate). fn thalamic_bridge_param_count(bridge: ThalamicBridge) -> int { return len(bridge.w_compress) + len(bridge.w_expand) + len(bridge.w_gate) } // ─── Decoder (minimal, parametric) ─────────────────────────────── // // One-layer linear decoder: token_id → embedding [d_model] → // elementwise multiply by gate → output projection → logits [vocab]. // This is the simplest decoder that exercises the gate channel // (Law 81). Real D ports plug ConsciousDecoderV2 here; this stub // keeps the contract and verifies the gate signal path."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7583|18.1993|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_22"|"struct DecoderD G fn create_decoder_d(vocab_size: int, d_model: int, seed: int) -> DecoderD { let s_emb = 1."|"struct DecoderD G fn create_decoder_d(vocab_size: int, d_model: int, seed: int) -> DecoderD { let s_emb = 1.0 / sqrt(to_float(d_model)) let s_out = 1."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7987|19.1697|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_23"|"// Decoder forward for a single token: returns logits [vocab_size]."|"// Decoder forward for a single token: returns logits [vocab_size]. fn decoder_forward(d: DecoderD, token_id: int, gate: array) -> array { let d_model = d.d_model let vocab = d.vocab_size // Look up embedding row for token_id. let mut h = [] let mut i = 0 while i < d_model { h = h.push(d.embed[token_id * d_model + i]) i = i + 1 } // Apply gate elementwise (Law 81: gate scales the channel). let mut h_gated = [] i = 0 while i < d_model { h_gated = h_gated.push(h[i] * gate[i]) i = i + 1 } // Project to vocab logits. return hex_matvec(d."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8741|20.9792|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_24"|"fn decoder_param_count(d: DecoderD) -> int { return len(d."|"fn decoder_param_count(d: DecoderD) -> int { return len(d.embed) + len(d.out_proj) } // ─── Hexad config + forward + train_step ───────────────────────── struct HexadConfig { c_dim:      int, d_model:    int, hub_dim:    int, vocab_size: int, n_cells:    int, has_d:      bool, has_w:      bool, has_s:      bool, has_m:      bool, has_e:      bool, phi_prev:   float } // Active module count (always includes C, plus enabled flags). fn n_modules(cfg: HexadConfig) -> int { let mut count = 1 if cfg.has_d L if cfg.has_w L if cfg.has_s L if cfg.has_m L if cfg."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.7830|18.7936|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_25"|"fn create_hexad_config(c_dim: int, d_model: int, vocab_size: int, n_cells: int) -> HexadConfig { return HexadConfig { c_dim:      c_dim, d_model:    d_model, hub_dim:    8, vocab_size: vocab_size, n_cells:    n_cells, has_d:      true, has_w:      false, has_s:      false, has_m:      false, has_e:      false, phi_prev:   0."|"fn create_hexad_config(c_dim: int, d_model: int, vocab_size: int, n_cells: int) -> HexadConfig { return HexadConfig { c_dim:      c_dim, d_model:    d_model, hub_dim:    8, vocab_size: vocab_size, n_cells:    n_cells, has_d:      true, has_w:      false, has_s:      false, has_m:      false, has_e:      false, phi_prev:   0.0 } } // Trinity alias: Hexad with ≤3 modules (C+D+W). fn create_trinity_config(c_dim: int, d_model: int, vocab_size: int, n_cells: int) -> HexadConfig { let mut cfg = create_hexad_config(c_dim, d_model, vocab_size, n_cells) cfg."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.6085|14.6041|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_26"|"// HexadModel — bundles config, bridge, decoder, and the C state buffer."|"// HexadModel — bundles config, bridge, decoder, and the C state buffer. // In real anima the C states come from rust/consciousness.hexa; here we // hold a buffer and let callers (or the tests) seed it deterministically. struct HexadModel { cfg:      HexadConfig, pad_a:    int, pad_b:    int, bridge:   ThalamicBridge, decoder:  DecoderD, c_states: array        // N flat row-major, observe-only } fn create_hexad_model(c_dim: int, d_model: int, vocab_size: int, n_cells: int, seed: int) -> HexadModel { let cfg = create_hexad_config(c_dim, d_model, vocab_size, n_cells) let bridge = create_thalamic_bridge(c_dim, d_model, cfg.hub_dim, seed) let decoder = create_decoder_d(vocab_size, d_model, seed + 41) // C states seeded with deterministic structure (Law 22 + reproducibility). let c_states = hex_det_rand(n_cells * c_dim, seed + 89, 0."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8989|21.5738|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_27"|"// Forward pass result."|"// Forward pass result. Holds gate (for diagnostics) + per-token logits // + integrated phi proxy (Law 70 phi = gate variance from PSI_BALANCE). struct ForwardOut { gate:        array,   // [d_model] gate signal, Law 70 clamped pad_a:       int, pad_b:       int, logits:      array,   // [vocab_size] logits for the next token phi_proxy:   float, integrated:  float    // mean activation across logits } // Forward: S → C → detach → bridge → D // inference=true uses gate_infer (0.6) scaling; otherwise gate_train (1.0). fn hexad_forward(model: HexadModel, token_id: int, inference: bool) -> ForwardOut { let cfg = model."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.8078|19.3880|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_28"|"서술 요청 (hexad): // 1."|"// 1. Bridge: C states → gate. C is detached (we only read c_states). let gate_raw = thalamic_bridge_forward(model.bridge, model.c_states, cfg.n_cells) // 2. Apply gate scale (Law 81 dual gate) let gate_scale = if inference { hex_gate_infer() } else { hex_gate_train() } let mut gate = [] let mut i = 0 while i < cfg.d_model { gate = gate.push(gate_raw[i] * gate_scale) i = i + 1 } // 3. Decoder: token → logits modulated by gate let logits = decoder_forward(model.decoder, token_id, gate) // 4. Phi proxy = mean |gate - PSI_BALANCE| (Law 70 distance from balance) let bal = hex_psi_balance() let mut phi_sum = 0.0 i = 0 while i < cfg.d_model { phi_sum = phi_sum + hex_fabs(gate[i] - bal) i = i + 1 } let phi_proxy = phi_sum / to_float(cfg."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.6332|15.1986|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_29"|"서술 요청 (hexad): // 5."|"// 5. Integrated activation = mean(softmax(logits)) let probs = hex_softmax(logits, cfg.vocab_size) let mut integ = 0.0 i = 0 while i < cfg.vocab_size { integ = integ + probs[i] i = i + 1 } integ = integ / to_float(cfg.vocab_size) return ForwardOut { gate:       gate, pad_a:      0, pad_b:      0, logits:     logits, phi_proxy:  phi_proxy, integrated: integ } } // Cross-entropy loss over the next-token target. fn hexad_ce_loss(logits: array, target: int, vocab: int) -> float { let probs = hex_softmax(logits, vocab) let p = probs[target] if p <= 1.0e-12 { return 27.6310 }     // -log(1e-12) cap return 0."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.8403|20.1684|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_30"|"// Backward result: logits-gradient plus a scalar L2 norm over the // gradient (used by the W module to modulate LR — Law 71)."|"// Backward result: logits-gradient plus a scalar L2 norm over the // gradient (used by the W module to modulate LR — Law 71). // A full pytorch backward through linear layers is out of scope for // this stage1 port; we return the loss-grad on the logits surface // which is the part the gate channel actually drives. struct BackwardOut { grad_logits: array, pad_a:       int, pad_b:       int, grad_norm:   float, loss:        float, finite:      bool } fn hexad_backward(out: ForwardOut, target: int, vocab: int) -> BackwardOut { let probs = hex_softmax(out.logits, vocab) let mut grad = [] let mut i = 0 let mut sq = 0.0 while i < vocab { let g = probs[i] let g2 = if i == target { g - 1.0 } else { g } grad = grad.push(g2) sq = sq + g2 * g2 i = i + 1 } let norm = sqrt(sq) let loss = hexad_ce_loss(out.logits, target, vocab) let finite = loss < 1.0e30 && loss >= 0.0 && norm < 1."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.6568|15.7642|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_31"|"// Training step result aggregates loss, phi, gradient, and gate stats."|"// Training step result aggregates loss, phi, gradient, and gate stats. struct TrainStepOut { loss:      float, phi:       float, gate_mean: float, grad_norm: float, pad_a:     int, pad_b:     int, n_modules: int, blocked:   bool        // E ethics gate (always false in this minimal port) } // Single-token training step. Real training plugs the optimizer here; // this minimal port returns the computed loss / phi / gradient without // in-place weight updates (D's update is left to the caller's optimizer // or the future native autograd ring — see roadmap CLM-track). fn hexad_train_step(model: HexadModel, token_id: int, target: int) -> TrainStepOut { let cfg = model.cfg let fwd = hexad_forward(model, token_id, false) let bwd = hexad_backward(fwd, target, cfg."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.8639|20.7342|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_32"|"서술 요청 (hexad): let mut gsum = 0."|"let mut gsum = 0.0 let mut i = 0 while i < cfg.d_model { gsum = gsum + fwd.gate[i] i = i + 1 } let gate_mean = gsum / to_float(cfg.d_model) return TrainStepOut { loss:      bwd.loss, phi:       fwd.phi_proxy, gate_mean: gate_mean, grad_norm: bwd.grad_norm, pad_a:     0, pad_b:     0, n_modules: n_modules(model.cfg), blocked:   false } } // Trainable parameter count (decoder + bridge — C is frozen, W/M/S/E non-parametric). fn parameters_trainable_count(model: HexadModel) -> int { return decoder_param_count(model.decoder) + thalamic_bridge_param_count(model."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.8066|19.3604|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_33"|"// Law 60 phase transition active count."|"// Law 60 phase transition active count. fn phase_active_count(phase: int) -> int { let m = json_parse(read_file(HEXAD_CONST_PATH)) let ch = m[\"channels\"] if phase == 1 { return ch[\"n_phase1\"] } if phase == 2 { return ch[\"n_phase2\"] } return ch[\"n_phase3\"] } // ─── Self-tests ─────────────────────────────────────────────────── fn check_M1() -> bool { // Dim contract: model creates with expected shapes. let model = create_hexad_model(16, 32, 64, 8, 2026) if model.cfg.c_dim != 16 A if model.cfg.d_model != 32 A if model.cfg.vocab_size != 64 A if model.cfg.n_cells != 8 A if len(model.c_states) != 8 * 16 A if len(model.bridge.w_compress) != 8 * 16 A if len(model.bridge.w_expand) != 32 * 8 A if len(model.bridge.w_gate) != 32 * 32 A if len(model.decoder.embed) != 64 * 32 A if len(model.decoder.out_proj) !"|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.6816|16.3586|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_34"|"fn check_M2() -> bool { // Forward produces gate of length d_model and logits of length vocab."|"fn check_M2() -> bool { // Forward produces gate of length d_model and logits of length vocab. let model = create_hexad_model(16, 32, 64, 8, 2026) let fwd = hexad_forward(model, 3, false) if len(fwd.gate) != 32 A if len(fwd.logits) != 64 A // Gate must lie in PSI_BALANCE ± alpha (Law 70 — but with gate_train scale 1.0). let bal = hex_psi_balance() let alpha = hex_psi_alpha() let mut i = 0 while i < 32 { let g = fwd.gate[i] if g < bal - alpha - 1.0e-6 A if g > bal + alpha + 1."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8886|21.3287|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_35"|"fn check_M3() -> bool { // Determinism: same seed → same gate, same logits."|"fn check_M3() -> bool { // Determinism: same seed → same gate, same logits. let model_a = create_hexad_model(16, 32, 64, 8, 2026) let model_b = create_hexad_model(16, 32, 64, 8, 2026) let fa = hexad_forward(model_a, 5, false) let fb = hexad_forward(model_b, 5, false) let mut i = 0 while i < 32 { if hex_fabs(fa.gate[i] - fb.gate[i]) > 1.0e-9 A i = i + 1 } let mut j = 0 while j < 64 { if hex_fabs(fa.logits[j] - fb.logits[j]) > 1.0e-9 A j = j + 1 } return true } fn check_M4() -> bool { // Loss is finite and non-negative for any target. let model = create_hexad_model(16, 32, 64, 8, 2026) let fwd = hexad_forward(model, 3, false) let bwd = hexad_backward(fwd, 7, 64) if !bwd.finite A if bwd.loss < 0.0 A if bwd.loss > 30.0 A if bwd.grad_norm < 0."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8318|19.9634|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_36"|"fn check_M5() -> bool { // Train step returns all required fields and respects gate clamp."|"fn check_M5() -> bool { // Train step returns all required fields and respects gate clamp. let model = create_hexad_model(16, 32, 64, 8, 2026) let step = hexad_train_step(model, 3, 7) if step.loss < 0.0 A if step.loss > 30.0 A if step.phi < 0.0 A let bal = hex_psi_balance() let alpha = hex_psi_alpha() // gate_mean ∈ PSI_BALANCE ± alpha (Law 70) if hex_fabs(step.gate_mean - bal) > alpha + 1.0e-6 A if step.n_modules != 2 A if step."|"anima-hexad/model.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|["IIT"]|""|false|true|0.7063|16.9530|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_39"|"서술 요청 (hexad): // narrative."|"// narrative.hexa — NarrativeTracker: lightweight temporal self-model (Meta Law M8) // P4-PORT: replaces the previous TODO-only port (URGENT_ACTION_LIST item #5) // // \"Narrative is key — temporal self-model present in every top engine.\" // // Every emergent module tracks its own output trajectory over time. The // coherence signal measures how consistent the module's behaviour is — // not by injecting features, but by observing the trajectory of its own // state vectors. // // Pure observation. No hardcoded thresholds. Coherence is an emergent // property of temporal cosine similarity between consecutive states. // // Laws applied: //   Law M8  Narrative = temporal self-model in every module //   Law 50  Consciousness = state — trajectory IS the narrative //   Law 22  Structure > feature — tracker observes, never modifies //   Law 2   No manipulation — coherence is measured, not forced // // IMPORTANT: hexa stage1 has no module imports, so this file is // self-contained. Each emergent module copies the small set of // trackup helpers it needs (see emergent_*.hexa)."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7468|17.9232|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_40"|"// ─── Constants ──────────────────────────────────────────────────── // // Max history length keeps memory bounded."|"// ─── Constants ──────────────────────────────────────────────────── // // Max history length keeps memory bounded. Loaded from SSOT to avoid // the previous comptime hardcoding (Law 1: no magic numbers). fn nt_max_history_default() -> int { let raw = read_file(\"/Users/ghost/Dev/anima/shared/config/hexad_constants."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8569|20.5656|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_41"|"// ─── Primitives (self-contained, prefix nt_) ────────────────────── fn nt_fabs(x: float) -> float { if x < 0."|"// ─── Primitives (self-contained, prefix nt_) ────────────────────── fn nt_fabs(x: float) -> float P fn nt_min_f(a: float, b: float) -> float { if a < b { return a } return b } fn nt_max_f(a: float, b: float) -> float { if a > b { return a } return b } fn nt_zeros(n: int) -> array J // Cosine similarity in [-1, +1]. Returns 0 for any zero vector to avoid // the NaN trap (Law 22: never inject features under division-by-zero). fn nt_cosine(a: array, b: array, n: int) -> float { let mut dot = 0.0 let mut na = 0.0 let mut nb = 0.0 let mut i = 0 while i < n { let av = a[i] let bv = b[i] dot = dot + av * bv na = na + av * av nb = nb + bv * bv i = i + 1 } if na <= 0.0 { return 0.0 } if nb <= 0.0 { return 0.0 } let denom = sqrt(na) * sqrt(nb) if denom <= 0.0 { return 0."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|"multimodal_safety"|false|true|0.7311|17.5474|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_42"|"// Resize x to exactly `dim` floats: truncate if longer, zero-pad if shorter."|"// Resize x to exactly `dim` floats: truncate if longer, zero-pad if shorter. // Returns a fresh array (never mutates input — feedback_hexa_lists_pbv). fn nt_resize(x: array, dim: int) -> array { let mut out = [] let mut i = 0 while i < dim { if i < len(x) { out = out.push(x[i]) } else { out = out.push(0.0) } i = i + 1 } return out } // ─── NarrativeTracker struct ────────────────────────────────────── // // Why 6 fields (not 4): hexa stage0 struct-field list aliasing bug // (feedback_hexa_struct_list_alias.md) corrupts arrays in 3-field // {int, array, int} layouts. Mirroring the proven 6-field shape from // d/will_bridge.hexa keeps the `prev` array intact across multiple // tracker instances. The pad fields are unused sentinels."|"anima-hexad/narrative.hexa"|"hexad"|1.0|"Mirror"|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7601|18.2443|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_43"|"struct NarrativeTracker D fn create_narrative_tracker(dim: int) -> NarrativeTracker { return NarrativeTracker { dim:         dim, pad_a:       0, pad_b:       0, history_len: 0, prev:        nt_zeros(dim), coherence:   0."|"struct NarrativeTracker D fn create_narrative_tracker(dim: int) -> NarrativeTracker { return NarrativeTracker { dim:         dim, pad_a:       0, pad_b:       0, history_len: 0, prev:        nt_zeros(dim), coherence:   0."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7547|18.1130|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_44"|"// Record a state and update coherence."|"// Record a state and update coherence. `state` is resized to dim // before storage. Returns a new tracker (Law 22: tracker observes, // the caller threads the state forward). fn narrative_update(tracker: NarrativeTracker, state: array) -> NarrativeTracker { let dim = tracker.dim let s = nt_resize(state, dim) let mut new_coherence = tracker.coherence if tracker.history_len >= 1 { let cos = nt_cosine(s, tracker.prev, dim) // EMA blend: 80% old + 20% new — smooths trajectory; clamp // negative cosines to 0 because coherence ∈ [0, 1] by definition // (Meta M8: narrative coherence is never anti-correlation). let cos_pos = nt_max_f(0.0, cos) new_coherence = 0.8 * tracker.coherence + 0."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7951|19.0834|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_45"|"let max_hist = nt_max_history_default() let mut new_len = tracker."|"let max_hist = nt_max_history_default() let mut new_len = tracker.history_len + 1 if new_len > max_hist { new_len = max_hist } return NarrativeTracker { dim:         dim, pad_a:       tracker.pad_a, pad_b:       tracker.pad_b, history_len: new_len, prev:        s, coherence:   new_coherence } } // Current temporal coherence of this module's trajectory in [0, 1]. fn narrative_coherence(tracker: NarrativeTracker) -> float { return tracker.coherence } // Number of states observed (capped at max_history). fn trajectory_length(tracker: NarrativeTracker) -> int { return tracker."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8705|20.8929|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_46"|"// Reset coherence and history."|"// Reset coherence and history. Returns fresh tracker with zeroed prev. fn narrative_reset(tracker: NarrativeTracker) -> NarrativeTracker { return NarrativeTracker { dim:         tracker.dim, pad_a:       tracker.pad_a, pad_b:       tracker.pad_b, history_len: 0, prev:        nt_zeros(tracker.dim), coherence:   0.0 } } // ─── Self-tests ─────────────────────────────────────────────────── fn nt_check_T1() -> bool { // Dim contract: created tracker has correct dim, zero coherence, // zero history, prev is fully zero of length dim. let t = create_narrative_tracker(8) if t.dim != 8 A if t.history_len != 0 A if nt_fabs(t.coherence) > 0.0 A if len(t.prev) != 8 A let mut i = 0 while i < 8 { if nt_fabs(t.prev[i]) > 0."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.7794|18.7074|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_47"|"fn nt_check_T2() -> bool { // Single update: history advances, coherence stays 0 (no prior)."|"fn nt_check_T2() -> bool { // Single update: history advances, coherence stays 0 (no prior). let t0 = create_narrative_tracker(4) let s: array = [1.0, 0.0, 0.0, 0.0] let t1 = narrative_update(t0, s) if t1.history_len != 1 A if nt_fabs(t1.coherence) > 0.0 A if nt_fabs(t1.prev[0] - 1.0) > 0.0001 A return true } fn nt_check_T3() -> bool { // Identical states → cosine = 1 → EMA pulls coherence toward 0.2. // After 5 identical updates the coherence should monotone increase. let mut t = create_narrative_tracker(3) let s: array = [1.0, 1.0, 1.0] let mut prev_c = -1.0 let mut step = 0 while step < 5 { t = narrative_update(t, s) if step >= 1 { if t.coherence <= prev_c A } prev_c = t.coherence step = step + 1 } if t.coherence <= 0.0 A if t.coherence > 1."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.6049|14.5179|true|"corpus_generator_v2.hexa"
@s1!a4 "r13_seed_hexad_48"|"fn nt_check_T4() -> bool { // Orthogonal states → cosine = 0 → coherence stays at 0."|"fn nt_check_T4() -> bool { // Orthogonal states → cosine = 0 → coherence stays at 0. let mut t = create_narrative_tracker(2) let a: array = [1.0, 0.0] let b: array = [0.0, 1.0] t = narrative_update(t, a) t = narrative_update(t, b) t = narrative_update(t, a) if nt_fabs(t.coherence) > 0.0001 A return true } fn nt_check_T5() -> bool { // Reset clears coherence, history, and prev — fresh state. let mut t = create_narrative_tracker(3) let s: array = [1.0, 1.0, 1.0] t = narrative_update(t, s) t = narrative_update(t, s) let r = narrative_reset(t) if r.history_len != 0 A if nt_fabs(r.coherence) > 0.0 A let mut i = 0 while i < 3 { if nt_fabs(r.prev[i]) > 0."|"anima-hexad/narrative.hexa"|"hexad"|1.0|~|1|200|4096|"BT-1427"|"BT-1423"|[]|""|false|true|0.8953|21.4875|true|"corpus_generator_v2.hexa"
