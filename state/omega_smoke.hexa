import "../../hexa-lang/stdlib/portable_fs.hexa"

fn main() {
    let here = "/Users/ghost/core/anima/state/omega_smoke.hexa"
    let sz = pfs_file_size(here)
    let ts = pfs_now_ns()
    let exists = pfs_file_exists(here)
    let json = "{\"smoke\":true,\"file_size\":" + to_string(sz)
             + ",\"now_ns\":\"" + ts + "\""
             + ",\"exists\":" + (if exists { "true" } else { "false" })
             + "}\n"
    let _ = exec("printf '%s' " + "'" + json.replace("'","'\\''") + "' > /Users/ghost/core/anima/state/omega_smoke_result.json")
    println("smoke ok")
}
main()
