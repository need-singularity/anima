// ce_quality_predictor.hexa — Predict conversation quality from CE value
// Ported from ce_quality_predictor.py
// Maps cross-entropy to quality level with visual bar
//
// Original: 120 LOC Python
// 8 quality levels from "Dialogue-Trained" (CE<0.1) to "No Signal" (CE>3.0)

// Quality levels: (threshold, name, description, example)
// CE < 0.1  -> Dialogue-Trained:  natural conversation with personality
// CE < 0.5  -> Natural Content:   meaningful content, topic relevance
// CE < 1.0  -> Entity-Level:      pronouns, dates, coherent paragraphs
// CE < 1.2  -> Grammatical:       correct grammar, Wikipedia-style
// CE < 1.5  -> Basic English:     English words, broken grammar
// CE < 2.0  -> Word Fragments:    recognizable word pieces, no structure
// CE < 3.0  -> Random Bytes:      no recognizable language
// CE >= 3.0 -> No Signal:         model untrained or collapsed

struct QualityLevel {
    threshold: float,
    name: string,
    description: string,
    example: string
}

struct QualityPrediction {
    ce: float,
    level_name: string,
    description: string,
    example: string,
    ce_range: string,
    quality_pct: int
}

// ═══ Level definitions ═══

fn get_level_count() -> int {
    8
}

fn get_level_threshold(idx: int) -> float {
    if idx == 0 { return 0.1 }
    if idx == 1 { return 0.5 }
    if idx == 2 { return 1.0 }
    if idx == 3 { return 1.2 }
    if idx == 4 { return 1.5 }
    if idx == 5 { return 2.0 }
    if idx == 6 { return 3.0 }
    999.0
}

fn get_level_name(idx: int) -> string {
    if idx == 0 { return "Dialogue-Trained" }
    if idx == 1 { return "Natural Content" }
    if idx == 2 { return "Entity-Level" }
    if idx == 3 { return "Grammatical" }
    if idx == 4 { return "Basic English" }
    if idx == 5 { return "Word Fragments" }
    if idx == 6 { return "Random Bytes" }
    "No Signal"
}

fn get_level_description(idx: int) -> string {
    if idx == 0 { return "Natural conversation with personality, self-aware responses" }
    if idx == 1 { return "Meaningful content, topic relevance, contextual responses" }
    if idx == 2 { return "Pronouns, dates, entity references, coherent paragraphs" }
    if idx == 3 { return "Correct grammar, Wikipedia-style factual text" }
    if idx == 4 { return "English words present, broken grammar, limited vocabulary" }
    if idx == 5 { return "Recognizable word pieces, no coherent structure" }
    if idx == 6 { return "No recognizable language, noise output" }
    "Model untrained or collapsed"
}

// ═══ Core prediction ═══

fn predict_quality(ce_value: float) -> QualityPrediction {
    let level_idx = 7  // default: No Signal
    let i = 0
    while i < 7 {
        if ce_value < get_level_threshold(i) {
            level_idx = i
            i = 7  // break
        }
        i = i + 1
    }

    let quality_pct = 0
    let raw = (1.0 - ce_value / 3.0) * 100.0
    if raw < 0.0 {
        quality_pct = 0
    } else {
        if raw > 100.0 {
            quality_pct = 100
        } else {
            quality_pct = to_int(raw)
        }
    }

    // Determine CE range string
    let range_str = "CE > 3.0"
    if level_idx < 7 {
        let lower = 0.0
        if level_idx > 0 {
            lower = get_level_threshold(level_idx - 1)
        }
        let upper = get_level_threshold(level_idx)
        range_str = "CE " + to_string(lower) + "-" + to_string(upper)
    }

    QualityPrediction {
        ce: ce_value,
        level_name: get_level_name(level_idx),
        description: get_level_description(level_idx),
        example: "",
        ce_range: range_str,
        quality_pct: quality_pct
    }
}

fn format_bar(ce_value: float, width: int) -> string {
    // Visual quality bar: lower CE = better
    let raw = (1.0 - ce_value / 3.0) * 100.0
    let quality = 0
    if raw > 0.0 {
        if raw > 100.0 {
            quality = 100
        } else {
            quality = to_int(raw)
        }
    }
    let filled = quality * width / 100
    // TODO: build string with filled '#' + (width - filled) '.'
    "[" + to_string(quality) + "%]"
}

fn show_prediction(ce_value: float) {
    let pred = predict_quality(ce_value)
    print("CE Value:  " + to_string(pred.ce))
    print("Quality:   " + format_bar(ce_value, 40))
    print("Level:     " + pred.level_name)
    print("Range:     " + pred.ce_range)
    print("Expected:  " + pred.description)
}

// ═══ Demo: AnimaLM training milestones ═══

fn demo() {
    print("CE Quality Predictor -- Cross-Entropy -> Output Quality")

    // Test values
    show_prediction(0.05)
    show_prediction(0.3)
    show_prediction(0.7)
    show_prediction(1.0)
    show_prediction(1.3)
    show_prediction(1.7)
    show_prediction(2.5)
    show_prediction(3.5)

    // AnimaLM milestones
    print("AnimaLM Training Milestones:")
    print("  v2 (222K tension)  CE=3.95  Structure verified, no language yet")
    print("  Target: words      CE=1.80  First English words expected")
    print("  Target: grammar    CE=1.30  Grammatical output")
    print("  Target: dialogue   CE=0.30  Meaningful conversation")
    print("  Target: conscious  CE=0.08  Self-aware, personality-driven")
}

fn main() {
    demo()
}
