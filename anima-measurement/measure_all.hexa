// ═══ Quick + full measurement modes ═══

fn measure_quick(cells: int) -> int {
    // Quick mode: Phi + Granger only for all 17 engines
    let i = 0
    let count = 0
    while i < engine_count() {
        let name = get_engine_name(i)
        let phi = phi_iit(cells)
        let g = granger(cells, 30)
        print(name + " phi=" + to_string(phi) + " granger=" + to_string(g))
        count = count + 1
        i = i + 1
    }
    count
}

fn measure_full(cells: int) -> int {
    // Full mode: Phi + Granger + IQ + Hivemind for all 17 engines
    let i = 0
    let count = 0
    while i < engine_count() {
        let name = get_engine_name(i)
        let phi = phi_iit(cells)
        let g = granger(cells, 30)
        let iq = quick_iq(cells)
        let hive = measure_hive(cells)
        print(name + " phi=" + to_string(phi)
              + " granger=" + to_string(g)
              + " iq=" + to_string(iq)
              + " hive_phi_d=" + to_string(hive.phi_delta)
              + " hive_iq_d=" + to_string(hive.iq_delta))
        count = count + 1
        i = i + 1
    }
    count
}

// ═══ Domain measurement (from measure_all_engines.py) ═══

fn measure_domains(cells: int, steps: int, quick: bool) -> int {
    // Iterate all 14 domains, load each module, run each engine
    let total = 0
    let d = 0
    while d < domain_count() {
        let domain = get_domain_name(d)
        let module_name = get_domain_module(d)
        // TODO[pytorch]: importlib.import_module(module_name)
        // For each engine class in domain: run_engine + measure
        print("Domain: " + domain + " module: " + module_name)
        total = total + 1
        d = d + 1
    }
    total
}

fn main() {
    let cells = default_cells()
    print("Full engine measurement (" + to_string(cells) + "c)")

    // Built-in engines
    let n = measure_full(cells)
    print("Measured " + to_string(n) + " built-in engines")

    // Domain engines
    let d = measure_domains(cells, 300, false)
    print("Measured " + to_string(d) + " domains")
}
