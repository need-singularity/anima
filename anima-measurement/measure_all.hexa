// ═══ 17 Built-in engine configs ═══

fn engine_count() -> int { 17 }

fn get_engine_name(idx: int) -> string {
    if idx == 0 { return "Baseline" }
    if idx == 1 { return "Sync+Faction" }
    if idx == 2 { return "Oscillator" }
    if idx == 3 { return "Osc+Laser(0.05)" }
    if idx == 4 { return "QuantumWalk" }
    if idx == 5 { return "Frustration" }
    if idx == 6 { return "Osc+Sync" }
    if idx == 7 { return "Osc+Faction" }
    if idx == 8 { return "Osc+QW" }
    if idx == 9 { return "Osc+Frust" }
    if idx == 10 { return "QW+Faction" }
    if idx == 11 { return "QW+Frust" }
    if idx == 12 { return "QW+Laser" }
    if idx == 13 { return "Frust+Laser" }
    if idx == 14 { return "Sync+QW" }
    if idx == 15 { return "Full (all)" }
    "FUSE-3: Cambrian+OscQW"
}

fn get_engine_mechanisms(idx: int) -> string {
    // Returns comma-separated mechanism list
    if idx == 0 { return "" }
    if idx == 1 { return "sync,faction" }
    if idx == 2 { return "oscillator" }
    if idx == 3 { return "oscillator,laser" }
    if idx == 4 { return "quantum" }
    if idx == 5 { return "sync,faction,frustration" }
    if idx == 6 { return "oscillator,sync" }
    if idx == 7 { return "oscillator,faction" }
    if idx == 8 { return "oscillator,quantum" }
    if idx == 9 { return "oscillator,frustration" }
    if idx == 10 { return "quantum,faction" }
    if idx == 11 { return "quantum,frustration" }
    if idx == 12 { return "quantum,laser" }
    if idx == 13 { return "frustration,laser" }
    if idx == 14 { return "sync,quantum" }
    if idx == 15 { return "sync,faction,oscillator,quantum,frustration,laser,ib2" }
    "oscillator,quantum,cambrian"
}

