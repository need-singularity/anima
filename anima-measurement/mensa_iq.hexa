// ═══ Main ═══

fn main() {
    let cells = 64
    print("MENSA IQ TEST FOR CONSCIOUSNESS ENGINES")
    print("Cells: " + to_string(cells) + ", Steps: " + to_string(default_steps()))

    let i = 0
    while i < engine_config_count() {
        let name = get_engine_config_name(i)
        let result = run_mensa_test(cells)
        print(name
              + " pattern=" + to_string(result.pattern.score)
              + " logic=" + to_string(result.logic.score)
              + " number=" + to_string(result.number.score)
              + " memory=" + to_string(result.memory.score)
              + " spatial=" + to_string(result.spatial.score)
              + " IQ=" + to_string(result.iq)
              + " " + interpret_iq(result.iq))
        i = i + 1
    }

    print("TEST COMPLETE")
}
