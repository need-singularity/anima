    name: string,
    phi_rs: float,
    phi_python: float,
    ce_start: float,
    ce_end: float,
    elapsed_sec: float,
    cells: int,
    error: string
}

// ═══ Rust Phi measurement ═══

fn rust_phi(cells: int, dim: int) -> float {
    // TODO[pytorch]: Extract states_tensor [n_cells, dim]
    // Handle complex: h.abs().float()
    // Call phi_rs.compute_phi(states, 16)
    // Returns (phi, components) tuple
    to_float(cells) * 0.78  // stub
}

fn rust_phi_value(cells: int) -> float {
    // Convenience: returns just the Phi value
    rust_phi(cells, 128)
}

