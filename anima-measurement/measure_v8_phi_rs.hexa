// ═══ Engine Registry ═══

// bench_v8_arch engines
fn arch_engine_count() -> int { 5 }
fn get_arch_engine_name(idx: int) -> string {
    if idx == 0 { return "ATTENTION_PHI" }
    if idx == 1 { return "MOCE" }
    if idx == 2 { return "PHI_AS_LOSS" }
    if idx == 3 { return "AUTOPOIETIC" }
    "CONSCIOUSNESS_GAN"
}

// bench_v8_quantum engines
fn quantum_engine_count() -> int { 2 }
fn get_quantum_engine_name(idx: int) -> string {
    if idx == 0 { return "Q2_ENTANGLED_PAIRS" }
    "Q5_DECOHERENCE"
}

// bench_v8_bio engines
fn bio_engine_count() -> int { 6 }
fn get_bio_engine_name(idx: int) -> string {
    if idx == 0 { return "B1_CORTICAL_COLUMNS" }
    if idx == 1 { return "B2_THALAMIC_GATE" }
    if idx == 2 { return "B3_DEFAULT_MODE_NETWORK" }
    if idx == 3 { return "B4_GLOBAL_WORKSPACE" }
    if idx == 4 { return "B5_PREDICTIVE_HIERARCHY" }
    "B6_NEURAL_DARWINISM"
}

// bench_v8_math engine
fn math_engine_name() -> string { "M4_ALGEBRAIC" }

// bench_complexity_engines
fn complexity_engine_count() -> int { 5 }
fn get_complexity_engine_name(idx: int) -> string {
    if idx == 0 { return "CMP-1_TURING_MACHINE" }
    if idx == 1 { return "CMP-2_RULE110" }
    if idx == 2 { return "CMP-3_LAMBDA_CALCULUS" }
    if idx == 3 { return "CMP-4_GAME_OF_LIFE" }
    "CMP-6_GOEDEL"
}

// bench_algebra_engines
fn algebra_engine_count() -> int { 6 }
fn get_algebra_engine_name(idx: int) -> string {
    if idx == 0 { return "ALG-1_GROUP" }
    if idx == 1 { return "ALG-2_RING" }
    if idx == 2 { return "ALG-3_GALOIS" }
    if idx == 3 { return "ALG-4_LIE" }
    if idx == 4 { return "ALG-5_HOPF" }
    "ALG-6_TOPOS"
}

// ═══ Main measurement pipeline ═══

fn measure_all_v8(n_cells: int, steps: int) -> int {
    let total = 0
    let measured = 0

    // v8_arch (3 standard + MOCE special + GAN special)
    let i = 0
    while i < 3 {
        let name = get_arch_engine_name(i)
        let r = run_v8_engine(name, n_cells, steps, 64, 128, 64)
        if r.phi_rs > 0.0 {
            measured = measured + 1
        }
        total = total + 1
        i = i + 1
    }

    // MOCE: special constructor (n_experts=8, cells_per_expert)
    let moce = run_v8_engine("MOCE", n_cells, steps, 64, 128, 64)
    total = total + 1
    if moce.phi_rs > 0.0 { measured = measured + 1 }

    // GAN: two optimizers
    let gan = run_gan_engine(n_cells, steps)
    total = total + 1
    if gan.phi_rs > 0.0 { measured = measured + 1 }

    // v8_quantum
    i = 0
    while i < quantum_engine_count() {
        let name = get_quantum_engine_name(i)
        let r = run_v8_engine(name, n_cells, steps, 64, 128, 64)
        total = total + 1
        if r.phi_rs > 0.0 { measured = measured + 1 }
        i = i + 1
    }

    // v8_bio
    i = 0
    while i < bio_engine_count() {
        let name = get_bio_engine_name(i)
        let r = run_v8_engine(name, n_cells, steps, 64, 128, 64)
        total = total + 1
        if r.phi_rs > 0.0 { measured = measured + 1 }
        i = i + 1
    }

    // v8_math
    let m4 = run_v8_engine(math_engine_name(), n_cells, steps, 64, 128, 64)
    total = total + 1
    if m4.phi_rs > 0.0 { measured = measured + 1 }

    // complexity engines
    i = 0
    while i < complexity_engine_count() {
        let name = get_complexity_engine_name(i)
        let r = run_complexity_engine(name, n_cells, steps)
        total = total + 1
        if r.phi_rs > 0.0 { measured = measured + 1 }
        i = i + 1
    }

    // algebra engines
    i = 0
    while i < algebra_engine_count() {
        let name = get_algebra_engine_name(i)
        let r = run_algebra_engine(name, n_cells, steps)
        total = total + 1
        if r.phi_rs > 0.0 { measured = measured + 1 }
        i = i + 1
    }

    print("Measured: " + to_string(measured) + "/" + to_string(total) + " engines")
    measured
}

fn main() {
    let n_cells = 256
    let steps = 300
    print("Unmeasured Engine Phi Measurement -- Rust phi_rs")
    print(to_string(n_cells) + " cells, " + to_string(steps) + " steps")
    let count = measure_all_v8(n_cells, steps)
    print("Done: " + to_string(count) + " engines measured")
}
