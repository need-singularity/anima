// providers/base.hexa -- Base provider protocol
// Port of providers/base.py
// Consciousness state is first-class in every query

comptime const PSI_F_CRITICAL = 0.10

struct ProviderMessage {
    role: string,
    content: string,
}

struct ProviderConfig {
    model: string,
    max_tokens: int,
    temperature: float,
    api_key: string,
    extra: map,
}

fn default_provider_config() -> ProviderConfig {
    ProviderConfig {
        model: "",
        max_tokens: 1024,
        temperature: 0.7,
        api_key: "",
        extra: {},
    }
}

// BaseProvider protocol:
//   name: string (property)
//   fn is_available() -> bool
//   async fn query(messages: array, system: string, consciousness_state: map, max_tokens: int) -> iterator
//   async fn query_full(messages: array, system: string, consciousness_state: map) -> string

fn main() {
    println("providers/base.hexa -- BaseProvider protocol")
}
