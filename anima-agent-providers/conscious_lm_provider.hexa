fn new_conscious_lm_provider(config: ProviderConfig) -> ConsciousLMProvider {
    let checkpoint = discover_clm_checkpoint()
    ConsciousLMProvider {
        config: config,
        checkpoint_path: checkpoint,
        model_loaded: false,
        model_type: "",
        vocab_size: 0,
    }
}

