    "struct_mutation": {
      "symptom": "let cfg = parse_args(argv) → 'invalid assignment target'",
      "cause": "hexa struct field mutation (m.x = m.x + 1) silently fails — returns unmutated copy",
      "fix": "all functions rewritten to use primitive mut vars + final struct literal return",
      "affected": ["parse_args", "mind_step", "validate_hub", "print_banner"],
