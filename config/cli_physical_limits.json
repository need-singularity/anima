    },
    "find_char_at": {
      "symptom": "unknown string method .find() / .char_at()",
      "cause": "hexa lacks .find() and .char_at() — only .contains() and .split() available",
      "fix": ".find(x)>=0 → .contains(x), char_at loop → .split(',') array iteration",
      "affected": ["hub_route (22 calls)", "validate_hub", "print_banner laws parse"],
      "date": "2026-04-11"
    }
