  "absolute_rules": {
    "_description": "절대 위반 금지 규칙. 위반 시 crash/data loss 확정.",
    "R01_no_concurrent_io": {
      "rule": "학습 중 대용량 다운로드/scp 절대 금지",
      "reason": "NFS I/O 포화 → 양쪽 crash (incident: nfs_io_conflict, qwen_download_kills_training)",
      "action": "순차 실행: 다운로드 완료 → 학습 시작"
    },
    "R02_check_disk_before_launch": {
      "rule": "학습 발사 전 du -sh /workspace/ 확인 (df 무시!)",
      "reason": "df는 NFS 전체 표시, 실제 쿼터와 무관 (incident: disk_quota, volume_quota_50gb)",
      "action": "du -sh /workspace/ < volume_gb의 80%"
    },
    "R03_delete_after_r2": {
      "rule": "R2 업로드 완료된 체크포인트 즉시 삭제",
      "reason": "체크포인트 누적 = 디스크 폭발 (incident: disk_quota)",
      "action": "R2 verify → rm -rf"
    },
    "R04_bf16_foreach_false": {
      "rule": "AdamW(foreach=False) 필수",
      "reason": "foreach=True + mixed dtype = 14건 crash (incident: bf16_dtype_14_incidents)",
      "action": "acceleration_flow.json bf16_master_rule 참조"
    },
    "R05_72b_needs_2gpu": {
      "rule": "72B 모델은 H100 2대 필수 (1대 불가)",
      "reason": "4-bit도 80GB 초과 (incident: 72b_oom_on_h100)",
      "action": "gpuCount=2, max_memory={0:'70GiB', 1:'70GiB'}"
    },
    "R06_pin_versions_for_72b": {
      "rule": "72B 학습 시 transformers==4.46.0, torchvision==0.19.1 고정",
      "reason": "transformers 5.x BNB 호환성 문제 (incident: set_submodule_missing)",
      "action": "pip install transformers==4.46.0 torch==2.4.1 torchvision==0.19.1 bitsandbytes==0.44.1"
    },
    "R07_config_not_weight_shape": {
      "rule": "4-bit 모델에서 .weight.shape 접근 금지 → model.config 사용",
      "reason": "bnb dequantize 블로킹 → hang (incident: 72b_purefield_hang)",
      "action": "config.hidden_size, config.intermediate_size 사용"
    },
    "R08_dtype_try_except": {
      "rule": "4-bit 파라미터 dtype 변환 시 try/except 필수",
      "reason": "quantized param은 dtype 변경 불가 (incident: dtype_incompatible_set_data)",
      "action": "try .to(dtype) except → .to(device) only"
    },
    "R09_checkpoint_every_large": {
      "rule": "checkpoint_every >= 2000 (NFS Pod) / >= 4000 (대형 모델)",
      "reason": "체크포인트 2GB × 빈번 저장 = 디스크 폭발",
      "action": "--checkpoint-every 4000"
    },
    "R10_verify_script_exists": {
      "rule": "학습 발사 전 서버에 학습 스크립트 존재 확인",
      "reason": "watchdog가 없는 스크립트로 재시작 → 무한 crash 루프 (incident: watchdog_script_mismatch)",
      "action": "ls /workspace/train_anima_lm.py && md5sum 비교"
    },
    "R11_nohup_check_disk": {
      "rule": "nohup 전 root 파티션 여유 확인 (df -h /)",
      "reason": "디스크 풀이면 nohup 즉시 죽음 (incident: nohup_empty_log)",
      "action": "df -h / (최소 1GB 여유)"
    },
    "R12_pod_stop_loses_gpu": {
      "rule": "Pod 중지하면 GPU 보장 안 됨 — 중요 학습 중 중지 금지",
      "reason": "resume 시 GPU 없으면 재시작 불가 (incident: pod2_gpu_unavailable)",
      "action": "학습 중에는 절대 중지하지 말 것. 완료 후 삭제."
    }
  },
