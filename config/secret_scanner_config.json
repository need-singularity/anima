{
  "schema": "anima.secret_scanner_config.v1",
  "tool": "tool/secret_scanner.hexa",
  "purpose": "regex-based secret detection for tool/ + state/ — pre-commit suitable, NEVER auto-installed",
  "repo_root": "/Users/ghost/core/anima",
  "scan_roots": [
    "tool",
    "state",
    "config"
  ],
  "exclude_paths": [
    "state/secret_scan_violations.json",
    "state/secret_scan_violations_redacted.json",
    "state/security_roi_audit.json",
    "config/secret_scanner_config.json",
    "tool/secret_scanner.hexa"
  ],
  "exclude_path_substrings": [
    "_audit.json",
    "_completion.json",
    "_ledger.json",
    "_snapshot.json",
    "_dryrun.json",
    "_dry_run.json",
    "_summary.json",
    "_manifest.json",
    "_tokenizer_sha.json",
    "_progress.jsonl",
    "_log.jsonl",
    "_cert.json",
    ".meta2-cert/",
    "phi_offset_auto_detected.json",
    "h_last_ffi_p1_smoke.json",
    "n6_cluster_completion_audit.json",
    "spec_tools_completion_audit.json",
    "tool_dir_completion_audit.json",
    "edu_cell_audit.json",
    "file_completion_ledger.json",
    "sbom_cyclonedx.json",
    "techniques_225_import_b_result.json",
    "techniques_225_import_f_result.json",
    "techniques_225_import_g_result.json",
    "n6_substrate_selftest_result.json",
    "n6_consciousness_substrate_status.json"
  ],
  "exclude_keyword_for_generic_entropy": [
    "tokenizer",
    "tokenizer.json",
    "sha256",
    "checksum",
    "hash",
    "manifest",
    "ledger"
  ],
  "exclude_extensions": [
    ".pyc",
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".pdf",
    ".bin",
    ".safetensors",
    ".gguf",
    ".tar",
    ".gz",
    ".zip"
  ],
  "max_file_bytes": 524288,
  "patterns": [
    {
      "id": "AWS_ACCESS_KEY",
      "regex": "AKIA[0-9A-Z]{16}",
      "severity": "CRITICAL",
      "note": "AWS access key id (40 char IAM principal prefix)"
    },
    {
      "id": "AWS_SECRET_KEY",
      "regex_keyword": "aws_secret_access_key",
      "regex": "[0-9a-zA-Z/+]{40}",
      "severity": "CRITICAL",
      "note": "40-char base64-ish secret — keyword-anchored to reduce false positives"
    },
    {
      "id": "HF_TOKEN",
      "regex": "hf_[a-zA-Z0-9]{32,}",
      "severity": "HIGH",
      "note": "HuggingFace user access token"
    },
    {
      "id": "PRIVATE_KEY_HEADER",
      "regex": "-----BEGIN [A-Z ]+PRIVATE KEY-----",
      "severity": "CRITICAL",
      "note": "PEM-encoded private key block header"
    },
    {
      "id": "GITHUB_TOKEN",
      "regex": "gh[pousr]_[a-zA-Z0-9]{36,}",
      "severity": "HIGH",
      "note": "GitHub personal access / OAuth / refresh / server token"
    },
    {
      "id": "SLACK_TOKEN",
      "regex": "xox[abprs]-[0-9a-zA-Z-]{10,}",
      "severity": "HIGH",
      "note": "Slack bot/user/refresh token"
    },
    {
      "id": "OPENAI_API_KEY",
      "regex": "sk-[a-zA-Z0-9]{32,}",
      "severity": "HIGH",
      "note": "OpenAI / Anthropic-style API key prefix"
    },
    {
      "id": "GENERIC_HIGH_ENTROPY",
      "regex_keyword_any": ["secret", "token", "api_key", "apikey", "password", "passwd", "private_key"],
      "min_entropy_chars": 32,
      "severity": "MEDIUM",
      "note": "Long high-entropy string adjacent to a credential keyword"
    }
  ],
  "redaction": {
    "policy": "first_4_chars + length_only",
    "max_redacted_value_len": 64,
    "never_log_full_match": true
  },
  "output": {
    "violations_path": "state/secret_scan_violations.json",
    "summary_path": "state/secret_scan_summary.json"
  },
  "exit_policy": {
    "no_violations": 0,
    "medium_only": 1,
    "high_or_critical": 2,
    "config_or_setup_error": 3
  },
  "pre_commit_hook_install": {
    "policy": "MANUAL_ONLY",
    "rationale": "agent MUST NOT auto-install git hooks (privacy + user control)",
    "manual_command_template": "ln -s ../../tool/secret_scanner_pre_commit.sh .git/hooks/pre-commit"
  }
}
