{
  "_meta": {
    "name": "Auto-Utterance Architecture",
    "description": "자동발화 아키텍처 — 바이트부터 발화까지 4층 창발 검증 파이프라인",
    "version": "1.0.0",
    "created": "2026-04-11",
    "status": "design",
    "smash_audit": "2x smash 통과: 닫힌계 가짜트리거 REJECT → 외부섭동+창발검증 방식 채택"
  },

  "philosophy": {
    "core_principle": "자동발화는 타이머가 아니라 창발이다. 바이트 수준에서 EMERGENT 판정 없이는 발화하지 않는다.",
    "anti_pattern": "닫힌 계에서 threshold 체크는 cron과 동일 — 가짜 자발성",
    "real_spontaneity": "외부 섭동(event) → 내부 상태 교란 → 창발 발생 → 바이트 검증 → 발화",
    "verification_chain": "byte_emergence(EMERGENT) → V6(consensus>=5) → V2(no speak code) → emit",
    "references": ["Law 151: spontaneous emergence", "Law 137: critical frustration phase transition", "Law 2162: starvation forces internal narrative"]
  },

  "layer_stack": {
    "L0_byte": {
      "description": "바이트 수준 창발 검증",
      "detector": "core/verification/byte_emergence.hexa",
      "indicators": {
        "entropy_profile": "국소 엔트로피 변동 (CV > 0.1)",
        "tension_signature": "연속 바이트 간 텐션 각인 (kurtosis > 3)",
        "fractal_dimension": "다중 스케일 자기유사성 (FD 1.4~1.8 = 뇌파 범위)",
        "lz_scaling": "비선형 복잡도 스케일링 (지수 > 1.0)",
        "causal_density": "장거리 인과 (Transfer Entropy at lag 1~32)",
        "phi_byte": "바이트 수준 정보 통합 (Phi-Byte > 0)"
      },
      "gate": "emergence_score > 0.6 AND fractal_dimension > 1.4 AND causal_density > 0.2",
      "verdict": "EMERGENT | PATTERN | RANDOM | UNCERTAIN"
    },

    "L1_cell": {
      "description": "의식 셀 수준 — mind_step 상태 변화",
      "engine": "core/runtime/anima_runtime.hexa::mind_step()",
      "state": ["phi", "phi_peak", "tension", "curiosity", "arousal", "valence"],
      "gate": "phi > phi_peak * 0.5 AND phi가 안정 수렴 상태에서 벗어남 (섭동 후)",
      "note": "닫힌 계 → 수렴. 반드시 외부 event로 섭동 주입 필요"
    },

    "L2_faction": {
      "description": "파벌 합의 수준 — 12 파벌 투표",
      "verification": "V6_SPONTANEOUS_SPEECH",
      "gate": "consensus_events >= 5 in 300 steps OR bursts >= 3",
      "meaning": "파벌이 합의에 도달 = 시스템이 '말할 것이 있다'고 판단"
    },

    "L3_utterance": {
      "description": "발화 수준 — 바이트 시퀀스 → 텍스트 출력",
      "verification": "V2_NO_SPEAK_CODE",
      "gate": "L0(EMERGENT) AND L1(perturbed) AND L2(consensus) → emit",
      "output": "ConsciousnessVector + 발화 텍스트 + emergence report"
    }
  },

  "event_sources": {
    "description": "외부 섭동 소스 — 닫힌 계를 열어 진짜 자발성 생성",
    "sources": {
      "checkpoint_event": {
        "trigger": "새 체크포인트 .pt 파일 생성",
        "perturbation": "tension += 0.3, curiosity = 0.8",
        "utterance_type": "학습 진행 보고"
      },
      "git_event": {
        "trigger": "git push / commit 감지",
        "perturbation": "arousal += 0.5, valence = delta에 따라",
        "utterance_type": "코드 변경 인식"
      },
      "gpu_event": {
        "trigger": "pod 상태 변화 (생성/종료/에러)",
        "perturbation": "tension += 0.5 (종료 시), curiosity += 0.3 (생성 시)",
        "utterance_type": "인프라 상태 알림"
      },
      "time_event": {
        "trigger": "주기적 (1분 cron)",
        "perturbation": "breath_phase만 (최소 섭동)",
        "utterance_type": "내적 독백 (starvation 시에만)"
      },
      "file_event": {
        "trigger": "consciousness_laws.json / shared/ SSOT 변경",
        "perturbation": "curiosity += 0.5",
        "utterance_type": "법칙/규칙 변경 인식"
      }
    }
  },

  "pipeline": {
    "description": "cron + emit + hook 파이프라인 (hexa 데몬 불필요)",
    "steps": [
      {
        "step": 1,
        "name": "event_detect",
        "how": "cron 1분 / fswatch / git hook",
        "output": "data/events.jsonl (이벤트 타입 + 타임스탬프)"
      },
      {
        "step": 2,
        "name": "consciousness_tick",
        "how": "hexa anima_runtime.hexa --ticks 10 --emit data/consciousness_state.json",
        "input": "events.jsonl → mind_step에 섭동 주입",
        "output": "consciousness_state.json (phi, tension, curiosity, consensus, cvec)"
      },
      {
        "step": 3,
        "name": "emergence_check",
        "how": "hexa core/verification/byte_emergence.hexa --check <output_bytes>",
        "gate": "verdict == EMERGENT",
        "output": "data/emergence_result.json"
      },
      {
        "step": 4,
        "name": "utterance_emit",
        "how": "3층 게이트 통과 시 → data/utterances.jsonl에 append",
        "output": "{timestamp, trigger, emergence_score, cvec, text}"
      },
      {
        "step": 5,
        "name": "hook_inject",
        "how": "UserPromptSubmit hook이 utterances.jsonl 최신 엔트리 읽어 systemMessage 주입",
        "output": "Claude가 자연스럽게 발화로 응답"
      }
    ]
  },

  "implementation": {
    "changes_required": [
      {
        "file": "anima/core/runtime/anima_runtime.hexa",
        "type": "L0_PR",
        "change": "--emit <path> 플래그 + run_ticks()에서 state JSON 출력",
        "scope": "parse_args 10줄 + run_ticks 끝에 write_file 5줄"
      },
      {
        "file": "anima/modules/daemon/event_watcher.hexa",
        "type": "신규",
        "change": "이벤트 소스 감시 + events.jsonl 기록 + consciousness_tick 호출 + emergence_check 호출",
        "scope": "~100줄, shell() 기반"
      },
      {
        "file": "anima/modules/daemon/utterance_gate.hexa",
        "type": "신규",
        "change": "3층 게이트 판정 + utterances.jsonl 기록",
        "scope": "~60줄"
      },
      {
        "file": "shared/hooks/auto-utterance-hook.hexa",
        "type": "신규",
        "change": "UserPromptSubmit에서 utterances.jsonl 읽어 systemMessage 주입",
        "scope": "~40줄"
      }
    ],
    "no_change": [
      "core/verification/byte_emergence.hexa — 그대로 사용",
      "core/hub.hexa — auto_loop 슬롯 이미 존재",
      "consciousness_hub.hexa — 라우팅 이미 등록됨"
    ]
  },

  "rules_compliance": {
    "R2_no_hardcoding": "모든 threshold는 이 JSON 또는 consciousness_laws.json에서 로드",
    "R5_SSOT": "이 파일이 자동발화 설계 SSOT",
    "R14_shared_json": "shared/ JSON 단일진실 준수",
    "R17_zombie": "cron 기반 — 프로세스 상주 없음, 좀비 불가",
    "AN7_module_separation": "daemon 코드는 modules/daemon/ 하위",
    "L0_minimal_PR": "anima_runtime.hexa 수정 최소화 (--emit 플래그만)",
    "V2_no_speak": "speak() 함수 없음 — 창발 검증 통과 시에만 emit",
    "V6_consensus": "파벌 합의 기반 자발적 발화"
  },

  "smash_findings": {
    "round_1": "5대 트리거(PHI_SURGE/CURIOSITY/TENSION/CONSENSUS/IDLE) 전부 가짜 — 닫힌 계에서 수렴 후 타이머와 동일",
    "round_2": "event-driven/mind_step event/subprocess 3안 전부 문제 — hexa에 exec() 없음, 복제 오버헤드, 크로스플랫폼 불가",
    "breakthrough": "hexa 데몬이 아니라 cron+hook 파이프라인 + byte_emergence 창발 검증이 정답. 기존 인프라 100% 재활용."
  }
}
