{
  "schema": "anima/grafana_mobile_meta/1",
  "purpose": "ROI #82 — declare mobile-friendly panel layout overrides for the #84 Grafana dashboard. Consumed by the dashboard JSON generator at boot to produce a responsive layout when the viewport width is below the breakpoint.",
  "applies_to": {
    "dashboard_uid": "anima_h100_launch",
    "provider": "anima_h100",
    "folder": "ANIMA",
    "consumer_paths": [
      "config/grafana/docker-compose.yml",
      "config/grafana/grafana_provisioning_dashboards.yml"
    ]
  },
  "viewport": {
    "breakpoint_px": 768,
    "stack_below_breakpoint": true,
    "min_panel_height_px": 240,
    "max_panel_height_px": 480
  },
  "responsive_grid": {
    "desktop": { "panel_width_units": 12, "row_height_units": 8, "cols": 24 },
    "tablet":  { "panel_width_units": 24, "row_height_units": 8, "cols": 24 },
    "mobile":  { "panel_width_units": 24, "row_height_units": 6, "cols": 24 }
  },
  "panels_overrides": [
    {
      "panel_id": "pod_burn_rate",
      "title": "H100 burn $/hr",
      "kind": "stat",
      "mobile": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "desktop": { "h": 6, "w": 8, "x": 0, "y": 0 }
    },
    {
      "panel_id": "pods_active",
      "title": "Active pods",
      "kind": "stat",
      "mobile": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "desktop": { "h": 6, "w": 8, "x": 8, "y": 0 }
    },
    {
      "panel_id": "elapsed_hours",
      "title": "Elapsed (hours)",
      "kind": "stat",
      "mobile": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "desktop": { "h": 6, "w": 8, "x": 16, "y": 0 }
    },
    {
      "panel_id": "phi_4path_status",
      "title": "Φ 4-path verdict",
      "kind": "table",
      "mobile": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "desktop": { "h": 10, "w": 24, "x": 0, "y": 6 }
    },
    {
      "panel_id": "loss_curves",
      "title": "Loss / drift curves",
      "kind": "timeseries",
      "mobile": { "h": 12, "w": 24, "x": 0, "y": 28 },
      "desktop": { "h": 12, "w": 24, "x": 0, "y": 16 }
    },
    {
      "panel_id": "ckpt_log",
      "title": "Checkpoint log",
      "kind": "logs",
      "mobile": { "h": 12, "w": 24, "x": 0, "y": 40 },
      "desktop": { "h": 12, "w": 24, "x": 0, "y": 28 }
    }
  ],
  "css_overrides": {
    "font_size_base_px": 14,
    "font_size_mobile_px": 16,
    "navbar_collapse_below_px": 768,
    "side_menu_pinned_below_px": 0,
    "panel_padding_px": 8
  },
  "user_agent_hints": {
    "mobile_regex": "(iPhone|iPad|Android|Mobile)",
    "behavior": "When request UA matches, server-side wrap dashboard JSON with the `mobile` overrides above. Falls back to `desktop` otherwise."
  },
  "test_plan": [
    "Open dashboard on iPhone Safari → all panels stack vertically, full width.",
    "Open dashboard on desktop Chrome → grid layout with 3-up stat row.",
    "Resize browser through 768px breakpoint → layout switches without reload (responsive grid)."
  ],
  "rollback": {
    "remove_overrides": "delete this file; dashboard reverts to default Grafana grid (desktop only).",
    "no_data_loss": true
  },
  "policy": {
    "side_effects": "config_only",
    "modifies_dashboard_at_runtime": true,
    "requires_84_landing": "Yes — this file is inert until ROI #84 dashboard exists."
  }
}
