{
  "schema": "anima.sbom_generate_config.v1",
  "tool": "tool/sbom_generate.hexa",
  "purpose": "CycloneDX 1.5 SBOM generation for hexa-lang + tool/*.hexa + config/*.json",
  "repo_root": "/Users/ghost/core/anima",
  "format": "CycloneDX",
  "spec_version": "1.5",
  "serial_number_prefix": "urn:uuid:anima-sbom",
  "metadata": {
    "component_name": "anima",
    "component_version": "0.1.0",
    "supplier": "Anima Project",
    "vendor": "Anima Project"
  },
  "core_components": [
    {
      "name": "hexa-lang",
      "version": "0.1.0",
      "type": "framework",
      "purl": "pkg:generic/hexa-lang@0.1.0",
      "license": "Apache-2.0",
      "description": "Hexa language runtime (anima primary impl language)",
      "source": "/Users/ghost/.hx/bin/hexa"
    }
  ],
  "scan_groups": [
    {
      "id": "tool_hexa",
      "type": "application",
      "root": "tool",
      "extension": ".hexa",
      "license_default": "Apache-2.0",
      "description": "Anima hexa tool"
    },
    {
      "id": "config_json",
      "type": "data",
      "root": "config",
      "extension": ".json",
      "license_default": "Apache-2.0",
      "description": "Anima config SSOT"
    }
  ],
  "license_overrides": {
    "tool/_airgenome_probe_selftest.hexa": "Apache-2.0"
  },
  "output": {
    "sbom_path": "state/sbom_cyclonedx.json",
    "summary_path": "state/sbom_summary.json"
  },
  "version_strategy": {
    "primary": "git_short_sha",
    "fallback": "0.1.0-static"
  }
}
