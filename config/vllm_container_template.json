{
  "schema_version": "1",
  "roi_item": "S1",
  "track": "pre-H100 ROI",
  "description": "vLLM 컨테이너 템플릿 — H100 × 4 pod 즉시 부팅용 spec. R2에서 weight를 stream 로딩하는 mock 검증 경로 포함.",
  "doc_ref": [
    "https://docs.vllm.ai/en/latest/serving/deploying_with_docker.html",
    "https://developers.cloudflare.com/r2/api/s3/api/"
  ],
  "container": {
    "image": "vllm/vllm-openai:v0.6.4",
    "image_digest_pin": "sha256:__TBD__",
    "fallback_image": "vllm/vllm-openai:v0.6.3",
    "platform": "linux/amd64",
    "shm_size": "32g",
    "ipc_mode": "host",
    "gpu": {
      "runtime": "nvidia",
      "count": 4,
      "expected_model": "H100-80GB-SXM5",
      "min_compute_capability": "9.0"
    }
  },
  "model_load": {
    "source": "r2",
    "bucket": "anima-models",
    "weight_prefix": "alm14b/h100_release/",
    "tokenizer_prefix": "alm14b/h100_release/tokenizer/",
    "stream_mode": "fsspec_s3",
    "expected_weight_files": [
      "model-00001-of-00006.safetensors",
      "model-00002-of-00006.safetensors",
      "model-00003-of-00006.safetensors",
      "model-00004-of-00006.safetensors",
      "model-00005-of-00006.safetensors",
      "model-00006-of-00006.safetensors",
      "model.safetensors.index.json",
      "config.json"
    ],
    "tokenizer_files": ["tokenizer.json", "tokenizer_config.json", "special_tokens_map.json"],
    "sha256_manifest": "config/r2_tokenizer_sha256_manifest.json"
  },
  "vllm_args": {
    "tensor_parallel_size": 4,
    "pipeline_parallel_size": 1,
    "dtype": "bfloat16",
    "max_model_len": 8192,
    "block_size": 16,
    "gpu_memory_utilization": 0.90,
    "max_num_seqs": 256,
    "max_num_batched_tokens": 8192,
    "enable_prefix_caching": true,
    "trust_remote_code": false,
    "swap_space_gb": 4
  },
  "env": {
    "R2_ENDPOINT_URL": "${R2_ENDPOINT_URL}",
    "AWS_ACCESS_KEY_ID": "${R2_AWS_ACCESS_KEY_ID}",
    "AWS_SECRET_ACCESS_KEY": "${R2_AWS_SECRET_ACCESS_KEY}",
    "VLLM_LOGGING_LEVEL": "INFO",
    "HF_HUB_OFFLINE": "1",
    "VLLM_DISABLE_TELEMETRY": "1",
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
  },
  "ports": [
    { "container": 8000, "purpose": "OpenAI-compatible REST" },
    { "container": 8001, "purpose": "metrics (prometheus)" }
  ],
  "healthcheck": {
    "endpoint": "/health",
    "interval_s": 15,
    "timeout_s": 5,
    "retries": 4,
    "start_period_s": 180
  },
  "mock_verify": {
    "tool": "tool/vllm_r2_weight_load_test.hexa",
    "mode": "mock-only",
    "asserts": [
      "tensor_parallel_size == 4",
      "all expected_weight_files non-empty",
      "tokenizer sha256 matches manifest",
      "vllm_args.max_model_len <= 8192",
      "gpu.count == 4 && gpu.min_compute_capability == '9.0'"
    ]
  },
  "do_not": [
    "DO NOT actually spawn pod from this template in dry-run land",
    "DO NOT bake R2 credentials into image",
    "DO NOT enable trust_remote_code"
  ]
}
