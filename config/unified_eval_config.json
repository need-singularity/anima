{
  "schema": "anima.unified_eval_config.v1",
  "description": "Unified eval harness config — fans out cert tools in parallel and aggregates verdicts into a single proof-carrying cert. Roadmap cluster #33 #16.",
  "timeout_per_cert_s": 60,
  "parallel_max": 3,
  "certs": [
    {
      "slug": "hexad_closure",
      "path": "tool/hexad_closure_verifier.hexa",
      "args": [],
      "ssot": "state/hexad_closure_verdict.json",
      "verdict_rule": {"key": "closure_verdict", "pass_values": ["CLOSED"]},
      "accept_rc": [0]
    },
    {
      "slug": "an11_c_real_usable",
      "path": "tool/an11_c_verifier.hexa",
      "args": ["--dest", "alm", "--round", "r0", "--dry-run"],
      "ssot": "state/alm_r0_an11_c.json",
      "verdict_rule": {"key": "verdict", "pass_values": ["PASS", "OK", "VERIFIED"]},
      "accept_rc": [0, 1, 3]
    },
    {
      "slug": "true_closure",
      "path": "tool/true_closure_verifier.hexa",
      "args": ["--skip-run"],
      "ssot": "state/true_closure_cert.json",
      "verdict_rule": {"key": "failed", "pass_values": ["0"]},
      "accept_rc": [0, 1]
    }
  ]
}
