{
  "schema": "anima.tui.config.v1",
  "title": "anima TUI — OS-level live dashboard config (raw#15)",
  "refresh_sec_default": 2,
  "watch_poll_ms": 1000,
  "recent_commits_n": 5,
  "active_bg_pattern": "hexa.*\\.hexa",
  "sources_scan": [
    "state/phase_progression_cert.json",
    "state/roadmap_integrity_result.json",
    "state/true_closure_cert.json",
    "state/closure_debt_summary.json",
    "state/anima_main_result.json"
  ],
  "colors": {
    "reset":   "\u001B[0m",
    "dim":     "\u001B[2m",
    "bold":    "\u001B[1m",
    "green":   "\u001B[32m",
    "yellow":  "\u001B[33m",
    "red":     "\u001B[31m",
    "blue":    "\u001B[34m",
    "cyan":    "\u001B[36m",
    "magenta": "\u001B[35m",
    "gray":    "\u001B[90m"
  },
  "glyphs": {
    "pass": "✓",
    "warn": "⚠",
    "fail": "✗",
    "run":  "▸",
    "idle": "·"
  }
}
