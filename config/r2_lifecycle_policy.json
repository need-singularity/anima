{
  "schema_version": "1",
  "roi_item": "G37",
  "description": "Cloudflare R2 lifecycle policy — auto-archive ckpt artefacts older than 30d to a cheaper tier, expire incomplete multipart uploads, and clean intermediate scratch.",
  "doc_ref": "https://developers.cloudflare.com/r2/buckets/object-lifecycles/",
  "buckets": ["anima-ckpt", "anima-archive"],
  "Rules": [
    {
      "ID": "ckpt-archive-30d",
      "Status": "Enabled",
      "Filter": { "Prefix": "checkpoints/" },
      "Transitions": [
        {
          "Days": 30,
          "StorageClass": "InfrequentAccess",
          "_note": "R2 IA tier — ~50% cost reduction; first byte same latency, retrieval $/GB applies."
        }
      ]
    },
    {
      "ID": "lora-archive-30d",
      "Status": "Enabled",
      "Filter": { "Prefix": "lora/" },
      "Transitions": [
        { "Days": 30, "StorageClass": "InfrequentAccess" }
      ]
    },
    {
      "ID": "abort-incomplete-multipart-7d",
      "Status": "Enabled",
      "Filter": { "Prefix": "" },
      "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 7 }
    },
    {
      "ID": "scratch-expire-14d",
      "Status": "Enabled",
      "Filter": { "Prefix": "scratch/" },
      "Expiration": { "Days": 14 }
    },
    {
      "ID": "logs-archive-30d-expire-365d",
      "Status": "Enabled",
      "Filter": { "Prefix": "logs/" },
      "Transitions": [
        { "Days": 30, "StorageClass": "InfrequentAccess" }
      ],
      "Expiration": { "Days": 365 }
    }
  ],
  "estimated_savings": {
    "assumed_archive_fraction": 0.6,
    "assumed_ia_discount": 0.5,
    "monthly_pct_reduction": 30,
    "applies_to": ["anima-ckpt", "anima-archive"]
  }
}
