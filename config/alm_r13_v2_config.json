    "cpgd_active_fold": {
      "enabled_default": true,
      "wrapper_path": "edu/lora/cpgd_wrapper.hexa",
      "kickoff_flag": "--cpgd-active",
      "env_var": "ANIMA_CPGD_ACTIVE",
      "fallback_behavior": "cpgd_wrapper present but passive fold (current default)",
      "spec_doc": "state/training_knob_cpgd_active.json",
      "roi_item": "B11",
      "roadmap_dependencies": [26, 29]
    },
    "dropout_kl_reg": {
      "enabled_default": false,
      "dropout": 0.05,
      "kl_reg_weight": 0.01,
      "env_var": "ANIMA_DROPOUT_KL_REG",
      "fallback_behavior": "dropout=0, kl_reg=0 (current default)",
      "spec_doc": "state/training_knob_dropout_kl.json",
      "roi_item": "B12",
      "rationale": "overfit prevention, val loss stability at validated default"
    }
  },

