      "tier_bands": "30/50/70",
      "env_var": "ANIMA_CURRICULUM_TIER_ENFORCE",
      "fallback_behavior": "tool runs but reward multipliers ignored if env var unset",
      "spec_doc": "state/training_knob_curriculum_tier.json",
      "roi_item": "B10",
      "roadmap_dependency": 68
