{
  "schema": "anima.sli_slo.v1",
  "slug": "sli-slo",
  "roi_item": 49,
  "description": "SSOT for anima serving SLI definitions and SLO error budgets. Consumed by tool/error_budget_check.hexa and downstream Grafana dashboards. Window unit is rolling 30-day; budget arithmetic is documented per indicator.",
  "service": "anima.serving",
  "window_days": 30,
  "indicators": [
    {
      "id": "request_success_rate",
      "label": "Request success rate (HTTP 2xx + 3xx) / total",
      "unit": "ratio",
      "objective_min": 0.99,
      "input_field": "success",
      "input_field_type": "bool",
      "budget": {
        "kind": "ratio",
        "formula": "1 - objective_min",
        "interpretation": "Maximum allowed failure ratio across the window."
      }
    },
    {
      "id": "request_latency_p95_ms",
      "label": "Request latency P95",
      "unit": "ms",
      "objective_max": 500,
      "input_field": "latency_ms",
      "input_field_type": "int",
      "budget": {
        "kind": "ratio",
        "formula": "fraction of requests with latency_ms <= objective_max must be >= 0.95",
        "interpretation": "Burn-rate triggered when fewer than 95% of requests are <= 500ms."
      }
    },
    {
      "id": "cert_gate_pass_rate",
      "label": "cert_gate pass rate",
      "unit": "ratio",
      "objective_min": 0.999,
      "input_field": "cert_pass",
      "input_field_type": "bool",
      "budget": {
        "kind": "ratio",
        "formula": "1 - objective_min",
        "interpretation": "<=0.1% of requests may fail cert gate."
      }
    },
    {
      "id": "an11_a_pass_rate",
      "label": "AN11(a) inline gate pass rate",
      "unit": "ratio",
      "objective_min": 0.995,
      "input_field": "an11_a",
      "input_field_type": "bool",
      "budget": {
        "kind": "ratio",
        "formula": "1 - objective_min",
        "interpretation": "<=0.5% of requests may fail AN11(a)."
      }
    }
  ],
  "burn_rate_alerts": [
    {"name": "fast_burn",  "lookback_minutes": 60,    "threshold_x": 14.4, "severity": "page"},
    {"name": "slow_burn",  "lookback_minutes": 360,   "threshold_x": 6.0,  "severity": "ticket"},
    {"name": "trend_burn", "lookback_minutes": 4320,  "threshold_x": 1.0,  "severity": "review"}
  ],
  "samples_input_default": "state/serve_alm_persona_log.jsonl",
  "status_output_default": "state/error_budget_status.json",
  "raw_alignment": {
    "raw_9":  "hexa-only consumer (tool/error_budget_check.hexa)",
    "raw_10": "deterministic — formulas pure functions of samples",
    "raw_11": "snake_case",
    "raw_15": "no-hardcode in consumer; this file is the SSOT"
  }
}
