// experiment.hexa — EEG experiment protocol: automated paradigm runner with markers
// Protocols: resting, alpha, meditation, anima (not in closed_loop)

struct ExperimentConfig {
    protocol: string,
    duration_sec: i32,
    board_type: string,
    markers: bool
}

struct ExperimentResult {
    protocol: string,
    n_markers: i32,
    mean_alpha: float,
    mean_phi: float,
    filepath: string
}

fn run_experiment(config: ExperimentConfig) -> ExperimentResult {
    print("EEG experiment: " + config.protocol)
    return ExperimentResult(config.protocol, 0, 0.0, 0.0, "")
}

fn run_resting(duration: i32) -> ExperimentResult {
    return run_experiment(ExperimentConfig("resting", duration, "synthetic", true))
}

fn run_alpha_entrainment(duration: i32) -> ExperimentResult {
    return run_experiment(ExperimentConfig("alpha", duration, "synthetic", true))
}
