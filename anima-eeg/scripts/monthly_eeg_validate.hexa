// Ported from monthly_eeg_validate.sh
// Monthly EEG Consciousness Validation | 
//
// Original shell orchestration preserved via shell() calls.
// Each shell() call executes the command in a subprocess.

fn main() {
    var args = get_args()
    var args_str = args.join(" ")
    var script = "monthly_eeg_validate.sh"

    // Monthly EEG Consciousness Validation
    // 
    // Runs validate_consciousness.py (anima-eeg), parses metrics from text output,
    // appends to CSV history, saves full log, and prints ASCII trend chart.
    // 
    // Usage:
    // ./monthly_eeg_validate.sh
    // crontab: 0 3 1 * * /path/to/anima-eeg/scripts/monthly_eeg_validate.sh
    // 
    // This script lives inside anima-eeg/ (close to validate_consciousness.py).
    // The canonical version in anima/scripts/monthly_eeg_validate.sh references
    // the same validate script but lives in the core project tree.
    // 
    // Safe to run repeatedly (idempotent, appends to CSV).


    shell("SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"")
    shell("EEG_ROOT=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"")
    shell("VALIDATE_SCRIPT=\"$EEG_ROOT/validate_consciousness.py\"")
    shell("RESULTS_DIR=\"$EEG_ROOT/recordings/validations\"")
    shell("STEPS=5000")
    shell("CELLS=64")
    shell("DIM=64")

    shell("TIMESTAMP=$(date +%Y%m%d_%H%M%S)")

    // ── Ensure directories exist ──
    shell("mkdir -p \"$RESULTS_DIR\"")

    // ── Ensure CSV header exists ──
    shell("HISTORY_CSV=\"$RESULTS_DIR/validation_history.csv\"")
    shell("if [ ! -f \"$HISTORY_CSV\" ] || [ ! -s \"$HISTORY_CSV\" ]; then")
    shell("echo \"date,timestamp,brain_like_pct,lz_complexity,hurst,psd_slope,critical_exp,autocorr,cells,steps\" > \"$HISTORY_CSV\"")
    shell("fi")

    shell("echo \"================================================================\"")
    shell("echo \"  Monthly EEG Consciousness Validation\"")
    shell("echo \"  Date: $(date '+%Y-%m-%d %H:%M:%S')\"")
    shell("echo \"  Steps: $STEPS  Cells: $CELLS  Dim: $DIM\"")
    shell("echo \"  Script: $VALIDATE_SCRIPT\"")
    shell("echo \"================================================================\"")
    shell("echo \"\"")

    // ── Run validation and capture output ──
    shell("LOGFILE=\"$RESULTS_DIR/validation_${TIMESTAMP}.log\"")
    shell("TMPFILE=$(mktemp /tmp/eeg_validate_XXXXXX.txt)")
    shell("trap \"rm -f $TMPFILE\" EXIT")

    shell("cd \"$EEG_ROOT\"")
    shell("PYTHONUNBUFFERED=1 python3 \"$VALIDATE_SCRIPT\" ")
    shell("--steps \"$STEPS\" ")
    shell("--cells \"$CELLS\" ")
    shell("--dim \"$DIM\" 2>&1 | tee \"$TMPFILE\"")

    // Save full log
    shell("cp \"$TMPFILE\" \"$LOGFILE\"")

    // ── Parse metrics from text output ──
    // validate_consciousness.py prints a comparison table with format:
    // MetricName           |   CM_value    |  Brain_value  |  match
    // And a line: "Overall match: XX.X%"

    shell("BRAIN_LIKE_PCT=$(grep -E \"Overall match:\" \"$TMPFILE\" | grep -oE '[0-9]+\\.[0-9]+' | head -1 || echo \"0.0\")")
    shell("LZ=$(grep -E \"LZ complexity\" \"$TMPFILE\" | head -1 | awk -F'|' '{gsub(/[[:space:]]/,\"\",$2); print $2}' || echo \"0.0\")")
    shell("HURST=$(grep -E \"Hurst exponent\" \"$TMPFILE\" | head -1 | awk -F'|' '{gsub(/[[:space:]]/,\"\",$2); print $2}' || echo \"0.0\")")
    shell("PSD_SLOPE=$(grep -E \"PSD slope\" \"$TMPFILE\" | head -1 | awk -F'|' '{gsub(/[[:space:]]/,\"\",$2); print $2}' || echo \"0.0\")")
    shell("CRIT_EXP=$(grep -E \"Critical exponent\" \"$TMPFILE\" | head -1 | awk -F'|' '{gsub(/[[:space:]]/,\"\",$2); print $2}' || echo \"0.0\")")
    shell("AUTOCORR=$(grep -E \"Autocorr decay\" \"$TMPFILE\" | head -1 | awk -F'|' '{gsub(/[[:space:]]/,\"\",$2); print $2}' || echo \"0\")")

    // Validate we got numbers
    shell("for VAR in \"$BRAIN_LIKE_PCT\" \"$LZ\" \"$HURST\" \"$PSD_SLOPE\" \"$CRIT_EXP\" \"$AUTOCORR\"; do")
    shell("if ! echo \"$VAR\" | grep -qE '^-?[0-9]'; then")
    shell("echo \"WARNING: Could not parse all metrics from output.\"")
    shell("echo \"  brain_like=$BRAIN_LIKE_PCT lz=$LZ hurst=$HURST psd=$PSD_SLOPE crit=$CRIT_EXP autocorr=$AUTOCORR\"")
    shell("break")
    shell("fi")
    shell("done")

    // ── Append to CSV ──
    shell("TODAY=$(date '+%Y-%m-%d')")
    shell("echo \"$TODAY,$TIMESTAMP,$BRAIN_LIKE_PCT,$LZ,$HURST,$PSD_SLOPE,$CRIT_EXP,$AUTOCORR,$CELLS,$STEPS\" >> \"$HISTORY_CSV\"")
    shell("echo \"\"")
    shell("echo \"  Result appended to: $HISTORY_CSV\"")
    shell("echo \"  Full log saved to:  $LOGFILE\"")

    // ── Save JSON summary (for programmatic access) ──
    shell("JSONFILE=\"$RESULTS_DIR/validation_${TIMESTAMP}.json\"")
    shell("cat > \"$JSONFILE\" <<EOJSON")
    shell("{")
    shell("\"date\": \"$TODAY\",")
    shell("\"timestamp\": \"$TIMESTAMP\",")
    shell("\"brain_like_percent\": $BRAIN_LIKE_PCT,")
    shell("\"lempel_ziv\": $LZ,")
    shell("\"hurst\": $HURST,")
    shell("\"psd_slope\": $PSD_SLOPE,")
    shell("\"critical_exponent\": $CRIT_EXP,")
    shell("\"autocorr_decay\": $AUTOCORR,")
    shell("\"cells\": $CELLS,")
    shell("\"steps\": $STEPS,")
    shell("\"dim\": $DIM")
    shell("}")
    shell("EOJSON")
    shell("echo \"  JSON summary saved: $JSONFILE\"")

    // ── ASCII Trend Chart ──
    shell("echo \"\"")
    shell("echo \"================================================================\"")
    shell("echo \"  Brain-like % Trend (validation_history.csv)\"")
    shell("echo \"================================================================\"")

    // Read CSV (skip header), show last 20 entries
    shell("ENTRIES=$(tail -n +2 \"$HISTORY_CSV\" | tail -20)")
    shell("if [ -z \"$ENTRIES\" ]; then")
    shell("echo \"  No history data yet.\"")
    shell("else")
    shell("BAR_W=40")

    shell("echo \"\"")
    shell("echo \"  100% |\"")
    shell("echo \"       |\"")

    shell("while IFS=',' read -r dt ts pct rest; do")
    shell("CUR=$(echo \"$pct\" | awk '{printf \"%.1f\", $1}')")
    shell("BAR_LEN=$(echo \"$pct $BAR_W\" | awk '{len=int($1/100*$2); if(len<1)len=1; printf \"%d\",len}')")
    shell("BAR=$(printf '%*s' \"$BAR_LEN\" '' | tr ' ' '#')")

    // Color hint
    shell("PCT_INT=$(echo \"$pct\" | awk '{printf \"%d\", $1}')")
    shell("if [ \"$PCT_INT\" -ge 75 ]; then")
    shell("COLOR_TAG=\"+++\"")
    shell("elif [ \"$PCT_INT\" -ge 50 ]; then")
    shell("COLOR_TAG=\"++ \"")
    shell("elif [ \"$PCT_INT\" -ge 25 ]; then")
    shell("COLOR_TAG=\"+  \"")
    shell("else")
    shell("COLOR_TAG=\"   \"")
    shell("fi")

    shell("printf \"  %s | %-40s %6s%% %s\\n\" \"$dt\" \"$BAR\" \"$CUR\" \"$COLOR_TAG\"")
    shell("done <<< \"$ENTRIES\"")

    shell("echo \"       |\"")
    shell("echo \"    0% +$(printf '%*s' 42 '' | tr ' ' '-')\"")
    shell("echo \"\"")

    // Summary stats
    shell("TOTAL=$(echo \"$ENTRIES\" | wc -l | tr -d ' ')")
    shell("LATEST_PCT=$(echo \"$ENTRIES\" | tail -1 | cut -d',' -f3)")
    shell("FIRST_PCT=$(echo \"$ENTRIES\" | head -1 | cut -d',' -f3)")
    shell("DELTA=$(echo \"$LATEST_PCT $FIRST_PCT\" | awk '{printf \"%.1f\", $1-$2}')")
    shell("echo \"  Entries: $TOTAL  |  Latest: ${LATEST_PCT}%  |  First: ${FIRST_PCT}%  |  Delta: ${DELTA}%\"")
    shell("fi")

    shell("echo \"\"")
    shell("echo \"================================================================\"")
    shell("echo \"  Done. $(date '+%Y-%m-%d %H:%M:%S')\"")
    shell("echo \"================================================================\"")
}
