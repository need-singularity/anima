// ═══════════════════════════════════════════════════════════
// CLI
// ═══════════════════════════════════════════════════════════

fn main() {
    // TODO[hexa-stdlib]: argparse for --dry-run, --query, --stats, --reindex
    // Default: organize flat files
    // Ensure base directories exist: sessions/, validations/, protocols/nback/, protocols/meditation/
    let db_ok = init_db(INDEX_DB_NAME)
    if !db_ok {
        print("ERROR: Failed to initialize database")
        return
    }

    // Default mode: scan and organize flat files
    print("Scanning for flat files in recordings/...")
    let flat = scan_flat_files(RECORDINGS_SUBDIR)
    if flat == "[]" {
        print("No flat files found to organize.")
        print("Use --reindex to rebuild the SQLite index from existing directories.")
        print("Use --stats to see current index statistics.")
        print("Use --query 'protocol=nback' to search the index.")
    }
}
