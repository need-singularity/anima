// collect.hexa — EEG data collection: OpenBCI Cyton+Daisy 16-ch via BrainFlow
// Usage: collect(duration_sec, tag) or collect(duration, tag, board_type)

struct CollectConfig {
    duration_sec: i32,
    tag: string,
    board_type: string,
    protocol: string
}

struct CollectResult {
    filepath: string,
    n_samples: i32,
    n_channels: i32,
    duration_actual: float
}

fn collect(duration: i32, tag: string) -> CollectResult {
    print("collecting EEG: " + tag + " for " + to_string(duration) + "s")
    return CollectResult("", 0, 0, 0.0)
}

fn list_boards() {
    print("supported boards: cyton, cyton_daisy, ganglion, synthetic")
}
