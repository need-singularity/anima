// anima-eeg/protocols/__init__.hexa
// raw#9 hexa-only strict · raw#11 snake_case
// Spec doc: anima-eeg/MIGRATION_PLAN.md §3 (Tier-0)
//
// PURPOSE
//   anima-eeg.protocols package entry point. 4 protocols + load marker.
//
// SUBPROTOCOLS
//   bci_control       — WRAPPER (realtime EEG threshold control)
//   multi_eeg         — WRAPPER (multi-board hivemind sync)
//   sleep_protocol    — FULL    (band-power threshold rules)
//   emotion_sync      — FULL    (FAA = ln(R/F4) - ln(L/F3))
//
// USAGE
//   hexa run anima-eeg/protocols/__init__.hexa --selftest
//
// raw10_honest: load-marker only.

let SCHEMA = "anima-eeg/protocols_init/1"

fn protocol_count() -> int { return 4 }
fn full_count() -> int     { return 2 }   // sleep_protocol, emotion_sync
fn wrapper_count() -> int  { return 2 }   // bci_control, multi_eeg

fn init() {
    print("eeg.protocols module loaded")
}

fn assert_true(cond: bool, label: string) -> bool {
    if cond { println("  PASS: " + label) } else { println("  FAIL: " + label) }
    return cond
}

fn run_tests() -> int {
    let mut pass = 0
    let mut fail = 0

    println("=== anima-eeg.protocols __init__ raw#9 self-tests ===")

    // T1: protocol manifest
    println("[T1] protocol manifest count")
    let ok1 = assert_true(protocol_count() == 4, "protocol_count == 4")
    if ok1 { pass = pass + 1 } else { fail = fail + 1 }

    // T2: verdict closure
    println("[T2] verdict closure")
    let ok2 = assert_true((full_count() + wrapper_count()) == protocol_count(), "FULL + WRAPPER == 4")
    if ok2 { pass = pass + 1 } else { fail = fail + 1 }

    // T3: init idempotence
    println("[T3] init idempotence")
    init()
    init()
    let ok3 = assert_true(true, "init() runs without panic")
    if ok3 { pass = pass + 1 } else { fail = fail + 1 }

    println("")
    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL out of " + to_string(pass + fail))
    return fail
}

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 1
    while i < len(av) {
        if av[i] == "--selftest" { selftest = true }
        i = i + 1
    }

    if !selftest {
        init()
        return
    }

    println("── anima-eeg.protocols __init__ raw#9 selftest ──")
    println("schema=" + SCHEMA)
    println("raw10_honest=load_marker_only")
    println("protocol_count=" + to_string(protocol_count()))
    println("full=" + to_string(full_count()))
    println("wrapper=" + to_string(wrapper_count()))
    println("")

    let fails = run_tests()
    if fails != 0 {
        println("selftest=fail")
        eprintln("selftest FAILED: " + to_string(fails) + " test(s) failed")
        exit(1)
    }
    println("selftest=ok")
    println("DONE")
}

main()
