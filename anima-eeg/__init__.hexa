// anima-eeg/__init__.hexa
// raw#9 hexa-only strict · raw#11 snake_case
// Spec doc: anima-eeg/MIGRATION_PLAN.md §3 (Tier-0)
//
// PURPOSE
//   anima-eeg package entry point. Lists submodules + emits load marker
//   in selftest mode. Pure declarative — no external deps, no RNG.
//
// SUBMODULES (21 .hexa files in anima-eeg/, 4 in anima-eeg/protocols/)
//   collect, analyze, realtime, calibrate, closed_loop, dual_stream,
//   eeg_recorder, experiment, neurofeedback, transplant_eeg_verify,
//   validate_consciousness, rp_adaptive_response, eeg
//   protocols: bci_control, multi_eeg, sleep_protocol, emotion_sync
//
// USAGE
//   hexa run anima-eeg/__init__.hexa --selftest
//   # Expected stdout: schema kv-line, submodule list, "selftest=ok", "DONE"
//
// raw10_honest: this is a load-marker only. Actual module bodies are
//               separate .hexa files. No re-export semantics in hexa-lang
//               0.2.0 — listing is documentary.

// ════════════════════════════════════════════════════════════════════
// Section 0. Submodule manifest (declarative)
// ════════════════════════════════════════════════════════════════════

let SCHEMA = "anima-eeg/init/1"

fn submodule_count() -> int {
    // 13 top-level + 4 protocols + 2 scripts = 19 candidates + 1 exemplar (rp_adaptive)
    return 20
}

fn full_verdict_count() -> int {
    // FULL: __init__, neurofeedback, protocols/__init__, analyze,
    //       validate_consciousness, transplant_eeg_verify,
    //       protocols/emotion_sync, protocols/sleep_protocol
    return 8
}

fn wrapper_verdict_count() -> int {
    // WRAPPER: calibrate, collect, eeg_recorder, experiment, realtime,
    //          closed_loop, dual_stream, protocols/multi_eeg,
    //          protocols/bci_control
    return 9
}

// ════════════════════════════════════════════════════════════════════
// Section 1. Load marker
// ════════════════════════════════════════════════════════════════════

fn init() {
    print("eeg module loaded")
}

// ════════════════════════════════════════════════════════════════════
// Section 2. Self-test
// ════════════════════════════════════════════════════════════════════

fn assert_true(cond: bool, label: string) -> bool {
    if cond { println("  PASS: " + label) } else { println("  FAIL: " + label) }
    return cond
}

fn run_tests() -> int {
    let mut pass = 0
    let mut fail = 0

    println("=== anima-eeg __init__ raw#9 self-tests ===")

    // T1: submodule count invariant
    println("[T1] submodule manifest")
    let n = submodule_count()
    let ok1 = assert_true(n == 20, "submodule_count == 20")
    if ok1 { pass = pass + 1 } else { fail = fail + 1 }

    // T2: verdict counts sum check
    println("[T2] verdict accounting")
    let f = full_verdict_count()
    let w = wrapper_verdict_count()
    let ok2a = assert_true(f == 8, "FULL verdicts == 8")
    let ok2b = assert_true(w == 9, "WRAPPER verdicts == 9")
    // f + w + 1 (rp_exempt) + 1 (EMIT-TMP) + 1 (WRAPPER_OR_HEXA_STDLIB) = 20
    let ok2c = assert_true((f + w + 1 + 1 + 1) == submodule_count(), "verdict sum closure")
    if ok2a && ok2b && ok2c { pass = pass + 1 } else { fail = fail + 1 }

    // T3: idempotence — re-running init() does not change global state
    println("[T3] init idempotence")
    init()
    init()
    let ok3 = assert_true(true, "init() runs without panic")
    if ok3 { pass = pass + 1 } else { fail = fail + 1 }

    println("")
    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL out of " + to_string(pass + fail))
    return fail
}

// ════════════════════════════════════════════════════════════════════
// Section 3. CLI entry point
// ════════════════════════════════════════════════════════════════════

fn main() {
    let av = argv()
    let mut selftest = false
    let mut i = 1
    while i < len(av) {
        if av[i] == "--selftest" { selftest = true }
        i = i + 1
    }

    if !selftest {
        // Default behavior: load marker (preserves prior public surface)
        init()
        return
    }

    println("── anima-eeg __init__ raw#9 selftest ──")
    println("schema=" + SCHEMA)
    println("raw10_honest=load_marker_only_no_actual_reexport")
    println("submodule_count=" + to_string(submodule_count()))
    println("full_verdict=" + to_string(full_verdict_count()))
    println("wrapper_verdict=" + to_string(wrapper_verdict_count()))
    println("")

    let fails = run_tests()
    if fails != 0 {
        println("selftest=fail")
        eprintln("selftest FAILED: " + to_string(fails) + " test(s) failed")
        exit(1)
    }
    println("selftest=ok")
    println("DONE")
}

main()
