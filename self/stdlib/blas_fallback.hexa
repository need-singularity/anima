// blas_fallback.hexa — Pure-hexa scalar BLAS fallbacks
//
// Purpose:
//   Portable, dependency-free implementations of every hxblas_* symbol used
//   by training/nn_core.hexa. Signatures match the real FFI block so
//   dispatch shims are a 1:1 swap. Floats are f32 stored in raw byte
//   buffers — read/written via deref_f32/write_f32. Slow but correct.
//
// When used:
//   If HX_BLAS != "1", nn_core.hexa routes every hxblas_* call through
//   dispatch_* shims that fall back to these fb_* functions. Lets code
//   that links libhxblas.dylib parse + run on any machine (macOS w/o
//   Accelerate, Linux w/o OpenBLAS, new dev laptops, CI, etc.).
//
// Not a BLAS:
//   No blocking, no vectorisation, no parallelism. Naïve triple-loop
//   sgemm. For correctness-smoke only. Real training must set HX_BLAS=1.
//
// All signatures mirror training/nn_core.hexa's @link extern fn block
// (raw ptrs as int, alpha/beta as float). Float dtype = f32 (4 bytes).

let FB_FLOAT_SIZE = 4

// ── sigmoid helper (no tensor dep) ─────────────────────────────────
fn fb_sigmoid(x: float) -> float {
    1.0 / (1.0 + exp(0.0 - x))
}

// ── fb_sgemm: C = alpha * A * B + beta * C (row-major, no trans) ───
// Matches hxblas_sgemm signature. order/transA/transB accepted for ABI
// parity; transposes dispatched via integer flag (111 = no, 112 = yes).
// lda/ldb/ldc are the leading dims in elements, not bytes.
fn fb_sgemm(order: int, transA: int, transB: int,
            M: int, N: int, K: int,
            alpha: float, A: int, lda: int,
            B: int, ldb: int,
            beta: float, C: int, ldc: int) {
    let ta = transA == 112
    let tb = transB == 112
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut p = 0
            while p < K {
                let a_off = if ta { (p * lda + i) * FB_FLOAT_SIZE } else { (i * lda + p) * FB_FLOAT_SIZE }
                let b_off = if tb { (j * ldb + p) * FB_FLOAT_SIZE } else { (p * ldb + j) * FB_FLOAT_SIZE }
                acc = acc + deref_f32(A, a_off) * deref_f32(B, b_off)
                p = p + 1
            }
            let c_off = (i * ldc + j) * FB_FLOAT_SIZE
            let prev = deref_f32(C, c_off)
            write_f32(C, c_off, alpha * acc + beta * prev)
            j = j + 1
        }
        i = i + 1
    }
}

// ── fb_saxpy: y[i*incy] += alpha * x[i*incx] ───────────────────────
fn fb_saxpy(N: int, alpha: float, x: int, incx: int, y: int, incy: int) {
    let mut i = 0
    while i < N {
        let x_off = i * incx * FB_FLOAT_SIZE
        let y_off = i * incy * FB_FLOAT_SIZE
        let prev = deref_f32(y, y_off)
        write_f32(y, y_off, prev + alpha * deref_f32(x, x_off))
        i = i + 1
    }
}

// ── fb_axpy_inplace: dst[i] += src[i] ──────────────────────────────
fn fb_axpy_inplace(N: int, dst: int, src: int) {
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        let prev = deref_f32(dst, off)
        write_f32(dst, off, prev + deref_f32(src, off))
        i = i + 1
    }
}

// ── fb_copy: dst[i] = src[i] ───────────────────────────────────────
fn fb_copy(N: int, dst: int, src: int) {
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        write_f32(dst, off, deref_f32(src, off))
        i = i + 1
    }
}

// ── fb_zero: dst[i] = 0 ────────────────────────────────────────────
fn fb_zero(N: int, dst: int) {
    let mut i = 0
    while i < N {
        write_f32(dst, i * FB_FLOAT_SIZE, 0.0)
        i = i + 1
    }
}

// ── fb_sgd_inplace: w[i] -= lr * g[i] ──────────────────────────────
fn fb_sgd_inplace(N: int, lr: float, w: int, g: int) {
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        let prev = deref_f32(w, off)
        write_f32(w, off, prev - lr * deref_f32(g, off))
        i = i + 1
    }
}

// ── fb_sscal: x[i] *= alpha ────────────────────────────────────────
fn fb_sscal(N: int, alpha: float, x: int) {
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        write_f32(x, off, alpha * deref_f32(x, off))
        i = i + 1
    }
}

// ── fb_sdot: Σ x[i]*y[i] ───────────────────────────────────────────
fn fb_sdot(N: int, x: int, y: int) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        s = s + deref_f32(x, off) * deref_f32(y, off)
        i = i + 1
    }
    s
}

// ── fb_snrm2: sqrt(Σ x[i]^2) ───────────────────────────────────────
fn fb_snrm2(N: int, x: int) -> float {
    let mut s = 0.0
    let mut i = 0
    while i < N {
        let v = deref_f32(x, i * FB_FLOAT_SIZE)
        s = s + v * v
        i = i + 1
    }
    sqrt(s)
}

// ── fb_silu_fwd: out[i] = x[i] * sigmoid(x[i]) ─────────────────────
fn fb_silu_fwd(N: int, out: int, x: int) {
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        let v = deref_f32(x, off)
        write_f32(out, off, v * fb_sigmoid(v))
        i = i + 1
    }
}

// ── fb_silu_bwd: dx[i] = dy[i] * (s + x[i]*s*(1-s)) ────────────────
fn fb_silu_bwd(N: int, dx: int, x: int, dy: int) {
    let mut i = 0
    while i < N {
        let off = i * FB_FLOAT_SIZE
        let xv = deref_f32(x, off)
        let s = fb_sigmoid(xv)
        let dyv = deref_f32(dy, off)
        write_f32(dx, off, dyv * (s + xv * s * (1.0 - s)))
        i = i + 1
    }
}

// ── fb_rmsnorm_fwd: row-wise y[i,p] = gain[p] * x[i,p]/sqrt(mean(x²)+eps)
fn fb_rmsnorm_fwd(S: int, D: int, eps: float, y: int, x: int, g: int) {
    let mut i = 0
    while i < S {
        let row = i * D * FB_FLOAT_SIZE
        let mut s = 0.0
        let mut p = 0
        while p < D {
            let v = deref_f32(x, row + p * FB_FLOAT_SIZE)
            s = s + v * v
            p = p + 1
        }
        let inv = 1.0 / sqrt(s / to_float(D) + eps)
        p = 0
        while p < D {
            let off = row + p * FB_FLOAT_SIZE
            let gv = deref_f32(g, p * FB_FLOAT_SIZE)
            write_f32(y, off, gv * deref_f32(x, off) * inv)
            p = p + 1
        }
        i = i + 1
    }
}

// ── fb_rmsnorm_bwd: chain rule, accumulates dg across rows ─────────
// dx[i,p] = gain[p]*inv*dy[i,p] - x[i,p]*inv³/D * Σ_q gain[q]*dy[i,q]*x[i,q]
// dg[p] += dy[i,p] * x[i,p] * inv  (summed over rows i)
fn fb_rmsnorm_bwd(S: int, D: int, eps: float, dx: int, dg: int, x: int, g: int, dy: int) {
    let Df = to_float(D)
    let mut i = 0
    while i < S {
        let row = i * D * FB_FLOAT_SIZE
        // Pass 1: mean square + dot(gain*dy, x)
        let mut ms = 0.0
        let mut dot = 0.0
        let mut p = 0
        while p < D {
            let xv = deref_f32(x, row + p * FB_FLOAT_SIZE)
            let gv = deref_f32(g, p * FB_FLOAT_SIZE)
            let dyv = deref_f32(dy, row + p * FB_FLOAT_SIZE)
            ms = ms + xv * xv
            dot = dot + gv * dyv * xv
            p = p + 1
        }
        let inv = 1.0 / sqrt(ms / Df + eps)
        let inv3_over_D = inv * inv * inv / Df
        p = 0
        while p < D {
            let off = row + p * FB_FLOAT_SIZE
            let xv = deref_f32(x, off)
            let gv = deref_f32(g, p * FB_FLOAT_SIZE)
            let dyv = deref_f32(dy, off)
            let dxv = gv * dyv * inv - xv * dot * inv3_over_D
            write_f32(dx, off, dxv)
            // Accumulate dg[p] += dy[i,p] * x[i,p] * inv
            let dg_off = p * FB_FLOAT_SIZE
            let prev = deref_f32(dg, dg_off)
            write_f32(dg, dg_off, prev + dyv * xv * inv)
            p = p + 1
        }
        i = i + 1
    }
}

// ── fb_attn_softmax_causal: in-place stable softmax + causal mask + scale
// scores is [S, S] row-major. For row i: mask j>i to -inf, scale, softmax.
fn fb_attn_softmax_causal(S: int, scale: float, scores: int) {
    let NEG_BIG = -1.0e30
    let mut i = 0
    while i < S {
        let row = i * S * FB_FLOAT_SIZE
        // Apply scale + mask
        let mut j = 0
        while j < S {
            let off = row + j * FB_FLOAT_SIZE
            if j > i {
                write_f32(scores, off, NEG_BIG)
            } else {
                write_f32(scores, off, deref_f32(scores, off) * scale)
            }
            j = j + 1
        }
        // Stable softmax on row [0..S)
        let mut mx = deref_f32(scores, row)
        j = 1
        while j < S {
            let v = deref_f32(scores, row + j * FB_FLOAT_SIZE)
            if v > mx { mx = v }
            j = j + 1
        }
        let mut sm = 0.0
        j = 0
        while j < S {
            let off = row + j * FB_FLOAT_SIZE
            let e = exp(deref_f32(scores, off) - mx)
            write_f32(scores, off, e)
            sm = sm + e
            j = j + 1
        }
        let inv = 1.0 / sm
        j = 0
        while j < S {
            let off = row + j * FB_FLOAT_SIZE
            write_f32(scores, off, deref_f32(scores, off) * inv)
            j = j + 1
        }
        i = i + 1
    }
}

// ── fb_attn_softmax_bwd: dscores = probs * (dprobs - Σ(probs*dprobs)) * scale
fn fb_attn_softmax_bwd(S: int, scale: float, dscores: int, probs: int, dprobs: int) {
    let mut i = 0
    while i < S {
        let row = i * S * FB_FLOAT_SIZE
        let mut dot = 0.0
        let mut j = 0
        while j < S {
            let off = row + j * FB_FLOAT_SIZE
            dot = dot + deref_f32(probs, off) * deref_f32(dprobs, off)
            j = j + 1
        }
        j = 0
        while j < S {
            let off = row + j * FB_FLOAT_SIZE
            let pv = deref_f32(probs, off)
            let dpv = deref_f32(dprobs, off)
            write_f32(dscores, off, pv * (dpv - dot) * scale)
            j = j + 1
        }
        i = i + 1
    }
}

// ── fb_cross_entropy: fused softmax + NLL + gradient; returns summed loss.
// targets is a raw int64 buffer of length S.
fn fb_cross_entropy(S: int, V: int, scale: float, logits: int, dlogits: int, targets: int) -> float {
    let mut total = 0.0
    let mut i = 0
    while i < S {
        let row = i * V * FB_FLOAT_SIZE
        // Find max for stability
        let mut mx = deref_f32(logits, row)
        let mut j = 1
        while j < V {
            let v = deref_f32(logits, row + j * FB_FLOAT_SIZE)
            if v > mx { mx = v }
            j = j + 1
        }
        // sum exp(x - max)
        let mut sm = 0.0
        j = 0
        while j < V {
            sm = sm + exp(deref_f32(logits, row + j * FB_FLOAT_SIZE) - mx)
            j = j + 1
        }
        let logsum = mx + log(sm)
        let tgt = deref_i64(targets, i * 8)
        let tgt_off = row + tgt * FB_FLOAT_SIZE
        total = total + (logsum - deref_f32(logits, tgt_off))
        // Gradient: (softmax - onehot) * scale
        let inv = 1.0 / sm
        j = 0
        while j < V {
            let off = row + j * FB_FLOAT_SIZE
            let p = exp(deref_f32(logits, off) - mx) * inv
            let sub = if j == tgt { 1.0 } else { 0.0 }
            write_f32(dlogits, off, (p - sub) * scale)
            j = j + 1
        }
        i = i + 1
    }
    total
}

// ── fb_embed_lookup: h[i,:] = embed[tokens[i],:] ───────────────────
fn fb_embed_lookup(S: int, D: int, h: int, embed_ptr: int, tokens: int) {
    let mut i = 0
    while i < S {
        let tid = deref_i64(tokens, i * 8)
        let src_row = tid * D * FB_FLOAT_SIZE
        let dst_row = i * D * FB_FLOAT_SIZE
        let mut p = 0
        while p < D {
            let off = p * FB_FLOAT_SIZE
            write_f32(h, dst_row + off, deref_f32(embed_ptr, src_row + off))
            p = p + 1
        }
        i = i + 1
    }
}

// ── fb_embed_scatter: dembed[tokens[i],:] += dh[i,:] ───────────────
fn fb_embed_scatter(S: int, D: int, dembed_ptr: int, dh: int, tokens: int) {
    let mut i = 0
    while i < S {
        let tid = deref_i64(tokens, i * 8)
        let dst_row = tid * D * FB_FLOAT_SIZE
        let src_row = i * D * FB_FLOAT_SIZE
        let mut p = 0
        while p < D {
            let off = p * FB_FLOAT_SIZE
            let prev = deref_f32(dembed_ptr, dst_row + off)
            write_f32(dembed_ptr, dst_row + off, prev + deref_f32(dh, src_row + off))
            p = p + 1
        }
        i = i + 1
    }
}

fn main() {
    println("blas_fallback.hexa — pure-hexa scalar BLAS fallbacks")
    println("12 fallback functions: sgemm, saxpy, axpy_inplace, copy, zero,")
    println("  sgd_inplace, sscal, sdot, snrm2, silu_fwd/bwd, rmsnorm_fwd/bwd,")
    println("  attn_softmax_causal/bwd, cross_entropy, embed_lookup/scatter")
    println("Correctness-only; gate via HX_BLAS=1 in training/nn_core.hexa")
}
