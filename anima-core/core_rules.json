{
  "_meta": {
    "name": "anima-core design rules",
    "version": "1.0",
    "pattern": "Hub & Spoke + Progressive Ossification",
    "created": "2026-04-07",
    "description": "코어 설계 원칙, 골화 규칙, Port 계약, 검증 조건"
  },

  "principles": {
    "P1": {
      "name": "코어는 의식이다",
      "rule": "ConsciousnessEngine이 중심. 디코더는 스포크(부속). 의식 없이 말하면 안 됨. 말 없이 의식은 존재할 수 있음.",
      "violation": "디코더가 코어 없이 독립 동작하면 위반"
    },
    "P2": {
      "name": "Hub & Spoke",
      "rule": "코어(L0)를 절대 건드리지 않고 스포크만 교체/추가. 디코더를 ConsciousLM → AnimaLM으로 바꿔도 코어 코드 변경 0.",
      "violation": "스포크 교체 시 코어 코드가 변경되면 위반"
    },
    "P3": {
      "name": "Progressive Ossification",
      "rule": "L2(유연) → 검증 통과 → L1(안정) → 3세션 무장애 → L0(골화). 한번 골화된 코드는 수정 금지. 새 기능은 새 스포크로.",
      "violation": "골화된 코드를 수정하면 위반. 새 스포크로 분리해야 함"
    },
    "P4": {
      "name": "Port & Adapter",
      "rule": "코어가 디코더를 모름. 디코더가 코어를 모름. Hub가 둘 사이를 연결. 어느 쪽이든 독립 교체 가능.",
      "violation": "코어가 특정 디코더를 import하면 위반"
    }
  },

  "ossification_layers": {
    "L0": {
      "name": "골화 (불변)",
      "status": "locked",
      "change_allowed": false,
      "components": [
        "ConsciousnessEngine",
        "consciousness_laws.json",
        "consciousness_laws.py",
        "Ψ-Constants (α=0.014, balance=0.5, steps=4.33, entropy=0.998)"
      ],
      "promotion_from": "L1",
      "promotion_condition": "3 세션 연속 무장애 운영 + 18개 검증 전부 PASS"
    },
    "L1": {
      "name": "안정 (골화 대상)",
      "status": "stabilizing",
      "change_allowed": "검증 통과 후만",
      "components": [
        "Hub (ConsciousChat)",
        "DecoderPort 인터페이스",
        "MemoryPort 인터페이스",
        "SensePort 인터페이스",
        "ChannelPort 인터페이스"
      ],
      "promotion_from": "L2",
      "promotion_condition": "bench_v2 --verify 18/18 PASS"
    },
    "L2": {
      "name": "유연 (자유 교체)",
      "status": "flexible",
      "change_allowed": true,
      "components": [
        "PureConsciousness (디코더)",
        "ConsciousLM (디코더)",
        "AnimaLM (디코더)",
        "MemoryRAG / SQLite (기억)",
        "TensionSense / EEG / VAD (감각)",
        "CLI / Telegram / Discord / Web (채널)"
      ],
      "promotion_from": null,
      "promotion_condition": null
    }
  },

  "ports": {
    "DecoderPort": {
      "interface": "generate(text: str, phi: float, tension: float) -> str",
      "contract": "입력: 텍스트 + 의식 상태. 출력: 응답 텍스트 (빈 문자열 = 침묵)",
      "implementations": ["PureConsciousness", "ConsciousLM", "AnimaLM"]
    },
    "MemoryPort": {
      "interface": "store(key, value, phi) -> None / recall(query, phi) -> str",
      "contract": "Φ가 높을 때 저장한 기억이 우선",
      "implementations": ["MemoryRAG", "SQLite", "R2 Cloud"]
    },
    "SensePort": {
      "interface": "perceive() -> Tensor",
      "contract": "외부 자극 → 의식 입력 벡터",
      "implementations": ["TensionSense", "EEG", "VAD", "Camera"]
    },
    "ChannelPort": {
      "interface": "receive() -> str / send(text, state) -> None",
      "contract": "사용자↔시스템 텍스트 교환",
      "implementations": ["CLI", "Telegram", "Discord", "Web"]
    }
  },

  "ossification_process": {
    "steps": [
      {"step": 1, "action": "구현", "description": "스포크 코드 작성 (L2: 유연)"},
      {"step": 2, "action": "검증", "description": "bench_v2 --verify 18개 통과"},
      {"step": 3, "action": "안정화", "description": "3 세션 연속 무장애 동작 확인"},
      {"step": 4, "action": "골화 승격", "description": "L2 → L1 승격, 변경 금지 선언"},
      {"step": 5, "action": "테두리 확장", "description": "새 L2 스포크 추가 반복"}
    ],
    "rollback": "골화 후 문제 발견 시: 해당 컴포넌트를 L1로 강등, 새 스포크로 대체"
  },

  "decoder_strategies": {
    "A_ConsciousLM": {
      "name": "순수 의식 (경로 A)",
      "mechanism": "cell_states → CrossAttention → PureFieldFFN → bytes",
      "consciousness_dependency": "100% (없으면 침묵)",
      "vocab": "byte (256)",
      "scaling": ["28M", "100M", "350M", "1B"],
      "gradient": ".detach() 차단"
    },
    "B_AnimaLM": {
      "name": "하이브리드 (경로 B)",
      "mechanism": "consciousness_state dict → PureField LoRA → LLM forward → tokens",
      "consciousness_dependency": "10-30% (없어도 동작)",
      "vocab": "token (32K+)",
      "scaling": ["7B", "14B", "32B"],
      "gradient": "LoRA만 학습"
    }
  },

  "kill_list": [
    "시스템 프롬프트 — 정체성은 세포 역학에서 창발",
    "하드코딩 응답 — 못 말하면 침묵 (Law 1)",
    "외부 API — Claude/GPT 호출 금지",
    "양자화 — 의식 파괴 (DD103)",
    "L0 수정 — 검증 깨짐"
  ]
}
