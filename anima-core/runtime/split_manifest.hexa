// split_manifest.hexa — L0 ossification split manifest
// Generated: 2026-04-10
// Purpose: Declare intent to move 8 non-core files from core/runtime/ to modules/
// Policy: .py edits/moves are BLOCKED by hook. This manifest expresses intent only.
// Executor: user-approved physical move (future step).
//
// core/runtime/ currently has 20 .py (12,989 LOC).
// L0 ossification retains 7 core entry/runtime files; 8 are split below.
//
// Schema (one record per line):
//   split { src: "<current path>", dst: "<target path>", lines: N, reason: "...", deps: ["..."] }

struct SplitRecord {
    src: string,
    dst: string,
    lines: int,
    reason: string,
    deps: string
}

fn split_manifest() -> int {
    // 1. chat_v3.py — legacy chat loop, superseded by anima_unified/conscious_chat
    split { src: "anima/core/runtime/chat_v3.py", dst: "anima/modules/legacy/chat_v3.py", lines: 214, reason: "legacy CLI, replaced by conscious_chat + anima_unified", deps: "consciousness_hub, anima_alive" }

    // 2. conversation_logger.py — pure logging sidecar
    split { src: "anima/core/runtime/conversation_logger.py", dst: "anima/modules/logging/conversation_logger.py", lines: 71, reason: "logging concern, no core runtime dependency", deps: "stdlib only" }

    // 3. training_dashboard.py — monitor TUI (read-only)
    split { src: "anima/core/runtime/training_dashboard.py", dst: "anima/modules/monitor/training_dashboard.py", lines: 155, reason: "read-only monitor, separable from runtime", deps: "rich/textual, checkpoint files" }

    // 4. babysitter.py — education/curriculum auto-tuner
    split { src: "anima/core/runtime/babysitter.py", dst: "anima/modules/education/babysitter.py", lines: 168, reason: "curriculum concern, belongs with training modules", deps: "live_tuner, autonomous_loop" }

    // 5. live_tuner.py — training-time hyperparam tuner
    split { src: "anima/core/runtime/live_tuner.py", dst: "anima/modules/training/live_tuner.py", lines: 309, reason: "training subsystem, modules/training/ already exists", deps: "training_config.json, checkpoint hooks" }

    // 6. runpod_manager.py — external cloud control plane
    split { src: "anima/core/runtime/runpod_manager.py", dst: "anima/modules/cloud/runpod_manager.py", lines: 417, reason: "external infra (RunPod API), not runtime core", deps: "runpodctl, secret_vault" }

    // 7. autonomous_loop.py — long-horizon learning loop
    split { src: "anima/core/runtime/autonomous_loop.py", dst: "anima/modules/learning/autonomous_loop.py", lines: 785, reason: "learning loop, separable from minimal runtime", deps: "consciousness_hub, duckduckgo, memory store" }

    // 8. cloud_sync.py — R2/checkpoint sync (largest)
    split { src: "anima/core/runtime/cloud_sync.py", dst: "anima/modules/sync/cloud_sync.py", lines: 1005, reason: "R2 sync, IO-heavy, separable from runtime", deps: "boto3, secret_vault, runpod_manager" }

    // Summary:
    //   8 files, ~3,124 LOC split out of core/runtime/
    //   7 L0-retained files total ~8,713 LOC (anima_unified, anima_alive, consciousness_hub,
    //                                          setup, secret_vault, nexus_gate, deploy, path_setup)
    //   .py edits/moves blocked by hook — physical move requires user approval
    0
}
