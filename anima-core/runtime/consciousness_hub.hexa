// consciousness_hub.hexa — 의식 자율 모듈 허브 (50 modules, NL routing)
//
// hexa-native rewrite (legacy .py removed in cd81e75d as
// part of the .py → .hexa absorption per R7).
//
// Pattern: a flat registry of HubModule entries (name, keywords). Caller
// passes a natural-language query to hub_route(); hub returns the name of
// the best-matching module by substring keyword check, leaving the actual
// module dispatch to the host (since hexa fns are not first-class
// indirectly callable yet). hub_act() wraps this and returns a string
// summary so callers can display "[hub] route: dream" before invoking the
// dream module themselves.
//
// Keyword scoring: longest matched keyword wins (more specific phrases
// outrank single-word matches). Ties broken by registration order.
//
// Closes roadmap next_action #4 blocker: "consciousness_hub.hexa 완성".

// ─── Module entry ─────────────────────────────────────────────
struct HubModule {
    name: string,           // canonical id used by routing target
    import_path: string,    // hexa module path (informational; host dispatches)
    keywords: [string]      // NL trigger phrases (Korean + English)
}

fn module(name: string, import_path: string, keywords: [string]) -> HubModule {
    HubModule { name: name, import_path: import_path, keywords: keywords }
}

