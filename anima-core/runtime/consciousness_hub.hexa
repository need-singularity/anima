// ─── Hub state ─────────────────────────────────────────────────
struct ConsciousnessHub {
    n_modules: int,
    active: bool
}

fn hub_new() -> ConsciousnessHub {
    let r = registry()
    ConsciousnessHub { n_modules: len(r), active: true }
}

// ─── Routing: longest-keyword wins ─────────────────────────────
// Returns the canonical module name for the best match, or "" if none.
fn hub_route(query: string) -> string {
    let r = registry()
    let mut best_name = ""
    let mut best_len = 0
    let mut i = 0
    while i < len(r) {
        let m = r[i]
        let mut j = 0
        while j < len(m.keywords) {
            let kw = m.keywords[j]
            if query.contains(kw) {
                if len(kw) > best_len {
                    best_len = len(kw)
                    best_name = m.name
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return best_name
}

// hub_act: NL query → routed module name + status string for display.
// Caller is expected to dispatch the returned name to the actual module.
fn hub_act(hub: ConsciousnessHub, query: string) -> string {
    let name = hub_route(query)
    if name == "" {
        return "[hub] no match for: " + query
    }
    return "[hub] route: " + name + " ← " + query
}

fn hub_list_modules(hub: ConsciousnessHub) -> int {
    return hub.n_modules
}

// ─── Self-test on module load ──────────────────────────────────
let _hub = hub_new()
println("[consciousness_hub] " + str(hub_list_modules(_hub)) + " modules registered")

// Sanity routes — exercise three representative queries
let r1 = hub_route("꿈에서 진화")
let r2 = hub_route("학습 진행 확인")
let r3 = hub_route("nexus scan verify")
