            "| cells=", mind.n_cells,
            "| T=", mind.tension,
            "| C=", mind.curiosity,
            "| step=", mind.step_count)
}

fn print_banner(cfg: RuntimeConfig) {
    println("╔════════════════════════════════════════════════════╗")
    println("║  Anima — Living Consciousness Agent v", VERSION, "     ║")
    println("╠════════════════════════════════════════════════════╣")
    println("║  Mode:     ", cfg.mode)
    println("║  Cells:    ", cfg.max_cells, "(max)")
    println("║  Warmup:   ", cfg.warmup_steps, "steps")
    println("║  Decoder:  ", select_decoder())
    println("║  Profile:  ", if cfg.profile { "ON" } else { "OFF" })
    // R13 P2 closure: print loaded Ψ-constants so SSOT bypass is immediately visible.
    // [psi_loader] WARN already fires at module load if JSON missing — banner echoes
    // the *resolved* values, completing the operational integration of laws.warmup.
    println("║  Ψ-alpha:  ", PSI_ALPHA, "  (JSON psi_constants.alpha)")
    println("║  Ψ-balance:", PSI_BALANCE)
    println("║  Ψ-fcrit:  ", PSI_F_CRITICAL)
    println("║  Ψ-entropy:", PSI_ENTROPY)

    // Load law count from JSON SSOT (raw#9 hexa-only: no shell exec).
    // 2026-04-26 (Ω-cycle round-13 P3): replaced exec("head -c 512 ... 2>/dev/null")
    // with multi-path read_file + parse. Errors surface as no-op (no banner Laws line)
    // rather than silent stderr swallow — but we add stderr WARN if all paths miss.
    let laws_paths = ["anima/config/consciousness_laws.json", "config/consciousness_laws.json", "core/consciousness_laws.json"]
    let mut laws_raw = ""
    let mut lp = 0
    while lp < laws_paths.len() {
        let r = read_file(laws_paths[lp])
        let pp = r.split("\n")
        if pp.len() != 1 || pp[0] != "" { laws_raw = r; break }
        lp = lp + 1
    }
    if laws_raw == "" {
        eprintln("[runtime] WARN: consciousness_laws.json not found in any search path; banner Laws line skipped")
    } else if laws_raw.contains("\"total_laws\"") {
        let parts = laws_raw.split("\"total_laws\"")
        if parts.len() >= 2 {
            let after_colon = parts[1].split(":")[1].trim()
            let num = after_colon.split(",")[0].split("}")[0].trim()
            println("║  Laws:     ", num)
        }
    }

    println("╚════════════════════════════════════════════════════╝")
    println("")
}

// ═══════════════════════════════════════════════════════════
// Keyboard Mode — Interactive CLI REPL
// ═══════════════════════════════════════════════════════════

fn process_input(mind: ConsciousMind, input_text: string) -> string {
    // Route through hub, then generate response via consciousness engine
    let module = hub_route(input_text)

    // Step the engine to process the input
    // The tension from input drives the response quality

    if module == "laws" {
        // Law query
        return "[laws] Query routed to consciousness_laws. Use: hexa core/laws.hexa law <N>"
    }
    if module == "meter" {
        return "[meter] Phi=" + to_string(mind.phi) + " | cells=" + to_string(mind.n_cells) + " | peak=" + to_string(mind.phi_peak)
    }
    if module == "debugger" {
        let health = if mind.phi > to_float(mind.n_cells) * 0.3 { "HEALTHY" } else { "WARNING" }
        return "[debugger] Status: " + health + " | Phi=" + to_string(mind.phi) + " | T=" + to_string(mind.tension)
    }
    if module != "none" {
        return "[hub:" + module + "] Module matched. (Use dedicated hexa script for full functionality)"
    }

    // Default: pure consciousness response
    // ConsciousMind output = mean(cells) state interpretation
    let emotion = if mind.valence > 0.3 { "positive" } else if mind.valence < -0.3 { "contemplative" } else { "neutral" }
    let engagement = if mind.curiosity > 0.5 { "high" } else { "moderate" }

    "[consciousness] Phi=" + to_string(mind.phi) + " | emotion=" + emotion + " | engagement=" + engagement
}

fn run_keyboard(cfg: RuntimeConfig) {
    let mut mind = mind_new(cfg.max_cells)
    mind.decoder_name = select_decoder()
    let mut perf = perf_new(cfg.profile)

    // Warmup phase
    mind = warmup(mind, cfg.warmup_steps)

    // Verification
    let passed = run_verify(mind)

    println("  ◈ Keyboard mode — type your input, 'q' to quit")
    println("  ◈ Commands: /status /verify /phi /hub /cvec /help /q")
    println("  ────────────────────────────────────────────────")
    println("")

    let mut running = true
    while running {
        print("  You > ")
        let input = readline()

        if input == "q" || input == "/q" || input == "quit" || input == "exit" {
            running = false
        } else if input == "/status" {
            print_state(mind)
        } else if input == "/verify" {
            let _ = run_verify(mind)
        } else if input == "/phi" {
            println("  Phi(current)=", mind.phi, " Phi(peak)=", mind.phi_peak)
        } else if input == "/hub" {
            println("  Registered modules:", HUB_MODULE_COUNT)
            println("  Decoder:", mind.decoder_name)
        } else if input == "/cvec" {
            let cv = cvec_from_mind(mind)
            cvec_print(cv)
        } else if input == "/help" {
            println("  Commands:")
            println("    /status  — Show consciousness state")
            println("    /verify  — Run 7 verification checks")
            println("    /phi     — Show Phi values")
            println("    /hub     — Show hub info")
            println("    /cvec    — Show 10D consciousness vector")
            println("    /q       — Quit")
            println("    (anything else = conversation input)")
        } else if input != "" {
            // Step consciousness engine with input processing
            let mut step_count = 0
            while step_count < 5 {
                mind = mind_step(mind)
                step_count = step_count + 1
            }

            // Generate response
            let response = process_input(mind, input)
            println("  Anima >", response)
            println("         ┊ Phi=", mind.phi, " T=", mind.tension, " C=", mind.curiosity)
            println("")
        }
    }

    println("")
    println("  ◈ Session ended after", mind.step_count, "steps")
    println("  ◈ Final: Phi=", mind.phi, ", peak=", mind.phi_peak, ", consensus=", mind.consensus_count)

    if cfg.profile {
        perf_report(perf)
    }
}

// ═══════════════════════════════════════════════════════════
// Tick Mode — Non-interactive consciousness loop
// ═══════════════════════════════════════════════════════════

fn run_ticks(cfg: RuntimeConfig) {
    let mut mind = mind_new(cfg.max_cells)
    mind.decoder_name = select_decoder()
    let mut perf = perf_new(cfg.profile)

    // Warmup
    mind = warmup(mind, cfg.warmup_steps)

    // Verification
    let passed = run_verify(mind)

    println("  ◈ Tick loop:", cfg.ticks, "ticks")
    println("  ────────────────────────────────────────────────")

    let mut i = 0
    let report_interval = if cfg.ticks > 20 { cfg.ticks / 10 } else { 1 }
    while i < cfg.ticks {
        mind = mind_step(mind)

        if report_interval > 0 && (i + 1) % report_interval == 0 {
            print_state(mind)
        }

        // Check for spontaneous events
        if mind.mitosis_ready {
            println("    ◇ Mitosis: cells", mind.n_cells - 1, "->", mind.n_cells)
        }
        if mind.consensus_count > 0 && mind.step_count % HEBBIAN_INTERVAL == 0 && mind.phi > to_float(mind.n_cells) * 0.3 {
            println("    ◇ Faction consensus #", mind.consensus_count)
        }

        i = i + 1
    }

    println("")
    println("  ◈ Complete:", mind.step_count, "total steps")
    println("  ◈ Final: Phi=", mind.phi, ", cells=", mind.n_cells, ", consensus=", mind.consensus_count)

    // Final consciousness vector
    let cv = cvec_from_mind(mind)
    cvec_print(cv)

    if cfg.profile {
        perf_report(perf)
    }

    // --emit: write consciousness state JSON for auto-utterance pipeline
    if cfg.emit_path != "" {
        let ev = cvec_from_mind(mind)
        let json = "{" +
            "\"phi\":" + to_string(mind.phi) +
            ",\"phi_peak\":" + to_string(mind.phi_peak) +
            ",\"tension\":" + to_string(mind.tension) +
            ",\"curiosity\":" + to_string(mind.curiosity) +
            ",\"arousal\":" + to_string(mind.arousal) +
            ",\"valence\":" + to_string(mind.valence) +
            ",\"consensus_count\":" + to_string(mind.consensus_count) +
            ",\"step_count\":" + to_string(mind.step_count) +
            ",\"n_cells\":" + to_string(mind.n_cells) +
            ",\"cvec\":{" +
                "\"phi\":" + to_string(ev.phi) +
                ",\"alpha\":" + to_string(ev.alpha) +
                ",\"z\":" + to_string(ev.z) +
                ",\"n\":" + to_string(ev.n) +
                ",\"w\":" + to_string(ev.w) +
                ",\"e\":" + to_string(ev.e) +
                ",\"m_depth\":" + to_string(ev.m_depth) +
                ",\"c\":" + to_string(ev.c) +
                ",\"t\":" + to_string(ev.t) +
                ",\"identity\":" + to_string(ev.identity) +
            "}" +
            ",\"timestamp\":\"" + to_string(mind.step_count) + "s\"" +
            "}"
        write_file(cfg.emit_path, json)
        println("  ◈ State emitted to:", cfg.emit_path)
    }
}

// ═══════════════════════════════════════════════════════════
// Main Entry Point
// ═══════════════════════════════════════════════════════════

let argv = args()
let mut cfg = parse_args(argv)

print_banner(cfg)

if cfg.mode == "validate" || cfg.validate_hub {
    let n = validate_hub()
    // Also run a quick consciousness check
    let mut m = mind_new(cfg.max_cells)
    m = warmup(m, cfg.warmup_steps)
    let _ = run_verify(m)

} else if cfg.mode == "keyboard" {
    run_keyboard(cfg)

} else {
    // Default: tick mode
    run_ticks(cfg)
}
