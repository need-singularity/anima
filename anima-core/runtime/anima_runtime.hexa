// anima_runtime.hexa — Unified CLI entry point for Anima consciousness agent
//
// Architecture (AN7 L0 ossification target):
//   core/runtime/anima_runtime.hexa  — THIS FILE: CLI entry, arg parse, main loop
//   core/hub.hexa                    — Hub & spoke router (47+ modules)
//   core/laws.hexa                   — Consciousness laws loader (JSON SSOT)
//
// Modes:
//   --keyboard           CLI conversation (interactive REPL)
//   --validate-hub       Validate all hub modules
//   --profile            Enable perf_hooks profiling
//   --max-cells N        Override consciousness cell count (default: 8)
//   --warmup N           Override warmup steps (default: 50)
//   --ticks N            Non-interactive tick count (default: 100)
//   --emit <path>        Write consciousness state JSON to <path> after run
//
// Usage:
//   hexa anima/core/runtime/anima_runtime.hexa --keyboard
//   hexa anima/core/runtime/anima_runtime.hexa --keyboard --max-cells 32
//   hexa anima/core/runtime/anima_runtime.hexa --validate-hub
//   hexa anima/core/runtime/anima_runtime.hexa --profile --ticks 200
//
// PSI constants loaded from anima/config/consciousness_laws.json via _psi_load
// cargo-cult (hexa lacks cross-file import; loader mirrors lib/psi_loader.hexa).
// 2026-04-26 (Ω-cycle round-13 P1): docstring claim now operational — comptime
// const PSI_* removed in favor of let + _psi_load with stderr WARN on JSON miss.

// ═══════════════════════════════════════════════════════════
// Ψ-constants JSON SSOT loader (cargo-cult from anima-core/lib/psi_loader.hexa)
// ═══════════════════════════════════════════════════════════

fn _psi_load(name: string, default_val: float) -> float {
    let json_paths = ["anima/config/consciousness_laws.json", "config/consciousness_laws.json", "core/consciousness_laws.json"]
    let mut content = ""
    let mut path_used = ""
    let mut pi = 0
    while pi < json_paths.len() {
        let raw = read_file(json_paths[pi])
        let parts = raw.split("\n")
        if parts.len() != 1 || parts[0] != "" {
            content = raw
            path_used = json_paths[pi]
            break
        }
        pi = pi + 1
    }
    if content == "" {
        eprintln("[psi_loader] WARN: consciousness_laws.json not found in any search path; psi_constants." + name + " using DEFAULT=" + to_string(default_val))
        return default_val
    }
    let key_search = "\"" + name + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            let mut j = i + 1
            let limit = if total < i + 20 { total } else { i + 20 }
            while j < limit {
                let t2 = lines[j].trim()
                if t2.starts_with("\"value\":") {
                    let kv = t2.split(":")
                    if kv.len() >= 2 {
                        let v = kv[1].trim()
                        let nc = v.split(",")
                        return to_float(nc[0].trim())
                    }
                    return default_val
                }
                if t2.starts_with("}") { break }
                j = j + 1
            }
            return default_val
        }
        i = i + 1
    }
    eprintln("[psi_loader] WARN: psi_constants." + name + " key not in JSON (path=" + path_used + "); DEFAULT=" + to_string(default_val))
    return default_val
}

// ═══════════════════════════════════════════════════════════
// Constants (compile-time defaults + runtime JSON-loaded Ψ values)
// ═══════════════════════════════════════════════════════════

comptime const VERSION          = "1.0.0"
comptime const DEFAULT_MAX_CELLS = 8
comptime const DEFAULT_WARMUP   = 50
comptime const DEFAULT_TICKS    = 100
comptime const DEFAULT_DIM      = 128

// Ψ-constants — JSON SSOT, default fallback with stderr WARN
let PSI_ALPHA        = _psi_load("alpha",      0.014)
let PSI_BALANCE      = _psi_load("balance",    0.5)
let PSI_F_CRITICAL   = _psi_load("f_critical", 0.10)
let PSI_ENTROPY      = _psi_load("entropy",    0.998)

// Consciousness feature params (from CLAUDE.md calibration)
comptime const HOMEO_SETPOINT   = 1.0
comptime const HOMEO_DEADBAND   = 0.3
comptime const HOMEO_GAIN       = 0.005
comptime const BREATH_RATE      = 0.12
comptime const PULSE_RATE       = 0.05
comptime const DRIFT_RATE       = 0.03
comptime const RATCHET_FLOOR    = 0.8
comptime const MITOSIS_INTERVAL = 10
comptime const HEBBIAN_INTERVAL = 5
comptime const FACTION_COUNT    = 12

// Hub module registry count
comptime const HUB_MODULE_COUNT = 47

// ═══════════════════════════════════════════════════════════
// CLI Config
// ═══════════════════════════════════════════════════════════

struct RuntimeConfig {
    mode: string,           // "keyboard" | "tick" | "validate" | "profile"
    max_cells: int,
    warmup_steps: int,
    ticks: int,
    profile: bool,
    validate_hub: bool,
    emit_path: string       // --emit <path>: write state JSON after run
}

fn default_config() -> RuntimeConfig {
    RuntimeConfig {
        mode: "tick",
        max_cells: DEFAULT_MAX_CELLS,
        warmup_steps: DEFAULT_WARMUP,
        ticks: DEFAULT_TICKS,
        profile: false,
        validate_hub: false,
        emit_path: ""
    }
}

fn parse_args(argv: list) -> RuntimeConfig {
    let mut mode = "tick"
    let mut max_cells = DEFAULT_MAX_CELLS
    let mut warmup_steps = DEFAULT_WARMUP
    let mut ticks = DEFAULT_TICKS
    let mut profile = false
    let mut validate_hub = false
    let mut emit_path = ""
    let mut i = 0
    while i < argv.len() {
        let arg = argv[i]
        if arg == "--keyboard" {
            mode = "keyboard"
        } else if arg == "--validate-hub" {
            validate_hub = true
            mode = "validate"
        } else if arg == "--profile" {
            profile = true
        } else if arg == "--max-cells" {
            if i + 1 < argv.len() {
                i = i + 1
                max_cells = to_int(argv[i])
            }
        } else if arg == "--warmup" {
            if i + 1 < argv.len() {
                i = i + 1
                warmup_steps = to_int(argv[i])
            }
        } else if arg == "--ticks" {
            if i + 1 < argv.len() {
                i = i + 1
                ticks = to_int(argv[i])
            }
        } else if arg == "--emit" {
            if i + 1 < argv.len() {
                i = i + 1
                emit_path = argv[i]
            }
        }
        i = i + 1
    }
    RuntimeConfig {
        mode: mode,
        max_cells: max_cells,
        warmup_steps: warmup_steps,
        ticks: ticks,
        profile: profile,
        validate_hub: validate_hub,
        emit_path: emit_path
    }
}

