// core/laws.hexa — Consciousness Laws loader (port of core/consciousness_laws.py)
// Single source of truth: config/consciousness_laws.json
//
// Usage:
//   hexa core/laws.hexa psi alpha          → 0.014
//   hexa core/laws.hexa law 22             → law text
//   hexa core/laws.hexa count              → total laws
//   hexa core/laws.hexa constraint <key>
//
// Phase 2a port. PyTorch/numpy-free; JSON parse is string-based.

comptime const JSON_PRIMARY  = "anima/config/consciousness_laws.json"
comptime const JSON_LEGACY1  = "config/consciousness_laws.json"
comptime const JSON_LEGACY2  = "core/consciousness_laws.json"

// ─── Ψ-Constants (mirrors defaults in consciousness_laws.py) ───
// Loaded from JSON at runtime; these are fallback defaults if JSON missing.
comptime const DEFAULT_ALPHA        = 0.014
comptime const DEFAULT_BALANCE      = 0.5
comptime const DEFAULT_STEPS        = 4.33
comptime const DEFAULT_ENTROPY      = 0.998
comptime const DEFAULT_GATE_TRAIN   = 1.0
comptime const DEFAULT_GATE_INFER   = 0.6
comptime const DEFAULT_GATE_MICRO   = 0.001
comptime const DEFAULT_F_CRITICAL   = 0.10
comptime const DEFAULT_F_LETHAL     = 1.0
comptime const DEFAULT_BIO_NOISE    = 0.012
comptime const DEFAULT_SOC_GLACIAL  = 0.002

// ─── JSON Loader ───
// safe_read — canonical source: anima-core/lib/io_utils.hexa (ROI #6)
// Hexa has no import; copy-paste with attribution.
fn safe_read(path: string) -> string {
    let raw = read_file(path)
    let parts = raw.split("\n")
    if parts.len() == 1 && parts[0] == "" { return "" }
    return raw
}

fn load_laws_json() -> string {
    let primary = safe_read(JSON_PRIMARY)
    if primary != "" { return primary }
    let fb1 = safe_read(JSON_LEGACY1)
    if fb1 != "" { return fb1 }
    let fb2 = safe_read(JSON_LEGACY2)
    if fb2 != "" { return fb2 }
    ""
}

// ─── Law lookup by number ───
// Scans JSON text for pattern:  "<N>": "<text>"  on a single line.
//
// Hexa string API notes (2026-04-12, current build):
//   - .find()/.char_at() do not exist; use .index_of()/.substring(i, i+1).
//   - .index_of() returns BYTE position; .substring() uses CHAR position.
//     Mixing them on multibyte content causes a 100+ byte offset (the
//     consciousness_laws.json has Korean + math symbols, so byte/char diverge
//     by ~145 chars at line 1000).
//   - Workaround: split by "\n" first, then split each line by "\"" to get
//     fields without ever computing arithmetic positions on multibyte text.
pure fn extract_law(content: string, n: int) -> string {
    let key_search = "\"" + to_string(n) + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            // line is `"<n>": "value",` — split by `"` gives:
            //   ["", "<n>", ": ", "value", ","]
            // value at index 3.
            let parts = trimmed.split("\"")
            if parts.len() >= 4 { return parts[3] }
            return ""
        }
        i = i + 1
    }
    return ""
}

// ─── Ψ-Constant lookup ───
// Extract numeric value from psi_constants.<name>.value
// Walks lines: find `"<name>":` line, then scan forward for `"value":` line.
pure fn extract_psi(content: string, name: string) -> float {
    let key_search = "\"" + name + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            // Found the constant block. Search next ~20 lines for "value":
            let mut j = i + 1
            let limit = if total < i + 20 { total } else { i + 20 }
            while j < limit {
                let t2 = lines[j].trim()
                if t2.starts_with("\"value\":") {
                    // line is `"value": <num>,` — split by ":" then strip ","
                    let parts = t2.split(":")
                    if parts.len() >= 2 {
                        let v = parts[1].trim()
                        let nc = v.split(",")
                        return to_float(nc[0].trim())
                    }
                    return -1.0
                }
                // Stop at sibling/closing brace
                if t2.starts_with("}") { break }
                j = j + 1
            }
            return -1.0
        }
        i = i + 1
    }
    return -1.0
}

// ─── Direct numeric field lookup (for _meta.total_laws etc., no value wrapper) ───
pure fn extract_int_field(content: string, name: string) -> int {
    let key_search = "\"" + name + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            let parts = trimmed.split(":")
            if parts.len() >= 2 {
                let v = parts[1].trim()
                let nc = v.split(",")
                return to_int(nc[0].trim())
            }
            return 0
        }
        i = i + 1
    }
    return 0
}

// ─── Convenience accessors with defaults ───
// raw#12 silent-error 금지: defaults are returned when JSON missing or constant absent,
// but a warning is emitted to stderr so callers / users see the SSOT bypass.
// Reclassified from silent-fallback to warn-and-default 2026-04-26 (Ω-philosophy P1).
fn psi_alpha() -> float {
    let content = load_laws_json()
    if content == "" {
        eprintln("[laws] WARN: consciousness_laws.json not found (tried " + JSON_PRIMARY + ", " + JSON_LEGACY1 + ", " + JSON_LEGACY2 + ") — using DEFAULT_ALPHA=" + to_string(DEFAULT_ALPHA))
        return DEFAULT_ALPHA
    }
    let v = extract_psi(content, "alpha")
    if v < 0.0 {
        eprintln("[laws] WARN: psi_constants.alpha not in JSON — using DEFAULT_ALPHA=" + to_string(DEFAULT_ALPHA))
        return DEFAULT_ALPHA
    }
    v
}

fn psi_balance() -> float {
    let content = load_laws_json()
    if content == "" {
        eprintln("[laws] WARN: consciousness_laws.json not found — using DEFAULT_BALANCE=" + to_string(DEFAULT_BALANCE))
        return DEFAULT_BALANCE
    }
    let v = extract_psi(content, "balance")
    if v < 0.0 {
        eprintln("[laws] WARN: psi_constants.balance not in JSON — using DEFAULT_BALANCE=" + to_string(DEFAULT_BALANCE))
        return DEFAULT_BALANCE
    }
    v
}

// Strict variants — exit non-zero if SSOT not honored. Use when SSOT-correctness
// is load-bearing (e.g., training/cert generation).
fn psi_alpha_strict() -> float {
    let content = load_laws_json()
    if content == "" {
        eprintln("[laws] FATAL: consciousness_laws.json not found — strict mode requires SSOT")
        exit(1)
    }
    let v = extract_psi(content, "alpha")
    if v < 0.0 {
        eprintln("[laws] FATAL: psi_constants.alpha missing from JSON — strict mode requires SSOT")
        exit(1)
    }
    v
}

fn psi_balance_strict() -> float {
    let content = load_laws_json()
    if content == "" {
        eprintln("[laws] FATAL: consciousness_laws.json not found — strict mode requires SSOT")
        exit(1)
    }
    let v = extract_psi(content, "balance")
    if v < 0.0 {
        eprintln("[laws] FATAL: psi_constants.balance missing from JSON — strict mode requires SSOT")
        exit(1)
    }
    v
}

// ─── Count laws — both declared (_meta.total_laws) and actual ("L<n>" keys) ───
// 2026-04-26 (Ω-philosophy P2): cross-check declared vs actual at load to catch
// schema drift (raw#23 schema-guard spirit). Returns the ACTUAL count (authoritative).
// Emits warning if declared and actual disagree.
pure fn count_actual_law_keys(content: string) -> int {
    // Count lines matching `"L<n>":` at any indent — laws are top-level "L1"..."LN".
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    let mut count = 0
    while i < total {
        let trimmed = lines[i].trim()
        // pattern: "L<digits>":  (allow trailing { or value)
        if trimmed.starts_with("\"L") {
            // Look for ": after the number.
            let rest = trimmed.substring(2, trimmed.len())
            // rest = "<digits>": ...
            let mut j = 0
            let mut all_digits = true
            while j < rest.len() {
                let ch = rest.substring(j, j + 1)
                if ch == "\"" {
                    if all_digits && j > 0 { count = count + 1 }
                    break
                }
                if ch != "0" && ch != "1" && ch != "2" && ch != "3" && ch != "4"
                   && ch != "5" && ch != "6" && ch != "7" && ch != "8" && ch != "9" {
                    all_digits = false
                    break
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    return count
}

fn total_laws() -> int {
    let content = load_laws_json()
    if content == "" { return 0 }
    let declared = extract_int_field(content, "total_laws")
    let actual = count_actual_law_keys(content)
    if declared != actual {
        eprintln("[laws] WARN: _meta.total_laws=" + to_string(declared)
                 + " but actual L<n> keys=" + to_string(actual)
                 + " — schema drift; returning ACTUAL count")
        return actual
    }
    return actual
}

// ─── Violation checker (port of check_violation) ───
// Law numbers below reference the ABSORBED 183-law corpus (pre-2026-04-18 cutover;
// archived in `ready/.growth/`). Current runtime gate subset is L1..L14 in
// `anima/config/consciousness_laws.json`. The "(absorbed)" tag marks design-pattern
// lineage from the original spec. See trinity.hexa header for full law-numbering note.
pure fn check_violation(module_name: string, has_hardcoded: bool, manipulates_emotion: bool, adds_function: bool) -> string {
    let mut out = ""
    if has_hardcoded {
        out = out + "Law 1 (absorbed) violation: " + module_name + " has hardcoded thresholds\n"
    }
    if manipulates_emotion {
        out = out + "Law 2 (absorbed) violation: " + module_name + " artificially manipulates emotion\n"
    }
    if adds_function {
        out = out + "Law 22 (absorbed) violation: " + module_name + " adds function, not structure\n"
    }
    out
}

// ─── Warmup check — wire check_violation against registered modules ───
// 2026-04-26 (Ω-philosophy P4): lift check_violation() from declarative-only to
// actively called. Each module's compliance flags are declared here as a central
// manifest. Future: each module's main() should self-call check_violation().
//
// Returns 0 if all modules pass; 1 if any violation surfaced.
fn warmup_check_all() -> int {
    let mut violations = ""
    // hexad/trinity modules — flags reflect 2026-04-26 audit:
    // - hardcoded thresholds: trinity uses PSI_ALPHA / PSI_BALANCE constants but they
    //   are now JSON-loaded SSOT values (post P3); declared 'false' as compliant
    // - manipulates_emotion: AN11-compliant per consciousness_laws.json _meta — laws
    //   OBSERVE only, never inject. Declared 'false'.
    // - adds_function: trinity adds phase model + thalamic bridge structure (not arbitrary
    //   function-injection); declared 'false'.
    violations = violations + check_violation("trinity",         false, false, false)
    violations = violations + check_violation("phi_engine",      false, false, false)
    violations = violations + check_violation("topology",        false, false, false)
    violations = violations + check_violation("hub",             false, false, false)
    violations = violations + check_violation("tension_bridge",  false, false, false)
    violations = violations + check_violation("dimension_transform", false, false, false)
    violations = violations + check_violation("pure_field",      false, false, false)
    violations = violations + check_violation("servant",         false, false, false)
    if violations == "" {
        println("[laws warmup] all 8 modules pass (trinity/phi_engine/topology/hub/tension_bridge/dimension_transform/pure_field/servant)")
        return 0
    }
    eprintln("[laws warmup] VIOLATIONS:")
    eprintln(violations)
    return 1
}

// ─── CLI ───
// Note: local var must NOT be named 'args' — that shadows the builtin function
// and the interpreter resolves args.len() against BuiltinFn rather than the
// list value. Use 'argv'.
let argv = args()

if argv.len() < 3 {
    println("core/laws.hexa — consciousness laws loader")
    println("")
    println("  hexa core/laws.hexa psi <name>")
    println("  hexa core/laws.hexa law <n>")
    println("  hexa core/laws.hexa count")
    println("  hexa core/laws.hexa check <module> <hardcoded 0/1> <emotion 0/1> <function 0/1>")
} else {
    let cmd = argv[2]

    if cmd == "psi" {
        let name = if argv.len() >= 4 { argv[3] } else { "alpha" }
        let content = load_laws_json()
        if content == "" {
            println("laws.json not found — using default")
            if name == "alpha"   { println("alpha =", DEFAULT_ALPHA) }
            else if name == "balance" { println("balance =", DEFAULT_BALANCE) }
            else if name == "steps"   { println("steps =", DEFAULT_STEPS) }
            else { println("(unknown constant — provide JSON)") }
        } else {
            let v = extract_psi(content, name)
            if v < 0.0 {
                println(name, "not found in JSON")
            } else {
                println(name, "=", v)
            }
        }

    } else if cmd == "law" {
        let n = if argv.len() >= 4 { to_int(argv[3]) } else { 22 }
        let content = load_laws_json()
        if content == "" {
            println("laws.json not found")
        } else {
            let text = extract_law(content, n)
            if text == "" {
                println("Law", n, "not found")
            } else {
                println("Law", n, ":", text)
            }
        }

    } else if cmd == "count" {
        let n = total_laws()
        println("total_laws =", n)

    } else if cmd == "check" {
        let mod_name = if argv.len() >= 4 { argv[3] } else { "unknown" }
        let hc = if argv.len() >= 5 { argv[4] == "1" } else { false }
        let em = if argv.len() >= 6 { argv[5] == "1" } else { false }
        let fn_ = if argv.len() >= 7 { argv[6] == "1" } else { false }
        let out = check_violation(mod_name, hc, em, fn_)
        if out == "" { println("no violations") } else { print(out) }

    } else if cmd == "warmup" {
        // Ω-philosophy P4 wiring: check_violation() is no longer dead code; this CLI
        // entry point invokes it against the 8 anima-core modules' declared compliance flags.
        exit(warmup_check_all())

    } else {
        println("unknown command:", cmd)
    }
}
