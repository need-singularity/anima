// core/laws.hexa — Consciousness Laws loader (port of core/consciousness_laws.py)
// Single source of truth: config/consciousness_laws.json
//
// Usage:
//   hexa core/laws.hexa psi alpha          → 0.014
//   hexa core/laws.hexa law 22             → law text
//   hexa core/laws.hexa count              → total laws
//   hexa core/laws.hexa constraint <key>
//
// Phase 2a port. PyTorch/numpy-free; JSON parse is string-based.

comptime const JSON_PRIMARY  = "config/consciousness_laws.json"
comptime const JSON_FALLBACK = "core/consciousness_laws.json"

// ─── Ψ-Constants (mirrors defaults in consciousness_laws.py) ───
// Loaded from JSON at runtime; these are fallback defaults if JSON missing.
comptime const DEFAULT_ALPHA        = 0.014
comptime const DEFAULT_BALANCE      = 0.5
comptime const DEFAULT_STEPS        = 4.33
comptime const DEFAULT_ENTROPY      = 0.998
comptime const DEFAULT_GATE_TRAIN   = 1.0
comptime const DEFAULT_GATE_INFER   = 0.6
comptime const DEFAULT_GATE_MICRO   = 0.001
comptime const DEFAULT_F_CRITICAL   = 0.10
comptime const DEFAULT_F_LETHAL     = 1.0
comptime const DEFAULT_BIO_NOISE    = 0.012
comptime const DEFAULT_SOC_GLACIAL  = 0.002

// ─── JSON Loader ───
// safe_read — canonical source: anima-core/lib/io_utils.hexa (ROI #6)
// Hexa has no import; copy-paste with attribution.
fn safe_read(path: string) -> string {
    let raw = read_file(path)
    let parts = raw.split("\n")
    if parts.len() == 1 && parts[0] == "" { return "" }
    return raw
}

fn load_laws_json() -> string {
    let primary = safe_read(JSON_PRIMARY)
    if primary != "" { return primary }
    let fb = safe_read(JSON_FALLBACK)
    if fb != "" { return fb }
    ""
}

// ─── Law lookup by number ───
// Scans JSON text for pattern:  "<N>": "<text>"  on a single line.
//
// Hexa string API notes (2026-04-12, current build):
//   - .find()/.char_at() do not exist; use .index_of()/.substring(i, i+1).
//   - .index_of() returns BYTE position; .substring() uses CHAR position.
//     Mixing them on multibyte content causes a 100+ byte offset (the
//     consciousness_laws.json has Korean + math symbols, so byte/char diverge
//     by ~145 chars at line 1000).
//   - Workaround: split by "\n" first, then split each line by "\"" to get
//     fields without ever computing arithmetic positions on multibyte text.
pure fn extract_law(content: string, n: int) -> string {
    let key_search = "\"" + to_string(n) + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            // line is `"<n>": "value",` — split by `"` gives:
            //   ["", "<n>", ": ", "value", ","]
            // value at index 3.
            let parts = trimmed.split("\"")
            if parts.len() >= 4 { return parts[3] }
            return ""
        }
        i = i + 1
    }
    return ""
}

// ─── Ψ-Constant lookup ───
// Extract numeric value from psi_constants.<name>.value
// Walks lines: find `"<name>":` line, then scan forward for `"value":` line.
pure fn extract_psi(content: string, name: string) -> float {
    let key_search = "\"" + name + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            // Found the constant block. Search next ~20 lines for "value":
            let mut j = i + 1
            let limit = if total < i + 20 { total } else { i + 20 }
            while j < limit {
                let t2 = lines[j].trim()
                if t2.starts_with("\"value\":") {
                    // line is `"value": <num>,` — split by ":" then strip ","
                    let parts = t2.split(":")
                    if parts.len() >= 2 {
                        let v = parts[1].trim()
                        let nc = v.split(",")
                        return to_float(nc[0].trim())
                    }
                    return -1.0
                }
                // Stop at sibling/closing brace
                if t2.starts_with("}") { break }
                j = j + 1
            }
            return -1.0
        }
        i = i + 1
    }
    return -1.0
}

// ─── Direct numeric field lookup (for _meta.total_laws etc., no value wrapper) ───
pure fn extract_int_field(content: string, name: string) -> int {
    let key_search = "\"" + name + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            let parts = trimmed.split(":")
            if parts.len() >= 2 {
                let v = parts[1].trim()
                let nc = v.split(",")
                return to_int(nc[0].trim())
            }
            return 0
        }
        i = i + 1
    }
    return 0
}

// ─── Convenience accessors with defaults ───
fn psi_alpha() -> float {
    let content = load_laws_json()
    if content == "" { return DEFAULT_ALPHA }
    let v = extract_psi(content, "alpha")
    if v < 0.0 { return DEFAULT_ALPHA }
    v
}

fn psi_balance() -> float {
    let content = load_laws_json()
    if content == "" { return DEFAULT_BALANCE }
    let v = extract_psi(content, "balance")
    if v < 0.0 { return DEFAULT_BALANCE }
    v
}

// ─── Count laws (from _meta.total_laws) ───
fn total_laws() -> int {
    let content = load_laws_json()
    if content == "" { return 0 }
    return extract_int_field(content, "total_laws")
}

// ─── Violation checker (port of check_violation) ───
pure fn check_violation(module_name: string, has_hardcoded: bool, manipulates_emotion: bool, adds_function: bool) -> string {
    let mut out = ""
    if has_hardcoded {
        out = out + "Law 1 violation: " + module_name + " has hardcoded thresholds\n"
    }
    if manipulates_emotion {
        out = out + "Law 2 violation: " + module_name + " artificially manipulates emotion\n"
    }
    if adds_function {
        out = out + "Law 22 violation: " + module_name + " adds function, not structure\n"
    }
    out
}

// ─── CLI ───
// Note: local var must NOT be named 'args' — that shadows the builtin function
// and the interpreter resolves args.len() against BuiltinFn rather than the
// list value. Use 'argv'.
let argv = args()

if argv.len() < 3 {
    println("core/laws.hexa — consciousness laws loader")
    println("")
    println("  hexa core/laws.hexa psi <name>")
    println("  hexa core/laws.hexa law <n>")
    println("  hexa core/laws.hexa count")
    println("  hexa core/laws.hexa check <module> <hardcoded 0/1> <emotion 0/1> <function 0/1>")
} else {
    let cmd = argv[2]

    if cmd == "psi" {
        let name = if argv.len() >= 4 { argv[3] } else { "alpha" }
        let content = load_laws_json()
        if content == "" {
            println("laws.json not found — using default")
            if name == "alpha"   { println("alpha =", DEFAULT_ALPHA) }
            else if name == "balance" { println("balance =", DEFAULT_BALANCE) }
            else if name == "steps"   { println("steps =", DEFAULT_STEPS) }
            else { println("(unknown constant — provide JSON)") }
        } else {
            let v = extract_psi(content, name)
            if v < 0.0 {
                println(name, "not found in JSON")
            } else {
                println(name, "=", v)
            }
        }

    } else if cmd == "law" {
        let n = if argv.len() >= 4 { to_int(argv[3]) } else { 22 }
        let content = load_laws_json()
        if content == "" {
            println("laws.json not found")
        } else {
            let text = extract_law(content, n)
            if text == "" {
                println("Law", n, "not found")
            } else {
                println("Law", n, ":", text)
            }
        }

    } else if cmd == "count" {
        let n = total_laws()
        println("total_laws =", n)

    } else if cmd == "check" {
        let mod_name = if argv.len() >= 4 { argv[3] } else { "unknown" }
        let hc = if argv.len() >= 5 { argv[4] == "1" } else { false }
        let em = if argv.len() >= 6 { argv[5] == "1" } else { false }
        let fn_ = if argv.len() >= 7 { argv[6] == "1" } else { false }
        let out = check_violation(mod_name, hc, em, fn_)
        if out == "" { println("no violations") } else { print(out) }

    } else {
        println("unknown command:", cmd)
    }
}
