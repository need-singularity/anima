// lib/io_utils.hexa — shared I/O utilities for anima-core
// ROI #6: marker_present() + safe_read() 통합 모듈
//
// Hexa note (2026-04-12): read_file() returns Error type for missing paths,
// NOT "". `Error != ""` evaluates to true, causing false-ready signals.
// Probe via .split() which silently coerces Error -> [""] with warning.

// Check if a marker file exists and has content.
// Returns true if the file exists and is non-empty.
fn marker_present(path: string) -> bool {
    let raw = read_file(path)
    let parts = raw.split("\n")
    // split("\n") on Error returns [""] (length 1, empty single element)
    // split("\n") on real empty file also returns [""]
    // both should be treated as "no marker"
    if parts.len() == 1 && parts[0] == "" { return false }
    return true
}

// Safely read a file, returning "" if missing or Error.
// Use this instead of raw read_file() to avoid Error-type leaks.
fn safe_read(path: string) -> string {
    let raw = read_file(path)
    let parts = raw.split("\n")
    if parts.len() == 1 && parts[0] == "" { return "" }
    return raw
}
