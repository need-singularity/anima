// lib/psi_loader.hexa — Ψ-constants JSON SSOT loader (canonical reference)
//
// Loads psi_constants.<name>.value from anima/config/consciousness_laws.json.
// Falls back to default + emits stderr warning if JSON missing or key absent
// (raw#12 silent-error 금지 — visible degradation, not silent).
//
// Created 2026-04-26 (Ω-cycle R2 LR2.1 closure pattern). Cargo-cult target:
// each anima-core module copy-pastes the _psi_load function below (hexa lacks
// cross-file import — Phase 2b dependency). Modules MUST keep _psi_load in
// sync with this canonical reference.
//
// Multi-path search (matches anima-core/laws.hexa convention):
//   1. anima/config/consciousness_laws.json (post-2026-04-18 canonical)
//   2. config/consciousness_laws.json       (legacy)
//   3. core/consciousness_laws.json         (legacy fallback)
//
// Usage (per consumer module):
//   let PSI_ALPHA   = _psi_load("alpha",   0.014)   // (sopfr/J2)^e ≈ 0.014
//   let PSI_BALANCE = _psi_load("balance", 0.5)
//   let PSI_ENTROPY = _psi_load("entropy", 0.998)
//   let PSI_COUPLING = _psi_load("coupling", 0.015317)  // anima-specific (not in JSON yet)
//
// raw#9 hexa-only / raw#10 honest fallback / raw#12 visible degradation /
// raw#15 SSOT contract (JSON psi_constants.alpha.value is authoritative).

fn _psi_load(name: string, default_val: float) -> float {
    let json_paths = ["anima/config/consciousness_laws.json", "config/consciousness_laws.json", "core/consciousness_laws.json"]
    let mut content = ""
    let mut path_used = ""
    let mut pi = 0
    while pi < json_paths.len() {
        let raw = read_file(json_paths[pi])
        let parts = raw.split("\n")
        if parts.len() != 1 || parts[0] != "" {
            content = raw
            path_used = json_paths[pi]
            break
        }
        pi = pi + 1
    }
    if content == "" {
        eprintln("[psi_loader] WARN: consciousness_laws.json not found in any search path; psi_constants." + name + " using DEFAULT=" + to_string(default_val))
        return default_val
    }
    let key_search = "\"" + name + "\":"
    let lines = content.split("\n")
    let total = lines.len()
    let mut i = 0
    while i < total {
        let trimmed = lines[i].trim()
        if trimmed.starts_with(key_search) {
            let mut j = i + 1
            let limit = if total < i + 20 { total } else { i + 20 }
            while j < limit {
                let t2 = lines[j].trim()
                if t2.starts_with("\"value\":") {
                    let kv = t2.split(":")
                    if kv.len() >= 2 {
                        let v = kv[1].trim()
                        let nc = v.split(",")
                        return to_float(nc[0].trim())
                    }
                    eprintln("[psi_loader] WARN: psi_constants." + name + ".value parse failed; DEFAULT=" + to_string(default_val))
                    return default_val
                }
                if t2.starts_with("}") { break }
                j = j + 1
            }
            eprintln("[psi_loader] WARN: psi_constants." + name + ".value not found within block; DEFAULT=" + to_string(default_val))
            return default_val
        }
        i = i + 1
    }
    eprintln("[psi_loader] WARN: psi_constants." + name + " key not in JSON (path=" + path_used + "); DEFAULT=" + to_string(default_val))
    return default_val
}
