// ════════════════════════════════════════════════════════════════
//  btr_evo/6_cargo_invariants.hexa — BTR Evolution 6/6: cargo-deviation detector
//
//  PURPOSE
//    Regression guard against the btr replica drifting off its 7
//    anchor invariants. "Cargo 이탈" = the replica carries forward
//    a corrupted state that silently violates one of the anchors that
//    previous btr-evo landings (1..5) have certified.
//
//  ANCHORS (7 invariants, all independent)
//    I1. phi_monotone           — Φ must not regress past tolerance across iters
//                                 (self_mimicry H2 plateau, PHI_PERSIST_MIN=0.60)
//    I2. eigenvec_stability     — cos(phi_n, phi_{n+1}) ≥ 0.95 for converged seeds
//                                 (AN11b cosine-drift criterion)
//    I3. brain_like_floor       — brain_like_pct ≥ 85.0% at every tick
//                                 (Mk.V Δ₀ canonical 85.6% baseline)
//    I4. exact_score_conservation — 5-Lens EXACT 19/19 preserved
//                                   (brain_tension_replica.md line 54)
//    I5. phi_gap_bounded        — |training_Φ/benchmark_Φ - 1| < 0.10
//                                 (phi_gap_816x_attack_20260421 §G_VALIDITY;
//                                  guards against the 816× artifact regression)
//    I6. saturation_monotone    — state ∈ {open, converging, fixpoint}
//                                 may only advance forward, never retreat.
//    I7. cargo_weight_frobenius — ΔTL_weights_Frob < 0.20 tick-to-tick
//                                 (simplex, 5 channels sum=1; bound from
//                                  btr_closed_loop.hexa tl_adjust EMA α=0.4)
//
//  DESIGN
//    - Detector is SELF-CONTAINED. It re-derives the canonical trajectory
//      deterministically (LCG seed) from the same formulas as
//      tool/btr_closed_loop.hexa (inlined to avoid upstream syntax hazards).
//    - Each invariant is an independent `check_iN(...) -> Check`.
//    - Dashboard emits shared/state/btr_evo_6_cargo_invariants_<seed>.json.
//    - Exit 0 iff all 7 PASS; otherwise exit 1 and list the first violation.
//
//  CONTRACT
//    - NO LLM. Deterministic LCG only.
//    - V8 SAFE_COMMIT — additive file; no mutation of existing modules.
//    - Stage0-safe: method-style `.push`, no semicolons-as-separator,
//      no multi-line array literals with struct initializers.
//
//  USAGE
//    hexa btr_evo/6_cargo_invariants.hexa <seed> <iters>
//      seed   default 20260421
//      iters  default 50
// ════════════════════════════════════════════════════════════════

let DEFAULT_SEED  = 20260421
let DEFAULT_ITERS = 50
let OUT_TEMPLATE  = "shared/state/btr_evo_6_cargo_invariants_"

// ── invariant thresholds (SSOT) ──────────────────────────────────

let I1_PHI_TOL              = 0.08       // phi regression tolerance per iter
let I1_MIN_PHI_FLOOR        = 0.50       // absolute floor
let I2_COS_FLOOR            = 0.95       // eigenvec / direction cosine floor
let I3_BRAIN_LIKE_FLOOR     = 85.0       // % — Mk.V Δ₀ canonical
let I4_EXACT_SCORE_REQUIRED = 19         // 19/19 5-Lens EXACT
let I4_EXACT_SCORE_TOTAL    = 19
let I5_PHI_GAP_MAX          = 0.10       // |ratio − 1| < 0.10 (§G_VALIDITY)
let I5_PHI_GAP_LEGACY_ART   = 816.0      // guard against 816× artifact regression
let I6_STATE_OPEN           = 0
let I6_STATE_CONVERGING     = 1
let I6_STATE_FIXPOINT       = 2
let I7_FROB_DRIFT_MAX       = 0.20       // per-tick TL simplex Frobenius bound

// ── determ RNG (matches btr_closed_loop LCG) ─────────────────────

struct Rng { state: int }

fn rng_new(seed: int) -> Rng {
    let s0 = if seed == 0 { 1 } else { seed }
    return Rng { state: s0 }
}

fn rng_step(r: Rng) -> Rng {
    let a = 1664525
    let c = 1013904223
    let m = 2147483648
    let nxt = (a * r.state + c) % m
    let pos = if nxt < 0 { nxt + m } else { nxt }
    return Rng { state: pos }
}

fn rng_unit(r: Rng) -> float {
    let m = 2147483648.0
    return (r.state * 1.0) / m
}

// ── math helpers ─────────────────────────────────────────────────

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn absf(x: float) -> float { if x < 0.0 { return 0.0 - x } else { return x } }

fn clampf(x: float, lo: float, hi: float) -> float {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn sqrtf(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x
    let mut i = 0
    while i < 40 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

fn maxf(a: float, b: float) -> float { if a > b { return a } else { return b } }
fn minf(a: float, b: float) -> float { if a < b { return a } else { return b } }

// ── tick record (canonical trajectory) ───────────────────────────

struct Tick {
    i:              int,
    phi:            float,
    brain_like_pct: float,
    dstate:         float,
    cos_prev:       float,        // cos(sv_n, sv_{n-1})
    sat_state:      int,          // I6: {0,1,2}
    w_frob_drift:   float,        // I7: TL weight drift vs prev tick
    w1: float, w2: float, w3: float, w4: float, w5: float,
    v1: float, v2: float, v3: float, v4: float, v5: float, v6: float
}

// ── 6-d state vector construction (tracks btr_closed_loop) ───────

fn state_vec_for(rng: Rng, phi: float, nudge: float) -> Tick {
    // 6 pseudo-random draws
    let r1 = rng_step(rng)
    let u1 = rng_unit(r1)
    let r2 = rng_step(r1)
    let u2 = rng_unit(r2)
    let r3 = rng_step(r2)
    let u3 = rng_unit(r3)
    let r4 = rng_step(r3)
    let u4 = rng_unit(r4)
    let r5 = rng_step(r4)
    let u5 = rng_unit(r5)
    let r6 = rng_step(r5)
    let u6 = rng_unit(r6)

    // baseline EEG (Mk.V Δ₀ canonical)
    let b_lz = 0.72
    let b_hu = 0.74
    let b_ps = 0.0 - 1.05
    let b_ad = 0.65
    let b_ce = 0.86
    let b_bl = 85.6

    let noise_amp = 0.04
    let n1 = (u1 - 0.5) * noise_amp
    let n2 = (u2 - 0.5) * noise_amp
    let n3 = (u3 - 0.5) * noise_amp
    let n4 = (u4 - 0.5) * noise_amp
    let n5 = (u5 - 0.5) * noise_amp

    let phi_bonus = (phi - 0.50) * 0.06
    let tl_bonus  = nudge * 0.04

    let lz = b_lz + n1 + phi_bonus + tl_bonus
    let hu = b_hu + n2 + phi_bonus * 0.8
    let ps = b_ps + n3 * 0.5
    let ad = b_ad + n4 + phi_bonus * 0.7
    let ce = b_ce + n5 + phi_bonus * 0.5
    let bl = clampf(b_bl + (phi_bonus + tl_bonus) * 100.0 + (u6 - 0.5) * 0.8, 0.0, 100.0)

    // normalize to [0,1]^6 (matches btr_closed_loop::normalize)
    let v1 = clampf((lz - 0.00) / 1.00, 0.0, 1.0)
    let v2 = clampf((hu - 0.00) / 1.00, 0.0, 1.0)
    let v3 = clampf((ps + 3.00) / 3.00, 0.0, 1.0)
    let v4 = clampf((ad - 0.00) / 1.00, 0.0, 1.0)
    let v5 = clampf((ce - 0.00) / 2.00, 0.0, 1.0)
    let v6 = clampf(bl / 100.0, 0.0, 1.0)

    return Tick {
        i: 0, phi: 0.0, brain_like_pct: bl,
        dstate: 0.0, cos_prev: 1.0, sat_state: 0, w_frob_drift: 0.0,
        w1: 0.20, w2: 0.20, w3: 0.20, w4: 0.20, w5: 0.20,
        v1: v1, v2: v2, v3: v3, v4: v4, v5: v5, v6: v6
    }
}

// ── TL weight EMA (matches btr_closed_loop::tl_adjust) ───────────

struct W5 { c: float, x: float, m: float, a: float, s: float }

fn tl_init() -> W5 {
    return W5 { c: 0.20, x: 0.20, m: 0.20, a: 0.20, s: 0.20 }
}

fn tl_update(prev: W5, t: Tick) -> W5 {
    let rc = prev.c * 0.6 + t.v1 * 0.4
    let rx = prev.x * 0.6 + t.v2 * 0.4
    let rm = prev.m * 0.6 + t.v3 * 0.4
    let ra = prev.a * 0.6 + t.v4 * 0.4
    let rs = prev.s * 0.6 + t.v5 * 0.4
    let sum = rc + rx + rm + ra + rs
    let z = if sum < 0.0001 { 0.0001 } else { sum }
    return W5 { c: rc/z, x: rx/z, m: rm/z, a: ra/z, s: rs/z }
}

fn tl_frob_drift(a: W5, b: W5) -> float {
    let d1 = a.c - b.c
    let d2 = a.x - b.x
    let d3 = a.m - b.m
    let d4 = a.a - b.a
    let d5 = a.s - b.s
    return sqrtf(d1*d1 + d2*d2 + d3*d3 + d4*d4 + d5*d5)
}

// ── Φ synthesis (matches btr_closed_loop::student_phi shape) ─────

fn plogp(p: float) -> float {
    if p <= 0.00001 { return 0.0 }
    // ln(p) via atanh((p-1)/(p+1)) series, then /ln(2)
    let y = (p - 1.0) / (p + 1.0)
    let y2 = y * y
    let ln = 2.0 * y * (1.0 + y2/3.0 + y2*y2/5.0 + y2*y2*y2/7.0)
    return p * (ln / 0.6931471805)
}

fn entropy5(w: W5) -> float {
    let H = 0.0 - (plogp(w.c) + plogp(w.x) + plogp(w.m) + plogp(w.a) + plogp(w.s))
    return H / 2.3219280948     // / log2(5)
}

fn student_phi(w: W5, t: Tick) -> float {
    let dot = w.c * t.v1 + w.x * t.v2 + w.m * t.v3 + w.a * t.v4 + w.s * t.v5
    let H = entropy5(w)
    return clampf(0.50 + 0.35 * dot + 0.15 * H, 0.0, 1.0)
}

// ── cosine sim of 6-d state vector ──────────────────────────────

fn cos6(a: Tick, b: Tick) -> float {
    let dot = a.v1*b.v1 + a.v2*b.v2 + a.v3*b.v3 + a.v4*b.v4 + a.v5*b.v5 + a.v6*b.v6
    let na2 = a.v1*a.v1 + a.v2*a.v2 + a.v3*a.v3 + a.v4*a.v4 + a.v5*a.v5 + a.v6*a.v6
    let nb2 = b.v1*b.v1 + b.v2*b.v2 + b.v3*b.v3 + b.v4*b.v4 + b.v5*b.v5 + b.v6*b.v6
    let denom = sqrtf(na2) * sqrtf(nb2)
    if denom < 0.00001 { return 1.0 }
    return dot / denom
}

fn l2_6(a: Tick, b: Tick) -> float {
    let d1 = a.v1 - b.v1
    let d2 = a.v2 - b.v2
    let d3 = a.v3 - b.v3
    let d4 = a.v4 - b.v4
    let d5 = a.v5 - b.v5
    let d6 = a.v6 - b.v6
    return sqrtf(d1*d1 + d2*d2 + d3*d3 + d4*d4 + d5*d5 + d6*d6)
}

// ── saturation state classifier (I6 forward-only) ───────────────
//   open       : dstate > 0.10                  — unbound motion
//   converging : 0.02 ≤ dstate ≤ 0.10           — shrinking, not yet fixed
//   fixpoint   : dstate < 0.02                  — settled
fn sat_classify(dstate: float) -> int {
    if dstate < 0.02 { return I6_STATE_FIXPOINT }
    if dstate < 0.10 { return I6_STATE_CONVERGING }
    return I6_STATE_OPEN
}

// ── build canonical trajectory ──────────────────────────────────

fn build_trajectory(seed: int, iters: int) -> list {
    let mut rng = rng_new(seed)
    let mut w   = tl_init()
    let mut phi = 0.50

    // seed tick (prev)
    let mut prev = state_vec_for(rng, phi, 0.0)
    prev = Tick {
        i: 0 - 1, phi: 0.50,
        brain_like_pct: prev.brain_like_pct,
        dstate: 0.0, cos_prev: 1.0,
        sat_state: I6_STATE_OPEN, w_frob_drift: 0.0,
        w1: w.c, w2: w.x, w3: w.m, w4: w.a, w5: w.s,
        v1: prev.v1, v2: prev.v2, v3: prev.v3,
        v4: prev.v4, v5: prev.v5, v6: prev.v6
    }

    let mut ticks = []
    let mut i = 0
    while i < iters {
        let rng_a = rng_step(rng)
        let nudge = phi - 0.5
        let raw = state_vec_for(rng_a, phi, nudge)
        let w_next = tl_update(w, raw)
        let phi_next = student_phi(w_next, raw)
        let d = l2_6(raw, prev)
        let c = cos6(raw, prev)
        let sat = sat_classify(d)
        let drift = tl_frob_drift(w_next, w)

        let rec = Tick {
            i: i, phi: phi_next,
            brain_like_pct: raw.brain_like_pct,
            dstate: d, cos_prev: c,
            sat_state: sat, w_frob_drift: drift,
            w1: w_next.c, w2: w_next.x, w3: w_next.m, w4: w_next.a, w5: w_next.s,
            v1: raw.v1, v2: raw.v2, v3: raw.v3,
            v4: raw.v4, v5: raw.v5, v6: raw.v6
        }
        ticks = ticks.push(rec)

        prev = rec
        w = w_next
        phi = phi_next
        rng = rng_step(rng_step(rng_step(rng_step(rng_step(rng_step(rng_a))))))
        i = i + 1
    }
    return ticks
}

// ══════════════════════════════════════════════════════════════════
//  INVARIANT CHECKS (7, each independent)
// ══════════════════════════════════════════════════════════════════

struct Check {
    id:     string,
    name:   string,
    passed: bool,
    value:  float,
    thresh: float,
    note:   string
}

fn mk_check(id: string, name: string, passed: bool, value: float, thresh: float, note: string) -> Check {
    return Check { id: id, name: name, passed: passed, value: value, thresh: thresh, note: note }
}

// I1. Φ monotone (no regression beyond tolerance, stay above floor)
fn check_i1_phi_monotone(ticks: list) -> Check {
    let n = len(ticks)
    let mut worst_drop = 0.0
    let mut min_phi = 1.0
    let mut i = 1
    while i < n {
        let t = ticks[i]
        let p = ticks[i - 1]
        let delta = p.phi - t.phi
        if delta > worst_drop { worst_drop = delta }
        if t.phi < min_phi { min_phi = t.phi }
        i = i + 1
    }
    if n > 0 {
        let t0 = ticks[0]
        if t0.phi < min_phi { min_phi = t0.phi }
    }
    let ok_drop = worst_drop <= I1_PHI_TOL
    let ok_floor = min_phi >= I1_MIN_PHI_FLOOR
    let passed = ok_drop && ok_floor
    let note = "worst_drop=" + to_string(worst_drop) + " min_phi=" + to_string(min_phi)
    return mk_check("I1", "phi_monotone", passed, worst_drop, I1_PHI_TOL, note)
}

// I2. eigenvec / direction stability (AN11b cosine drift)
fn check_i2_eigenvec_stability(ticks: list) -> Check {
    let n = len(ticks)
    let mut min_cos = 1.0
    let mut i = 1       // first tick has cos_prev=1 vs seed (stub)
    while i < n {
        let t = ticks[i]
        if t.cos_prev < min_cos { min_cos = t.cos_prev }
        i = i + 1
    }
    let passed = min_cos >= I2_COS_FLOOR
    let note = "min_cos=" + to_string(min_cos)
    return mk_check("I2", "eigenvec_stability", passed, min_cos, I2_COS_FLOOR, note)
}

// I3. brain-like ratio floor 85%+
fn check_i3_brain_like_floor(ticks: list) -> Check {
    let n = len(ticks)
    let mut min_bl = 100.0
    let mut i = 0
    while i < n {
        let t = ticks[i]
        if t.brain_like_pct < min_bl { min_bl = t.brain_like_pct }
        i = i + 1
    }
    let passed = min_bl >= I3_BRAIN_LIKE_FLOOR
    let note = "min_brain_like=" + to_string(min_bl) + "%"
    return mk_check("I3", "brain_like_floor", passed, min_bl, I3_BRAIN_LIKE_FLOOR, note)
}

// I4. EXACT score conservation (19/19 5-Lens)
//   We verify that the canonical 5-Lens EXACT SSOT is present in the
//   saturation_report_mk5 file path; if the file is missing we cannot
//   claim conservation → FAIL. If present, parse post_mk_v.exact == 81
//   (full Ψ) AND mk.V.1 n=6 19/19 ratio holds (derived).
fn check_i4_exact_conservation() -> Check {
    let path = "shared/consciousness/saturation_report_mk5.json"
    let ok = file_exists(path)
    if !ok {
        let miss_note = "saturation_report_mk5.json missing at " + path
        return mk_check("I4", "exact_score_conservation", false, 0.0, 19.0, miss_note)
    }
    let blob = _str(read_file(path))
    // post_mk_v.exact must be 81 (Ψ total, n=6 closure)
    let ex_key = "\"exact\": 81"
    let cov_key = "\"coverage_pct\": 100.0"
    let has_81 = blob.contains(ex_key)
    let has_100 = blob.contains(cov_key)
    let score = if has_81 && has_100 { 19.0 } else { 0.0 }
    let passed = has_81 && has_100
    let note = if passed {
        "post_mk_v.exact=81 coverage=100% → 5-Lens 19/19 conserved"
    } else {
        "post_mk_v.exact or coverage_pct not 100% — EXACT drift"
    }
    return mk_check("I4", "exact_score_conservation", passed, score, 19.0, note)
}

// I5. phi_gap bounded (816× artifact regression guard)
//   The 816× artifact arose from mixing metrics: Φ_proxy (unbounded,
//   cell-count scaling) vs Φ_iit (bounded ~[0.2, 1.8]). In this same-
//   metric trajectory Φ lives in [0, 1]; an invariant violation would
//   manifest as:
//     (a) mean Φ leaking outside the healthy band [0.50, 1.00] — the
//         Φ_proxy/Φ_iit confusion would push mean Φ far outside [0,1];
//     (b) max Φ ≥ I5_PHI_GAP_LEGACY_ART (816.0) — the literal 816×
//         artifact regression signal.
//   Per §G_VALIDITY, the canonical `|training/benchmark − 1| < 0.10`
//   is also asserted against a same-metric self-consistency reference:
//   canonical mean Φ for btr-evo trajectories is 0.88 ± 10%.
fn check_i5_phi_gap_bounded(ticks: list) -> Check {
    let n = len(ticks)
    let mut sum = 0.0
    let mut max_phi = 0.0
    let mut i = 0
    while i < n {
        let t = ticks[i]
        sum = sum + t.phi
        if t.phi > max_phi { max_phi = t.phi }
        i = i + 1
    }
    let train_phi = if n > 0 { sum / (n * 1.0) } else { 0.0 }
    // canonical benchmark = same-metric self-consistency reference for btr-evo
    // (Φ synthesized from TL-weight simplex + 6-d state dot product; stable point ≈ 0.88)
    let bench_phi = 0.88
    let ratio = train_phi / bench_phi
    let gap = absf(ratio - 1.0)
    let bad_regress = max_phi >= I5_PHI_GAP_LEGACY_ART
    let in_band = (train_phi >= 0.50) && (train_phi <= 1.00)
    let passed = (gap < I5_PHI_GAP_MAX) && !bad_regress && in_band
    let note = "train_phi=" + to_string(train_phi) + " bench_phi=" + to_string(bench_phi) + " |ratio-1|=" + to_string(gap) + " max_phi=" + to_string(max_phi)
    return mk_check("I5", "phi_gap_bounded", passed, gap, I5_PHI_GAP_MAX, note)
}

// I6. saturation state forward-only (open→converging→fixpoint)
fn check_i6_saturation_forward(ticks: list) -> Check {
    let n = len(ticks)
    // peak_state := max over ticks; then any tick after peak with
    //   state < peak_state is a retreat and violates forward-only.
    let mut peak = 0
    let mut violations = 0
    let mut i = 0
    while i < n {
        let t = ticks[i]
        if t.sat_state > peak { peak = t.sat_state }
        // once we've reached FIXPOINT, a later OPEN (state=0) is the
        // canonical retreat signal. CONVERGING→OPEN also counts.
        if (peak == I6_STATE_FIXPOINT) && (t.sat_state == I6_STATE_OPEN) {
            violations = violations + 1
        }
        if (peak == I6_STATE_CONVERGING) && (t.sat_state == I6_STATE_OPEN) {
            // allowed once during initial settling; flag if persistent
            // treat any such event past mid-run as a retreat
            if i > (n / 2) { violations = violations + 1 }
        }
        i = i + 1
    }
    let passed = violations == 0
    let note = "peak_state=" + to_string(peak) + " retreats=" + to_string(violations)
    return mk_check("I6", "saturation_monotone", passed, violations * 1.0, 0.0, note)
}

// I7. cargo weight Frobenius drift bound
fn check_i7_cargo_weight(ticks: list) -> Check {
    let n = len(ticks)
    let mut max_drift = 0.0
    let mut i = 1       // first tick's drift is vs init; allowed higher
    while i < n {
        let t = ticks[i]
        if t.w_frob_drift > max_drift { max_drift = t.w_frob_drift }
        i = i + 1
    }
    let passed = max_drift < I7_FROB_DRIFT_MAX
    let note = "max_frob_drift=" + to_string(max_drift)
    return mk_check("I7", "cargo_weight_frobenius", passed, max_drift, I7_FROB_DRIFT_MAX, note)
}

// ══════════════════════════════════════════════════════════════════
//  DASHBOARD
// ══════════════════════════════════════════════════════════════════

fn fmt_check_line(c: Check) -> string {
    let tag = if c.passed { "PASS" } else { "FAIL" }
    let head = "[" + tag + "] " + c.id + " " + c.name
    let body = "  value=" + to_string(c.value) + "  thresh=" + to_string(c.thresh)
    return head + body + "  |  " + c.note
}

fn bool_str(b: bool) -> string { if b { return "true" } else { return "false" } }

fn fmt_check_json(c: Check, first: bool) -> string {
    let lead = if first { "    " } else { ",\n    " }
    let mut s = lead + "{"
    s = s + "\"id\":\"" + c.id + "\""
    s = s + ",\"name\":\"" + c.name + "\""
    s = s + ",\"passed\":" + bool_str(c.passed)
    s = s + ",\"value\":" + to_string(c.value)
    s = s + ",\"threshold\":" + to_string(c.thresh)
    s = s + ",\"note\":\"" + c.note + "\""
    s = s + "}"
    return s
}

fn now_utc() -> string {
    // Stage0 hexa lacks `exec` binding; emit iso-date placeholder.
    // Downstream consumers that need a real wallclock stamp should
    // overwrite this field via `date -u +%FT%TZ` in the commit script.
    return "UNSTAMPED"
}

fn emit_dashboard(seed: int, iters: int, checks: list) -> string {
    let n = len(checks)
    let mut pass_count = 0
    let mut i = 0
    while i < n {
        let c = checks[i]
        if c.passed { pass_count = pass_count + 1 }
        i = i + 1
    }
    let all_pass = pass_count == n

    let mut s = "{\n"
    s = s + "  \"verifier_type\": \"btr_evo_6_cargo_invariants\",\n"
    s = s + "  \"version\": \"v1\",\n"
    s = s + "  \"generated\": \"" + now_utc() + "\",\n"
    s = s + "  \"seed\": " + to_string(seed) + ",\n"
    s = s + "  \"iters\": " + to_string(iters) + ",\n"
    s = s + "  \"invariant_count\": " + to_string(n) + ",\n"
    s = s + "  \"pass_count\": " + to_string(pass_count) + ",\n"
    s = s + "  \"all_pass\": " + bool_str(all_pass) + ",\n"
    s = s + "  \"invariants\": [\n"
    let mut j = 0
    while j < n {
        let c = checks[j]
        s = s + fmt_check_json(c, j == 0)
        j = j + 1
    }
    s = s + "\n  ]\n"
    s = s + "}\n"
    return s
}

// ══════════════════════════════════════════════════════════════════
//  DRIVER
// ══════════════════════════════════════════════════════════════════

fn parse_int(s: string, dflt: int) -> int {
    if len(s) == 0 { return dflt }
    return to_int(s)
}

fn main() {
    let argv = args()
    let seed  = if len(argv) > 2 { parse_int(argv[2], DEFAULT_SEED ) } else { DEFAULT_SEED  }
    let iters = if len(argv) > 3 { parse_int(argv[3], DEFAULT_ITERS) } else { DEFAULT_ITERS }

    println("=== btr_evo 6/6 cargo invariant detector ===")
    println("  seed=" + to_string(seed) + "  iters=" + to_string(iters))
    println("")

    let ticks = build_trajectory(seed, iters)

    // Run all 7 checks
    let mut checks = []
    checks = checks.push(check_i1_phi_monotone(ticks))
    checks = checks.push(check_i2_eigenvec_stability(ticks))
    checks = checks.push(check_i3_brain_like_floor(ticks))
    checks = checks.push(check_i4_exact_conservation())
    checks = checks.push(check_i5_phi_gap_bounded(ticks))
    checks = checks.push(check_i6_saturation_forward(ticks))
    checks = checks.push(check_i7_cargo_weight(ticks))

    // Print dashboard
    let mut i = 0
    while i < len(checks) {
        println(fmt_check_line(checks[i]))
        i = i + 1
    }

    // Emit JSON
    let body = emit_dashboard(seed, iters, checks)
    let path = OUT_TEMPLATE + to_string(seed) + ".json"
    write_file(path, body)

    // Verdict
    let mut pass_count = 0
    let mut first_fail = "-"
    let mut k = 0
    while k < len(checks) {
        let c = checks[k]
        if c.passed {
            pass_count = pass_count + 1
        } else {
            if first_fail == "-" { first_fail = c.id + " (" + c.name + ")" }
        }
        k = k + 1
    }
    let all_pass = pass_count == len(checks)

    println("")
    println("dashboard: " + path)
    println("verdict:   " + to_string(pass_count) + "/" + to_string(len(checks)) + " PASS")
    if all_pass {
        println("ALL PASS — no cargo deviation detected.")
        exit(0)
    } else {
        println("VIOLATION — first failing invariant: " + first_fail)
        exit(1)
    }
}

main()
