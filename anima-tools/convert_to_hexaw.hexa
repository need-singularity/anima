// anima-tools/convert_to_hexaw.hexa — Convert PyTorch .pt weights to HEXAW binary format
// Source: anima-tools/convert_to_hexaw.py (149 LOC)
//
// HEXAW format (matches load_weights_bin / mmap_weights in hexa-lang):
//   Header:  b"HEXAW\0" (6B) + version:u32 LE (4B) + n_tensors:u32 LE (4B)
//   Per tensor:
//     name_len:u32 LE + name:bytes
//     ndim:u32 LE + shape:u32 LE * ndim
//     data:f32 LE * product(shape)
//
// CLI:
//   hexa convert_to_hexaw.hexa best.pt weights_v14.hexaw
//   hexa convert_to_hexaw.hexa best.pt weights_v14.hexaw --key model
//   hexa convert_to_hexaw.hexa weights_dir/ weights_v14.hexaw --json
//   hexa convert_to_hexaw.hexa best.pt weights_v14.hexaw --all-dims

comptime const HEXAW_MAGIC   = "HEXAW"
comptime const HEXAW_VERSION = 1

// ═══════════════════════════════════════════════════════════
// HEXAW Writer
// ═══════════════════════════════════════════════════════════

struct TensorEntry {
    name: string,
    ndim: int,
    shape: string,      // serialized int array
    n_params: int
}

fn write_hexaw(tensors: string, out_path: string) {
    // TODO[hexa-stdlib]: Binary file writing
    // 1. Write header: HEXAW\0 + version(u32 LE) + n_tensors(u32 LE)
    // 2. Per tensor:
    //    name_len(u32 LE) + name(bytes)
    //    ndim(u32 LE) + shape(u32 LE * ndim)
    //    data(f32 LE * product(shape))
    // 3. Print summary: n tensors, total params, file size
    print("Writing HEXAW: " + out_path)
}

// ═══════════════════════════════════════════════════════════
// PyTorch Loader
// ═══════════════════════════════════════════════════════════

fn load_from_pt(pt_path: string, key: string, max_dim: int) -> string {
    // TODO[pytorch]: torch.load(pt_path, map_location="cpu")
    // Find state dict:
    //   1. If key provided, use ckpt[key]
    //   2. Try common keys: "decoder", "model", "state_dict", "model_state_dict"
    //   3. Fallback: treat ckpt as state dict
    // For each tensor in state dict:
    //   Skip if dim > max_dim (default: 2)
    //   Flatten to f32 list
    // Returns serialized list of TensorEntry
    print("Loading from PyTorch: " + pt_path)
    "[]"
}

// ═══════════════════════════════════════════════════════════
// JSON Loader
// ═══════════════════════════════════════════════════════════

fn load_from_json(dir_path: string) -> string {
    // TODO[hexa-stdlib]: Read _manifest.json, then each weight file
    // For each entry in manifest:
    //   Read JSON data file (flat f32 array)
    //   Create TensorEntry with name, shape, data
    // Returns serialized list of TensorEntry
    print("Loading from JSON: " + dir_path)
    "[]"
}

// ═══════════════════════════════════════════════════════════
// CLI
// ═══════════════════════════════════════════════════════════

fn main() {
    // TODO[hexa-stdlib]: argparse for input, output, --key, --json, --all-dims
    // Default: max_dim=2 (skip tensors with dim > 2)
    // If --all-dims: max_dim=0 (include all)
    // If --json: use load_from_json instead of load_from_pt
    let input_path = "best.pt"
    let output_path = "weights.hexaw"
    let use_json = false
    let max_dim = 2

    print("Converting " + input_path + " -> " + output_path)

    let tensors = if use_json {
        load_from_json(input_path)
    } else {
        load_from_pt(input_path, "", max_dim)
    }

    write_hexaw(tensors, output_path)
    print("Done.")
}
