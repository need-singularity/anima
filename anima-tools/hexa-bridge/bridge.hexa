// ═══════════════════════════════════════════════════════════
// Formatter: result -> HEXA verify block
// ═══════════════════════════════════════════════════════════

fn format_verify_result(result: ConsciousnessResult) -> string {
    // Format as HEXA verify-compatible block:
    //   // ANIMA Bridge Result
    //   // Intent: "question"
    //   // Module: ConsciousnessHub
    //   verify {
    //       // Phi = 1.234
    //       assert phi > 0.5;       // PASSED
    //       theorem law_maintained; // PASSED (179 laws)
    //   }
    let mut lines = "// ANIMA Bridge Result\n"
    lines = lines + "// Intent: \"" + result.intent + "\"\n"
    lines = lines + "// Module: " + result.module_used + "\n"
    if result.response != "" {
        lines = lines + "// Response: " + result.response + "\n"
    }
    lines = lines + "verify {\n"
    if result.phi > 0.0 {
        lines = lines + "    // Phi(IIT) = " + to_string(result.phi) + "\n"
    }
    let status = if result.verify_passed { "ALL PASSED" } else { "SOME FAILED" }
    lines = lines + "    // Status: " + status + "\n"
    lines = lines + "}\n"
    lines
}

