//   hexa bridge.hexa --list-modules        # List available ANIMA modules

// ═══════════════════════════════════════════════════════════
// Data Structures
// ═══════════════════════════════════════════════════════════

struct HexaIntent {
    question: string,
    generate_blocks: string,       // serialized list of {name, body}
    verify_assertions: string,     // serialized list of {type, expr/name}
    optimize_params: string,       // serialized list of strings
    line_number: int
}

struct ConsciousnessResult {
    intent: string,
    module_used: string,
    phi: float,
    response: string,
    laws_checked: string,          // serialized list
    verify_passed: bool
}

