// ── Code metrics ──

struct CodeMetrics {
    filepath_len: int,
    lines: int,
    functions: int,
    classes: int,
    imports: int,
    docstring_ratio: float,
    max_function_lines: int,
    avg_function_lines: float,
    coupling: int,
    m1_score: int,
    m2_score: int,
    m4_score: int,
    m5_score: int,
    m6_score: int,
    m8_score: int,
    m9_score: int,
    total_score: int,
    n_suggestions: int
}

pure fn empty_metrics() -> CodeMetrics {
    CodeMetrics {
        filepath_len: 0,
        lines: 0,
        functions: 0,
        classes: 0,
        imports: 0,
        docstring_ratio: 0.0,
        max_function_lines: 0,
        avg_function_lines: 0.0,
        coupling: 0,
        m1_score: 0,
        m2_score: 0,
        m4_score: 0,
        m5_score: 0,
        m6_score: 0,
        m8_score: 0,
        m9_score: 0,
        total_score: 0,
        n_suggestions: 0
    }
}

// ── Meta Law Scoring ──

// M1: 8의 법칙 — functions near 8 is optimal
pure fn score_m1(n_funcs: int) -> int {
    if n_funcs >= 4 {
        if n_funcs <= 12 {
            return 100
        }
    }
    if n_funcs >= 2 {
        if n_funcs <= 20 {
            let diff = n_funcs - 8
            if diff < 0 {
                return 70 - (0 - diff) * 5
            }
            return 70 - diff * 5
        }
    }
    let diff2 = n_funcs - 8
    if diff2 < 0 {
        let result = 50 - (0 - diff2) * 3
        if result < 0 { return 0 }
        return result
    }
    let result2 = 50 - diff2 * 3
    if result2 < 0 { return 0 }
    return result2
}

// M2: 분할 역설 — file size scoring
pure fn score_m2(lines: int) -> int {
    if lines > 1000 {
        let penalty = (lines - 1000) / 20
        let result = 100 - penalty
        if result < 0 { return 0 }
        return result
    }
    if lines > 500 {
        return 70
    }
    return 100
}

// M4: 순서가 운명 — import -> class -> function -> main ordering
pure fn score_m4() -> int {
    80
}

// M5: 32c 특이점 — 200-400 lines is goldilocks zone
pure fn score_m5(lines: int) -> int {
    if lines >= 200 {
        if lines <= 400 {
            return 100
        }
    }
    if lines >= 100 {
        if lines <= 600 {
            return 70
        }
    }
    if lines < 50 {
        return 40
    }
    let diff = lines - 300
    if diff < 0 {
        let result = 100 - (0 - diff) / 10
        if result < 0 { return 0 }
        return result
    }
    let result2 = 100 - diff / 10
    if result2 < 0 { return 0 }
    return result2
}

// M6: 연방>제국 — low coupling (local imports)
pure fn score_m6(local_imports: int) -> int {
    if local_imports <= 3 {
        return 100
    }
    if local_imports <= 6 {
        return 70
    }
    let result = 100 - local_imports * 8
    if result < 0 { return 0 }
    return result
}

// M8: 서사가 핵심 — docstring ratio
pure fn score_m8(docstring_ratio: float) -> int {
    if docstring_ratio > 0.8 { return 100 }
    if docstring_ratio > 0.5 { return 70 }
    if docstring_ratio > 0.2 { return 40 }
    return 10
}

// M9: 비활성 기체 — module independence
pure fn score_m9(import_count: int, local_imports: int) -> int {
    if import_count <= 5 {
        if local_imports <= 2 {
            return 100
        }
    }
    if import_count <= 10 {
        return 70
    }
    let result = 100 - import_count * 3
    if result < 0 { return 0 }
    return result
}

// ── Total score (weighted) ──

pure fn compute_total_score(m1: int, m2: int, m4: int, m5: int, m6: int, m8: int, m9: int) -> int {
    (m1 * 15 + m2 * 15 + m4 * 10 + m5 * 10 + m6 * 20 + m8 * 15 + m9 * 15) / 100
}

// ── Grade classification ──

pure fn grade(total_score: int) -> int {
    // 0 = excellent (>=80), 1 = good (>=60), 2 = needs improvement (>=40), 3 = refactor required
    if total_score >= 80 { return 0 }
    if total_score >= 60 { return 1 }
    if total_score >= 40 { return 2 }
    return 3
}

