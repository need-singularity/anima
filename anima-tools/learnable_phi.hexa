// learnable_phi.hexa — Learnable Phi Predictor stub
// Neural network that learns to predict IIT Phi from cell states (DeepSets)
// Original: learnable_phi.py (740 LOC)

fn psi_f_critical() -> float {
    0.10
}

// ── Model architecture (DeepSets) ──

struct CellEncoderConfig {
    hidden_dim: int,
    embed_dim: int
}

pure fn default_encoder_config() -> CellEncoderConfig {
    CellEncoderConfig { hidden_dim: 128, embed_dim: 64 }
}

struct LearnablePhiConfig {
    hidden_dim: int,
    embed_dim: int
}

pure fn default_model_config() -> LearnablePhiConfig {
    LearnablePhiConfig { hidden_dim: 128, embed_dim: 64 }
}

// CellEncoder: per-cell MLP (hidden_dim -> 128 -> 128 -> embed_dim)
// With LayerNorm + GELU activations
// TODO[pytorch]: nn.Sequential(Linear, LayerNorm, GELU, Linear, LayerNorm, GELU, Linear)
fn cell_encoder_forward(n_cells: int, hidden_dim: int, embed_dim: int) -> int {
    // Returns n_cells (each cell gets embedded)
    n_cells
}

// PairEncoder: captures inter-cell relationships
// TODO[pytorch]: nn.Sequential(Linear(embed_dim*2, 64), GELU, Linear(64, 32))
fn pair_encoder_forward(n_pairs: int) -> int {
    n_pairs
}

// Predictor input size: embed_dim*3 + 32*3 + 4 (scale features)
pure fn predictor_input_size(embed_dim: int) -> int {
    embed_dim * 3 + 32 * 3 + 4
}

// Full forward pass:
// 1. Encode each cell -> cell_embs [B, N, embed_dim]
// 2. Set pooling: sum + mean + max (permutation-invariant)
// 3. Pairwise interaction features (sampled for efficiency)
// 4. Scale features: log(n), n/32, (n/32)^2, 1/n
// 5. Predictor MLP -> Softplus -> scalar Phi (non-negative)
// TODO[pytorch]: Full forward pass implementation
fn learnable_phi_forward(batch_size: int, max_cells: int, hidden_dim: int) -> int {
    // Returns batch_size (one Phi prediction per batch element)
    batch_size
}

// Compute pairwise interaction features (sampled for large N)
// For N<=8: all pairs. For N>8: random sample up to K=32 pairs
pure fn max_pairs(n_cells: int) -> int {
    let all_pairs = n_cells * (n_cells - 1) / 2
    if all_pairs < 32 { return all_pairs }
    return 32
}

// Predict Phi from MitosisEngine (convenience method)
// TODO[pytorch]: extract states, unsqueeze, forward, .item()
fn predict_from_engine(n_cells: int) -> float {
    0.0
}

// ── Data generation ──

struct DataGenConfig {
    n_samples: int,
    min_cells: int,
    max_cells: int,
    hidden_dim: int,
    n_warmup_steps: int,
    seed: int,
    extra_large: int,
    extra_large_max: int
}

pure fn default_datagen_config() -> DataGenConfig {
    DataGenConfig {
        n_samples: 1000,
        min_cells: 4,
        max_cells: 64,
        hidden_dim: 128,
        n_warmup_steps: 10,
        seed: 42,
        extra_large: 50,
        extra_large_max: 128
    }
}

// TODO[pytorch]: Generate training data by computing exact Phi on engines
// Create MitosisEngine with varying cell counts, warm up, compute exact Phi
fn generate_training_data(cfg: DataGenConfig) -> int {
    // Returns total samples generated
    cfg.n_samples + cfg.extra_large
}

// TODO[pytorch]: Collate variable-length cell states into padded batch
// Returns (padded_states, masks, phi_targets)
fn collate_batch(batch_size: int, max_cells: int) -> int {
    batch_size
}

// ── Training ──

struct TrainConfig {
    epochs: int,
    batch_size: int,
    lr: float,
    val_split: float,
    save_path_len: int
}

pure fn default_train_config() -> TrainConfig {
    TrainConfig {
        epochs: 150,
        batch_size: 32,
        lr: 0.001,
        val_split: 0.1,
        save_path_len: 16
    }
}

struct TrainHistory {
    best_val_loss: float,
    best_val_r2: float,
    best_epoch: int,
    n_params: int
}

// TODO[pytorch]: Train LearnablePhi on generated data
// AdamW + CosineAnnealingLR, MSE loss, gradient clipping 1.0
fn train_learnable_phi(n_samples: int, train_cfg: TrainConfig) -> TrainHistory {
    TrainHistory {
        best_val_loss: 0.0,
        best_val_r2: 0.0,
        best_epoch: 0,
        n_params: 0
    }
}

