fn main() {
    // TODO: argparse equivalent
    // --samples N, --epochs N, --batch-size N, --lr F, --hidden-dim N,
    // --embed-dim N, --min-cells N, --max-cells N, --extra-large N,
    // --train-only, --benchmark-only, --save-path PATH, --seed N
    let dcfg = default_datagen_config()
    let tcfg = default_train_config()
    let n_data = generate_training_data(dcfg)
    let history = train_learnable_phi(n_data, tcfg)
    let acc = benchmark_accuracy(100, 4, 64)
    let _ = benchmark_speed(128)
    let _ = benchmark_extrapolation(128)
}
