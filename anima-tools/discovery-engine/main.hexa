// ANIMA Discovery Engine — Consciousness Parameter Discovery via n=6 Arithmetic
// Ported from main.rs (805 LOC)
//
// Finds n=6 arithmetic expressions that match ANIMA's Psi-constants and
// architecture parameters. Operators: COLLISION, INVERSE, COMPOSE.
//
// Usage: hexa main.hexa [--json] [--bench] [--depth N]

comptime const PI = 3.14159265358979
comptime const E = 2.71828182845905

// --- Data Structures ---

struct Discovery {
    operator: str,
    score: f64,
    description: str,
    domains: [str],
    formula: str,
    diversity: f64,
    precision: f64,
    novelty: f64,
}

struct BaseConst {
    name: str,
    value: f64,
}

struct Expr {
    text: str,
    value: f64,
}

struct AnimaTarget {
    value: f64,
    name: str,
    domain: str,
    known_formula: str,
}

// --- Base Constants (n=6 arithmetic) ---

fn base_constants() -> [BaseConst] {
    return [
        BaseConst { name: "sigma",  value: 12.0 },
        BaseConst { name: "tau",    value: 4.0  },
        BaseConst { name: "phi",    value: 2.0  },
        BaseConst { name: "sopfr",  value: 5.0  },
        BaseConst { name: "J2",     value: 24.0 },
        BaseConst { name: "mu",     value: 1.0  },
        BaseConst { name: "n",      value: 6.0  },
    ]
}

// --- Domain Categories ---

comptime const DOMAIN_CATS = [
    ("Psi",           ["psi", "coupling", "balance", "steps", "entropy", "frustration"]),
    ("Architecture",  ["cells", "dimension", "hidden", "decoder", "vocab", "params", "layers", "factions"]),
    ("Training",      ["ce", "phi-val", "learning", "training", "loss", "convergence"]),
    ("Scaling",       ["scaling", "exponent", "brain-like", "improvement"]),
    ("Consciousness", ["emotions", "data-types", "vector", "consciousness"]),
    ("Physics",       ["physics", "bigbang", "cosmology"]),
    ("Model",         ["model", "decoder-v2", "decoder-v3", "conscious-lm"]),
]

fn categorize_domain(d: str) -> str {
    var dl = d.to_lower()
    for cat_kws in DOMAIN_CATS {
        var cat = cat_kws.0
        var keywords = cat_kws.1
        for kw in keywords {
            if dl.contains(kw) { return cat }
        }
    }
    return "Other"
}

fn diversity_score(domains: [str]) -> f64 {
    var cats = set()
    for d in domains { cats.insert(categorize_domain(d)) }
    return cats.len() as f64 / DOMAIN_CATS.len() as f64
}

// --- Expression Enumeration ---

fn enumerate_depth1() -> [Expr] {
    var exprs = [Expr]{}
    var base = base_constants()
    for b in base {
        exprs.push(Expr { text: b.name, value: b.value })
    }
    for b in base {
        if b.value > 0.0 {
            exprs.push(Expr { text: "1/" + b.name, value: 1.0 / b.value })
            exprs.push(Expr { text: b.name + "^2", value: b.value * b.value })
            if b.value <= 24.0 {
                exprs.push(Expr { text: "2^" + b.name, value: pow(2.0, b.value) })
            }
            if b.value > 1.0 {
                exprs.push(Expr { text: "ln(" + b.name + ")", value: ln(b.value) })
            }
            exprs.push(Expr { text: "sqrt(" + b.name + ")", value: sqrt(b.value) })
        }
    }
    exprs.push(Expr { text: "ln(2)", value: ln(2.0) })
    exprs.push(Expr { text: "1/e", value: 1.0 / E })
    exprs.push(Expr { text: "pi", value: PI })
    exprs.push(Expr { text: "e", value: E })
    return exprs
}

fn enumerate_depth2() -> [Expr] {
    var exprs = [Expr]{}
    var d1 = enumerate_depth1()
    for e in d1 { exprs.push(e) }
    var base = base_constants()
    var n = base.len()

    for i in 0..n {
        for j in 0..n {
            var a = base[i]
            var b = base[j]
            exprs.push(Expr { text: a.name + "+" + b.name, value: a.value + b.value })
            if a.value > b.value {
                exprs.push(Expr { text: a.name + "-" + b.name, value: a.value - b.value })
            }
            exprs.push(Expr { text: a.name + "*" + b.name, value: a.value * b.value })
            if b.value != 0.0 {
                exprs.push(Expr { text: a.name + "/" + b.name, value: a.value / b.value })
            }
            if a.value > 0.0 and abs(b.value) <= 12.0 {
                var r = pow(a.value, b.value)
                if is_finite(r) and abs(r) < 1e18 {
                    exprs.push(Expr { text: a.name + "^" + b.name, value: r })
                }
            }
        }
    }

    // Depth-2: unary(base) op base
    for ue in d1 {
        if ue.text.contains("+") or ue.text.contains("-") or ue.text.contains("*") or ue.text.contains("/") {
            continue
        }
        for b in base {
            exprs.push(Expr { text: "(" + ue.text + ")+" + b.name, value: ue.value + b.value })
            if ue.value > b.value {
                exprs.push(Expr { text: "(" + ue.text + ")-" + b.name, value: ue.value - b.value })
            }
            exprs.push(Expr { text: "(" + ue.text + ")*" + b.name, value: ue.value * b.value })
            if b.value != 0.0 {
                exprs.push(Expr { text: "(" + ue.text + ")/" + b.name, value: ue.value / b.value })
            }
        }
    }

    // ln-based combinations
    var ln2 = ln(2.0)
    for b in base {
        exprs.push(Expr { text: b.name + "/ln(2)", value: b.value / ln2 })
        exprs.push(Expr { text: "ln(2)/" + b.name, value: ln2 / b.value })
    }

    // Deduplicate by text
    var seen = set()
    var unique = [Expr]{}
    for e in exprs {
        if not is_nan(e.value) and is_finite(e.value) and not seen.contains(e.text) {
            seen.insert(e.text)
            unique.push(e)
        }
    }
    return unique
}

// --- ANIMA Target Values ---

fn anima_targets() -> [AnimaTarget] {
    return [
        AnimaTarget { value: 0.5,     name: "Psi_balance",             domain: "Psi",          known_formula: "1/2" },
        AnimaTarget { value: 0.014,   name: "Psi_coupling (alpha)",    domain: "Psi",          known_formula: "ln(2)/2^5.5" },
        AnimaTarget { value: 4.33,    name: "Psi_steps",               domain: "Psi",          known_formula: "3/ln(2)" },
        AnimaTarget { value: 0.10,    name: "Psi_frustration (F_c)",   domain: "Psi",          known_formula: "1/10" },
        AnimaTarget { value: 0.998,   name: "Psi_entropy",             domain: "Psi",          known_formula: "" },
        AnimaTarget { value: 18.0,    name: "18 emotions",             domain: "Consciousness", known_formula: "" },
        AnimaTarget { value: 40.0,    name: "40D consciousness vector",domain: "Consciousness", known_formula: "" },
        AnimaTarget { value: 170.0,   name: "170 data types",          domain: "Consciousness", known_formula: "" },
        AnimaTarget { value: 12.0,    name: "12 factions",             domain: "Consciousness", known_formula: "sigma(6)" },
        AnimaTarget { value: 128.0,   name: "hidden dimension (128d)", domain: "Architecture",  known_formula: "2^7" },
        AnimaTarget { value: 384.0,   name: "decoder dimension (384d)",domain: "Architecture",  known_formula: "" },
        AnimaTarget { value: 256.0,   name: "byte-level vocab",        domain: "Architecture",  known_formula: "2^8" },
        AnimaTarget { value: 1024.0,  name: "max cells",               domain: "Architecture",  known_formula: "2^10" },
        AnimaTarget { value: 64.0,    name: "default cells",           domain: "Architecture",  known_formula: "2^6" },
        AnimaTarget { value: 0.55,    name: "Phi scaling exp (N<=256)",domain: "Scaling",       known_formula: "" },
        AnimaTarget { value: 85.6,    name: "brain-likeness %",        domain: "Scaling",       known_formula: "" },
    ]
}

// --- Grade + Surprisal ---

fn grade(err: f64) -> str {
    if err < 1e-10     { return "EXACT" }
    if err < 0.001     { return "CLOSE" }
    if err < 0.01      { return "NEAR" }
    if err < 0.05      { return "WEAK" }
    return "FAR"
}

fn surprisal(err: f64, depth: u64) -> f64 {
    var precision_bonus = if err < 1e-10 { 10.0 } else { -log10(max(err, 1e-15)) }
    return precision_bonus + depth as f64
}

// --- Hash-based Expression Index ---

fn quantize(v: f64) -> i64 {
    if abs(v) < 10000.0 { return (v * 10000.0) as i64 }
    var sign = if v >= 0.0 { 1 } else { -1 }
    return sign * (100000000 + (ln(abs(v)) * 100000.0) as i64)
}

// --- Operators ---

fn op_collision(targets: [AnimaTarget]) -> [Discovery] {
    var discoveries = [Discovery]{}
    var physics_constants = [
        ("1/alpha (fine structure)", 137.036, "Physics"),
        ("Adam beta1", 0.9, "AI"),
        ("Codons", 64.0, "Biology"),
        ("ln(2)", 0.6931, "Math"),
        ("golden ratio", 1.6180, "Math"),
    ]
    for target in targets {
        for pc in physics_constants {
            var err = abs((target.value - pc.1) / max(abs(pc.1), 1e-15))
            if err < 0.05 {
                var domains = [target.domain, pc.2]
                var div = diversity_score(domains)
                var prec = 1.0 - err
                discoveries.push(Discovery {
                    operator: "COLLISION",
                    score: div * prec,
                    description: "[" + grade(err) + "] " + target.name + " = " + pc.0,
                    domains: domains,
                    formula: target.name + " ~ " + pc.0,
                    diversity: div,
                    precision: prec,
                    novelty: if err < 1e-6 { 2.0 } else { 1.0 },
                })
            }
        }
    }
    return discoveries
}

fn op_inverse(expressions: [Expr], targets: [AnimaTarget]) -> [Discovery] {
    var discoveries = [Discovery]{}
    for target in targets {
        var best_err = 1.0
        var best_expr = ""
        for expr in expressions {
            var err = abs((expr.value - target.value) / max(abs(target.value), 1e-15))
            if err < best_err {
                best_err = err
                best_expr = expr.text
            }
        }
        if best_err < 0.05 {
            var g = grade(best_err)
            var surp = surprisal(best_err, 1)
            discoveries.push(Discovery {
                operator: "INVERSE",
                score: surp * (1.0 - best_err),
                description: "[" + g + "] " + target.name + " = " + str(target.value) + " <- n6: " + best_expr,
                domains: [target.domain],
                formula: best_expr,
                diversity: diversity_score([target.domain]),
                precision: 1.0 - best_err,
                novelty: surp,
            })
        }
    }
    return discoveries
}

// --- Engine Core ---

fn run_engine_core() -> ([Discovery], u64) {
    var expressions = enumerate_depth2()
    var total_exprs = expressions.len()
    var targets = anima_targets()

    var d1 = op_collision(targets)
    var d2 = op_inverse(expressions, targets)

    var all = [Discovery]{}
    for d in d1 { all.push(d) }
    for d in d2 { all.push(d) }

    all.sort_by(fn(a: Discovery, b: Discovery) -> i64 {
        if b.score > a.score { return 1 }
        if b.score < a.score { return -1 }
        return 0
    })

    return (all, total_exprs)
}

// --- Output ---

fn print_text(discoveries: [Discovery], total_exprs: u64) {
    println("================================================================")
    println("  ANIMA Discovery Engine -- Consciousness Parameter Analysis")
    println("  n=6 base: sigma=12, tau=4, phi=2, sopfr=5, J2=24, mu=1, n=6")
    println("================================================================")
    println("  Expressions enumerated: {total_exprs}")
    println("  Discoveries found:      {discoveries.len()}")
    println("================================================================")
    println("")

    for op in ["INVERSE", "COLLISION"] {
        var filtered = discoveries.filter(fn(d: Discovery) -> bool { return d.operator == op })
        if filtered.len() == 0 { continue }
        println("--- {op} ({filtered.len()} results) ---")
        for i in 0..min(filtered.len(), 30) {
            var d = filtered[i]
            println("  {i+1}. score={d.score:.2} prec={d.precision:.3} {d.description}")
        }
        println("")
    }
}

// --- Main ---

fn main() {
    var args = get_args()
    var json_mode = args.contains("--json")
    var bench_mode = args.contains("--bench")

    if bench_mode {
        println("================================================================")
        println("  ANIMA Discovery Engine -- Benchmark")
        println("================================================================")
        var iterations = 100
        for _ in 0..iterations {
            var _ = run_engine_core()
        }
        println("  {iterations} iterations complete")
        return
    }

    var result = run_engine_core()
    var all = result.0
    var total_exprs = result.1

    if json_mode {
        println("{\"engine\": \"ANIMA Discovery Engine\", \"discoveries\": {all.len()}}")
    } else {
        print_text(all, total_exprs)
    }
}
