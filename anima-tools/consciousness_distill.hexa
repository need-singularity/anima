// ── Core simulation ──

struct DistillConfig {
    teacher_cells: int,
    student_cells: int,
    steps: int,
    hidden_dim: int,
    seed: int
}

pure fn default_config() -> DistillConfig {
    DistillConfig {
        teacher_cells: 256,
        student_cells: 32,
        steps: 1000,
        hidden_dim: 128,
        seed: 42
    }
}

