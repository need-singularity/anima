// ── Main pipeline ──

fn distill(cfg: DistillConfig) -> DistillComparison {
    let teacher = run_consciousness(cfg.teacher_cells, cfg.hidden_dim, cfg.steps, cfg.seed)
    let student = run_consciousness(cfg.student_cells, cfg.hidden_dim, cfg.steps, cfg.seed)
    compare_trajectories(teacher, student)
}

// ── Conclusion logic ──

pure fn classify_preservation(preservation_mean: float) -> int {
    // 0 = EXCELLENT (>90%), 1 = GOOD (>70%), 2 = MODERATE (>50%), 3 = POOR
    if preservation_mean > 0.9 {
        return 0
    }
    if preservation_mean > 0.7 {
        return 1
    }
    if preservation_mean > 0.5 {
        return 2
    }
    return 3
}

pure fn classify_correlation(correlation: float) -> int {
    // 0 = close tracking (>0.8), 1 = moderate (>0.5), 2 = divergent
    if correlation > 0.8 {
        return 0
    }
    if correlation > 0.5 {
        return 1
    }
    return 2
}

fn main() {
    let cfg = default_config()
    let result = distill(cfg)
    // TODO: print formatted report
}
