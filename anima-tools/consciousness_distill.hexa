// ── Comparison metrics ──

struct DistillComparison {
    preservation_mean: float,
    preservation_final: float,
    correlation: float,
    mse: float,
    speed_ratio: float,
    compression: float
}

// TODO[numpy]: Pearson correlation, MSE between teacher/student Phi trajectories
