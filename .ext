# anima /.ext — external resource declarations
# SSOT — 이 프로젝트가 의존하는 모든 외부 자원 (SSH host, API endpoint, service, submodule, binary) 명시적 선언.
# 포맷 스펙: hexa-lang self/raw_loader.hexa (L0/.raw 와 동일 문법, id namespace 독립)
# 상속: hexa-lang/.raw raw#14 ext-ssot whitelist (kind ∈ {ssh, api, service, binary, submodule, pod})
#
# 포맷:
#   ext <id> <status> "<name>"
#     kind      <ssh|api|service|binary|submodule|pod>
#     <key>     <value...>
#
# status (5 잠금): live warn new deferred convention
#
# 필수 key (kind 별):
#   ssh       : addr use (why)
#   api       : endpoint auth use (rate-limit)
#   service   : url health use
#   binary    : path version use
#   submodule : path commit url
#   pod       : host image use
#
# 표준 key (공통): why proof note deprecated-at

ext 1 live "drill_breakthrough_criteria — nexus canonical"
  kind       submodule
  subkind    config_json
  canonical  $HOME/core/nexus/shared/bench/drill_breakthrough_criteria.json
  owner      nexus
  follower   anima
  purpose    H★ falsification + 5-lens DFS drill 기준 (T3→T4 85%→95%)
  use        tool/drill_breakthrough_runner.hexa — criteria load
  why        nexus 는 shared bench SSOT 의 owner. anima 는 follower, 중복 복사 금지 (raw#0).
  proof      test -f $HOME/core/nexus/shared/bench/drill_breakthrough_criteria.json
  alive      static

ext 2 live "drill_seed_set — nexus canonical"
  kind       submodule
  subkind    seed_jsonl
  canonical  $HOME/core/nexus/shared/bench/drill_seed_set.jsonl
  owner      nexus
  follower   anima
  purpose    drill 5-module lens seed set (pos/neg/closure/diagonal)
  use        tool/drill_breakthrough_runner.hexa — seeds load
  why        nexus shared bench SSOT. anima 는 follower.
  proof      test -f $HOME/core/nexus/shared/bench/drill_seed_set.jsonl
  alive      static
